theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  classical
  let sigma := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hfin : sigma.Finite :=
    Set.Finite.inter_of_left (Module.IsTorsion.finite_primeHeight_one_support hMT) _
  by_cases hsigma : sigma.Nonempty
  · let S := ⨅ p ∈ sigma, p.1.primeCompl
    have hS : S ≤ nonZeroDivisors A :=
      iInf_le_of_le hsigma.some <| iInf_le_of_le hsigma.some_mem hsigma.some.1.primeCompl_le_nonZeroDivisors
    obtain ⟨hdom, hpid⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma Set.inter_subset_right hsigma hfin
    let R' := Localization S
    let M' := LocalizedModule S M
    haveI : Module.Finite R' M' := Module.Finite_of_isLocalization S M _
    haveI : Module.IsTorsion R' M' := Module.IsTorsion_of_isLocalization S hMT
    obtain ⟨ι', fι', I, hI, ⟨e'⟩⟩ := Module.equiv_directSum_of_isTorsion R' M'
    let factors (i : ι') := UniqueFactorizationMonoid.normalizedFactors ((I i).generator)
    let primes (i : ι') := (factors i).toFinset
    let ι := Σ i, primes i
    let p_loc (k : ι) : PrimeSpectrum R' :=
      PrimeSpectrum.mk (Ideal.span {k.2.1}) (Ideal.isPrime_span_singleton_of_prime (UniqueFactorizationMonoid.prime_of_normalized_factor k.2.1 (Multiset.mem_toFinset.mp k.2.2)))
    let e (k : ι) : ℕ := (factors k.1).count k.2.1
    let p (k : ι) : PrimeSpectrum A := (p_loc k).comap (algebraMap A R')
    refine ⟨ι, inferInstance, p, ?_, e, ?_, ?_⟩
    · intro k
      have := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one R' sigma Set.inter_subset_right hsigma hfin
      have hmem : p k ∈ Set.range (PrimeSpectrum.comap (algebraMap A R')) := ⟨p_loc k, rfl⟩
      rw [this, Set.union_singleton, Set.mem_insert_iff] at hmem
      cases hmem with
      | inl hbot =>
         exfalso; apply IsPrime.ne_bot (p_loc k).2
         rw [← Ideal.span_singleton_eq_bot, hbot]; rfl
      | inr h => exact (Set.mem_setOf_eq _).mp h.2
    · intro k; exact Multiset.count_pos.mpr (Multiset.mem_toFinset.mp k.2.2)
    · let N := (k : ι) → A ⧸ (p k).1 ^ (e k)
      have hNT : Module.IsTorsion A N := by
        intro f
        rw [← Module.annihilator_ne_bot_iff]
        have : ⨅ i, (p i).1 ^ (e i) ≤ Module.annihilator A N := by
           intro x hx; ext k; rw [Pi.smul_apply, Submodule.quotient_mk_smul, (Ideal.mem_iInf.1 hx) k, Submodule.Quotient.mk_zero]
        refine Ideal.ne_bot_of_le_ne_bot ?_ this
        apply Ideal.IsPrime.ne_bot (Ideal.isPrime_of_primeHeight_eq_one ((p hsigma.some_mem).2))
        apply le_trans (iInf_le _ (⟨hsigma.some, (primes _).some_mem⟩ : ι))
        apply le_trans (Ideal.pow_le_self (e _))
        -- Proving intersection of powers of ht 1 primes is non-zero in Noetherian domain requires Krull/PID props.
        -- Assuming standard property for this level of structure theorem.
        exact sorry
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
      -- S^{-1}M ≅ ⊕ R'/I_i ≅ ⊕ Π R'/q^e ≅ ⊕ ⊕ R'/q^e (finite) ≅ S^{-1}N
      -- The decomposition into prime powers is standard for PIDs
      have iso : LocalizedModule S M ≃ₗ[R'] LocalizedModule S N := sorry
      exact ⟨iso.toLinearMap, iso.bijective⟩
  · refine ⟨Empty, inferInstance, Empty.elim, Empty.elim, Empty.elim, Empty.elim, ?_⟩
    rw [isPseudoIsomorphism_def]
    refine ⟨fun _ ↦ inferInstance, fun p hp ↦ ?_⟩
    rw [Set.mem_inter_iff] at hp
    have := hp.2; rw [← not_mem_subset Set.inter_subset_right hsigma] at this
    contradiction
