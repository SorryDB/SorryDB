  · refine ⟨PUnit, inferInstance, fun _ ↦ ⟨⊥, Ideal.bot_prime⟩, fun _ ↦ by contradiction, fun _ ↦ 1, fun _ ↦ zero_lt_one, ?_⟩
    apply (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (Module.isTorsion_of_isTorsion_on_range hMT) 0).mpr
    rw [Set.not_nonempty_iff_eq_empty, Set.Finite.toFinset_eq_empty] at h_empty
    rw [Set.union_empty, Set.inter_comm, Set.inter_assoc, h_empty, Set.inter_empty, iInf_neg, iInf_top]
    exact Function.Bijective.of_subsingleton _ (fun _ _ _ _ ↦ rfl)
  · let S := ⨅ p ∈ s, p.1.primeCompl
    obtain ⟨hDom, hPID⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s_set
