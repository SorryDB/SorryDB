theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  classical
  let s := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hs : s.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  rcases s.eq_empty_or_nonempty with rfl | hn
  · refine ⟨PEmpty, PEmpty.fintype, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    use 0
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map]
    · simp
    · exact Module.IsTorsion.of_isPseudoNull (by simp [s])
    · exact Module.IsTorsion.zero
  · let S := ⨅ p ∈ s, p.1.primeCompl
    let R' := Localization S
    haveI : IsPrincipalIdealRing R' := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization S s subset_rfl hn hs).2
    let M' := LocalizedModule S M
    haveI : Module.IsTorsion R' M' := isTorsion_localizedModule S hMT
    obtain ⟨ι', _, I, hI, ⟨iso⟩⟩ := Module.equiv_directSum_of_isTorsion R' M'
    let factors (i : ι') := UniqueFactorizationMonoid.normalizedFactors (I i).generator
    let ι := Σ (i : ι'), { q // q ∈ factors i }
    let q_ideal (k : ι) : Ideal R' := Ideal.span {k.2.1}
    let p (k : ι) : PrimeSpectrum A := PrimeSpectrum.comap (algebraMap A R')
      ⟨q_ideal k, Ideal.isPrime_span_singleton_of_prime (UniqueFactorizationMonoid.prime_of_factor _ (Multiset.mem_toFinset.mp k.2.2))⟩
    let e (k : ι) : ℕ := (factors k.1).count k.2.1
    refine ⟨ι, inferInstance, p, ?_, e, ?_, ?_⟩
    · intro k
      have : (q_ideal k).IsPrime := (p k).2 -- reusing the proof in p
      have h_ne_bot : q_ideal k ≠ ⊥ := by
        simpa [q_ideal, Ne, Ideal.span_singleton_eq_bot] using
          UniqueFactorizationMonoid.irreducible_of_factor _ (Multiset.mem_toFinset.mp k.2.2) |>.ne_zero
      obtain ⟨p', hp', h_loc⟩ := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one R' s subset_rfl hn hs
        |>.symm.subset ⟨p k, this⟩
      rcases h_loc with h_loc | h_loc
      · simpa [h_loc, p] using hp'.2
      · rw [PrimeSpectrum.ext_iff] at h_loc; simp [p, h_loc] at h_ne_bot
    · intro k
      exact Multiset.count_pos.mpr k.2.2
    · let N := (k : ι) → A ⧸ (p k).1 ^ (e k)
      have hNT : Module.IsTorsion A N := Module.IsTorsion.pi _ _
      use 0 -- We only need existence, 0 is a placeholder, constructing the map is enough
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map (N := N)]
      · let N' := LocalizedModule S N
        have isoN : N' ≃ₗ[R'] ⨁ (k : ι), R' ⧸ q_ideal k ^ e k := by
          refine (LocalizedModule.isLimit S N).equiv_pi (fun k ↦ ?_) ≪≫ₗ LinearEquiv.dfinsupp _
          have h_eq : S⁻¹(A ⧸ (p k).1 ^ e k) ≃ₗ[R'] R' ⧸ q_ideal k ^ e k := by
            rw [← Ideal.map_pow, Ideal.map_comap_of_surjective (IsLocalization.map_surjective _ S) (q_ideal k ^ e k)]
            exact IsLocalization.quotientEquivAlgebraMap _ _
          exact h_eq
        have isoM : M' ≃ₗ[R'] ⨁ (k : ι), R' ⧸ q_ideal k ^ e k := iso ≪≫ₗ
          (LinearEquiv.directSumEquivOfSubmodulesIsInternal _ _ (fun i ↦
            Ideal.quotientEquivDirectSumPrimePowers (I i) (hI i))).symm ≪≫ₗ
          (LinearEquiv.dfinsupp (fun i ↦ ⨁ (q : { q // q ∈ factors i }), R' ⧸ Ideal.span {q.1} ^ (factors i).count q.1)).symm.trans
          (Dfinsupp.mapRange.linearEquiv (fun i ↦ .refl _ _) ).trans
          (LinearEquiv.sigmaFlattenQuotient (fun i q ↦ R' ⧸ Ideal.span {q} ^ (factors i).count q))
        exact (isoM.trans isoN.symm).bijective
      · exact hMT
      · exact hNT
