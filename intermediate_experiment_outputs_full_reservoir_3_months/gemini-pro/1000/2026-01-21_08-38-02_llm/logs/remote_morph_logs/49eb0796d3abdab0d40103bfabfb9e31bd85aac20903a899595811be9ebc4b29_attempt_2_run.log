  have hfin : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  rcases σ.eq_empty_or_nonempty with rfl | ⟨p_some, hp_some⟩
  · exact ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim,
      (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (Module.isTorsion_of_subsingleton 0)
        (0 : M →ₗ[A] (PEmpty → A))).mpr ⟨fun x ↦ Subsingleton.elim _ _, fun x ↦ Subsingleton.elim _ _⟩⟩
