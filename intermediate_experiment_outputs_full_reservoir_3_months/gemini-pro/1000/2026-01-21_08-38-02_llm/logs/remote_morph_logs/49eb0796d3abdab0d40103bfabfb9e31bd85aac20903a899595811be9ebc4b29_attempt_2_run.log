    -- Each prime of S corresponds to p ∈ σ. So M_S ≅ ⊕ S⁻¹(A/p^k).
    -- This guarantees the existence of such N.
    obtain ⟨ι, fι, p, hp, e, he, ψ⟩ : ∃ ι (fι : Fintype ι) (p : ι → PrimeSpectrum A)
        (hp : ∀ i, (p i).asIdeal.primeHeight = 1) (e : ι → ℕ) (he : ∀ i, 0 < e i),
        Nonempty (LocalizedModule S_ideal M ≃ₗ[S] LocalizedModule S_ideal ((i : ι) → A ⧸ (p i).asIdeal ^ e i)) := by
      let ι_type := Σ (p : σ), Fin (Module.compositionLength (Localization.AtPrime p.1.1) (LocalizedModule p.1.1.primeCompl M))
      refine ⟨ι_type, inferInstance, fun x ↦ x.1, fun x ↦ x.1.2.2, fun _ ↦ 1, fun _ ↦ zero_lt_one, ?_⟩
