    refine ⟨0, ?_⟩
    simp only [LinearMap.ker_zero, LinearMap.coker_zero]
    constructor
    · rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rw [Module.subsingleton_iff_not_mem_support]
      simp [s] at hp
      exact hp
    · infer_instance
  · let S := ⨅ p ∈ s, p.1.primeCompl
    obtain ⟨hdom, hpid⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (Set.inter_subset_right _ _) hn hfin
    let AS := Localization S
