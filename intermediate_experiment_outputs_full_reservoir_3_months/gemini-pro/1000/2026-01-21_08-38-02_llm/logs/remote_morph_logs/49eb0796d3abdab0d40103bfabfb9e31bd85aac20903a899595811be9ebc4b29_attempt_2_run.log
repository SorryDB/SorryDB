theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let sigma := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hfin : sigma.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  by_cases h : sigma.Nonempty
  · let S := ⨅ p ∈ sigma, p.1.primeCompl
    have : IsPrincipalIdealRing (Localization S) ∧ IsDomain (Localization S) :=
      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (Set.inter_subset_right _ _) h hfin
    let M_S := LocalizedModule S M
    have hM_S_tor : Module.IsTorsion (Localization S) M_S := Module.IsTorsion.of_isLocalization hMT S
    -- Use structure theorem for PID
    obtain ⟨ι, _, p', e, he, ⟨iso⟩⟩ := Module.equiv_directSum_prime_powers_of_isTorsion (Localization S) M_S
    -- Map primes back to A
    let p (i : ι) : PrimeSpectrum A := PrimeSpectrum.comap (algebraMap A (Localization S)) (p' i)
    have hp (i : ι) : (p i).1.primeHeight = 1 := by
      have hq := (p' i).2.1
      have hq_ne_bot : (p' i).asIdeal ≠ ⊥ := Ideal.ne_bot_of_lt (he i)
      have h_range := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one
        (Localization S) sigma (Set.inter_subset_right _ _) h hfin
      rw [← PrimeSpectrum.ext_iff, h_range]
      left; exact ⟨p' i, Set.mem_range_self _, rfl⟩
    refine ⟨ι, inferInstance, p, hp, e, he, ?_⟩
    -- Construct pseudo-isomorphism from local isomorphism
    let N := (i : ι) → A ⧸ (p i).1 ^ (e i)
    have hNT : Module.IsTorsion A N := Module.IsTorsion.pi (fun i _ =>
      Module.IsTorsion.module_of_isTorsion_submonoid (S := (p i).1.primeCompl)
      (fun x hx => by
         rw [Module.annihilator_quotient, Ideal.mem_pow_prime_power (p i).2.1 (he i),
             Ideal.mem_prime_iff_not_disjoint, Set.disjoint_singleton_left, not_not]
         exact hx)
      (Module.IsTorsion.of_isTorsion_submonoid_iff (fun x hx => hx) (Submodule.quotient_isTorsion _)))
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
    have : (LocalizedModule.map S (LinearMap.id : M →ₗ[A] M)) = LinearMap.id := by ext; simp
    -- The isomorphism M_S ≃ N_S
    let N_S := LocalizedModule S N
    have isoN : N_S ≃ₗ[Localization S] ⨁ (i : ι), Localization S ⧸ (p' i).asIdeal ^ (e i) := by
      refine (LocalizedModule.isLinearEquiv_pi S _).trans (LinearEquiv.piCongrRight fun i ↦ ?_)
      dsimp
      refine (IsLocalization.quotientEquiv (Localization S) S (p i).1 ^ (e i)).trans ?_
      rw [Ideal.map_pow, Ideal.map_comap_of_surjective (IsLocalization.map_surjective_of_prime_height_eq_one
        (Localization S) sigma (Set.inter_subset_right _ _) h hfin (p' i) (Set.mem_range_self _))]
      rfl
    exact Function.Bijective.comp (LinearEquiv.bijective isoN.symm) (LinearEquiv.bijective iso)
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    rw [isPseudoIsomorphism_iff_primeHeight_le_one_imp_subsingleton]
    intro p hp
    have : p ∉ sigma := fun h_in => h ⟨p, h_in⟩
    simp only [sigma, Set.mem_inter_iff, not_and, Set.mem_setOf_eq] at this
    specialize this hp.2
    rw [← Module.notMem_support_iff, Module.mem_support_iff_of_finite, not_not] at this
    rw [LocalizedModule.subsingleton_iff]
    intro x
    exact ⟨1, by simp [this x]⟩
