    haveI : IsDomain AS := hdom
    haveI : IsPrincipalIdealRing AS := hpid
    haveI : Module.Finite AS MS := Module.Finite_of_isLocalization A S _ _
    haveI : Module.IsTorsion AS MS := by
      intro x
