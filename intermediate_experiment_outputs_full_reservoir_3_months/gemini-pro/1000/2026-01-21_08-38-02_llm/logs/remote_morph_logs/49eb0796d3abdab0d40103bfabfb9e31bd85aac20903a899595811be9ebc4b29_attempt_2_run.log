    let R' := Localization S
    let M' := LocalizedModule S M
    haveI : Module.IsTorsion R' M' := Module.IsTorsion.localizedModule S hMT
    let D := Module.equiv_directSum_of_isTorsion R' M'
    let I := D.some
    let J := D.some_1
    let gen (i : I) := Submodule.IsPrincipal.generator (J i)
    let facts (i : I) := UniqueFactorizationMonoid.normalizedFactors (gen i)
    let ι := Σ (i : I), {q // q ∈ facts i}
    let p_map (x : ι) : PrimeSpectrum A :=
