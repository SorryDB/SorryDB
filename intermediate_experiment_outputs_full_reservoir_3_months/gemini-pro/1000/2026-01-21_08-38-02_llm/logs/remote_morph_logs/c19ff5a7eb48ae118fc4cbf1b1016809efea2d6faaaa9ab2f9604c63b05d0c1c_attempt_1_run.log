              rw [HermitianMat.inner_comm, ← MState.exp_val]
              apply MState.exp_val_le_one
              apply HermitianMat.proj_le_le_one
            have hP2_le : (↑((ℰ n) (statePow ρ n))).inner (P2 ε2 n) ≤ 1 := by
