noncomputable def NatIso_inverse {α β : Type*} [C : Category α] [D : Category β]
    {F G : Functor α β} (η : NaturalTransformation F G) (h : IsNatIso η) :
    NaturalTransformation G F where
  arrow X := (Classical.choose ((iso_iff_isIso (η.arrow X)).mp (h X))).inv
  naturality {X Y} f := by
    let iX := Classical.choose ((iso_iff_isIso (η.arrow X)).mp (h X))
    let iY := Classical.choose ((iso_iff_isIso (η.arrow Y)).mp (h Y))
    have hX : iX.hom = η.arrow X := Classical.choose_spec ((iso_iff_isIso (η.arrow X)).mp (h X))
    have hY : iY.hom = η.arrow Y := Classical.choose_spec ((iso_iff_isIso (η.arrow Y)).mp (h Y))
    rw [← comp_id (iX.inv ≫ F.homF f), ← iY.hom_inv_id, assoc, assoc, hY, η.naturality,
      ← assoc, ← hX, iX.inv_hom_id, id_comp]
