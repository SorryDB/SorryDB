lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    apply (hM.isMax_of_no_augmenting _).max M' hM'
    intro P hP
    exact hP.first_not_in (hsu hP.toIsPath.first_mem)
