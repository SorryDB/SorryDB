  let p := 59649589127497217
  let q := 5704689200685129054721
  have hp : p.Prime := by norm_num
  have hq : q.Prime := by norm_num
  have h : fermatNumber 7 = p * q := by rw [fermatNumber]; norm_num
  rw [a, h, Nat.minFac_mul_of_prime_of_prime hp hq, min_eq_left (by norm_num)]
  norm_num
