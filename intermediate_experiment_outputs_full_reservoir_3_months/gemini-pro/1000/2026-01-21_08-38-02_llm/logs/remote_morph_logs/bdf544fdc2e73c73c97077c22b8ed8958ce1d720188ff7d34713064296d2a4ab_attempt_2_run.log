    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  -- Let V be the image of the map k ↦ k + a k
  let V := {x : ℤ | ∃ k : ℕ+, x = k + a k}
  -- Let H be the holes in Z_{\ge 2}
  let H := {x : ℤ | 2 ≤ x ∧ x ∉ V}
  -- H is finite because the image has density 1
  have hH_fin : Set.Finite H := by
    -- For large M, image contains roughly M elements ≤ M+C
    -- k + a k ≤ X => k ≤ X - 1. k + a k ≥ k + 1.
    -- The number of k such that k + a k ≤ X is between X-2015 and X-1.
    -- Hence the number of holes ≤ 2015.
    apply Set.Finite.of_finite_image (s := {x | ∃ k, x = k + a k}ᶜ ∩ Set.Ici 2) (f := id)
    let C := 2015
