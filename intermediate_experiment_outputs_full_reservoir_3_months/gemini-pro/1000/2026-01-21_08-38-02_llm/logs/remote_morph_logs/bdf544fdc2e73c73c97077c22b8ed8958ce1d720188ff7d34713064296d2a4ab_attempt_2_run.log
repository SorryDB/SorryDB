       sorry
    apply Set.Finite.subset (Set.finite_Iic (2 + 2015))
    intro x hx
    simp at hx ⊢
    exact claim hx.1 hx.2

  let b_nat := hH_fin.toFinset.card + 1
  let b : ℕ+ := ⟨b_nat, Nat.succ_pos _⟩
  use b, 1
  intro m n hmn
  
  -- Let S_k = ∑_{j=1}^k (a j - b)
  -- We want to bound |S_n - S_m|.
  -- We identify S_k with the displacement E_k
  -- S_k = E_k + const
