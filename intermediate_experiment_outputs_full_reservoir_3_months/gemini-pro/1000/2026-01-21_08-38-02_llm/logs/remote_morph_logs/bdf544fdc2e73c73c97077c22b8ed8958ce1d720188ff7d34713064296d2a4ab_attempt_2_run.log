  let C : ℤ := 2015
  let f (k : ℕ+) : ℤ := k + a k
  have hf : Function.Injective f := λ x y h => by
    rcases lt_trichotomy x y with (hxy | rfl | hyx)
    · exact (hii y x ⟨x.2, hxy⟩ h.symm).elim
    · rfl
    · exact (hii x y ⟨y.2, hyx⟩ h).elim
  have hrng : ∀ k, (k:ℤ) < f k ∧ f k ≤ k + C := λ k => ⟨by linarith [hi k], by linarith [hi k]⟩

  let S (n : ℕ) := (Finset.Icc 1 n).image (λ i => f ⟨i, by simp; linarith⟩)
  let H (n : ℕ) := (Finset.Icc 2 (n + C)).filter (λ x => x ∉ S n)

  have hH_card : ∀ n, (H n).card = 2014 := λ n => by
    have hS_sub : S n ⊆ Finset.Icc 2 (n + C) := by
      intro x hx; simp at hx; rcases hx with ⟨i, hi, rfl⟩
      simp; constructor <;> linarith [hrng ⟨i, by simp; linarith⟩]
    have hS_card : (S n).card = n := by
      rw [Finset.card_image_of_injective]; simp; exact hf
    rw [Finset.filter_not, Finset.card_sdiff hS_sub, Int.card_Icc, hS_card]
    linarith

