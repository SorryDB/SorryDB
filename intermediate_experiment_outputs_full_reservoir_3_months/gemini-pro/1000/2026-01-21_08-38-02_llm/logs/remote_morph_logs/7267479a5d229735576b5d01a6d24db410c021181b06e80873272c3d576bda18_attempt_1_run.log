```lean
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 ≤ S.length := by
  let knowers (s : State n) := Finset.univ.filter (λ i => s i k)
  have h_init : (knowers (initialState n)).card = 1 := by
    simp [knowers, initialState]
    rw [Finset.filter_eq']
    simp
  have h_step : ∀ s c, (knowers (update s c)).card ≤ (knowers s).card + 1 := by
    intro s c
    simp [knowers, update]
