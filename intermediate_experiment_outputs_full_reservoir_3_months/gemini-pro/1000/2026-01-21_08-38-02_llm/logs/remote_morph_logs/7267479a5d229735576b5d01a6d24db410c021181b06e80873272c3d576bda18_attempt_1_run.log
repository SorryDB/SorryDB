lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 ≤ S.length := by
  let knowers (s : State n) := Finset.univ.filter (λ i => k ∈ s i)
  have h_step : ∀ s c, (knowers (update s c.1 c.2)).card ≤ (knowers s).card + 1 := by
    intro s c
    by_cases hk : k ∈ s c.1 ∨ k ∈ s c.2
    · have : knowers (update s c.1 c.2) = knowers s ∪ {c.1, c.2} := by
        ext; simp [knowers, update]; split_ifs <;> simp_all
      rw [this, Finset.card_union_eq_card_add_card_diff]
      apply Nat.add_le_add_left
      have : {c.1, c.2} ∩ knowers s ≠ ∅ := by
        simp [Finset.inter_eq_empty_iff_disjoint, Finset.disjoint_iff_ne]
        cases hk <;> (intro h; use k; simp [knowers, h])
      have : ({c.1, c.2} \ knowers s).card + ({c.1, c.2} ∩ knowers s).card = ({c.1, c.2}).card :=
        Finset.card_sdiff_add_card_inter _ _
      have : ({c.1, c.2}).card ≤ 2 := by simp; split_ifs <;> simp
      have : ({c.1, c.2} ∩ knowers s).card ≥ 1 := Finset.card_pos.mpr this
      linarith
    · have : knowers (update s c.1 c.2) = knowers s := by
        ext; simp [knowers, update]; split_ifs <;> simp_all
      rw [this]; exact Nat.le_succ _

  have h_bound : (knowers (after S)).card ≤ 1 + S.length := by
    induction S using List.reverseRecOn with
    | nil =>
      simp [after, makeCalls, knowers, initialState]
      rw [Finset.filter_eq, Finset.card_singleton]
    | snoc xs x ih =>
      rw [after, makeCalls_append]
      calc (knowers (update (after xs) x.1 x.2)).card
        _ ≤ (knowers (after xs)).card + 1 := h_step _ _
        _ ≤ (1 + xs.length) + 1 := Nat.add_le_add_right ih _
        _ = 1 + (xs ++ [x]).length := by simp; linarith

  have h_full : (knowers (after S)).card = n := by
    simp [knowers]; convert Finset.card_fin n; ext; simp [h]

  rw [h_full] at h_bound
  exact Nat.sub_le_iff_le_add.mpr h_bound
