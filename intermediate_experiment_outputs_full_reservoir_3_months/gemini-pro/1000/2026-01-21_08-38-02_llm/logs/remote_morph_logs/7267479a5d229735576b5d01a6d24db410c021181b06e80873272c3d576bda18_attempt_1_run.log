lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 ≤ S.length := by
  let K (s : State n) := Finset.univ.filter (λ i => k ∈ s i)
  have step : ∀ s c, (K (update s c)).card ≤ (K s).card + 1 := by
    intro s c
    let A : Finset (Fin n) := {c.fst, c.snd}
    have Ks_sub : K s ⊆ K (update s c) := by
      intro i hi
      simp [K, update] at *
      split_ifs
      · exact Finset.mem_union_left _ hi
      · exact hi
    have diff_sub : K (update s c) \ K s ⊆ A \ K s := by
      intro i hi
      rw [Finset.mem_sdiff] at hi ⊢
      constructor
      · simp [K, update] at hi; split_ifs at hi with h_in
        · exact h_in
        · exact hi.1
      · exact hi.2
    by_cases hA : Disjoint A (K s)
    · have : K (update s c) \ K s = ∅ := by
        rw [Finset.eq_empty_iff_forall_not_mem]
        intro i hi
        have := diff_sub hi
        simp [Finset.mem_sdiff] at this
        have h_in : i ∈ A := this.1
        simp [K, update] at hi
        rw [Finset.mem_sdiff] at hi
        have ik := hi.1
        split_ifs at ik with h_eq
        · rw [Finset.mem_union] at ik
          have : ¬ Disjoint A (K s) := by
             rw [Finset.disjoint_iff_ne]; push_neg
             cases ik with
             | inl h => use c.fst; simp [A, K] at *; constructor <;> assumption
             | inr h => use c.snd; simp [A, K] at *; constructor <;> assumption
          contradiction
        · contradiction
      rw [←Finset.card_union_sdiff_eq_card_of_subset Ks_sub, this, Finset.card_empty]
      simp
    · have A_card : A.card ≤ 2 := by
         simp [A]; apply Finset.card_insert_le
      have inter_card : (A ∩ K s).card ≥ 1 := by
         rwa [Finset.one_le_card, ←Finset.not_disjoint_iff_nonempty_inter]
      rw [←Finset.card_union_sdiff_eq_card_of_subset Ks_sub]
      apply le_trans (add_le_add_left (Finset.card_le_of_subset diff_sub) _)
      rw [Finset.card_sdiff_eq_card_sub_card_inter (Finset.inter_subset_left _ _)]
      apply le_trans (Nat.add_le_add_left (Nat.sub_le_sub_left inter_card A.card) _)
      simp; linarith
  have fold_le : ∀ l s, (K (l.foldl update s)).card ≤ (K s).card + l.length := by
    intro l; induction l with
    | nil => simp
    | cons c l ih => 
      intro s; simp
      apply le_trans (ih (update s c))
      have := step s c; linarith
  have h_start : (K (initialState n)).card = 1 := by
    simp [K, initialState]; rw [Finset.card_eq_one]; use k; ext; simp
  have h_end : (K (after S)).card = n := by
    simp [K]; have : Finset.univ.filter (λ i => k ∈ after S i) = Finset.univ := by ext; simp [h]
