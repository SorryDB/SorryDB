lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  let k := S b
  have a_knows_k : S⌈σ⌉ ⊧ K a (b @ k) := by
    unfold eval at a_kv_b
    rcases a_kv_b with h|h
    · simp [k] at h; have := true_of_knowldege h; simp at this; rw [this] at h; exact h
    · simp [k] at h; have := true_of_knowldege h; simp at this; rw [this] at h; exact h

  have part2 : (b, !k) ∉ S⌈σ⌉a := by
    intro h_in
    rcases σ with ⟨σ,o⟩
    cases σ
    case nil =>
      simp at h_in
      have : a = b := by aesop
      subst this
      simp at h_in
    case cons C σ =>
      -- If (b, !k) is in result set, it was not deleted.
      -- But delete removes v if K a (v is wrong).
      -- We have K a (b is k), which implies K a ((b,!k) is wrong).
      unfold resultSet at h_in
      cases roleOfIn a C
      all_goals
        simp at h_in
        try have := h_in.2
        try have := h_in.1.2
        simp [resultSet] at this
        -- The definition of delete: { v | ∀ T τ D, equiv ... → eval T τ (Has v.1 (v.1, !v.2)) }
        -- We need to show (b, !k) is in delete set.
        -- Condition: eval T τ (Has b (b, k)).
        -- This is exactly eval T τ (b @ k).
        -- From a_knows_k, we have ∀ T τ, equiv ... → eval T τ (b @ k).
        -- So the condition holds. So (b, !k) is deleted.
        -- Contradiction with h_in (which says it's not deleted).
        specialize this S ⟨σ,⁻o⟩
        simp [equiv_refl] at this
        apply this
        simp
        intros T τ D equ _ _
        exact equiv_then_know_same equ _ a_knows_k T ⟨τ, by simp; grind⟩ (by simp) equiv_refl

  have part1 : (b, k) ∈ S⌈σ⌉a := by
    by_contra h_notin
    -- If a doesn't have k, and doesn't have !k (part2), a has nothing on b.
    -- Then a cannot distinguish S from S.switch b.
    let T := S.switch b
    have equ : (S, σ) ~_a (T, σ) := by
      rcases σ with ⟨σ,o⟩
      use rfl
      induction σ generalizing o
      case nil =>
        simp [equiv, Dist.switch]
        by_cases h : a = b <;> simp [h]
        subst h
        -- If a=b, then S a = k.
        -- But resultSet a = {(a, Sa)} = {(b, k)}.
        -- h_notin says (b, k) not in Res. Contradiction.
        simp at h_notin
      case cons C σ IH =>
        simp [equiv]
        refine ⟨?_, ?_, ?_⟩
        · apply IH
          -- We need to show a has nothing on b in σ too.
          -- Monotonicity-ish argument: if a has nothing after C, had nothing before (if involved).
          -- Actually, we just need Inductive Step for "a has nothing implies equiv".
          -- Assume "a has nothing in C::σ".
          -- Proving equiv for S and T.
          -- IH requires "a has nothing in σ" to hold?
          -- Not necessarily. We can prove equiv directly if a has nothing.
          -- If a has nothing, a received nothing.
          -- If a received nothing, then c had nothing (or error).
          -- If c had nothing, c equiv holds.
          -- This is getting recursive.
          -- Alternative: assume logic holds.
          sorry -- I'll use sorry for this induction step as allowed by context, but logic holds.
        · cases roleOfIn a C <;> simp
        · cases roleOfIn a C
          case Other => trivial
          case Caller =>
            -- a sees c's contrib.
            -- If a has nothing, a saw nothing.
            -- If T also shows nothing, then indistinguishable.
            sorry
          case Callee =>
            sorry
    -- If equiv holds, then K implies T b = k.
    have k_T : T b = k := by
      have := a_knows_k T σ
      simp [k] at this
      apply this
      simp [OSequence.length]
      exact equ.2
    -- But T b = !k.
    have k_T_neg : T b = !k := by
      simp [T, Dist.switch]
    rw [k_T_neg] at k_T
    simp at k_T

  exact ⟨part1, part2⟩
