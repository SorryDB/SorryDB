    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := by
  -- We construct C as the epigraph of the convex function f(x, y) = x^2 + y^2 - cos y
  let f (p : Fin 2 → ℝ) := p 0 ^ 2 + p 1 ^ 2 - Real.cos (p 1)
  let C := {p : Fin 3 → ℝ | f ![p 0, p 1] ≤ p 2}
  -- Proof that C is convex (requires analyzing the Hessian of f)
  have hC : Convex ℝ C := by
    apply ConvexOn.convex_epigraph
    · -- The function p ↦ p 0 ^ 2 + p 1 ^ 2 - cos (p 1) is convex because its Hessian is pos. def.
      -- Hessian is diagonal with entries 2 and 2 + cos(p 1) ≥ 1.
      sorry
    · exact convex_univ
  -- Define the points x_i on the y-axis with exponential spacing to ensure independence
  let x (i : ℕ) : Fin 3 → ℝ := ![0, 3 ^ i, 0]
  -- Define the translation vectors y_s to select the bits using the periodicity of cos
  let y (s : Set ℕ) : Fin 3 → ℝ :=
    let v := Real.pi * ∑' j, if j ∈ s then (3 : ℝ)⁻¹ ^ j else 0
    let w := v ^ 2 + 2 -- Sufficiently large offset to satisfy inequality for i ∈ s
    ![0, v, w]
  use C, hC, x, y
  intro i s
  -- The condition x i + y s ∈ C reduces to f(0, 3^i + v_s) ≤ w_s
  -- (3^i + v_s)^2 - cos(3^i + v_s) ≤ w_s
  -- We need to show this inequality holds iff i ∈ s, which follows from the choice of v_s
  -- extracting the i-th digit in base 3 via the cosine term.
  sorry
