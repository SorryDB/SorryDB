     theorem perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        intro h
        have aux (l : List α) (i : Fin l.length) : l.Perm (l[i] :: l.eraseIdx i) := by
          induction l with
          | nil => exact i.elim0
          | cons x xs ih =>
            match i with
            | ⟨0, _⟩ => simp [List.eraseIdx]
            | ⟨k+1, hk⟩ =>
              simp only [List.eraseIdx_cons_succ, List.getElem_cons_succ]
              exact (List.Perm.cons _ (ih ⟨k, Nat.lt_of_succ_lt_succ hk⟩)).trans (List.Perm.swap _ _ _)
        apply List.Perm.cons_inv (a := l1[idx1])
        have p1 := aux l1 idx1
        have p2 := aux l2 idx2
        rw [←h] at p2
        exact p1.symm.trans (hPerm.trans p2)
