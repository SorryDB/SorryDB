          | ⟨i+1, hi⟩, ⟨0, _⟩ =>
            simp at h; rw [←h]
            exact (p.symm.trans (perm_elem_erase ⟨i, hi⟩)).symm
          | ⟨i+1, hi⟩, ⟨j+1, hj⟩ =>
            simp; apply List.Perm.cons; apply ih; simp at h; exact h
        | swap y x l =>
          intro idx1 idx2 h
          match idx1, idx2 with
          | ⟨0, _⟩, ⟨0, _⟩ => simp at h; rw [h]; apply List.Perm.refl
          | ⟨0, _⟩, ⟨1, _⟩ => apply List.Perm.refl
          | ⟨1, _⟩, ⟨0, _⟩ => apply List.Perm.refl
          | ⟨1, _⟩, ⟨1, _⟩ => simp at h; rw [h]; apply List.Perm.refl
          | ⟨i+2, hi⟩, ⟨j+2, hj⟩ => simp; apply List.Perm.swap
          | ⟨0, _⟩, ⟨j+2, hj⟩ => simp; apply perm_elem_erase
          | ⟨i+2, hi⟩, ⟨0, _⟩ => simp; apply List.Perm.symm; apply perm_elem_erase
          | ⟨1, _⟩, ⟨j+2, hj⟩ => simp; apply perm_elem_erase
          | ⟨i+2, hi⟩, ⟨1, _⟩ => simp; apply List.Perm.symm; apply perm_elem_erase
