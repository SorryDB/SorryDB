      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        have perm_elem_erase {l : List α} (i : Fin l.length) : l.Perm (l[i] :: l.eraseIdx i) := by
          induction l generalizing i with
          | nil => exact i.elim0
          | cons x l ih =>
            match i with
            | ⟨0, _⟩ => simp; apply List.Perm.refl
            | ⟨i+1, hi⟩ =>
