    theorem perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        -- Helper lemma: l is a permutation of l[i] :: l.eraseIdx i
        have perm_cons_erase {α} (l : List α) (i : Fin l.length) : l.Perm (l[i] :: l.eraseIdx i) := by
          induction l with
          | nil => exact i.elim0
          | cons x xs ih =>
            match i with
            | ⟨0, _⟩ => simp; exact List.Perm.refl _
            | ⟨k+1, hk⟩ =>
              simp; exact (List.Perm.cons x (ih ⟨k, hk⟩)).trans (List.Perm.swap _ _ _)

        revert idx1 idx2
        induction hPerm with
        | nil => intro ⟨_, _⟩; contradiction
        | cons x _ _ p IH =>
          intro idx1 idx2 h
          match idx1, idx2 with
          | ⟨0, _⟩, ⟨0, _⟩ => exact p
          | ⟨0, _⟩, ⟨k+1, hk⟩ =>
             simp at h; subst x
             exact p.trans (perm_cons_erase _ ⟨k, hk⟩)
          | ⟨k+1, hk⟩, ⟨0, _⟩ =>
             simp at h; subst x
             exact (perm_cons_erase _ ⟨k, hk⟩).symm.trans p
          | ⟨k1+1, _⟩, ⟨k2+1, _⟩ =>
             simp at h
             exact (IH h).cons x
        | swap x y l =>
          intro idx1 idx2 h
          let p1 := perm_cons_erase (y::x::l) idx1
          let p2 := perm_cons_erase (x::y::l) idx2
          rw [h] at p1
          apply List.Perm.of_cons
          exact p1.symm.trans ((List.Perm.swap x y l).trans p2)
        | trans p1 p2 IH1 IH2 =>
           intro idx1 idx2 h
           obtain ⟨idx', h'⟩ := in_list_idx (list_perm_in p1 (List.get_mem _ idx1.1 idx1.2))
           exact (IH1 h'.symm).trans (IH2 (h'.trans h))
