      := by
        revert idx1 idx2
        have perm_cons_eraseIdx {α} (l : List α) (i : Fin l.length) :
          l.Perm (l[i] :: l.eraseIdx i) := by
            induction l with
            | nil => exact i.elim0
            | cons x xs ih =>
              match i with
              | ⟨0, _⟩ => simp
              | ⟨k+1, hk⟩ =>
                simp; trans (x :: xs[k] :: xs.eraseIdx k)
                · apply List.Perm.cons; apply ih
