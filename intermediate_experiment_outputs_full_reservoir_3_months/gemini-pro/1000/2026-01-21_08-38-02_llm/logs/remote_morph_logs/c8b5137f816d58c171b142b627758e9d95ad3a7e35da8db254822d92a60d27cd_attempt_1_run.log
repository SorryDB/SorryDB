theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  let f (m n : ℕ) : ℚ := ((2 * m)! * (2 * n)! : ℚ) / (m ! * n ! * (m + n)!)
  have h_step : ∀ m n, f (m + 1) n = 4 * f m n - f m (n + 1) := by
    intro m n
    dsimp [f]
    have h1 : (m + 1 + n)! = (m + n + 1) * (m + n)! := by rw [add_assoc, Nat.factorial_succ]; rfl
    have h2 : (2 * (m + 1))! = (2 * m + 2) * (2 * m + 1) * (2 * m)! := by
      rw [mul_add, mul_one, Nat.factorial_succ, Nat.factorial_succ]; ring
    have h3 : (m + 1)! = (m + 1) * m! := Nat.factorial_succ m
    have h4 : (2 * (n + 1))! = (2 * n + 2) * (2 * n + 1) * (2 * n)! := by
      rw [mul_add, mul_one, Nat.factorial_succ, Nat.factorial_succ]; ring
    have h5 : (n + 1)! = (n + 1) * n! := Nat.factorial_succ n
    rw [h1, h2, h3, h4, h5]
    have : (m ! * n ! * (m + n)! : ℚ) ≠ 0 := by
      exact_mod_cast mul_ne_zero (mul_ne_zero (Nat.factorial_ne_zero _) (Nat.factorial_ne_zero _)) (Nat.factorial_ne_zero _)
    field_simp
    ring
  have h_int : ∀ m n, ∃ k : ℤ, f m n = k := by
    intro m; induction m with
    | zero =>
      intro n; use (Nat.choose (2 * n) n); dsimp [f]
      rw [Nat.choose_eq_factorial_div_factorial (Nat.le_mul_of_pos_left n two_pos)]
      simp
    | succ m ih =>
      intro n; rw [h_step]; obtain ⟨k1, hk1⟩ := ih n; obtain ⟨k2, hk2⟩ := ih (n + 1)
