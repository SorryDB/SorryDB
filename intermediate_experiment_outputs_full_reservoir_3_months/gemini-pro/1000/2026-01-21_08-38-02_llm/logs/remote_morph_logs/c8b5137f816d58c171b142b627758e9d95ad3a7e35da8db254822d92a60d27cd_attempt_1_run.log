theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  let R (m n : ℕ) : ℚ := ((2 * m).factorial * (2 * n).factorial) / (m.factorial * n.factorial * (m + n).factorial)
  have h_rec : ∀ m n, R m (n + 1) + R (m + 1) n = 4 * R m n := by
    intro m n; simp only [R]
    have f1 : (2 * (n + 1)).factorial = (2 * n + 2) * (2 * n + 1) * (2 * n).factorial := by
      have : 2 * (n + 1) = 2 * n + 2 := by ring
      rw [this, Nat.factorial_succ, Nat.factorial_succ]; ring
    have f2 : (2 * (m + 1)).factorial = (2 * m + 2) * (2 * m + 1) * (2 * m).factorial := by
      have : 2 * (m + 1) = 2 * m + 2 := by ring
      rw [this, Nat.factorial_succ, Nat.factorial_succ]; ring
    rw [f1, f2]; field_simp [Nat.factorial_ne_zero]; ring
  have h_int : ∀ m n, ∃ k : ℤ, R m n = k := by
    intro m n; induction n generalizing m with
    | zero =>
      use (2 * m).choose m
      simp [R, Nat.choose_eq_factorial_div_factorial (show m ≤ 2 * m by linarith)]
      field_simp [Nat.factorial_ne_zero]; ring
    | succ n ih =>
      obtain ⟨k1, hk1⟩ := ih m; obtain ⟨k2, hk2⟩ := ih (m + 1)
      use 4 * k1 - k2; rw [← hk1, ← hk2]; linarith [h_rec m n]
  obtain ⟨k, hk⟩ := h_int m n
  have : 0 ≤ k := by rw [← hk]; unfold R; positivity
  lift k to ℕ using this
  use k; norm_cast at hk ⊢; rw [← hk, R]; field_simp; ring
