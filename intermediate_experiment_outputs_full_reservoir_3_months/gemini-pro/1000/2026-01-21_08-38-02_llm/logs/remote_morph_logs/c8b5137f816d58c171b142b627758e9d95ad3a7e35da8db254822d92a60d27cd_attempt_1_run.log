theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  let F (m n : ℕ) : ℚ := ((2 * m)! * (2 * n)!) / (m ! * n ! * (m + n)!)
  have h_rec : ∀ m n, F (m + 1) n + F m (n + 1) = 4 * F m n := by
    intro m n
    simp only [F]
    have h₁ : (2 * (m + 1))! = (2 * m + 2) * (2 * m + 1) * (2 * m)! := by
      rw [mul_add, mul_one, Nat.factorial_succ, Nat.factorial_succ]
      ring
    have h₂ : (2 * (n + 1))! = (2 * n + 2) * (2 * n + 1) * (2 * n)! := by
      rw [mul_add, mul_one, Nat.factorial_succ, Nat.factorial_succ]
      ring
    rw [h₁, h₂, Nat.factorial_succ (m + n), Nat.factorial_succ m, Nat.factorial_succ n]
    push_cast
    field_simp [Nat.factorial_ne_zero]
    ring
  have h_int : ∀ m n, ∃ k : ℕ, F m n = k := by
    intro m
    induction m generalizing n with
    | zero =>
      intro n
      use (2 * n).choose n
      rw [Nat.choose_eq_factorial_div_factorial (by linarith)]
      simp [F, two_mul]
    | succ m ih =>
      intro n
      obtain ⟨k₁, hk₁⟩ := ih n
      obtain ⟨k₂, hk₂⟩ := ih (n + 1)
      specialize h_rec m n
      rw [hk₁, hk₂] at h_rec
      have h_le : (k₂ : ℚ) ≤ 4 * k₁ := by
        have : 0 ≤ F (m + 1) n := div_nonneg (by exact_mod_cast Nat.zero_le _) (by exact_mod_cast Nat.zero_le _)
        linarith
      use 4 * k₁ - k₂
      rw [Nat.cast_sub (by exact_mod_cast h_le)]
      linarith
  obtain ⟨k, hk⟩ := h_int m n
  use k
  rw [← Nat.cast_inj (R := ℚ), Nat.cast_mul, hk, F]
  field_simp
