  carrier_indep : ∀ D ∈ carrier, sSupIndep D
  bot_not_mem : ∀ D ∈ carrier, ⊥ ∉ D
  range_le : ∀ D ∈ carrier, sSup D ≤ sSup S

instance (S : Set α) : SetLike (refinement S) (Set α) where
  coe := refinement.carrier
  coe_injective' D₁ := by cases D₁; congr!

