  obtain ⟨C, hC⟩ := (φ.continuous.bounded_of_compact_support φ.hasCompactSupport).subset_ball 0
  have hφ : Memℒp φ ⊤ (μ.restrict (tsupport φ)) :=
    Memℒp.of_bound φ.continuous.aestronglyMeasurable C (eventually_of_forall fun x ↦ le_of_lt (hC (mem_range_self x)))
  exact (hφ.smul hf').integrable_of_support_subset (support_smul_subset_left _ _)

end ofFun
