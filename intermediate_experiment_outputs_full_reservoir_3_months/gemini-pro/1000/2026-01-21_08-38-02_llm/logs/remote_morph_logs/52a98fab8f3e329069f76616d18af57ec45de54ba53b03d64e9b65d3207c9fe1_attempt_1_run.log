The problem asks whether the limit of `f n` as `n → ∞` is infinity. The function `f n` is defined as the minimum of the mean squared gap of the sumset $A+A$, over all Sidon sets $A$ of size $n$.
For a Sidon set $A$ of size $n$, the cardinality of the sumset $A+A$ is $|A+A| = \binom{n+1}{2} = \frac{n(n+1)}{2}$. Let $k = |A+A|$.
The sum $\sum (s_i - s_{i-1})^2$ involves $k-1$ terms, where each term is the square of a gap between distinct integers, so each gap is at least 1. Thus, the sum is at least $k-1$.
The value of `f n` is therefore bounded below by $\frac{k-1}{n} = \frac{n(n+1)/2 - 1}{n} = \frac{n+1}{2} - \frac{1}{n} \approx \frac{n}{2}$.
Since $\frac{n}{2} \to \infty$, `f n` tends to infinity.
Thus, the answer to the question "Must `lim f n = ∞`?" is "Yes" (True).

```lean
@[category research open, AMS 5]
theorem erdos_153 : answer(True) ↔ Tendsto f atTop atTop := by
  simp only [answer, true_iff]
  have lb : ∀ n, 2 ≤ n → (n : ℝ) / 2 ≤ f n := by
    intro n hn; rw [f]; apply le_ciInf; rintro ⟨A, rfl, hA⟩
    let k := (A + A).card
    have hk : k = n * (n + 1) / 2 := IsSidon.card_add hA
    let s := (A + A).orderIsoOfFin rfl
    have h_sum : ∑ i : Set.Ico 1 k, (s ⟨i, i.2.2⟩ - s ⟨i - 1, by grind⟩) ^ 2 ≥ k - 1 := by
      calc
        _ ≥ ∑ i : Set.Ico 1 k, 1 := Finset.sum_le_sum fun i hi => by
          have : s ⟨i - 1, by grind⟩ < s ⟨i, i.2.2⟩ := s.strictMono (by simp at hi; linarith)
          norm_cast; exact Nat.pow_two_pos_of_ne_zero (Nat.sub_ne_zero_of_lt this)
        _ = k - 1 := by simp
    calc
      (n : ℝ) / 2 ≤ ((k - 1 : ℕ) : ℝ) / n := by
        rw [hk]; field_simp; rw [div_le_div_right (by norm_cast; linarith)]; norm_cast; nlinarith
      _ ≤ _ := by gcongr; norm_cast
  exact tendsto_atTop_mono' (atTop.sets_of_superset (Set.Ici_mem_atTop 2) lb) (Tendsto.atTop_div_const tendsto_id (by norm_num))
