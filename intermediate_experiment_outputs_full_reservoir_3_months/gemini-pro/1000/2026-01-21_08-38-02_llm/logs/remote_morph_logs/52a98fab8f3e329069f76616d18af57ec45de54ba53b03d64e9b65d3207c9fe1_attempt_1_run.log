    let S := A + A
    have hS_card : S.card = n * (n + 1) / 2 := Finset.card_add_of_sidon hA
    have hS_pos : S.card > 0 := by rw [hS_card]; exact Nat.div_pos (by nlinarith) (by norm_num)
    let s := S.orderIsoOfFin (Finset.card_pos.mp hS_pos)
    have h_sq_ge_one : ∀ i, (s ⟨i, i.2.2⟩ - s ⟨i - 1, by grind⟩ : ℝ) ^ 2 ≥ 1 := by
      intro i
      have : s ⟨i - 1, by grind⟩ < s ⟨i, i.2.2⟩ := s.strictMono (by simp; omega)
      norm_cast; replace this := Nat.le_of_lt_iff_le_sub_one.mp this
      calc (s ⟨i, _⟩ - s ⟨i - 1, _⟩ : ℝ) ^ 2 
        _ ≥ (1 : ℝ) ^ 2 := by gcongr; norm_cast; linarith
        _ = 1 := by norm_num
    calc
      ∑ i : Set.Ico 1 S.card, (s ⟨i, i.2.2⟩ - s ⟨i - 1, by grind⟩) ^ 2 / (n : ℝ)
      _ ≥ ∑ i : Set.Ico 1 S.card, (1 : ℝ) / n := by
        gcongr; apply h_sq_ge_one
      _ = (S.card - 1 : ℝ) / n := by simp
