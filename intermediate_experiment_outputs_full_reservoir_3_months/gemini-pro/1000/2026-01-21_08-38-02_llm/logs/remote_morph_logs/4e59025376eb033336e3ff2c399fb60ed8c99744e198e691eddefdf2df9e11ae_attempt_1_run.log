theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  -- Define the image of S in Measure E
  let coe := (↑) : ProbabilityMeasure E → Measure E
  let S' := coe '' S
  have hS' : {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} = S' := Set.ext (by simp [S', coe])
  rw [hS']
  
  -- The coercion is an embedding
  have h_emb : IsEmbedding coe := ProbabilityMeasure.embedding_coe

  -- Apply the Prokhorov theorem for finite measures
  rw [MeasureTheory.isTightMeasureSet_iff_isCompact_closure]
  · constructor
    · -- If S' is tight, its closure is compact. Since S' is tight, limits are probability measures.
      intro h_compact
      have h_tight : IsTightMeasureSet S' :=
        (MeasureTheory.isTightMeasureSet_iff_isCompact_closure 
          (fun _ ⟨μ, _, h⟩ => h ▸ μ.instIsFiniteMeasure) 
          ⟨1, fun _ ⟨μ, _, h⟩ => h ▸ le_refl _⟩).mpr h_compact
      
      -- We show IsCompact (closure S) by showing closure S is homeomorphic to closure S'
      rw [← h_emb.isCompact_iff_isCompact_image]
      refine IsCompact.of_isClosed_subset h_compact (h_emb.isClosed_map _ isClosed_closure) (fun μ hμ => ?_)
      
      -- Closure of tight set of probability measures consists of probability measures
      obtain ⟨ν, hν⟩ := IsTightMeasureSet.exists_tendsto_of_mem_closure h_tight hμ
      lift ν to ProbabilityMeasure E using hν.1
      exact ⟨ν, rfl⟩

    · -- If closure S is compact, then closure S' is a closed subset of a compact set
      intro h_compact
      refine IsCompact.of_isClosed_subset (h_compact.image h_emb.continuous) isClosed_closure ?_
      rw [image_closure_subset_iff]
      exact subset_closure

  · -- Check finite measure condition
    rintro _ ⟨μ, _, rfl⟩
    exact μ.instIsFiniteMeasure
  · -- Check uniform bound condition
    use 1
    rintro _ ⟨μ, _, rfl⟩
    simp
