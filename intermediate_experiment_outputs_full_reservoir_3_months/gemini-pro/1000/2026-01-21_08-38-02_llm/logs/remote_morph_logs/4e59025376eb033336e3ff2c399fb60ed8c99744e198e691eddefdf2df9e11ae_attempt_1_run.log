  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  let s := {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
  have h_fin : ∀ μ ∈ s, IsFiniteMeasure μ := by
    rintro μ ⟨p, -, rfl⟩; exact p.isFiniteMeasure
  have h_bound : ∃ C, ∀ μ ∈ s, μ univ ≤ C :=
    ⟨1, by rintro μ ⟨p, -, rfl⟩; simp⟩
  rw [MeasureTheory.isTightMeasureSet_iff_isCompact_closure h_fin h_bound]
  let val : ProbabilityMeasure E ↪ Measure E := Embedding.subtypeVal
  constructor
  · intro h
    have h_tight := (MeasureTheory.isTightMeasureSet_iff_isCompact_closure h_fin h_bound).mpr h
    rw [val.isCompact_iff_isCompact_image]
    convert h using 1
    ext μ
    constructor
    · intro hμ
      obtain ⟨u, huS, huμ⟩ := mem_closure_iff_seq_limit.mp hμ
      have : μ univ = 1 := MeasureTheory.tendsto_measure_univ_of_isTight
        (h_tight.mono (range_subset_iff.mpr huS)) huμ (fun n ↦ (huS n).2 ▸ (by simp))
      lift μ to ProbabilityMeasure E using ⟨this⟩
      refine ⟨μ, mem_closure_iff_seq_limit.mpr ⟨fun n ↦ ?_, ?_⟩, rfl⟩
      · choose p hp eq using huS
        exact ⟨p, hp, val.injective (eq n ▸ rfl)⟩
      · choose p hp eq using huS
