    intro u hu
    choose v hvS hv_dist using fun n => Metric.mem_closure_iff.mp (hu n) (n + 1 : ℕ)⁻¹ (inv_pos.mpr (Nat.cast_add_one_pos n))
    have h_tight : IsTightMeasureSet (range (fun n => ((v n) : Measure E))) :=
