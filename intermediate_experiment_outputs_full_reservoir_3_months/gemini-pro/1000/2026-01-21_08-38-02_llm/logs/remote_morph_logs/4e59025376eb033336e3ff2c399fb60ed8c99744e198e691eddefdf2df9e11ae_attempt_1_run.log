    obtain ⟨μ, hμ, φ, hφ, hlim⟩ := IsTightMeasureSet.exists_subseq_of_isTight (fun n => (v n).prop) h_tight
    refine ⟨⟨μ, hμ⟩, ⟨φ, hφ, ?_⟩⟩
    rw [ProbabilityMeasure.tendsto_iff_weak_convergence] at hlim ⊢
    rw [← ProbabilityMeasure.tendsto_iff_weak_convergence] at hlim
    apply tendsto_of_dist_eq_zero
    refine squeeze_zero (fun n => dist_nonneg) (fun n => dist_triangle _ (v (φ n)) _) ?_
