        simpa [eq] using huμ
    · rintro ⟨p, hp, rfl⟩
      exact val.continuous.continuousOn.closure_image_subset _ hp
  · intro h
    rw [val.isCompact_iff_isCompact_image] at h
    apply IsCompact.of_isClosed_subset h isClosed_closure
    refine closure_minimal ?_ h.isClosed
    rintro μ ⟨p, hp, rfl⟩
    exact ⟨p, subset_closure hp, rfl⟩
