/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf s := if Real.pi ∈ s then 1 else 0
  empty := by simp
  mono {S T} hST := by
    dsimp
    split_ifs with h₁ h₂
    · rfl
    · exact absurd (hST h₁) h₂
    · exact zero_le_one
    · rfl
  iUnion_nat s := by
    dsimp
    split_ifs with h
    · obtain ⟨i, hi⟩ := h
      refine le_trans ?_ (ENNReal.le_tsum i)
      simp [hi]
    · exact zero_le _
