section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf s := if Real.pi ∈ s then 1 else 0
  empty := by simp
  mono {S T} hST := by
    dsimp
    split_ifs with h <;> simp [hST h]
  iUnion_nat s := by
    dsimp
    split_ifs with h
    · obtain ⟨i, hi⟩ := mem_iUnion.1 h
      exact le_trans (le_of_eq (if_pos hi).symm) (ENNReal.le_tsum i)
    · exact zero_le _
