/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf s := if Real.pi ∈ s then 1 else 0
  empty := by simp
  mono {S T} hST := by
    dsimp
    split_ifs with h₁ h₂
    · exact le_rfl
    · exact absurd (hST h₁) h₂
    · exact zero_le _
    · exact le_rfl
```
