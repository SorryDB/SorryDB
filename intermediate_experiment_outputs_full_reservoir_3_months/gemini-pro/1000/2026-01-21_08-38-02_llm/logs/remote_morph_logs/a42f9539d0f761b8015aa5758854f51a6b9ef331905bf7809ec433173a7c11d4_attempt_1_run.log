theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction h₀ with
  | base => norm_num
  | step k hk ih =>
    rw [factorial_succ, Nat.succ_eq_add_one]
    calc (k + 1) ^ 2 ≤ (k + 1) * k ^ 2 := by nlinarith
      _ ≤ (k + 1) * k ! := by gcongr
```
