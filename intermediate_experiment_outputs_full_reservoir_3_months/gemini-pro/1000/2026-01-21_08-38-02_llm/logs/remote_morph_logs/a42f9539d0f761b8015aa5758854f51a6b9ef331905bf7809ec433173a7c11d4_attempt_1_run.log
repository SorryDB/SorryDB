theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction n, h₀ using Nat.le_induction with
  | base => norm_num
  | succ n hn ih =>
    have : n + 1 ≤ n ^ 2 := calc
      n + 1 ≤ 2 * n := by linarith
      _     ≤ n * n := Nat.mul_le_mul_right n (by linarith)
      _     = n ^ 2 := by ring
    calc (n + 1) ^ 2
      _ = (n + 1) * (n + 1) := by ring
      _ ≤ (n + 1) * n ^ 2   := Nat.mul_le_mul_left _ this
      _ ≤ (n + 1) * n !     := Nat.mul_le_mul_left _ ih
      _ = (n + 1)!          := rfl
