    (preexisting_cache : (spec α).QueryCache) (n : ℕ)
    (leaves : List.Vector α (2 ^ (n + 1))) : HasEvalSPMF.NeverFail
      ((simulateQ randomOracle (buildLayer α n leaves)).run preexisting_cache) := by
  simp_rw [buildLayer]
  simp only [range_def, eq_mp_eq_cast, cast_eq, bind_pure]
  generalize h : List.Vector.ofFn _ = v
  clear h
  induction v using List.Vector.inductionOn generalizing preexisting_cache with
  | nil =>
    simp [List.Vector.mmap, List.Vector.mapM]
    infer_instance
  | cons hd tl ih =>
    simp [List.Vector.mmap, List.Vector.mapM]
    apply HasEvalSPMF.NeverFail.bind
    · infer_instance
    · intro _ _
      apply HasEvalSPMF.NeverFail.bind
      · apply ih
      · intro _ _
        infer_instance
