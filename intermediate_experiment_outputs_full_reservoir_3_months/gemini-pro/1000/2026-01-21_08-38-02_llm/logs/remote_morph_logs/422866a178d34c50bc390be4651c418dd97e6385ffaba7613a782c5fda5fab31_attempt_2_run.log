theorem buildLayer_neverFails (α : Type) [inst : DecidableEq α]
    [inst_1 : SampleableType α] [(spec α).DecidableEq]
    (preexisting_cache : (spec α).QueryCache) (n : ℕ)
    (leaves : List.Vector α (2 ^ (n + 1))) : HasEvalSPMF.NeverFail
      ((simulateQ randomOracle (buildLayer α n leaves)).run preexisting_cache) := by
  rw [buildLayer]
  simp [List.Vector.mmap]
  generalize (List.Vector.ofFn _).toList = l
  induction l generalizing preexisting_cache <;> simp
  · exact HasEvalSPMF.NeverFail.pure _
  · apply HasEvalSPMF.NeverFail.bind
    · simp [simulateQ_query]
      intro s
      unfold randomOracle
      split <;> simp [HasEvalSPMF.NeverFail.pure, HasEvalSPMF.NeverFail.bind, HasEvalSPMF.NeverFail.sample]
    · intro _ _
      apply_assumption
```
