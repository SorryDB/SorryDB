  have : Fintype.card (Fin (p.sqrt + 1) × Fin (p.sqrt + 1)) > Fintype.card (ZMod p) := by
    simp; apply Nat.lt_succ_sqrt
  obtain ⟨x, y, hne, heq⟩ := Finite.exists_ne_map_eq_of_card_lt f this
  let a := ((x.1 : ℤ) - y.1).natAbs; let b := ((x.2 : ℤ) - y.2).natAbs
  use a, b
  have h_eq : (x.1 : ZMod p) - y.1 = -z * (x.2 - y.2) := by
    simp [f] at heq; rw [sub_eq_iff_eq_add]; linear_combination heq
  have h_div : (p : ℤ) ∣ a ^ 2 + b ^ 2 := by
