theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  rcases h₀ with ⟨hx, hy, hz⟩
  refine ⟨?_, ?_⟩
  · by_cases h : x ≤ 1/2
    · have : 1 - 2 * x ≥ 0 := by linarith
      rw [← h₁, show y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - 2 * x) + x * (y + z) by ring]
      nlinarith
    · have : y ≤ 1/2 := by linarith [h₁, hx, hy, hz]
      have : 1 - 2 * y ≥ 0 := by linarith
      rw [← h₁, show y * z + z * x + x * y - 2 * x * y * z = z * x * (1 - 2 * y) + y * (z + x) by ring]
      nlinarith
  · rw [div_le_iff₀ (by norm_num)]
    trans 27 * (x + y + z) * (y * z + z * x + x * y) - 54 * x * y * z
    · rw [h₁]; ring
    suffices 7 * (x + y + z)^3 - (27 * (x + y + z) * (y * z + z * x + x * y) - 54 * x * y * z) ≥ 0 by linarith
    let S (a b c : ℝ) := a * (a - b) * (a - c) + b * (b - c) * (b - a) + c * (c - a) * (c - b)
    let M (a b c : ℝ) := (a + b) * (a - b)^2 + (b + c) * (b - c)^2 + (c + a) * (c - a)^2
    have : 7 * (x + y + z)^3 - (27 * (x + y + z) * (y * z + z * x + x * y) - 54 * x * y * z) = 5 * S x y z + M x y z := by ring
    rw [this]
    have hM : M x y z ≥ 0 := by dsimp [M]; nlinarith
    have hS : S x y z ≥ 0 := by
      wlog hxy : x ≤ y generalizing x y z
      · have : S x y z = S y x z := by dsimp [S]; ring
        rw [this]; exact this y x z hy hx hz
      wlog hyz : y ≤ z generalizing x y z
      · have : S x y z = S x z y := by dsimp [S]; ring
        rw [this]; exact this x z y hx hz hy hxy
      dsimp [S]
      have : y * (y - z) * (y - x) + z * (z - x) * (z - y) = (z - y)^2 * (z + y - x) := by ring
      nlinarith
    linarith
