theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have h_low : 0 ≤ y * z + z * x + x * y - 2 * x * y * z := by
    have : y * z + z * x + x * y - 2 * x * y * z =
        x * y * z + x^2 * y + x * y^2 + y^2 * z + y * z^2 + z^2 * x + z * x^2 := by
      calc y * z + z * x + x * y - 2 * x * y * z
        _ = (x + y + z) * (y * z + z * x + x * y) - 2 * x * y * z := by rw [h₁, one_mul]
        _ = x * y * z + x^2 * y + x * y^2 + y^2 * z + y * z^2 + z^2 * x + z * x^2 := by ring
    rw [this]
    nlinarith [h₀]
  have h_up : y * z + z * x + x * y - 2 * x * y * z ≤ 7 / 27 := by
    have h_yz_le : y * z ≤ (1 - x)^2 / 4 := by
      have : (y + z)^2 - 4 * y * z = (y - z)^2 := by ring
      have h_sum : y + z = 1 - x := by linear_combination h₁
      nlinarith [sq_nonneg (y - z)]
    have h_eq : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - 2 * x) + x * (1 - x) := by
      have h_sum : y + z = 1 - x := by linear_combination h₁
      linear_combination -2 * x * y * z + x * h_sum
    rw [h_eq]
    by_cases hx : x ≤ 1 / 2
    · have h_factor : 54 * x^3 - 27 * x^2 + 1 = (3 * x - 1)^2 * (6 * x + 1) := by ring
      have h_nonneg : 0 ≤ 1 - 2 * x := by linarith
      calc y * z * (1 - 2 * x) + x * (1 - x)
        _ ≤ ((1 - x)^2 / 4) * (1 - 2 * x) + x * (1 - x) := by nlinarith
        _ = (-(54 * x^3 - 27 * x^2 + 1) + 28) / 108 := by ring
        _ ≤ 28 / 108 := by
          rw [h_factor]
          have : 0 ≤ (3 * x - 1)^2 * (6 * x + 1) := by nlinarith [h₀]
          linarith
        _ = 7 / 27 := by norm_num
    · have h_neg : 1 - 2 * x < 0 := by linarith
      calc y * z * (1 - 2 * x) + x * (1 - x)
        _ ≤ 0 + x * (1 - x) := by nlinarith [h₀]
        _ = -(x - 1/2)^2 + 1/4 := by ring
        _ ≤ 1/4 := by nlinarith [sq_nonneg (x - 1/2)]
        _ ≤ 7 / 27 := by norm_num
  exact ⟨h_low, h_up⟩
