theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  let a := 1 - 2 * x
  let b := 1 - 2 * y
  let c := 1 - 2 * z
  have ha : a = 1 - 2 * x := rfl
  have hb : b = 1 - 2 * y := rfl
  have hc : c = 1 - 2 * z := rfl

  have key : 4 * (y * z + z * x + x * y - 2 * x * y * z) = 1 + a * b * c := by
    rw [ha, hb, hc]
    ring_nf
    rw [h₁]
    ring

  have h_sum : a + b + c = 1 := by linarith
  rcases h₀ with ⟨hx, hy, hz⟩
  have ha_abs : |a| ≤ 1 := by rw [ha, abs_le]; constructor <;> linarith
  have hb_abs : |b| ≤ 1 := by rw [hb, abs_le]; constructor <;> linarith
  have hc_abs : |c| ≤ 1 := by rw [hc, abs_le]; constructor <;> linarith

  have lower : -1 ≤ a * b * c := by
    have : |a * b * c| ≤ 1 := by
      rw [abs_mul, abs_mul]
      apply mul_le_one
      · apply mul_le_one (abs_nonneg _) ha_abs.2 (abs_nonneg _) hb_abs.2
      · apply mul_nonneg (abs_nonneg _) (abs_nonneg _)
      · exact hc_abs.2
    rw [abs_le] at this
    exact this.1

  have upper : a * b * c ≤ 1 / 27 := by
    by_cases h : a < 0 ∨ b < 0 ∨ c < 0
    · rcases h with ha_neg | hb_neg | hc_neg
      · rw [ha] at ha_neg; have : x > 1/2 := by linarith
        have : y < 1/2 := by linarith
        have : z < 1/2 := by linarith
        have : b > 0 := by rw [hb]; linarith
        have : c > 0 := by rw [hc]; linarith
        nlinarith
      · rw [hb] at hb_neg; have : y > 1/2 := by linarith
        have : x < 1/2 := by linarith
        have : z < 1/2 := by linarith
        have : a > 0 := by rw [ha]; linarith
        have : c > 0 := by rw [hc]; linarith
        nlinarith
      · rw [hc] at hc_neg; have : z > 1/2 := by linarith
        have : x < 1/2 := by linarith
        have : y < 1/2 := by linarith
        have : a > 0 := by rw [ha]; linarith
        have : b > 0 := by rw [hb]; linarith
        nlinarith
    · push_neg at h
      rcases h with ⟨ha_pos, hb_pos, hc_pos⟩
      have gm : b * c ≤ ((b + c) / 2) ^ 2 := by linarith [sq_nonneg (b - c)]
      have sub : b + c = 1 - a := by linarith
      rw [sub] at gm
      have : a * b * c ≤ a * ((1 - a) / 2) ^ 2 := by
        apply mul_le_mul_of_nonneg_left gm ha_pos
      
      have poly : a * ((1 - a) / 2) ^ 2 ≤ 1 / 27 := by
         rw [le_div_iff₀ (by norm_num)]
         have : 27 * (a * ((1 - a) / 2) ^ 2) - 1 = 1 / 4 * (3 * a - 4) * (3 * a - 1) ^ 2 := by ring
         rw [← sub_nonpos, this]
         nlinarith [sq_nonneg (3 * a - 1), ha_abs.2]
      linarith

  constructor
  · linarith
  · linarith
