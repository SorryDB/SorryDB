@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  rcases h₀ with ⟨hx, hy, hz⟩
  let s := x + y
  let p := x * y
  have hs : s = 1 - z := by linarith
  have h_s_rng : 0 ≤ s ∧ s ≤ 1 := by constructor <;> linarith
  have h_p_nonneg : 0 ≤ p := by nlinarith
  have h_p_ub : 4 * p ≤ s ^ 2 := by nlinarith [sq_nonneg (x - y)]
  have h_expr : y * z + z * x + x * y - 2 * x * y * z = p * (2 * s - 1) + s * (1 - s) := by
    rw [hs]; ring
  rw [h_expr]
  constructor
  · by_cases h : 2 * s - 1 ≥ 0
    · nlinarith [h_s_rng.2]
    · have : p * (2 * s - 1) ≥ (s ^ 2 / 4) * (2 * s - 1) := by nlinarith
      have : (s ^ 2 / 4) * (2 * s - 1) + s * (1 - s) = s * (2 * s ^ 2 - 5 * s + 4) / 4 := by ring
      have : 2 * s ^ 2 - 5 * s + 4 > 0 := by nlinarith
      nlinarith [h_s_rng.1]
