      ∑ k ∈ I, ∑ a, if action alg (n + 1) ω = a ∧ pullCount (action alg) a (n + 1) ω = k then
        f ((hist alg ω n, a), ω.2 k a) else 0 := by
    simp only [reward_eq, Finset.sum_ite, Finset.sum_const_zero, Finset.mem_range]
