      simp; intro h'; exact hk' (congr_arg Prod.fst (h_uniq (k', a') ⟨by simp at *, h'.2, h'.1⟩).symm)
  simp_rw [h_eq, lintegral_finset_sum I (fun _ _ ↦ (by fun_prop)),
    lintegral_tsum (fun _ ↦ (by fun_prop))]
  refine Finset.sum_congr rfl fun k _ ↦ tsum_congr fun a ↦ ?_
