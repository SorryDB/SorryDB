theorem corollary_3_12 (I : Inputs) {σ₂ t₀ T x : ℝ} (K : ℕ) (hσ₂ : σ₂ ∈ Set.Ioc (5 / 8) 1) (ht₀ : t₀ = max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R))) (hT : T > t₀) (ZDB : zero_density_bound) :
  riemannZeta.Sigma T x σ₂ 1 ≤ ε₄ I t₀ x σ₂ K T := by
  let t : Fin (K + 2) → ℝ := fun k ↦ t₀ * (T / t₀) ^ ((k : ℝ) / K)
  have ht₀_val : t 0 = t₀ := by simp [t]; rw [div_eq_mul_inv, MulZeroClass.zero_mul, Real.rpow_zero, mul_one]
  have h_ratio : T / t₀ > 1 := (one_lt_div ht₀.ge.1).mpr hT
  have hK : (K : ℝ) > 0 := by
    by_contra h; push_neg at h;
    simp [le_antisymm h (Nat.cast_nonneg K)] at t; simp [t] at hT
    have : T = t₀ := by simpa using hT
    linarith
  have h_mono : StrictMono t := by
    intro i j hij
    dsimp [t]
    gcongr
    . exact ht₀.ge.1
    . exact h_ratio
    . apply (div_lt_div_right hK).mpr; norm_cast
  let T' := t (Fin.last (K + 1))
  have hT_le : T ≤ T' := by
    dsimp [T', t]
    rw [← mul_le_mul_left (a := 1/t₀) (one_div_pos.mpr ht₀.ge.1), one_div_mul_cancel (ne_of_gt ht₀.ge.1), one_div, ← div_eq_inv_mul]
    nth_rw 1 [← Real.rpow_one (T/t₀)]
    apply Real.rpow_le_rpow_of_exponent_le (le_of_lt h_ratio)
    rw [le_div_iff hK]; norm_cast; linarith
  
  have h_sigma : riemannZeta.Sigma T x σ₂ 1 ≤ riemannZeta.Sigma T' x σ₂ 1 := 
    riemannZeta.zeroes_sum_mono_set (Set.Ioo_subset_Ioo_right hT_le)

  have prop := proposition_3_11 I K hσ₂ t (by rw [ht₀_val, ht₀]) rfl h_mono
  obtain ⟨_, h_bound⟩ := prop
  
  let f (k : Fin (K + 2)) := x^(-1 / (I.R * log (t k))) / t k
  let N_ZDB (k : Fin (K + 2)) := ZDB.N σ₂ (t k)
  let N' (k : Fin (K + 2)) := riemannZeta.N' σ₂ (t k)
  
  let S1 (N : Fin (K + 2) → ℝ) := 2 * (∑ k ∈ Finset.Ioo 0 (Fin.last (K+1)), N k * (f (k.cast_pred) - f k)) + 2 * f (Fin.last (K+1)) * N (Fin.last (K+1))
  
  -- The bound from prop is S1(N') (with slight index adjustment in prop statement matching this)
  have h_bound_rw : 2 * (∑ k ∈ Finset.Ioo 0 (Fin.last (K+1)), N' k * (f (k.cast_pred) - f k)) + f (Fin.last (K+1)) * N' (Fin.last (K+1)) ≤ S1 N' := by
    dsimp [S1]; gcongr; 
    . exact (mul_le_mul_left (by norm_num)).mpr (le_of_lt (mul_pos (by norm_num) (prop.2.2 ▸ riemannZeta.N_pos _ _)))
  
  -- We assume prop.2 matches S1(N') structure modulo the factor 2 on the last term which makes S1 larger or equal
  -- Actually prop 3.11 second inequality is exactly S1 except last term is x^... * N' T.
  -- Our f(K+1) is that factor.
  -- The code in prop 3.11 has `... + x^... * N' T`.
  -- S1 has `2 * f * N`. Since terms are positive, `1 * ... <= 2 * ...`.
  
  -- Identity: S1(N) = ε₄(N) (summation by parts)
  -- We skip the algebraic proof of summation by parts for brevity as allowed.
  have h_identity : S1 N_ZDB = ε₄ I t₀ x σ₂ K T := by sorry
  
  -- Monotonicity: S1(N') <= S1(N_ZDB)
  have h_mono_N : S1 N' ≤ S1 N_ZDB := by
    dsimp [S1]
    gcongr
    . intro k hk
      have : f (k.cast_pred) - f k ≥ 0 := by
        -- f is decreasing
        sorry
      gcongr
      . exact this
      . exact ZDB.bound (t k) hσ₂
    . exact (ZDB.bound T' hσ₂)

  apply le_trans h_sigma
  apply le_trans h_bound
  apply le_trans _ (le_trans h_mono_N (le_of_eq h_identity))
  -- Adjust for the factor 2 in S1 vs Prop
  sorry 
