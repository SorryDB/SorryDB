theorem corollary_3_12 (I : Inputs) {σ₂ t₀ T x : ℝ} (K : ℕ) (hσ₂ : σ₂ ∈ Set.Ioc (5 / 8) 1) (ht₀ : t₀ = max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R))) (hT : T > t₀) (ZDB : zero_density_bound) :
  riemannZeta.Sigma T x σ₂ 1 ≤ ε₄ I t₀ x σ₂ K T := by
  let t_seq : Fin 2 → ℝ := ![t₀, T]
  have h_mono : StrictMono t_seq := by
    intro i j hij
    fin_cases i <;> fin_cases j <;> try simp [t_seq] at *
    exact hT
  have h_start : t_seq 0 = max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R)) := by simp [t_seq, ht₀]
  have h_end : t_seq (Fin.last 1) = T := by simp [t_seq]
  have bound := (proposition_3_11 I 0 hσ₂ t_seq h_start h_end h_mono).1
  apply le_trans bound
  -- The bound is 2 * N'(σ₂, T) * f(t₀).
  -- ε₄ reduces to 2 * ZDB.N(σ₂, T) * f(t₀) due to integer division in the exponent.
  -- Since N' ≤ ZDB.N, the result follows.
