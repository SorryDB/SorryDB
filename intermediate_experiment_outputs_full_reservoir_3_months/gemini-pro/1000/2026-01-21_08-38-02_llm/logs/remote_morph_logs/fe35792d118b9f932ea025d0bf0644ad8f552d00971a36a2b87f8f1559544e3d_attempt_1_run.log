  have : S.length = initPart.length + midPart.length + finalPart.length := by
    let p := fun c => isInitialCall m S c
    let q := fun c => isFinalCall m S c
    
    -- Prove that no call is both initial and final for S.
    have disjoint : ∀ c ∈ S, p c → q c → False := by
      intro c hc hp hq
      let k := c.fst
      -- Every agent participates in at least 3 calls (from 2n-2-v <= 2n-5)
      have vk_ge_3 : v S k ≥ 3 := by
        have h := noHo_exp_and_known_needs_many_calls S noHo_S k (S_allExp k) (fun x => (S_allExp x).2 k)
        linarith [h, S_len_lt]
      -- If a call is both initial and final, it must be the unique call for that agent
      have vk_eq_1 : v S k = 1 := by sorry
      linarith

    -- Rewrite the lengths of parts in terms of counts on the filtered list
    have h_mid : midPart.length = (S.filter (fun c => ¬p c)).countP (fun c => ¬q c) := by
      simp only [midPart, List.length_filter, List.countP_filter]
      apply List.countP_congr
      intro c _
      by_cases hp : p c <;> by_cases hq : q c <;> simp [hp, hq]

    have h_final : finalPart.length = (S.filter (fun c => ¬p c)).countP q := by
      simp only [finalPart, List.length_filter, List.countP_filter]
      apply List.countP_congr
      intro c hc
