  have : S.length = initPart.length + midPart.length + finalPart.length := by
    -- We first prove that no call can be both initial and final.
    have disjoint : ∀ c ∈ S, isInitialCall m S c → isFinalCall m S c → False := by
      intro c hc hI hF
      -- If c is both initial and final, then for k = c.fst:
      -- 1. c is the first call k participates in.
      -- 2. c is the last call k participates in.
      -- 3. Since noHo holds, k and c.snd cannot meet twice, so c appears uniquely for this pair.
      -- Thus k participates in exactly 1 call (c).
      have v_eq_1 : v m S c.fst = 1 := by sorry 
      -- We use the lemma relating valency to length.
      have : 2 * m - 2 - v m S c.fst ≤ S.length := 
        noHo_exp_and_known_needs_many_calls S noHo_S c.fst (S_allExp c.fst) (fun x => (S_allExp x).2)
      -- This implies 2m - 3 <= S.length.
      -- But S.length <= 2m - 5.
      -- 2m - 3 <= 2m - 5 implies -3 <= -5, which is false.
      linarith

    -- Now use list arithmetic.
    simp only [initPart, midPart, finalPart]
    -- Split S into (Initial) and (Not Initial)
    rw [List.length_eq_sum_filter_add_length_filter_not (fun c => isInitialCall m S c)]
    congr 1
    -- Split (Not Initial) into (Final) and (Not Final)
    -- We do this by observing (Not Initial) = (Not Initial & Final) ++ (Not Initial & Not Final)
    -- And since Final -> Not Initial (by disjointness), (Not Initial & Final) is just Final.
    rw [List.length_eq_sum_filter_add_length_filter_not (fun c => isFinalCall m S c)]
    congr 1
    · -- Prove: filter (!I & !F) = filter (!F) of filter (!I)
      -- Actually, the RHS of the split above is `filter (!Final) (filter (!Initial) S)`
      -- We want to match `midPart` which is `filter (!Initial & !Final) S`.
      -- These are equal.
      rw [List.filter_filter]
      apply List.filter_congr
      intro x _
      simp only [Bool.not_eq_true, Bool.and_eq_true, decide_eq_true_eq]
      -- Logical equivalence is trivial
      rfl
    · -- Prove: filter Final = filter (Final) of filter (!Initial) S
      -- Matches if Final -> !Initial.
      rw [List.filter_filter]
      apply List.filter_congr
      intro x hx
      simp only [Bool.not_eq_true, Bool.and_eq_true, decide_eq_true_eq]
      apply Iff.intro
      · intro hF
        constructor
        · by_contra hI
          exact disjoint x hx hI hF
        · exact hF
      · intro h; exact h.2
