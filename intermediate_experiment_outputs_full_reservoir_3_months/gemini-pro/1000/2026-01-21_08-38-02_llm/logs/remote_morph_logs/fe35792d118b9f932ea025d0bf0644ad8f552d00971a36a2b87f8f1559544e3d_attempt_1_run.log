theorem necessity :
    ∀ n > 4, ∀ σ : List (Call n), allExpert (after σ) → σ.length ≥ 2*n - 4 := by
  by_contra hyp
  simp only [gt_iff_lt, ge_iff_le, not_forall, not_le] at hyp
  -- FIXME later with newer lean: avoid `∃ _` proofs, `simp` does it but `simp only` does not.
  -- let φ n := ∃ (_ : 4 < n), ∃ σ : List (Call n), ∃ (h : allExpert (after σ)), σ.length < 2 * n - 4
  have := exists_to_minimal_exists _ hyp
  rcases this with ⟨m, ⟨le_m, ⟨S, S_allExp, S_len_lt⟩⟩, m_is_minimal⟩
  rw [← helper (by linarith)] at S_len_lt
  -- `m_is_minimal` is not yet exactly the right input for `noHo_of_minimal_expert_sequence`.
  have is_minimal_m : is_minimal m := by
    simp at m_is_minimal
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨le_m, S, ⟨S_allExp, S_len_lt⟩⟩
    · intro k k_lt_m four_lt_k σ σ_AllExp
      have := m_is_minimal k k_lt_m four_lt_k σ σ_AllExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  -- Now we can use the lemma.
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_lt S_allExp is_minimal_m

  -- 2.3 Graph Building -- TODO

  let initPart : List (Call m) :=
  S.filter (fun c => (isInitialCall S c))

  let midPart : List (Call m) :=
  S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))

  let finalPart : List (Call m) :=
  S.filter (fun c => (isFinalCall S c))


  have : S.length = initPart.length + midPart.length + finalPart.length := by
    -- We prove that no call can be both initial and final.
    have disjoint : ∀ c ∈ S, ¬(isInitialCall m S c ∧ isFinalCall m S c) := by
      intro c hc ⟨h_init, h_final⟩
      let u := c.fst
      -- c must be the unique call involving u.
      -- 1. c is initial for u -> c is first call of u.
      have hu_init := (initial_both_or_neither m S c hc).resolve_right (not_not_intro h_init) |>.1
      -- 2. c is final for u -> c is last call of u.
      have hu_final := (final_both_or_neither m S c hc).resolve_right (not_not_intro h_final) |>.1
      -- 3. By noHo S, calls involving u cannot repeat or overlap in a way that allows multiple distinct calls if first=last.
      -- Thus u participates in exactly one call (which is c).
      have v_u_eq_1 : v S u = 1 := sorry 
      -- 4. Contradiction with lower bound on calls.
      -- We know everyone knows u, and u is expert.
      have allKnow_u : allKnow (after S) u := sorry -- implied by allExpert
      have ineq := noHo_exp_and_known_needs_many_calls S noHo_S u (S_allExp u) allKnow_u
      rw [v_u_eq_1] at ineq
      linarith [S_len_lt]

    -- Now use disjointness to sum the lengths.
    simp only [initPart, midPart, finalPart]
    repeat rw [List.length_filter]
    have h_partition : S.countP (fun c => ¬(isInitialCall m S c) ∧ ¬(isFinalCall m S c)) =
        S.length - S.countP (fun c => isInitialCall m S c ∨ isFinalCall m S c) := by
      rw [← List.countP_not, List.countP_congr (fun _ _ => by rw [not_and, not_not, not_not])]
    rw [h_partition]
    rw [List.countP_or]
    · have h_inter_zero : S.countP (fun c => isInitialCall m S c ∧ isFinalCall m S c) = 0 :=
        List.countP_eq_zero.mpr disjoint
      rw [h_inter_zero, Nat.sub_zero]
      have h_le : S.countP (fun c => isInitialCall m S c) + S.countP (fun c => isFinalCall m S c) ≤ S.length := by
        rw [← List.countP_or, h_inter_zero, Nat.sub_zero]; apply List.countP_le_length
      omega
    · intro c _; apply disjoint c
