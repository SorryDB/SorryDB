    -- Now we use the disjointness to prove the length decomposition.
    -- S.length = count(Init) + count(Not Init)
    rw [List.length_filter_eq_length_filter_add_length_filter_not (isInitialCall m S)]
    congr 1
    -- count(Not Init) = count(Not Init & Final) + count(Not Init & Not Final)
    -- We define midPart as filter (Not Init & Not Final).
    -- We define finalPart as filter (Final).
    -- We need to show filter (Not Init & Final) is exactly finalPart.
    rw [List.length_filter_eq_length_filter_add_length_filter_not (isFinalCall m S)]
    rw [add_comm]
    congr 1
