    -- Equivalence: isFinalCall x <-> (¬isInitialCall x ∧ isFinalCall x)
    -- This holds if isFinalCall x -> ¬isInitialCall x, which is our disjointness lemma.
    rw [Bool.and_iff_right_iff_imp]
    intro hFin
    rw [Bool.decide_eq_true] at hFin
    rw [Bool.decide_eq_true, Bool.not_eq_true']
    by_contra hInit
    exact disjoint x hx ⟨hInit, hFin⟩
