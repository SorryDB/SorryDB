  -- We need the number of `d k = true` to be exactly `n`.
  -- We can reverse cycles in the Eulerian orientation to adjust the count.
  
  have exists_balanced_orientation : ∃ d : Fin (2 * n) → Bool, 
      (∀ i, (List.range (2 * n)).countP (fun k => if d k then c (2 * k + 1) = i else c (2 * k) = i) = 2) ∧
      (Finset.univ.filter (fun k => d k)).card = n := by
