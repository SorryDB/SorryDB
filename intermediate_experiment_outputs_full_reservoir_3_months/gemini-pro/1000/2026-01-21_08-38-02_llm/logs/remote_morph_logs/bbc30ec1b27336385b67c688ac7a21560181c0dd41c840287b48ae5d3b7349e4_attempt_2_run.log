import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let N := 4 * n
  let M := 2 * n
  -- We consider pairs {k, N - 1 - k} for k in 0..M-1.
  -- These pairs partition the set 0..N-1.
  -- Each pair sums to N - 1. In terms of values +1, sum is N + 1.
  -- Total sum is N(N+1)/2. Half is N(N+1)/4.
  -- If we pick exactly one pair for each k? No, we pick n pairs.
