  -- We then adjust the orientation to satisfy the sum constraint.
  
  let edges : List (Fin n × Fin n) := (List.range (2 * n)).map fun k => (c (2 * k), c (2 * k + 1))
  
  -- The graph is 4-regular (each vertex has degree 4 in the multigraph).
  have h_deg : ∀ i, (edges.map Prod.fst ++ edges.map Prod.snd).count i = 4 := by
    intro i
