  -- We represent the orientation by a boolean `d k` for each pair `k`.
  -- `d k = true` means we pick `2k+1` (edge oriented c(2k) -> c(2k+1)).
  -- `d k = false` means we pick `2k` (edge oriented c(2k+1) -> c(2k)).
  have exists_orientation : ∃ d : Fin (2 * n) → Bool, ∀ i, 
      (List.range (2 * n)).countP (fun k => if d k then c (2 * k + 1) = i else c (2 * k) = i) = 2 := by
    -- Standard result: regular graph of even degree has an Eulerian orientation.
    sorry

  obtain ⟨d₀, hd₀⟩ := exists_orientation

  -- We need to satisfy the sum constraint.
