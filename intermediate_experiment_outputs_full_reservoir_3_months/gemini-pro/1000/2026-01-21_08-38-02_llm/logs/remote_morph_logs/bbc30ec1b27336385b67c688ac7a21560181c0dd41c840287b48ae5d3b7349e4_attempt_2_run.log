      simp
      ring
    rw [h_compl]
    have sum_univ : ∑ i : Fin (4 * n), (i : ℕ) = ∑ i ∈ S, (i : ℕ) + ∑ i ∈ Sᶜ, (i : ℕ) :=
      (Finset.sum_add_sum_compl S _).symm
    rw [hS_sum] at sum_univ
    have h_sc_sum : ∑ i ∈ Sᶜ, (i : ℕ) = target := by
      rw [h_target] at sum_univ
      linarith
    rw [h_sc_sum]
    simp [target]
  · -- Color condition
    exact hS_color
