  · -- Translate diff d = 0 to sum equality
    rw [←Finset.sum_filter_add_sum_filter_not (to_set d) (fun i => (i : ℕ) + 1)]
    suffices ∑ i ∈ to_set d, ((i : ℕ) + 1) - ∑ i ∈ (to_set d)ᶜ, ((i : ℕ) + 1) = 0 by omega
    -- The sum difference is sum of (val_pick - val_not_pick) = sum (±1) = diff d
    sorry
  · intro i
    convert hd_deg i
    ext x; simp [to_set, deg]
