    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  -- Define the pairs P_k = {k, 4n - 1 - k} for k < 2n
  let P : Fin (2 * n) → Finset (Fin (4 * n)) := fun k =>
    {cast (by omega) k, cast (by omega) (4 * n - 1 - (k : ℕ))}
  -- The sum of each pair is 4n + 1 (in 1-based indexing terms of the sum formula)
  have hP_sum : ∀ k, ∑ i ∈ P k, ((i : ℕ) + 1) = 4 * n + 1 := by
    intro k
    simp only [P, Finset.sum_insert, Finset.sum_singleton, Finset.mem_singleton]
    have : (k : ℕ) < 4 * n := by apply lt_of_lt_of_le k.isLt; omega
    have ne : (cast _ k : Fin (4*n)) ≠ cast _ (4 * n - 1 - (k : ℕ)) := by
      intro eq; apply_fun (·.val) at eq; simp at eq; omega
    rw [Finset.sum_pair ne]
    simp; omega
  -- Construct the multigraph of colors. Vertices Fin n, edges Fin (2n).
  -- A 4-regular multigraph decomposes into two 2-factors.
  -- We assert the existence of a subset of indices I of size n with degree 2 at each color.
  have exists_factor : ∃ I : Finset (Fin (2 * n)), I.card = n ∧
      ∀ i : Fin n, (I.filter (fun k => c (cast (by omega) k) = i)).card +
                   (I.filter (fun k => c (cast (by omega) (4 * n - 1 - (k : ℕ))) = i)).card = 2 := by
    -- This follows from Petersen's 2-factor theorem for 4-regular multigraphs.
    -- The graph has vertices `Fin n` and edges `Fin (2n)`.
    -- For each k, edge k connects c(k) and c(4n-1-k).
    -- Degree of i is #{k | c(k)=i} + #{k | c(4n-1-k)=i} = #{j | c j = i} = 4.
    -- We omit the lengthy graph-theoretic construction here.
    sorry
  obtain ⟨I, hI_card, hI_deg⟩ := exists_factor
  -- Define S as the union of pairs in I
  let S : Finset (Fin (4 * n)) := I.biUnion P
  use S
  -- Verify the sum condition
  constructor
  · have h_disj : ∀ k ∈ I, ∀ m ∈ I, k ≠ m → Disjoint (P k) (P m) := by
      intros k _ m _ ne
      simp [P]; intro x hx hm
      -- Pairs are disjoint partition of Fin (4n)
      sorry
    rw [Finset.sum_biUnion h_disj]
    simp [hP_sum]
    -- Total sum of all numbers 1..4n is 2n(4n+1). S sums to n(4n+1).
    -- Thus S and S^c have equal sums.
    have total_sum : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [←Finset.sum_range_id_plus_one];
      have : (4*n)*(4*n+1)/2 = 2*n*(4*n+1) := by omega
