/-- Collect formulas in a pre-state. The non-loaded part of Λ(π) in paper. -/
def PreState.forms : PreState bt → List Formula
| .fromRoot π => PreStateP.forms π
| .fromMod _ _ π => PreStateP.forms π
where
  PreStateP.forms {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → List Formula
  | .edge _ _ π => (Match.btAt m).1.2.1.1 ++ (Match.btAt m).1.2.1.2.1 ++ PreStateP.forms π
  | .stopLeaf _ => (Match.btAt m).1.2.1.1 ++ (Match.btAt m).1.2.1.2.1
  | .stopAtM _ _ => (Match.btAt m).1.2.1.1 ++ (Match.btAt m).1.2.1.2.1

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms : PreState bt → List NegLoadFormula
| .fromRoot π => PreStateP.lforms π
| .fromMod _ _ π => PreStateP.lforms π
where
  PreStateP.lforms {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → List NegLoadFormula
  | .edge _ _ π => getLoad (Match.btAt m).1.2.1 ++ PreStateP.lforms π
  | .stopLeaf _ => getLoad (Match.btAt m).1.2.1
  | .stopAtM _ _ => getLoad (Match.btAt m).1.2.1
  getLoad (X : Sequent) : List NegLoadFormula :=
    match X.2.2 with | some (Sum.inl f) => [f] | some (Sum.inr f) => [f] | _ => []

def PreState.last : PreState bt → Sequent
| .fromRoot π => PreStateP.last π
| .fromMod _ _ π => PreStateP.last π
where
  PreStateP.last {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → Sequent
  | .edge _ _ π => PreStateP.last π
  | .stopLeaf _ => (Match.btAt m).1.2.1
  | .stopAtM _ _ => (Match.btAt m).1.2.1

