def PreStateP.last {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → Sequent
| .stopLeaf _ => (m.btAt).1.2.1
| .stopAtM _ _ => (m.btAt).1.2.1
| .edge _ _ tail => tail.last

def PreStateP.forms {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → List Formula
| .stopLeaf _ => (m.btAt).1.2.1.L.map (·.unload) ++ (m.btAt).1.2.1.R.map (·.unload)
| .stopAtM _ _ => (m.btAt).1.2.1.L.map (·.unload) ++ (m.btAt).1.2.1.R.map (·.unload)
| .edge _ _ tail => (m.btAt).1.2.1.L.map (·.unload) ++ (m.btAt).1.2.1.R.map (·.unload) ++ tail.forms

def PreState.forms : PreState bt → List Formula
| .fromRoot p => p.forms
| .fromMod _ _ p => p.forms

def PreState.lforms : PreState bt → List NegLoadFormula := sorry

def PreState.last : PreState bt → Sequent
| .fromRoot p => p.last
| .fromMod _ _ p => p.last

