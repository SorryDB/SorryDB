```lean
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  ext i j
  simp only [inertiaTensor, solidSphere, Nat.succ_eq_add_one, LinearMap.coe_mk, AddHom.coe_mk,
    ContMDiffMap.coeFn_mk, Matrix.smul_apply, Matrix.one_apply, smul_eq_mul, Pi.smul_apply,
    ContMDiffMap.coe_smul, RingHom.id_apply]
  rw [integral_const_mul]
  · by_cases h : i = j
    · subst h
      simp only [if_true, mul_one, sub_self, mul_zero, sub_zero]
      rw [Space.integral_closedBall_norm_sq, Space.integral_closedBall_coord_sq]
      have hV : (@volume (Space 3) measureSpaceOfInnerProductSpace).real (Metric.closedBall 0 R) ≠ 0 := by
        apply Space.volume_closedBall_neq_zero
        exact lt_of_le_of_ne R.2 (Ne.symm (by simpa using hr))
      field_simp
      ring
    · simp only [h, if_false, mul_zero, sub_zero]
      rw [Space.integral_closedBall_coord_mul_coord]
      · simp
      · exact h
  · apply ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
    fun_prop
```
