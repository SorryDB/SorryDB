  have h_card : (reach S).card ≤ S.length + 1 := by
    induction S with
    | nil => simp [reach]
    | cons c S ih =>
      simp only [reach, List.foldr_cons]
      split_ifs with h_in
      · rw [Finset.card_union_eq_card_add_card_sub_card_inter]
        have h_inter : 1 ≤ (reach S ∩ {c.fst, c.snd}).card := by
          rw [Finset.one_le_card]
          rcases h_in with hf | hs
          · exact ⟨c.fst, by simp [hf]⟩
