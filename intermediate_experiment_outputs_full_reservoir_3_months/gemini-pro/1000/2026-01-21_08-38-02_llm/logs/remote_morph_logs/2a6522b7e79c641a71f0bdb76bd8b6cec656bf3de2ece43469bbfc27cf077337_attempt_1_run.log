```lean
lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  let G := Graph.from_list n S
  have h_conn : Connected G := connected_of_expert S k h
  have h_edges := Graph.min_edges_connected h_conn
  simp [Graph.from_list] at h_edges
  exact h_edges
```
