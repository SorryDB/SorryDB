lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  rcases n with _ | n
  · simp
  let G := SimpleGraph.fromEdgeList (S.map (λ c => (c.fst, c.snd)))
  have h_conn : G.Connected := by
    rw [SimpleGraph.Connected]
    intro x y
    have h_reach : ∀ i j, i ∈ after S j → G.Reachable i j := by
      intro i j hij
      induction S using List.reverseRecOn generalizing j with
      | nil => simp [after, initialState] at hij; subst hij; exact SimpleGraph.Reachable.refl _
      | cons xs c ih =>
        simp only [after, makeCalls_append, makeCalls] at hij
        rcases c with ⟨u, v⟩
        simp at hij
        let h_adj : G.Adj u v := by
          apply SimpleGraph.fromEdgeList_adj.mpr
          use (u, v)
          simp; exact List.mem_append_of_mem_last _ rfl
        split_ifs at hij with hu hv
        · rcases hij with h | h
          · exact (ih _ h).trans h_adj.reachable
          · exact (ih _ h).trans h_adj.symm.reachable
        · rcases hij with h | h
          · exact (ih _ h).trans h_adj.symm.reachable
          · exact (ih _ h).trans h_adj.reachable
        · exact ih _ hij
    exact (h_reach _ _ (h x)).trans (h_reach _ _ (h y)).symm
  rcases h_conn.exists_spanningTree with ⟨T, hT⟩
  rw [← SimpleGraph.IsTree.card_edgeFinset hT.2, Nat.add_sub_cancel]
  refine le_trans (Finset.card_le_of_subset hT.1) ?_
  trans (S.map (λ c => Sym2.mk (c.fst, c.snd))).toFinset.card
  · refine Finset.card_le_of_subset ?_
    intro e he
    rw [List.mem_toFinset]
    simp [G, SimpleGraph.fromEdgeList] at he
    rcases he with ⟨a, b, hab, he⟩
    subst he
    use (a, b)
    simp [hab, Sym2.eq_iff]
  · apply List.toFinset_card_le
