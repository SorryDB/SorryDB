lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  let Rel (u v : Fin n) : Prop := ∃ c ∈ S, c.fst = u ∧ c.snd = v ∨ c.fst = v ∧ c.snd = u
  let G : SimpleGraph (Fin n) := SimpleGraph.fromRel Rel
  have h_conn : G.Connected := by
    rw [SimpleGraph.Connected]
    intro u v
    have claim : ∀ (s : Fin n → Finset (Fin n)) (L : List (Call n)),
        (∀ i j, j ∈ s i → G.Reachable j i) →
        ∀ i j, j ∈ (makeCalls s L) i → G.Reachable j i := by
      intro s L H i j hj
      induction L generalizing s with
      | nil => exact H i j hj
      | cons c cs ih =>
        simp only [makeCalls, List.foldl_cons] at hj
        apply ih _ _ _ hj
        intro x y hxy
        simp only [update] at hxy
        split_ifs at hxy with h_if
        · simp only [Finset.mem_union] at hxy
          have h_adj : G.Adj c.fst c.snd := SimpleGraph.fromRel_adj.mpr ⟨c, List.mem_cons_self _ _, by simp⟩
          rcases hxy with h|h
          · exact H x y h
          · rcases h_if with rfl | rfl
            · exact (H c.snd y h).trans (G.reachable_of_adj h_adj.symm)
            · exact (H c.fst y h).trans (G.reachable_of_adj h_adj)
        · exact H x y hxy
    have h_reach : ∀ i, G.Reachable i k := by
      intro i
      apply claim (initialState n) S (fun x y h => by simp [initialState] at h; subst h; rfl)
      exact h i
    exact (h_reach u).trans (h_reach v).symm
  refine le_trans h_conn.card_edge_le ?_
  let f : S.toFinset → G.edgeFinset := fun ⟨c, hc⟩ =>
    ⟨s(c.fst, c.snd), SimpleGraph.fromRel_adj.mpr ⟨c, (List.mem_toFinset.mp hc), by simp⟩⟩
  calc
    G.edgeFinset.card ≤ S.toFinset.card := Finset.card_le_card_of_surjective f (by
      rintro ⟨e, he⟩
      obtain ⟨c, hc, rfl | rfl⟩ := SimpleGraph.fromRel_adj.mp he
      · exact ⟨⟨c, List.mem_toFinset.mpr hc⟩, rfl⟩
      · exact ⟨⟨c, List.mem_toFinset.mpr hc⟩, Sym2.eq_swap⟩)
    _ ≤ S.length := List.toFinset_card_le S
