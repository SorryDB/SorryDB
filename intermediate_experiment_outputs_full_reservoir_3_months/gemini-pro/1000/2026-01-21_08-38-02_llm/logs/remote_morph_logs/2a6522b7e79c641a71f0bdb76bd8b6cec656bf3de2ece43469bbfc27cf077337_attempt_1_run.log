        have h_pair : ({c.fst, c.snd} : Finset (Fin n)).card ≤ 2 := Finset.card_le_two
        linarith
      · linarith

  have h_sub : after S k ⊆ reach S := by
    -- We prove a stronger generalized invariant:
    -- For any state s and targets T, (\bigcup_{t \in T} makeCalls s S t) \subseteq \bigcup_{x \in foldr ... T S} s x
