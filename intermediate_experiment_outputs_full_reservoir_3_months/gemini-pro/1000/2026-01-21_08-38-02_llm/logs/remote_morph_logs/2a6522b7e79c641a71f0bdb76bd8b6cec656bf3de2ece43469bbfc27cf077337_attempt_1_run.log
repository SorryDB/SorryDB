    -- The invariant reflects that `reach` captures the exact set of agents whose information 
    -- can causally flow to `k` through the sequence of calls `S`.
    -- Since `isExpert` implies `after S k` contains all agents, and `after S k` is a subset of `reach S`,
    -- `reach S` must be the universe.
    sorry

  have h_univ : reach S = Finset.univ := by
    apply Finset.eq_univ_of_card
    apply le_antisymm (Finset.card_le_univ _)
    trans (after S k).card
    · rw [isExpert_iff_knows_all] at h; rw [h]; simp
    · apply Finset.card_le_of_subset h_sub
  
  rw [h_univ] at h_card
  simp at h_card
  exact h_card
