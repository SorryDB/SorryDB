lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  let G := SimpleGraph.fromRel (fun i j : Fin n => ∃ c ∈ S, c.fst = i ∧ c.snd = j ∨ c.fst = j ∧ c.snd = i)
  have h_conn : G.Connected := by
    rw [SimpleGraph.connected_iff_exists_forall_reachable]
    have : Nonempty (Fin n) := ⟨k⟩
    use k
    intro j
    -- Information flow from j to k implies a path in G
    suffices ∀ S', (∀ c ∈ S', c ∈ S) → ∀ x y, (after S') x y → G.Reachable x y by
      exact this S (fun c hc => hc) k j (h j)
    intro S' h_sub x y h_knows
    induction S' using List.reverseRecOn generalizing x y
    · simp [after, initialState] at h_knows; subst h_knows; exact Relation.ReflTransGen.refl
    · next S' c ih =>
      rw [after, makeCalls_append] at h_knows
      -- We assume standard gossip logic: x knows y after c=(u,v) iff x knew y before or (x=u and v knew y) or (x=v and u knew y)
      -- Since specific definitions of 'step' are hidden, we rely on the structural property that information only flows across calls.
      have path_in_prev : G.Reachable x y ∨ (∃ z, (c.fst = x ∧ c.snd = z ∨ c.fst = z ∧ c.snd = x) ∧ G.Reachable z y) := by
        -- This step formally requires unfolding 'step'. Assuming standard propagation:
        sorry
      rcases path_in_prev with h_old | ⟨z, h_edge, h_path⟩
      · exact h_old
      · have hc : c ∈ S := h_sub c (List.mem_append_right S' (List.mem_singleton_self c))
        apply Relation.ReflTransGen.tail h_path
        use c; simp [hc]; tauto
  have h_edges : G.edgeFinset.card ≤ S.length := by
    let f : Call n → Sym2 (Fin n) := fun c => Sym2.mk (c.fst, c.snd)
    calc G.edgeFinset.card
      _ ≤ (S.map f).toFinset.card := by
        apply Finset.card_le_card_of_subset
        intro e he
        simp only [G, SimpleGraph.fromRel_edgeFinset, Finset.mem_image, List.mem_toFinset, List.mem_map] at he ⊢
        rcases he with ⟨x, y, ⟨c, hc, hxy⟩, he⟩
        use c, hc
        rw [← he, Sym2.eq_iff]; exact hxy
      _ ≤ (S.map f).length := List.toFinset_card_le _
      _ = S.length := List.length_map _ _
  have := SimpleGraph.Connected.card_le_card_edges_add_one h_conn
  rw [Fintype.card_fin] at this
  linarith
