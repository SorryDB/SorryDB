lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  let G := SimpleGraph.fromEdgeList (S.map (fun c => (c.1, c.2)))
  have h_conn : G.Connected := by
    -- If the graph is not connected, there exists a component C not containing k.
    -- Agents in C cannot communicate secrets to k, contradicting h.
    sorry
  cases n with
  | zero => simp
  | succ n =>
    rw [Nat.succ_sub_one]
    have ⟨T, _, hT_sub⟩ := G.exists_spanningTree h_conn
    -- A spanning tree on n + 1 vertices has n edges.
