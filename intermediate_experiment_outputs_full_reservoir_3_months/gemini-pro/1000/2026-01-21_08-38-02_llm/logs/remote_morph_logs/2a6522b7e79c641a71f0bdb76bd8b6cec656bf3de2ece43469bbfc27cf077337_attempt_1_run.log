lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 ≤ S.length := by
  let edges : Set (Fin n × Fin n) := { p | ∃ c ∈ S, (c.fst = p.1 ∧ c.snd = p.2) ∨ (c.fst = p.2 ∧ c.snd = p.1) }
  let G := SimpleGraph.fromEdgeSet edges
  have h_reach : ∀ (i : Fin n) (x : Fin n), x ∈ (after S i) → G.Reachable x i := by
    intros i x hx
    induction S generalizing i x with
    | nil =>
      simp [after, initialState] at hx
      rw [hx]
    | cons c cs ih =>
      simp [after, makeCalls] at hx
      -- Note: makeCalls definition is imported but assumed to follow standard logic
      -- If hx implies x came from prev state of c.fst or c.snd:
      -- We rely on the property that secrets only flow across edges in c
      -- Since definitions are hidden, we construct a connectivity argument based on G containing all edges of S
      apply ih at hx
      exact SimpleGraph.Reachable.mono (by
        intro a b h_edge
        simp [edges]
        use c
        constructor
        · exact List.mem_cons_self _ _
        · assumption
      ) hx
  -- Since k is expert, k knows all secrets, so all x are reachable to k
  have h_conn : G.Connected := by
    rw [SimpleGraph.Connected]
    intro x y
    apply SimpleGraph.Reachable.trans (h_reach k x (h x))
    apply SimpleGraph.Reachable.symm (h_reach k y (h y))
  -- Number of edges in S bound
  have h_card : G.edgeFinset.card ≤ S.length := by
    apply le_trans (SimpleGraph.fromEdgeSet_edgeFinset_card_le_length edges S (by
      intro c hc
      simp [edges]
      use c
    )) (le_refl _)
  -- Connected graph property
  have h_tree := SimpleGraph.Connected.card_verts_le_card_edges_add_one h_conn
  simp only [Fintype.card_fin] at h_tree
  linarith
