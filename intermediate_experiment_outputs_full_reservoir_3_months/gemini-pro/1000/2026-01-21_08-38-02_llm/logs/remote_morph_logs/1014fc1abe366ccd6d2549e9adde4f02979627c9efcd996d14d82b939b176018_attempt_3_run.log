section Pi

variable {őĻ : Type*} {Y : őĻ ‚Üí Type*} [(i : őĻ) ‚Üí DiffeologicalSpace (Y i)]
  {X : Type*} [DiffeologicalSpace X] {f : X ‚Üí ((i : őĻ) ‚Üí Y i)}

theorem dsmooth_pi_iff : DSmooth f ‚ÜĒ ‚ąÄ i, DSmooth fun x ‚Ü¶ f x i := by
  simp_rw [dsmooth_iff_coinduced_le,Pi.diffeologicalSpace,le_iInf_iff]
  refine forall_congr' fun i ‚Ü¶ ?_
  rw [‚ÜźDiffeologicalSpace.coinduced_le_iff_le_induced,DiffeologicalSpace.coinduced_compose]; rfl

@[fun_prop]
theorem dsmooth_pi (h : ‚ąÄ i, DSmooth fun a ‚Ü¶ f a i) : DSmooth f :=
  dsmooth_pi_iff.2 h

@[fun_prop]
theorem dsmooth_apply (i : őĻ) : DSmooth fun p : (i : őĻ) ‚Üí Y i ‚Ü¶ p i :=
  dsmooth_pi_iff.1 dsmooth_id i

theorem isPlot_pi_iff {n} {p : Eucl n ‚Üí ((i : őĻ) ‚Üí Y i)} :
    IsPlot p ‚ÜĒ ‚ąÄ i, IsPlot fun x ‚Ü¶ p x i := by
  simp_rw [isPlot_iff_dsmooth,dsmooth_pi_iff]

private lemma dTopCompatible_fin (n : ‚Ąē) (Y : Fin n ‚Üí Type*)
    [(i : Fin n) ‚Üí DiffeologicalSpace (Y i)] [(i : Fin n) ‚Üí TopologicalSpace (Y i)]
    [(i : Fin n) ‚Üí LocallyCompactSpace (Y i)] [(i : Fin n) ‚Üí DTopCompatible (Y i)] :
    DTopCompatible ((i : Fin n) ‚Üí Y i) := by
  induction n with
  | zero =>
    refine ‚ü®?_‚ü©; rw [dTop_top]
    exact (Unique.default_eq _).trans (Unique.default_eq _).symm
  | succ n ih =>
    let Y' (i : Fin n) := Y i.succ
    haveI := ih Y'
    let e := Homeomorph.finSuccPi Y
    have he : DSmooth e := by
      rw [dsmooth_prod_mk]; exact ‚ü®dsmooth_apply 0, dsmooth_pi fun i ‚Ü¶ dsmooth_apply i.succ‚ü©
    have he' : DSmooth e.symm := by
      rw [dsmooth_pi_iff]; intro i; refine Fin.cases ?_ ?_ i
      ¬∑ exact dsmooth_fst
      ¬∑ intro i; exact (dsmooth_apply i).comp dsmooth_snd
    refine ‚ü®?_‚ü©
    rw [dTop_induced_comm he.isDInducing]
    haveI : LocallyCompactSpace (Y 0) DTop := dTop_eq (Y 0) ‚Ėł inferInstance
    rw [dTop_prod_eq_prod_dTop_of_locallyCompact_left, dTop_eq (Y 0), dTop_eq ((i : Fin n) ‚Üí Y' i),
      ‚Üźe.induced_eq]

/-
TODO: mathematically, this follows easily from
`dTop_prod_eq_prod_dTop_of_locallyCompact_left`, but I'm not yet sure how to best formalise
that in lean. -/
instance [Fintype őĻ] [(i : őĻ) ‚Üí TopologicalSpace (Y i)] [(i : őĻ) ‚Üí LocallyCompactSpace (Y i)]
    [(i : őĻ) ‚Üí DTopCompatible (Y i)] : DTopCompatible ((i : őĻ) ‚Üí Y i) := ‚ü®by
  let e := Homeomorph.piCongrLeft (fun i ‚Ü¶ Y i) (Fintype.equivFin őĻ)
  have he : DSmooth e := dsmooth_pi fun i ‚Ü¶ dsmooth_apply _
  have he' : DSmooth e.symm := dsmooth_pi fun i ‚Ü¶ dsmooth_apply _
