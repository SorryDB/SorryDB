theorem dsmooth_pi_iff : DSmooth f ‚ÜĒ ‚ąÄ i, DSmooth fun x ‚Ü¶ f x i := by
  simp_rw [dsmooth_iff_coinduced_le,Pi.diffeologicalSpace,le_iInf_iff]
