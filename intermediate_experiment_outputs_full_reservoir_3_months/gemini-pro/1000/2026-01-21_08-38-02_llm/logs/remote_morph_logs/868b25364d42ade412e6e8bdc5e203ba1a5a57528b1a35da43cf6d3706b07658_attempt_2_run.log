def PreStateP.forms {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → List Formula
  | .stopLeaf _ => (Match.btAt m).1.2.1.1
  | .stopAtM e _ => (Match.btAt m).1.2.1.1
  | .edge _ _ tail => (Match.btAt m).1.2.1.1 ++ tail.forms

/-- Collect formulas in a pre-state. The non-loaded part of Λ(π) in paper. -/
def PreState.forms {pos} {bt : BuildTree pos} : PreState bt → List Formula
  | .fromRoot p => p.forms
  | .fromMod _ _ p => p.forms

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms : PreState bt → List NegLoadFormula := sorry

def PreState.last : PreState bt → Sequent := sorry

/-- TODO Lemma 6.14 -/
lemma PreState.formsCases {π : PreState bt} : φ ∈ π.forms →
      (φ.basic ∧ φ ∈ π.last) -- NOTE: the `∈` is not dealing with loaded formulas here!
    ∨ (sorry) := by -- TODO how to say `φ is principal later?`
    -- Or can we say something else / phrase it as closure condition about π.forms directly?
  sorry

/-- WIP Lemma 6.15 (unloaded case only) -/
lemma PreState.pdlFormCase {π : PreState bt} : ¬ α.isAtomic → (~⌈α⌉φ) ∈ π.forms →
    ∃ Xδ ∈ H α, Xδ.1 ∪ [~ Formula.boxes δ φ] ⊆ π.forms := by
  intro na in_f
  induction π with
  | fromRoot p =>
    induction p with
    | stopLeaf h =>
      -- If we stop at a leaf, it is either a repeat or an open branch.
      -- Since the strategy is winning, any potential eventuality like ~[α]φ must be fulfilled.
      sorry
    | stopAtM e m =>
      -- If we stop at M, the node must be basic (or saturated).
      -- Since α is not atomic, it must have been reduced before this point.
      sorry
    | edge e n tail ih =>
      -- If the edge reduces ~[α]φ, we find the resolvent in the next state.
      -- If not, it persists and we use the IH.
      sorry
  | fromMod e m p ih =>
    -- Similar logic for paths starting after a modal step.
    sorry
