@[grind]
theorem mem_addLabel (t : LabelledTree α) (label : α) (y : α) :
    y ∈ LabelledTree.addLabel t label ↔ y ∈ t ∨ y = label := by
  induction t <;> simp [LabelledTree.addLabel] <;> split_ifs <;> simp [LabelledTree.mem, *] <;> try tauto
  rename_i x; by_cases label = x <;> simp_all; tauto

def buildBST : List α → LabelledTree α
  | [] => leaf sorry
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    simp [buildBST]
    generalize leaf x = t
    have : IsOrdered t := by simp [←(by assumption : t = leaf x), IsOrdered]
    induction xs generalizing t with
    | nil => exact this
    | cons y ys ih => apply ih; apply ordered_addLabel _ _ this

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered _)]
    simp [buildBST]
    generalize leaf x = t
    have : ∀ z, z ∈ t ↔ z = x := by simp [←(by assumption : t = leaf x), LabelledTree.mem]
    induction xs generalizing t with
    | nil => simp [this, eq_comm]
    | cons y ys ih =>
      simp; rw [ih]
      · simp [mem_addLabel]; tauto
      · intros; rw [mem_addLabel, this]; tauto
```
