theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  have mem_addLabel (t : LabelledTree α) (label : α) (y : α) :
      y ∈ LabelledTree.addLabel t label ↔ y = label ∨ y ∈ t := by
    induction t <;> dsimp [LabelledTree.addLabel] <;> split_ifs <;> simp [LabelledTree.mem, *] <;> tauto
  induction t with
  | leaf x =>
    dsimp [LabelledTree.addLabel]
    split_ifs <;> simp [IsOrdered, *]
    · exact ⟨le_refl _, le_of_lt ‹_›⟩
    · exact ⟨le_of_lt ‹_›, le_refl _⟩
  | node v l r ihl ihr =>
    simp [IsOrdered] at h ⊢
    split_ifs with h_le
    · refine ⟨?_, h.2.1, ihl h.2.2.1, h.2.2.2.1, ?_⟩
      · intro x hx; rw [mem_addLabel] at hx; rcases hx with rfl | hx
        · exact h_le
        · exact h.1 x hx
      · rw [mem_addLabel]; right; left; exact h.2.2.2.2
    · refine ⟨h.1, ?_, h.2.2.1, ihr h.2.2.2.1, ?_⟩
      · intro x hx; rw [mem_addLabel] at hx; rcases hx with rfl | hx
        · exact le_of_not_le h_le
        · exact h.2.1 x hx
      · rw [mem_addLabel]; right; right; exact h.2.2.2.2

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x => simp [fastCheckMem]
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    dsimp [fastCheckMem]
    split_ifs with h_eq
    · simp [h_eq]; rw [h_eq] at h; tauto
    · rw [ihl h.2.2.1]; constructor <;> intro H
