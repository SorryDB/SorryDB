    · intro h; rcases h with rfl | rfl; simp
    · intro h; rcases h with rfl | rfl; simp
  | node v l r ihl ihr =>
    simp [LabelledTree.addLabel]
    split_ifs <;> simp [LabelledTree.mem, ihl, ihr, or_assoc, or_left_comm]

