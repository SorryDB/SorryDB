      · cases H; assumption; have := h.2.1 _ ‹_›; linarith
    · rw [ihr h.2.2.2.1]; constructor <;> intro H
      · right; exact H
      · cases H; have := h.1 _ ‹_›; have : v < label := lt_of_le_of_ne (le_of_not_lt ‹_›) (Ne.symm h_eq); linarith; assumption

