        · exact h_le
        · exact h.1 x hx
      · rw [mem_addLabel_iff]
        cases h.2.2.2.2 with
        | inl hv => left; right; exact hv
        | inr hv => right; exact hv
    · simp [IsOrdered] at h ⊢
      refine ⟨h.1, ?_, h.2.2.1, ihr h.2.2.2.1, ?_⟩
      · intro x hx
        rw [mem_addLabel_iff] at hx
        rcases hx with rfl | hx
        · exact le_of_not_ge h_le
        · exact h.2.1 x hx
      · rw [mem_addLabel_iff]
