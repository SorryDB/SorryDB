lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  have h1 : ∀ μ, ∂_ μ ε ∘ Λ = ∑ ρ, Λ⁻¹.1 ρ μ • ∂_ ρ (fun x => ε (Λ x)) := by
    intro μ
    ext x
    rw [SpaceTime.deriv_comp_linearMap]
    simp only [Lorentz.Vector.apply_basis_eq_sum, map_sum, map_smul,
      ContinuousLinearMap.coe_smul', Pi.smul_apply, ContinuousLinearMap.sum_apply,
      Finset.sum_smul, smul_smul]
    rw [Finset.sum_comm]
    simp only [← Matrix.mul_apply, Matrix.mul_eq_one_comm.mp (Lorentz.Group.mul_inv Λ),
      Matrix.one_apply, ite_smul, one_smul, zero_smul, Finset.sum_ite_eq,
      Finset.mem_univ, if_true]
  calc deriv (Λ • A) ε
    _ = ∑ μ, ∑ ν, (SpaceTime.distDeriv μ (Λ • A) ε ν) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
        rw [deriv]; simp
    _ = ∑ μ, ∑ ν, (∑ ρ, ∑ κ, (Λ⁻¹.1 ρ μ) * (Λ.1 ν κ) *
        (SpaceTime.distDeriv ρ A (fun x => ε (Λ x)) κ)) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
        refine Finset.sum_congr rfl (fun μ _ => ?_)
        refine Finset.sum_congr rfl (fun ν _ => ?_)
        simp only [SpaceTime.distDeriv, Distribution.action_apply]
        rw [h1, map_sum, map_smul]
        simp only [Lorentz.Vector.apply_smul, Lorentz.Vector.apply_sum, smul_eq_mul, neg_smul,
          Finset.sum_neg_distrib]
        rw [Finset.sum_comm]
        apply Finset.sum_congr rfl
