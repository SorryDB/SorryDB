  simp only [LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk', map_smul,
    Finset.sum_apply, Pi.smul_apply, smul_sum]
  have h_key : ∀ μ, SpaceTime.distDeriv μ (Λ • A) ε =
      ∑ ρ, (Λ⁻¹.1 ρ μ) • Λ • SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) := by
    intro μ
    rw [SpaceTime.distDeriv, SpaceTime.distDeriv]
    simp only [Distribution.smul_def, Distribution.neg_apply, neg_smul, smul_neg]
    rw [← Finset.smul_sum, ← LinearMap.map_smul]
