lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε μν
  match μν with
  | (μ, ν) =>
  rw [deriv_basis_repr_apply]
  have hRHS : (Λ • deriv A) ε (μ, ν) =
      ∑ ρ, ∑ κ, (Λ⁻¹.1 ρ μ * Λ.1 ν κ) * distDeriv ρ A (Λ⁻¹ • ε) κ := by
    rw [show (Λ • deriv A) ε = Λ • (deriv A (Λ⁻¹ • ε)) by rfl]
    simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
      map_sum, map_smul, Finsupp.coe_finset_sum, Finsupp.coe_smul, Finset.sum_apply,
      Pi.smul_apply, Basis.tensorProduct_repr_tmul_apply, Basis.repr_self, smul_eq_mul]
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro ρ _
    rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro κ _
    rw [Tensorial.smul_tmul, Tensorial.repr_tmul]
    rw [Lorentz.CoVector.smul_basis_repr, Lorentz.Vector.smul_basis_repr]
    ring
  rw [hRHS]
  calc distDeriv μ (Λ • A) ε ν
    _ = - (Λ • A) (SpaceTime.deriv μ ε) ν := by rfl
    _ = - ∑ κ, Λ.1 ν κ * A (Λ⁻¹ • SpaceTime.deriv μ ε) κ := by
      simp only [Lorentz.Vector.smul_apply, Distribution.smul_apply, Distribution.action_apply]
    _ = - ∑ κ, Λ.1 ν κ * A (∑ ρ, Λ⁻¹.1 ρ μ • SpaceTime.deriv ρ (Λ⁻¹ • ε)) κ := by
      rw [SpaceTime.deriv_comp_lorentz_inv]
    _ = ∑ κ, ∑ ρ, (Λ.1 ν κ * Λ⁻¹.1 ρ μ) * (- A (SpaceTime.deriv ρ (Λ⁻¹ • ε)) κ) := by
      simp only [map_sum, map_smul, Finset.sum_apply, Pi.smul_apply, smul_eq_mul]
      simp_rw [Finset.mul_sum]
      apply Finset.sum_congr rfl; intro κ _
      apply Finset.sum_congr rfl; intro ρ _
      ring
    _ = ∑ ρ, ∑ κ, (Λ⁻¹.1 ρ μ * Λ.1 ν κ) * distDeriv ρ A (Λ⁻¹ • ε) κ := by
      rw [Finset.sum_comm]
      apply Finset.sum_congr rfl; intro ρ _
      apply Finset.sum_congr rfl; intro κ _
      ring
