/-!

### C.3. Equivariance of the derivative distribution

-/

@[simp]
lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  apply (Lorentz.CoVector.basis.tensorProduct Lorentz.Vector.basis).ext
  intro ⟨μ, ν⟩
  rw [deriv_basis_repr_apply]
  rw [SpaceTime.distDeriv, SpaceTime.distDeriv]
  simp only [Lorentz.Vector.smul_apply, Lorentz.Vector.smul_eq_sum,
    ContinuousLinearMap.smul_apply, smul_eq_mul]
  have h_deriv : ∂_ μ ε ∘ (Λ • ·) = ∑ ρ, (Λ⁻¹.1 ρ μ) • ∂_ ρ (fun x => ε (Λ x)) := by
    funext x
    rw [← SpaceTime.deriv_comp_lorentz_action (fun x => ε (Λ x)) Λ⁻¹]
    simp
  rw [h_deriv, map_sum]
  simp only [map_smul, smul_eq_mul, Finset.sum_apply, Pi.smul_apply]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro ρ _
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro κ _
  rw [neg_mul, neg_mul, mul_assoc]
  congr 1
  rw [mul_comm]
  congr 1
  change _ = (Lorentz.CoVector.basis.tensorProduct Lorentz.Vector.basis).repr
    (Λ • deriv A (fun x => ε (Λ x))) (μ, ν)
  rw [deriv]
  simp only [map_sum, map_smul, ContinuousLinearMap.coe_smul', TensorProduct.tmul_smul,
    smul_tmul, smul_smul]
  rw [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
  rw [map_sum, map_sum, map_sum, map_sum]
  simp only [map_smul, Basis.tensorProduct_repr_tmul_apply, Basis.repr_self,
    Finsupp.single_apply, smul_eq_mul]
  apply Finset.sum_congr rfl
  intro ρ _
  apply Finset.sum_congr rfl
  intro κ _
  rw [Finset.sum_eq_single μ, Finset.sum_eq_single ν]
  · simp; ring
  · intro; simp
  · simp
  · intro; simp
  · simp
