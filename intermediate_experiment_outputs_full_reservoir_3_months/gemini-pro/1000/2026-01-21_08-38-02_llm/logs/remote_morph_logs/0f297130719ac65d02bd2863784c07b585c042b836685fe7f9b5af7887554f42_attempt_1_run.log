/-!

### C.3. Equivariance of the derivative distribution

-/

@[simp]
lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  calc deriv (Λ • A) ε
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (Λ.1 ν κ * Λ⁻¹.1 ρ μ) * (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) •
          (Lorentz.CoVector.basis μ) ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
        Finset.sum_apply, Pi.smul_apply]
      congr; funext μ; congr; funext ν
      rw [SpaceTime.distDeriv_lorentz_smul]
      simp only [Finset.sum_mul, Finset.mul_sum]
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) •
          (Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ]
          (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      simp only [smul_tmul, tmul_smul, smul_smul]
      congr 1; funext μ; congr 1; funext ν; congr 1; funext κ; congr 1; funext ρ
      ring
    _ = ∑ κ, ∑ ρ, ∑ μ, ∑ ν, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) •
          (Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ]
          (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      repeat rw [Finset.sum_comm]
    _ = ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) • (∑ μ, Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ]
          (∑ ν, Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      congr 1; funext κ; congr 1; funext ρ
      rw [TensorProduct.sum_tmul, TensorProduct.tmul_sum, Finset.smul_sum]
    _ = ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) • (Λ • (Lorentz.CoVector.basis ρ)) ⊗ₜ[ℝ]
          (Λ • Lorentz.Vector.basis κ) := by
      congr 1; funext κ; congr 1; funext ρ
      congr 2
      · rw [Lorentz.CoVector.smul_basis]
      · rw [Lorentz.Vector.smul_basis]
    _ = ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) • Λ • ((Lorentz.CoVector.basis ρ) ⊗ₜ[ℝ]
        Lorentz.Vector.basis κ) := by
      simp only [Tensorial.smul_prod]
    _ = Λ • (deriv A (Λ⁻¹ • ε)) := by
      rw [deriv]
      simp only [LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk', map_sum, map_smul,
        Finset.sum_apply, Pi.smul_apply]
      congr 1; funext κ; congr 1; funext ρ
      rw [Finset.smul_sum]
