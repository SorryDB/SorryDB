    rw [SpaceTime.deriv_eq, SpaceTime.deriv_eq]
    rw [fderiv_comp _ (ε.differentiableAt _) (Λ.differentiableAt _)]
    rw [ContinuousLinearMap.fderiv, Lorentz.Vector.actionCLM_basis_apply]
    simp only [ContinuousLinearMap.coe_comp', Function.comp_apply,
      ContinuousLinearMap.map_sum, ContinuousLinearMap.map_smul]
    apply Finset.sum_congr rfl
    intro k _
    rw [SpaceTime.fderiv_basis_apply]
    simp only [smul_eq_mul]
    ring
  simp only [h_key, Finset.sum_smul, smul_smul, map_sum, map_smul]
  conv_rhs =>
    enter [1, ρ, 1, κ]
    rw [Tensorial.smul_prod, Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis,
        tmul_sum, sum_tmul, Finset.smul_sum, Finset.smul_sum]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl; intro μ _
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl; intro ν _
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl; intro ρ _
  rw [← mul_assoc, mul_comm _ (Λ.1 ν _), mul_assoc]
  congr 1
  rw [Lorentz.Vector.smul_apply_eq_sum]
  rw [mul_comm]
