lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  calc deriv (Λ • A) ε
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, ((Λ.1 ν κ * Λ⁻¹.1 ρ μ) * distDeriv ρ A (Λ⁻¹ • ε) κ) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      refine Finset.sum_congr rfl (fun μ _ => ?_)
      refine Finset.sum_congr rfl (fun ν _ => ?_)
      simp [distDeriv, SpaceTime.distDeriv, SpaceTime.deriv_comp_lorentz_action, ε.differentiable]
      ring
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) •
        (Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ]
        (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      simp only [smul_tmul, tmul_smul, smul_smul]
      refine Finset.sum_congr rfl (fun μ _ => ?_)
      refine Finset.sum_congr rfl (fun ν _ => ?_)
      refine Finset.sum_congr rfl (fun κ _ => ?_)
      refine Finset.sum_congr rfl (fun ρ _ => ?_)
      ring
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) • (Λ • (Lorentz.CoVector.basis ρ)) ⊗ₜ[ℝ]
        (Λ • Lorentz.Vector.basis κ) := by
      rw [Finset.sum_comm]
      conv_lhs => enter [2, ρ]; rw [Finset.sum_comm]
      conv_lhs => enter [2, ρ, 2, κ]; rw [Finset.sum_comm]
      conv_lhs => enter [2, ρ]; rw [Finset.sum_comm]
      simp only [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis, sum_tmul, tmul_sum,
        Finset.smul_sum]
    _ = Λ • deriv A (Λ⁻¹ • ε) := by
      simp only [Tensorial.smul_prod, Finset.sum_smul]
      rw [deriv]
      rfl
    _ = (Λ • deriv A) ε := rfl
