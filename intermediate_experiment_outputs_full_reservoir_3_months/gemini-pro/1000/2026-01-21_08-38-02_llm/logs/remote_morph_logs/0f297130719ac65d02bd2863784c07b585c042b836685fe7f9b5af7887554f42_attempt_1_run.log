@[sorryful]
lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  change deriv (Λ • A) ε = Λ • (deriv A (Λ⁻¹ • ε))
  rw [deriv, deriv]
  simp only [LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk', map_sum, map_smul]
  conv_lhs =>
    enter [1, 2, μ, 2, ν]
    rw [SpaceTime.distDeriv, SpaceTime.distDeriv]
    change - (Λ • (A (Λ⁻¹ • ∂_μ ε))) ν = _
    rw [Lorentz.Vector.smul_apply, Lorentz.Vector.smul_eq_sum]
    rw [Finset.sum_apply]
    rw [show Λ⁻¹ • (∂_μ ε) = ∑ ρ, Λ⁻¹.1 ρ μ • ∂_ρ (Λ⁻¹ • ε) by
      funext x
      simp only [Pi.smul_apply, ContinuousLinearMap.coe_sum, ContinuousLinearMap.coe_smul,
        Pi.add_apply, smul_eq_mul, Finset.sum_apply]
      rw [← SpaceTime.deriv_comp_lorentz_action Λ (Λ⁻¹ • ε)]
      simp]
    simp only [map_sum, map_smul]
    rw [Finset.sum_apply]
    simp only [Pi.smul_apply, smul_eq_mul]
    rw [Finset.mul_sum]
  conv_rhs =>
    rw [Tensorial.smul_sum]
    apply Finset.sum_congr rfl; intro ρ _
    rw [Tensorial.smul_sum]
    apply Finset.sum_congr rfl; intro κ _
    rw [Tensorial.smul_smul]
    rw [Tensorial.smul_prod]
    rw [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
    rw [tmul_sum, sum_tmul]
    rw [Finset.smul_sum, Finset.smul_sum]
  rw [Finset.sum_comm]
