/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  have h_deriv_ε : ∀ μ, Λ⁻¹ • (∂_ μ ε) = ∑ ρ, Λ⁻¹.1 ρ μ • (∂_ ρ (Λ⁻¹ • ε)) := by
    intro μ
    ext x
    simp only [ContinuousLinearMap.coe_sum', ContinuousLinearMap.coe_smul', Pi.sum_apply,
      Pi.smul_apply, smul_eq_mul]
    have h1 : ∂_ μ (ε ∘ Λ) x = ∑ ρ, Λ.1 ρ μ * ∂_ ρ ε (Λ x) := by
      rw [SpaceTime.deriv_eq, SpaceTime.deriv_eq]
      rw [fderiv_comp x ε.diff.differentiable (Lorentz.Vector.actionCLM Λ).differentiable]
      have hL : fderiv ℝ (fun y => Λ • y) x = Lorentz.Vector.actionCLM Λ :=
        fderiv_continuousLinearMap
      rw [hL, ContinuousLinearMap.apply_basis, ContinuousLinearMap.map_sum,
        ContinuousLinearMap.coe_sum', Finset.sum_apply]
      apply Finset.sum_congr rfl
      intro ρ _
      rw [ContinuousLinearMap.coe_smul', Pi.smul_apply, smul_eq_mul, mul_comm]
    have h2 : (∂_ μ ε) (Λ x) = ∑ ρ, Λ⁻¹.1 ρ μ * (∂_ ρ (ε ∘ Λ) x) := by
      rw [h1]
      simp only [Finset.mul_sum]
      rw [Finset.sum_comm]
      trans ∑ ρ, (∑ k, Λ⁻¹.1 k μ * Λ.1 ρ k) * ∂_ ρ ε (Λ x)
      · apply Finset.sum_congr rfl
        intro ρ _
        rw [← Matrix.mul_apply, Matrix.inv_mul_self, Matrix.one_apply]
        by_cases h : ρ = μ
        · simp [h]
        · simp [h]
      · apply Finset.sum_congr rfl
        intro k _
        ring
