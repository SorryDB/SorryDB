theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp [partialSums]
  | cons l L ih =>
    simp only [flatten_cons, map_cons, partialSums_cons, findIdx_cons, decide_eq_true_eq]
    by_cases hi : l.length > i
    · simp [hi, take_append_of_le_length (Nat.le_of_lt hi)]
    · simp only [hi, ↓reduceIte, map_map, Function.comp_def]
      push_neg at hi
      rw [take_append_eq_append_take, take_length_le hi, ih (i - l.length)]
      have hshift : ∀ xs : List Nat,
          findIdx (fun x => decide (i < l.length + x)) (xs.map (l.length + ·)) =
          findIdx (fun x => decide (i - l.length < x)) xs := by
        intro xs
        induction xs with
        | nil => rfl
        | cons x xs ih' =>
          simp only [map_cons, findIdx_cons]
          by_cases hx : i < l.length + x
          · simp [hx, Nat.sub_lt_iff_lt_add hi, hx]
          · simp only [hx, ↓reduceIte]
            have : ¬(i - l.length < x) := by omega
            simp [this, ih']
      simp only [hshift]
      congr 1
      · congr 1
        omega
      · simp only [getElem?_cons_succ]
        congr 1
        simp only [length_flatten, take_succ_cons]
        omega
```
