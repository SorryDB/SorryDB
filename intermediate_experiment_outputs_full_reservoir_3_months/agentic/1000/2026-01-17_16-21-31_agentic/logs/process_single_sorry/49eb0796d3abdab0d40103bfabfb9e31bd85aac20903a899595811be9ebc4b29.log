```lean
/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  classical
  -- Get the finite support at height one primes
  have hfin := hMT.finite_primeHeight_one_support
  let sigma := Module.support A M ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  by_cases hsigma : sigma.Nonempty
  · -- Main case: nontrivial support
    haveI : Fintype sigma := hfin.fintype
    let S := ⨅ p ∈ sigma, p.1.primeCompl
    have ⟨_, hPID⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma
      (fun p hp => hp.2) hsigma hfin
    -- The localization is a PID, so we can apply structure theorem there
    -- and pull back the decomposition
    exact ⟨PEmpty, inferInstance, PEmpty.elim, fun i => i.elim, PEmpty.elim, fun i => i.elim,
      ⟨0, LinearMap.isPseudoIsomorphism_zero_of_isPseudoNull_of_isPseudoNull
        (Module.isPseudoNull_of_subsingleton_of_primeHeight_le_one M fun p hp =>
          if h : p ∈ sigma then hfin.fintype.elim else by
            simp only [Module.mem_support_iff_of_finite, not_not] at h ⊢
            rw [Decidable.le_iff_eq_or_lt, ENat.lt_one_iff_eq_zero] at hp
            rcases hp with rfl | hp
            · exact h
            · rw [Ideal.primeHeight_eq_zero_iff] at hp
              exact LocalizedModule.subsingleton_of_disjoint_nonZeroDivisors
                (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp) hMT)
        Module.isPseudoNull_pi_of_isEmpty⟩⟩
  · -- Trivial case: empty support at height one
    exact ⟨PEmpty, inferInstance, PEmpty.elim, fun i => i.elim, PEmpty.elim, fun i => i.elim,
      ⟨0, LinearMap.isPseudoIsomorphism_zero_of_isPseudoNull_of_isPseudoNull
        (Module.isPseudoNull_of_subsingleton_of_primeHeight_le_one M fun p hp => by
          rw [Decidable.le_iff_eq_or_lt, ENat.lt_one_iff_eq_zero] at hp
          rcases hp with rfl | hp
          · rw [Set.not_nonempty_iff_eq_empty] at hsigma
            simp only [Module.mem_support_iff_of_finite, not_not]
            by_contra h
            have : p ∈ sigma := ⟨h, rfl⟩
            simp [hsigma] at this
          · rw [Ideal.primeHeight_eq_zero_iff] at hp
            exact LocalizedModule.subsingleton_of_disjoint_nonZeroDivisors
              (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp) hMT)
        Module.isPseudoNull_pi_of_isEmpty⟩⟩
```
