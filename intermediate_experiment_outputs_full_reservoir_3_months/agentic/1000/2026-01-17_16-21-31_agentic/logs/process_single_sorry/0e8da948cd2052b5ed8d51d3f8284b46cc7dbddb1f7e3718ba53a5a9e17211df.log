theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · intro ⟨f, hoto, honto⟩
    choose g hg using honto
    exact ⟨f, g, funext hg, funext fun u => hoto (hg (f u))⟩
  · intro ⟨f, g, hfg, hgf⟩
    refine ⟨f, ?_, ?_⟩
    · intro u1 u2 h
      have h1 : u1 = g (f u1) := (congrFun hgf u1).symm
      have h2 : u2 = g (f u2) := (congrFun hgf u2).symm
      rw [h1, h2, h]
    · intro v
      exact ⟨g v, congrFun hfg v⟩
```
