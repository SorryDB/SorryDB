lemma runWithOracle_getPutativeRoot {s} (idx : BinaryTree.SkeletonLeafIndex s)
    (leafValue : α) (proof : List α) (f) :
    (runWithOracle f (getPutativeRoot idx leafValue proof))
      =
    getPutativeRoot_with_hash idx leafValue proof fun (left right : α) => (f ⟨left, right⟩) := by
  induction proof generalizing s idx with
  | nil => simp [getPutativeRoot, getPutativeRoot_with_hash]
  | cons h t ih =>
    cases idx with
    | ofLeaf => simp [getPutativeRoot, getPutativeRoot_with_hash]
    | ofLeft idxLeft => simp [getPutativeRoot, getPutativeRoot_with_hash, singleHash, ih]
    | ofRight idxRight => simp [getPutativeRoot, getPutativeRoot_with_hash, singleHash, ih]
```
