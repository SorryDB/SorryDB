lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext A
  ext x
  simp only [Function.comp_apply, id_eq]
  constructor
  · intro ⟨y, ⟨z, hz, hfz⟩, hgy⟩
    have heq : g (f z) = z := congrFun h z
    rw [← hfz, heq] at hgy
    rw [← hgy]
    exact hz
  · intro hx
    exact ⟨f x, ⟨x, hx, rfl⟩, congrFun h x⟩
```
