theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  define
  use fun n => ⟨2 * fnz n, ⟨fnz n, rfl⟩⟩
  apply And.intro
  · intro a b h1
    have h2 : 2 * fnz a = 2 * fnz b := Subtype.ext_iff.mp h1
    have h3 : fnz a = fnz b := by linarith
    have h4 : fzn (fnz a) = fzn (fnz b) := congrArg fzn h3
    rw [congrFun fzn_fnz a, congrFun fzn_fnz b] at h4
    exact h4
  · intro ⟨m, k, hk⟩
    use fzn k
    apply Subtype.ext
    have h : fnz (fzn k) = k := congrFun fnz_fzn k
    simp only [h, hk]
```
