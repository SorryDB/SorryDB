            have h' : i' < l'.length := Nat.lt_of_succ_lt_succ h
            exact (List.Perm.cons a (ih i' h')).trans (List.Perm.swap _ _ _)
      have h1 := perm_eraseIdx l1 idx1 hidx1
      have h2 := perm_eraseIdx l2 idx2 hidx2
      have h3 : (l1[idx1] :: l1.eraseIdx idx1).Perm (l2[idx2] :: l2.eraseIdx idx2) := 
        h1.symm.trans (hperm.trans h2)
      rw [heq] at h3
      exact h3.cons_inv
