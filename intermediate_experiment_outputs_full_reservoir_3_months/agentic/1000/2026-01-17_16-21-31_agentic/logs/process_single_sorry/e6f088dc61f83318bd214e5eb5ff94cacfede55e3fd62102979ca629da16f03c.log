    (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
      have perm_eraseIdx : ∀ (l : List α) (i : Nat) (h : i < l.length), 
          l.Perm (l[i] :: l.eraseIdx i) := fun l i h => by
        induction l generalizing i with
