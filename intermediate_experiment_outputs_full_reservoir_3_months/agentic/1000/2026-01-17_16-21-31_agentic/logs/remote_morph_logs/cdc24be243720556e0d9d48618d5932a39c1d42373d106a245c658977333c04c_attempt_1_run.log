      simp only [Inner.inner, map_add, Prod.norm_def, smul_eq_mul]
      have ⟨cY, dY, hcY, hdY, hY⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
      have ⟨hxl, hxu⟩ := _hx x
      have ⟨hyl, hyu⟩ := hY y
      simp only [smul_eq_mul] at hxl hxu hyl hyu
      have hn1 : 0 ≤ ‖x‖ := norm_nonneg x
      have hn2 : 0 ≤ ‖y‖ := norm_nonneg y
      have hix : 0 ≤ re ⟪x, x⟫_𝕜 := inner_self_nonneg
      have hiy : 0 ≤ re ⟪y, y⟫_𝕜 := inner_self_nonneg
      have hsup_nonneg : 0 ≤ ‖x‖ ⊔ ‖y‖ := le_sup_of_le_left hn1
      have hx_le_sup : ‖x‖ ≤ ‖x‖ ⊔ ‖y‖ := le_sup_left
      have hy_le_sup : ‖y‖ ≤ ‖x‖ ⊔ ‖y‖ := le_sup_right
      have hx_sq : ‖x‖^2 ≤ (‖x‖ ⊔ ‖y‖)^2 := sq_le_sq' (by linarith) hx_le_sup
      have hy_sq : ‖y‖^2 ≤ (‖x‖ ⊔ ‖y‖)^2 := sq_le_sq' (by linarith) hy_le_sup
      constructor
      · have h1 : cx * cx ≤ cx := by nlinarith
        have h2 : cy * cy ≤ cy := by nlinarith
        calc (cx * cx + cy * cy) * (‖x‖ ⊔ ‖y‖) ^ 2 
            ≤ cx * (‖x‖ ⊔ ‖y‖) ^ 2 + cy * (‖x‖ ⊔ ‖y‖) ^ 2 := by nlinarith
          _ ≤ cx * ‖x‖^2 + re ⟪x, x⟫_𝕜 + (cy * ‖y‖^2 + re ⟪y, y⟫_𝕜) := by nlinarith
