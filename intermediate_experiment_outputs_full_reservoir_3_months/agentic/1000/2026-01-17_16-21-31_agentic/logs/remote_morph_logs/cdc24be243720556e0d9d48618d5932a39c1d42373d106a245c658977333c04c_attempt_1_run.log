          _ ≤ dx * (‖x‖ ⊔ ‖y‖)^2 + dY * (‖x‖ ⊔ ‖y‖)^2 := by nlinarith
          _ = (dx + dY) * (‖x‖ ⊔ ‖y‖)^2 := by ring
