def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    · calc
        _ = LinearMap.mul' R (C ⊗[R] C) ∘ₗ (TensorProduct.map (antipode R) (antipode R) ∘ₗ comul ⊗ₘ comul) ∘ₗ comul := rfl
        _ = LinearMap.mul' R (C ⊗[R] C) ∘ₗ (TensorProduct.map (antipode R) (antipode R) ⊗ₘ LinearMap.id) ∘ₗ (comul ⊗ₘ comul) ∘ₗ comul := by
            simp only [TensorProduct.map_comp, LinearMap.comp_assoc, TensorProduct.map_id]
        _ = LinearMap.mul' R (C ⊗[R] C) ∘ₗ ((comul ∘ₗ antipode R) ⊗ₘ comul) ∘ₗ comul := by
            congr 1
            ext a b
            simp [IsCocomm.comul_comm (R := R) (A := C)]
        _ = comul * (comul ∘ₗ antipode R) := rfl
        _ = 1 := comul_right_inv
    · exact comul_right_inv
```
