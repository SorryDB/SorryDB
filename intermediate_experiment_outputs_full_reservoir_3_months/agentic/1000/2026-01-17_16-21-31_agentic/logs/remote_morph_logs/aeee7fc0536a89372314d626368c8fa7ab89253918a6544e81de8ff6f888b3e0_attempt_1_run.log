lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  induction z using TensorProduct.induction_on with
  | zero => exact ⟨1, 0, by simp⟩
  | tmul d zhat =>
    induction d using TensorProduct.induction_on with
    | zero => exact ⟨1, 0, by simp⟩
    | tmul q h =>
      refine ⟨⟨q.den, q.den_pos⟩, q.num • h ⊗ₜ zhat, ?_⟩
      simp only [j₁, j₂, Algebra.TensorProduct.includeLeft_apply,
        Algebra.TensorProduct.includeRight_apply]
      rw [show (q.den : ℕ+).val = q.den from rfl]
      simp only [PNat.coe_mk, Rat.inv_def', Int.cast_one, one_mul]
      conv_lhs => rw [← Rat.num_div_den q]
      rw [div_eq_mul_inv]
      simp only [Algebra.TensorProduct.tmul_mul_tmul, mul_one, one_mul]
      congr 1
      · ring
      · rfl
    | add x y hx hy =>
      obtain ⟨nx, zx, hzx⟩ := hx
      obtain ⟨ny, zy, hzy⟩ := hy
      refine ⟨nx * ny, (ny : ℤ) • zx + (nx : ℤ) • zy, ?_⟩
      simp only [map_add, mul_add, ← hzx, ← hzy, j₁, j₂]
      simp only [Algebra.TensorProduct.includeLeft_apply, Algebra.TensorProduct.tmul_mul_tmul,
        mul_one, one_mul]
      congr 1 <;> ring
  | add x y hx hy =>
    obtain ⟨nx, zx, hzx⟩ := hx
    obtain ⟨ny, zy, hzy⟩ := hy
    refine ⟨nx * ny, (ny : ℤ) • zx + (nx : ℤ) • zy, ?_⟩
    simp only [map_add, mul_add, ← hzx, ← hzy, j₁, j₂]
    simp only [Algebra.TensorProduct.includeLeft_apply, Algebra.TensorProduct.tmul_mul_tmul,
      mul_one, one_mul]
