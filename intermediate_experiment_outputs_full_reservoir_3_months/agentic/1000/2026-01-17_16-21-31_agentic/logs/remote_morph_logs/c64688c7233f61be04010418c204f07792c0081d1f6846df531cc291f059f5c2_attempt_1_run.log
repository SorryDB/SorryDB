lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
  intro w args e h ⟨h₁, h₂⟩
  simp only [Exp.eval] at h h₂
  subst h₂
  simp only [Exp.eval] at h
  apply h
  clear h e
  induction w with
  | zero =>
    have : args = #v[] := by simp
    simp [this, bits2num, Vector.foldl]
  | succ w ih =>
    unfold assert_bits at h₁
    unfold bits2num Vector.foldl
    simp only [Vector.toArray_cast, Array.foldl_eq_foldl_toList, Vector.toList_toArray] at ih ⊢
    simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true,
      decide_eq_true_eq] at h₁
    have hp := Fact.out (p := Nat.Prime p)
    have hp2 : 2 ≤ p := hp.two_le
    have hval : ∀ x : ZMod p, (x = 0 ∨ x = 1) → x.val ≤ 1 := by
      intro x hx; rcases hx with rfl | rfl <;> simp [ZMod.val_one_of_ne_one (by omega : p ≠ 1)]
    have : ∀ (l : List (ZMod p)) (acc : ZMod p), 
      (∀ x ∈ l, x = 0 ∨ x = 1) → acc.val < 2^(w + 1 - l.length) → 
      (l.foldl (fun a b => b + 2 * a) acc).val < 2^(w + 1) := by
      intro l
      induction l with
      | nil => simp
      | cons b bs ihbs =>
        intro acc hall hbound
        simp only [List.foldl_cons]
        apply ihbs
        · exact fun x hx => hall x (List.mem_cons_of_mem b hx)
        · have hb := hall b (List.mem_cons_self b bs)
          have hbval := hval b hb
          simp only [List.length_cons, Nat.add_sub_add_right] at hbound ⊢
          calc (b + 2 * acc).val ≤ b.val + (2 * acc).val := ZMod.val_add_le b (2 * acc)
            _ ≤ 1 + 2 * acc.val := by
                have : (2 * acc).val ≤ 2 * acc.val := by
                  by_cases h : 2 * acc.val < p
                  · simp [ZMod.val_mul_of_lt h]
                  · push_neg at h; exact le_of_lt (ZMod.val_lt (2 * acc))
                omega
            _ < 2^(w - bs.length) := by omega
    exact this args.toList 0 (by simp_all) (by simp)
