/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  obtain ⟨l, hl⟩ := hf (half_pos hε)
  refine ⟨l, hl.pos, fun x y hxy => ?_⟩
  obtain ⟨t, ⟨ht0, htl⟩, hxt⟩ := hl (-x)
  have h1 : IsLinftyAP (ε / 2) (x + t) f := hxt
  have hx' := h1 0
  simp only [zero_add] at hx'
  have hy' := h1 (y - x)
  simp only [sub_add_cancel] at hy'
  calc ‖f x - f y‖ = ‖(f x - f (x + t)) + (f (x + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f y‖ := norm_add_le ..
    _ = ‖f (x + t) - f x‖ + ‖f (x + t) - f y‖ := by rw [norm_sub_comm]
    _ = ‖f (0 + (x + t)) - f 0‖ + ‖f (y + (x + t - y)) - f y‖ := by ring_nf
    _ = ‖f (0 + (x + t)) - f 0‖ + ‖f (y + (x - y + t)) - f y‖ := by ring_nf
    _ ≤ ε / 2 + ε / 2 := by linarith [hx', hy']
    _ = ε := add_halves ε
