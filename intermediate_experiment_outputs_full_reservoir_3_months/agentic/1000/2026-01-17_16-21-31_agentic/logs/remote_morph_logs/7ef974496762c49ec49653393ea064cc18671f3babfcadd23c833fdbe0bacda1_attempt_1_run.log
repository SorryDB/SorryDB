The key insight is that we need to work with the raw expressions and avoid using `ring` on function arguments. Let me use a cleaner approach with `show` to handle the type conversions:

```lean
/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  obtain ⟨l, hl⟩ := hf (half_pos hε)
  refine ⟨l, hl.pos, fun x y _ => ?_⟩
  obtain ⟨t, ⟨_, _⟩, hapt⟩ := hl (y - x)
  have h1 : ‖f (y + t) - f x‖ ≤ ε / 2 := by
    have := hapt x
    show ‖f (x + (y - x + t)) - f x‖ ≤ ε / 2 at this
    simp only [add_sub_cancel, add_assoc] at this
    exact this
  obtain ⟨s, ⟨_, _⟩, haps⟩ := hl 0
  have h2 : ‖f (y + s) - f y‖ ≤ ε / 2 := by simpa using haps y
  have h3 : ‖f (y + t) - f (y + s)‖ ≤ ε / 2 := by
    have := hapt (y + s - (y - x))
    simp only [sub_add_eq_add_sub, add_sub_cancel_left] at this
    have key : x + s + (y - x + t) = y + t + s := by ring
    simp only [key, add_comm t s] at this
    have := haps (y + t)
    simp only [zero_add] at this
    exact this
  calc dist (f x) (f y) = ‖f x - f y‖ := rfl
    _ ≤ ‖f x - f (y + t)‖ + ‖f (y + t) - f y‖ := norm_sub_le_norm_sub_add_norm_sub ..
    _ = ‖f (y + t) - f x‖ + ‖f (y + t) - f y‖ := by rw [norm_sub_rev]
    _ ≤ ‖f (y + t) - f x‖ + (‖f (y + t) - f (y + s)‖ + ‖f (y + s) - f y‖) := by
        gcongr; exact norm_sub_le_norm_sub_add_norm_sub ..
    _ ≤ ε / 2 + (ε / 2 + ε / 2) := by gcongr
    _ = ε / 2 + ε := by ring
    _ < ε + ε := by linarith
