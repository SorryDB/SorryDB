lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  obtain ⟨l, hl⟩ := hf (half_pos hε)
  refine ⟨l, hl.pos, fun x y hxy => ?_⟩
  obtain ⟨s, ⟨hs0, hsl⟩, hxs⟩ := hl (-x)
  obtain ⟨t, ⟨ht0, htl⟩, hyt⟩ := hl (-y)
  have h1 : IsLinftyAP (ε / 2) (-x + s) f := hxs
  have h2 : IsLinftyAP (ε / 2) (-y + t) f := hyt
  have hx' := h1 x
  have hy' := h2 y
  simp only [neg_add_cancel_left] at hx' hy'
  calc dist (f x) (f y) 
      = ‖f x - f y‖ := rfl
    _ ≤ ‖f x - f s‖ + ‖f s - f t‖ + ‖f t - f y‖ := by
        calc ‖f x - f y‖ = ‖(f x - f s) + (f s - f t) + (f t - f y)‖ := by ring_nf
