```lean
/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  obtain ⟨l, hl⟩ := hf (half_pos hε)
  refine ⟨l, hl.pos, fun x y _ => ?_⟩
  obtain ⟨t, ⟨_, _⟩, hapt⟩ := hl (y - x)
  obtain ⟨s, ⟨_, _⟩, haps⟩ := hl (x - y)
  have h1 : ‖f (y + t) - f x‖ ≤ ε / 2 := by convert hapt x using 2; ring
  have h2 : ‖f (x + s) - f y‖ ≤ ε / 2 := by convert haps y using 2; ring
  have h3 : ‖f (x + s) - f (y + t)‖ ≤ ε / 2 := by convert hapt (x + s - (y - x + t)) using 2; ring
  calc dist (f x) (f y) = ‖f x - f y‖ := rfl
    _ ≤ ‖f x - f (y + t)‖ + ‖f (y + t) - f (x + s)‖ + ‖f (x + s) - f y‖ := by
        have eq : f x - f y = (f x - f (y + t)) + (f (y + t) - f (x + s)) + (f (x + s) - f y) := by ring
        rw [eq]
        exact (norm_add_le _ _).trans (add_le_add_right (norm_add_le _ _) _)
    _ = ‖f (y + t) - f x‖ + ‖f (x + s) - f (y + t)‖ + ‖f (x + s) - f y‖ := by
        rw [norm_sub_rev (f x), norm_sub_rev (f (y + t))]
    _ ≤ ε / 2 + ε / 2 + ε / 2 := by linarith
    _ < ε := by linarith
```
