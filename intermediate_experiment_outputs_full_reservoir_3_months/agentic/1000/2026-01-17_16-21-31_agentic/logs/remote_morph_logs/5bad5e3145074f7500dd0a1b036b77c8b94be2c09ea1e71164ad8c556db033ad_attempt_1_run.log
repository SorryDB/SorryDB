    ext z
    simp only [ContinuousLinearMap.add_apply, ContinuousLinearMap.coe_mk', LinearMap.coe_mk, AddHom.coe_mk]
    have h : cfc_toComplexMeasure ha (x + y) z = cfc_toComplexMeasure ha x z + cfc_toComplexMeasure ha y z := by
      unfold cfc_toComplexMeasure cfc_toLinearFunctional
      have hlin : compSL C(spectrum ℂ a, ℂ) (H →L[ℂ] H) ℂ _ _ (toLinearFunctional (x + y) z) (cfcCLM ha) =
                  compSL C(spectrum ℂ a, ℂ) (H →L[ℂ] H) ℂ _ _ (toLinearFunctional x z) (cfcCLM ha) +
                  compSL C(spectrum ℂ a, ℂ) (H →L[ℂ] H) ℂ _ _ (toLinearFunctional y z) (cfcCLM ha) := by
        ext g
