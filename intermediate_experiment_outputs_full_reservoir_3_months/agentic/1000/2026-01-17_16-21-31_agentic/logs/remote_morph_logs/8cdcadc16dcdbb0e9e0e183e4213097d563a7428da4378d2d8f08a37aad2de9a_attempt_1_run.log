  have hca : c ‚Č§ a := hcb.trans hba
  have hda : d ‚Č§ a := hdc.trans hca
  have hwamgm : a ^ a * b ^ b * c ^ c * d ^ d ‚Č§ a * a + b * b + c * c + d * d :=
    Real.geom_mean_le_arith_mean4_weighted ha0.le hb0.le hc0.le hd0.le ha0.le hb0.le hc0.le hd0.le h1
  have hsq_le_a : a * a + b * b + c * c + d * d ‚Č§ a := by
