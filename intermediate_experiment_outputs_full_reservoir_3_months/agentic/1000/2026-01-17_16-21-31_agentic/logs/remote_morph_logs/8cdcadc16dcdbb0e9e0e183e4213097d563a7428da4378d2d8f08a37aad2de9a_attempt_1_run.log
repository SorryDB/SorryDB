    have hc1 : c * c ‚Č§ a * c := (mul_le_mul_right hc0).mpr hca
    have hd1 : d * d ‚Č§ a * d := (mul_le_mul_right hd0).mpr hda
    linarith
  have hcoef_pos : 0 < a + 2 * b + 3 * c + 4 * d := by linarith
  have hpow_le : a ^ a * b ^ b * c ^ c * d ^ d ‚Č§ a := hwamgm.trans hsq_le_a
  have hcoef_a : (a + 2 * b + 3 * c + 4 * d) * a < 1 := by
