          linarith
        ¬∑ have : d * d < c * d := by nlinarith
          have : c * d ‚Č§ a * d := mul_le_mul_of_nonneg_right (hcb.trans hba) hd0.le
          linarith
      have hpow_lt_a : a ^ a * b ^ b * c ^ c * d ^ d < a := lt_of_le_of_lt hwamgm hstrict_ineq
