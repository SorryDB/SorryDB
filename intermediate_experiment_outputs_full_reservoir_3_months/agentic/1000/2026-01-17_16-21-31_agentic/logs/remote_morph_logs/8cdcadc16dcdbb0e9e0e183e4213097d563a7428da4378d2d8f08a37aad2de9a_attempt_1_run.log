namespace IMO2020P2

theorem result {a b c d : ‚ĄĚ} (hd0 : 0 < d) (hdc : d ‚Č§ c) (hcb : c ‚Č§ b) (hba : b ‚Č§ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha0 : 0 < a := lt_of_lt_of_le hd0 (hdc.trans (hcb.trans hba))
  have hb0 : 0 < b := lt_of_lt_of_le hd0 (hdc.trans hcb)
  have hc0 : 0 < c := lt_of_lt_of_le hd0 hdc
  have hwamgm : a ^ a * b ^ b * c ^ c * d ^ d ‚Č§ a * a + b * b + c * c + d * d :=
    Real.geom_mean_le_arith_mean4_weighted ha0.le hb0.le hc0.le hd0.le ha0.le hb0.le hc0.le hd0.le h1
  have hsq_le_a : a * a + b * b + c * c + d * d ‚Č§ a := by
    have h2 : b * b ‚Č§ a * b := mul_le_mul_of_nonneg_right hba hb0.le
    have h3 : c * c ‚Č§ a * c := mul_le_mul_of_nonneg_right (hcb.trans hba) hc0.le
    have h4 : d * d ‚Č§ a * d := mul_le_mul_of_nonneg_right (hdc.trans (hcb.trans hba)) hd0.le
    have h5 : a * a + a * b + a * c + a * d = a * (a + b + c + d) := by ring
    have h6 : a * (a + b + c + d) = a := by rw [h1]; ring
    linarith
  have hpow_le_a : a ^ a * b ^ b * c ^ c * d ^ d ‚Č§ a := hwamgm.trans hsq_le_a
  have hcoef_pos : 0 < a + 2 * b + 3 * c + 4 * d := by linarith
  have hcoef_bound : a + 2 * b + 3 * c + 4 * d ‚Č§ 3 - 2 * a := by linarith
  have hquad : (3 - 2 * a) * a ‚Č§ 1 := by nlinarith [sq_nonneg (2 * a - 1)]
  have ha_ne_half_or_bounds : a ‚Č† 1/2 ‚ą® (b ‚Č† c ‚ą® c ‚Č† d) := by
    by_contra h
    push_neg at h
    have := h.1
    have hbcd := h.2
    have : b = d := hbcd.1.trans hbcd.2
    have : a = 1/2 := h.1
    have : b + c + d = 1/2 := by linarith
    have : 3 * d = 1/2 := by linarith [hbcd.1, hbcd.2]
    have hd_val : d = 1/6 := by linarith
    have ha_val : a = 1/2 := h.1
    linarith
  have hstrict : (a + 2 * b + 3 * c + 4 * d) * a < 1 := by
    nlinarith [sq_nonneg (a - b), sq_nonneg (b - c), sq_nonneg (c - d), sq_nonneg (2*a - 1), 
               mul_pos ha0 hb0, mul_pos hb0 hc0, mul_pos hc0 hd0, mul_pos ha0 hd0]
  calc (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d
      = (a + 2 * b + 3 * c + 4 * d) * (a ^ a * b ^ b * c ^ c * d ^ d) := by ring
    _ ‚Č§ (a + 2 * b + 3 * c + 4 * d) * a := mul_le_mul_of_nonneg_left hpow_le_a hcoef_pos.le
    _ < 1 := hstrict
