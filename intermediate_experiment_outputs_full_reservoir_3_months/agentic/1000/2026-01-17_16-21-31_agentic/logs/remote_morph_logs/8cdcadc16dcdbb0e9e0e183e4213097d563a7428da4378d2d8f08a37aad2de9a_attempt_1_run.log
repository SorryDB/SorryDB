  have hcoef_pos : 0 < a + 2 * b + 3 * c + 4 * d := by linarith
  have hpow_pos : 0 < a ^ a * b ^ b * c ^ c * d ^ d := by positivity
  have hcoef_bound : a + 2 * b + 3 * c + 4 * d ‚Č§ 4 - 3 * a := by linarith
  have ha_upper : a < 1 := by linarith
  have ha_lower : 1/4 ‚Č§ a := by linarith
  have hprod_lt : (a + 2 * b + 3 * c + 4 * d) * (a ^ a * b ^ b * c ^ c * d ^ d) < 1 := by
    have h1' : (a + 2 * b + 3 * c + 4 * d) * (a ^ a * b ^ b * c ^ c * d ^ d) ‚Č§ 
               (a + 2 * b + 3 * c + 4 * d) * a := mul_le_mul_of_nonneg_left hpow_le_a hcoef_pos.le
    have h2' : (a + 2 * b + 3 * c + 4 * d) * a ‚Č§ (4 - 3 * a) * a := 
