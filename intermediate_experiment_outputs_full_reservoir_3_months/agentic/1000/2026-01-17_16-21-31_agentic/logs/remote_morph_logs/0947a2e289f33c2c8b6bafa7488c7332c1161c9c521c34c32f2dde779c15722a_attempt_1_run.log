  rw [show Ioc 0 π = Ioo 0 π ∪ {π} from by ext; simp [or_comm, le_antisymm_iff]; tauto, 
      show Ioc (-1) 1 = Ioo (-1) 1 ∪ {1} from by ext; simp [or_comm, le_antisymm_iff]; tauto]
  simp only [measure_singleton, integral_union_eq_left_of_ae_aux]
  rw [MeasureTheory.integral_image_eq_integral_abs_deriv_smul measurableSet_Ioo hderiv h3]
  simp only [hmap, smul_eq_mul]
