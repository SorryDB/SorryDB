    have hsin : 0 < sin x := sin_pos_of_pos_of_lt_pi hx.1 hx.2
    simp [abs_of_neg (neg_neg_of_pos hsin)]
  rw [intervalIntegral.integral_of_le (le_of_lt pi_pos), ← integral_Ioc_eq_integral_Ioo]
  rw [intervalIntegral.integral_of_le (by linarith : (-1 : ℝ) ≤ 1), ← integral_Ioc_eq_integral_Ioo]
  have hIoo : Ioo 0 π ⊆ [[0, π]] := Ioo_subset_uIcc_self
  have hderiv : ∀ x ∈ Ioo 0 π, HasDerivWithinAt cos (-sin x) (Ioo 0 π) x := 
    fun x hx => (hasDerivAt_cos x).hasDerivWithinAt
