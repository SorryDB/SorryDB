```lean
lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h : ∫ x in (0:ℝ)..π, -sin x * f (cos x) = ∫ y in (1:ℝ)..-1, f y := by
    have := integral_comp_mul_deriv_hasDeriv continuous_sin.neg.continuousOn
      (fun x _ => hasDerivAt_cos x) f
    simpa [cos_zero, cos_pi] using this
  have eq1 : ∫ x in (0:ℝ)..π, sin x * f (cos x) = -∫ x in (0:ℝ)..π, -sin x * f (cos x) := by
    rw [← integral_neg]
    congr 1
    ext x
    ring
  rw [eq1, h, integral_symm]
```
