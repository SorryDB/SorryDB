  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y, hy, ⟨z, hz, rfl⟩⟩ := hy
  by_cases h : Reversible x y p
  · rw [reverseSet_of_reversible h] at hz
    intro hr
    cases p with
    | left =>
      obtain ⟨w, hw, hle⟩ := hr
      rw [moves_unreverse, Set.mem_iUnion₂] at hw
      obtain ⟨a, ha, b, hb, rfl⟩ := hw
      have sub_b := subposition_of_mem_reverseSet ha hb
      have sub_z : Subposition z x := .trans (.of_mem_moves hz) <|
        .trans (.of_mem_moves h.choose_mem_moves) (.of_mem_moves hy)
      have : Subposition b x := sub_b.trans sub_z
      grw [unreverse_equiv b, unreverse_equiv x] at hle
      exact left_lf hz (h.choose_le.trans hle)
    | right =>
      obtain ⟨w, hw, hle⟩ := hr
      rw [moves_unreverse, Set.mem_iUnion₂] at hw
      obtain ⟨a, ha, b, hb, rfl⟩ := hw
      have sub_b := subposition_of_mem_reverseSet ha hb
      have sub_z : Subposition z x := .trans (.of_mem_moves hz) <|
        .trans (.of_mem_moves h.choose_mem_moves) (.of_mem_moves hy)
      have : Subposition b x := sub_b.trans sub_z
      grw [unreverse_equiv b, unreverse_equiv x] at hle
      exact lf_right hz (hle.trans h.le_choose)
