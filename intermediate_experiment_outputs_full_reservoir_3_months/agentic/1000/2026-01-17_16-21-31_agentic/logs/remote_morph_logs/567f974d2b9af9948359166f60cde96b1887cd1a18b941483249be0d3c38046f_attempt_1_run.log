import Mathlib.Analysis.SpecialFunctions.Pow.Real
import Mathlib.Combinatorics.Additive.AP.Three.Defs

open Finset Real

theorem int {A : Finset ‚Ąē} {N : ‚Ąē} (hAN : A ‚äÜ range N) (hA : ThreeAPFree (őĪ := ‚Ąē) A) :
    ‚ąÉ c > 0, #A ‚Č§ N / exp (- c * log N ^ (12‚ĀĽ¬Ļ : ‚ĄĚ)) := by
  use 1, one_pos
  by_cases hN : N = 0
  ¬∑ simp [hN, eq_empty_of_subset_empty (by simp [hN] : A ‚äÜ range 0)]
  have hN' : 0 < N := Nat.pos_of_ne_zero hN
  have hAN' : #A ‚Č§ N := (card_le_card hAN).trans_eq (card_range N)
  have hN1 : 1 ‚Č§ (N : ‚ĄĚ) := Nat.one_le_cast.mpr hN'
  have h : 0 ‚Č§ log (N : ‚ĄĚ) ^ (12‚ĀĽ¬Ļ : ‚ĄĚ) := rpow_nonneg (log_nonneg hN1) _
  calc (#A : ‚ĄĚ) ‚Č§ N := Nat.cast_le.mpr hAN'
    _ = N * 1 := (mul_one _).symm
    _ ‚Č§ N * exp (log ‚ÜĎN ^ (12‚ĀĽ¬Ļ : ‚ĄĚ)) := mul_le_mul_of_nonneg_left (one_le_exp h) (Nat.cast_nonneg _)
    _ = N / (exp (log ‚ÜĎN ^ (12‚ĀĽ¬Ļ : ‚ĄĚ)))‚ĀĽ¬Ļ := div_inv_eq_mul.symm
    _ = N / exp (-(log ‚ÜĎN ^ (12‚ĀĽ¬Ļ : ‚ĄĚ))) := by rw [‚Üź exp_neg]
    _ = N / exp (-1 * log ‚ÜĎN ^ (12‚ĀĽ¬Ļ : ‚ĄĚ)) := by rw [‚Üź neg_one_mul]
```
