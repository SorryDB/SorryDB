  have h_meas1 : Measurable (rewardByCount A R a (n + 1)) := measurable_rewardByCount hA hR a (n + 1)
  have h_meas2 : Measurable (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) :=
    measurable_pi_lambda _ fun i => measurable_rewardByCount hA hR a i
  exact h_id.symm.indepFun_snd h_meas1 h_meas2
```
