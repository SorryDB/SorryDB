    [prop] ξ = Γ.conj ⋏ φ ➝ ξ
  [eqc] True propositions
    [prop] Nonempty (Finset (Formula ℕ))
    [prop] χ ➝ ξ ∉ T.theory
    [prop] ↑Γ ⊆ construction T ⋯ (encode φ)
    [prop] ↑Δ ⊆ construction T ⋯ (encode ψ)
    [prop] ↑(Γ ∪ Δ) ⊆ construction T ⋯ (max (encode φ) (encode ψ))
    [prop] Γ.conj ⋏ φ ➝ ξ ∈ T.theory
    [prop] Δ.conj ⋏ ψ ➝ ξ ∈ T.theory
    [prop] φ ⋎ ψ ∈ construction_omega T ⋯
    [prop] ¬L ⊢ (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ
    [prop] (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ ∉ L
