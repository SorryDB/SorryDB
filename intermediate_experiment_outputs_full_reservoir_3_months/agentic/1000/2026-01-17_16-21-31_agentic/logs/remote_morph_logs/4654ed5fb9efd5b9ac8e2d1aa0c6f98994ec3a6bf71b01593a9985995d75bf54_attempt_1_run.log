    [prop] (χ ➝ ψ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) = (χ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ∧ ψ = ξ)
    [prop] (χ ➝ ξ = χ ➝ φ) = (ξ = φ)
    [prop] (χ ➝ ξ = χ ➝ ψ) = (ξ = ψ)
    [prop] (χ ➝ ξ = Γ.conj ⋏ φ ➝ ξ) = (χ = Γ.conj ⋏ φ)
    [prop] (χ ➝ ξ = Δ.conj ⋏ ψ ➝ ξ) = (χ = Δ.conj ⋏ ψ)
    [prop] (χ ➝ ξ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
