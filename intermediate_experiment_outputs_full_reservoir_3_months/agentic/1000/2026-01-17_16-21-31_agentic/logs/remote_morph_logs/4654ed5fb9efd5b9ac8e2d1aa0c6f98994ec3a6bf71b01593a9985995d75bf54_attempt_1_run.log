    [prop] (χ ➝ ξ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) = (χ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ))
    [prop] (Γ.conj ⋏ φ ➝ ξ = χ ➝ φ) = (Γ.conj ⋏ φ = χ ∧ ξ = φ)
    [prop] (Γ.conj ⋏ φ ➝ ξ = χ ➝ ψ) = (Γ.conj ⋏ φ = χ ∧ ξ = ψ)
