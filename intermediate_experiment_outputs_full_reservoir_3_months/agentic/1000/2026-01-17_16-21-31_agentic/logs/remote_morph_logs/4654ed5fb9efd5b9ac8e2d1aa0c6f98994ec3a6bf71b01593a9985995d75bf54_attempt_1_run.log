    [prop] (Δ.conj ⋏ ψ ➝ ξ = χ ➝ ξ) = (Δ.conj ⋏ ψ = χ)
    [prop] (Δ.conj ⋏ ψ ➝ ξ = Γ.conj ⋏ φ ➝ ξ) = (Δ.conj ⋏ ψ = Γ.conj ⋏ φ)
    [prop] (Δ.conj ⋏ ψ ➝ ξ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
          (Δ.conj ⋏ ψ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ∧ ξ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ)
    [prop] (Δ.conj ⋏ ψ ➝ ξ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) = (Δ.conj ⋏ ψ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ))
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ φ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = χ ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = φ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ ψ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = χ ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = ψ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ ξ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = χ ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = ξ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = Γ.conj ⋏ φ ➝ ξ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = Γ.conj ⋏ φ ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = ξ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = Δ.conj ⋏ ψ ➝ ξ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = Δ.conj ⋏ ψ ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = ξ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ∧ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = ξ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ φ) = ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = χ ∧ ξ = φ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ ψ) = ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = χ ∧ ξ = ψ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = χ ➝ ξ) = ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = χ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = Γ.conj ⋏ φ ➝ ξ) = ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = Γ.conj ⋏ φ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = Δ.conj ⋏ ψ ➝ ξ) = ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = Δ.conj ⋏ ψ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
          ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ∧ ξ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ)
    [prop] (Γ.conj ⋏ φ = Γ.conj ⋏ Δ.conj) = (φ = Δ.conj)
    [prop] (Γ.conj ⋏ φ = Δ.conj ⋏ ψ) = (Γ.conj = Δ.conj ∧ φ = ψ)
    [prop] (Γ.conj ⋏ φ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ)) = (Γ.conj = Γ.conj ⋏ φ ➝ ξ ∧ φ = Δ.conj ⋏ ψ ➝ ξ)
    [prop] (Γ.conj ⋏ φ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) = (Γ.conj = Γ.conj ⋏ Δ.conj ∧ φ = φ ⋎ ψ)
    [prop] (Γ.conj ⋏ Δ.conj = Γ.conj ⋏ φ) = (Δ.conj = φ)
    [prop] (Γ.conj ⋏ Δ.conj = Δ.conj ⋏ ψ) = (Γ.conj = Δ.conj ∧ Δ.conj = ψ)
    [prop] (Γ.conj ⋏ Δ.conj = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ)) = (Γ.conj = Γ.conj ⋏ φ ➝ ξ ∧ Δ.conj = Δ.conj ⋏ ψ ➝ ξ)
    [prop] (Γ.conj ⋏ Δ.conj = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) = (Γ.conj = Γ.conj ⋏ Δ.conj ∧ Δ.conj = φ ⋎ ψ)
    [prop] (Δ.conj ⋏ ψ = Γ.conj ⋏ φ) = (Δ.conj = Γ.conj ∧ ψ = φ)
    [prop] (Δ.conj ⋏ ψ = Γ.conj ⋏ Δ.conj) = (Δ.conj = Γ.conj ∧ ψ = Δ.conj)
    [prop] (Δ.conj ⋏ ψ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ)) = (Δ.conj = Γ.conj ⋏ φ ➝ ξ ∧ ψ = Δ.conj ⋏ ψ ➝ ξ)
    [prop] (Δ.conj ⋏ ψ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) = (Δ.conj = Γ.conj ⋏ Δ.conj ∧ ψ = φ ⋎ ψ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = Γ.conj ⋏ φ) = (Γ.conj ⋏ φ ➝ ξ = Γ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = φ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = Γ.conj ⋏ Δ.conj) = (Γ.conj ⋏ φ ➝ ξ = Γ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = Δ.conj)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = Δ.conj ⋏ ψ) = (Γ.conj ⋏ φ ➝ ξ = Δ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = ψ)
    [prop] ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) =
          (Γ.conj ⋏ φ ➝ ξ = Γ.conj ⋏ Δ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = φ ⋎ ψ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = Γ.conj ⋏ φ) = (Γ.conj ⋏ Δ.conj = Γ.conj ∧ φ ⋎ ψ = φ)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = Γ.conj ⋏ Δ.conj) = (Γ.conj ⋏ Δ.conj = Γ.conj ∧ φ ⋎ ψ = Δ.conj)
    [prop] ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = Δ.conj ⋏ ψ) = (Γ.conj ⋏ Δ.conj = Δ.conj ∧ φ ⋎ ψ = ψ)
