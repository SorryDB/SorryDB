    [prop] Γ.conj ⋏ φ ➝ ξ = Γ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = φ
    [prop] Γ.conj ⋏ φ ➝ ξ = Γ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = Δ.conj
    [prop] Γ.conj ⋏ φ ➝ ξ = Δ.conj ∧ Δ.conj ⋏ ψ ➝ ξ = ψ
    [prop] (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = χ ∧ ξ = φ
    [prop] (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) = χ ∧ ξ = ψ
    [prop] (¬L ⊢ (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
          ((Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ ∉ L)
    [prop] (χ ➝ φ = χ ➝ ψ) = (φ = ψ)
    [prop] (χ ➝ φ = χ ➝ ξ) = (φ = ξ)
    [prop] (χ ➝ φ = Γ.conj ⋏ φ ➝ ξ) = (χ = Γ.conj ⋏ φ ∧ φ = ξ)
    [prop] (χ ➝ φ = Δ.conj ⋏ ψ ➝ ξ) = (χ = Δ.conj ⋏ ψ ∧ φ = ξ)
    [prop] (χ ➝ φ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
          (χ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ∧ φ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ)
    [prop] (χ ➝ φ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) = (χ = (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ∧ φ = ξ)
    [prop] (χ ➝ ψ = χ ➝ φ) = (ψ = φ)
    [prop] (χ ➝ ψ = χ ➝ ξ) = (ψ = ξ)
    [prop] (χ ➝ ψ = Γ.conj ⋏ φ ➝ ξ) = (χ = Γ.conj ⋏ φ ∧ ψ = ξ)
    [prop] (χ ➝ ψ = Δ.conj ⋏ ψ ➝ ξ) = (χ = Δ.conj ⋏ ψ ∧ ψ = ξ)
    [prop] (χ ➝ ψ = (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ) ➝ (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ➝ ξ) =
