import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have hx := h₀.1
  have hy := h₀.2.1
  have hz := h₀.2.2
  have hx1 : x ≤ 1 := by linarith
  have hy1 : y ≤ 1 := by linarith
  have hz1 : z ≤ 1 := by linarith
  have hxy := mul_nonneg hx hy
  have hyz := mul_nonneg hy hz
  have hzx := mul_nonneg hz hx
  have hxyz := mul_nonneg hxy hz
  constructor
  · nlinarith [mul_nonneg (sub_nonneg.mpr hx1) hyz, mul_nonneg (sub_nonneg.mpr hy1) hzx, 
               mul_nonneg (sub_nonneg.mpr hz1) hxy, hxyz]
  · nlinarith [sq_nonneg (x - y), sq_nonneg (y - z), sq_nonneg (z - x),
               mul_nonneg hx (sq_nonneg (y - z)), mul_nonneg hy (sq_nonneg (z - x)), 
               mul_nonneg hz (sq_nonneg (x - y)), hxy, hyz, hzx, hxyz,
               sq_nonneg x, sq_nonneg y, sq_nonneg z]
```
