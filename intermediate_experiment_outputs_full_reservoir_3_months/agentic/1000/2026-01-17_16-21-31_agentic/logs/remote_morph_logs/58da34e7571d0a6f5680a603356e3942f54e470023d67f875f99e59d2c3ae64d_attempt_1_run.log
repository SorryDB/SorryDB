    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  haveI : ∀ j, SigmaFinite (μ j) := fun _ => inferInstance
  have hmeas : Measurable (fun (a : Fin d → ℝ) => a i) := measurable_pi_apply i
  have hmap : (Measure.pi μ).map (fun x : Fin d → ℝ => x i) = μ i := by
    ext s hs
    rw [Measure.map_apply hmeas hs]
    let t : Fin d → Set ℝ := fun j => if j = i then s else Set.univ
    have heq : (fun x : Fin d → ℝ => x i) ⁻¹' s = Set.pi Set.univ t := by
      ext x
