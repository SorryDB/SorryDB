      constructor <;> intro h
      · intro j; by_cases hji : j = i <;> simp_all
      · specialize h i; simp at h; exact h
    rw [heq, Measure.pi_pi (fun j => by split_ifs <;> simp [*])]
    exact Finset.prod_eq_single i (fun j _ hji => by simp [hji, measure_univ]) (by simp)
  refine ⟨(hmap ▸ hf.aestronglyMeasurable).comp_measurable hmeas, ?_⟩
  simp only [HasFiniteIntegral, Function.comp_apply]
  rw [← lintegral_map _ hmeas.aemeasurable, hmap]
  · exact hf.hasFiniteIntegral
  · exact measurable_nnnorm.coe_nnreal_ennreal.comp hf.aestronglyMeasurable.measurable
