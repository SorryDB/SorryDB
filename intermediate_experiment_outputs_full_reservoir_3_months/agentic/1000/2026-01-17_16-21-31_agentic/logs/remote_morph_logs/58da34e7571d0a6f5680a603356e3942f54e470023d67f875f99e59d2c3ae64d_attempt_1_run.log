```lean
lemma integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  haveI : ∀ j, SigmaFinite (μ j) := fun _ => inferInstance
  have hmeas : Measurable (fun (a : Fin d → ℝ) => a i) := measurable_pi_apply i
  refine Integrable.comp_measurable ?_ hmeas
  have hmap : (Measure.pi μ).map (fun x : Fin d → ℝ => x i) = μ i := by
    ext s hs
    rw [Measure.map_apply hmeas hs]
    have heq : (fun x : Fin d → ℝ => x i) ⁻¹' s =
        Set.pi Set.univ (fun j : Fin d => if j = i then s else Set.univ) := by
      ext x
      simp only [Set.mem_preimage, Set.mem_pi, Set.mem_univ, true_implies]
      constructor
      · intro h j; split_ifs with hji; subst hji; exact h; trivial
      · intro h; simpa using h i
    have hms : ∀ j, MeasurableSet ((fun j : Fin d => if j = i then s else Set.univ) j) :=
      fun j => by split_ifs <;> [exact hs; exact MeasurableSet.univ]
    rw [heq, Measure.pi_pi _ hms, Finset.prod_eq_single i]
    · simp
    · intro j _ hne; simp [hne]
    · simp
  rw [hmap]
  exact hf
