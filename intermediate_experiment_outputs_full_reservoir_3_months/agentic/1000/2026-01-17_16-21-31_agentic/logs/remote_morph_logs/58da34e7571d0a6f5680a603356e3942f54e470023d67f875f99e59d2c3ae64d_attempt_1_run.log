    · simp only [t, ↓reduceIte]
    · intro j _ hne; simp only [t, if_neg hne, measure_univ]
    · simp
  rw [← hmap] at hf
  exact (integrable_map_measure hmeas.aemeasurable hf.aestronglyMeasurable).mp hf
