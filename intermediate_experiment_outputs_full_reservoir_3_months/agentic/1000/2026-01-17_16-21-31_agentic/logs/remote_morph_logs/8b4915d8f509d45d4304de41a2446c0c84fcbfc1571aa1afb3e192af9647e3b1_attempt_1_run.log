/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  obtain ⟨N, hN, hBN⟩ := H
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') fun heq => hBN ?_
  ext M
  simp only [Set.mem_singleton_iff]
  constructor
  · intro hM
    have hMref : M ∈ (refinement B hB hB' hB'' : Set _) := by
      simp only [refinement, Set.mem_iUnion]; exact ⟨N, hN, hM⟩
    rw [heq] at hMref
    have hM_le_N : M ≤ N := (hB N hN).symm ▸ le_sSup hM
    by_contra hMN
    exact D.not_bot_mem (le_bot_iff.mp ((disjoint_iff_inf_le.mp
      (D.sSupIndep.pairwiseDisjoint hMref hN hMN)) ▸ le_inf le_rfl hM_le_N))
  · intro hM
    subst hM
    have hNref : N ∈ (refinement B hB hB' hB'' : Set _) := by rw [heq]; exact hN
    simp only [refinement, Set.mem_iUnion] at hNref
    obtain ⟨N', hN', hNN'⟩ := hNref
    have hN_le_N' : N ≤ N' := (hB N' hN').symm ▸ le_sSup hNN'
    by_cases hne : N = N'
    · subst hne; exact hNN'
    · exact absurd rfl (D.not_bot_mem (le_bot_iff.mp ((disjoint_iff_inf_le.mp
        (D.sSupIndep.pairwiseDisjoint hN hN' hne)) ▸ le_inf le_rfl hN_le_N')) ▸ hN)
```
