    have hlog_pos : 0 < Real.log P.n := Real.log_pos (by exact_mod_cast Nat.one_lt_iff_ne_one.mpr (by omega))
    have hM_pos : 0 < P.M ∨ P.M = 0 := by omega
    rcases hM_pos with hM_pos | hM_zero
    · have hbound : P.initial.balance p ≤ P.initial.a.card := by
        simp only [Factorization.balance, Factorization.sum, sub_le_iff_le_add]
        calc (P.initial.a.map (·.factorization p)).sum
          _ ≤ P.initial.a.card := Multiset.sum_le_card_nsmul _ _ 1 (fun x hx => by
              obtain ⟨m, hm, rfl⟩ := Multiset.mem_map.mp hx
              have hm_le : m ≤ P.n := P.initial.ha m hm
              have hm_pos : 0 < m := P.initial.hpos m hm
              by_cases h : p ∣ m
              · have hp_le_sqrt : (p : ℝ) ≤ Real.sqrt P.n := hp
                have hp_sq_le : p * p ≤ P.n := by
                  have := Real.sq_sqrt (Nat.cast_nonneg P.n)
                  have h1 : (p : ℝ) * p ≤ Real.sqrt P.n * Real.sqrt P.n := mul_le_mul hp_le_sqrt hp_le_sqrt (Nat.cast_nonneg p) (Real.sqrt_nonneg _)
                  rw [this] at h1; exact_mod_cast h1
                have : m.factorization p ≤ 1 := by
                  by_contra hc; push_neg at hc
                  have h2 : p ^ 2 ∣ m := pow_dvd_of_le_ord_proj_of_prime hprime hm_pos.ne' hc
                  have : p * p ≤ m := le_of_dvd hm_pos h2
                  have : P.n < p * p := by nlinarith [hm_le]
                  omega
                omega
              · simp [factorization_eq_zero_iff, hprime, h])
          _ ≤ _ := by simp [nsmul_eq_mul]
      calc (P.initial.balance p : ℝ) ≤ P.initial.a.card := by exact_mod_cast hbound
        _ ≤ P.n := by exact_mod_cast initial.card P
        _ ≤ P.M * Real.log P.n := by nlinarith [Real.add_one_le_exp (Real.log P.n), Real.exp_log (by exact_mod_cast hn_pos : (0:ℝ) < P.n)]
    · simp only [hM_zero, Nat.zero_mul, CharP.cast_eq_zero, zero_mul]
      simp only [Params.initial, hM_zero, Multiset.replicate_zero, Multiset.join_zero, Multiset.filter_zero] at *
      simp [Factorization.balance, Factorization.sum]
  · simp only [Factorization.balance, Factorization.sum]
    have h1 : (Multiset.map (fun m => m.factorization p) P.initial.a).sum = 0 :=
      Multiset.sum_eq_zero fun x hx => by
        obtain ⟨m, _, rfl⟩ := Multiset.mem_map.mp hx
        exact factorization_eq_zero_of_not_prime m hprime
    have h2 : P.n.factorial.factorization p = 0 := factorization_eq_zero_of_not_prime _ hprime
    simp [h1, h2]
