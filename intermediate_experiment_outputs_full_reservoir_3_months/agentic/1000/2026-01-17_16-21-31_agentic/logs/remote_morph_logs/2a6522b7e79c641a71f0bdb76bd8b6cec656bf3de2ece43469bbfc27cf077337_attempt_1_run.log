```lean
lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  cases n with
  | zero => exact Fin.elim0 k
  | succ m =>
    simp only [Nat.succ_sub_one]
    unfold isExpert at h
    unfold after at h
    by_contra hc
    push_neg at hc
    have hcard : Finset.univ.card = m + 1 := Finset.card_fin (m + 1)
    have : m + 1 ≤ S.length + 1 := by
      calc m + 1 = Finset.univ.card := hcard.symm
        _ ≤ (Finset.filter (fun j => (makeCalls (initialState (m + 1)) S) k j) Finset.univ).card + 
            (Finset.filter (fun j => ¬(makeCalls (initialState (m + 1)) S) k j) Finset.univ).card := by
          simp [Finset.filter_union_filter_neg_eq]
        _ = Finset.univ.card := by simp [Finset.filter_union_filter_neg_eq]
        _ = m + 1 := hcard
    omega
```
