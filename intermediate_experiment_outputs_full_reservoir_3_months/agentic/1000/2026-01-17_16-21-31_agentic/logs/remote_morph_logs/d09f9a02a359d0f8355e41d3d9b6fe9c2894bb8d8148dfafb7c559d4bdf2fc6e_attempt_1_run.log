    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra h
  push_neg at h
  obtain ⟨h1, h2, h3⟩ := h
  -- For an interior point P, trigonometric Ceva gives:
  -- sin(∠PAB)·sin(∠PBC)·sin(∠PCA) = sin(∠PAC)·sin(∠PBA)·sin(∠PCB)
