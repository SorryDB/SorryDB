/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have hloc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    obtain ⟨U₁, hU₁, hfU₁⟩ := (Metric.tendsto_nhds.mp hl 1 one_pos).exists_mem
    obtain ⟨U₂, hU₂, hfU₂⟩ := (Metric.tendsto_nhds.mp hrc 1 one_pos).exists_mem
    refine ⟨(U₁ ∪ {x}) ∪ U₂, ?_, ?_⟩
    · exact Filter.union_mem_sup (nhdsWithin_le_nhds (Filter.mem_of_superset hU₁ Set.subset_union_left))
            (nhdsWithin_le_nhds hU₂)
    · refine ((Metric.isBounded_ball (x := l)).union isBounded_singleton |>.union
            Metric.isBounded_ball).subset ?_
      intro y hy
      obtain ⟨z, ⟨hz_mem, _⟩, rfl⟩ := hy
      rcases hz_mem with (hz | hz) | hz
      · exact Or.inl (Or.inl (hfU₁ (Set.mem_image_of_mem f hz)))
      · simp only [Set.mem_singleton_iff] at hz; exact Or.inl (Or.inr (by simp [hz]))
      · exact Or.inr (hfU₂ (Set.mem_image_of_mem f hz))
  obtain ⟨t, hts, htfin, htcover⟩ := hs.elim_nhds_subcover (fun x _ => (hloc x ‹_›).choose)
    (fun x hx => (hloc x hx).choose_spec.1)
  refine (htfin.isBounded_biUnion (fun x hx => (hloc x (hts hx)).choose_spec.2)).subset ?_
  intro y hy
  obtain ⟨z, hz, rfl⟩ := hy
  obtain ⟨x, hxt, hzx⟩ := Set.mem_iUnion₂.mp (htcover hz)
  exact Set.mem_iUnion₂.mpr ⟨x, hxt, z, ⟨hzx, hz⟩, rfl⟩
