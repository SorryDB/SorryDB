/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  rcases s.eq_empty_or_nonempty with rfl | _
  · simp
  have hloc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    have h1 : ∀ᶠ y in 𝓝[<] x, dist (f y) l < 1 := Metric.tendsto_nhds.mp hl 1 one_pos
    have h2 : ∀ᶠ y in 𝓝[>] x, dist (f y) (f x) < 1 := Metric.tendsto_nhds.mp hrc 1 one_pos
    rw [eventually_nhdsWithin_iff] at h1 h2
    obtain ⟨V₁, hV₁_mem, hV₁_prop⟩ := h1
    obtain ⟨V₂, hV₂_mem, hV₂_prop⟩ := h2
    refine ⟨V₁ ∩ V₂, Filter.inter_mem hV₁_mem hV₂_mem, ?_⟩
    refine ((isBounded_closedBall.union isBounded_singleton).union isBounded_closedBall).subset ?_
    intro y hy
    obtain ⟨z, ⟨⟨hzV₁, hzV₂⟩, _⟩, rfl⟩ := hy
    rcases lt_trichotomy z x with hzx | rfl | hzx
    · left; left; exact Metric.mem_closedBall.mpr (le_of_lt (hV₁_prop z ⟨hzV₁, hzx⟩))
    · left; right; exact Set.mem_singleton _
    · right; exact Metric.mem_closedBall.mpr (le_of_lt (hV₂_prop z ⟨hzV₂, hzx⟩))
  choose U hU hbdd using hloc
  obtain ⟨T, hTcover⟩ := hs.elim_finite_subcover (fun x : ι => interior (U x))
    (fun _ => isOpen_interior) (fun x hx => Set.mem_iUnion.mpr ⟨x, mem_interior_iff_mem_nhds.mpr (hU x hx)⟩)
  refine (T.isBounded_biUnion fun x _ => (hbdd x (T.subset_of_mem_of_subset (by trivial) (by
    intro z hz
    have := hTcover hz
    simp only [Set.mem_iUnion, Finset.mem_coe] at this
    obtain ⟨y, hyT, hzy⟩ := this
    exact ⟨y, hyT, interior_subset hzy⟩) x (by trivial))).subset
      (Set.image_subset f (Set.inter_subset_inter_left s interior_subset))).subset ?_
  intro y hy
  obtain ⟨z, hz, rfl⟩ := hy
  have := hTcover hz
  simp only [Set.mem_iUnion, Finset.mem_coe] at this
  obtain ⟨w, hwT, hzw⟩ := this
  exact Set.mem_biUnion hwT (Set.mem_image_of_mem f ⟨interior_subset hzw, hz⟩)
