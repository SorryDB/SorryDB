```lean
/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  rcases s.eq_empty_or_nonempty with rfl | hs'
  · simp
  have hloc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    rw [Metric.tendsto_nhdsWithin_nhds] at hl
    rw [Metric.continuousWithinAt_iff] at hrc
    obtain ⟨δ₁, hδ₁, h1⟩ := hl 1 one_pos
    obtain ⟨δ₂, hδ₂, h2⟩ := hrc 1 one_pos
    refine ⟨Metric.ball x (min δ₁ δ₂), Metric.ball_mem_nhds x (lt_min hδ₁ hδ₂), ?_⟩
    refine Metric.isBounded_of_subset_closedBall (f x) (max (dist l (f x) + 1) 1) ?_
    intro y hy
    simp only [Set.mem_image, Set.mem_inter_iff, Metric.mem_ball] at hy
    obtain ⟨z, ⟨hz_ball, hz_s⟩, rfl⟩ := hy
    have hz_lt : dist z x < min δ₁ δ₂ := hz_ball
    rcases lt_trichotomy z x with hzx | rfl | hzx
    · have : dist (f z) l < 1 := h1 hzx (hz_lt.trans_le (min_le_left _ _))
      calc dist (f z) (f x) ≤ dist (f z) l + dist l (f x) := dist_triangle _ _ _
        _ < 1 + dist l (f x) := by linarith
        _ ≤ max (dist l (f x) + 1) 1 := by linarith [le_max_left (dist l (f x) + 1) 1]
    · simp [le_max_right]
    · have : dist (f z) (f x) < 1 := h2 hzx (hz_lt.trans_le (min_le_right _ _))
      calc dist (f z) (f x) < 1 := this
        _ ≤ max (dist l (f x) + 1) 1 := le_max_right _ _
  choose U hU hbdd using hloc
  obtain ⟨t, hts, htfin, htcover⟩ := hs.elim_nhds_subcover U hU
  have : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    intro y hy
    obtain ⟨z, hz, rfl⟩ := hy
    obtain ⟨x, hxt, hzU⟩ := Set.mem_iUnion₂.mp (htcover hz)
    exact Set.mem_iUnion₂.mpr ⟨x, hxt, ⟨z, ⟨hzU, hz⟩, rfl⟩⟩
  exact (htfin.isBounded_biUnion.mpr fun x hx => hbdd x (hts hx)).subset this
```
