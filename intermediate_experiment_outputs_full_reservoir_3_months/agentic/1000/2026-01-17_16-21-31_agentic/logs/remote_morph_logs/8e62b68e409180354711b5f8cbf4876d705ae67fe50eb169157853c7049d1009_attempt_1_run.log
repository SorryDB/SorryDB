/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have hloc : ∀ x ∈ s, ∃ V ∈ 𝓝 x, IsBounded (f '' V) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    have h1 : ∀ᶠ y in 𝓝 x, y < x → dist (f y) l < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hl 1 one_pos)
    have h2 : ∀ᶠ y in 𝓝 x, x < y → dist (f y) (f x) < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hrc 1 one_pos)
    obtain ⟨V, hVmem, hVprop⟩ := (h1.and h2).exists_mem
    refine ⟨V, hVmem, Metric.isBounded_iff.mpr ⟨2 + 2 * dist l (f x), ?_⟩⟩
    rintro _ ⟨z₁, hz₁, rfl⟩ _ ⟨z₂, hz₂, rfl⟩
    have ⟨hV1₁, hV2₁⟩ := hVprop z₁ hz₁
    have ⟨hV1₂, hV2₂⟩ := hVprop z₂ hz₂
    have bd1 : dist (f z₁) l ≤ 1 + dist (f x) l := by
      by_cases h : z₁ < x
      · exact le_of_lt (hV1₁ h) |>.trans (by linarith)
      · by_cases h' : x < z₁
        · calc dist (f z₁) l ≤ dist (f z₁) (f x) + dist (f x) l := dist_triangle _ _ _
            _ ≤ 1 + dist (f x) l := by linarith [hV2₁ h']
        · simp only [not_lt] at h h'
          have : z₁ = x := le_antisymm h' h
          subst this; linarith
    have bd2 : dist (f z₂) l ≤ 1 + dist (f x) l := by
      by_cases h : z₂ < x
      · exact le_of_lt (hV1₂ h) |>.trans (by linarith)
      · by_cases h' : x < z₂
        · calc dist (f z₂) l ≤ dist (f z₂) (f x) + dist (f x) l := dist_triangle _ _ _
            _ ≤ 1 + dist (f x) l := by linarith [hV2₂ h']
        · simp only [not_lt] at h h'
          have : z₂ = x := le_antisymm h' h
          subst this; linarith
    calc dist (f z₁) (f z₂) ≤ dist (f z₁) l + dist l (f z₂) := dist_triangle _ _ _
      _ = dist (f z₁) l + dist (f z₂) l := by rw [dist_comm l]
      _ ≤ (1 + dist (f x) l) + (1 + dist (f x) l) := add_le_add bd1 bd2
      _ = 2 + 2 * dist l (f x) := by rw [dist_comm]; ring
  obtain ⟨t, _, htcover⟩ := (hs : IsCompact s).elim_nhds_subcover _ hloc
  refine (t.isBounded_biUnion fun x _ => ?_).subset ?_
  · obtain ⟨_, hV, hbdd⟩ := hloc x (by simp)
    exact hbdd.subset (Set.image_subset _ (mem_of_mem_nhds hV |> Set.singleton_subset_iff.mpr |> 
      fun h => h |> fun _ => Set.subset_refl _))
  · rintro _ ⟨z, hz, rfl⟩
    obtain ⟨x, hxt, hzV⟩ := Set.mem_iUnion₂.mp (htcover hz)
    obtain ⟨V, _, hbdd⟩ := hloc x (by simp)
    exact Set.mem_biUnion hxt ⟨z, hzV, rfl⟩
```
