/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have hloc : ∀ x : ι, ∃ V : Set ι, V ∈ 𝓝 x ∧ IsBounded (f '' (V ∩ s)) := fun x => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    have h1 : ∀ᶠ y in 𝓝 x, y < x → dist (f y) l < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hl 1 one_pos)
    have h2 : ∀ᶠ y in 𝓝 x, x < y → dist (f y) (f x) < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hrc 1 one_pos)
    obtain ⟨V, hVmem, hVprop⟩ := (h1.and h2).exists_mem
    refine ⟨V, hVmem, ?_⟩
    refine (Metric.isBounded_closedBall (x := l) (r := 1) |>.union
      (Metric.isBounded_singleton (x := f x) |>.union
        Metric.isBounded_closedBall (x := f x) (r := 1))).subset ?_
    rintro _ ⟨z, ⟨hzV, _⟩, rfl⟩
    have ⟨hV1, hV2⟩ := hVprop z hzV
    by_cases hzx : z < x
    · exact Or.inl (Metric.mem_closedBall.mpr (le_of_lt (hV1 hzx)))
    · by_cases hxz : x < z
      · exact Or.inr (Or.inr (Metric.mem_closedBall.mpr (le_of_lt (hV2 hxz))))
      · by_cases hzeq : z = x
        · subst hzeq; exact Or.inr (Or.inl rfl)
        · exact Or.inr (Or.inl rfl)
  choose V hVmem hVbdd using hloc
  obtain ⟨t, hts, htcover⟩ := hs.elim_nhds_subcover V (fun x _ => hVmem x)
  refine (t.isBounded_biUnion fun x _ => hVbdd x).subset ?_
  rintro _ ⟨z, hz, rfl⟩
  obtain ⟨x, hxt, hzV⟩ := Set.mem_iUnion₂.mp (htcover hz)
  exact Set.mem_biUnion hxt ⟨z, ⟨hzV, hz⟩, rfl⟩
