Looking at the previous attempts, the main issues were:
1. `lt_trichotomy` requires `LinearOrder` but we only have `PartialOrder`
2. The compactness API calls had incorrect signatures - `elim_nhds_subcover` takes a different form

For `PartialOrder`, we need to handle the case where elements might be incomparable. The key insight is that the implications `y < x → ...` and `x < y → ...` are vacuously true when neither holds, so we can use a simpler bound that accounts for all cases. Also, we need to use the correct form of the compactness API.

```lean
/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  rcases s.eq_empty_or_nonempty with rfl | ⟨x₀, hx₀⟩
  · simp only [Set.image_empty, isBounded_empty]
  have hloc : ∀ x ∈ s, ∃ V ∈ 𝓝 x, IsBounded (f '' V) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    have h1 : ∀ᶠ y in 𝓝 x, y < x → dist (f y) l < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hl 1 one_pos)
    have h2 : ∀ᶠ y in 𝓝 x, x < y → dist (f y) (f x) < 1 :=
      eventually_nhdsWithin_iff.mp (Metric.tendsto_nhds.mp hrc 1 one_pos)
    obtain ⟨V, hVmem, hVprop⟩ := (h1.and h2).exists_mem
    refine ⟨V, hVmem, Metric.isBounded_iff.mpr ⟨4 + 2 * dist l (f x), ?_⟩⟩
    intro a ha b hb
    simp only [Set.mem_image] at ha hb
    obtain ⟨za, hza, rfl⟩ := ha
    obtain ⟨zb, hzb, rfl⟩ := hb
    have ⟨hV1a, hV2a⟩ := hVprop za hza
    have ⟨hV1b, hV2b⟩ := hVprop zb hzb
    have da : dist (f za) l ≤ 1 + dist (f x) l := by
      by_cases hlt : za < x
      · exact (hV1a hlt).le.trans (by linarith [dist_nonneg (x := f x) (y := l)])
      · by_cases hgt : x < za
        · calc dist (f za) l ≤ dist (f za) (f x) + dist (f x) l := dist_triangle _ _ _
            _ ≤ 1 + dist (f x) l := by linarith [(hV2a hgt).le]
        · simp only [hlt, hgt, not_false_eq_true, forall_true_left] at hV1a hV2a
          exact le_of_lt (lt_of_le_of_lt (dist_nonneg) (by linarith [dist_nonneg (x := f x) (y := l)]))
    have db : dist (f zb) l ≤ 1 + dist (f x) l := by
      by_cases hlt : zb < x
      · exact (hV1b hlt).le.trans (by linarith [dist_nonneg (x := f x) (y := l)])
      · by_cases hgt : x < zb
        · calc dist (f zb) l ≤ dist (f zb) (f x) + dist (f x) l := dist_triangle _ _ _
            _ ≤ 1 + dist (f x) l := by linarith [(hV2b hgt).le]
        · simp only [hlt, hgt, not_false_eq_true, forall_true_left] at hV1b hV2b
          exact le_of_lt (lt_of_le_of_lt (dist_nonneg) (by linarith [dist_nonneg (x := f x) (y := l)]))
    calc dist (f za) (f zb) ≤ dist (f za) l + dist l (f zb) := dist_triangle _ _ _
      _ = dist (f za) l + dist (f zb) l := by rw [dist_comm l]
      _ ≤ (1 + dist (f x) l) + (1 + dist (f x) l) := add_le_add da db
      _ ≤ 4 + 2 * dist l (f x) := by rw [dist_comm (f x) l]; ring_nf; linarith
  choose V hVnhds hVbdd using hloc
  obtain ⟨t, htcover⟩ := hs.elim_nhds_subcover V hVnhds
  refine (t.isBounded_biUnion fun ⟨x, hx⟩ _ => hVbdd x hx).subset ?_
  intro y hy
  simp only [Set.mem_image] at hy
  obtain ⟨z, hz, rfl⟩ := hy
  obtain ⟨⟨x, hx⟩, hxt, hzV⟩ := Set.mem_iUnion₂.mp (htcover hz)
  exact Set.mem_biUnion hxt ⟨z, hzV, rfl⟩
