/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have hloc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := fun x _ => by
    obtain ⟨l, hl⟩ := hf.left_limit x
    have hrc := hf.right_continuous x
    have h1 : ∀ᶠ y in 𝓝[<] x, dist (f y) l < 1 := Metric.tendsto_nhds.mp hl 1 one_pos
    have h2 : ∀ᶠ y in 𝓝[>] x, dist (f y) (f x) < 1 := Metric.tendsto_nhds.mp hrc 1 one_pos
    rw [mem_nhdsWithin] at h1 h2
    obtain ⟨V₁, hV₁_open, hxV₁, hV₁_prop⟩ := h1
    obtain ⟨V₂, hV₂_open, hxV₂, hV₂_prop⟩ := h2
    refine ⟨V₁ ∩ V₂, Filter.inter_mem (hV₁_open.mem_nhds hxV₁) (hV₂_open.mem_nhds hxV₂), ?_⟩
    have hsub : f '' ((V₁ ∩ V₂) ∩ s) ⊆ Metric.closedBall l 1 ∪ {f x} ∪ Metric.closedBall (f x) 1 := by
      intro y hy
      obtain ⟨z, ⟨⟨hzV₁, hzV₂⟩, _⟩, rfl⟩ := hy
      rcases lt_trichotomy z x with hzx | rfl | hzx
      · left; left; exact Metric.mem_closedBall.mpr (le_of_lt (hV₁_prop ⟨hzV₁, hzx⟩))
      · left; right; exact Set.mem_singleton _
      · right; exact Metric.mem_closedBall.mpr (le_of_lt (hV₂_prop ⟨hzV₂, hzx⟩))
    exact (isBounded_closedBall.union isBounded_singleton |>.union isBounded_closedBall).subset hsub
  choose U hU_mem hU_bdd using hloc
  obtain ⟨t, hts, htfin, htcover⟩ := hs.elim_nhds_subcover U hU_mem
  refine (htfin.isBounded_biUnion (fun x hx => hU_bdd x (hts hx))).subset ?_
  intro y hy
  obtain ⟨z, hz, rfl⟩ := hy
  obtain ⟨x, hxt, hzU⟩ := Set.mem_iUnion₂.mp (htcover hz)
  exact Set.mem_iUnion₂.mpr ⟨x, hxt, z, ⟨hzU, hz⟩, rfl⟩
```
