  have hinv : Function.Involutive (secondInvo k) := fun x => congrFun (secondInvo_sq k) x
  have hfp : Fintype.card (fixedPoints (secondInvo k)) = 1 := card_fixedPoints_eq_one k
  have hbij := hinv.bijective
  let e := Equiv.ofBijective _ hbij
  have he : e * e = 1 := by ext x; exact hinv x
  have hcard := Equiv.Perm.card_support_modEq e
  rw [Nat.odd_iff]
  have hsup : e.support.card % 2 = 0 := Nat.even_iff.mp (Equiv.Perm.card_support_eq_two_mul_card_cycleType_count_two he)
