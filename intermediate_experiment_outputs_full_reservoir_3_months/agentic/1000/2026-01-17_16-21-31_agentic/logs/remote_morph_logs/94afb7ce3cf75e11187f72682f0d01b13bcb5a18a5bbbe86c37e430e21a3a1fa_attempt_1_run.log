-- exercise 1.4.i
noncomputable def NatIso_inverse {α β : Type*} [C : Category α] [D : Category β]
    {F G : Functor α β} (η : NaturalTransformation F G) (h : IsNatIso η) :
    NaturalTransformation G F where
  arrow X := by
    have := h X
    rw [iso_iff_isIso] at this
    choose f hf using this
    exact f.inv

  naturality {X Y} f := by
    have hX := h X
    have hY := h Y
    rw [iso_iff_isIso] at hX hY
    have specX := Classical.choose_spec hX
    have specY := Classical.choose_spec hY
    have rY := (Classical.choose hY).right_inv
    have lX := (Classical.choose hX).left_inv
    have nat := η.naturality f
    rw [← id_comp (G.homF f ≫ _), ← lX]
    rw [assoc, assoc, ← specX]
    rw [← assoc (η.arrow X), ← nat]
    rw [assoc (F.homF f), specY, ← assoc]
    rw [rY, comp_id]
```
