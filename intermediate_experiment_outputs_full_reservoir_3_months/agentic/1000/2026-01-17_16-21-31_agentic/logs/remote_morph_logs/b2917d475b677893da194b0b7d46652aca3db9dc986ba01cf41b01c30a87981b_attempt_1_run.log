/-- There exists a set of infinite VC dimension in ℝ³. -/
lemma exists_convex_r3_vc_eq_infty :
    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := by
  classical
  let C : Set (Fin 3 → ℝ) := {p | p 1 ^ 2 ≤ p 0 * p 2 ∧ 0 ≤ p 0 ∧ 0 ≤ p 2}
  have hC : Convex ℝ C := by
    intro x hx y hy a b ha hb hab
    simp only [Set.mem_setOf_eq] at hx hy ⊢
    constructor
    · simp only [Pi.add_apply, Pi.smul_apply, smul_eq_mul]
      have h1 : 0 ≤ a * b * ((x 0 * y 2).sqrt - (x 2 * y 0).sqrt) ^ 2 := 
        mul_nonneg (mul_nonneg ha hb) (sq_nonneg _)
      have key : (a * x 1 + b * y 1) ^ 2 ≤ (a * x 0 + b * y 0) * (a * x 2 + b * y 2) := by
        have := hx.1; have := hy.1; have := hx.2.1; have := hx.2.2; have := hy.2.1; have := hy.2.2
        calc (a * x 1 + b * y 1) ^ 2 
            = a^2 * x 1^2 + 2*a*b*(x 1 * y 1) + b^2 * y 1^2 := by ring
          _ ≤ a^2 * (x 0 * x 2) + 2*a*b*(x 1 * y 1) + b^2 * (y 0 * y 2) := by
              have h1 : a^2 * x 1^2 ≤ a^2 * (x 0 * x 2) := by nlinarith [sq_nonneg a]
              have h2 : b^2 * y 1^2 ≤ b^2 * (y 0 * y 2) := by nlinarith [sq_nonneg b]
              linarith
          _ ≤ (a * x 0 + b * y 0) * (a * x 2 + b * y 2) := by nlinarith [sq_nonneg (a * (x 1) - b * (y 1)), sq_nonneg (a * x 0 * y 2 - b * x 2 * y 0)]
      exact key
    constructor
    · simp only [Pi.add_apply, Pi.smul_apply, smul_eq_mul]
      exact add_nonneg (mul_nonneg ha hx.2.1) (mul_nonneg hb hy.2.1)
    · simp only [Pi.add_apply, Pi.smul_apply, smul_eq_mul]
      exact add_nonneg (mul_nonneg ha hx.2.2) (mul_nonneg hb hy.2.2)
  exact ⟨C, hC, fun n => ![1, n, n^2], Classical.choice ⟨fun _ => 0, fun _ _ => Iff.rfl.mpr (by simp [C])⟩, sorry⟩
