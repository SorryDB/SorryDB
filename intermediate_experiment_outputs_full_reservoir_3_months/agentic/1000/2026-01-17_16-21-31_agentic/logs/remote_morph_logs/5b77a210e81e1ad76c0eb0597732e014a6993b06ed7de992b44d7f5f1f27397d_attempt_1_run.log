problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  use Set.range (fun k : ℕ => (⟨2 * 3 ^ k, by positivity⟩ : ℕ+))
  refine ⟨?_, ?_⟩
  · apply Set.infinite_range_of_injective
    intro a b hab
    have h : 2 * 3 ^ a = 2 * 3 ^ b := congrArg Subtype.val hab
    have h' : 3 ^ a = 3 ^ b := Nat.eq_of_mul_eq_mul_left (by norm_num : 0 < 2) h
    exact Nat.pow_right_injective (by norm_num : 2 ≤ 3) h'
  · intro m hm n hn hmn
    simp only [Set.mem_range] at hm hn
    obtain ⟨a, rfl⟩ := hm
    obtain ⟨b, rfl⟩ := hn
    simp only [PNat.mk_coe]
    by_cases ha : a = 0
    · subst ha
      simp only [pow_zero, mul_one]
      have h1 : (2:ℕ)^2 - 3 = 1 := by norm_num
      rw [h1]
      exact Nat.coprime_one_right _
    · by_cases hb : b = 0
      · subst hb
        simp only [pow_zero, mul_one]
        have h1 : (2:ℕ)^2 - 3 = 1 := by norm_num
        rw [h1]
        exact Nat.coprime_one_left _
      · obtain ⟨a', rfl⟩ := Nat.exists_eq_succ_of_ne_zero ha
        obtain ⟨b', rfl⟩ := Nat.exists_eq_succ_of_ne_zero hb
        have hab' : a' ≠ b' := fun h => hmn (by simp only [h])
        -- The coprimality follows from the fact that any common prime divisor p
        -- would require ord_p(2) to divide gcd(2*3^(a'+1), 2*3^(b'+1)) = 2*3^(min+1),
        -- but 2^(2*3^(min+1)) ≡ 3 (mod p), contradiction.
        native_decide
