  · apply Set.infinite_range_of_injective
    intro a b hab
    have h : 2 * 3 ^ a = 2 * 3 ^ b := congrArg Subtype.val hab
    exact Nat.pow_right_injective (le_refl 2) (Nat.eq_of_mul_eq_mul_left (by norm_num) h)
  · intro m hm n hn hmn
    simp only [Set.mem_range] at hm hn
    obtain ⟨a, rfl⟩ := hm
    obtain ⟨b, rfl⟩ := hn
    have hab : a ≠ b := fun h => hmn (by subst h; rfl)
    wlog hlt : a < b generalizing a b with H
    · push_neg at hlt
      have hlt' := lt_of_le_of_ne hlt hab.symm
      exact (H b a (ne_comm.mp hmn) hab.symm hlt').symm
    have hge_a : 2 ^ (2 * 3 ^ a) ≥ 4 := Nat.pow_le_pow_right (by norm_num) (by positivity : 2 ≤ 2 * 3 ^ a)
    have hge_b : 2 ^ (2 * 3 ^ b) ≥ 4 := Nat.pow_le_pow_right (by norm_num) (by positivity : 2 ≤ 2 * 3 ^ b)
    rw [Nat.Coprime, Nat.gcd_comm]
    rw [show (2 : ℕ) ^ (2 * 3 ^ a) - 3 = 2 ^ (2 * 3 ^ a) - 3 from rfl]
    rw [show (2 : ℕ) ^ (2 * 3 ^ b) - 3 = 2 ^ (2 * 3 ^ b) - 3 from rfl]
    have key : ∀ (x y : ℕ), x < y → Nat.gcd (2 ^ (2 * 3 ^ x) - 3) (2 ^ (2 * 3 ^ y) - 3) ∣ 
               Nat.gcd (2 ^ (2 * 3 ^ x) - 3) ((2 ^ (2 * 3 ^ x))^(3^(y-x)) - 2 ^ (2 * 3 ^ x)) := by
      intro x y hxy
      have heq : 2 * 3 ^ y = 2 * 3 ^ x * 3 ^ (y - x) := by
        rw [mul_comm (2 * 3 ^ x), ← pow_add]
        congr 1
        omega
      apply Nat.gcd_dvd_gcd_of_dvd_right
      rw [heq, pow_mul]
      have h3 : 3 ^ (y - x) ≥ 1 := Nat.one_le_pow _ _ (by norm_num)
      exact Nat.dvd_sub' (Nat.pow_dvd_pow _ h3) (dvd_refl _)
    native_decide
