import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  classical
  have h : ∀ k : ℕ, ∃ f : Fin (k + 1) → ℕ+, Function.Injective f ∧
      (∀ i, 2 ≤ (f i).val) ∧
      ∀ i j, i ≠ j → Nat.Coprime (2 ^ (f j).val - 3) (2 ^ (f i).val - 3) := by
    intro k
    induction k with
    | zero =>
      use fun _ => ⟨2, by norm_num⟩
      constructor
      · intro i j _; fin_omega
      constructor
      · intro i; norm_num
      · intro i j h; fin_omega
    | succ n ih =>
      obtain ⟨f, hf_inj, hf_ge, hf_coprime⟩ := ih
      sorry
  choose f hf using h
  use ⋃ k, Set.range (fun i : Fin (k + 1) => f k i)
  constructor
  · rw [Set.infinite_coe_iff]
    apply Set.infinite_iUnion
    intro n
    use Set.range (fun i : Fin (n + 1 + 1) => f (n + 1) i)
    constructor
    · exact Set.mem_iUnion.mpr ⟨n + 1, rfl⟩
    · have : Fintype.card (Fin (n + 1 + 1)) = n + 2 := Fintype.card_fin _
      have hinj := (hf (n + 1)).1
      exact Set.ncard_image_of_injective _ hinj ▸ (by simp [this]; omega)
  · intro a ha b hb hab
    simp only [Set.mem_iUnion, Set.mem_range] at ha hb
    obtain ⟨ka, ia, rfl⟩ := ha
    obtain ⟨kb, ib, rfl⟩ := hb
    sorry
```
