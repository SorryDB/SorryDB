problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  use Set.range (fun k : ℕ => ⟨2 * 3 ^ k, by positivity⟩)
  constructor
  · apply Set.infinite_range_of_injective
    intro a b h
    simp only [PNat.mk.injEq] at h
    have h' : 3 ^ a = 3 ^ b := by omega
    exact Nat.pow_right_injective (by norm_num : 1 < 3) h'
  · intro m hm n hn hmn
    simp only [Set.mem_range] at hm hn
    obtain ⟨a, rfl⟩ := hm
    obtain ⟨b, rfl⟩ := hn
    simp only [PNat.mk.injEq, ne_eq, PNat.val_ofNat, PNat.pow_coe, PNat.coe_mul] at hmn ⊢
    wlog hab : a < b generalizing a b
    · cases' (Ne.lt_or_lt (by rintro rfl; exact hmn rfl : a ≠ b)) with h h
      · exact this b a hmn.symm (Nat.Coprime.symm) h
      · exact hab h
    have key : ∀ p : ℕ, p.Prime → p ∣ 2 ^ (2 * 3 ^ a) - 3 → p ∣ 2 ^ (2 * 3 ^ b) - 3 → False := by
      intro p hp hdiva hdivb
      have hodd : Odd p := hp.odd_of_ne_two (by
        intro h2; subst h2
        have : 2 ∣ 2 ^ (2 * 3 ^ a) - 3 := hdiva
        have h1 : 2 ^ (2 * 3 ^ a) ≥ 4 := by positivity
        omega)
      have hcong : 2 ^ (2 * 3 ^ a) ≡ 3 [MOD p] := (Nat.modEq_iff_dvd' (by positivity)).mpr hdiva
      have hcongb : 2 ^ (2 * 3 ^ b) ≡ 3 [MOD p] := (Nat.modEq_iff_dvd' (by positivity)).mpr hdivb
      have : 2 ^ (2 * 3 ^ a) ≡ 2 ^ (2 * 3 ^ b) [MOD p] := hcong.trans hcongb.symm
      have hord := Nat.ModEq.pow_card_sub_one_eq_one hp (Nat.Coprime.symm (Nat.Prime.coprime_iff_not_dvd hp).mpr (by
        intro hdiv2; have := Nat.Prime.eq_one_or_self_of_dvd hp 2 hdiv2
        omega))
      sorry
    exact Nat.Coprime.eq_one_of_self_dvd _ (fun d hd hdiv1 hdiv2 => by
      rcases Nat.eq_one_or_self_of_prime_of_dvd (Nat.minFac_prime (by omega : d ≠ 1)) hd with h | h
      · exact h
      · exact absurd (key d.minFac (Nat.minFac_prime (by omega)) 
          (Nat.dvd_trans (Nat.minFac_dvd d) hdiv1)
          (Nat.dvd_trans (h ▸ Nat.minFac_dvd d) hdiv2)) False.elim)
