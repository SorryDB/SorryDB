problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  use Set.range (fun k : ℕ => (⟨2 * 3 ^ k, by positivity⟩ : ℕ+))
  refine ⟨?_, ?_⟩
  · apply Set.infinite_range_of_injective
    intro a b hab
    have h : 2 * 3 ^ a = 2 * 3 ^ b := congrArg Subtype.val hab
    have h' : 3 ^ a = 3 ^ b := Nat.eq_of_mul_eq_mul_left (by norm_num : 0 < 2) h
    exact Nat.pow_right_injective (by norm_num : 2 ≤ 3) h'
  · intro m hm n hn hmn
    simp only [Set.mem_range] at hm hn
    obtain ⟨a, rfl⟩ := hm
    obtain ⟨b, rfl⟩ := hn
    simp only [PNat.mk_coe]
    match a, b with
    | 0, 0 => exact (hmn rfl).elim
    | 0, b + 1 =>
      have : (2 : ℕ) ^ 2 - 3 = 1 := by norm_num
      simp only [pow_zero, mul_one, this]
      exact Nat.coprime_one_right _
    | a + 1, 0 =>
      have : (2 : ℕ) ^ 2 - 3 = 1 := by norm_num
      simp only [pow_zero, mul_one, this]
      exact Nat.coprime_one_left _
    | a + 1, b + 1 =>
      have hab : a ≠ b := fun h => hmn (by simp only [h])
      wlog hlt : a < b generalizing a b with H
      · push_neg at hlt
        rcases hlt.eq_or_lt with rfl | hgt
        · exact (hab rfl).elim
        · exact Nat.Coprime.symm (H b a (fun h => hmn (by simp only [h])) (Ne.symm hab) hgt)
      · have h1 : 2 ^ (2 * 3 ^ (a + 1)) ≥ 3 := by nlinarith [Nat.one_le_pow (2 * 3 ^ (a + 1)) 2 (by norm_num)]
        have h2 : 2 ^ (2 * 3 ^ (b + 1)) ≥ 3 := by nlinarith [Nat.one_le_pow (2 * 3 ^ (b + 1)) 2 (by norm_num)]
        have hmod : (2 ^ (2 * 3 ^ (a + 1)) - 3) % 3 = 1 := by
          have : 2 ^ (2 * 3 ^ (a + 1)) % 3 = 1 := by
            have h4mod3 : (4 : ℕ) % 3 = 1 := by norm_num
            calc 2 ^ (2 * 3 ^ (a + 1)) % 3 = (2 ^ 2) ^ (3 ^ (a + 1)) % 3 := by ring_nf
              _ = 4 ^ (3 ^ (a + 1)) % 3 := by norm_num
              _ = (4 % 3) ^ (3 ^ (a + 1)) % 3 := by rw [Nat.pow_mod]
              _ = 1 := by simp [h4mod3]
          omega
        rw [Nat.Coprime]
        apply Nat.coprime_of_dvd
        intro p hp hdvda hdvdb
        have hpodd : p ≠ 2 := fun h => by subst h; have := Nat.even_pow.mpr ⟨Nat.even_two, by omega⟩; omega
        have hpnot3 : p ≠ 3 := fun h => by subst h; omega
        have hdiff : p ∣ 2 ^ (2 * 3 ^ (b + 1)) - 2 ^ (2 * 3 ^ (a + 1)) := Nat.dvd_sub h2 hdvdb hdvda
        have hfactor : 2 ^ (2 * 3 ^ (b + 1)) - 2 ^ (2 * 3 ^ (a + 1)) = 
                       2 ^ (2 * 3 ^ (a + 1)) * (2 ^ (2 * 3 ^ (b + 1) - 2 * 3 ^ (a + 1)) - 1) := by
          rw [Nat.mul_sub_one, ← Nat.pow_add]
          congr 1
          omega
        rw [hfactor] at hdiff
        have hcoprime2 : Nat.Coprime p (2 ^ (2 * 3 ^ (a + 1))) := by
          apply Nat.Coprime.pow_right
          rw [Nat.coprime_comm, Nat.Prime.coprime_iff_not_dvd Nat.prime_two]
          exact fun h => hpodd (Nat.Prime.eq_one_or_self_of_prime_of_dvd hp Nat.prime_two h).resolve_left (by omega)
        have hdvdrest : p ∣ 2 ^ (2 * 3 ^ (b + 1) - 2 * 3 ^ (a + 1)) - 1 := 
          (Nat.Coprime.dvd_of_dvd_mul_left hcoprime2 hdiff)
        sorry
