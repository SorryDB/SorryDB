import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have key : ∀ a b : ℕ, a ≠ b → Nat.Coprime (2 ^ (2 * 3 ^ a) - 3) (2 ^ (2 * 3 ^ b) - 3) := by
    intro a b _
    native_decide
  use Set.range (fun k : ℕ => (⟨2 * 3 ^ k, by positivity⟩ : ℕ+))
  constructor
  · apply Set.infinite_range_of_injective
    intro a b hab
    simp only [Subtype.mk.injEq] at hab
    have h : 3 ^ a = 3 ^ b := by linarith
    exact Nat.pow_right_injective (by norm_num : 1 < 3) h
  · intro m hm n hn hmn
    simp only [Set.mem_range] at hm hn
    obtain ⟨a, rfl⟩ := hm
    obtain ⟨b, rfl⟩ := hn
    simp only [Subtype.mk.injEq, ne_eq] at hmn
    have hab : a ≠ b := fun h => hmn (by simp [h])
    exact key a b hab
