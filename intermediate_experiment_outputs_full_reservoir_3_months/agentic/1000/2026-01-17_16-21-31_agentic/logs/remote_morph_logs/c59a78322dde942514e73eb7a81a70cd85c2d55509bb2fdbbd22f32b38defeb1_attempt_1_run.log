      Finset.card_le_card (Finset.subset_insert _ _)
    omega
  | @loop _ u' v' q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, dartEdge, List.map_cons, List.toFinset_cons]
    have h1 : q.support.toFinset.card ≤ (List.map dartEdge q.darts).toFinset.card + 1 := ih
    have h2 : (Finset.insert u' q.support.toFinset).card ≤ q.support.toFinset.card + 1 := 
      Finset.card_insert_le u' q.support.toFinset
    have h3 : (List.map dartEdge q.darts).toFinset.card ≤ 
