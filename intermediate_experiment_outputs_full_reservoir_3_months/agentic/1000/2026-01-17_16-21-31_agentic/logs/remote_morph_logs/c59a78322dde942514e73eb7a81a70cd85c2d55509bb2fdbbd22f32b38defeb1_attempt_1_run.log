  (supportSet p).card ≤ (edgeSet p).card +1 := by
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | @cons _ u' v' w' h q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, dartEdge, List.map_cons, List.toFinset_cons]
    have h1 : q.support.toFinset.card ≤ (List.map dartEdge q.darts).toFinset.card + 1 := ih
