lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have hv : V(G, M') ⊆ V(G, M) := (G.vertexSet_edgeSet_mono hM'.subset).trans hsu
    have hinj : ∃ f : M' → M, Function.Injective f := by
      choose g hg using fun e (he : e ∈ M') => 
        G.inc_some_mem_vertexSet_edge (hM'.subset he)
      have hgM : ∀ e he, g e he ∈ V(G, M) := fun e he => hv (hg e he)
      choose m hm using fun e he => hgM e he
      refine ⟨fun ⟨e, he⟩ => ⟨m e he, (hm e he).1⟩, ?_⟩
      intro ⟨e₁, he₁⟩ ⟨e₂, he₂⟩ heq
      simp only [Subtype.mk.injEq] at heq ⊢
      by_contra hne
      have : g e₁ he₁ ∈ V(G, m e₁ he₁) ∩ V(G, m e₂ he₂) := ⟨(hm e₁ he₁).2, heq ▸ (hm e₁ he₁).2⟩
      have hv1 : g e₁ he₁ ∈ V(G, e₁) := hg e₁ he₁
      have hv2 : g e₂ he₂ ∈ V(G, e₂) := hg e₂ he₂
      have hdisj : Disjoint V(G, e₁) V(G, e₂) := hM'.disjoint he₁ he₂ hne
      have hsame : g e₁ he₁ ∈ V(G, m e₁ he₁) ∧ g e₂ he₂ ∈ V(G, m e₁ he₁) := 
        ⟨(hm e₁ he₁).2, heq ▸ (hm e₂ he₂).2⟩
      have : g e₁ he₁ ∈ M ∩ E(G, g e₁ he₁) := ⟨(hm e₁ he₁).1, (hm e₁ he₁).2⟩
      exact (hM'.disjoint he₁ he₂ hne).le_bot ⟨hv1, by rw [hM.subsingleton_inc (g e₁ he₁) ⟨(hm e₁ he₁).1, (hm e₁ he₁).2⟩ ⟨heq ▸ (hm e₂ he₂).1, heq ▸ (hm e₂ he₂).2⟩] at hv2; exact hv2⟩
    exact encard_le_encard_of_injective hinj.choose hinj.choose_spec
