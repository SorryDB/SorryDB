@[blueprint
  "initial-score"
  (statement := /-- The score of the initial factorization can be taken to be $o(n)$.-/)
  (proof := /-- Pick $M$ large depending on $\varepsilon$, then $L = M^2$, then assume $n$ large.
  Using the prime number theorem and Theorem \ref{initial-factorization-waste},
  Theorem \ref{initial-factorization-large-prime-le},
  Theorem \ref{initial-factorization-large-prime-ge},
  Theorem \ref{initial-factorization-medium-prime-le},
  Theorem \ref{initial-factorization-medium-prime-ge},
  Theorem \ref{initial-factorization-small-prime-le},
  Theorem \ref{initial-factorization-small-prime-ge}, and
  Theorem \ref{initial-factorization-tiny-prime-ge}, one can hold all losses to be of size
  $O(\varepsilon n)$.-/)]
theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  filter_upwards [Filter.eventually_gt_atTop 4] with n hn
  refine ⟨⟨n, 2, 2, by norm_num, by nlinarith⟩, rfl, ?_⟩
  have hw := Params.initial.waste ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hbl := @Params.initial.balance_large_prime_le ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hbg := @Params.initial.balance_large_prime_ge ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hml := @Params.initial.balance_medium_prime_le ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hmg := @Params.initial.balance_medium_prime_ge ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hsl := @Params.initial.balance_small_prime_le ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have hsg := @Params.initial.balance_small_prime_ge ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  have htg := @Params.initial.balance_tiny_prime_ge ⟨n, 2, 2, by norm_num, (by nlinarith : n > 2 * 2)⟩
  simp only [Params.initial, Factorization.score] at *
  linarith [hw, Real.log_nonneg (by linarith : (1 : ℝ) ≤ n), Real.log_pos (by linarith : (1 : ℝ) < n), 
            mul_pos hε (by positivity : (0 : ℝ) < n)]
