  use 5
  intro n hn
  have hL : n > 2 * 2 := by omega
  let P : Params := ⟨n, 2, 2, by norm_num, hL⟩
  refine ⟨P, rfl, ?_⟩
  unfold Factorization.score Factorization.waste Factorization.sum
  simp only [Params.initial]
  all_goals sorry
