```lean
/-- Any fixed point of `secondInvo k` must be `(k, 1, 1)`. -/
theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, secondInvo, secondInvo_fun,
    singletonFixedPoint, Prod.mk_one_one, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    simp at ht
    simp only [Set.mem_singleton_iff]
    obtain ⟨⟨⟨x, y, z⟩, hS⟩, hU⟩ := t
    simp only [S, Set.mem_setOf_eq] at hS
    obtain ⟨hsum, hx_pos, hy_pos⟩ := hS
    have heq : (x - y + z, y, 2 * y - z) = (x, y, z) := congrArg (·.1.1) ht
    have hz : z = y := by
      have h3 : 2 * y - z = z := (Prod.ext_iff.mp (Prod.ext_iff.mp heq).2).2
      linarith
    have hfact : y * (4 * x + y) = 4 * (k : ℤ) + 1 := by nlinarith
    have hp := hk.out
    have y_nn : 0 ≤ y := le_of_lt hy_pos
    have y_eq : (y.toNat : ℤ) = y := Int.toNat_of_nonneg y_nn
    have other_pos : 0 < 4 * x + y := by linarith
    have other_eq : ((4 * x + y).toNat : ℤ) = 4 * x + y := Int.toNat_of_nonneg (le_of_lt other_pos)
    have hfact_nat : y.toNat * (4 * x + y).toNat = 4 * k + 1 := by
      have h : (y.toNat : ℤ) * ((4 * x + y).toNat : ℤ) = (4 * k + 1 : ℤ) := by
        rw [y_eq, other_eq]; exact hfact
      exact_mod_cast h
    have hdvd : y.toNat ∣ 4 * k + 1 := ⟨_, hfact_nat.symm⟩
    rcases hp.eq_one_or_self_of_dvd _ hdvd with hy1 | hy_big
    · have hyeq : y = 1 := by
        have h1 : (y.toNat : ℤ) = (1 : ℤ) := by simp only [hy1, Nat.cast_one]
        linarith
      have hxeq : x = (k : ℤ) := by nlinarith
      have hzeq : z = 1 := by linarith
      apply Subtype.ext; apply Subtype.ext
      simp [hxeq, hyeq, hzeq]
    · have ylarge : y = 4 * (k : ℤ) + 1 := by
        have h1 : (y.toNat : ℤ) = (4 * k + 1 : ℤ) := by simp only [hy_big]; push_cast; ring
        linarith
      have kpos := k_pos k
      nlinarith
  · intro hf
    simp only [Set.mem_singleton_iff] at hf
    subst hf
    simp only [Set.mem_setOf_eq]
    ext <;> simp
```
