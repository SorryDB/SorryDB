theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, secondInvo, secondInvo_fun,
    singletonFixedPoint, Prod.mk_one_one, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    simp at ht
    simp only [Set.mem_singleton_iff]
    obtain ⟨⟨⟨x, y, z⟩, ⟨hS, hx, hy⟩⟩, hU⟩ := t
    simp only [Subtype.ext_iff, Prod.ext_iff] at ht ⊢
    simp only [Subtype.mk.injEq, Prod.mk.injEq] at ht ⊢
    obtain ⟨h1, _, h3⟩ := ht
    have hz : z = y := by omega
    subst hz
    have hfact : y * (4 * x + y) = 4 * k + 1 := by linarith
    have hy1 : y = 1 := by
      have hp := hk.out
      have hy_pos' : 0 < y.toNat := Int.toNat_pos.mpr hy
      have hfact' : y.toNat * (4 * x + y).toNat = 4 * k + 1 := by
        have h1 : (4 * x + y).toNat = (4 * x + y) := Int.toNat_of_nonneg (by omega)
        have h2 : y.toNat = y := Int.toNat_of_nonneg (by omega)
        omega
      have hdvd : y.toNat ∣ (4 * k + 1) := ⟨(4 * x + y).toNat, hfact'.symm⟩
      have := Nat.Prime.eq_one_or_self_of_dvd hp y.toNat hdvd
      cases this with
      | inl h => omega
      | inr h =>
        have : (4 * x + y).toNat = 1 := by
          have : y.toNat * (4 * x + y).toNat = 4 * k + 1 := hfact'
          omega
        omega
    refine ⟨⟨?_, hy1⟩, hy1⟩
    omega
