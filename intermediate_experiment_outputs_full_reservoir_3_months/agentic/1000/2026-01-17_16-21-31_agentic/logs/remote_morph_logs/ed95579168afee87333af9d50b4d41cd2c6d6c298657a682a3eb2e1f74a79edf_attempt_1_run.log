    have heq : x - y + z = x ∧ 2 * y - z = z := by
      have h := Subtype.ext_iff.mp (Subtype.ext_iff.mp ht)
      exact ⟨(Prod.ext_iff.mp h).1, (Prod.ext_iff.mp (Prod.ext_iff.mp h).2).2⟩
    have hz : z = y := by linarith [heq.1, heq.2]
    have hfact : y * (4 * x + y) = 4 * (k : ℤ) + 1 := by nlinarith [hS, hz]
    have hp := hk.out
    have ypos : 0 ≤ y := by linarith
    have other_pos : 0 ≤ 4 * x + y := by linarith
    have ynat_eq : (y.toNat : ℤ) = y := Int.toNat_of_nonneg ypos
    have other_eq : ((4 * x + y).toNat : ℤ) = 4 * x + y := Int.toNat_of_nonneg other_pos
    have hfact_nat : y.toNat * (4 * x + y).toNat = 4 * k + 1 := by
      have h : (y.toNat * (4 * x + y).toNat : ℤ) = y * (4 * x + y) := by
        rw [Int.ofNat_mul, ynat_eq, other_eq]
      omega
    have hdvd : y.toNat ∣ 4 * k + 1 := ⟨_, hfact_nat.symm⟩
    rcases hp.eq_one_or_self_of_dvd _ hdvd with h1 | h_big
    · have hy : y = 1 := by omega
      have hx : x = k := by nlinarith
      simp only [hx, hy, hz]
    · have hother : (4 * x + y).toNat = 1 := by omega
      have : (4 * x + y : ℤ) = 1 := by omega
      omega
  · intro hf
    simp only [Set.mem_singleton_iff] at hf
    rw [hf]
