```lean
instance (G : Type*) [Group G] (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [Field L] [ValuativeRel L] [TopologicalSpace L] [IsNonarchimedeanLocalField L]
    [Algebra K L] [ValuativeExtension K L] [MulSemiringAction G L] [IsGaloisGroup G K L] :
    IsGaloisGroup G 𝒪[K] 𝒪[L] where
  faithful := ⟨fun {g₁ g₂} heq => (IsGaloisGroup.faithful (G := G) (K := K) (L := L)).eq_of_smul_eq_smul fun x => by
    by_cases hx : x = 0
    · simp only [smul_zero]
    · by_cases hv : x ∈ (valuation L).integer
      · exact congrArg Subtype.val (heq ⟨x, hv⟩)
      · have hvinv : x⁻¹ ∈ (valuation L).integer := by
          rw [Valuation.mem_integer_iff, Valuation.map_inv₀]
          rw [Valuation.mem_integer_iff] at hv
          push_neg at hv
          exact inv_le_one_of_one_le₀ (le_of_lt hv)
        have hinv := congrArg Subtype.val (heq ⟨x⁻¹, hvinv⟩)
        have h1 : g₁ • x = (g₁ • x⁻¹)⁻¹ := by
          conv_lhs => rw [← inv_inv x]
          rw [← MulSemiringAction.toRingEquiv_apply, (MulSemiringAction.toRingEquiv G L g₁).map_inv]
          rfl
        have h2 : g₂ • x = (g₂ • x⁻¹)⁻¹ := by
          conv_lhs => rw [← inv_inv x]
          rw [← MulSemiringAction.toRingEquiv_apply, (MulSemiringAction.toRingEquiv G L g₂).map_inv]
          rfl
        rw [h1, h2, hinv]⟩
```
