    (by norm_num : (3:ℝ) ∈ Set.Icc 2 30) (by omega) (by omega) x hx
  calc Eψ x ≤ ε Inputs.default (exp log_x0) σ2 3 9130 100000 := key
    _ ≤ ε_total := by simp only [table_5, List.mem_cons, Prod.mk.injEq] at h
