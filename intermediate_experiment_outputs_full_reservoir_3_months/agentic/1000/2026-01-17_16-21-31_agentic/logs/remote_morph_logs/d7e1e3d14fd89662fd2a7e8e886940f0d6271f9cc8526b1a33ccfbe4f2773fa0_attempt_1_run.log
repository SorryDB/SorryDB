theorem theorem_1_1b {log_x0 σ2 c N K ε1 ε2 ε3 ε4 ε_total : ℝ}
    (h : (log_x0, σ2, ε1, ε2, ε3, ε4, ε_total) ∈ table_5) : ∀ x, log x ≥ log_x0 → Eψ x ≤ ε_total := by
  intro x hlog
  have hx : x ≥ exp log_x0 := exp_le_exp.mpr hlog
  have key := theorem_1_1 Inputs.default (exp log_x0) σ2 3 9130 100000
    (by simp only [table_5, List.mem_cons, Prod.mk.injEq] at h
        rcases h with ⟨rfl, _⟩ | h <;> norm_num
        all_goals { simp_all only [List.mem_cons, Prod.mk.injEq, List.mem_nil_iff, or_false]
                    try norm_num; try aesop })
    (by simp only [table_5, List.mem_cons, Prod.mk.injEq, Set.mem_Ioo] at h ⊢
