    have := Submodule.mem_inf.mp hv_mem
    exact this.1
  rw [Module.End.mem_eigenspace_iff] at hv_eigen
  have hv_eq : A *ᵥ v = A.toEuclideanLin v := rfl
  rw [hv_eq, hv_eigen]
  congr 1
  simp only [sharedEigenvalueA]
  have hnorm : ‖v‖ = 1 := (sharedEigenbasis hA hB hAB).orthonormal.1 j
  have hdot : dotProduct v v = 1 := by
    rw [← EuclideanSpace.inner_eq_star_dotProduct]
