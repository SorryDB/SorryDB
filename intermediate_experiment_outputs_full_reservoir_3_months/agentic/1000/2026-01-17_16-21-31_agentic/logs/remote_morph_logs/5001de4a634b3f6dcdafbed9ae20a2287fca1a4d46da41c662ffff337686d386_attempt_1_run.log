      · have : Real.sqrt 49 < Real.sqrt 50 := Real.sqrt_lt_sqrt (by norm_num) (by norm_num)
        simp at this; linarith
      · have : Real.sqrt 50 < Real.sqrt 64 := Real.sqrt_lt_sqrt (by norm_num) (by norm_num)
