import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  by_contra h
  push_neg at h
  obtain ⟨hS_no, hC_no⟩ := h
  have h1 : ∀ a b, a ∈ S → b ∈ S → a ≠ b → ¬IsSquare (a + b) := fun a b ha hb => hS_no a ha b hb
  have h2 : ∀ a b, a ∈ Finset.Icc n (2 * n) \ S → b ∈ Finset.Icc n (2 * n) \ S → a ≠ b → 
      ¬IsSquare (a + b) := fun a b ha hb => hC_no a ha b hb
  have key : ∃ (pairs : List (ℕ × ℕ)), pairs.length ≥ n + 2 ∧ 
      (∀ p ∈ pairs, p.1 ∈ Finset.Icc n (2 * n) ∧ p.2 ∈ Finset.Icc n (2 * n) ∧ p.1 ≠ p.2 ∧ IsSquare (p.1 + p.2)) ∧
      pairs.Pairwise (fun p q => ({p.1, p.2} : Finset ℕ) ∩ {q.1, q.2} = ∅) := by
    sorry
  obtain ⟨pairs, hlen, hpairs, hdisj⟩ := key
  sorry
