    by_cases ha'S : a' ∈ S <;> by_cases hn1S : n + 1 ∈ S
    · left; exact ⟨a', ha'S, n + 1, hn1S, ha'b_ne, ha'b_sq⟩
    · left; exact ⟨n, hnS, n + 1, hn1S, by omega, ⟨k, by omega⟩⟩
    · right; exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, a', Finset.mem_sdiff.mpr ⟨ha'_in, ha'S⟩, by omega, ⟨k, by omega⟩⟩
