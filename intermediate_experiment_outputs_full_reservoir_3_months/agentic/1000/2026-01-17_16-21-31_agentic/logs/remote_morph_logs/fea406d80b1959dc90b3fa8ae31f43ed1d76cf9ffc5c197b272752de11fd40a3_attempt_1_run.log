import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k ^ 2 ≤ 3 * n := Nat.sqrt_le' (3 * n)
  have hk_lt_raw := Nat.lt_succ_sqrt (3 * n)
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega : 289 ≤ 3 * n)
  have hk2_gt : 2 * n < k ^ 2 := by
    have h1 : k * k + 2 * k + 1 > 3 * n := hk_lt_raw
    have h2 : k ^ 2 = k * k := sq k
    nlinarith [sq_nonneg k]
  let a1 := k ^ 2 - n
  let b1 := n
  let a2 := k ^ 2 - n - 1
  let b2 := n + 1
  have ha1_in : a1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb1_in : b1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨le_refl n, by omega⟩
  have ha2_in : a2 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb2_in : b2 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have h1_ne : a1 ≠ b1 := by omega
  have h2_ne : a2 ≠ b2 := by omega
  have h1_sq : IsSquare (a1 + b1) := ⟨k, by simp only [a1, b1, sq]; omega⟩
  have h2_sq : IsSquare (a2 + b2) := ⟨k, by simp only [a2, b2, sq]; omega⟩
  by_cases ha1S : a1 ∈ S <;> by_cases hb1S : b1 ∈ S <;> by_cases ha2S : a2 ∈ S <;> by_cases hb2S : b2 ∈ S
  all_goals first
    | (left; exact ⟨a1, ‹_›, b1, ‹_›, h1_ne, h1_sq⟩)
    | (left; exact ⟨a2, ‹_›, b2, ‹_›, h2_ne, h2_sq⟩)
    | (right; exact ⟨a1, Finset.mem_sdiff.mpr ⟨ha1_in, ‹_›⟩, b1, Finset.mem_sdiff.mpr ⟨hb1_in, ‹_›⟩, h1_ne, h1_sq⟩)
    | (right; exact ⟨a2, Finset.mem_sdiff.mpr ⟨ha2_in, ‹_›⟩, b2, Finset.mem_sdiff.mpr ⟨hb2_in, ‹_›⟩, h2_ne, h2_sq⟩)
