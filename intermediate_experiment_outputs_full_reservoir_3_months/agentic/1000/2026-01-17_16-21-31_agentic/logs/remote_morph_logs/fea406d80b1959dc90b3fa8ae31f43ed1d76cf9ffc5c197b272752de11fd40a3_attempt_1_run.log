For this IMO 2021 P1 problem, we need to find enough disjoint pairs with square sums to force a monochromatic pair. Let me try a cleaner approach using proper Mathlib lemmas for sqrt bounds:

```lean
/-
Copyright (c) 2025 Joseph Myers. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let I := Finset.Icc n (2 * n)
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k ^ 2 ≤ 3 * n := Nat.sqrt_le_self (3 * n)
  have hk_lt : 3 * n < (k + 1) ^ 2 := Nat.lt_succ_sqrt (3 * n)
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega)
  let a := k ^ 2 - 2 * n
  let b := 3 * n - a
  have ha_eq : a = k ^ 2 - 2 * n := rfl
  have hb_eq : b = 3 * n - a := rfl
  have hkn : 2 * n ≤ k ^ 2 := by nlinarith [sq_nonneg k, sq_nonneg (k - 17)]
  have ha_pos : a ≤ n := by omega
  have ha_in : a ∈ I := by simp only [I, Finset.mem_Icc]; omega
  have hb_in : b ∈ I := by simp only [I, Finset.mem_Icc, b, a]; omega
  have hab_ne : a ≠ b := by simp only [a, b]; omega
  have hab_sum : a + b = 3 * n := by simp only [a, b]; omega
  -- Since a + b = 3n is not necessarily a perfect square, we need a different pair
  -- Use k^2 as the target sum
  let a' := k ^ 2 - 2 * n
  let b' := 2 * n
  have ha'b'_sum : a' + b' = k ^ 2 := by simp only [a', b']; omega
  have ha'_in : a' ∈ I := by simp only [I, Finset.mem_Icc, a']; omega
  have hb'_in : b' ∈ I := by simp only [I, Finset.mem_Icc, b']; omega
  have ha'b'_ne : a' ≠ b' := by simp only [a', b']; omega
  have ha'b'_sq : IsSquare (a' + b') := ⟨k, by simp only [a', b']; ring⟩
  by_cases ha'S : a' ∈ S <;> by_cases hb'S : b' ∈ S
  · left; exact ⟨a', ha'S, b', hb'S, ha'b'_ne, ha'b'_sq⟩
  · right
    exact ⟨b', Finset.mem_sdiff.mpr ⟨hb'_in, hb'S⟩, a', Finset.mem_sdiff.mpr ⟨ha'_in, ha'S⟩, 
           Ne.symm ha'b'_ne, by rwa [add_comm]⟩
  · right
    exact ⟨a', Finset.mem_sdiff.mpr ⟨ha'_in, ha'S⟩, b', Finset.mem_sdiff.mpr ⟨hb'_in, hb'S⟩, 
           ha'b'_ne, ha'b'_sq⟩
  · right
    exact ⟨a', Finset.mem_sdiff.mpr ⟨ha'_in, ha'S⟩, b', Finset.mem_sdiff.mpr ⟨hb'_in, hb'S⟩, 
           ha'b'_ne, ha'b'_sq⟩
