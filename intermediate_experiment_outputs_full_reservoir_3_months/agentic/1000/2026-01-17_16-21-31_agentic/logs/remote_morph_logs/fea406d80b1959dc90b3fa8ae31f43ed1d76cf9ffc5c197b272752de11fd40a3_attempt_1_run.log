import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let I := Finset.Icc n (2 * n)
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k * k ≤ 3 * n := Nat.sqrt_le' (3 * n)
  have hk_lt : 3 * n < (k + 1) * (k + 1) := Nat.lt_succ_sqrt (3 * n)
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega : 289 ≤ 3 * n)
  have hk2_ge : 2 * n ≤ k * k := by nlinarith
  let a := k * k - n
  let b := n
  have ha_in : a ∈ I := by simp only [I, Finset.mem_Icc, a]; omega
  have hb_in : b ∈ I := by simp only [I, Finset.mem_Icc, b]; omega
  have hab_ne : a ≠ b := by simp only [a, b]; omega
  have hab_sum : a + b = k * k := by simp only [a, b]; omega
  have hab_sq : IsSquare (a + b) := ⟨k, by simp only [sq]; omega⟩
  by_cases haS : a ∈ S
  · by_cases hbS : b ∈ S
    · left; exact ⟨a, haS, b, hbS, hab_ne, hab_sq⟩
    · right
      exact ⟨b, Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, b + 1, 
             Finset.mem_sdiff.mpr ⟨by simp [I, Finset.mem_Icc]; omega, 
             fun h => hbS (hS (by simp [I, Finset.mem_Icc] at h ⊢; omega))⟩, 
             by omega, ⟨k, by simp [sq]; omega⟩⟩
  · by_cases hbS : b ∈ S
    · right
      exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, a, 
             Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, by omega, ⟨k, by simp [sq]; omega⟩⟩
    · right
      exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, b, 
             Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, hab_ne, hab_sq⟩
