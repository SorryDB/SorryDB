import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k * k ≤ 3 * n := Nat.sqrt_le (3 * n)
  have hk_lt : 3 * n < (k + 1) * (k + 1) := Nat.lt_succ_sqrt (3 * n)
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega : 289 ≤ 3 * n)
  have hk2_gt : 2 * n + 3 < k * k := by nlinarith
  let a1 := k * k - n; let b1 := n
  let a2 := k * k - n - 1; let b2 := n + 1
  let a3 := k * k - n - 2; let b3 := n + 2
  have ha1_in : a1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb1_in : b1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨le_refl n, by omega⟩
  have ha2_in : a2 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb2_in : b2 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have ha3_in : a3 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb3_in : b3 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have h1_ne : a1 ≠ b1 := by omega; have h2_ne : a2 ≠ b2 := by omega; have h3_ne : a3 ≠ b3 := by omega
  have h1_sq : IsSquare (a1 + b1) := ⟨k, by omega⟩
  have h2_sq : IsSquare (a2 + b2) := ⟨k, by omega⟩
  have h3_sq : IsSquare (a3 + b3) := ⟨k, by omega⟩
  by_cases ha1S : a1 ∈ S <;> by_cases hb1S : b1 ∈ S <;> by_cases ha2S : a2 ∈ S <;> 
    by_cases hb2S : b2 ∈ S <;> by_cases ha3S : a3 ∈ S <;> by_cases hb3S : b3 ∈ S
  all_goals first
    | (left; exact ⟨a1, ‹a1 ∈ S›, b1, ‹b1 ∈ S›, h1_ne, h1_sq⟩)
    | (left; exact ⟨a2, ‹a2 ∈ S›, b2, ‹b2 ∈ S›, h2_ne, h2_sq⟩)
    | (left; exact ⟨a3, ‹a3 ∈ S›, b3, ‹b3 ∈ S›, h3_ne, h3_sq⟩)
    | (right; exact ⟨a1, Finset.mem_sdiff.mpr ⟨ha1_in, ‹a1 ∉ S›⟩, b1, Finset.mem_sdiff.mpr ⟨hb1_in, ‹b1 ∉ S›⟩, h1_ne, h1_sq⟩)
    | (right; exact ⟨a2, Finset.mem_sdiff.mpr ⟨ha2_in, ‹a2 ∉ S›⟩, b2, Finset.mem_sdiff.mpr ⟨hb2_in, ‹b2 ∉ S›⟩, h2_ne, h2_sq⟩)
    | (right; exact ⟨a3, Finset.mem_sdiff.mpr ⟨ha3_in, ‹a3 ∉ S›⟩, b3, Finset.mem_sdiff.mpr ⟨hb3_in, ‹b3 ∉ S›⟩, h3_ne, h3_sq⟩)
