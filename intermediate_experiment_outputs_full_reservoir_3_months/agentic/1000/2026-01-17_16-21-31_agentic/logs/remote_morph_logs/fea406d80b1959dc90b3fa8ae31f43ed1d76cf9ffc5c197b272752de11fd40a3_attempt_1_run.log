import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k ^ 2 ≤ 3 * n := Nat.sqrt_le' (3 * n)
  have hk_lt : 3 * n < (k + 1) ^ 2 := by
    have := Nat.lt_succ_sqrt (3 * n); simp only [Nat.succ_eq_add_one, pow_two] at this ⊢; exact this
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega)
  have hk2_gt : 2 * n < k ^ 2 := by nlinarith [sq_nonneg k, sq_nonneg (k + 1)]
  have hk2_le : k ^ 2 ≤ 3 * n := hk_sq_le
  let a := k ^ 2 - n
  have ha_eq : a = k ^ 2 - n := rfl
  have ha_bounds : n ≤ a ∧ a ≤ 2 * n := ⟨by omega, by omega⟩
  have ha_in : a ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ha_bounds
  have hn_in : n ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨le_refl n, by omega⟩
  have hab_ne : a ≠ n := by omega
  have hab_sum : a + n = k ^ 2 := by omega
  have hab_sq : IsSquare (a + n) := ⟨k, by rw [hab_sum, sq]⟩
  by_cases haS : a ∈ S
  · by_cases hnS : n ∈ S
    · left; exact ⟨a, haS, n, hnS, hab_ne, hab_sq⟩
    · right
      exact ⟨n, Finset.mem_sdiff.mpr ⟨hn_in, hnS⟩, a, Finset.mem_sdiff.mpr ⟨ha_in, fun h => 
        hnS (by have := hS h; simp only [Finset.mem_Icc] at this; 
        have := hS haS; simp only [Finset.mem_Icc] at this; exact haS)⟩, 
        Ne.symm hab_ne, by rwa [add_comm]⟩
  · by_cases hnS : n ∈ S
    · right
      exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩,
        fun h => haS (by rw [← h] at haS; exact haS), ⟨k, by rw [← hab_sum, add_comm]; ring_nf; omega⟩⟩
    · right
      exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, n, Finset.mem_sdiff.mpr ⟨hn_in, hnS⟩,
        hab_ne, hab_sq⟩
