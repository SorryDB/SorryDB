  let a := k * k - n
  have ha_in : a ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hn_in : n ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨le_refl n, by omega⟩
  have hab_ne : a ≠ n := by omega
  have hab_sq : IsSquare (a + n) := ⟨k, by omega⟩
  by_cases haS : a ∈ S <;> by_cases hnS : n ∈ S
  · left; exact ⟨a, haS, n, hnS, hab_ne, hab_sq⟩
  · let a' := k * k - n - 1
    have ha'_in : a' ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
    have hn1_in : n + 1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
    have ha'b_ne : a' ≠ n + 1 := by omega
    have ha'b_sq : IsSquare (a' + (n + 1)) := ⟨k, by omega⟩
    by_cases ha'S : a' ∈ S <;> by_cases hn1S : n + 1 ∈ S
    · left; exact ⟨a', ha'S, n + 1, hn1S, ha'b_ne, ha'b_sq⟩
    · left; exact ⟨a, haS, a', ha'S, by omega, ⟨k, by omega⟩⟩
    · right; exact ⟨n, Finset.mem_sdiff.mpr ⟨hn_in, hnS⟩, n + 1, Finset.mem_sdiff.mpr ⟨hn1_in, hn1S⟩, by omega, ⟨k, by omega⟩⟩
    · right; exact ⟨n, Finset.mem_sdiff.mpr ⟨hn_in, hnS⟩, a', Finset.mem_sdiff.mpr ⟨ha'_in, ha'S⟩, by omega, ha'b_sq⟩
  · let a' := k * k - n - 1
    have ha'_in : a' ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
    have hn1_in : n + 1 ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
