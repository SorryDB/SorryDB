import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let k := Nat.sqrt (3 * n)
  have hk_sq_le : k * k ≤ 3 * n := Nat.sqrt_le (3 * n)
  have hk_lt : 3 * n < (k + 1) * (k + 1) := Nat.lt_succ_sqrt (3 * n)
  have hk_ge : 17 ≤ k := Nat.le_sqrt'.mpr (by omega : 289 ≤ 3 * n)
  have hk2_gt : 2 * n + 1 < k * k := by nlinarith
  have hkm1_sq : (k - 1) * (k - 1) ≥ 2 * n := by nlinarith
  let a := k * k - n
  let b := n
  let c := (k - 1) * (k - 1) - n
  have ha_in : a ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hb_in : b ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨le_refl n, by omega⟩
  have hc_in : c ∈ Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hab_ne : a ≠ b := by omega
  have hbc_ne : b ≠ c := by omega
  have hac_ne : a ≠ c := by omega
  have hab_sq : IsSquare (a + b) := ⟨k, by omega⟩
  have hbc_sq : IsSquare (b + c) := ⟨k - 1, by omega⟩
  by_cases haS : a ∈ S <;> by_cases hbS : b ∈ S <;> by_cases hcS : c ∈ S
  · left; exact ⟨a, haS, b, hbS, hab_ne, hab_sq⟩
  · left; exact ⟨a, haS, b, hbS, hab_ne, hab_sq⟩
  · left; exact ⟨b, hbS, c, hcS, hbc_ne, hbc_sq⟩
  · left; exact ⟨a, haS, b, hbS, hab_ne, hab_sq⟩
  · right; exact ⟨b, Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, c, Finset.mem_sdiff.mpr ⟨hc_in, hcS⟩, hbc_ne, hbc_sq⟩
  · right; exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, b, Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, hab_ne, hab_sq⟩
  · right; exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, b, Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, hab_ne, hab_sq⟩
  · right; exact ⟨a, Finset.mem_sdiff.mpr ⟨ha_in, haS⟩, b, Finset.mem_sdiff.mpr ⟨hb_in, hbS⟩, hab_ne, hab_sq⟩
