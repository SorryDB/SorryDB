import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let I := Finset.Icc n (2 * n)
  -- For n ≥ 100, we use k where k² is close to 3n
  -- The pairs (a, k² - a) for appropriate k give us square sums
  have h1 : n ∈ I := by simp [I, Finset.mem_Icc]; omega
  have h2 : n + 1 ∈ I := by simp [I, Finset.mem_Icc]; omega
  -- Key: there exist elements a, b ∈ I with a + b a perfect square
  -- For n ≥ 100, consider k = 15: k² = 225, and for large n, 
  -- n and 225-n might not both be in I, so we need a different approach
  -- Instead, for any n ≥ 100, 2n + (2n-2) = 4n - 2, and we look for k with k² ∈ [2n, 4n]
  -- Such k exists: k ∈ [⌈√(2n)⌉, ⌊√(4n)⌋]
  -- For n = 100: k ∈ [15, 20], giving k² ∈ {225, 256, 289, 324, 361, 400}
  -- For k² = 289 (k=17): pairs (a, 289-a) with a, 289-a ∈ [100, 200]
  --   Need 100 ≤ a ≤ 189 and 89 ≤ a ≤ 189, so a ∈ [100, 189]
  -- Choose a = 100, b = 189: both in I, sum = 289 = 17², a ≠ b
  -- But this only works for n = 100 specifically...
  -- General approach: native pigeonhole on enough disjoint pairs
  have key : ∃ a b : ℕ, a ∈ I ∧ b ∈ I ∧ a ≠ b ∧ IsSquare (a + b) := by
    use n, 3 * n + 1 - n
    constructor
    · exact h1
    constructor
    · simp [I, Finset.mem_Icc]; omega
    constructor
    · omega
    · sorry
  obtain ⟨a, b, ha, hb, hab, hsq⟩ := key
  by_cases haS : a ∈ S <;> by_cases hbS : b ∈ S
  · left; exact ⟨a, haS, b, hbS, hab, hsq⟩
  · right
    refine ⟨b, Finset.mem_sdiff.mpr ⟨hb, hbS⟩, ?_, ?_, ?_, ?_⟩
    all_goals sorry
  · right
