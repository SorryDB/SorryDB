Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  let I := Finset.Icc n (2 * n)
  let k := Nat.sqrt (3 * n)
  have hk_sq : k ^ 2 ≤ 3 * n ∧ 3 * n < (k + 1) ^ 2 := Nat.sqrt_le_sqrt_of_sq_le_sq (by omega) (Nat.sqrt_lt_self (by omega))
  have hk_lb : 17 ≤ k := by
    have : 289 ≤ 3 * n := by omega
    have : 17 ^ 2 ≤ 3 * n := by norm_num; omega
    exact Nat.le_sqrt.mpr this
  let a := k ^ 2 - 2 * n
  let b := 2 * n - a
  have ha_in : a ∈ I := by
    simp only [Finset.mem_Icc, I, a]
    constructor <;> omega
  have hb_in : b ∈ I := by
    simp only [Finset.mem_Icc, I, b, a]
    constructor <;> omega
  have hab_ne : a ≠ b := by simp only [a, b]; omega
  have hab_sq : IsSquare (a + b) := by
    use k
    simp only [a, b]
    omega
  by_cases haS : a ∈ S
  · by_cases hbS : b ∈ S
    · left; exact ⟨a, haS, b, hbS, hab_ne, hab_sq⟩
    · let a' := (k + 1) ^ 2 - 2 * n
      let b' := 2 * n - a'
      have ha'_in : a' ∈ I := by simp only [Finset.mem_Icc, I, a']; omega
      have hb'_in : b' ∈ I := by simp only [Finset.mem_Icc, I, b', a']; omega
      have ha'b'_ne : a' ≠ b' := by simp only [a', b']; omega
      have ha'b'_sq : IsSquare (a' + b') := ⟨k + 1, by simp only [a', b']; omega⟩
      by_cases ha'S : a' ∈ S
      · by_cases hb'S : b' ∈ S
        · left; exact ⟨a', ha'S, b', hb'S, ha'b'_ne, ha'b'_sq⟩
        · right
          refine ⟨b, ?_, b', ?_, ?_, ?_⟩
          · simp only [Finset.mem_sdiff]; exact ⟨hb_in, hbS⟩
          · simp only [Finset.mem_sdiff]; exact ⟨hb'_in, hb'S⟩
          · simp only [b, b', a, a']; omega
          · use k; simp only [b, b', a, a']; ring_nf; omega
      · right
        refine ⟨b, ?_, a', ?_, ?_, ?_⟩
        · simp only [Finset.mem_sdiff]; exact ⟨hb_in, hbS⟩
        · simp only [Finset.mem_sdiff]; exact ⟨ha'_in, ha'S⟩
        · simp only [b, a', a]; omega
        · use k; simp only [b, a', a]; ring_nf; omega
  · by_cases hbS : b ∈ S
    · let a' := (k + 1) ^ 2 - 2 * n
      let b' := 2 * n - a'
      have ha'_in : a' ∈ I := by simp only [Finset.mem_Icc, I, a']; omega
      have hb'_in : b' ∈ I := by simp only [Finset.mem_Icc, I, b', a']; omega
      have ha'b'_ne : a' ≠ b' := by simp only [a', b']; omega
      have ha'b'_sq : IsSquare (a' + b') := ⟨k + 1, by simp only [a', b']; omega⟩
      by_cases ha'S : a' ∈ S
      · by_cases hb'S : b' ∈ S
        · left; exact ⟨a', ha'S, b', hb'S, ha'b'_ne, ha'b'_sq⟩
        · right
          refine ⟨a, ?_, b', ?_, ?_, ?_⟩
          · simp only [Finset.mem_sdiff]; exact ⟨ha_in, haS⟩
          · simp only [Finset.mem_sdiff]; exact ⟨hb'_in, hb'S⟩
          · simp only [a, b', a']; omega
          · use k; simp only [a, b', a']; ring_nf; omega
      · right
        refine ⟨a, ?_, a', ?_, ?_, ?_⟩
        · simp only [Finset.mem_sdiff]; exact ⟨ha_in, haS⟩
        · simp only [Finset.mem_sdiff]; exact ⟨ha'_in, ha'S⟩
        · simp only [a, a']; omega
        · use k; simp only [a, a']; ring_nf; omega
    · right; exact ⟨a, ⟨ha_in, haS⟩, b, ⟨hb_in, hbS⟩, hab_ne, hab_sq⟩
