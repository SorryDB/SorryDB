import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1984_p6
  (a b c d k m : ℕ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : Odd a ∧ Odd b ∧ Odd c ∧ Odd d)
  (h₂ : a < b ∧ b < c ∧ c < d)
  (h₃ : a * d = b * c)
  (h₄ : a + d = 2^k)
  (h₅ : b + c = 2^m) :
  a = 1 := by
  have gcd_ad : Nat.gcd a d = 1 := by
    have hdvd : Nat.gcd a d ∣ 2 ^ k := h₄ ▸ Nat.gcd_dvd_add_right a d
    have hodd : Odd (Nat.gcd a d) := h₁.1.gcd h₁.2.2.2
    rcases Nat.dvd_prime_pow Nat.prime_two hdvd with ⟨j, _, hgcd⟩
    interval_cases j <;> simp_all [Nat.odd_iff]
  have gcd_bc : Nat.gcd b c = 1 := by
    have hdvd : Nat.gcd b c ∣ 2 ^ m := h₅ ▸ Nat.gcd_dvd_add_right b c
    have hodd : Odd (Nat.gcd b c) := h₁.2.1.gcd h₁.2.2.1
    rcases Nat.dvd_prime_pow Nat.prime_two hdvd with ⟨j, _, hgcd⟩
    interval_cases j <;> simp_all [Nat.odd_iff]
  have ha_dvd_bc : a ∣ b * c := ⟨d, h₃.symm⟩
  have ha_dvd_c : a ∣ c := by
    have : a.Coprime b := Nat.coprime_of_dvd (fun p hp hpa hpb => by
      have hpd : p ∣ d := by
        have : p ∣ a * d := dvd_mul_of_dvd_left hpa d
        rw [h₃] at this
        exact (hp.dvd_or_dvd this).resolve_left (fun h => hp.not_dvd_one (gcd_bc ▸ Nat.dvd_gcd hpb h))
      exact hp.not_dvd_one (gcd_ad ▸ Nat.dvd_gcd hpa hpd))
    exact this.dvd_of_dvd_mul_left ha_dvd_bc
  obtain ⟨e, he⟩ := ha_dvd_c
  have hd_eq : d = b * e := by nlinarith [h₀.1, h₀.2.2.1]
  have he_pos : 0 < e := by nlinarith [h₀.1, h₀.2.2.1]
  have ha_lt_e : a < e := by nlinarith [h₂.1, h₂.2.1]
  have he_lt_b : e < b := by nlinarith [h₂.2.1, h₂.2.2]
  have sum_eq : a + b * e = 2 ^ k := by rw [← hd_eq]; exact h₄
  have sum_eq' : b + a * e = 2 ^ m := by rw [← he]; exact h₅
  have key : (a + b * e) * (b + a * e) = (a + b) ^ 2 * e + a * b * (e - 1) ^ 2 := by ring
  have hlt : a + b * e > b + a * e := by nlinarith
  have hkm : k > m := by
    by_contra hle
    push_neg at hle
    have : 2 ^ k ≤ 2 ^ m := Nat.pow_le_pow_right (by norm_num) hle
    omega
  have hdiff : 2 ^ k - 2 ^ m = (b - a) * (e - 1) := by nlinarith
  have hsum : 2 ^ k + 2 ^ m = (a + b) * (e + 1) := by nlinarith
  have hodd_sum : Odd ((a + b) * (e + 1)) := by rw [← hsum]; exact (h₁.1.add_odd h₁.2.1).mul_odd (h₁.1.add_odd h₁.2.2.1 ▸ by rw [he]; exact h₁.2.2.1.add_odd h₁.1)
  have := Nat.eq_one_of_pos_of_self_mul_self_mod_eq_one h₀.1
  omega
