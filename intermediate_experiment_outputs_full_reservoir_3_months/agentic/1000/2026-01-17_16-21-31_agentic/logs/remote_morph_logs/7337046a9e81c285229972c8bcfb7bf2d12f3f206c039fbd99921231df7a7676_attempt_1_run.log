```lean
/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_
  intro h_eq
  obtain ⟨N, hN, hNne⟩ := H
  have hne : (B N hN).Nonempty := by
    by_contra hempty
    rw [Set.not_nonempty_iff_eq_empty] at hempty
    simp only [hempty, sSup_empty] at hB
    exact D.not_bot_mem (hB N hN ▸ hN)
  have : ∃ P ∈ B N hN, P ≠ N := by
    by_contra h
    push_neg at h
    exact hNne (Set.eq_singleton_iff_nonempty_unique_mem.mpr ⟨hne, fun x hx => h x hx⟩)
  obtain ⟨P, hPmem, hPne⟩ := this
  have hPleN : P ≤ N := by rw [hB N hN]; exact le_sSup hPmem
  have hPne' : P ≠ ⊥ := fun h => hB'' N hN (h ▸ hPmem)
  have hPinD : P ∈ D := by
    have : P ∈ (refinement B hB hB' hB'' : Set _) := by
      simp only [refinement, Set.mem_iUnion]
      exact ⟨N, hN, hPmem⟩
    rwa [← h_eq] at this
  have hNlesSup : N ≤ sSup ((D : Set _) \ {P}) := le_sSup ⟨hN, hPne.symm⟩
  have hPlesSup : P ≤ sSup ((D : Set _) \ {P}) := le_trans hPleN hNlesSup
  have hDisj : Disjoint P (sSup ((D : Set _) \ {P})) :=
    D.sSupIndep.disjoint_sSup hPinD Set.diff_subset (Set.not_mem_diff_of_mem rfl)
  exact hPne' (Disjoint.eq_bot_of_le hDisj hPlesSup)
```
