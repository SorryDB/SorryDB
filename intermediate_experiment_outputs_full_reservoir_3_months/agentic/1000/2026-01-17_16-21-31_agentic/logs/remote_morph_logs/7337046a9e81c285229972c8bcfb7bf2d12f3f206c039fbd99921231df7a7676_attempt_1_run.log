/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')
  intro heq
  obtain ⟨N₀, hN₀, hne⟩ := H
  apply hne
  have hne' : (B N₀ hN₀).Nonempty := by
    by_contra he
    simp only [Set.not_nonempty_iff_eq_empty] at he
    exact D.not_bot_mem ((hB N₀ hN₀ ▸ he ▸ sSup_empty : N₀ = ⊥) ▸ hN₀)
  rw [Set.eq_singleton_iff_nonempty_unique_mem]
  refine ⟨hne', fun P hP => ?_⟩
  have hPinRef : P ∈ (refinement B hB hB' hB'' : Set _) := Set.mem_iUnion₂.mpr ⟨N₀, hN₀, hP⟩
  have hcoe : (D : Set _) = (refinement B hB hB' hB'' : Set _) := congrArg SetLike.coe heq
  have hPinD : P ∈ D := hcoe ▸ hPinRef
  have hPleN₀ : P ≤ N₀ := hB N₀ hN₀ ▸ le_sSup hP
  have hPneBot : P ≠ ⊥ := fun h => hB'' N₀ hN₀ (h ▸ hP)
