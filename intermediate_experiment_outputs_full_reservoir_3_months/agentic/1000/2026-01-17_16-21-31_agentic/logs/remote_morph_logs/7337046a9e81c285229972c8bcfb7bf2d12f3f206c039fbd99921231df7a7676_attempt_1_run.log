  have hN₀inDmP : N₀ ∈ (D : Set _) \ {P} := ⟨hN₀, Ne.symm hPneN₀⟩
  have hPlesSup : P ≤ sSup ((D : Set _) \ {P}) := hPleN₀.trans (le_sSup hN₀inDmP)
  have hDisj := D.sSupIndep.disjoint_sSup hPinD Set.diff_subset (fun h => h.2 rfl)
  exact hPneBot (hDisj.eq_bot_of_le hPlesSup)
