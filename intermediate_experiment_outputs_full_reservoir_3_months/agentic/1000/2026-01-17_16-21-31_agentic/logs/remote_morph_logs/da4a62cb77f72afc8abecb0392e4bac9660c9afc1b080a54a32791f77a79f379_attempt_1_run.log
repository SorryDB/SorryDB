```lean
@[sorryful]
lemma tendsto_sin_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  by_cases hr : r = 0
  · simp [hr]
  · have heq : ∀ᶠ x in 𝓝[≠] 0, Real.sin (r * x) / x = r * (Real.sin (r * x) / (r * x)) := by
      filter_upwards [self_mem_nhdsWithin] with x hx
      field_simp [hr, hx]
    rw [show (𝓝 r) = 𝓝 (r * 1) by simp]
    refine Tendsto.congr' heq.symm (Tendsto.const_mul r ?_)
    refine Real.tendsto_sin_div_self.comp ?_
    refine tendsto_nhdsWithin_of_tendsto_nhds_of_eventually_within _ ?_ ?_
    · simp only [mul_zero]
      exact (continuous_mul_left r).tendsto 0 |>.mono_left nhdsWithin_le_nhds
    · filter_upwards [self_mem_nhdsWithin] with x hx
      simp only [Set.mem_compl_iff, Set.mem_singleton_iff, mul_eq_zero]
      push_neg
      exact ⟨hr, hx⟩
```
