```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype]
  intro p
  simp only [hE]
  intro h
  have hsum : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = 4 := add_left_cancel h
  have hval : (∑ i : Fin (2 * n - 1), (p i : Fin 8)).val = 4 := by rw [hsum]; rfl
  rw [Fin.val_sum] at hval
  have heach : ∀ i : Fin (2 * n - 1), (p i : Fin 8).val % 2 = 1 := fun i => by
    rcases Int.units_eq_one_or (p i) with hp | hp <;> simp [hp]
  have hmod2 : (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 2 = 1 := by
    rw [Finset.sum_nat_mod]
    conv_lhs => arg 1; ext i; rw [heach i]
    simp only [Finset.sum_const, Finset.card_fin, smul_eq_mul, mul_one]
    omega
  have hcontra : (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 8 % 2 = 0 := by
    rw [hval]; rfl
  rw [Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8)] at hcontra
  omega
```
