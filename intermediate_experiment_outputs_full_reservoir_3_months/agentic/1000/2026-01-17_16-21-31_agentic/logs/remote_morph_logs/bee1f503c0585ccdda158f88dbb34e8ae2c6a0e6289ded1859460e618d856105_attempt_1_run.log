```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype]
  intro p
  simp only [hE]
  intro h
  have hsum : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = 4 := add_left_cancel h
  have key1 : ∀ u : ℤˣ, (u : Fin 2) = 1 := fun u => by
    rcases Int.units_eq_one_or u with hu | hu <;> simp [hu]
  have key2 : ∀ u : ℤˣ, ((u : Fin 8) : Fin 2) = (u : Fin 2) := fun u => by
    rcases Int.units_eq_one_or u with hu | hu <;> simp [hu]
  have sum1 : (∑ i : Fin (2 * n - 1), (p i : Fin 2)) = 1 := by
    simp only [key1, Finset.sum_const, Finset.card_fin, smul_eq_mul, mul_one]
    ext; simp only [Fin.val_natCast, Fin.val_one]; omega
  have sum_eq : (∑ i : Fin (2 * n - 1), ((p i : Fin 8) : Fin 2)) =
                (∑ i : Fin (2 * n - 1), (p i : Fin 2)) := by simp only [key2]
  have h4 : ((4 : Fin 8) : Fin 2) = 0 := by native_decide
  have sum0 : (∑ i : Fin (2 * n - 1), ((p i : Fin 8) : Fin 2)) = 0 := by
    have := congrArg (Fin.castRingHom 2 (by norm_num : 2 ∣ 8)) hsum
    simp only [map_sum, Fin.castRingHom_apply] at this
    convert this using 2
    exact h4
  rw [sum_eq, sum1] at sum0
  exact one_ne_zero sum0
