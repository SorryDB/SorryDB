```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype]
  intro p
  simp only [hE]
  intro h
  have hsum : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = 4 := add_left_cancel h
  let φ : ZMod 8 →+* ZMod 2 := ZMod.castHom (by norm_num : 2 ∣ 8) (ZMod 2)
  have hφ_sum : φ (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = φ 4 := congrArg φ hsum
  rw [map_sum] at hφ_sum
  have hφ4 : φ 4 = 0 := rfl
  have hφ_unit : ∀ u : ℤˣ, φ (u : Fin 8) = 1 := fun u => by
    rcases Int.units_eq_one_or u with hu | hu <;> subst hu <;> rfl
  simp only [hφ_unit, Finset.sum_const, Finset.card_fin, smul_eq_mul, mul_one, hφ4] at hφ_sum
  have h2n1 : (2 * n - 1 : ZMod 2) = 1 := by
    have heq : 2 * n - 1 = 2 * (n - 1) + 1 := by omega
    simp only [heq, Nat.cast_add, Nat.cast_mul, Nat.cast_ofNat, CharP.cast_eq_zero,
               zero_mul, zero_add, Nat.cast_one]
  rw [h2n1] at hφ_sum
  exact one_ne_zero hφ_sum
