    rw [← ZMod.val_natCast (∑ i : Fin (2 * n - 1), (p i : Fin 8).val)]
    congr 1
    simp only [Nat.cast_sum, ZMod.natCast_val]
  have h4mod2 : 4 % 2 = 0 := by norm_num
  have h8div2 : 2 ∣ 8 := by norm_num
  rw [hsum_mod8, Nat.mod_mod_of_dvd _ h8div2] at hsum_val
  omega
