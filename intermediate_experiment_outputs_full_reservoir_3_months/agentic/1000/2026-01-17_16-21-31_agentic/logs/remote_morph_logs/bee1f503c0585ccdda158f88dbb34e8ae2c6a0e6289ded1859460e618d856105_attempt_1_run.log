```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype]
  intro p h
  simp only [hE] at h
  have hsum : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = 4 := add_left_cancel h
  have unit_val_odd : ∀ u : ℤˣ, (u : Fin 8).val % 2 = 1 := fun u => by
    rcases Int.units_eq_one_or u with rfl | rfl <;> rfl
  have sum_odd : (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 2 = 1 := by
    rw [Finset.sum_nat_mod]
    simp only [unit_val_odd, Finset.sum_const, Finset.card_fin, smul_eq_mul, mul_one]
    omega
  have h_mod : (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 8 = 4 := by
    have h1 : (↑(∑ i : Fin (2 * n - 1), (p i : Fin 8).val) : ZMod 8) = 4 := by
      rw [Nat.cast_sum]
      conv_lhs => arg 2; ext i; rw [ZMod.natCast_val]
      exact hsum
    have h2 : (↑(∑ i : Fin (2 * n - 1), (p i : Fin 8).val) : ZMod 8).val = 
              (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 8 := ZMod.val_natCast _
    rw [h1] at h2
    exact h2
  have sum_even : (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 2 = 0 := by
    calc (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 2 
        = (∑ i : Fin (2 * n - 1), (p i : Fin 8).val) % 8 % 2 := by
            rw [Nat.mod_mod_of_dvd]; decide
      _ = 4 % 2 := by rw [h_mod]
      _ = 0 := rfl
  omega
