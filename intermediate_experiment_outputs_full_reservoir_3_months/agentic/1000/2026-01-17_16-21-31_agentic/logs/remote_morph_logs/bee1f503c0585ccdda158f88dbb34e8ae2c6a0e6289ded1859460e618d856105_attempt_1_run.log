```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype]
  intro p h
  simp only [hE] at h
  have hsum : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = 4 := add_left_cancel h
  let φ : ZMod 8 →+* ZMod 2 := ZMod.castHom (by decide : 2 ∣ 8) (ZMod 2)
  have hφ : ∀ u : ℤˣ, φ (u : Fin 8) = 1 := fun u => by
    rcases Int.units_eq_one_or u with rfl | rfl <;> native_decide
  have h1 : φ (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = ∑ i : Fin (2 * n - 1), φ (p i : Fin 8) :=
    map_sum φ _ _
  simp only [hφ, Finset.sum_const, Finset.card_fin, smul_eq_mul, mul_one] at h1
  rw [hsum] at h1
  have h2 : φ (4 : Fin 8) = 0 := by native_decide
  rw [h2] at h1
  have h3 : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by
    have eq : 2 * n - 1 = 2 * (n - 1) + 1 := by omega
    simp [eq]
  rw [h3] at h1
  exact one_ne_zero h1
