  exact MState.exp_val_nonneg (HermitianMat.proj_le_nonneg (Real.exp (n * (Rsup + Оө4)) вҖў (Пғ n).M) (ПҒ n).M) (ПҒ n)

private theorem LemmaS3_helper {Оө : Prob} {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
  (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
  (f : в„• вҶ’ в„қвүҘ0) (hПғ : вҲҖ (i : в„•), Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ (ПғвӮҒ i)) (n : в„•) :
    вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) вүӨ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n := by
  have hвӮҒ (T : HermitianMat (d n) в„Ӯ) (hT : 0 вүӨ T) :
          Real.exp (-f n) * T.inner (ПғвӮӮ n).M вүӨ T.inner (ПғвӮҒ n).M := by
    simpa using HermitianMat.inner_mono hT (hПғ n)
  by_cases hПғвӮӮ : ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) = 0
  В· simp [hПғвӮӮ]
  replace hПғвӮӮ := Prob.zero_lt_coe hПғвӮӮ
  have hПғвӮҒ : (0 : в„қ) < ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) := by
    refine OptimalHypothesisRate.rate_pos_of_smul_pos hПғвӮӮ (Real.exp_pos (-f n)) ?_
    exact hПғ n --For some reason turning these two lines into one `exact` causes timeouts
  rw [вҶҗ ENNReal.toReal_le_toReal (by finiteness) (by finiteness)]
  rw [ENNReal.toReal_add (by finiteness) (by finiteness)]
  simp only [Prob.negLog_pos_Real, ENNReal.coe_toReal, OptimalHypothesisRate,
    Set.mem_singleton_iff, iSup_iSup_eq_left] at hПғвӮҒ hПғвӮӮ вҠў
  rw [вҶҗ neg_le_neg_iff]
  simp only [neg_add_rev, neg_neg]
  rw [вҶҗ Real.log_exp (-f n), вҶҗ Real.log_mul (by positivity) (by positivity)]
  apply Real.log_le_log (by positivity)
  simp only [Prob.coe_iInf]
  rw [Real.mul_iInf_of_nonneg (by positivity)]
  apply ciInf_mono
  В· use 0
    rintro a вҹЁy, rflвҹ©
    have := (ПғвӮӮ n).exp_val_nonneg y.2.2.1
    positivity
  intro вҹЁx, hxвӮҒ, hxвӮӮ, hxвӮғвҹ©
  simp only [MState.exp_val, вҶҗ HermitianMat.smul_inner]
  exact HermitianMat.inner_mono' hxвӮӮ (hПғ n)

/-- Lemma S3 from the paper. What they denote as ПғвӮҷ and ПғвӮҷ', we denote as ПғвӮҒ and ПғвӮӮ. The `exp(-o(n))`
we express as a function `f : в„• вҶ’ в„қ`, together with the fact that `f` is little-o of `n` (i.e. that
`f =o[.atTop] id`), and then writing `exp(-f)`. We also split LemmaS3 into two parts, the `lim inf` part
and the `lim sup` part. The theorem as written is true for any `f`, but we can restrict to nonnegative
`f` (so, `в„• вҶ’ в„қвүҘ0`) which is easier to work with and more natural in the subsequent proofs. -/
private theorem LemmaS3_inf {Оө : Prob}
    {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
    (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
    (f : в„• вҶ’ в„қвүҘ0) (hf : (f В· : в„• вҶ’ в„қ) =o[.atTop] (В· : в„• вҶ’ в„қ))
    (hПғ : вҲҖ i, Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ ПғвӮҒ i)
    :
    Filter.atTop.liminf (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) / n) вүӨ
      Filter.atTop.liminf (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) / n)
    := by
  --Starting with `helper`, divide by n and take the limits. Since f is o(n),
  --the (f n) / n term will go to zero.
  trans Filter.atTop.liminf fun n вҶҰ (вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n) / n
  В· refine Filter.liminf_le_liminf (.of_forall ?_)
    intro
    grw [LemmaS3_helper _ _ _ _ hПғ]
  В· apply le_of_eq
    simp_rw [ENNReal.add_div]
    apply ENNReal.liminf_add_of_right_tendsto_zero
    convert Asymptotics.IsLittleO.tendsto_div_nhds_zero hf
    rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
    В· simp
    В· rw [Filter.eventually_atTop]
      use 1
      finiteness

private theorem LemmaS3_sup {Оө : Prob}
    {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
    (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
    (f : в„• вҶ’ в„қвүҘ0) (hf : (f В· : в„• вҶ’ в„қ) =o[.atTop] (В· : в„• вҶ’ в„қ))
    (hПғ : вҲҖ i, Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ ПғвӮҒ i)
    :
    Filter.atTop.limsup (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) / n) вүӨ
      Filter.atTop.limsup (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) / n)
    := by
  --Starting with `helper`, divide by n and take the limits. Since f is o(n),
  --the (f n) / n term will go to zero.
  trans Filter.atTop.limsup fun n вҶҰ (вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n) / n
  В· refine Filter.limsup_le_limsup (.of_forall ?_)
    dsimp
    intro x
    grw [LemmaS3_helper _ _ _ _ hПғ]
  В· apply le_of_eq
    simp_rw [ENNReal.add_div]
    apply ENNReal.limsup_add_of_right_tendsto_zero
    convert Asymptotics.IsLittleO.tendsto_div_nhds_zero hf
    rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
    В· simp
    В· rw [Filter.eventually_atTop]
      use 1
      finiteness

-- This is not exactly how R_{1, Оө} is defined in Eq. (17), but it should be equal due to
-- the monotonicity of log and Lemma 3.
private noncomputable def R1 (ПҒ : MState (H i)) (Оө : Prob) : в„қвүҘ0вҲһ :=
  Filter.atTop.liminf fun n вҶҰ вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–IsFree) / n

private noncomputable def R2 (ПҒ : MState (H i)) : ((n : в„•) вҶ’ IsFree (i := i ^ n)) вҶ’ в„қвүҘ0вҲһ :=
  fun Пғ вҶҰ Filter.atTop.liminf fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ n) / n

open MatrixOrder

open scoped HermitianMat

section proj_le

variable {d : Type*} [Fintype d] [DecidableEq d] (A B : HermitianMat d в„Ӯ)

private lemma commute_aux (n : в„•) {x : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat)
  (hE : E = 1 - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : Commute ((1 / n : в„қ) вҖў E).toMat (в„°.log - Пғ.log).toMat := by
  rw [HermitianMat.one_sub_proj_le] at hE
  obtain вҹЁC, вҹЁf, rflвҹ©, вҹЁg, rflвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_sub]
  rw [HermitianMat.proj_lt_def, вҶҗ HermitianMat.cfc_const_mul] at hE
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_comp] at hE
  subst E
  rw [вҶҗ HermitianMat.cfc_const_mul]
  apply HermitianMat.cfc_self_commute

open HermMul in
private lemma rexp_mul_smul_proj_lt_mul_sub_le_mul_sub {n : в„•} {x : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat) (hx : 0 < x)
  (hв„° : в„°.toMat.PosSemidef) (hПғ : Пғ.toMat.PosDef)
  (hE : E = 1 - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : в„°.inner (((1 / n : в„қ) вҖў E) * (в„°.log - Пғ.log)) вүӨ в„°.inner (x вҖў E) := by
  rw [HermitianMat.inner_eq_re_trace, HermitianMat.inner_eq_re_trace]
  rcases n.eq_zero_or_pos with rfl | hn
  В· have hE' : 0 вүӨ E.toMat := by
      rw [hE, HermitianMat.one_sub_proj_le]
      apply HermitianMat.proj_lt_nonneg
    have hв„° : 0 вүӨ в„° := by rwa [HermitianMat.zero_le_iff]
    replace hв„° : 0 вүӨ в„°.inner E := HermitianMat.inner_ge_zero hв„° hE'
    rw [HermMul.mul_eq_symmMul, HermitianMat.symmMul_of_commute]
    В· simp only [HermitianMat.val_eq_coe, CharP.cast_eq_zero, div_zero, zero_smul,
        ZeroMemClass.coe_zero, AddSubgroupClass.coe_sub, zero_mul, mul_zero, Matrix.trace_zero,
        map_zero, selfAdjoint.val_smul, Algebra.mul_smul_comm, trace_smul, Complex.real_smul,
        RCLike.mul_re, RCLike.im_to_complex, Complex.ofReal_im, sub_zero, ge_iff_le]
      rw [вҶҗ HermitianMat.inner_eq_re_trace]
      positivity
    В· simp only [CharP.cast_eq_zero, div_zero, zero_smul, HermitianMat.val_eq_coe,
        ZeroMemClass.coe_zero, AddSubgroupClass.coe_sub, Commute.zero_left, Commute.sub_right]
  rw [HermMul.mul_eq_symmMul, HermitianMat.symmMul_of_commute (commute_aux n hв„°Пғ hE)]
  dsimp
  repeat rw [HermitianMat.val_eq_coe]
  gcongr
  apply Matrix.PosSemidef.trace_mono
  rw [one_div, smul_mul_assoc, mul_smul_comm]
  rw [inv_smul_le_iff_of_pos (mod_cast hn)]
  rw [mul_smul_comm]
  obtain вҹЁC, вҹЁf, hfвҹ©, вҹЁg, hgвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [hf, hg] at hE вҠў
  rw [HermitianMat.one_sub_proj_le, HermitianMat.proj_lt_def] at hE
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.cfc_sub] at hE
  rw [вҶҗ HermitianMat.cfc_comp] at hE
  unfold Function.comp at hE
  dsimp at hE
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp, smul_smul]
  change _ * (E.toMat * HermitianMat.toMat (_ - _)) вүӨ _
  rw [вҶҗ HermitianMat.cfc_sub]
  subst E
  rw [вҶҗ HermitianMat.coe_cfc_mul, вҶҗ HermitianMat.coe_cfc_mul]
  rw [вҶҗ HermitianMat.coe_cfc_mul]
  change _ вүӨ HermitianMat.toMat ((n * x) вҖў C.cfc _)
  rw [вҶҗ HermitianMat.cfc_const_mul]
  change (C.cfc _ : HermitianMat _ _) вүӨ C.cfc _
  rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
  intro i
  simp only [mul_ite, Pi.sub_apply, Pi.mul_apply, ite_mul]
  rw [ite_sub_ite]
  simp only [sub_pos, mul_one, Function.comp_apply, one_mul, mul_zero, zero_mul, sub_self]
  split_ifs with h; swap
  В· rfl
  set fi := f (C.H.eigenvalues i) with hfi
  set gi := g (C.H.eigenvalues i) with hgi
  have hfiвӮҖ : 0 вүӨ fi := by
    rw [hf, вҶҗ HermitianMat.zero_le_iff, HermitianMat.zero_le_cfc] at hв„°
    exact hв„° i
  have hgiвӮҖ : 0 < gi := by
    rw [hg, HermitianMat.cfc_PosDef] at hПғ
    exact hПғ i
  rcases hfiвӮҖ.eq_or_lt with hfiвӮӮ | hfiвӮӮ
  В· simp [вҶҗ hfiвӮӮ]
  В· simp [mul_comm fi]
    suffices Real.log fi < n * x + Real.log gi by
      grw [this]
      simp only [add_sub_cancel_right, le_refl]
    rw [вҶҗ Real.log_exp (n * x), вҶҗ Real.log_mul (by positivity) (by positivity)]
    apply Real.strictMonoOn_log hfiвӮӮ ?_ h
    change 0 < Real.exp (n * x) * gi
    positivity

private lemma rexp_mul_smul_proj_lt_mul_sub_le_mul_sub' {n : в„•} {x : в„қ} {y : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat)
  (hв„° : в„°.toMat.PosSemidef) (hПғ : Пғ.toMat.PosDef)
  (hE : E = {Real.exp (n * y) вҖў Пғ вүӨвӮҡ в„°} - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : (1 / n : в„қ) вҖў E.toMat * (в„°.log.toMat - Пғ.log.toMat) вүӨ x вҖў E := by
  --Another version of the above. Once we've proved one it's probably very easy to adapt the
  --code for the other. This doesn't suffer from the zero eigenvalue issue as much.
  rcases n.eq_zero_or_pos with rfl | hn
  В· simp_all
  obtain вҹЁC, вҹЁf, hfвҹ©, вҹЁg, hgвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [hf, hg] at hE вҠў
  rw [HermitianMat.proj_le_def, HermitianMat.proj_le_def] at hE
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.cfc_sub] at hE
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_const_mul] at hE
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_sub] at hE
  subst E
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp]
  conv =>
    enter [1]
    congr
    В· change HermitianMat.toMat ((1 / (n : в„қ)) вҖў _)
    В· change HermitianMat.toMat (_ - _)
  change _ вүӨ HermitianMat.toMat (x вҖў C.cfc _)
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.coe_cfc_mul]
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ sub_nonneg]
  change 0 вүӨ HermitianMat.toMat (_ - _)
  rw [вҶҗ HermitianMat.cfc_sub]
  change (0 : HermitianMat d в„Ӯ) вүӨ _
  rw [HermitianMat.zero_le_cfc]
  intro i
  simp only [Pi.sub_apply, Function.comp_apply, one_div, Pi.mul_apply]
  set fi := f (C.H.eigenvalues i) with hfi
  set gi := g (C.H.eigenvalues i) with hgi
  have hfiвӮҖ : 0 вүӨ fi := by
    rw [hf, вҶҗ HermitianMat.zero_le_iff, HermitianMat.zero_le_cfc] at hв„°
    exact hв„° i
  have hgiвӮҖ : 0 < gi := by
    rw [hg, HermitianMat.cfc_PosDef] at hПғ
    exact hПғ i
  split_ifs with ha hb hb <;> simp only [вҶҗ hfi, вҶҗ hgi] at ha hb вҠў
  В· simp
  В· simp only [sub_nonneg, not_le, sub_zero, mul_one] at ha hb вҠў
    rw [inv_mul_le_iffвӮҖ (by positivity)]
    rw [вҶҗ Real.exp_le_exp, Real.exp_sub]
    rw [Real.exp_log (lt_of_lt_of_le (by positivity) ha), Real.exp_log hgiвӮҖ]
    rw [div_le_iffвӮҖ hgiвӮҖ]
    exact hb.le
  В· simp only [sub_nonneg, not_le, zero_sub, mul_neg, mul_one, neg_mul, sub_neg_eq_add,
      le_neg_add_iff_add_le, add_zero] at ha hb вҠў
    rw [le_inv_mul_iffвӮҖ (by positivity)]
    rw [вҶҗ Real.exp_le_exp, Real.exp_sub]
    rw [Real.exp_log (lt_of_lt_of_le (by positivity) hb), Real.exp_log hgiвӮҖ]
    rw [le_div_iffвӮҖ hgiвӮҖ]
    exact hb
  В· simp

end proj_le

