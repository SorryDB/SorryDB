theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  classical
  induction a with
  | nil => exact ⟨[], rfl, fun _ _ h => (List.not_mem_nil _ h).elim, List.nodup_nil⟩
  | cons hd tl ih =>
    obtain ⟨btl, hlen, hfresh, hnodup⟩ := ih
    let used := (ε.toList.map (·.1)).filter (·.1 == hd) |>.map (·.2) ++ (tl.zip btl).filter (·.1 == hd) |>.map (·.2)
    let fresh := String.join used ++ "x"
    refine ⟨fresh :: btl, by simp [hlen], ?_, ?_⟩
    · intro a' b' h
      simp only [List.zip_cons_cons, List.mem_cons] at h
      rcases h with ⟨rfl, rfl⟩ | h
      · intro hc
        have hmem := Batteries.AssocList.contains_eq.mp hc
        have : fresh ∈ used := by
          simp only [List.mem_append, List.mem_map, List.mem_filter]
          left
          obtain ⟨y, hy⟩ := hmem
          exact ⟨(hd, fresh), ⟨hy, by simp⟩, rfl⟩
        have hpref : used.foldl (· ++ ·) "" ++ "x" = fresh := by simp [fresh, String.join]
        simp [String.join] at hpref
        omega_nat
      · exact hfresh _ _ h
    · simp only [List.zip_cons_cons, List.nodup_cons, hnodup, and_true]
      intro hmem
      have : fresh ∈ used := by
        simp only [List.mem_append, List.mem_map, List.mem_filter]
        right
        exact ⟨(hd, fresh), ⟨hmem, by simp⟩, rfl⟩
      simp [fresh, String.join] at this
```
