def toEnv {Ident Typ} [DecidableEq Typ] (ε : FinEnv Ident Typ) : Env Ident Typ := ε.find?

theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  classical
  let usedStrs := ε.toList.map (·.1.2)
  let maxLen := usedStrs.foldl (fun acc s => max acc s.length) 0
  let b := List.range a.length |>.map fun i => String.mk (List.replicate (maxLen + i + 1) 'x')
  refine ⟨b, ?_, ?_, ?_⟩
  · simp [b]
  · intro a' b' hmem
    simp only [Batteries.AssocList.contains_eq, Bool.not_eq_true, not_exists]
    intro v hfind
    have hmem_b : b' ∈ b := List.mem_of_mem_zip_right hmem
    simp only [b, List.mem_map, List.mem_range] at hmem_b
    obtain ⟨i, _, hb'⟩ := hmem_b
    have hlen_b' : b'.length = maxLen + i + 1 := by simp [← hb']
    have hmem_used : b' ∈ usedStrs := by
      simp only [usedStrs, List.mem_map]
      exact ⟨((a', b'), v), Batteries.AssocList.mem_toList.mpr hfind, rfl⟩
    have hle : b'.length ≤ maxLen := by
      clear hlen_b' hmem hfind
      induction usedStrs generalizing maxLen with
      | nil => exact absurd hmem_used (List.not_mem_nil _)
      | cons h t ih =>
        simp only [List.foldl_cons] at *
        cases List.mem_cons.mp hmem_used with
        | inl heq => subst heq; exact Nat.le_trans (Nat.le_max_right _ _) (foldl_max_ge t _)
        | inr hmem' => exact ih _ hmem'
    omega
  · apply List.nodup_of_pairwise_ne
    intro i j hi hj hne
    simp only [b, List.getElem_map, List.getElem_range, ne_eq]
    intro heq
    have : (maxLen + i + 1) = (maxLen + j + 1) := by
      have h1 : (String.mk (List.replicate (maxLen + i + 1) 'x')).length = maxLen + i + 1 := by simp
      have h2 : (String.mk (List.replicate (maxLen + j + 1) 'x')).length = maxLen + j + 1 := by simp
      rw [heq] at h1; omega
    omega
where
  foldl_max_ge (l : List String) (init : Nat) : init ≤ l.foldl (fun acc s => max acc s.length) init := by
    induction l generalizing init with
    | nil => exact Nat.le_refl _
    | cons h t ih => exact Nat.le_trans (Nat.le_max_left _ _) (ih _)
```
