theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  classical
  induction a with
  | nil => exact ⟨[], rfl, nofun, .nil⟩
  | cons hd tl ih =>
    obtain ⟨btl, hlen, hfresh, hnodup⟩ := ih
    let bad := (ε.toList.filter (·.1.1 == hd)).map (·.1.2) ++ (tl.zip btl).filter (·.1 == hd) |>.map (·.2)
    let fresh := String.join bad ++ "x" ++ toString bad.length
    refine ⟨fresh :: btl, by simp [hlen], ?_, ?_⟩
    · intro a' b' hmem
      simp only [List.zip_cons_cons, List.mem_cons] at hmem
      rcases hmem with ⟨rfl, rfl⟩ | hmem
      · simp only [Batteries.AssocList.contains_eq, not_exists]
        intro v hv
        have : fresh ∈ bad := by
          simp only [List.mem_append, List.mem_map, List.mem_filter, beq_iff_eq]
          left; exact ⟨((hd, fresh), v), ⟨hv, rfl⟩, rfl⟩
        have hlen : fresh.length > (String.join bad).length := by simp [fresh]
        have hsub : (String.join bad).length ≥ fresh.length := String.join_length_ge_of_mem this
        omega
      · exact hfresh a' b' hmem
    · simp only [List.zip_cons_cons, List.nodup_cons, hnodup, and_true]
      intro hmem
      have : fresh ∈ bad := by
        simp only [List.mem_append, List.mem_map, List.mem_filter, beq_iff_eq]
        right; exact ⟨(hd, fresh), ⟨hmem, rfl⟩, rfl⟩
      have hlen : fresh.length > (String.join bad).length := by simp [fresh]
      have hsub : (String.join bad).length ≥ fresh.length := String.join_length_ge_of_mem this
      omega
