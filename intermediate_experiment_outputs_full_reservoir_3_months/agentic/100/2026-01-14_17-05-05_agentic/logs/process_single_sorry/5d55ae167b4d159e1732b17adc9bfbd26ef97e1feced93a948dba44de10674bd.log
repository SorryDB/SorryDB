      have h_comm : f ≫ k = g ≫ lightToProfinite.map (S.proj (n+1) ≫ S.transitionMap n) := by
        rw [h_down, lightToProfinite.map_comp]
        exact congrArg _ (S.proj_comp_transitionMap n).symm
      exact profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n)) 
        (g ≫ lightToProfinite.map (S.proj (n+1))) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ lightToProfinite.obj (S.component n) // 
      f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
