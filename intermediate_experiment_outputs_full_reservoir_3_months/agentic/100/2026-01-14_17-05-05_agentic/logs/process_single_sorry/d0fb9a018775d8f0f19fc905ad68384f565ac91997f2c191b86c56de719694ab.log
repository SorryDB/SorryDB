namespace LO.Propositional

namespace Axioms

variable {F : Type*} [LogicalConnective F]
variable (ŌÜ Ōą Ōá : F)

protected alias PCon‚āĀ := LO.Axioms.Dummett

protected abbrev PCon‚āā := (ŌÜ ‚ěĚ Ōą) ‚ěĚ ((ŌÜ ‚ěĚ Ōą) ‚ěĚ ŌÜ)

protected abbrev PCon‚āÉ := (ŌÜ ‚ěĚ Ōą) ‚ěĚ ((ŌÜ ‚ěĚ Ōą) ‚ěĚ Ōą)

protected abbrev PCon‚āĄ := (ŌÜ ‚ěĚ Ōą ‚čé Ōá) ‚ěĚ (ŌÜ ‚ěĚ Ōą) ‚čé (ŌÜ ‚ěĚ Ōá)

protected abbrev PCon‚āÖ := (ŌÜ ‚čŹ Ōą ‚čé Ōá) ‚ěĚ (ŌÜ ‚ěĚ Ōá) ‚čé (ŌÜ ‚ěĚ Ōą)

protected abbrev PCon‚āÜ := ((ŌÜ ‚ěĚ Ōą) ‚ěĚ Ōą) ‚čŹ ((Ōą ‚ěĚ ŌÜ) ‚ěĚ ŌÜ) ‚ěĚ (ŌÜ ‚čé Ōą)

end Axioms


open Kripke2
open Formula.Kripke2

namespace Kripke2

variable {F : Kripke2.Frame} {ŌÜ Ōą : Formula ‚Ąē}

namespace Frame

protected abbrev IsPiecewiseConnected (F : Kripke2.Frame) := _root_.IsPiecewiseConnected F.Rel
@[grind ‚Üí] lemma p_connected  [F.IsPiecewiseConnected] : ‚ąÄ {x y z : F}, x ‚Čļ y ‚Üí x ‚Čļ z ‚Üí y ‚Čļ z ‚ą® y = z ‚ą® z ‚Čļ y := by apply IsPiecewiseConnected.p_connected
@[grind ‚Üí] lemma p_connected' [F.IsPiecewiseConnected] : ‚ąÄ {x y z : F}, x ‚Čļ y ‚Üí x ‚Čļ z ‚Üí y ‚Č† z ‚Üí y ‚Čļ z ‚ą® z ‚Čļ y := by apply IsPiecewiseConnected.p_connected'

end Frame

