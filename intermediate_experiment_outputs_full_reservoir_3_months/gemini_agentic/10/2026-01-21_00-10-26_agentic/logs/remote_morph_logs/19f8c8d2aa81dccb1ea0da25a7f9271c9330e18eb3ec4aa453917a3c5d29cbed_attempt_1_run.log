  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  induction w generalizing i cs args with
  | zero => exact (Nat.not_lt_zero i h).elim
  | succ w ih =>
    have h_decomp : args = Vector.insertIdx args.tail 0 args.head := by
      simp only [Vector.insertIdx_zero]
      ext k hk; match k with | .zero => simp; rfl | .succ k => simp [add_comm]
    rw [h_decomp] at h h' h'' ⊢
    unfold assert_bits_e Vector.foldl
    simp only [Vector.toArray_insertIdx, Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil, zero_add, Array.size_singleton]
    rw [← Vector.foldl, ← assert_bits_e]
    cases i with
    | zero =>
      have h_n : (assert_bit_e cs args.head).eval = .n := by
        unfold assert_bit_e Cs.eval Exp.eval
        simp only [Vector.insertIdx_zero] at h' h''
        simp [ZMod.mul_eq_zero_iff, sub_eq_zero, h', h'']
      clear h h' h'' ih
      induction w generalizing args cs with
      | zero =>
        have : args.tail = #v[] := by ext k; exact k.elim0
        simp [this, assert_bits_e, Vector.foldl, h_n]
      | succ w ih' =>
        have h_decomp' : args.tail = Vector.insertIdx args.tail.tail 0 args.tail.head := by
          simp only [Vector.insertIdx_zero]
          ext k hk; match k with | .zero => simp; rfl | .succ k => simp [add_comm]
        rw [h_decomp', assert_bits_e, Vector.foldl, Vector.toArray_insertIdx, Array.foldl_append']
        simp only [Array.size_singleton, List.foldl_toArray', List.foldl_cons, List.foldl_nil, zero_add]
        rw [← Vector.foldl, ← assert_bits_e]
