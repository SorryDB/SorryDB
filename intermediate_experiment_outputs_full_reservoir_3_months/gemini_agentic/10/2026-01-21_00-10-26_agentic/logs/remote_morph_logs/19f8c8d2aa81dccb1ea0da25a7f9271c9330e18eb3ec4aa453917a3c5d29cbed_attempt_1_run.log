  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, hi, h_not0, h_not1⟩
  revert i hi h_not0 h_not1 cs args
  induction w with
  | zero =>
    intros args cs i hi h_not0 h_not1
    exfalso; exact Nat.not_lt_zero i hi
  | succ w ih =>
    intros args cs i hi h_not0 h_not1
    rw [assert_bits_e, ← Vector.cons_head_tail args, Vector.foldl_cons]
    cases i with
    | zero =>
      have h_n : (assert_bit_e cs args.head).eval = .n := by
        simp [assert_bit_e, Cs.eval, Exp.eval]
        split
        · rename_i hb
          cases ZMod.mul_eq_zero_iff.mp hb with
          | inl h0 => exact h_not0 (by simpa using h0)
          | inr h1 => exact h_not1 (by simpa [sub_eq_zero] using h1)
        · rfl
      clear ih hi h_not0 h_not1 i
      induction w generalizing cs args with
      | zero =>
        unfold assert_bits_e; simp [Vector.foldl, h_n]
