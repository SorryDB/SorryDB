        rw [assert_bits_e, ← Vector.cons_head_tail args, Vector.foldl_cons]
        apply ih' args.tail (assert_bit_e cs args.head)
        simp [assert_bit_e, Cs.eval, h_n, apply_ite]
    | succ j =>
      apply ih args.tail (assert_bit_e cs args.head) j (Nat.lt_of_succ_lt_succ hi)
      · exact h_not0
      · exact h_not1

end Clap
