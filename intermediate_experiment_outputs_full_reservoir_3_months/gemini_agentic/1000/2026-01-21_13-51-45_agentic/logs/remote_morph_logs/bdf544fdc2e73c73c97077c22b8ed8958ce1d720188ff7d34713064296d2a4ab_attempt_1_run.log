      have : (nk : ℤ) * (2014 - nk) ≤ 1007 ^ 2 := by
        have h1 : 1007 * (2014 - 1007) = 1007^2 := by ring
        have h2 : ∀ x : ℤ, x * (2014 - x) ≤ 1007 * 1007 := by
          intro x; nlinarith
        exact h2 nk
      linarith
  have hS_val (k : ℕ+) (hk : N ≤ k) : S_sum k = Ek k + (∑ j ∈ {j | f j ≤ b_val}.toFinset, f j - ∑ g ∈ (gaps 4030), g) := sorry
  rw [hS_diff, hS_val n (hNm.trans hmn.le), hS_val m hNm]
  simp; rw [abs_le]
  have h1 := hE_bound n (hNm.trans hmn.le); have h2 := hE_bound m hNm
  constructor <;> linarith [h1.1, h1.2, h2.1, h2.2]

