import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k h; rcases lt_trichotomy j k with h' | rfl | h'
    · exact (hii k j ⟨Nat.one_le j, h'⟩ h.symm).elim
    · rfl
    · exact (hii j k ⟨Nat.one_le k, h'⟩ h).elim
  let G := {g : ℤ | g ≥ 1 ∧ ∀ j, f j ≠ g}
  have G_bound : ∀ g ∈ G, g ≤ 2015 := by
    intro g ⟨hg1, hg_not⟩
    by_contra hg_large; push_neg at hg_large
    have : f (PNat.mk 2015 (by linarith)) ≥ 2016 := by
      dsimp [f]; have := (hi (PNat.mk 2015 (by linarith))).1; linarith
    have : g ∈ (Finset.Icc 1 g).map ⟨(fun x => (x : ℤ)), Int.coe_nat_inj⟩ := by simp [hg1]
    sorry
  let G_fin : Finset ℤ := (Finset.range 2016).filter (λ g => g ≥ 1 ∧ ∀ j, f j = g → False)
  let b_val := G_fin.card
  have hb_pos : b_val ≥ 1 := by
    have : (1 : ℤ) ∈ G_fin := by
      simp [G_fin]; constructor; · linarith
      · intro j hj; have := (hi j).1; dsimp [f] at hj; linarith [hj, (j : ℕ).one_le]
    exact Finset.card_pos.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, Nat.pos_of_one_le hb_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S n - S m := by
    rw [S, S, ← Finset.sum_Icc_union_Icc]
    · simp
    · exact PNat.one_le m
    · exact hmn
  have S_val (k : ℕ+) (hk : N ≤ k) : S k = (b * (b + 1) / 2 : ℤ) - (∑ g ∈ G_fin, g) +
      (∑ j ∈ (Finset.Icc 1 k).filter (λ j => f j > k + b), (f j - (k + b))) +
      (∑ j ∈ (Finset.Icc (k + 1) (k + 2016)).filter (λ j => f j ≤ k + b), (k + b - f j)) := sorry
  let E (k : ℕ+) := (∑ j ∈ (Finset.Icc 1 k).filter (λ j => f j > k + b), (f j - (k + b))) +
      (∑ j ∈ (Finset.Icc (k + 1) (k + 2016)).filter (λ j => f j ≤ k + b), (k + b - f j))
  have E_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ E k ∧ E k ≤ 1007 ^ 2 := sorry
  rw [hS_diff, S_val n (hNm.trans (le_of_lt hmn)), S_val m hNm]
  have : S n - S m = E n - E m := by ring
  rw [this]; have := E_bound n (hNm.trans (le_of_lt hmn)); have := E_bound m hNm
  simp [abs_le]; constructor <;> linarith
