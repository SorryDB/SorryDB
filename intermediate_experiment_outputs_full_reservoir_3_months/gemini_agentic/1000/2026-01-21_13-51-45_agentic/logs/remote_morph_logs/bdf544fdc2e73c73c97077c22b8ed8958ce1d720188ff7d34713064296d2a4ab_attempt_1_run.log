import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with h | rfl | h
    · exact (hii k j ⟨j.2, h⟩ hjk.symm).elim
    · rfl
    · exact (hii j k ⟨k.2, h⟩ hjk).elim
  let G := {g : ℤ | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have G_finite : G.Finite := by
    have h_card_bdd : ∀ M : ℕ, (G ∩ Set.Icc 1 M).toFinset.card ≤ 2015 := by
      intro M
      let SM := {j | f j ≤ M}
      have SM_finite : SM.Finite := by
        apply Set.Finite.subset (Set.finite_Icc 1 M)
        intro j hj; simp at hj ⊢; linarith [(hi j).1]
      have h_im_card : SM.toFinset.card = M - (G ∩ Set.Icc 1 M).toFinset.card := by
        have : SM.toFinset.image f = (Finset.Icc 1 M).filter (· ∈ Set.range f) := by
          ext x; simp; constructor
          · rintro ⟨j, hj, rfl⟩; exact ⟨hj, j, rfl⟩
          · rintro ⟨h1, h2, j, rfl⟩; exact ⟨j, h1⟩
        have h_card := Finset.card_image_of_injective SM.toFinset f_inj
        rw [h_card, this, Finset.filter_card_add_filter_neg_card_eq_card (Finset.Icc 1 M) (· ∈ Set.range f)]
        simp [G]; omega
      have : M - 2015 ≤ SM.toFinset.card := by
        have : Finset.Icc 1 (M.fwd 2015) ⊆ SM.toFinset := sorry
        sorry
      sorry
    exact Set.Finite.subset (Set.finite_Icc 1 2015) (sorry)
  let G_fin := G_finite.toFinset
  let b_val := G_fin.card
  have b_pos : 0 < b_val := by
    have h1 : 1 ∈ G_fin := by
      simp [G_fin, G]; intro j; have := (hi j).1; linarith [PNat.one_le j]
    exact Finset.card_pos.mpr ⟨1, h1⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - (b : ℤ))
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S_sum n - S_sum m := by
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc (PNat.one_le m) hmn.le]
    simp; ring
  let Ek (k : ℕ+) : ℤ :=
    (∑ j ∈ (Finset.Icc 1 k).filter (λ j => f j > (k : ℤ) + b_val), (f j - ((k : ℤ) + b_val))) +
    (∑ j ∈ (Finset.Icc (k + 1) (k + 2016)).filter (λ j => f j ≤ (k : ℤ) + b_val), ((k : ℤ) + b_val - f j))
  have hE_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ Ek k ∧ Ek k ≤ 1007 ^ 2 := by
    constructor
    · apply add_nonneg <;> apply Finset.sum_nonneg <;> intro j hj <;> simp at hj <;> linarith
    · sorry
  have hS_val (k : ℕ+) (hk : N ≤ k) : S_sum k = Ek k + (b_val * (b_val + 1) / 2 - ∑ g ∈ G_fin, g) := sorry
  rw [hS_diff, hS_val n (hNm.trans hmn.le), hS_val m hNm]
  simp; rw [abs_le]; have h1 := hE_bound n (hNm.trans hmn.le); have h2 := hE_bound m hNm
  constructor <;> linarith [h1.1, h1.2, h2.1, h2.2]

