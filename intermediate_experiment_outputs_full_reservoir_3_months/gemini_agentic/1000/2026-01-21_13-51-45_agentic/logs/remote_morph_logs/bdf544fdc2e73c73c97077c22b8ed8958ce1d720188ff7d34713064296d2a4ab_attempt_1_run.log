import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with h | rfl | h
    · exact (hii k j ⟨PNat.one_le j, h⟩ hjk.symm).elim
    · rfl
    · exact (hii j k ⟨PNat.one_le k, h⟩ hjk).elim
  let G := {g : ℤ | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have hG_subset : G ⊆ Set.Icc 1 2015 := by
    intro g ⟨hg1, hgn⟩
    constructor; exact hg1
    by_contra hgt; push_neg at hgt
    let S := Finset.Icc 1 (g.toNat)
    have hS_card : S.card = g.toNat := by rw [Finset.card_Icc, Nat.add_sub_cancel]; rfl
    let fS := S.image (λ (j : ℕ) => f ⟨j, Nat.pos_of_gt (by linarith)⟩)
    have hfS_card : fS.card = g.toNat := by
      rw [Finset.card_image_of_injective]; exact hS_card
      intro x y hxy; apply PNat.ext; apply f_inj; exact hxy
    have hfS_le : ∀ x ∈ fS, x ≤ g + 2015 := by
      intro x hx; rcases Finset.mem_image.1 hx with ⟨j, hj, rfl⟩
      simp at hj; have := hi ⟨j, ⋯⟩; linarith
    have hfS_ge : ∀ x ∈ fS, x ≥ 2 := by
      intro x hx; rcases Finset.mem_image.1 hx with ⟨j, hj, rfl⟩
      simp at hj; have := hi ⟨j, ⋯⟩; linarith
    have hfS_g : ∀ x ∈ fS, x ≠ g := by
      intro x hx; rcases Finset.mem_image.1 hx with ⟨j, hj, rfl⟩; apply hgn
    sorry
  have G_finite : G.Finite := (Set.finite_Icc 1 2015).subset hG_subset
  let b_val := G_finite.toFinset.card
  have b_pos : 0 < b_val := by
    have h1 : (1 : ℤ) ∈ G := by
      constructor; exact le_refl 1; intro j; have := hi j; linarith [PNat.one_le j]
    exact Finset.card_pos.mpr ⟨1, G_finite.toFinset.mem_toFinset.mpr h1⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨2016, by norm_num⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - (b : ℤ))
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - (b : ℤ)) = S_sum n - S_sum m := by
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc (PNat.one_le m) hmn.le]
    simp; ring
  have hS_val (k : ℕ+) (hk : N ≤ k) : ∃ Dk, S_sum k = Dk + (b_val * (b_val + 1) / 2 - ∑ g ∈ G_finite.toFinset, g) ∧ 0 ≤ Dk ∧ Dk ≤ 1007 ^ 2 := sorry
  rcases hS_val n (hNm.trans hmn.le) with ⟨Dn, hSn, hDn1, hDn2⟩
  rcases hS_val m hNm with ⟨Dm, hSm, hDm1, hDm2⟩
  rw [hS_diff, hSn, hSm]; simp
  rw [abs_le]; constructor <;> linarith
