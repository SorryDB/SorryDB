import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with h | rfl | h
    · exact absurd hjk.symm (hii k j ⟨PNat.one_le j, h⟩)
    · rfl
    · exact absurd hjk (hii j k ⟨PNat.one_le k, h⟩)
  let gaps (M : ℕ) := (Finset.Icc 1 M).filter (λ g => ∀ j, f j ≠ g)
  have h_gaps_bound : ∀ M, (gaps M).card ≤ 2015 := by
    intro M
    let S := (Finset.Icc 1 M).filter (λ g => ∃ j, f j = g)
    have h_card : (gaps M).card + S.card = M := by
      rw [← Finset.card_union_eq, Finset.filter_union_filter_neg_eq]
      · simp; intro x hx; simp [S, gaps]
      · apply Finset.disjoint_filter_filter_neg
    have hS_inj : ∀ x ∈ S, ∃! j, f j = x := by
      intro x hx; rcases Finset.mem_filter.1 hx with ⟨_, j, rfl⟩
      use j, rfl; intro k hk; exact f_inj hk
    let f_inv (x : S) : ℕ+ := Classical.choose (hS_inj x x.2).exists
    have f_inv_f : ∀ x, f (f_inv x) = x := λ x => Classical.choose_spec (hS_inj x x.2).exists
    have f_inv_inj : Function.Injective f_inv := by
      intro x y hxy; apply Subtype.ext; rw [← f_inv_f x, ← f_inv_f y, hxy]
    have hf_inv_val : ∀ x : S, (f_inv x : ℤ) ≥ (x : ℤ) - 2015 := by
      intro x; have := (hi (f_inv x)).2; have := f_inv_f x; dsimp [f] at this; linarith
    have hf_inv_le : ∀ x : S, (f_inv x : ℤ) ≤ (x : ℤ) - 1 := by
      intro x; have := (hi (f_inv x)).1; have := f_inv_f x; dsimp [f] at this; linarith
    have h_im_S : Finset.image f_inv Finset.univ ⊆ Finset.Icc 1 M := by
      intro j hj; rcases Finset.mem_image.1 hj with ⟨x, _, rfl⟩; simp; constructor
      · exact PNat.one_le _
      · have : (f_inv x : ℤ) ≤ (x : ℤ) - 1 := hf_inv_le x
        have : (x : ℤ) ≤ M := by have := x.2; simp at this; linarith
        linarith
    have h_S_card : S.card ≥ M - 2015 := by
      have : S.card = (Finset.image f_inv Finset.univ).card := by
        rw [Finset.card_image_of_injective Finset.univ f_inv_inj, Finset.card_univ]
      have h_f_inv_range : Finset.image f_inv Finset.univ ⊆ Finset.Icc 1 (M.fwd 0) := sorry
      sorry
    linarith
  let b_val := (gaps 4030).card
  have b_pos : 0 < b_val := by
    have : (1 : ℤ) ∈ gaps 4030 := by
      simp [gaps]; intro j; have := (hi j).1; linarith [PNat.one_le j]
    exact Finset.card_pos.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨4031, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - (b : ℤ))
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S_sum n - S_sum m := by
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc (PNat.one_le m) hmn.le]
    simp; ring
  let Ek (k : ℕ+) : ℤ :=
    (∑ j ∈ (Finset.Icc 1 k).filter (λ j => f j > (k : ℤ) + b_val), (f j - ((k : ℤ) + b_val))) +
    (∑ j ∈ (Finset.Icc (k + 1) (k + 2015)).filter (λ j => f j ≤ (k : ℤ) + b_val), ((k : ℤ) + b_val - f j))
  have hE_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ Ek k ∧ Ek k ≤ 1007 ^ 2 := by
    constructor
    · apply add_nonneg <;> apply Finset.sum_nonneg <;> intro j hj <;> simp at hj <;> linarith
    · let nk := ((Finset.Icc (k + 1) (k + 2015)).filter (λ j => f j ≤ (k : ℤ) + b_val)).card
      have h_nk_b : nk ≤ b_val - 1 := sorry
      have h_nk_a : nk ≤ 2015 - b_val := sorry
