import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with h | rfl | h
    · exfalso; exact hii k j ⟨PNat.one_le j, h⟩ hjk.symm
    · rfl
    · exfalso; exact hii j k ⟨PNat.one_le k, h⟩ hjk
  let G_set := {g : ℤ | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have G_bound : ∀ g ∈ G_set, g ≤ 2015 := sorry
  have G_finite : G_set.Finite := by
    refine Set.Finite.subset (Set.finite_Icc 1 2015) ?_
    intro g hg; simp; exact ⟨hg.1, G_bound g hg⟩
  let G_fin := G_finite.toFinset
  let b_val := G_fin.card
  have b_pos : 1 ≤ b_val := by
    have : (1 : ℤ) ∈ G_fin := by
      simp [G_fin, G_set]; intro j; have := (hi j).1; linarith [PNat.one_le j]
    exact Finset.card_pos.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - (b : ℤ))
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - (b : ℤ)) = S_sum n - S_sum m := sorry
  let Vk (k : ℕ+) := (Finset.Icc 1 k).filter (λ j => f j > (k : ℤ) + b_val)
  let Uk_set (k : ℕ+) := {j : ℕ+ | j > k ∧ f j ≤ (k : ℤ) + b_val}
  have Uk_finite (k : ℕ+) : (Uk_set k).Finite := by
    apply Set.Finite.subset (Set.finite_Icc (k + 1) (k + 2016))
    intro j hj; simp at hj; constructor; · linarith
    · have := (hi j).1; linarith
  let Uk_fin (k : ℕ+) := (Uk_finite k).toFinset
  let Ek (k : ℕ+) := (∑ j ∈ Vk k, (f j - ((k : ℤ) + b_val))) + (∑ j ∈ Uk_fin k, ((k : ℤ) + b_val - f j))
  have hE_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ Ek k ∧ Ek k ≤ 1007 ^ 2 := sorry
  have hS_val (k : ℕ+) (hk : N ≤ k) : S_sum k = Ek k + (b_val * (b_val + 1) / 2 - ∑ g ∈ G_fin, g) := sorry
  rw [hS_diff, hS_val n (hNm.trans (le_of_lt hmn)), hS_val m hNm]
  simp; ring_nf
  have hE_n := hE_bound n (hNm.trans (le_of_lt hmn))
  have hE_m := hE_bound m hNm
  rw [abs_le]
  constructor <;> linarith [hE_n.1, hE_n.2, hE_m.1, hE_m.2]

