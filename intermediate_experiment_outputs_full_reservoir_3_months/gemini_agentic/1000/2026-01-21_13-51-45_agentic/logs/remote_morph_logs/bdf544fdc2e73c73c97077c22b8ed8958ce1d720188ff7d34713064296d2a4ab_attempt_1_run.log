import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro k l h; rcases lt_trichotomy k l with hkl | hkl | hkl
    · exact (hii l k ⟨Nat.one_le k, hkl⟩ h.symm).elim
    · exact hkl
    · exact (hii k l ⟨Nat.one_le l, hkl⟩ h).elim
  let c (n : ℕ) : ℕ := n - (Finset.filter (λ k => ∃ j : ℕ+, f j = k) (Finset.range (n + 1))).card
  have c_step : ∀ n, c (n + 1) = c n + (if ∃ j, f j = n + 1 then 0 else 1) := by
    intro n
    have : (Finset.range (n + 2)).filter (λ k => ∃ j, f j = k) =
           if ∃ j, f j = n + 1 then insert (n + 1) ((Finset.range (n + 1)).filter (λ k => ∃ j, f j = k))
           else (Finset.range (n + 1)).filter (λ k => ∃ j, f j = k) := by
      rw [Finset.range_succ, Finset.filter_insert]
    rw [c, this]; split_ifs with h_ex <;> simp [c]
    · have h_mem : n + 1 ∉ (Finset.range (n + 1)).filter (λ k => ∃ j, f j = k) := by simp
      rw [Finset.card_insert_of_not_mem h_mem]
      omega
    · omega
  have c_mono : Monotone c := fun _ _ h => by
    induction h with | refl => rfl | step h ih => rw [c_step]; split_ifs <;> omega
  have c_le : ∀ n, c n ≤ 2015 := by
    intro n; induction n with
    | zero => simp [c]
    | succ n ih =>
      rw [c, n.succ_eq_add_one]
      let D_n := (Finset.Icc 1 (n + 1)).filter (λ j => f j > n + 1)
      have h_card : c (n + 1) = D_n.card := by
        rw [c, Finset.card_range_succ]
        have : ∀ j, f j ≥ 2 := fun j => by linarith [(hi j).1, (j : ℕ).one_le]
        have : {k ∈ Finset.range (n + 2) | ∃ j, f j = k} = (Finset.Icc 1 (n + 1)).image f ∩ Finset.range (n + 2) := sorry
        sorry
      have : ∀ j ∈ D_n, (j : ℤ) > (n : ℤ) + 1 - 2015 := fun j hj => by
        have := (hi j).2; have := (Finset.mem_filter.mp hj).2; omega
      have : D_n ⊆ Finset.Icc (Nat.max 1 (n + 2 - 2015)) (n + 1) := sorry
      have : D_n.card ≤ 2015 := sorry
      exact this
  obtain ⟨b_val, N_val, hN⟩ : ∃ b N, ∀ n ≥ N, c n = b := by
    have h_bound : ∃ b, ∃ N, ∀ n ≥ N, c n = b := by
      have : ∃ N, ∀ n ≥ N, c n = c N := ⟨2015, fun n hn => by
        have := c_mono hn; have := c_le n; have := c_le 2015; omega⟩
      obtain ⟨N, hN⟩ := this; exact ⟨c N, N, hN⟩
    obtain ⟨b, N, hN⟩ := h_bound; exact ⟨b, N, hN⟩
  have b_pos : b_val ≥ 1 := by rw [← hN (Nat.max 1 N_val) (Nat.le_max_right _ _)]; exact c_mono (Nat.le_max_left 1 N_val) (by omega)
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨N_val + 1, Nat.succ_pos _⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S (k : ℕ) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  have hS : ∀ k ≥ N_val, S k = (∑ d ∈ (Finset.Icc 1 2015).filter (λ d => ∃ j ≤ k, f j = k + d), (d : ℤ)) - (∑ r ∈ (Finset.range (k + 1)).filter (λ k => ¬∃ j, f j = k), (r : ℤ)) + (∑ r ∈ (Finset.range (k + 1)).filter (λ k => ¬∃ j, f j = k), (r : ℤ)) - (∑ r ∈ (Finset.range (k + 1)).filter (λ k => ¬∃ j, f j = k), (r : ℤ)) := sorry
  have hS_diff : ∀ k ≥ N_val, S k = (∑ d ∈ (Finset.Icc 1 2015).filter (λ d => ∃ j ≤ k, f j = k + d), (d : ℤ)) - (∑ r ∈ (Finset.range (N_val + 1)).filter (λ k => ¬∃ j, f j = k), (r : ℤ)) := sorry
  let D (k : ℕ) := (Finset.Icc 1 2015).filter (λ d => ∃ j ≤ k, f j = k + d)
  have h_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = (∑ d ∈ D n, (d : ℤ)) - (∑ d ∈ D m, (d : ℤ)) := by
    rw [Finset.sum_Icc_eq_sub_sum_Icc hmn, S, S, hS_diff n, hS_diff m]
    · ring
    · exact hNm
    · omega
  have h_card_D : ∀ k ≥ N_val, (D k).card = b_val := sorry
  have h_1_mem_D : ∀ k ≥ N_val, 1 ∈ D k := sorry
  have h_bound_sum : ∀ k ≥ N_val, (b_val * (b_val + 1) / 2 : ℤ) ≤ ∑ d ∈ D k, (d : ℤ) ∧
    ∑ d ∈ D k, (d : ℤ) ≤ 1 + (b_val - 1) * 2015 - (b_val - 1) * (b_val - 2) / 2 := by
    intro k hk
    let sum_D := ∑ d ∈ D k, (d : ℤ)
    constructor
    · have := h_card_D k hk; have := h_1_mem_D k hk; sorry
    · have := h_card_D k hk; have := h_1_mem_D k hk; sorry
  have : abs ((∑ d ∈ D n, (d : ℤ)) - (∑ d ∈ D m, (d : ℤ))) ≤ (b_val - 1) * (2015 - b_val) := sorry
  apply this.trans; rw [← Nat.cast_mul, ← Nat.cast_pow]; apply Nat.cast_le.mpr
  let x := b_val - 1; have : x * (2014 - x) ≤ 1007^2 := by
    have : (x : ℤ) * (2014 - x) = 1007^2 - ((x : ℤ) - 1007)^2 := by ring
    nlinarith [sq_nonneg ((x : ℤ) - 1007)]
  convert this using 2; omega
