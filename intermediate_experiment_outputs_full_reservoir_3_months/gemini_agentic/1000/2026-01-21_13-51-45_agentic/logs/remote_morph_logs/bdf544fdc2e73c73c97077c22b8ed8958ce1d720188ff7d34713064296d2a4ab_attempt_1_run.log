  have f_inj : Function.Injective f := by
    intro j k h
    rcases lt_trichotomy j k with h' | rfl | h'
    · exact (hii k j ⟨Nat.one_le j, h'⟩ h.symm).elim
    · rfl
    · exact (hii j k ⟨Nat.one_le k, h'⟩ h).elim
  let gaps (n : ℕ) : Finset ℤ := (Finset.range (n + 1)).filter (fun g => g ≥ 1 ∧ ∀ j, f j ≠ g)
  let c (n : ℕ) : ℕ := (gaps n).card
  have c_mono : Monotone c := fun n m hnm => Finset.card_le_card (Finset.filter_subset_filter _ (Finset.range_mono (Nat.succ_le_succ hnm)))
  have c_le : ∀ n, c n ≤ 2015 := by
    intro n
    let Kn := (Finset.Icc 1 n).filter (fun j => f j ≤ n)
    have : c n + Kn.card = n := by
      let S := (Finset.Icc 1 n).map ⟨(fun k => (k : ℤ)), Int.coe_nat_inj⟩
      have h1 : gaps n ∪ Kn.map ⟨f, f_inj⟩ = S := by
        ext g; simp [gaps, Kn, S]; constructor
        · rintro (⟨⟨hg, hg1⟩, hf⟩ | ⟨j, ⟨hj1, hjf⟩, rfl⟩)
          · exact ⟨hg, hg1⟩
          · constructor
            · exact (Int.le_trans (by linarith [(hi j).1]) hjf)
            · exact hjf
        · rintro ⟨hg1, hgn⟩
          by_cases h : ∃ j, f j = g
          · obtain ⟨j, rfl⟩ := h; right; use j; simp; constructor
            · linarith [hi j]
            · exact hgn
          · left; simp [h, hg1, hgn]
      have h2 : Disjoint (gaps n) (Kn.map ⟨f, f_inj⟩) := by
        simp [Disjoint, gaps]; intro g; simp; rintro _ ⟨j, _, rfl⟩; contradiction
      have h3 := Finset.card_union_of_disjoint h2
      rw [h1, Finset.card_map, Finset.card_map, Finset.card_Icc, Nat.add_sub_cancel] at h3
      exact h3
    have hKn : Kn.card ≥ n.satSub 2015 := by
      have : Finset.Icc 1 (n.satSub 2015) ⊆ Kn := by
        intro j hj; simp at hj ⊢; constructor; · linarith; · linarith [hi j]
      exact (Finset.card_le_card this).trans_eq' (by simp)
    linarith [Nat.satSub_le_self n 2015]
  obtain ⟨b_val, N_val, hN⟩ : ∃ b N, ∀ n ≥ N, c n = b := by
    let b_max := (Finset.range 2016).filter (fun b => ∃ n, c n = b) |>.max.getD 0
    obtain ⟨N0, hN0⟩ := (Finset.range 2016).filter (fun b => ∃ n, c n = b) |>.mem_max_getD 0
    have : ∃ n, c n = b_max := by simpa using hN0
    obtain ⟨N, hN⟩ := this; use b_max, N; intro n hn; exact (c_le n).eq_of_ge (c_mono hn) |>.symm.trans (hN ▸ c_le N)
  have hb_pos : b_val ≥ 1 := by
    have : gaps N_val |>.Nonempty := ⟨1, by simp [gaps]; linarith [hi 1]⟩
    rw [← hN N_val (le_refl _), c]; exact Finset.card_pos.mpr this
  let b : ℕ+ := ⟨b_val, hb_pos⟩
  let N : ℕ+ := ⟨N_val + 2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S (k : ℕ) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  let G := gaps (N_val + 2016)
