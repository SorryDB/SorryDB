import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k h
    rcases lt_trichotomy j k with h' | rfl | h'
    · exfalso; exact hii k j ⟨k.2, h'⟩ h.symm
    · rfl
    · exfalso; exact hii j k ⟨j.2, h'⟩ h
  let G := {g : ℤ | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have G_bound : ∀ g ∈ G, g ≤ 2015 := by
    intro g ⟨hg1, hg_not⟩
    by_contra hg_large; push_neg at hg_large
    let S := Finset.Icc 1 (g - 1)
    have : ∀ j ∈ S, f (⟨j, by omega⟩ : ℕ+) ≤ g := fun j hj => by
      have hj' : j ≤ g - 1 := (Finset.mem_Icc.1 hj).2
      dsimp [f]; linarith [hi ⟨j, by omega⟩, hj']
    have : S.image (λ j => f (⟨j, by omega⟩ : ℕ+)) ⊆ Finset.Icc 2 g := by
      intro y hy; simp at hy; obtain ⟨j, hj, rfl⟩ := hy
      constructor; · dsimp [f]; linarith [hi ⟨j, by omega⟩]
      · exact this j hj
    have h_card : (S.image (λ j => f (⟨j, by omega⟩ : ℕ+))).card = g - 1 := by
      rw [Finset.card_image_of_injective]; · simp; · intro j k hjk; apply PNat.ext; exact f_inj hjk
    have h_not_in : g ∉ S.image (λ j => f (⟨j, by omega⟩ : ℕ+)) := by
      simp; intro j hj; exact hg_not ⟨j, by omega⟩
    have : (S.image (λ j => f (⟨j, by omega⟩ : ℕ+))) ⊆ Finset.Icc 2 (g - 1) := by
      intro y hy; have := this hy; simp at this ⊢
      constructor; · exact this.1
      · have : y ≠ g := by intro h; rw [h] at hy; contradiction
        omega
    have : (g - 1) ≤ (g - 2) := by
      have h1 := Finset.card_le_card this
      rwa [h_card, Finset.card_Icc] at h1; simp; omega
    omega
  let b_set := (Finset.range 2016).filter (λ g => 1 ≤ g ∧ ∀ j, f j ≠ g)
  let b_val := b_set.card
  have hb_pos : 1 ≤ b_val := by
    have : 1 ∈ b_set := by simp [b_set]; intro j; dsimp [f]; linarith [hi j]
    exact Finset.one_le_card.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, hb_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S_sum n - S_sum m := by
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc]
    · simp; ring
    · exact PNat.one_le m
    · exact hmn
  have E_val (k : ℕ+) (hk : N ≤ k) : ∃ E_k : ℤ, S_sum k = E_k + (b_val * (b_val + 1) / 2 - ∑ g ∈ b_set, g) ∧ 0 ≤ E_k ∧ E_k ≤ 1007 ^ 2 := by
    let Vk := (Finset.Icc 1 k).filter (λ j => f j > k + b_val)
    let Uk := {j : ℕ+ | j > k ∧ f j ≤ k + b_val}
    have hU_fin : {j : ℕ+ | j > k ∧ f j ≤ k + b_val}.Finite := by
      apply Set.Finite.subset (Set.finite_Icc (k + 1) (k + 2016))
      intro j hj; simp at hj; constructor; · linarith
      · dsimp [f] at hj; linarith [hi j, hj.2]
    let Uk_fin := hU_fin.toFinset
    let Ek := (∑ j ∈ Vk, (f j - (k + b_val))) + (∑ j ∈ Uk_fin, (k + b_val - f j))
    use Ek; constructor
    · sorry
    · constructor
      · apply add_nonneg <;> apply Finset.sum_nonneg <;> intro j hj <;> dsimp <;> simp at hj <;> omega
      · have h_kn : Vk.card = Uk_fin.card := sorry
        have : Ek ≤ Vk.card * (2014 - Vk.card) := sorry
        have h_kn_bound : Vk.card ≤ 1007 ∨ Vk.card > 1007 := em _
        cases h_kn_bound <;> nlinarith
  obtain ⟨En, hEn_val, hEn_bound⟩ := E_val n (hNm.trans_lt hmn |>.le)
  obtain ⟨Em, hEm_val, hEm_bound⟩ := E_val m hNm
  rw [hS_diff, hEn_val, hEm_val]; simp; ring_nf
  have : abs (En - Em) ≤ 1007 ^ 2 := by
    rw [abs_le]; constructor <;> linarith [hEn_bound.1, hEn_bound.2, hEm_bound.1, hEm_bound.2]
  exact this

