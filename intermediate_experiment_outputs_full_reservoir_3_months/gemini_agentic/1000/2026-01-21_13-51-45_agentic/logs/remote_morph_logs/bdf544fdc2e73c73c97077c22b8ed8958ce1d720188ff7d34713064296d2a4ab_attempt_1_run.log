    have hfS_le : ∀ x ∈ fS, x ≤ g.toNat + 2015 := by
      intro x hx; rcases Finset.mem_image.1 hx with ⟨j, hj, rfl⟩
      simp at hj; have := hi ⟨j, ⋯⟩; linarith
    sorry
  have G_finite : G.Finite := (Set.finite_Icc 1 2015).subset (λ g hg => ⟨hg.1, hG_bound g hg⟩)
  let b_val := G_finite.toFinset.card
  have b_pos : 0 < b_val := by
    have h1 : (1 : ℤ) ∈ G := ⟨le_refl 1, λ j => by have := hi j; linarith [PNat.one_le j]⟩
    exact Finset.card_pos.mpr ⟨1, G_finite.toFinset.mem_toFinset.mpr h1⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨2016, by norm_num⟩
  use b, N
  intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - (b : ℤ))
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - (b : ℤ)) = S_sum n - S_sum m := by
    have h1m : 1 ≤ m := PNat.one_le m
    have hmn_le : m ≤ n := hmn.le
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc h1m hmn_le]
    simp; ring
  let C : ℤ := b_val * (b_val + 1) / 2 - ∑ g ∈ G_finite.toFinset, g
  let D (k : ℕ+) : ℤ := S_sum k - C
  have hD_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ D k ∧ D k ≤ 1007 ^ 2 := sorry
  rcases hD_bound n (hNm.trans hmn.le) with ⟨Dn_ge, Dn_le⟩
  rcases hD_bound m hNm with ⟨Dm_ge, Dm_le⟩
  rw [hS_diff, (show S_sum n = D n + C by linarith), (show S_sum m = D m + C by linarith)]
  simp; rw [abs_le]; constructor <;> linarith
