import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k h
    rcases lt_trichotomy j k with h' | rfl | h'
    · exfalso; exact hii k j ⟨PNat.one_le j, h'⟩ h.symm
    · rfl
    · exfalso; exact hii j k ⟨PNat.one_le k, h'⟩ h
  let gaps : Set ℤ := {g | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have gaps_bound : ∀ g ∈ gaps, g ≤ 2015 := by
    intro g ⟨hg1, hg_not⟩
    by_contra hg_large; push_neg at hg_large
    let S := Finset.Icc (1 : ℕ) (g.toNat - 1)
    have h_card_S : S.card = g.toNat - 1 := by simp [gaps_bound, hg1]
    let fS := S.attach.image (λ j => (f ⟨j.1, by have := j.2; simp at this; exact (Nat.pos_of_ge_rv (by omega))⟩))
    have hfS_sub : fS ⊆ (Finset.Icc 2 (g - 1)).image (λ x => x) := by
      intro y hy; simp at hy; obtain ⟨j, hj, rfl⟩ := hy
      simp at hj; have hjpos : 0 < j := by omega
      have : f ⟨j, hjpos⟩ ≤ j + 2015 := by dsimp [f]; linarith [hi ⟨j, hjpos⟩]
      have : f ⟨j, hjpos⟩ ≥ j + 1 := by dsimp [f]; linarith [hi ⟨j, hjpos⟩]
      simp; constructor; · linarith; · linarith
    have h_card_fS : fS.card = g.toNat - 1 := by
      rw [Finset.card_image_of_injective]; · exact h_card_S
      · intro j k hjk; apply PNat.ext; apply f_inj; exact hjk
    have : fS.card ≤ (g - 2).toNat := by
      have := Finset.card_le_card hfS_sub
      rwa [h_card_fS] at this; simp at this; apply this
    omega
  let G_fin := gaps.toFinset
  let b_val := G_fin.card
  have hb_pos : 1 ≤ b_val := by
    have : (1 : ℤ) ∈ G_fin := by
      simp [G_fin, gaps]; intro j; dsimp [f]; linarith [hi j, (j : ℕ).pos]
    exact Finset.one_le_card.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, hb_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let S_sum (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  have hS_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S_sum n - S_sum m := by
    rw [S_sum, S_sum, ← Finset.sum_Icc_union_Icc]
    · simp; ring
    · exact PNat.one_le m
    · exact hmn
  let Vk (k : ℕ+) := (Finset.Icc 1 k).filter (λ j => f j > k + b_val)
  let Uk (k : ℕ+) := (Finset.Icc (k + 1) (k + 2016)).filter (λ j => f j ≤ k + b_val)
  let Ek (k : ℕ+) := (∑ j ∈ Vk k, (f j - (k + b_val))) + (∑ j ∈ Uk k, (k + b_val - f j))
  have hE_bound (k : ℕ+) (hk : N ≤ k) : 0 ≤ Ek k ∧ Ek k ≤ 1007 ^ 2 := by
    have h_card : (Vk k).card = (Uk k).card := sorry
    have h_Ek_max : Ek k ≤ (Vk k).card * (2014 - (Vk k).card) := sorry
    constructor
    · apply add_nonneg <;> apply Finset.sum_nonneg <;> intro j hj <;> simp at hj <;> linarith
    · have hx := (Vk k).card; have : hx * (2014 - hx) ≤ 1007 ^ 2 := by nlinarith
      exact h_Ek_max.trans this
  have hS_val (k : ℕ+) (hk : N ≤ k) : S_sum k = Ek k + (b_val * (b_val + 1) / 2 - ∑ g ∈ G_fin, g) := sorry
  rw [hS_diff, hS_val n (hNm.trans_lt hmn |>.le), hS_val m hNm]; simp; ring_nf
  have := hE_bound n (hNm.trans_lt hmn |>.le); have := hE_bound m hNm
  rw [abs_le]; constructor <;> linarith
