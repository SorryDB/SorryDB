import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  classical
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with h | rfl | h
    · exact (hii k j ⟨PNat.one_le j, h⟩ (by rw [f, f]; linarith)).elim
    · rfl
    · exact (hii j k ⟨PNat.one_le k, h⟩ (by rw [f, f]; linarith)).elim
  let G := {g : ℤ | 1 ≤ g ∧ ∀ j, f j ≠ g}
  have hG_bound : ∀ g ∈ G, g ≤ 2015 := by
    intro g ⟨hg1, hg_not_im⟩
    by_contra hgt
    push_neg at hgt
    let M := (g : ℕ)
    let SM := (Finset.Icc 1 M).filter (λ j => f ⟨j, PNat.one_le _⟩ ≤ g)
    have hSM_card : SM.card = g - 1 := sorry
    sorry
  have G_finite : G.Finite := (Set.finite_Icc 1 2015).subset (λ g hg => ⟨hg.1, hG_bound g hg⟩)
  let b_val := G_finite.toFinset.card
  have b_pos : 0 < b_val := by
    have h1 : (1 : ℤ) ∈ G := ⟨le_refl 1, λ j => by have := hi j; linarith [PNat.one_le j]⟩
    exact Finset.card_pos.mpr ⟨1, G_finite.toFinset.mem_toFinset.mpr h1⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨2016, by norm_num⟩
  use b, N
  intro m n ⟨hmn, hNm⟩
  let S (k : ℕ+) : ℤ := ∑ j in Finset.Icc 1 k, (a j - (b : ℤ))
  have h_diff : ∑ j in Finset.Icc (m + 1) n, (a j - b) = S n - S m := by
    rw [S, S, ← Finset.sum_Icc_union_Icc (PNat.one_le m) hmn.le]
    simp; ring
  let R (k : ℕ+) : ℤ := (∑ j in Finset.Icc 1 k, f j) - (∑ i in Finset.Icc 1 (k + b_val), i) + (∑ g in G_finite.toFinset, g)
  have hRS : ∀ k, S k = R k + (b_val * (b_val + 1) / 2 - ∑ g in G_finite.toFinset, g) := sorry
  have hR_val (k : ℕ+) (hk : N ≤ k) : 0 ≤ R k ∧ R k ≤ 1007 ^ 2 := by
    let Uk := (Finset.Icc 1 k).filter (λ j => f j > k + b_val)
    let Wk := (Finset.Icc (k + 1) (k + 2015)).filter (λ j => f j ≤ k + b_val ∧ ∃ j', f j' = f j ∧ j' > k)
    sorry
  rw [h_diff, hRS n, hRS m]; simp
  have hRn := hR_val n (hNm.trans hmn.le)
  have hRm := hR_val m hNm
  rw [abs_le]; constructor <;> linarith [hRn.1, hRn.2, hRm.1, hRm.2]

