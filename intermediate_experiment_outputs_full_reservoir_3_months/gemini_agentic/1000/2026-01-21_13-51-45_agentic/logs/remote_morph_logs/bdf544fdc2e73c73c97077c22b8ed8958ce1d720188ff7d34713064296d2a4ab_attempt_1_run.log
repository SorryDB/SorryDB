import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro k l h; rcases lt_trichotomy k l with hkl | hkl | hkl
    · exact (hii l k ⟨Nat.one_le k, hkl⟩ h.symm).elim
    · exact hkl
    · exact (hii k l ⟨Nat.one_le l, hkl⟩ h).elim
  let gap (k : ℕ) : Prop := ∀ j : ℕ+, f j ≠ k + 1
  have gap_dec (k : ℕ) : Decidable (gap k) :=
    decidable_of_iff (∀ j ∈ Finset.Icc 1 (PNat.mk (k + 1) (Nat.succ_pos k)), f j ≠ k + 1) (by
      constructor
      · intro h j hj; by_cases hj' : (j : ℕ) ≤ k + 1
        · exact h j (Finset.mem_Icc.mpr ⟨Nat.one_le j, hj'⟩)
        · have : f j ≥ (j : ℤ) + 1 := by linarith [(hi j).1]
          have : (j : ℤ) > k + 1 := by exact_mod_cast Nat.lt_of_not_ge hj'
          linarith
      · intro h j hj; exact h j)
  let c (n : ℕ) : ℕ := (Finset.range n).filter gap |>.card
  have c_mono : Monotone c := fun n m hnm => Finset.card_le_card (Finset.filter_subset_filter _ (Finset.range_mono hnm))
  have c_le : ∀ n, c n ≤ 2015 := by
    intro n; let Sn := (Finset.range n).filter (fun k => ∃ j, f j = k + 1)
    have : c n + Sn.card = n := by
      rw [← Finset.card_union_eq, Finset.filter_union_filter_neg_eq]
      · exact Finset.card_range n
      · exact Finset.disjoint_filter_filter_neg _ _ _
    have hSn : (n.satSub 2015) ≤ Sn.card := by
      let s := n.satSub 2015
      have : Finset.range s ⊆ Sn.image (fun k => (k : ℤ) + 1) := sorry
      sorry
    linarith [c_mono (Nat.le_refl n)]
  obtain ⟨b_val, N_val, hN⟩ : ∃ b N, ∀ n ≥ N, c n = b := by
    have : ∃ N, ∀ n ≥ N, c n = c N := ⟨2016, fun n hn => (c_le n).eq_of_ge (c_mono hn) |>.symm.trans (c_le 2016).eq_of_ge (c_mono (by linarith))⟩
    obtain ⟨N, hN⟩ := this; exact ⟨c N, N, hN⟩
  have hb : 1 ≤ b_val := by
    have : gap 0 := fun j hj => by have : f j ≥ 2 := by linarith [(hi j).1]; linarith
    have : 0 ∈ (Finset.range (N_val + 1)).filter gap := by simp [this]; linarith
    have : 1 ≤ (Finset.range (N_val + 1)).filter gap |>.card := Finset.card_pos.mpr ⟨0, this⟩
    rw [hN (N_val + 1) (Nat.le_succ _)] at this; exact this
  let b : ℕ+ := ⟨b_val, Nat.pos_of_pcN hb⟩
  let N : ℕ+ := ⟨N_val + 1, Nat.succ_pos _⟩
