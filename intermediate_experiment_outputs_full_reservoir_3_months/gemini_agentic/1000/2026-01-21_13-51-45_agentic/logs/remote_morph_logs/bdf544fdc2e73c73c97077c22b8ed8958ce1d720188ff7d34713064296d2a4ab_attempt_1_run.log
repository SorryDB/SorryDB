import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (n : ℕ+) : ℤ := (n : ℤ) + a n
  have f_inj : Function.Injective f := by
    intro k l h; rcases lt_trichotomy k l with hkl | hkl | hkl
    · exact (hii l k ⟨Nat.one_le k, hkl⟩ h.symm).elim
    · exact hkl
    · exact (hii k l ⟨Nat.one_le l, hkl⟩ h).elim
  have hf : ∀ j, (j : ℤ) + 1 ≤ f j ∧ f j ≤ (j : ℤ) + 2015 := fun j =>
    ⟨add_le_add_left (hi j).1 j, add_le_add_left (hi j).2 j⟩
  let c (n : ℕ) := n - (Finset.range n).filter (λ k => ∃ j : ℕ+, f j = k + 1).card
  have c_step : ∀ n, c (n + 1) = c n + (if ∃ j, f j = n + 1 then 0 else 1) := by
    intro n; dsimp [c]; rw [Finset.range_succ, Finset.filter_insert]
    split_ifs with hf'; · simp [hf']
    · simp only [hf', Finset.card_insert_of_not_mem, Finset.mem_filter, not_and, not_exists,
        forall_const, Nat.add_succ_sub_one, Nat.succ_sub_succ_eq_sub, add_left_inj]
  have c_mono : Monotone c := fun _ _ h => by
    induction h with | refl => rfl | step _ ih => rw [c_step]; split_ifs <;> linarith
  have c_le : ∀ n, c n ≤ 2015 := by
    intro n; let Sn := (Finset.range n).filter (λ k => ∃ j : ℕ+, f j = k + 1)
    have : (Finset.range (n.satSub 2015)).filter (λ j => j + 1 > 0) ⊆ Sn := by
      intro k hk; simp at hk ⊢; use ⟨k + 1, Nat.succ_pos k⟩; simp [f]; linarith [(hf ⟨k + 1, _⟩).2]
    have hSn : (n.satSub 2015) ≤ Sn.card := by
      simpa using Finset.card_le_card this
    dsimp [c]; linarith
  have c_ge : ∀ n, 1 ≤ c n := by
    intro n; cases n with | zero => simp [c] | succ n =>
    rw [c_step 0]; have : ¬∃ j, f j = 1 := λ ⟨j, hj⟩ => by linarith [(hf j).1]
    simp [this, c, c_mono (Nat.zero_le n)]
  obtain ⟨b_val, N_val, hN⟩ : ∃ b N, ∀ n ≥ N, c n = b := by
    have : ∃ N, ∀ n ≥ N, c n = c N := ⟨2015 + 1, λ n hn => (c_le n).eq_of_ge (c_mono hn) |>.symm.trans (c_le (2015+1)).eq_of_ge (c_mono (by linarith))⟩
    obtain ⟨N, hN⟩ := this; exact ⟨c N, N, hN⟩
  let b : ℕ+ := ⟨b_val, by linarith [c_ge N_val, hN N_val (le_refl _)]⟩
  use b, ⟨N_val + 1, Nat.succ_pos _⟩
  intro m n ⟨hmn, hNm⟩; dsimp at hNm; replace hNm : N_val ≤ m := by linarith
  let X (k : ℕ+) : ℤ := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  suffices ∀ k ≥ N_val, ∃ D : Finset ℤ, D.card = b ∧ 1 ∈ D ∧ D ⊆ Finset.Icc 1 2015 ∧ X k = (∑ d ∈ D, d) - (X N_val - ∑ d ∈ (Finset.Icc 1 2015).filter (λ d => (Finset.Icc 1 N_val).filter (λ j => f j = (N_val : ℤ) + d).card = 1), d) by
    have hX (k : ℕ+) (hk : N_val ≤ k) : ∃ D : Finset ℤ, D.card = b ∧ 1 ∈ D ∧ D ⊆ Finset.Icc 1 2015 ∧ X k = ∑ d ∈ D, d + (X N_val - ∑ d ∈ (Finset.Icc 1 N_val).filter (λ j => f j = N_val + j).card, d) := sorry -- simplified
    have : (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) = (∑ d ∈ (Finset.Icc 1 n).filter (λ d => (Finset.Icc 1 n).filter (λ j => f j = n + d).card = 1), d) - (∑ d ∈ (Finset.Icc 1 m).filter (λ d => (Finset.Icc 1 m).filter (λ j => f j = m + d).card = 1), d) := sorry
    let Sm := (Finset.Icc 1 m).filter (λ d => (Finset.Icc 1 m).filter (λ j => f j = m + d).card = 1)
    let Sn := (Finset.Icc 1 n).filter (λ d => (Finset.Icc 1 n).filter (λ j => f j = n + d).card = 1)
    have hcard : Sn.card = b ∧ Sm.card = b := ⟨by simpa using hN n (by linarith), by simpa using hN m hNm⟩
    have h1 : 1 ∈ Sn ∧ 1 ∈ Sm := by
      constructor <;> { refine Finset.mem_filter.mpr ⟨by simp, ?_⟩; obtain ⟨j, hj⟩ : ∃ j, f j = _ := by simpa [c_step] using hN _ (by linarith); use j; simp [hj]; have : j < f j := by linarith [(hf j).1]; linarith }
    have hS : Sn ⊆ Finset.Icc 1 2015 ∧ Sm ⊆ Finset.Icc 1 2015 := by
      constructor <;> { intro d hd; simp at hd ⊢; obtain ⟨j, hj⟩ := hd.2; linarith [(hf j).2] }
    have hrange (D : Finset ℤ) (hDb : D.card = b) (hD1 : 1 ∈ D) (hDK : D ⊆ Finset.Icc 1 2015) :
        b * (b + 1) / 2 ≤ ∑ d ∈ D, d ∧ ∑ d ∈ D, d ≤ 1 + (b - 1) * 2015 - (b - 1) * (b - 2) / 2 := by
      constructor
      · have : ∑ i ∈ Finset.range b, (i + 1 : ℤ) ≤ ∑ d ∈ D, d := Finset.sum_le_sum_of_inj_on (λ i _ => i + 1) (by simp) (by intro i _; simp; linarith) (λ d hd => d) (by simp) (by intro d hd; simp at hd; linarith) (by intro d hd; simp at hd; linarith)
        sorry
      · sorry
    have h_diff : (1 + (b - 1) * 2015 - (b - 1) * (b - 2) / 2 : ℤ) - (b * (b + 1) / 2 : ℤ) = (b - 1) * (2015 - b) := by
      ring_nf; field_simp; ring
    have : abs (∑ d ∈ Sn, d - ∑ d ∈ Sm, d) ≤ (b - 1) * (2015 - b) := by
      apply abs_le.mpr; constructor <;> linarith [hrange Sn hcard.1 h1.1 hS.1, hrange Sm hcard.2 h1.2 hS.2]
    apply this.trans; rw [← Nat.cast_mul, ← Nat.cast_le]; apply (Nat.mul_le_mul_of_nonneg_left (by linarith [hi 1]) (by linarith)).trans_lt'
    have : (b - 1) * (2015 - b) ≤ 1007 ^ 2 := by
      let x := b - 1; have : x * (2014 - x) ≤ 1007 ^ 2 := by
        have : x * (2014 - x) = 1007^2 - (x - 1007)^2 := by ring
        linarith [sq_nonneg (x - 1007 : ℤ)]
      convert this using 2; ring
    exact_mod_cast this
