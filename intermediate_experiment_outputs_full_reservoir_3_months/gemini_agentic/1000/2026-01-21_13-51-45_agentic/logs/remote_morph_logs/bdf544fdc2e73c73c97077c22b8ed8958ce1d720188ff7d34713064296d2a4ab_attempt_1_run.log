  have hSn (k : ℕ) (hk : k ≥ N_val) : S k = (∑ j ∈ (Finset.Icc 1 k).filter (fun j => f j > k + b), (f j - (k + b))) + (∑ j ∈ (Finset.Icc (k + 1) (k + b)).filter (fun j => f j ≤ k + b ∧ j ∉ G.map ⟨(fun x => x.toNat), by intro x y; simp⟩), ((k + b) - f j)) + (b * (b + 1) / 2 - ∑ g ∈ G, g) := sorry
  let m_val (k : ℕ) := ((Finset.Icc 1 k).filter (fun j => f j > k + b)).card
  have hm_bound (k : ℕ) (hk : k ≥ N_val) : m_val k * (2014 - m_val k) ≤ 1007 ^ 2 := by
    have : m_val k ≤ 1007 ∨ m_val k > 1007 := em _; cases this
    · nlinarith; · have : m_val k ≤ 2014 := sorry; nlinarith
  sorry
