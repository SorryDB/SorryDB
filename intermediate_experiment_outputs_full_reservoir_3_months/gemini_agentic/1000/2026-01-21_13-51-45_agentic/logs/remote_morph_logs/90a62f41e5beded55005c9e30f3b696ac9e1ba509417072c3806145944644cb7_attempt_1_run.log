namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · intro h
    rw [solution] at h
    obtain ⟨rfl, rfl⟩ := h
    refine Set.Infinite.mono ?_ (Set.infinite_atTop_nat.image (fun (a : ℕ) ↦ (a + 2 : ℤ)))
    · rintro _ ⟨a, -, rfl⟩
      refine ⟨by dsimp; linarith, ?_⟩
      use ((a + 2 : ℤ) ^ 2 - (a + 2) + 1)
      ring
    · intro a b h; simp at h; exact h
  · intro h
    -- For infinitely many a, the polynomial x^n + x^2 - 1 must divide x^m + x - 1.
    -- Let α be the unique root of x^n + x^2 - 1 in (0, 1).
    -- Then α^n + α^2 - 1 = 0 and α^m + α - 1 = 0.
    -- α^n = 1 - α^2 = (1 - α)(1 + α) = α^m(1 + α).
    -- So 1 + α = α^(n-m), implying n < m.
    -- Let k = m - n. Then 1 + α = α^(-k), so α^k + α^(k+1) = 1.
    -- Comparing x^n + x^2 - 1 and x^(k+1) + x^k - 1, we must have (n, 2) = (k+1, k).
    -- This implies k = 2 and n = 3, so m = n + k = 5.
    simp [solution]
    by_contra! h_mn
    have h_poly : (X ^ n + X ^ 2 - 1 : ℚ[X]) ∣ (X ^ m + X - 1 : ℚ[X]) := by
      refine poly_div_of_infinite_div ?_ h
      · exact (degree_X_pow_n_plus_X_2_minus_1_pos (by linarith)).ne'
    let α : ℂ := sorry -- Root of X^n + X^2 - 1 in (0, 1)
    have : α ^ n + α ^ 2 - 1 = 0 := sorry
    have : α ^ m + α - 1 = 0 := sorry
    have : (m, n) = (5, 3) := sorry
    exact h_mn this

end Imo2002P3
