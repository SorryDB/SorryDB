problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    refine Set.Infinite.mono ?_ (Set.infinite_atTop_nat.image (fun a ↦ (a + 1 : ℤ)))
    · rintro _ ⟨a, -, rfl⟩
      exact ⟨Int.pos_of_nat_succ a, ⟨(a + 1) ^ 2 - (a + 1) + 1, by ring⟩⟩
    · intro a b h; simp at h; assumption
  · intro h
    /- Any pair (m, n) with m, n ≥ 3 satisfying this condition must have xⁿ + x² - 1 | xᵐ + x - 1.
       By considering the unique positive root α of xⁿ + x² - 1, we find αᵐ = 1 - α,
       and substituting αⁿ = 1 - α², we get 1 + α = αⁿ⁻ᵐ. This implies m > n and,
       specifically, m = 5, n = 3 for m, n ≥ 3. -/
    sorry

end Imo2002P3
