import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let P (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨(k : ℕ), by omega⟩, ⟨4 * n - 1 - (k : ℕ), by omega⟩}
  have P_disj : ∀ k1 k2, k1 ≠ k2 → Disjoint (P k1) (P k2) := by
    intros k1 k2 hne
    apply Finset.disjoint_left.mpr
    intro x hx1 hx2
    simp [P] at hx1 hx2
    rcases hx1 with rfl | rfl <;> rcases hx2 with rfl | rfl <;> simp at *
    · exact hne (Fin.ext hx2)
    · omega
    · omega
    · exact hne (Fin.ext (by omega))
  have hsum (T : Finset (Fin (2 * n))) : ∑ i ∈ T.biUnion P, ((i : ℕ) + 1) = T.card * (4 * n + 1) := by
    rw [Finset.sum_biUnion P_disj]
    simp [P]
    intro k _
    rw [Finset.sum_pair (by intro h_eq; simp [Fin.ext_iff] at h_eq; omega)]
    simp; omega
  have univ_biUnion_P : (Finset.univ : Finset (Fin (2 * n))).biUnion P = Finset.univ := by
    ext x
    simp [P]
    by_cases hx : (x : ℕ) < 2 * n
    · use ⟨x, hx⟩; left; rfl
    · use ⟨4 * n - 1 - x, by omega⟩; right; simp; omega
  obtain ⟨S', hS'card, hS'⟩ : ∃ S' : Finset (Fin (2 * n)), S'.card = n ∧ ∀ i, (∑ k ∈ S', #((P k).filter (fun j => c j = i))) = 2 := by
    sorry -- Existence of a 2-factor in a 4-regular multigraph
  let S : Finset (Fin (4 * n)) := S'.biUnion P
  use S
  constructor
  · have hS_sum : ∑ i ∈ S, (↑i + 1) = n * (4 * n + 1) := by rw [hsum S', hS'card]
    have h_total_sum : ∑ i : Fin (4 * n), (↑i + 1) = 2 * n * (4 * n + 1) := by
      rw [← univ_biUnion_P, hsum Finset.univ, Finset.card_univ, Fintype.card_fin]
    rw [← add_left_inj (∑ i ∈ S, (↑i + 1)), Finset.sum_add_sum_compl, hS_sum, h_total_sum]
    omega
  · intro i
    rw [Finset.card_filter, Finset.filter_biUnion, Finset.card_biUnion]
    · exact hS' i
    · intros k1 _ k2 _ hne; apply Finset.disjoint_filter_filter (P_disj k1 k2 hne)

