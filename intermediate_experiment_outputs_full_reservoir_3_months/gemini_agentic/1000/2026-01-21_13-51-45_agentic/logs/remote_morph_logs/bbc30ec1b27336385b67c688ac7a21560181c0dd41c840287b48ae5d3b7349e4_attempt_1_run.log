import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  rcases n.eq_zero_or_pos with rfl | hn
  · use ∅; simp
  let P (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k.val, by omega⟩, ⟨4 * n - 1 - k.val, by omega⟩}
  have P_disj : ∀ k1 k2, k1 ≠ k2 → Disjoint (P k1) (P k2) := by
    intro k1 k2 hne
    rw [Finset.disjoint_left]
    intro x hx1 hx2
    simp [P, Fin.ext_iff] at hx1 hx2
    rcases hx1 with hx1 | hx1 <;> rcases hx2 with hx2 | hx2 <;> omega
  have hPsum (k : Fin (2 * n)) : ∑ i ∈ P k, ((i : ℕ) + 1) = 4 * n + 1 := by
    have hne : (⟨k.val, by omega⟩ : Fin (4 * n)) ≠ ⟨4 * n - 1 - k.val, by omega⟩ := by
      simp [Fin.ext_iff]; omega
    rw [Finset.sum_pair hne]
    simp; omega
  have hsum (T : Finset (Fin (2 * n))) : ∑ i ∈ T.biUnion P, ((i : ℕ) + 1) = T.card * (4 * n + 1) := by
    rw [Finset.sum_biUnion (λ k1 _ k2 _ hne => P_disj k1 k2 hne)]
    simp [hPsum]
  have univ_eq : (Finset.univ : Finset (Fin (2 * n))).biUnion P = Finset.univ := by
    ext x
    simp [P, Fin.ext_iff]
    by_cases hx : x.val < 2 * n
    · use ⟨x.val, hx⟩; left; rfl
    · have hx' : x.val < 4 * n := x.is_lt
      have : 4 * n - 1 - x.val < 2 * n := by omega
      use ⟨4 * n - 1 - x.val, this⟩; right; omega
  have h_exists : ∃ S' : Finset (Fin (2 * n)), S'.card = n ∧ ∀ i, #{j ∈ S'.biUnion P | c j = i} = 2 := by
    sorry
  let S' := Classical.choose h_exists
  let S := S'.biUnion P
  use S
  constructor
  · have h_sum_total : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [← univ_eq, hsum Finset.univ, Finset.card_univ, Fintype.card_fin]
    have h_sum_S : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [hsum S', (Classical.choose_spec h_exists).1]
    have : ∑ i ∈ S, ((i : ℕ) + 1) + ∑ i ∈ Sᶜ, ((i : ℕ) + 1) = ∑ i, ((i : ℕ) + 1) := Finset.sum_add_sum_compl S
    omega
  · exact (Classical.choose_spec h_exists).2
