import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let P (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩}
  have P_disj : ∀ k1 k2, k1 ≠ k2 → Disjoint (P k1) (P k2) := by
    intros k1 k2 hne
    rw [Finset.disjoint_left]
    intro x hx1 hx2
    simp [P] at hx1 hx2; omega
  obtain ⟨S', hS'card, hS'⟩ : ∃ S' : Finset (Fin (2 * n)), S'.card = n ∧ ∀ i, (∑ k ∈ S', #((P k).filter (fun j => c j = i))) = 2 := by
    sorry
  let S : Finset (Fin (4 * n)) := S'.biUnion P
  use S
  constructor
  · have hsum (T : Finset (Fin (2 * n))) : ∑ i ∈ T.biUnion P, ((i : ℕ) + 1) = T.card * (4 * n + 1) := by
      rw [Finset.sum_biUnion (fun k1 _ k2 _ => P_disj k1 k2)]
      simp [P]; intro k hk; omega
    have hS_sum : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by rw [hsum S', hS'card]
    have h_total_sum : ∑ i, ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [← hsum Finset.univ, Finset.card_univ, Fintype.card_fin]
    rw [← add_left_inj (∑ i ∈ S, ((i : ℕ) + 1)), Finset.sum_add_sum_compl, hS_sum, h_total_sum]
    omega
  · intro i
    rw [Finset.card_filter, Finset.filter_biUnion, Finset.card_biUnion]
    · exact hS' i
    · intros k1 _ k2 _ hne; apply Finset.disjoint_filter_filter (P_disj k1 k2 hne)

