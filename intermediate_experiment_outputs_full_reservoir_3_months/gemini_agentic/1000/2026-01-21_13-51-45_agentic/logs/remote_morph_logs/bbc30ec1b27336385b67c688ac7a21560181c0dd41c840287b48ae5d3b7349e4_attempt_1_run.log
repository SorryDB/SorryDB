import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  obtain rfl | hn : n = 0 ∨ 0 < n := Nat.eq_zero_or_pos n
  · use ∅; simp
  let P (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k.1, by omega⟩, ⟨4 * n - 1 - k.1, by omega⟩}
  have P_pair : ∀ k, (P k).card = 2 := by
    intro k; apply Finset.card_doubleton; intro h_eq; simp [Fin.ext_iff] at h_eq; omega
  have P_disj : (Finset.univ : Finset (Fin (2 * n))).PairwiseDisjoint P := by
    intro k1 _ k2 _ hne; simp [P, Finset.disjoint_left, Fin.ext_iff]
    intro x; rintro (rfl | rfl) <;> rintro (rfl | rfl) <;> omega
  have univ_eq : (Finset.univ : Finset (Fin (2 * n))).biUnion P = Finset.univ := by
    ext x; simp [P]; by_cases hx : x.1 < 2 * n
    · use ⟨x.1, hx⟩; left; rfl
    · use ⟨4 * n - 1 - x.1, by omega⟩; right; simp; omega
  obtain ⟨S', hS'card, hS'sum⟩ : ∃ S' : Finset (Fin (2 * n)), S'.card = n ∧
      ∀ i, (∑ k ∈ S', #((P k).filter (fun j => c j = i))) = 2 := by
    sorry
  let S := S'.biUnion P
  use S; constructor
  · have h_sum_total : ∑ i, ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [← univ_eq, Finset.sum_biUnion P_disj]
      simp only [P]
      rw [Finset.sum_congr rfl (fun k _ => Finset.sum_pair (by simp [Fin.ext_iff]; omega))]
      simp only [Finset.card_univ, Finset.sum_const, Fintype.card_fin, Nat.cast_id]
      intro k _; simp; omega
    have h_sum_S : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion (P_disj.subset (Finset.subset_univ S'))]
      simp only [P]
      rw [Finset.sum_congr rfl (fun k _ => Finset.sum_pair (by simp [Fin.ext_iff]; omega))]
      simp only [hS'card, Finset.sum_const, Nat.cast_id]
      intro k _; simp; omega
    rw [h_sum_S, ← add_left_inj (∑ i ∈ S, ((i : ℕ) + 1)), Finset.sum_add_sum_compl, h_sum_total, h_sum_S]
    omega
  · intro i
    rw [Finset.filter_biUnion, Finset.card_biUnion, hS'sum]
    · intro k1 _ k2 _ hne; apply Finset.disjoint_filter_filter (P_disj (Finset.mem_univ _) (Finset.mem_univ _) hne)

