theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, {j | c j = i}.card = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, {j ∈ S | c j = i}.card = 2 := by
  obtain rfl | hn : n = 0 ∨ 0 < n := Nat.eq_zero_or_pos n
  · use ∅; simp
  let P (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k.1, by omega⟩, ⟨4 * n - 1 - k.1, by omega⟩}
  have P_disj : ∀ k1 ∈ Finset.univ, ∀ k2 ∈ Finset.univ, k1 ≠ k2 → Disjoint (P k1) (P k2) := by
    intro k1 _ k2 _ hne; simp [P, Finset.disjoint_left, Fin.ext_iff]; intro x; rintro (rfl | rfl) <;> rintro (rfl | rfl) <;> omega
  have hsum (T : Finset (Fin (2 * n))) : ∑ i ∈ T.biUnion P, (↑i + 1) = T.card * (4 * n + 1) := by
    rw [Finset.sum_biUnion (λ k1 hk1 k2 hk2 hne => P_disj k1 (Finset.mem_univ _) k2 (Finset.mem_univ _) hne)]
    · simp [P, Finset.sum_pair, Fin.ext_iff]
      intro k _; have : k.1 ≠ 4 * n - 1 - k.1 := by omega
      simp [this]; omega
  have univ_eq : (Finset.univ : Finset (Fin (2 * n))).biUnion P = Finset.univ := by
    ext x; simp [P, Fin.ext_iff]; by_cases hx : x.1 < 2 * n
    · use ⟨x.1, hx⟩; left; rfl
    · use ⟨4 * n - 1 - x.1, by omega⟩; right; omega
  obtain ⟨S', hS'card, hS'sum⟩ : ∃ S' : Finset (Fin (2 * n)), S'.card = n ∧ ∀ i, ∑ k ∈ S', {j ∈ P k | c j = i}.card = 2 := by
    sorry -- Existence of a 2-factor in a 4-regular multigraph
  let S := S'.biUnion P
  use S; constructor
  · have h_sum_S : ∑ i ∈ S, (↑i + 1) = n * (4 * n + 1) := by rw [hsum S', hS'card]
    have h_sum_total : ∑ i : Fin (4 * n), (↑i + 1) = 2 * n * (4 * n + 1) := by
      rw [← univ_eq, hsum Finset.univ, Finset.card_univ, Fintype.card_fin]
    rw [h_sum_S, ← add_left_inj (∑ i ∈ S, (↑i + 1)), Finset.sum_add_sum_compl, h_sum_total, h_sum_S]
    omega
  · intro i
    rw [Finset.card_filter, Finset.filter_biUnion, Finset.card_biUnion, hS'sum]
    · intro k1 _ k2 _ hne; apply Finset.disjoint_filter_filter (P_disj k1 (Finset.mem_univ _) k2 (Finset.mem_univ _) hne)

