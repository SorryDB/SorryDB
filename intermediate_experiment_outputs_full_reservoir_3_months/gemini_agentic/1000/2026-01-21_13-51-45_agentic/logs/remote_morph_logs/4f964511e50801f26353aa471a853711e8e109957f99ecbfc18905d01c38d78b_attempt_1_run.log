lemma solidSphere_centerOfMass {d : ℕ} (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere d.succ m R).centerOfMass = 0 := by
  ext i
  simp only [centerOfMass, solidSphere, mass, Pi.zero_apply, ContinuousLinearMap.coe_mk,
    LinearMap.coe_mk, AddHom.coe_mk, ContMDiffMap.coeFn_mk, smul_eq_mul]
