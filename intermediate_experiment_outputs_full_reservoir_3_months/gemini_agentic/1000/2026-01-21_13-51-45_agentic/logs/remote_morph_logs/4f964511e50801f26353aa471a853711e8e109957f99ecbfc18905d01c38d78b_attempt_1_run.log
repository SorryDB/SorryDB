/-- The center of mass of a solid sphere located at the origin is `0`. -/
lemma solidSphere_centerOfMass {d : ℕ} (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere d.succ m R).centerOfMass = 0 := by
  ext i
  simp only [centerOfMass, solidSphere, Pi.smul_apply, Pi.zero_apply,
    ContinuousLinearMap.coe_mk, LinearMap.coe_mk, AddHom.coe_mk, ContMDiffMap.coeFn_mk]
  let B := Metric.closedBall (0 : Space d.succ) (R : ℝ)
  have h_int : ∫ x in B, x i ∂volume = 0 := by
    let f : Space d.succ → ℝ := fun x => x i
    have hB : MeasurableSet B := measurableSet_closedBall
    have h1 : ∫ x, B.indicator f x ∂volume = ∫ x, B.indicator f (-x) ∂volume := by
      nth_rw 1 [← Measure.map_neg_eq_self (μ := volume)]
      rw [integral_map (measurable_neg : Measurable (fun x : Space d.succ => -x)).aemeasurable,
        Measure.map_neg_eq_self]
    have h2 : ∫ x, B.indicator f (-x) ∂volume = -∫ x, B.indicator f x ∂volume := by
      rw [← integral_neg]
      apply integral_congr; intro x
      simp only [f, Set.indicator_apply, mem_closedBall_zero_iff, norm_neg, Pi.neg_apply]
      split_ifs <;> simp
    rw [← integral_indicator hB]
    exact eq_zero_of_neg_eq (h1.trans h2).symm
  simp [h_int]

end RigidBody

