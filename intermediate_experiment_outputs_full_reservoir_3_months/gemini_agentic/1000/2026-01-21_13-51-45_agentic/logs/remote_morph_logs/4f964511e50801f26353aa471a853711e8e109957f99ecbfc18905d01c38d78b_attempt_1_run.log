    let f := fun (x : Space d.succ) => B.indicator (fun (x : Space d.succ) => x i) x
    have h1 : ∫ x, f x ∂volume = ∫ x, f (-x) ∂volume := (Measure.integral_comp_neg f volume).symm
    have h2 : ∫ x, f (-x) ∂volume = -∫ x, f x ∂volume := by
      rw [← integral_neg]
      apply integral_congr_ae
      filter_upwards with x
      simp only [Metric.mem_closedBall, dist_zero_right, norm_neg, Set.indicator_apply,
        Pi.neg_apply, neg_inj]
      split_ifs <;> simp
    rw [← integral_indicator measurableSet_closedBall]
    exact eq_zero_of_neg_eq (h1.trans h2)
  simp [h_int]

end RigidBody
