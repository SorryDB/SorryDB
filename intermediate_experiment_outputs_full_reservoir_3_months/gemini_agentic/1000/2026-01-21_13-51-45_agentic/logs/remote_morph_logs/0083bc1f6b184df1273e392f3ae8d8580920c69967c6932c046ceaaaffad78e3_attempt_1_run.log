/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  rcases hf zero_lt_one with ⟨l, hl⟩
  rcases isCompact_Icc.exists_isMaxOn (Set.nonempty_Icc.mpr hl.pos.le)
    hf.uniformContinuous.continuous.norm.continuousOn with ⟨y₀, -, hmax⟩
  use ‖f y₀‖ + 1
  intro x
  rcases hl (-x) with ⟨y, hy, ht⟩
  specialize ht x
