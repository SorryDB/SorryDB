lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  cases hf zero_lt_one with | intro l hl =>
  cases isCompact_Icc.exists_isMaxOn (Set.nonempty_Icc.mpr hl.pos.le)
    hf.uniformContinuous.continuous.norm.continuousOn with | intro y₀ hy₀ =>
  let ⟨_, hy₀_max⟩ := hy₀
