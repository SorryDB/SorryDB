      obtain ⟨lY, hYl⟩ := (hY.cadlag ω).2 t
      exact ⟨lX + lY, hXl.add hYl⟩
  · refine (iSup_mono fun i ↦ eLpNorm_add_le (hX.martingale.integrable i).1
      (hY.martingale.integrable i).1 one_le_two).trans_lt ?_
    refine (iSup_le fun i ↦ add_le_add (le_iSup (fun j ↦ eLpNorm (X j) 2 P) i)
      (le_iSup (fun j ↦ eLpNorm (Y j) 2 P) i)).trans_lt ?_
    exact ENNReal.add_lt_top.mpr ⟨hX.bounded, hY.bounded⟩
