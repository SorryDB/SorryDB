import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ 0 < n ∧ n % 50 = 39 := by
    intro n; rw [h₀]
    constructor
    · rintro ⟨h_pos, h_mod⟩; refine ⟨h_pos, ?_⟩
      have h1 : (2 * (7 * n)) % (2 * 50) = 46 := by rw [← Nat.mul_assoc]; exact h_mod
      rw [Nat.mul_mod_mul_left] at h1
      have h2 : (7 * n) % 50 = 23 := by omega
      have h3 : (7 * (n % 50)) % 50 = 23 := by rw [← Nat.mul_mod, h2]
      exact (by decide : ∀ m < 50, (7 * m) % 50 = 23 → m = 39) (n % 50) (Nat.mod_lt _ (by norm_num)) h3
    · rintro ⟨h_pos, h_mod⟩; refine ⟨h_pos, ?_⟩
      rw [← Nat.mul_assoc, Nat.mul_mod_mul_left, ← Nat.mul_mod, h_mod]
      norm_num
  have hu : u = 39 := h₁.unique ⟨by rw [hS]; norm_num, by
    intro n hn; rw [hS] at hn; have := Nat.div_add_mod n 50; rw [hn.2] at this; omega⟩
  have hv : v = 89 := h₂.unique ⟨by rw [Set.mem_diff, hS, hu]; norm_num, by
    intro n hn; rw [Set.mem_diff, hS, hu] at hn
    have := Nat.div_add_mod n 50; rw [hn.1.2] at this
    have : n / 50 ≥ 1 := by
      have : n / 50 ≠ 0 := by intro h; rw [h] at this; omega
      omega
    omega⟩
  simp [hu, hv]; norm_num
