set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ 0 < n ∧ n % 50 = 39 := by
    intro n; rw [h₀]; apply and_congr_right; intro h_pos
    constructor
    · intro h_mod
      have h1 : 14 * n % 100 = 2 * (7 * n % 50) := by
        rw [show 14 * n = 2 * (7 * n) by ring, show 100 = 2 * 50 by ring]
        rw [Nat.mul_mod_mul_left]
      have h2 : 7 * n % 50 = 23 := by rw [h1] at h_mod; omega
      have h3 : 7 * (n % 50) % 50 = 23 := by rw [← h2, Nat.mul_mod]; simp
      exact (by decide : ∀ m < 50, 7 * m % 50 = 23 → m = 39) (n % 50) (n.mod_lt (by norm_num)) h3
    · intro h_mod
      have h1 : 14 * n = 100 * (7 * (n / 50)) + 546 := by
        rw [← Nat.div_add_mod n 50, h_mod]; ring
      rw [h1, Nat.add_mod, Nat.mul_mod_left]; norm_num
  have hu : u = 39 := by
    apply h₁.unique
    refine ⟨by rw [hS]; norm_num, fun n hn ↦ ?_⟩
    rw [hS] at hn; have := Nat.div_add_mod n 50; rw [hn.2] at this; omega
  have hv : v = 89 := by
    apply h₂.unique
    refine ⟨by rw [Set.mem_diff, hS, hu]; norm_num, fun n hn ↦ ?_⟩
    rw [Set.mem_diff, hS, hu] at hn
    have h1 := Nat.div_add_mod n 50
    have h2 := hn.1.2
    have h3 : n / 50 ≠ 0 := by intro h; have : n = 39 := by omega; exact hn.2 this
    omega
  simp [hu, hv]; norm_num
