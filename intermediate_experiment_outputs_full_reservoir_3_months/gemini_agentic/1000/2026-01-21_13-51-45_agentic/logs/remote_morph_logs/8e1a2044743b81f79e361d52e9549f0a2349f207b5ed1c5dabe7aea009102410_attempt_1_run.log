    --TODO: might have to adjust the constant
    HasLorentzType T p 1 p вҲһ Ој ОҪ (4 * c / p) := by
  intro f hf
  --have hp : 1 вүӨ p := by sorry --use: should follow from hpp'
  have claim : вҲҖ (G : Set Оұ'), (MeasurableSet G) вҶ’ (ОҪ G < вҲһ) вҶ’ eLpNorm (T f) 1 (ОҪ.restrict G)
    вүӨ (4 * c / p) * eLorentzNorm f p 1 Ој * (ОҪ G) ^ p'вҒ»В№.toReal := by
      intro G measurable_G G_finite
      rcases hf with вҹЁaemeasurable_f, hfвҹ©
      revert f --TODO: go on here
      apply AEStronglyMeasurable.induction
      В· intro f g stronglyMeasurable_f hfg hf hg
        have : eLorentzNorm f p 1 Ој < вҠӨ := by
          sorry --use: hg
        have hf := hf this
        sorry --use: hf
      intro g stronglyMeasurable_g hg

      --TODO: decompose g into 4 nonnegative parts with constant coefficients
      set gвӮҒ := fun x вҶҰ Real.toNNReal (RCLike.re (g x))
      set gвӮӮ := fun x вҶҰ Real.toNNReal (- RCLike.re (g x))
      set gвӮғ := fun x вҶҰ Real.toNNReal (RCLike.im (g x))
      set gвӮ„ := fun x вҶҰ Real.toNNReal (- RCLike.im (g x))
      have g_decomposition : g = (1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮҒ)
                                + (-1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮӮ)
                                + (RCLike.I : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮғ)
                                + (-RCLike.I : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮ„) := by
        unfold gвӮҒ gвӮӮ gвӮғ gвӮ„
        ext x
        simp only [one_smul, neg_smul, Pi.add_apply, Function.comp_apply, Real.coe_toNNReal',
          Pi.neg_apply, Pi.smul_apply, smul_eq_mul]
        ring_nf
        rw [algebraMap]
        sorry --TODO: simple algebra
      set T' := T вҲҳ (fun f вҶҰ (@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ f)
      --TODO: use properties for T to get those for T'
      have hT' : HasRestrictedWeakType T' p p' Ој ОҪ c := sorry
      have weaklyCont_T' : WeaklyContinuous T' p Ој ОҪ := by
        unfold WeaklyContinuous T'
        intro fs hfs f hf G
        simp only [Function.comp_apply]
        apply weakly_cont_T
        В· --TODO: get this from (hf : MemLorentz f p 1 Ој)
          --TODO: add lemmas for locallyIntegrable
          --unfold LocallyIntegrable IntegrableAtFilter IntegrableOn

          --have : LocallyIntegrable f Ој :=
          --apply (hf.memLp _).locallyIntegrable
          sorry
        В· --apply Filter.Eventually.of_forall
          intro n
          apply Measurable.aestronglyMeasurable
          apply RCLike.measurable_ofReal.comp
          apply measurable_coe_nnreal_real.comp (SimpleFunc.measurable (fs n))
        В· intro x
          simp only [Function.comp_apply, norm_algebraMap', Real.norm_eq_abs, NNReal.abs_eq]
          exact fun вҰғa bвҰ„ a_1 вҶҰ hfs a_1 x
        В· --apply Filter.Eventually.of_forall
          intro x
          --apply Filter.Tendsto.algebraMap
          --apply Filter.Tendsto.comp _
          --apply Filter.Tendsto.comp _
          sorry --TODO: use that f is the supremum; maybe need to add a condition implying that
          -- the (fs n) are really converging to f


      have T'_subadd : вҲҖ (f g : Оұ вҶ’ в„қвүҘ0),
        MemLorentz f p 1 Ој вҶ’
          MemLorentz g p 1 Ој вҶ’
            eLpNorm (T' (f + g)) 1 (ОҪ.restrict G)
              вүӨ eLpNorm (T' f) 1 (ОҪ.restrict G) + eLpNorm (T' g) 1 (ОҪ.restrict G) := by
        intro f g hf hg
        unfold T'
        simp only [Function.comp_apply]
        have hf' : MemLorentz ((@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ f) p 1 Ој := by
          constructor
          В· apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hf.1.aemeasurable
          В· sorry --TODO: get this from hf, maybe write additional lemma
        have hg' : MemLorentz ((@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ g) p 1 Ој := by
          constructor
          В· apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hg.1.aemeasurable
          В· sorry --TODO: get this from hf, maybe write additional lemma
        apply le_trans _ (eLpNorm_add_le _ _ le_rfl)
        В· apply eLpNorm_mono_enorm
          intro x
          simp only [Pi.add_apply]
          apply le_of_eq_of_le _ (T_subadd _ _ _ hf' hg')
          congr with x
          simp
        В· apply AEStronglyMeasurable.restrict
          apply T_meas hf'
        В· apply AEStronglyMeasurable.restrict
          apply T_meas hg'
      have T'_submul : вҲҖ (f : Оұ вҶ’ в„қвүҘ0) (a : в„қвүҘ0), eLpNorm (T' (a вҖў f)) 1 (ОҪ.restrict G)
          вүӨ eLpNorm (a вҖў T' f) 1 (ОҪ.restrict G) := by
        intro f a
        apply eLpNorm_mono_enorm
        intro x
        unfold T'
        simp only [Function.comp_apply, Pi.smul_apply, enorm_smul_eq_smul]
        have : a вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘
          = вҖ–aвҖ–вӮ‘ вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘ := by
          congr
        rw [this]
        convert T_submul (NNReal.toReal a) _ x
        В· ext x
          simp
        congr
        simp
      have helper : вҲҖ {f : Оұ вҶ’ в„қвүҘ0} (hf : Measurable f) (hf' : MemLorentz f p 1 Ој),
          eLpNorm (T' f) 1 (ОҪ.restrict G) вүӨ (c / p) * eLorentzNorm f p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
        intro f hf hf'
        apply HasRestrictedWeakType.hasLorentzType_helper c_pos hT' hpp' weaklyCont_T' measurable_G G_finite
          T'_subadd T'_submul hf hf'

      calc eLpNorm (T g) 1 (ОҪ.restrict G)
        _ вүӨ eLpNorm (enorm вҲҳ T' gвӮҒ + enorm вҲҳ T' gвӮӮ + enorm вҲҳ T' gвӮғ + enorm вҲҳ T' gвӮ„) 1 (ОҪ.restrict G) := by
          have h (f' : Оұ вҶ’ в„қвүҘ0) : MemLorentz (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f') p 1 Ој := sorry
          apply eLpNorm_mono_enorm; intro x; rw [g_decomposition]
          simp only [Pi.add_apply, Function.comp_apply, enorm_eq_self]
          refine (T_subadd _ _ _ (h gвӮҒ |>.add (h gвӮӮ |>.add (h gвӮғ))) (h gвӮ„)).trans ?_
          refine (add_le_add_right (T_subadd _ _ _ (h gвӮҒ |>.add (h gвӮӮ)) (h gвӮғ)) _).trans ?_
          refine (add_le_add_right (add_le_add_right (T_subadd _ _ _ (h gвӮҒ) (h gвӮӮ)) _) _).trans ?_
          gcongr
          В· exact (T_submul 1 _ _).trans (by simp [T'])
          В· exact (T_submul (-1) _ _).trans (by simp [T', enorm_neg])
          В· exact (T_submul RCLike.I _ _).trans (by rw [вҶҗ ofReal_norm_eq_enorm, RCLike.norm_I]; split_ifs <;> simp [T'])
          В· exact (T_submul (-RCLike.I) _ _).trans (by rw [вҶҗ ofReal_norm_eq_enorm, norm_neg, RCLike.norm_I]; split_ifs <;> simp [T'])
        _ вүӨ eLpNorm (T' gвӮҒ) 1 (ОҪ.restrict G) + eLpNorm (T' gвӮӮ) 1 (ОҪ.restrict G)
          + eLpNorm (T' gвӮғ) 1 (ОҪ.restrict G) + eLpNorm (T' gвӮ„) 1 (ОҪ.restrict G) := by
          have h (f' : Оұ вҶ’ в„қвүҘ0) : AEStronglyMeasurable (enorm вҲҳ T' f') (ОҪ.restrict G) :=
            (T_meas (f := fun x вҶҰ RCLike.ofReal (NNReal.toReal (f' x))) sorry).enorm.restrict G
          refine (eLpNorm_add_le (h gвӮҒ |>.add (h gвӮӮ) |>.add (h gвӮғ)) (h gвӮ„) le_rfl).trans ?_
          add_le_add_right (refine (eLpNorm_add_le (h gвӮҒ |>.add (h gвӮӮ)) (h gвӮғ) le_rfl).trans ?_) _
          add_le_add_right (exact eLpNorm_add_le (h gвӮҒ) (h gвӮӮ) le_rfl) _
        _ вүӨ (4 * вҶ‘c / p) * eLorentzNorm g p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
          simp_rw [mul_assoc, вҶҗ add_mul, вҶҗ add_mul, вҶҗ add_mul]; gcongr
          В· exact (helper sorry sorry).trans (by gcongr; apply eLorentzNorm_mono; intro x; sorry)
          В· exact (helper sorry sorry).trans (by gcongr; apply eLorentzNorm_mono; intro x; sorry)
          В· exact (helper sorry sorry).trans (by gcongr; apply eLorentzNorm_mono; intro x; sorry)
          В· exact (helper sorry sorry).trans (by gcongr; apply eLorentzNorm_mono; intro x; sorry)
  constructor
  В· exact T_meas hf
  В· rw [eLorentzNorm_eq_wnorm hpp'.ne_zero]
    В· apply iSup_le; intro G; apply iSup_le; intro hG; apply iSup_le; intro hG'
      rw [ENNReal.le_div_iff_mul_le (Or.inl (by simp [hpp'.ne_zero])) (Or.inl (by simp [hpp'.ne_top]))]
      exact claim G hG hG'
    В· exact hpp'.ne_top
