Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  rcases n.eq_zero_or_pos with rfl | hn
  · left; use 0; intro j; exact j.elim0
  haveI : NeZero n := ⟨hn.ne'⟩
  let E : S → S → Prop := λ u v => ∃ x > 0, (u : ℕ) * v = x^2 + x + k
  have hE1 : ∀ i : Fin n, E (p₁ i) (p₁ (i + 1)) := hp₁
  have hE2 : ∀ i : Fin n, E (p₂ i) (p₂ (i + 1)) := hp₂
  have h_sym : ∀ {u v}, E u v ↔ E v u := λ {u v} => by simp [E, Nat.mul_comm]
  have h_deg : ∀ u : S, (Finset.univ.filter (E u)).card = 2 := sorry
  have h_p1_nb : ∀ i : Fin n, Finset.univ.filter (E (p₁ i)) = {p₁ (i - 1), p₁ (i + 1)} := sorry
  have h_p2_nb : ∀ i : Fin n, Finset.univ.filter (E (p₂ i)) = {p₂ (i - 1), p₂ (i + 1)} := sorry
  let f : Fin n ≃ Fin n := p₁.symm.trans p₂.toEquiv
  have hf_nb : ∀ i : Fin n, {f (i - 1), f (i + 1)} = {f i - 1, f i + 1} := sorry
  obtain ⟨i, hi⟩ | ⟨i, hi⟩ := Fin.exists_f_eq_add_or_f_eq_sub_add hf_nb
  · left; use i; intro j; simp [f, ← p₁.eq_apply_iff_apply_eq] at hi; exact hi j
  · right; use i; intro j; simp [f, ← p₁.eq_apply_iff_apply_eq] at hi; rw [hi j]; simp [Fin.rev]
