import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  cases n with
  | zero => left; use 0; intro j; exact j.elim0
  | succ n =>
    haveI : NeZero #S := ⟨n.succ_ne_zero⟩
    let E : Finset (Finset S) := Finset.univ.image (λ i => {p₁ i, p₁ (i + 1)})
    have h_p1_edges : ∀ i, {p₁ i, p₁ (i + 1)} ∈ E := λ i => Finset.mem_image_of_mem _ (Finset.mem_univ _)
    have h_p2_edges : ∀ i, {p₂ i, p₂ (i + 1)} ∈ E := by
      intro i
      have h_prop (u v : S) : (∃ x > 0, (u : ℕ) * v = x^2 + x + k) ↔ {u, v} ∈ E := sorry
      obtain ⟨x, hx_pos, hx⟩ := hp₂ i
      rw [h_prop]
      exact ⟨x, hx_pos, hx⟩
    have h_unique_cycle : ∀ (p : Fin #S ≃ S), (∀ i, {p i, p (i + 1)} ∈ E) → (∃ i, ∀ j, p j = p₁ (j + i)) ∨ ∃ i, ∀ j, p j = p₁ (Fin.rev j + i) := sorry
    exact h_unique_cycle p₂ h_p2_edges

