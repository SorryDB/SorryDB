import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let E := {e : Finset ↥S | e.card = 2 ∧ ∃ x > 0, (e.min' (by aesop) : ℕ) * (e.max' (by aesop) : ℕ) = x^2 + x + k}
  have hE : ∀ (p : Fin S.card ≃ S) (hp : Condition k S p), ∀ i, {p i, p (i+1)} ∈ E := by
    intro p hp i
    have h_p_eq : (p i : ℕ) * (p (i+1) : ℕ) = (p (i+1) : ℕ) * (p i : ℕ) := Nat.mul_comm _ _
    obtain ⟨x, hx_pos, hx⟩ := hp i
    have h_card : ({p i, p (i+1)} : Finset S).card = 2 := by
      refine Finset.card_doubleton_of_ne ?_
      intro h; subst h; rw [← hx] at hx_pos
      have : (p i : ℕ) * (p i : ℕ) = x^2 + x + k := hx
      have : (p i : ℕ)^2 > x^2 := by linarith
      have : (p i : ℕ)^2 < (x+1)^2 := by rw [hx]; nlinarith
      exact (Nat.abs_diff_ne_zero.1 (by linarith) (Nat.lt_succ_iff.1 (Nat.sqrt_lt_succ_iff.1 (by rw [hx]; nlinarith))).ne')
    exact ⟨h_card, x, hx_pos, by aesop⟩
  have h_unique_smaller : ∀ p ∈ S, p ≠ S.max' (by aesop) → ∃! q ∈ S, q < p ∧ {p, q} ∈ E := sorry
  have h_unique_max : ∃! q₁ q₂ : S, q₁ < S.max' (by aesop) ∧ q₂ < S.max' (by aesop) ∧ q₁ ≠ q₂ ∧ {S.max' (by aesop), q₁} ∈ E ∧ {S.max' (by aesop), q₂} ∈ E := sorry
  have h_graph_is_cycle : ∀ (p : Fin S.card ≃ S) (hp : Condition k S p), ∀ i, (p i = S.max' (by aesop) → (({p (i-1), p i} ∈ E) ∧ ({p i, p (i+1)} ∈ E))) := sorry
  exact sorry

