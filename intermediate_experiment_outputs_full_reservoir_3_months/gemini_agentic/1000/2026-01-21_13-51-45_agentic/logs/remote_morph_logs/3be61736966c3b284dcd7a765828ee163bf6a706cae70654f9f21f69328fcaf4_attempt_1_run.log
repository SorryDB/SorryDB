      field_simp [hf_wx, h₁ w hw, h₁ x hx, (by nlinarith : w^2 + x^2 ≠ 0)] at h_spec
      nlinarith
    have h_f_cases : ∀ x > 0, f x = x ∨ f x = 1 / x := by
