import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 zero_lt_one zero_lt_one zero_lt_one zero_lt_one rfl
      have hf1 := h₁ 1 zero_lt_one
      field_simp [hf1] at h
      nlinarith
    have hf_mul (w x : ℝ) (hw : 0 < w) (hx : 0 < x) :
        f (w * x) * (w ^ 2 + x ^ 2) = w * x * (f w ^ 2 + f x ^ 2) := by
      let y := (w * x).sqrt
      have hy : 0 < y := Real.sqrt_pos.mpr (mul_pos hw hx)
      have hyy : w * x = y * y := by rw [← Real.sq_sqrt (mul_pos hw hx).le, sq]
      have h_spec := h w x y y hw hx hy hy hyy
      have hy2 : y ^ 2 = w * x := by rw [sq, ← hyy]
      rw [hy2] at h_spec
      have hf_wx := h₁ (w * x) (by positivity)
      field_simp [hf_wx, h₁ w hw, h₁ x hx] at h_spec
      nlinarith
    have h_f_cases : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize hf_mul x 1 hx zero_lt_one
      rw [h1] at hf_mul
      have h_eq : (x * f x - 1) * (f x - x) = 0 := by
        field_simp [h₁ x hx] at hf_mul
        linear_combination hf_mul
      rcases mul_eq_zero.mp h_eq with h_inv | h_x
      · right; field_simp [hx.ne.symm]; nlinarith
      · left; exact h_x
    by_cases h_all : ∀ x > 0, f x = x
    · left; exact h_all
    · right
      push_neg at h_all
      rcases h_all with ⟨a, ha, h_fa_ne⟩
      have h_fa : f a = 1 / a := (h_f_cases a ha).resolve_left h_fa_ne
      have a_ne_1 : a ≠ 1 := by intro ha1; rw [ha1, h1] at h_fa_ne; exact h_fa_ne rfl
      intro b hb
      rcases h_f_cases b hb with h_fb_x | h_fb_inv
      · specialize hf_mul a b ha hb
        rcases h_f_cases (a * b) (by positivity) with hab_x | hab_inv
        · rw [hab_x, h_fa, h_fb_x] at hf_mul
          have h_a4 : a ^ 4 = 1 := by
            field_simp [ha.ne.symm, hb.ne.symm] at hf_mul
            linear_combination hf_mul
          have : a = 1 := (pow_left_inj (show 4 ≠ 0 by norm_num) ha.le (zero_le_one)).mp (by rw [h_a4, one_pow])
          contradiction
        · rw [hab_inv, h_fa, h_fb_x] at hf_mul
          have h_b4 : b ^ 4 = 1 := by
            field_simp [ha.ne.symm, hb.ne.symm] at hf_mul
            linear_combination hf_mul
          have : b = 1 := (pow_left_inj (show 4 ≠ 0 by norm_num) hb.le (zero_le_one)).mp (by rw [h_b4, one_pow])
          rw [this, h1, one_div_one]
      · exact h_fb_inv
  · rintro (h | h) w x y z hw hx hy hz hwx
    · rw [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
      field_simp
    · rw [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      rw [← mul_pow, ← mul_pow, hwx]
