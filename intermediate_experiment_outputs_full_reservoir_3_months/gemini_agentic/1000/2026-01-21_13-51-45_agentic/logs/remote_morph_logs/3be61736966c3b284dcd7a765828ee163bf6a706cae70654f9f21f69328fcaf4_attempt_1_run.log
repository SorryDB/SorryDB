import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      have h_spec := h 1 1 1 1 (zero_lt_one) (zero_lt_one) (zero_lt_one) (zero_lt_one) rfl
      have hf1 : f 1 > 0 := h₁ 1 zero_lt_one
      field_simp [hf1] at h_spec
      nlinarith
    have h_f_mul : ∀ w, 0 < w → ∀ x, 0 < x → f (w * x) = (w * x * (f w ^ 2 + f x ^ 2)) / (w ^ 2 + x ^ 2) := by
      intro w hw x hx
      let y := (w * x).sqrt
      have hy : 0 < y := Real.sqrt_pos.mpr (mul_pos hw hx)
      have h_spec := h w x y y hw hx hy hy (by simp [Real.mul_self_sqrt (mul_pos hw hx).le])
      have hf_wx : f (w * x) > 0 := h₁ (w * x) (mul_pos hw hx)
      have hf_w : f w > 0 := h₁ w hw
      have hf_x : f x > 0 := h₁ x hx
      field_simp [Real.sq_sqrt (mul_pos hw hx).le, hf_wx, hf_w, hf_x, hw, hx] at h_spec
      nlinarith
    have h_f_cases : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      have h_mul := h_f_mul x hx 1 (zero_lt_one)
      rw [h1] at h_mul
      have h_eq : (x * f x - 1) * (f x - x) = 0 := by
        have hf_x : f x > 0 := h₁ x hx
        field_simp [hf_x, hx] at h_mul
        nlinarith
      exact mul_eq_zero.mp h_eq
    by_cases h_all : ∀ x > 0, f x = x
    · left; exact h_all
    · right
      intro b hb
      by_cases hb1 : b = 1
      · rw [hb1, h1, one_div_one]
      · have : ∃ a > 0, f a ≠ a := by push_neg at h_all; exact h_all
        rcases this with ⟨a, ha, h_fa_ne⟩
        have h_fa : f a = 1 / a := (h_f_cases a ha).resolve_left h_fa_ne
        have a_ne_1 : a ≠ 1 := by intro h_a1; rw [h_a1, h1] at h_fa_ne; exact h_fa_ne rfl
        rcases h_f_cases b hb with h_fb_x | h_fb_inv
        · specialize h_f_mul a ha b hb
          rcases h_f_cases (a * b) (mul_pos ha hb) with hab_x | hab_inv
          · rw [hab_x, h_fa, h_fb_x] at h_f_mul
            have h_eq : a^4 = 1 := by
              field_simp [ha, hb, a_ne_1, hb1, h₁ (a*b) (mul_pos ha hb), h₁ a ha, h₁ b hb] at h_f_mul
              nlinarith
            have : a = 1 := (pow_left_inj ha.le zero_le_one (by norm_num)).mp (by rw [one_pow 4]; exact h_eq)
            contradiction
          · rw [hab_inv, h_fa, h_fb_x] at h_f_mul
            have h_eq : b^4 = 1 := by
              field_simp [ha, hb, a_ne_1, hb1, h₁ (a*b) (mul_pos ha hb), h₁ a ha, h₁ b hb] at h_f_mul
              nlinarith
            have : b = 1 := (pow_left_inj hb.le zero_le_one (by norm_num)).mp (by rw [one_pow 4]; exact h_eq)
            contradiction
        · exact h_fb_inv
  · rintro (h | h) w x y z hw hx hy hz hwx
    · rw [h w hw, h x hx, h (y ^ 2) (pow_pos hy 2), h (z ^ 2) (pow_pos hz 2)]
    · rw [h w hw, h x hx, h (y ^ 2) (pow_pos hy 2), h (z ^ 2) (pow_pos hz 2)]
      have hf_y2 : f (y ^ 2) > 0 := h₁ (y ^ 2) (pow_pos hy 2)
      have hf_z2 : f (z ^ 2) > 0 := h₁ (z ^ 2) (pow_pos hz 2)
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm, hf_y2, hf_z2]
      congr 1
      rw [← mul_pow, ← mul_pow, hwx]

