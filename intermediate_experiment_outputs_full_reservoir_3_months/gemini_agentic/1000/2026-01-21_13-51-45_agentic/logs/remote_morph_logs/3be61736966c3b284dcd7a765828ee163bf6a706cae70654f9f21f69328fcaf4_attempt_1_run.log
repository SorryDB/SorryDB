import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by positivity) (by positivity) (by positivity) (by positivity) (by linarith)
      field_simp [h₁ 1, ← pow_two] at h
      nlinarith [h₁ 1]
    have h2 : ∀ w x, 0 < w → 0 < x → f (w * x) = w * x * (f w ^ 2 + f x ^ 2) / (w ^ 2 + x ^ 2) := by
      intro w x hw hx
      let y := (w * x).sqrt
      have hy : 0 < y := Real.sqrt_pos.mpr (mul_pos hw hx)
      specialize h w x y y hw hx hy hy (by simp [y, Real.mul_self_sqrt (mul_pos hw hx).le])
      field_simp [Real.sq_sqrt (mul_pos hw hx).le, h₁ (w * x)] at h
      linear_combination h
    have h3 : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h2 x 1 hx (by linarith)
      rw [h1] at h2
      field_simp [hx.ne.symm] at h2
      have : (x * f x - 1) * (f x - x) = 0 := by
        rw [← h2]
        ring
      rcases mul_eq_zero.mp this with hf | hf
      · right; field_simp [hx.ne.symm, hf]
      · left; exact hf
    by_contra' hnot
    rcases hnot with ⟨⟨a, ha, hfna⟩, ⟨b, hb, hfnb⟩⟩
    have hfa : f a = 1 / a := (h3 a ha).resolve_left hfna
    have hfb : f b = b := (h3 b hb).resolve_right hfnb
    have hab : 0 < a * b := mul_pos ha hb
    cases' h3 (a * b) hab with hab_sol hab_sol
    · specialize h2 a b ha hb
      rw [hab_sol, hfa, hfb] at h2
      field_simp [ha.ne.symm, hb.ne.symm, (a^2+b^2).ne.symm] at h2
      have : a = 1 := (pow_left_inj ha.le (by linarith) (by linarith)).mp (by nlinarith)
      rw [this, h1] at hfna; exact hfna rfl
    · specialize h2 a b ha hb
      rw [hab_sol, hfa, hfb] at h2
      field_simp [ha.ne.symm, hb.ne.symm, (a^2+b^2).ne.symm] at h2
      have : b = 1 := (pow_left_inj hb.le (by linarith) (by linarith)).mp (by nlinarith)
      rw [this, h1, one_div_one] at hfnb; exact hfnb rfl
  · rintro (h | h) w x y z hw hx hy hz hwx
    · rw [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
    · rw [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      congr 1
      rw [← mul_pow, ← mul_pow, hwx]

