      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ : (Ω → ℝ≥0∞) → ℝ := fun f ↦ (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  obtain ⟨g, hg_conv, hg_gap⟩ := komlos_convex (fun _ ↦ ENNReal.toReal_nonneg)
    ⟨1, fun n ↦ ENNReal.toReal_le_one (lintegral_le_one fun _ ↦ ENNReal.inv_le_one (le_add_self))⟩
  let u : ℕ → Ω → ℝ := fun n ω ↦ ((1 + g n ω)⁻¹).toReal
  have hg_meas n : Measurable (g n) := by
    obtain ⟨w, s, -, hws, hg⟩ := (convexHull_iff_bis ℝ≥0).1 (hg_conv n)
    rw [hg]; exact s.measurable_sum (fun f hf ↦ by
      obtain ⟨m, rfl⟩ := hws f hf; exact (hX (n + m)).const_smul (w f))
  have h_u_meas n : Measurable (u n) := (hg_meas n).ennreal_add_const.ennreal_inv.ennreal_toReal
  have h_cau : CauchySeq (fun n ↦ ((h_u_meas n).toLp 2 (memLp_of_bounded (eventually_of_forall fun ω ↦
      ENNReal.toReal_le_one (ENNReal.inv_le_one (le_add_self)))))) := by
    refine cauchySeq_of_le_unit_sep 0 (fun δ δpos ↦ ?_)
    obtain ⟨N, hN⟩ := hg_gap (δ ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, Lp.norm_def, ENNReal.toReal_le_of_le_ofReal (by positivity)]
    refine (ENNReal.le_ofReal_le_toReal ?_).trans (ENNReal.mul_le_mul_left' (ENNReal.le_ofReal_le_toReal hN) 4)
    refine ENNReal.toReal_mono (by norm_num) (lintegral_mono fun ω ↦ ?_)
    have h_gap : (u n ω - u m ω)^2 / 4 ≤ (u n ω + u m ω) / 2 - (2 / ((u n ω)⁻¹ + (u m ω)⁻¹)) := by
      rcases eq_or_ne (u n ω + u m ω) 0 with h | h
      · simp [h] at *; linarith
      · field_simp; nlinarith
    convert ENNReal.ofReal_le_ofReal h_gap using 1
    · ring_nf
    · field_simp; congr; field_simp; field_simp
  obtain ⟨v, n', -, h_lim⟩ := h_cau.exists_seq_tendsto_ae
  let Y_lim : Ω → ℝ≥0∞ := fun ω ↦ (ENNReal.ofReal (v ω))⁻¹ - 1
  refine ⟨fun i ↦ g (n' i), Y_lim, fun i ↦ ?_, (Lp.measurable v).ennreal_ofReal.inv.sub_const 1, ?_⟩
  · have h_conv : g (n' i) ∈ convexHull ℝ≥0 (Set.range fun m ↦ X (i + m)) :=
