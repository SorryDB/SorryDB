lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ : (Ω → ℝ≥0∞) → ℝ := fun f ↦ (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nonneg : 0 ≤ φ := fun f ↦ ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ by
    simp only [φ]; rw [← ENNReal.toReal_one]
    apply ENNReal.toReal_mono ENNReal.one_ne_top
    exact lintegral_mono (fun ω ↦ ENNReal.inv_le_one.2 (le_add_right (le_refl 1))) |>.trans (by simp [measure_univ])⟩
  rcases komlos_convex hφ_nonneg hφ_bdd with ⟨g, hg_conv, hg_gap⟩
  have hg_meas n : Measurable (g n) := by
    let S := {f : Ω → ℝ≥0∞ | Measurable f}
    have hS : Convex ℝ≥0 S := fun f1 hf1 f2 hf2 a b ha hb hab ↦
      (hf1.const_mul (a : ℝ≥0∞)).add (hf2.const_mul (b : ℝ≥0∞))
    exact convexHull_min (Set.range_subset_iff.2 fun m ↦ hX (n + m)) hS (hg_conv n)
  let u n ω := ((1 + g n ω)⁻¹).toReal
  have hu_meas n : Measurable (u n) := ENNReal.measurable_toReal.comp ((measurable_const.add (hg_meas n)).inv)
  have hu_bdd n ω : u n ω ≤ 1 := ENNReal.toReal_mono ENNReal.one_ne_top (ENNReal.inv_le_one.2 (le_add_right (le_refl 1)))
  have hU_mem n : MemLp (u n) 2 P := memLp_of_bounded (hu_meas n).aestronglyMeasurable 2 (Eventually.of_forall (fun ω ↦ (hu_bdd n ω).trans (by norm_num)))
  let U n : Lp ℝ 2 P := (hU_mem n).toLp (u n)
  have h_cau : CauchySeq U := by
    refine Metric.cauchySeq_iff.mpr (fun δ δpos ↦ ?_)
    rcases hg_gap (δ ^ 2 / 5) (by positivity) with ⟨N, hN⟩
    refine ⟨N, fun i j hi hj ↦ ?_⟩
    rw [dist_eq_norm, Lp.norm_def, ← ENNReal.ofReal_le_ofReal_iff (by positivity), ENNReal.ofReal_pow (norm_nonneg _)]
    have h_norm : ENNReal.ofReal (snorm (U i - U j) 2 P).toReal ^ 2 = ∫⁻ ω, ENNReal.ofReal ((u i ω - u j ω) ^ 2) ∂P := by
      rw [ENNReal.ofReal_toReal (Lp.snorm_ne_top _), snorm_two_eq_lintegral_nnnorm, ← ENNReal.ofReal_pow (by positivity)]
      congr 1; apply lintegral_congr_ae
      filter_upwards [Lp.coeFn_sub (U i) (U j), Lp.coeFn_toLp (u i) (hU_mem i), Lp.coeFn_toLp (u j) (hU_mem j)] with ω hsub hUi hUj
      simp [hsub, hUi, hUj, u, ENNReal.ofReal_pow (abs_nonneg _)]
    rw [h_norm]; apply ENNReal.ofReal_le_ofReal_iff.1
    have h_gap_le ω : ENNReal.ofReal ((u i ω - u j ω) ^ 2) ≤ 4 * (2⁻¹ * (1 + g i ω)⁻¹ + 2⁻¹ * (1 + g j ω)⁻¹ - (1 + (g i ω + g j ω) / 2)⁻¹) := by
      let xi := u i ω; let xj := u j ω
      have : (xi - xj) ^ 2 ≤ 4 * ((xi + xj) / 2 - (if xi + xj = 0 then 0 else 2 * xi * xj / (xi + xj))) := by
        rcases eq_or_ne (xi + xj) 0 with h | h
        · simp [h, xi, xj]; positivity
        · have : 0 < xi + xj := by linarith [hu_bdd i ω, hu_bdd j ω, (by simp [u, xi] : 0 ≤ xi), (by simp [u, xj] : 0 ≤ xj)]
          field_simp; rw [div_le_div_iff (by positivity) (by linarith)]; nlinarith
      refine (ENNReal.ofReal_le_ofReal this).trans ?_
      rw [ENNReal.ofReal_mul (by positivity), ENNReal.ofReal_sub]
      · congr 1
        · rw [ENNReal.ofReal_add, ENNReal.ofReal_div, ENNReal.ofReal_div]; simp [xi, xj, u]; rfl
        · rcases eq_or_ne (1 + g i ω) ⊤ with hi | hi <;> rcases eq_or_ne (1 + g j ω) ⊤ with hj | hj <;> simp [hi, hj]
          · lift (1 + g i ω) to ℝ≥0 using hi; lift (1 + g j ω) to ℝ≥0 using hj; field_simp; norm_cast
      · rcases eq_or_ne (xi + xj) 0 with h | h
        · simp [h]
        · field_simp; rw [div_le_div_iff (by positivity) (by linarith)]; nlinarith
    refine (lintegral_mono h_gap_le).trans ?_
    rw [lintegral_const_mul _ (by simp), lintegral_sub, lintegral_add, lintegral_const_mul, lintegral_const_mul]
    · simp only [φ] at hN; specialize hN i j hi hj
      rw [ENNReal.ofReal_mul (by positivity), ENNReal.ofReal_sub _ (by linarith [hN.le]), ← ENNReal.ofReal_mul (by positivity),
          ← ENNReal.ofReal_add, ← ENNReal.ofReal_mul (by positivity), ← ENNReal.ofReal_mul (by positivity)]
      · apply ENNReal.ofReal_le_ofReal; linarith
      all_goals try (simp [φ]; linarith [hN.le])
    · exact (hg_meas i |>.add (hg_meas j) |>.div_const 2 |>.add_const 1 |>.inv).aemeasurable
    · exact (lintegral_mono (fun ω ↦ ENNReal.inv_le_one.2 (le_add_right le_rfl)) |>.trans_lt (by simp [measure_univ]; exact ENNReal.one_lt_top)).ne
  rcases cauchySeq_tendsto_of_complete h_cau with ⟨v, hv⟩
  rcases tendstoLp_exists_seq_tendsto_ae hv with ⟨n', hn'_mono, hn'_ae⟩
  let Y n := g (n' n)
  let Y_lim ω := liminf (fun k ↦ Y k ω) atTop
  refine ⟨Y, Y_lim, fun n ↦ ?_, measurable_liminf (fun k ↦ hg_meas (n' k)), ?_⟩
  · let S := Set.range fun m ↦ X (n + m)
    have h_subset : Set.range (fun m ↦ X (n' n + m)) ⊆ S :=
      Set.range_subset_iff.2 fun m ↦ ⟨m + (n' n - n), by rw [add_assoc, Nat.add_sub_cancel' (hn'_mono.id_le n)]⟩
    exact convexHull_min (h_subset.trans (subset_convexHull ℝ≥0∞ S)) ((convex_convexHull ℝ≥0∞ S).restrict_scalars ℝ≥0) (hg_conv (n' n))
  · filter_upwards [hn'_ae] with ω hω
    have h_g_lim : Tendsto (fun k ↦ Y k ω) atTop (𝓝 ((ENNReal.ofReal (v ω))⁻¹ - 1)) := by
