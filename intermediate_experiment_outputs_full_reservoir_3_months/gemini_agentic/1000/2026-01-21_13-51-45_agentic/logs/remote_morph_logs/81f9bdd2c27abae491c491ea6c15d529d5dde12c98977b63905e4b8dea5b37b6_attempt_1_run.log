lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ : (Ω → ℝ≥0∞) → ℝ := fun f ↦ (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nonneg : 0 ≤ φ := fun f ↦ ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ ENNReal.toReal_le_one
    (set_lintegral_le_one _ (fun ω _ ↦ ENNReal.inv_le_one (by simp)))⟩
  obtain ⟨g, hg_conv, hg_gap⟩ := komlos_convex hφ_nonneg hφ_bdd
  let u : ℕ → Ω → ℝ := fun n ω ↦ ((1 + g n ω)⁻¹).toReal
  have h_cau : CauchySeq (fun n ↦ (MeasureTheory.Lp.ofReal 2 (u n) : Lp ℝ 2 P)) := by
    refine cauchySeq_of_le_unit_sep 0 (fun δ δpos ↦ ?_)
    obtain ⟨N, hN⟩ := hg_gap (δ ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [MeasureTheory.Lp.dist_def, MeasureTheory.Lp.norm_def, ENNReal.toReal_le_of_le_ofReal (by positivity)]
    refine (ENNReal.le_ofReal_le_toReal ?_).trans (ENNReal.mul_le_mul_left' (ENNReal.le_ofReal_le_toReal hN) 4)
    refine ENNReal.toReal_mono (ENNReal.mul_ne_top (by norm_num) (by norm_num)) (lintegral_mono (fun ω ↦ ?_))
    have hu (k : ℕ) : u k ω ≤ 1 := ENNReal.toReal_le_one (ENNReal.inv_le_one (by simp))
    have h_gap : (u n ω - u m ω)^2 / 4 ≤ (u n ω + u m ω) / 2 - (2 / (u n ω⁻¹ + u m ω⁻¹)) := by
      field_simp; ring_nf; nlinarith
    convert ENNReal.ofReal_le_ofReal (mul_le_mul_of_nonneg_left h_gap (by norm_num)) using 1
    · ring
    · congr; field_simp; ring
  obtain ⟨v, n', -, h_lim⟩ := h_cau.exists_seq_tendsto_ae
  let Y_lim : Ω → ℝ≥0∞ := fun ω ↦ (ENNReal.ofReal (v ω))⁻¹ - 1
  refine ⟨fun i ↦ g (n' i), Y_lim, fun i ↦ (hg_conv (n' i)).mono (Set.range_subset_iff.2 fun m ↦ ?_), ?_, ?_⟩
  · exact ⟨m + (n' i - i), by linarith [n'.id_le i]⟩
  · exact (Lp.measurable v).ennreal_ofReal.inv.sub_const 1
  · filter_upwards [h_lim] with ω hω
    have h_v : v ω ≤ 1 := le_of_tendsto hω (eventually_of_forall fun i ↦ ENNReal.toReal_le_one (by simp))
    have : Tendsto (fun i ↦ (1 + g (n' i) ω)⁻¹) atTop (𝓝 (ENNReal.ofReal (v ω))) := by
      rw [ENNReal.tendsto_toReal_iff] at hω <;> try (intro i; simp)
      · exact hω
      · exact ENNReal.ofReal_ne_top
    convert ENNReal.Tendsto.sub_const (ENNReal.Tendsto.inv₀ this (by simp)) 1
    simp
