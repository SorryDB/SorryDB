theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp [partialSums_nil, findIdx_cons, findIdx_nil]
  | cons l L ih =>
    simp only [flatten_cons, partialSums_cons, findIdx_cons, getElem?_cons]
    if h : l.length > i then
      have : (map length (l :: L)).partialSums.findIdx (· > i) = 1 := by
        simp [findIdx_cons, h]
      simp [this, take_append, h]
    else
      have h' : (map length (l :: L)).partialSums.findIdx (· > i) =
               (map length L).partialSums.findIdx (· > i - l.length) + 1 := by
        simp [findIdx_cons, h]
        congr; funext x; simp; omega
      simp [h', take_append, h, ih (i - l.length)]
      omega
