    simp only [flatten_cons, partialSums_cons, findIdx_cons]
    if h : i < l.length then
      have h_idx : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by
        simp [partialSums_cons, findIdx_cons, h]
      simp [h_idx, h, take_append]
    else
      have h_idx : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =
          findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by
        simp [partialSums_cons, findIdx_cons, h]
        congr; funext x; simp; omega
      simp only [h_idx, Nat.add_sub_cancel]
      generalize h_idx' : findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums = idx
      have : idx > 0 := by
        rw [← h_idx', partialSums_cons, findIdx_cons]
        simp
      cases idx with
      | zero => contradiction
      | succ idx' =>
        simp [ih (i - l.length), h, getElem?_cons, take_cons, take_append, flatten_cons]
        congr
        omega
