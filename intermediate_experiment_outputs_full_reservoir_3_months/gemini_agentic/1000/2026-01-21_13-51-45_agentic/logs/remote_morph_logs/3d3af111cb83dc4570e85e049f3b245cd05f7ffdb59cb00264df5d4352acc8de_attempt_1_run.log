lemma IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  have h_disj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.subgraph
  have h_deg : ∀ v ∈ V(C), (E(C, v) ∩ M).encard = 1 ∧ (E(C, v) ∩ M').encard = 1 := by
    intro v hv
    have h2 := hC.eDegree_eq_two hv
    have h_union : E(C, v) = (E(C, v) ∩ M) ∪ (E(C, v) ∩ M') := by
      refine Subset.antisymm ?_ (union_subset (inter_subset_left _ _) (inter_subset_left _ _))
      intro e he; have h_mem : e ∈ M ∆ M' := (hCG.subgraph.edge_subset he).1
      cases h_mem with | inl hl => left; exact ⟨he, hl⟩ | inr hr => right; exact ⟨he, hr⟩
    have h_disj_v : Disjoint (E(C, v) ∩ M) (E(C, v) ∩ M') := h_disj.mono (inter_subset_left _ _) (inter_subset_left _ _)
    rw [h_union, encard_union h_disj_v] at h2
    have hM1 := hM.degree_le_one v
    have hM'1 := hM'.degree_le_one v
    constructor
    · apply le_antisymm hM1; rw [← ENat.add_le_add_iff_right (h := ENat.one_ne_top)]; exact h2.symm.le.trans (add_le_add_left hM'1 _)
    · apply le_antisymm hM'1; rw [← ENat.add_le_add_iff_left (h := ENat.one_ne_top)]; exact h2.symm.le.trans (add_le_add_right hM1 _)
  have h_sum : 2 * (E(C) ∩ M).encard = 2 * (E(C) ∩ M').encard := by
    rw [← sum_eDegree_eq_two_encard_inc, ← sum_eDegree_eq_two_encard_inc]
    · apply sum_encard_inc_congr (G := C)
      intro v hv; rw [(h_deg v hv).1, (h_deg v hv).2]
    · exact inter_subset_left _ _
    · exact inter_subset_left _ _
  exact ENat.mul_left_cancel h_sum two_ne_zero ENat.two_ne_top

