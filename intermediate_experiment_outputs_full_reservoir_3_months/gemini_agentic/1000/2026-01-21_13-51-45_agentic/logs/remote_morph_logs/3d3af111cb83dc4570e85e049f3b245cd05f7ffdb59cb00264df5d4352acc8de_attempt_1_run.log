lemma IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  obtain ⟨P, hP, hV, hE⟩ := hC
  have h_sub : C ≤ hM.restrict₂ hM' := hCG.1.1.1
  have h_disj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC h_sub
  have h_union : E(C) = (E(C) ∩ M) ∪ (E(C) ∩ M') := by
    refine Subset.antisymm ?_ (union_subset (inter_subset_left _ _) (inter_subset_left _ _))
    intro e he
    have h_mem : e ∈ (M ∆ M') := (h_sub.le_E he).1
    cases h_mem with
    | inl hl => left; exact ⟨he, hl.1⟩
    | inr hr => right; exact ⟨he, hr.1⟩
  have h_deg : ∀ v ∈ V(C), (E(C, v) ∩ M).encard = 1 ∧ (E(C, v) ∩ M').encard = 1 := by
    intro v hv
    have h2 : (E(C, v)).encard = 2 := by
      rw [← eDegree_eq_encard_inc, hP.eDegree v (hV hv)]
      exact hP.loopless
    have h_union_v : E(C, v) = (E(C, v) ∩ M) ∪ (E(C, v) ∩ M') := by
      rw [← inter_union_distrib_left, ← h_union, inter_self]
    have h_disj_v : Disjoint (E(C, v) ∩ M) (E(C, v) ∩ M') := h_disj.mono (inter_subset_left _ _) (inter_subset_left _ _)
    rw [h_union_v, Set.encard_union h_disj_v] at h2
    have hM1 := (encard_le_encard (inter_subset_right E(C, v) M)).trans (hM.degree_le_one v)
    have hM'1 := (encard_le_encard (inter_subset_right E(C, v) M')).trans (hM'.degree_le_one v)
    constructor
    · apply le_antisymm hM1
      rw [← ENat.add_le_add_iff_right ENat.one_ne_top]
      exact h2.symm.le.trans (add_le_add_left hM'1 _)
    · apply le_antisymm hM'1
      rw [← ENat.add_le_add_iff_left ENat.one_ne_top]
      exact h2.symm.le.trans (add_le_add_right hM1 _)
  have h_sum : 2 * (E(C) ∩ M).encard = 2 * (E(C) ∩ M').encard := by
    rw [← sum_eDegree_eq_two_encard_inc (G := C) (S := (E(C) ∩ M)) (inter_subset_left _ _),
        ← sum_eDegree_eq_two_encard_inc (G := C) (S := (E(C) ∩ M')) (inter_subset_left _ _)]
    apply finsum_congr
    intro v
    by_cases hv : v ∈ V(C)
    · rw [(h_deg v hv).1, (h_deg v hv).2]
    · have h_empty : E(C, v) = ∅ := by rw [E_inc_eq_empty_iff]; exact hv
      rw [h_empty, empty_inter, encard_empty, empty_inter, encard_empty]
  exact (ENat.mul_eq_mul_left two_ne_zero ENat.two_ne_top).1 h_sum

