  have hEN : E N = N := by
    have : ∀ j : Fin N, c N j = 1 := by intro j; simp [c]
    simp [E, this]
  have : 2021 % 2 = 0 := by simpa [hEN] using h_parity N (Nat.le_refl _)
  simp at this
