import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let N := 2021
  let f (n : ℕ) := move^[n] (p, 0)
  let p_n n := (f n).1
  let k_n n := (f n).2
  let H (n : ℕ) : Finset (Fin N) := Finset.univ.filter (λ h_idx => (p_n n h_idx).val < n)
  let E (n : ℕ) : ℕ := (Finset.univ.filter (λ h_idx => h_idx ∈ H n ∧ h_idx + 1 ∈ H n)).card
  have hk_n (n : ℕ) : k_n n = (n : Fin N) := by
    induction n with | zero => rfl | succ n ih => simp [k_n, f, move, ih]
  have hE (n : ℕ) (hn : n < N) : E (n + 1) % 2 = E n % 2 := by
    let kn : Fin N := ⟨n, hn⟩
    let h_hole := (p_n n).symm kn
    let a := (p_n n).swapped kn |>.1
    let b := (p_n n).swapped kn |>.2
    have ha_neq_k : a ≠ kn := by intro heq; have := (p_n n).injective (by simp [Position.swapped, heq, h_hole]); simp [Fin.ext_iff] at this
    have hb_neq_k : b ≠ kn := by intro heq; have := (p_n n).injective (by simp [Position.swapped, heq, h_hole]); simp [Fin.ext_iff] at this
    have hab : a < kn ↔ b < kn := by
      let hk := h kn; simp [Position.nth, hk_n] at hk
      constructor <;> intro h'
      · exact (hk.1 h').lt_of_ne hb_neq_k
      · exact (hk.2 h').lt_of_ne ha_neq_k
    have hH : H (n + 1) = H n ∪ {h_hole} := by
      ext j; simp [H, p_n, f, move, hk_n, Position.swapped]
      by_cases hj : j = h_hole
      · simp [hj, hn]
      · by_cases hja : p_n n j = a <;> by_cases hjb : p_n n j = b
        · exfalso; exact (p_n n).injective.ne (by rwa [hja]) (by rwa [hjb, Position.swapped])
        · simp [hja, hj, hab, hn, a]
        · simp [hjb, hj, hab, hn, b]
        · have : p_n n j ≠ kn := (p_n n).injective.ne hj (by simp [h_hole])
          simp [hj, hja, hjb, hn, this, Nat.lt_succ_iff_lt_or_eq, Fin.ext_iff]
    have hnotH : h_hole ∉ H n := by simp [H, h_hole]
    have h_card := Finset.card_union_of_disjoint (Finset.disjoint_singleton_right.mpr hnotH)
    have : E (n + 1) = E n + (if h_hole - 1 ∈ H n then 1 else 0) + (if h_hole + 1 ∈ H n then 1 else 0) := by
      let Hn := H n; let Hn' := H (n + 1)
      have : Hn' = Hn ∪ {h_hole} := hH
      let P (S : Finset (Fin N)) (j : Fin N) := j ∈ S ∧ j + 1 ∈ S
      have h1 : h_hole - 1 ≠ h_hole := by simp [Fin.ext_iff]
      have h2 : h_hole + 1 ≠ h_hole := by simp [Fin.ext_iff]
      simp [E, this, P, hj, h1, h2, hnotH]
      rw [Finset.filter_union, Finset.filter_singleton, Finset.card_disjoint_union]
      · congr; ext j; by_cases hjh : j = h_hole - 1
        · simp [hjh, h1]; rfl
        · by_cases hjh2 : j = h_hole
          · simp [hjh2, hnotH]
          · simp [hjh, hjh2]; rfl
      · apply Finset.disjoint_filter_filter; exact Finset.disjoint_singleton_right.mpr hnotH
    simp [this, hab, H, h_hole, Position.swapped]
  have h_parity : E N % 2 = E 0 % 2 := by
    induction N with | zero => rfl | succ n ih =>
      rw [hE n (Nat.lt_succ_self n), ih]
  have hE0 : E 0 = 0 := by simp [E, H]
  have hEN : E N = N := by
    have : H N = Finset.univ := by ext j; simp [H, p_n, f]
    simp [E, this]
  simp [hEN, hE0] at h_parity
