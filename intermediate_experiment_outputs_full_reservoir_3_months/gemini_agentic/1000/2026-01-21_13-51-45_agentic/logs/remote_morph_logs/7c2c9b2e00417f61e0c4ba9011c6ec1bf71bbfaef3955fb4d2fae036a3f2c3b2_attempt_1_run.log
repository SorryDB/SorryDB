import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let N : ℕ := 2021
  by_contra! h
  let f (n : ℕ) := move^[n] (p, 0)
  let p_ (n : ℕ) := (f n).1
  let k_ (n : ℕ) := (f n).2
  have hk_ (n : ℕ) : k_ n = (n : Fin 2021) := by
    induction n with | zero => rfl | succ n ih => rw [Function.iterate_succ_apply, move, ih]; rfl
  have hab (n : Fin 2021) : ((p_ n).swapped n).1 < n ↔ ((p_ n).swapped n).2 < n := by
    let hn := h n
    let a := ((p_ n).swapped n).1
    let b := ((p_ n).swapped n).2
    have ha : a ≠ n := by
      let h_hole := (p_ n).symm n
      intro heq
      have : p_ n (h_hole - 1) = p_ n h_hole := by dsimp [Position.swapped] at a; rw [← a, heq, Equiv.apply_symm_apply]
      have : h_hole - 1 = h_hole := (p_ n).injective this
      exact (sub_eq_self.mp (Fin.ext this)).zero_ne_one.symm
    have hb : b ≠ n := by
      let h_hole := (p_ n).symm n
      intro heq
      have : p_ n (h_hole + 1) = p_ n h_hole := by dsimp [Position.swapped] at b; rw [← b, heq, Equiv.apply_symm_apply]
      have : h_hole + 1 = h_hole := (p_ n).injective this
      exact (add_left_eq_self.mp (Fin.ext this)).zero_ne_one.symm
    constructor <;> intro hw
    · exact (hn.1 hw).lt_of_ne hb.symm
    · exact (hn.2 hw).lt_of_ne ha.symm
  let S (n : ℕ) : Finset (Fin 2021) := Finset.univ.filter (λ h => p_ n h < (n : Fin 2021))
  let E (n : ℕ) : ℕ := (Finset.univ.filter (λ h => h ∈ S n ∧ h + 1 ∈ S n)).card
  have hS (n : ℕ) (hn : n < N) : S (n + 1) = S n ∪ {(p_ n).symm n} := by
    ext h_idx
    simp only [S, Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_union, Finset.mem_singleton]
    let h_n := (p_ n).symm n
    let a := ((p_ n).swapped n).1
    let b := ((p_ n).swapped n).2
    have p_next : p_ (n + 1) = (p_ n).trans (Equiv.swap a b) := by
      simp [p_, f, move, hk_]
    rw [p_next, Equiv.trans_apply, Equiv.swap_apply_def]
    by_cases hj : h_idx = h_n
    · simp [hj, hn, hk_]
    · have h_pnj : p_ n h_idx ≠ (n : Fin 2021) := (p_ n).injective.ne hj (Equiv.apply_symm_apply (p_ n) n).symm
      by_cases ha : p_ n h_idx = a
      · simp [ha, (hab n).mp, hn, hj, h_pnj, Nat.lt_succ_iff_lt_or_eq, Fin.ext_iff]
      · by_cases hb_case : p_ n h_idx = b
        · simp [hb_case, (hab n).mpr, hn, hj, h_pnj, Nat.lt_succ_iff_lt_or_eq, Fin.ext_iff]
        · simp [ha, hb_case, hn, hj, h_pnj, Nat.lt_succ_iff_lt_or_eq, Fin.ext_iff]
  have hE (n : ℕ) (hn : n < N) : E (n + 1) % 2 = E n % 2 := by
    let h_n := (p_ n).symm n
    have hn_not_S : h_n ∉ S n := by simp [S, h_n]
    have hSn : S (n + 1) = S n ∪ {h_n} := hS n hn
    have h1 : h_n - 1 ≠ h_n := by intro h; have : (1 : Fin 2021) = 0 := by simpa using Fin.ext h; simp at this
    have h2 : h_n + 1 ≠ h_n := by intro h; have : (1 : Fin 2021) = 0 := by simpa using Fin.ext h; simp at this
    have : E (n + 1) = E n + (if h_n - 1 ∈ S n then 1 else 0) + (if h_n + 1 ∈ S n then 1 else 0) := by
