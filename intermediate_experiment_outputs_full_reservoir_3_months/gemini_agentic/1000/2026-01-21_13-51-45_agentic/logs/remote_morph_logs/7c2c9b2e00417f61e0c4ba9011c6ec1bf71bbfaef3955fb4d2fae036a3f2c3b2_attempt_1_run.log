    apply this N (Nat.le_refl N)
  have hE0 : E 0 = 0 := by simp [E, S]
  have hEN : E N = N := by
    have : S N = Finset.univ := by ext; simp [S]
    simp [E, this]
  simp [hEN, hE0, N] at h_parity
