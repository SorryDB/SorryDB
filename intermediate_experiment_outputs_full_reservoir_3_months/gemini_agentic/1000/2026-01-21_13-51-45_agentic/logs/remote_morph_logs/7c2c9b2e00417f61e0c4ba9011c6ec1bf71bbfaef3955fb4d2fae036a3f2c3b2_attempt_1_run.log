import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let N : ℕ := 2021
  let f (n : ℕ) := move^[n] (p, 0)
  let p_ (n : ℕ) := (f n).1
  let k_ (n : ℕ) := (f n).2
  have hk_ (n : ℕ) : k_ n = (n : Fin N) := by
    induction n with | zero => rfl | succ n ih => simp [k_, f, move, ih]
  let H (n : ℕ) : Finset (Fin N) := Finset.univ.filter (λ h_idx => (p_ n h_idx).val < n)
  let E (n : ℕ) : ℕ := (Finset.univ.filter (λ h_idx => h_idx ∈ H n ∧ h_idx + 1 ∈ H n)).card
  have hE (n : ℕ) (hn : n < N) : E (n + 1) % 2 = E n % 2 := by
    let kn : Fin N := ⟨n, hn⟩
    let hn_hole := (p_ n).symm kn
    let w := (p_ n).swapped kn
    have h_w1_ne : w.1 ≠ kn := by
      rw [Position.swapped]
      apply (p_ n).injective.ne
      intro heq; have : (1 : Fin N) = 0 := by simpa using sub_eq_zero.mp heq
      simp at this
    have h_w2_ne : w.2 ≠ kn := by
      rw [Position.swapped]
      apply (p_ n).injective.ne
      intro heq; have : (1 : Fin N) = 0 := by simpa using add_eq_self.mp heq
      simp at this
    have hw_iff : w.1 < kn ↔ w.2 < kn := by
      let hk := h kn; simp [Position.nth, hk_] at hk
      constructor <;> intro hw
      · exact (hk.1 hw).lt_of_ne h_w2_ne.symm
      · exact (hk.2 hw).lt_of_ne h_w1_ne.symm
    have hH : H (n + 1) = H n ∪ {hn_hole} := by
      ext j; simp [H, f, move, hk_, Position.swapped]
      by_cases hj : j = hn_hole
      · simp [hj, hn, hk_]; exact Nat.lt_succ_self n
      · have : p_ n j ≠ kn := (p_ n).injective.ne hj (Equiv.apply_symm_apply (p_ n) kn).symm
        simp [hj, this, hn, hw_iff, Nat.lt_succ_iff_lt_or_eq, Fin.ext_iff]
    have hnotH : hn_hole ∉ H n := by simp [H, hn_hole]
    have : E (n + 1) = E n + (if hn_hole - 1 ∈ H n then 1 else 0) + (if hn_hole + 1 ∈ H n then 1 else 0) := by
      let P (S : Finset (Fin N)) (j : Fin N) := j ∈ S ∧ j + 1 ∈ S
      have h1 : hn_hole - 1 ≠ hn_hole := by intro heq; have : (1 : Fin N) = 0 := by simpa using sub_eq_zero.mp heq; simp at this
      have h2 : hn_hole + 1 ≠ hn_hole := by intro heq; have : (1 : Fin N) = 0 := by simpa using add_eq_self.mp heq; simp at this
      simp [E, hH, P, hj, h1, h2, hnotH, Finset.filter_union, Finset.filter_singleton]
      rw [Finset.card_disjoint_union]
      · congr; ext j; by_cases hjh : j = hn_hole - 1
        · simp [hjh, h1]
        · by_cases hjh2 : j = hn_hole
          · simp [hjh2, hnotH]
          · simp [hjh, hjh2]
      · apply Finset.disjoint_filter_filter; exact Finset.disjoint_singleton_right.mpr hnotH
    simp [this, hw_iff, H, Position.swapped]
  have h_parity : E N % 2 = E 0 % 2 := by
    induction N with | zero => rfl | succ n ih => rw [hE n (Nat.lt_succ_self n), ih]
  have hE0 : E 0 = 0 := by simp [E, H]
  have hEN : E N = N := by
    have : H N = Finset.univ := by ext j; simp [H]; apply (p_ N j).2
    simp [E, this]
  simp [hEN, hE0, N] at h_parity
