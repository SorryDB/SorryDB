import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let N := 2021
  let f n := move^[n] (p, 0)
  let p_ n := (f n).1
  let k_ n := (f n).2
  have hk_ (n : ℕ) : k_ n = (n : Fin N) := by
    induction n with | zero => rfl | succ n ih => rw [Function.iterate_succ_apply, move, ih]; rfl
  let H (n : ℕ) : Finset (Fin N) := Finset.univ.filter (λ h => (p_ n h).val < n)
  let E (n : ℕ) : ℕ := (Finset.univ.filter (λ h => h ∈ H n ∧ h + 1 ∈ H n)).card
  have hE (n : ℕ) (hn : n < N) : E (n + 1) % 2 = E n % 2 := by
    let kn : Fin N := ⟨n, hn⟩
    let hn_hole := (p_ n).symm kn
    let a := (p_ n).swapped kn |>.1
    let b := (p_ n).swapped kn |>.2
    have ha_ne : a ≠ kn := by
      intro heq; have := (p_ n).injective (by rw [Position.swapped] at heq; rw [← heq, Equiv.apply_symm_apply])
      exact (sub_eq_self.mp (Fin.ext this)).zero_ne_one.symm
    have hb_ne : b ≠ kn := by
      intro heq; have := (p_ n).injective (by rw [Position.swapped] at heq; rw [← heq, Equiv.apply_symm_apply])
      exact (add_left_eq_self.mp (Fin.ext this)).zero_ne_one.symm
    have hab : a < kn ↔ b < kn := by
      let hk := h kn; simp [Position.nth, hk_] at hk
      constructor <;> intro hw; exact (hk.1 hw).lt_of_ne hb_ne.symm; exact (hk.2 hw).lt_of_ne ha_ne.symm
    have hH : H (n + 1) = H n ∪ {hn_hole} := by
      ext j; simp [H, f, move, hk_, Position.swapped, hn, Nat.lt_succ_iff_lt_or_eq]
      by_cases hj : j = hn_hole
      · simp [hj, hn]
      · have : p_ n j ≠ kn := (p_ n).injective.ne hj (by simp [hn_hole])
        simp [hj, this, hab, Fin.ext_iff, hn]
    have hnotH : hn_hole ∉ H n := by simp [H, hn_hole]
    have h_card : E (n + 1) = E n + (if a < kn then 1 else 0) + (if b < kn then 1 else 0) := by
      simp [E, hH]
      let P j := j ∈ H n ∧ j + 1 ∈ H n
      let Q j := (j = hn_hole - 1 ∧ a < kn) ∨ (j = hn_hole ∧ b < kn)
      have h1 : a < kn ↔ hn_hole - 1 ∈ H n := by simp [H, a, hn_hole]
      have h2 : b < kn ↔ hn_hole + 1 ∈ H n := by simp [H, b, hn_hole]
      have hP : ∀ j, j ∈ H (n + 1) ∧ j + 1 ∈ H (n + 1) ↔ P j ∨ Q j := by
        intro j; simp [P, Q, hH, hnotH, h1, h2]; constructor
        · intro ⟨hj, hj1⟩; by_cases h : j = hn_hole
          · right; right; exact ⟨h, by rwa [h] at hj1⟩
          · by_cases h1 : j + 1 = hn_hole
            · right; left; exact ⟨h1, by rwa [h1] at hj⟩
            · left; exact ⟨by rwa [hH, Finset.mem_union, Finset.mem_singleton] at hj, by rwa [hH, Finset.mem_union, Finset.mem_singleton] at hj1⟩
        · intro h; rcases h with h | ⟨h, -⟩ | ⟨h, -⟩ <;> (simp [hH, h]; try simp [h.1]; try simp [h.2])
      rw [Finset.filter_congr hP, Finset.card_union_eq_card_add_card_minus_card]
      have h_disj : (Finset.univ.filter P ∩ Finset.univ.filter Q) = ∅ := by
        ext j; simp [P, Q, hnotH]; intro h; rcases h with ⟨-, -, (⟨hj, -⟩ | ⟨hj, -⟩)⟩ <;> (rw [hj] at hnotH; exact hnotH (by assumption))
      rw [h_disj]; simp [Q]; by_cases hab' : a < kn
      · simp [hab, hab']; split_ifs with h_eq
        · have : (1 : Fin N) = 0 := by simpa using Fin.ext h_eq
          exact this.zero_ne_one.symm
        · rfl
      · simp [hab, hab']
    simp [h_card, hab]
  have h_parity : E N % 2 = E 0 % 2 := by
    have : ∀ n ≤ N, E n % 2 = E 0 % 2 := by
      intro n hn; induction n with
      | zero => rfl
      | succ n ih => rw [hE n (Nat.lt_of_succ_le hn), ih (Nat.le_of_lt (Nat.lt_of_succ_le hn))]
    apply this N (Nat.le_refl N)
  have hE0 : E 0 = 0 := by simp [E, H]
  have hEN : E N = N := by
    have : H N = Finset.univ := by ext j; simp [H]
    simp [E, this]
  simp [hEN, hE0, N] at h_parity

