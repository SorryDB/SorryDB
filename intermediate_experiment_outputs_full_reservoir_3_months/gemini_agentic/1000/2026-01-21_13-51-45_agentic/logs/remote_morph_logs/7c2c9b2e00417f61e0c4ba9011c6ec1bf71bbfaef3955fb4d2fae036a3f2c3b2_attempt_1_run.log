import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let N : ℕ := 2021
  let p_ (n : ℕ) : Position := (move^[n] (p, 0)).1
  have hk_ (n : ℕ) : (move^[n] (p, 0)).2 = (n : Fin N) := by
    induction n with | zero => rfl | succ n ih => rw [Function.iterate_succ_apply', move, ih]; rfl
  have hab (n : Fin N) : ((p.nth n).swapped n).1 < n ↔ ((p.nth n).swapped n).2 < n := by
    let a := ((p.nth n).swapped n).1; let b := ((p.nth n).swapped n).2
    specialize h n; have ha : a ≠ n := by
      intro heq; let h_h := (p.nth n).symm n
      have : p.nth n (h_h - 1) = p.nth n h_h := by simpa [a, Position.swapped, h_h] using heq
      exact (Fin.sub_one_ne_self h_h) ((p.nth n).injective this)
    have hb : b ≠ n := by
      intro heq; let h_h := (p.nth n).symm n
      have : p.nth n (h_h + 1) = p.nth n h_h := by simpa [b, Position.swapped, h_h] using heq
      exact (Fin.add_one_ne_self h_h) ((p.nth n).injective this)
    constructor <;> intro hw
    · exact (h.1 hw).lt_of_ne hb.symm
    · exact (h.2 hw).lt_of_ne ha.symm
  let c (n : ℕ) (j : Fin N) : ℕ := if (p_ n j).val < n then 1 else 0
  let E (n : ℕ) : ℕ := ∑ j : Fin N, c n j * c n (j + 1)
  have hE (n : ℕ) (hn : n < N) : E (n + 1) % 2 = E n % 2 := by
    let kn : Fin N := ⟨n, hn⟩; let h_n := (p_ n).symm kn
    have hp_next : p_ (n + 1) = (p_ n).trans (Equiv.swap (p_ n (h_n - 1)) (p_ n (h_n + 1))) := by
      show (move (p_ n, (n : Fin N))).1 = _; simp [move, Position.swapped, kn, h_n, hk_]
    have hab_n : p_ n (h_n - 1) < kn ↔ p_ n (h_n + 1) < kn := by
      have : p_ n = p.nth kn := by rw [Position.nth, p_]; congr; rw [hk_]
      rw [this]; exact hab kn
    have h_c_eq (j : Fin N) (hj : j ≠ h_n) : c (n + 1) j = c n j := by
      simp [c, hp_next, Equiv.swap_apply_def]; split_ifs <;> try simp [*]
      · simp [hj, hab_n, kn]
      · simp [hj, ← hab_n, kn]
      · have : p_ n j ≠ kn := (p_ n).injective.ne hj (by simp [h_n])
        simp [Nat.lt_succ_iff_lt_or_eq, this, kn]
    have h_c_h : c (n + 1) h_n = 1 ∧ c n h_n = 0 := by
      simp [c, kn, p_, f, move, hk_]; have : p_ (n + 1) h_n = kn := by
        simp [hp_next, Equiv.trans_apply, Equiv.swap_apply_def, h_n]
      simp [this, kn]
    have : E (n + 1) = E n + c n (h_n - 1) + c n (h_n + 1) := by
      let c1 := c (n + 1); let c0 := c n
      have h_sum (f : Fin N → ℕ) : ∑ j, f j = (∑ j in {h_n, h_n - 1}, f j) + ∑ j in Finset.univ \ {h_n, h_n - 1}, f j := by
