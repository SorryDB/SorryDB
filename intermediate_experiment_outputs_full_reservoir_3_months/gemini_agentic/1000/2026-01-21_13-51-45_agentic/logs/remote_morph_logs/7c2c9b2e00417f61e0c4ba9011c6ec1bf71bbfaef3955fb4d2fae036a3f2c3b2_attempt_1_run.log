      let P h := h ∈ S n ∧ h + 1 ∈ S n
      let Q h := (h = h_n - 1 ∧ h_n - 1 + 1 ∈ S n ∪ {h_n}) ∨ (h = h_n ∧ h + 1 ∈ S n ∪ {h_n})
      rw [Finset.filter_union, Finset.card_disjoint_union]
      · congr; simp [Q, h1, h2, hn_not_S]
      · apply Finset.disjoint_filter_filter; exact Finset.disjoint_singleton_right.mpr hn_not_S
    rw [this, Nat.add_mod, Nat.add_mod, (hab n).mp]
    · simp; rfl
    · simp [S, Position.swapped]
    · simp [S, Position.swapped]
  have h_parity : E N % 2 = E 0 % 2 := by
    have : ∀ n ≤ N, E n % 2 = E 0 % 2 := by
      intro n hn
      induction n with
      | zero => rfl
