import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let p_ (n : ℕ) : Position := (move^[n] (p, 0)).1
  let k_ (n : ℕ) : Fin 2021 := (move^[n] (p, 0)).2
  have hk_ (n : ℕ) : k_ n = (n : Fin 2021) := by
    induction n with | zero => rfl | succ n ih => rw [Function.iterate_succ_apply', move, ih]; rfl
  have hab (n : ℕ) (hn : n < 2021) :
      ((p_ n).swapped ⟨n, hn⟩).1 < ⟨n, hn⟩ ↔ ((p_ n).swapped ⟨n, hn⟩).2 < ⟨n, hn⟩ := by
    let k : Fin 2021 := ⟨n, hn⟩
    have hpn : p_ n = p.nth k := by rw [Position.nth, p_]
    let a := (p.nth k).swapped k .1; let b := (p.nth k).swapped k .2
    specialize h k; rw [hpn] at h
    have ha : a ≠ k := by
      intro heq; let h_h := (p.nth k).symm k; have : p.nth k (h_h - 1) = p.nth k h_h := by simpa [a, Position.swapped, h_h] using heq
      exact (Fin.sub_one_ne_self h_h) ((p.nth k).injective this)
    have hb : b ≠ k := by
      intro heq; let h_h := (p.nth k).symm k; have : p.nth k (h_h + 1) = p.nth k h_h := by simpa [b, Position.swapped, h_h] using heq
      exact (Fin.add_one_ne_self h_h) ((p.nth k).injective this)
    constructor <;> intro hw
    · exact (h.1 hw).lt_of_ne hb.symm
    · exact (h.2 hw).lt_of_ne ha.symm
  let c (n : ℕ) (j : Fin 2021) : ℕ := if (p_ n j).val < n then 1 else 0
  let E (n : ℕ) : ℕ := ∑ j : Fin 2021, c n j * c n (j + 1)
  have h_cn (n : ℕ) (hn : n < 2021) : ∀ j, c (n + 1) j = c n j + (if j = (p_ n).symm ⟨n, hn⟩ then 1 else 0) := by
    let k : Fin 2021 := ⟨n, hn⟩; let h_n := (p_ n).symm k
    let a := (p_ n).swapped k .1; let b := (p_ n).swapped k .2
    have hp_next : p_ (n + 1) = (p_ n).trans (Equiv.swap a b) := by simp [p_, move, hk_, k]
    intro j; simp [c, hp_next, Equiv.trans_apply, Equiv.swap_apply_def]
    by_cases hj : j = h_n
    · simp [hj, k]; rw [if_pos hn]
    · have h_pnj : p_ n j ≠ k := (p_ n).injective.ne hj (by simp [h_n])
      simp [hj, Nat.lt_succ_iff_lt_or_eq, h_pnj]
      by_cases ha_ : p_ n j = a <;> by_cases hb_ : p_ n j = b <;> simp [*]
      · exact (hab n hn).symm
      · exact hab n hn
  have hE (n : ℕ) (hn : n < 2021) : E (n + 1) % 2 = E n % 2 := by
    let h_n := (p_ n).symm ⟨n, hn⟩
    have : E (n + 1) = ∑ j, (c n j + if j = h_n then 1 else 0) * (c n (j + 1) + if j + 1 = h_n then 1 else 0) := by
      simp [E, h_cn n hn]
    rw [this]; simp [add_mul, mul_add, Finset.sum_add_distrib]
    simp [Finset.sum_ite, (by simp : h_n + 1 ≠ h_n)]; rw [← hab n hn]; simp [c, (p_ n).apply_symm_apply]
  have h_parity : E 2021 % 2 = E 0 % 2 := by
    induction 2021 with | zero => rfl | succ n ih => rw [hE n (Nat.lt_succ_self n), ih]
  have hE0 : E 0 = 0 := by simp [E, c]
  have hEN : E 2021 = 2021 := by
    have : ∀ j : Fin 2021, c 2021 j = 1 := by intro j; simp [c]
    simp [E, this]
  simp [hE0, hEN] at h_parity
