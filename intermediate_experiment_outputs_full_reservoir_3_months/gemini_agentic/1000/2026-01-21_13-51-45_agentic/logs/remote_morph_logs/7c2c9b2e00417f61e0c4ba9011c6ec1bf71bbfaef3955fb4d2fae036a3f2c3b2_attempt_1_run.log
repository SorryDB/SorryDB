      have h1 : h_n - 1 ≠ h_n := Fin.sub_one_ne_self h_n
      have : ∑ j in Finset.univ \ {h_n, h_n - 1}, c1 j * c1 (j + 1) = ∑ j in Finset.univ \ {h_n, h_n - 1}, c0 j * c0 (j + 1) := by
