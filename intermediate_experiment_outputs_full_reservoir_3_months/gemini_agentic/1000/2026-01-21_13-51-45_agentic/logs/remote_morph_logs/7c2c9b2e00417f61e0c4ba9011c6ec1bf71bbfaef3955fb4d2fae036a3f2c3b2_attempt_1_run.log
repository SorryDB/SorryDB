    let a := ((p.nth k).swapped k).1; let b := ((p.nth k).swapped k).2
    have ha : a ≠ k := by
      let h_h := (p.nth k).symm k; intro heq
      have : h_h - 1 = h_h := (p.nth k).injective heq
      have : (1 : Fin 2021) = 0 := by simpa [Fin.sub_eq_iff_eq_add] using this
      simp [Fin.ext_iff] at this
    have hb : b ≠ k := by
