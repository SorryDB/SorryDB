import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k + 1) : ZMod 5) * 3 ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k) : ZMod 5) * 3 ^ k
  have h1 : ∀ m, s (m + 1) = s m + c m := by
    intro m; simp [s, c, ← Finset.sum_add_distrib]
    rw [Finset.sum_range_succ]; simp [Nat.choose_succ_succ, Nat.choose_eq_zero_of_lt, add_comm]
  have h2 : ∀ m, c (m + 1) = 3 * s m + c m := by
    intro m; rw [c, s, Finset.sum_range_succ' _ (m + 1), Nat.choose_zero_right]
    simp [Nat.choose_succ_succ, Finset.sum_add_distrib, Finset.mul_sum, pow_succ, mul_assoc]
    rw [Finset.sum_range_succ]; simp [Nat.choose_eq_zero_of_lt, add_comm]
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [h1 (m + 1), h2 m, h1 m]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; iterate 5 rw [h_rec]; ring
  have h3 : ∀ (x : ZMod 5), 3 * x = 0 ↔ x = 0 := by decide
  have s0 : s 0 = 0 := by simp [s]
  have s1 : s 1 = 1 := by rw [s]; simp [Finset.sum_range_succ]; decide
  have s2 : s 2 = 2 := by rw [h_rec 0, s1, s0]; decide
  have s3 : s 3 = 1 := by rw [h_rec 1, s2, s1]; decide
  have s4 : s 4 = 1 := by rw [h_rec 2, s3, s2]; decide
  have s5 : s 5 = 4 := by rw [h_rec 3, s4, s3]; decide
  have h_odd : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    induction' m using Nat.strong_induction_on with m ih
    match m with
    | 0 | 2 | 4 => simp at hm
    | 1 => simp [s1]
    | 3 => simp [s3]
    | 5 => simp [s5]
    | n + 6 =>
      rw [h_s6, h3]
      apply ih n (by linarith)
      simp at hm; exact hm
  intro h_dvd
  have h_zero : s (2 * n + 1) = 0 := by
    rw [← ZMod.eq_zero_iff_dvd] at h_dvd
    simp [s]; rw [← h_dvd]; push_cast
    apply (Finset.sum_subset (Finset.range_mono (by linarith)) _).symm
    · intro k hk hkn; simp at hk hkn
      rw [Nat.choose_eq_zero_of_lt (by linarith)]; simp
    · intro k _; rw [pow_mul]; simp; rfl
  exact h_odd (2 * n + 1) (by simp) h_zero

