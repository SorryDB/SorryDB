open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k
  have hs : ∀ m, s (m + 1) = s m + c m := by
    intro m; unfold s c
    simp only [Nat.choose_succ_succ, Nat.cast_add, add_mul, Finset.sum_add_distrib]
    rw [Finset.sum_range_succ (fun k => (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k) (m + 1)]
    rw [Finset.sum_range_succ (fun k => (m.choose (2 * k) : ZMod 5) * 3 ^ k) (m + 1)]
    rw [Nat.choose_eq_zero_of_lt (by linarith), Nat.choose_eq_zero_of_lt (by linarith)]
    simp only [Nat.cast_zero, zero_mul, add_zero]
    rw [add_comm]
  have hc : ∀ m, c (m + 1) = 3 * s m + c m := by
    intro m; unfold s c
    rw [Finset.sum_range_succ' (fun k => (Nat.choose (m + 1) (2 * k) : ZMod 5) * 3 ^ k) (m + 1)]
    simp only [Nat.choose_zero_right, Nat.cast_one, pow_zero, one_mul]
    rw [Finset.sum_range_succ' (fun k => (Nat.choose m (2 * k) : ZMod 5) * 3 ^ k) (m + 1)]
    simp only [Nat.choose_zero_right, Nat.cast_one, pow_zero, one_mul]
    rw [Finset.mul_sum, ← Finset.sum_add_distrib]
    simp only [← pow_succ]
    apply (add_left_inj (1 : ZMod 5)).mpr
    rw [Finset.sum_range_succ (fun k => (m.choose (2 * k + 2) : ZMod 5) * 3 ^ (k + 1)) m]
    rw [Nat.choose_eq_zero_of_lt (by linarith), Nat.cast_zero, zero_mul, add_zero]
    apply Finset.sum_congr rfl
    intro k hk; rw [Nat.choose_succ_succ, Nat.cast_add, add_mul]; ring
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [hs (m + 1), hc m, hs m]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; rw [h_rec (m + 4), h_rec (m + 3), h_rec (m + 2), h_rec (m + 1), h_rec m]; ring
  have h_not_zero : ∀ m, s (2 * m + 1) ≠ 0 := by
    intro m; induction' m using Nat.strong_induction_on with m ih
    match m with
    | 0 => unfold s; simp; decide
    | 1 => unfold s; simp; decide
    | 2 => unfold s; simp; decide
    | k + 3 =>
      have h_step : s (2 * (k + 3) + 1) = 3 * s (2 * k + 1) := by
        have : 2 * (k + 3) + 1 = (2 * k + 1) + 6 := by ring
        rw [this, h_s6]
      rw [h_step]; apply mul_ne_zero (by decide); apply ih k (by linarith)
  intro h_dvd
  have h_zmod : (∑ k ∈ Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k) = 0 := by
    have h1 : (↑(∑ k ∈ Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 2 ^ (3 * k)) : ZMod 5) = 0 := by
      rwa [← ZMod.nat_cast_zmod_eq_zero_iff_dvd]
    push_cast at h1
    have h2 : (2 : ZMod 5) ^ 3 = 3 := by decide
    simp_rw [pow_mul, h2] at h1; exact h1
  have h_s : s (2 * n + 1) = 0 := by
    unfold s; rw [← h_zmod]; apply Finset.sum_subset
    · apply Finset.range_mono; linarith
    · intro k hk hkn; simp only [Finset.mem_range] at hk hkn
      rw [Nat.choose_eq_zero_of_lt (by linarith), Nat.cast_zero, zero_mul]
  exact h_not_zero n h_s
