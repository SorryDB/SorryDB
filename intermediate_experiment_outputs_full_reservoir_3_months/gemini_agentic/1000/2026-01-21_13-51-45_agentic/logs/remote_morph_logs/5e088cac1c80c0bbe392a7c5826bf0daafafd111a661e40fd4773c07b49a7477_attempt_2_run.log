theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k + 1) : ZMod 5) * (3 : ZMod 5) ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k) : ZMod 5) * (3 : ZMod 5) ^ k
  have h1 : ∀ m, s (m + 1) = s m + c m := by
    intro m
    simp [s, c, ← Finset.sum_add_distrib, Nat.choose_succ_succ]
    rw [Finset.sum_range_succ]
    simp [Nat.choose_eq_zero_of_lt]
  have h2 : ∀ m, c (m + 1) = 3 * s m + c m := by
    intro m
    simp [s, c, Finset.sum_range_succ', Nat.choose_succ_succ, Nat.choose_zero_right]
    rw [Finset.sum_add_distrib, Finset.mul_sum]
    simp [← Finset.sum_add_distrib, pow_succ, mul_assoc]
    rw [Finset.sum_range_succ]
    simp [Nat.choose_eq_zero_of_lt]
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [h1 (m + 1), h2 m, h1 m]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; repeat (rw [h_rec]); ring
  have s0 : s 0 = 0 := by simp [s]
  have s1 : s 1 = 1 := by simp [s, Nat.choose_zero_right]; decide
  have s2 : s 2 = 2 := by rw [h_rec 0, s1, s0]; decide
  have s3 : s 3 = 1 := by rw [h_rec 1, s2, s1]; decide
  have s4 : s 4 = 1 := by rw [h_rec 2, s3, s2]; decide
  have s5 : s 5 = 4 := by rw [h_rec 3, s4, s3]; decide
  have h_odd : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    induction m using Nat.strong_induction_on with | h m ih =>
    if h6 : m < 6 then
      match m with
      | 1 => simp [s1]
      | 3 => simp [s3]
      | 5 => simp [s5]
      | 0 | 2 | 4 => simp [Nat.mod_eq_of_lt] at hm
      | _ => linarith
    else
      have hge : m ≥ 6 := Nat.ge_of_not_lt h6
      have h_m6 : (m - 6) % 2 = 1 := by rw [Nat.sub_mod, hm]; rfl; exact hge
      rw [← Nat.sub_add_cancel hge, h_s6]
      apply mul_ne_zero (by decide)
      apply ih (m - 6) (Nat.sub_lt_of_pos_curr m 6 (by decide)) h_m6
  intro h_dvd
  have h_zero : s (2 * n + 1) = 0 := by
    rw [← ZMod.nat_cast_eq_zero_iff _ 5] at h_dvd
    simp [s]
    rw [← h_dvd]
    push_cast
    apply Finset.sum_subset
    · apply Finset.range_mono; linarith
    · intro k hk hkn; simp at hk hkn
      rw [Nat.choose_eq_zero_of_lt]; simp; linarith; linarith
    · intro k _; congr; rw [pow_mul]; rfl
  exact h_odd (2 * n + 1) (by simp) h_zero

