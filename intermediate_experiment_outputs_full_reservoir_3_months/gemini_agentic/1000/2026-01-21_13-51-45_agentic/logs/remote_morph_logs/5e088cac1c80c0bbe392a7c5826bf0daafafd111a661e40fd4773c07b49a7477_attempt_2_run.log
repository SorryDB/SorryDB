import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k in Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k in Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k
  have hs0 : s 0 = 0 := by simp [s]
  have hc0 : c 0 = 1 := by simp [c, Finset.sum_range_succ]
  have h : ∀ m, s (m + 1) = s m + c m ∧ c (m + 1) = 3 * s m + c m := by
    intro m
    constructor
    · simp [s, c, Nat.choose_succ_succ, Finset.sum_add_distrib]
      simp [Finset.sum_range_succ]
    · simp [s, c, Finset.sum_range_succ', Nat.choose_succ_succ, Finset.sum_add_distrib, pow_succ, Finset.mul_sum]
      rw [Finset.sum_range_succ]
      simp [Nat.choose_zero_right, Nat.choose_succ_succ]
      ring
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [(h (m + 1)).1, (h (m + 1)).2, (h m).1]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; rw [h_rec (m + 4), h_rec (m + 3), h_rec (m + 2), h_rec (m + 1), h_rec m]; ring
  have h_3x : ∀ {x : ZMod 5}, x ≠ 0 ↔ 3 * x ≠ 0 := by decide
  have h_not_zero : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    induction' m using Nat.strong_induction_on with m ih
    match m with
    | 0 | 2 | 4 => simp at hm
    | 1 => unfold s; simp [Finset.sum_range_succ]; decide
    | 3 => unfold s; simp [Finset.sum_range_succ]; decide
    | 5 => unfold s; simp [Finset.sum_range_succ]; decide
    | k + 6 =>
      have hk : k < k + 6 := by linarith
      have hkm : k % 2 = 1 := by rw [Nat.add_mod] at hm; simp at hm; exact hm
      rw [h_s6, ← h_3x]
      exact ih k hk hkm
  intro h_dvd
  rw [← ZMod.nat_cast_eq_zero_iff] at h_dvd
  have h_s : s (2 * n + 1) = 0 := by
    unfold s
    apply (Finset.sum_subset (Finset.range_mono (by linarith)) _).symm
    · intro k hk hkn; simp at hk hkn
      rw [Nat.choose_eq_zero_of_lt (by linarith)]; simp
    · rw [← h_dvd]; push_cast; apply Finset.sum_congr rfl
      intro k _; congr; rw [pow_mul]; rw [show (2^3 : ZMod 5) = 3 by decide]
  exact h_not_zero (2 * n + 1) (by simp) h_s

