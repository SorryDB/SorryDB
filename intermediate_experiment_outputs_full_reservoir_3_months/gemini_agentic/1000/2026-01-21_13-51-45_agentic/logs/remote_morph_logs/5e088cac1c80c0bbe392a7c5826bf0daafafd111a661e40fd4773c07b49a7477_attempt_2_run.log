import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s : ℕ → ZMod 5
    | 0 => 0
    | 1 => 1
    | (m + 2) => 2 * s (m + 1) + 2 * s m
  have h_sum : (∑ k ∈ Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) * 8 ^ k : ℤ)) ≡ (s (2 * n + 1) : ZMod 5).val [ZMOD 5] := by
    let C : ℕ → ZMod 5
      | 0 => 1
      | (m + 1) => C m + 3 * s m
    have hS1 : s 1 = 1 := rfl
    have hC1 : C 1 = 1 := rfl
    have hS : ∀ m, s (m + 1) = s m + C m := by
      intro m; induction m with | zero => rfl | succ m ih => simp [s, C]; rw [ih]; ring
    have hC : ∀ m, C (m + 1) = C m + 3 * s m := fun m => rfl
    have h_both : ∀ m, s m = ∑ k in Finset.range (m + 1), (m.choose (2 * k + 1) * (3 : ZMod 5) ^ k) ∧
                       C m = ∑ k in Finset.range (m + 1), (m.choose (2 * k) * (3 : ZMod 5) ^ k) := by
      intro m; induction m with
      | zero => simp [s, C]
      | succ m ih =>
        constructor
        · rw [hS, ih.1, ih.2, ← Finset.sum_add_distrib]
          apply Finset.sum_congr rfl; intro k _; rw [← Nat.choose_succ_succ]; ring
        · rw [hC, ih.1, ih.2]
          simp [Finset.sum_range_succ, Nat.choose_succ_self]
          rw [Finset.mul_sum, ← Finset.sum_add_distrib]
          simp [Nat.choose_succ_zero]
          apply Finset.sum_congr rfl; intro k hk
          rw [Nat.choose_succ_succ (n := m) (k := 2*k + 1), add_comm]
          ring
    have h_s_val := (h_both (2 * n + 1)).1
    have : (8 : ZMod 5) = 3 := rfl
    simp [this] at h_s_val
    rw [h_s_val]
    exact ZMod.eq_iff_modEq_nat.mp rfl
  have s_6m : ∀ m, s (m + 6) = 3 * s m := by
    intro m
    repeat rw [s]
    ring
  have s_odd : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    let m6 := m % 6
    have h_m6 : m = 6 * (m / 6) + m6 := (Nat.div_add_mod m 6).symm
    rw [h_m6]
    induction m / 6 with
    | zero =>
      simp at hm
      have : m6 ∈ [1, 3, 5] := by
        revert hm; match m6 with | 0|1|2|3|4|5 => decide
      rcases this with rfl | rfl | rfl <;> decide
    | succ k ih =>
      rw [Nat.mul_succ, ← add_assoc, s_6m]
      simp [ih]
  intro h
  have h_s_zero : s (2 * n + 1) = 0 := by
    have h_mod := h_sum
    rw [h] at h_mod
    exact mod_cast h_mod
  apply s_odd (2 * n + 1)
  · simp
  · exact h_s_zero

