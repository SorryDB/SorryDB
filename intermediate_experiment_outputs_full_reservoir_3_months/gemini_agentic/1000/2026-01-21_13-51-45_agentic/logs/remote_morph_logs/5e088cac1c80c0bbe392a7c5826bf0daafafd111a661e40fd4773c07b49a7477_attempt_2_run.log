import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k + 1) : ZMod 5) * (3 : ZMod 5) ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (Nat.choose m (2 * k) : ZMod 5) * (3 : ZMod 5) ^ k
  have h1 : ∀ m, s (m + 1) = s m + c m := by
    intro m
    simp [s, c, Finset.sum_add_distrib]
    rw [Finset.sum_range_succ]
    simp [Nat.choose_succ_succ, Nat.choose_eq_zero_of_lt]
  have h2 : ∀ m, c (m + 1) = 3 * s m + c m := by
    intro m
    simp [s, c, Finset.sum_range_succ', Nat.choose_succ_succ, Nat.choose_zero_right, Finset.sum_add_distrib, Finset.mul_sum, pow_succ, mul_assoc]
    rw [Finset.sum_range_succ]
    simp [Nat.choose_eq_zero_of_lt]
    ring
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [h1 (m + 1), h2 m, h1 m]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; rw [h_rec (m + 4), h_rec (m + 3), h_rec (m + 2), h_rec (m + 1), h_rec m]; ring
  have s0 : s 0 = 0 := by simp [s]
  have s1 : s 1 = 1 := by
    simp [s, Finset.sum_range_succ]
    decide
  have s2 : s 2 = 2 := by rw [h_rec 0, s1, s0]; ring
  have s3 : s 3 = 1 := by rw [h_rec 1, s2, s1]; ring
  have s4 : s 4 = 1 := by rw [h_rec 2, s3, s2]; ring
  have s5 : s 5 = 4 := by rw [h_rec 3, s4, s3]; ring
  have h_odd : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    induction' m using Nat.strong_induction_on with m ih
    match m with
    | 0 => simp at hm
    | 1 => simp [s1]
    | 2 => simp at hm
    | 3 => simp [s3]
    | 4 => simp at hm
    | 5 => simp [s5]
    | k + 6 =>
      have hm_k : k % 2 = 1 := by rw [Nat.add_mod_right] at hm; exact hm
      rw [h_s6]
      apply mul_ne_zero (by decide)
      apply ih k (by linarith) hm_k
  intro h_dvd
  have h_zero : s (2 * n + 1) = 0 := by
    rw [← ZMod.eq_zero_iff_dvd] at h_dvd
    simp [s]; rw [← h_dvd]; push_cast
    apply (Finset.sum_subset (Finset.range_mono (by linarith)) _).symm
    · intro k hk hkn; simp at hk hkn
      rw [Nat.choose_eq_zero_of_lt (by linarith)]; simp
    · intro k _; congr; rw [pow_mul]; rfl
  exact h_odd (2 * n + 1) (by simp) h_zero

