set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let c (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k
  have hs : ∀ m, s (m + 1) = s m + c m := by
    intro m; unfold s c
    simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib]
    rw [Finset.sum_range_succ _ (m + 1), Finset.sum_range_succ _ (m + 1)]
    have h1 : (m.choose (2 * m + 3) : ZMod 5) = 0 := Nat.choose_eq_zero_of_lt (by linarith)
    have h2 : (m.choose (2 * m + 2) : ZMod 5) = 0 := Nat.choose_eq_zero_of_lt (by linarith)
    simp only [h1, h2, Nat.cast_zero, zero_mul, add_zero]
  have hc : ∀ m, c (m + 1) = 3 * s m + c m := by
    intro m; unfold s c
    rw [Finset.sum_range_succ' _ (m + 1)]
    simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib, pow_succ, Finset.mul_sum]
    rw [Finset.sum_range_succ _ (m + 1)]
    have h1 : (m.choose (2 * m + 2) : ZMod 5) = 0 := Nat.choose_eq_zero_of_lt (by linarith)
    simp only [h1, Nat.cast_zero, zero_mul, add_zero, Nat.choose_zero_right, Nat.cast_one]
    rw [Finset.sum_range_succ' _ m]
    simp only [Nat.choose_zero_right, Nat.cast_one]
    ring
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m; rw [hs (m + 1), hc m, hs m]; ring
  have h_s6 : ∀ m, s (m + 6) = 3 * s m := by
    intro m; rw [h_rec (m + 4), h_rec (m + 3), h_rec (m + 2), h_rec (m + 1), h_rec m]; ring
  have h_not_zero : ∀ m, m % 2 = 1 → s m ≠ 0 := by
    intro m hm
    induction' m using Nat.strong_induction_on with m ih
    if h_lt : m < 6 then
      interval_cases m <;> (simp at hm || (unfold s; simp; decide))
    else
      have h_mod : (m - 6) % 2 = 1 := by
        rw [Nat.sub_mod (by linarith)]; rw [hm]; rfl
      rw [h_s6]
      have h3 : ∀ {x : ZMod 5}, 3 * x = 0 ↔ x = 0 := by decide
      rw [h3]
      apply ih (m - 6) (by linarith) h_mod
  intro h_dvd
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h_dvd
  apply h_not_zero (2 * n + 1) (by simp)
  unfold s; rw [← h_dvd]; push_cast
  apply Finset.sum_subset (Finset.range_mono (by linarith))
  · intro k hk hkn; simp only [Finset.mem_range] at hk hkn
    rw [Nat.choose_eq_zero_of_lt (by linarith), Nat.cast_zero, zero_mul]
  · intro k _; rw [pow_mul]; have : (2^3 : ZMod 5) = 3 := by decide; rw [this]

