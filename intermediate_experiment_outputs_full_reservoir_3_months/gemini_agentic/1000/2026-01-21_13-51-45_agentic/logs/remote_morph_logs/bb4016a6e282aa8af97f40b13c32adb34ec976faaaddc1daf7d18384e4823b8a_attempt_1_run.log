    have h_sk_gt : ∀ k ∈ Finset.Icc 2 (n - 2), (p : ℝ) < s k := sorry
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by
      rw [Nat.card_Icc]; omega
    have : (n - 3 : ℝ) * p = (Finset.Icc 2 (n - 2)).card * (p : ℝ) := by
      rw [h_card]; push_cast; rfl
