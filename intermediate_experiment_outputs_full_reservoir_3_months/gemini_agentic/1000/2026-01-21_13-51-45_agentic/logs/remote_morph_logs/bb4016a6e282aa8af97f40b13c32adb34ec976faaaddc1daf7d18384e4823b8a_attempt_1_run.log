  constructor
  · rw [lt_div_iff₀ hp_pos, h2d]
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by rw [Finset.card_Icc]; omega
    have : (n - 3 : ℝ) * p = ∑ k ∈ Finset.Icc 2 (n - 2), (p : ℝ) := by
