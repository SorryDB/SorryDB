import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (0 : ℝ) < p := by
    rw [hp]
    apply Finset.sum_pos
    · intro i _
      apply dist_pos.mpr; intro h_eq
      have h1 : (i + 1 : Fin n) ≠ i - 1 := by
        intro h; rw [Fin.ext_iff] at h; simp at h
        if n4 : n = 4 then subst n4; norm_num at h
        else have : n > 4 := by omega; have : 1 < n - 1 := by omega
             have := Nat.mod_eq_of_lt (show 1 < n by omega); omega
      have h2 : (i + 1 : Fin n) ≠ i := by
        intro h; rw [Fin.ext_iff] at h; simp at h
        have : 1 < n := by omega; have := Nat.mod_eq_of_lt this; omega
      have h_sign := hP i (i + 1) h1 h2
      rw [h_eq] at h_sign; simp at h_sign
    · exact Finset.univ_nonempty

  let s (k : ℕ) : ℝ := ∑ i : Fin n, dist (P i) (P (i + k))
  have h2d : (2 * d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), s k := by
    rw [hd]; push_cast; field_simp
    have : ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) =
           ∑ i, ∑ k ∈ Finset.Icc 2 (n - 2), dist (P i) (P (i + k)) := by
      apply Finset.sum_congr rfl
      intro i _
      let f : ℕ → Fin n := fun k => i + k
      have hf : ∀ k ∈ Finset.Icc 2 (n - 2), f k ∈ Finset.univ \ {i - 1, i, i + 1} := by
        intro k hk; simp; rw [Finset.Icc, Finset.mem_filter] at hk
        constructor
        · intro h; rw [Fin.ext_iff] at h; simp at h
          have : k < n := by omega
          rw [Nat.mod_eq_of_lt this] at h; omega
        · constructor
          · intro h; rw [Fin.ext_iff] at h; simp at h
            have : k < n := by omega
            rw [Nat.mod_eq_of_lt this] at h; omega
          · intro h; rw [Fin.ext_iff] at h; simp at h
            have : k < n := by omega
            rw [Nat.mod_eq_of_lt this] at h; omega
      rw [Finset.sum_nbinder (s := f)]; swap
      · intro k1 hk1 k2 hk2 h; rw [Fin.ext_iff] at h; simp at h
        have : k1 < n := by omega; have : k2 < n := by omega
        rw [Nat.mod_eq_of_lt this, Nat.mod_eq_of_lt this] at h; exact h
      · congr; apply Finset.ext; intro j
        constructor
        · intro hj; simp at hj; rw [Finset.mem_image]
          let k := (j.val + n - i.val) % n
          use k; constructor; swap; · rw [Fin.ext_iff]; simp [k]
          rw [Finset.mem_Icc]; have : n > 3 := hn
          if h0: k=0 then
            subst h0; simp at hj
          else if h1: k=1 then
            subst h1; simp at hj
          else if hn1: k=n-1 then
            subst hn1; simp at hj
          else omega
        · intro hj; rw [Finset.mem_image] at hj; obtain ⟨k, hk, rfl⟩ := hj; apply hf k hk
    rw [this, Finset.sum_comm]; rfl

  have h_sk_gt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : (p : ℝ) < s k := sorry
  have h_sk_lt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : s k < (min (k : ℝ) (n - k : ℝ)) * p := sorry
  have h_sum_min : ∑ k ∈ Finset.Icc 2 (n - 2), (min (k : ℝ) (n - k : ℝ)) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 := sorry

  constructor
  · rw [lt_div_iff₀ hp_pos, h2d]
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by
      rw [Finset.card_Icc]; omega
    have h_p_n3 : (↑n - 3) * (p : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), (p : ℝ) := by
      rw [Finset.sum_const, h_card]; simp; rfl
    rw [h_p_n3]
    apply Finset.sum_lt_sum
    · intro k hk; exact (h_sk_gt k hk).le
    · use 2; simp; constructor; · omega; · apply h_sk_gt; simp; omega
  · rw [div_lt_iff₀ hp_pos, h2d]
    have : (∑ k ∈ Finset.Icc 2 (n - 2), s k) < (∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k : ℝ)) * p := by
      rw [Finset.sum_mul]
      apply Finset.sum_lt_sum
      · intro k hk; exact (h_sk_lt k hk).le
      · use 2; simp; constructor; · omega; · apply h_sk_lt; simp; omega
    apply this.trans_le
    rw [h_sum_min]; push_cast; exact le_rfl

