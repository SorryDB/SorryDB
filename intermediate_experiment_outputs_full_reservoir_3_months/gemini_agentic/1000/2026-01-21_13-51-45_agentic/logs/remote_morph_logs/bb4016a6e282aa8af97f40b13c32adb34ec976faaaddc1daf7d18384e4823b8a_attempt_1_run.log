import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (0 : ℝ) < p := by
    rw [hp]
    apply Finset.sum_pos
    · intro i _; apply dist_pos.mpr
      intro h; have := hP i (i + 1) (by omega) (by omega)
      rw [h] at this; simp at this
    · exact Finset.univ_nonempty
  have h2d : (2 * d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
    rw [hd]; push_cast; field_simp
  let s (k : ℕ) : ℝ := ∑ i, dist (P i) (P (i + (k : Fin n)))
  have h_sum_reorder : (2 * d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), s k := sorry
  have h_sk_gt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : (p : ℝ) < s k := sorry
  have h_sk_lt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : s k < min (k : ℝ) (n - k) * p := sorry
  constructor
  · rw [lt_div_iff₀ hp_pos, h_sum_reorder]
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by
      rw [Nat.card_Icc]; omega
    have : (n - 3 : ℝ) * p = ∑ k ∈ Finset.Icc 2 (n - 2), (p : ℝ) := by
      rw [Finset.sum_const, h_card]; push_cast; rfl
    rw [this]
    apply Finset.sum_lt_sum
    · intro k hk; exact (h_sk_gt k hk).le
    · use 2; simp; omega; exact h_sk_gt 2 (by simp; omega)
  · rw [div_lt_iff₀ hp_pos, h_sum_reorder]
    have h_sum_min : ∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k) = ⌊(n:ℝ)/2⌋ * ⌊((n:ℝ)+1)/2⌋ - 2 := sorry
    have : (⌊(n:ℝ)/2⌋ * ⌊((n:ℝ)+1)/2⌋ - 2) * p = ∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k) * p := by
      rw [← Finset.sum_mul, h_sum_min]
    rw [this]
    apply Finset.sum_lt_sum
    · intro k hk; exact (h_sk_lt k hk).le
    · use 2; simp; omega; exact h_sk_lt 2 (by simp; omega)
