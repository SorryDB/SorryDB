import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (0 : ℝ) < p := by
    rw [hp]
    apply Finset.sum_pos
    · intro i _
      apply dist_pos.mpr
      intro h_eq
      have h_sign := hP (i + 1) i (by simp) (by simp)
      rw [h_eq] at h_sign
      simp at h_sign
    · exact Finset.univ_nonempty
  have h2d : (2 * d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
    rw [hd]; push_cast; field_simp
  let s (k : ℕ) : ℝ := ∑ i : Fin n, dist (P i) (P (i + k))
  have h_sum_reorder : (2 * d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), s k := by
    rw [h2d, Finset.sum_comm]
    apply Finset.sum_congr rfl
    intro k hk
    rw [Finset.sum_bij (fun i _ => i + k) (fun i _ => Finset.mem_univ _)]
    · intro i _; rfl
    · intro i1 i2 _ _ h_eq; simpa using h_eq
    · intro j _; use j - k; simp
    · intro i _; simp
      have hk_n : k < n := by apply (Finset.mem_Icc.mp hk).2.trans_lt; omega
      have hk_2 : 2 ≤ k := (Finset.mem_Icc.mp hk).1
      intro h_mem
      rcases (Finset.mem_insert.mp (Finset.mem_insert.mp (Finset.mem_singleton.mp h_mem))) with h_eq | h_eq | h_eq
      · have : (i + k) = i - 1 := h_eq
        have : (k : Fin n) = (n - 1 : Fin n) := by simpa using (sub_eq_iff_eq_add.mp (eq_comm.mp this))
        have : k = n - 1 := by simpa [Fin.ext_iff] using this
        omega
      · have : (i + k) = i := h_eq
        have : (k : Fin n) = 0 := by simpa using (eq_comm.mp (add_left_cancel this))
        have : k % n = 0 := by simpa [Fin.ext_iff] using this
        omega
      · have : (i + k) = i + 1 := h_eq
        have : (k : Fin n) = 1 := by simpa using (add_left_cancel this)
        have : k % n = 1 := by simpa [Fin.ext_iff] using this
        omega
  have h_sk_gt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : (p : ℝ) < s k := by
    have h_quad (i : Fin n) : dist (P i) (P (i + k + 1)) + dist (P (i + 1)) (P (i + k)) > dist (P i) (P (i + 1)) + dist (P (i + k)) (P (i + k + 1)) := sorry
    have : 2 * s k > 2 * p := sorry
    linarith
  have h_sk_lt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : s k < min (k : ℝ) (n - k : ℝ) * p := by
    have h1 : s k < k * p := sorry
    have h2 : s k < (n - k) * p := sorry
    rw [lt_min_iff]; exact ⟨h1, h2⟩
  constructor
  · rw [lt_div_iff₀ hp_pos, h_sum_reorder]
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by rw [Nat.card_Icc]; omega
    rw [← h_card, ← Finset.sum_const, nsmul_eq_mul, mul_comm]
    apply Finset.sum_lt_sum
    · intro k hk; exact (h_sk_gt k hk).le
    · use 2; simp; constructor; · omega; · apply h_sk_gt; simp; omega
  · rw [div_lt_iff₀ hp_pos, h_sum_reorder]
    have h_sum_min : ∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k : ℝ) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 := sorry
    rw [← h_sum_min, Finset.sum_mul]
    apply Finset.sum_lt_sum
