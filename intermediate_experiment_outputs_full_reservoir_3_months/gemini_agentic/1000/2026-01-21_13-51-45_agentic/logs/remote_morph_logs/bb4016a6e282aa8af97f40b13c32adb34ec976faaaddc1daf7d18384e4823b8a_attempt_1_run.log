    rw [hp]; apply Finset.sum_pos
    · intro i _; apply dist_pos.mpr; intro h_eq
      have h1 : i + 1 ≠ i - 1 := by
        intro h; rw [Fin.ext_iff] at h; simp at h
        if n4 : n = 4 then subst n4; norm_num at h
        else have : n > 4 := by omega
             have : 1 % n ≠ (n - 1) % n := by
               have : 1 < n := by omega; have : n - 1 < n := by omega
               rw [Nat.mod_eq_of_lt this, Nat.mod_eq_of_lt (by omega)]; omega
             exact this h
      have h2 : i + 1 ≠ i := by
        intro h; rw [Fin.ext_iff] at h; simp at h; rw [Nat.mod_eq_of_lt (by omega)] at h; omega
      have h_sign := hP i (i + 1) h1 h2; rw [h_eq] at h_sign; simp at h_sign
    · exact Finset.univ_nonempty

