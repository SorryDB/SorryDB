    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (0 : ℝ) < p := by
    rw [hp]; apply Finset.sum_pos
    · intro i _; apply dist_pos.mpr; intro h_eq
      have h1 : (i + 1 : Fin n) ≠ i - 1 := by
        intro h; rw [Fin.ext_iff] at h; simp at h
        if hn4 : n = 4 then subst hn4; norm_num at h
        else
          have : n > 4 := by omega
          have : 2 < n := by omega
          have := Nat.mod_eq_of_lt this; omega
      have h2 : (i + 1 : Fin n) ≠ i := by
        intro h; rw [Fin.ext_iff] at h; simp at h
        have : 1 % n = 0 := by cases n; omega; omega
        omega
      have h_sign := hP i (i + 1) h1 h2
      rw [h_eq] at h_sign; simp at h_sign
    · exact Finset.univ_nonempty
  have h2d : (2 * d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
    rw [hd]; push_cast; field_simp
  let s (k : ℕ) : ℝ := ∑ i : Fin n, dist (P i) (P (i + k))
  have h_sum_reorder : (2 * d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), s k := by
    rw [h2d, Finset.sum_comm]
    apply Finset.sum_congr rfl
    intro k hk
    let f : Fin n → Fin n := fun i => i + k
    have hf : Function.Bijective f := ⟨fun i1 i2 h => by simpa using h, fun j => ⟨j - k, by simp⟩⟩
    rw [Finset.sum_bij (fun i _ => i + k) (fun i _ => Finset.mem_univ _)]
    · intro i _; rfl
    · intro i1 i2 _ _ h; exact hf.1 h
    · intro j _; exact ⟨j - k, Finset.mem_univ _, by simp⟩
    · intro i _; simp
      have hk_2 : 2 ≤ k := (Finset.mem_Icc.mp hk).1
      have hk_n2 : k ≤ n - 2 := (Finset.mem_Icc.mp hk).2
      intro h_mem; rcases h_mem with h_eq | h_eq | h_eq
      · have : (k : Fin n) = (n - 1 : Fin n) := by simpa [sub_eq_iff_eq_add, eq_comm] using h_eq
        have : k % n = n - 1 := by simpa [Fin.ext_iff] using this
        have : k = n - 1 := by
          have : k < n := by omega
          rwa [Nat.mod_eq_of_lt this] at this
        omega
      · have : (k : Fin n) = 0 := by simpa [eq_comm] using h_eq
        have : k % n = 0 := by simpa [Fin.ext_iff] using this
        have : k = 0 := by
          have : k < n := by omega
          rwa [Nat.mod_eq_of_lt this] at this
        omega
