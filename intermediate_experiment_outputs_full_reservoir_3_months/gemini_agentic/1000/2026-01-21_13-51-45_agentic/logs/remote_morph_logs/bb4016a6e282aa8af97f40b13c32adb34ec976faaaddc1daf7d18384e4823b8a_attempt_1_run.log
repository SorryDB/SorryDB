  · rw [div_lt_iff₀ hp_pos, h_sum_reorder]
    have h_sk_lt : ∀ k ∈ Finset.Icc 2 (n - 2), s k < min (k : ℝ) (n - k) * p := sorry
    have h_sum_min : ∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 := sorry
    have : (⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 : ℝ) * p = (∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) (n - k)) * p := by
      rw [h_sum_min]
