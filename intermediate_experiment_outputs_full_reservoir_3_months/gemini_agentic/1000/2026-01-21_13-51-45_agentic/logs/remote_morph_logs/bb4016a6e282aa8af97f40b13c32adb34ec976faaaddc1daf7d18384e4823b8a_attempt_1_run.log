  have h_sk_lt (k : ℕ) (hk : k ∈ Finset.Icc 2 (n - 2)) : s k < min (k : ℝ) ((n : ℝ) - k) * p := sorry
  have h_sum_min : ∑ k ∈ Finset.Icc 2 (n - 2), min (k : ℝ) ((n : ℝ) - k) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 := sorry
  constructor
