theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    have h1 : Fintype.card (S k) = Fintype.card V + Fintype.card {s | s ∉ V} := by
      rw [← Fintype.card_subtype_mem_add_card_subtype_compl V]
    rw [h1, two_mul, add_left_inj]
    apply Fintype.card_congr
    refine {
      toFun := fun ⟨s, hs⟩ => ⟨f s, (hV s).mp hs⟩
      invFun := fun ⟨s, hs⟩ => ⟨f s, (hV (f s)).mpr (by simpa [hf_inv] using hs)⟩
      left_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s
      right_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s
    }
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have hzne : z ≠ 0 := by
      intro h0; obtain ⟨h_eq, -, -⟩ := hS_prop; rw [h0] at h_eq
      have h4 : (4 * x * y + 0^2 : ℤ) % 4 = (4 * k + 1 : ℤ) % 4 := congr_arg (· % 4) h_eq
      simp at h4; norm_num at h4
    simp [T, linearInvo, hzne]; omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have hxyz_ne : x - y + z ≠ 0 := by
      intro h0; have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        calc
          (x + y) ^ 2 = 4 * x * y + (y - x) ^ 2 := by ring
          _ = 4 * x * y + z ^ 2 := by rw [show y - x = z by omega]
          _ = 4 * k + 1 := hS_prop.1
      have hp : (4 * k + 1).Prime := hk.out
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        rw [← Int.natAbs_sq, hsq]; norm_cast
      have h_dvd : (x + y).natAbs ∣ (4 * k + 1) := by
        rw [← hsq_nat, sq]; exact dvd_mul_left _ _
      cases (Nat.dvd_prime hp).mp h_dvd with
      | inl h1 => rw [h1] at hsq_nat; norm_num at hsq_nat; exact hp.ne_one hsq_nat.symm
      | inr h2 => rw [h2] at hsq_nat
        have h_p1 : 4 * k + 1 = 1 := (mul_left_inj' hp.ne_zero).mp (by rw [← hsq_nat, sq]; ring)
        exact hp.ne_one h_p1
    simp [U, linearInvo, hxyz_ne]; omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
