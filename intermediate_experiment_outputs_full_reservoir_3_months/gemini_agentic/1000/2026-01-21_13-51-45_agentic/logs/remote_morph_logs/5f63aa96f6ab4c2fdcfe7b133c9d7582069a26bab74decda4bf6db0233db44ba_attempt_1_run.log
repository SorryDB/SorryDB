theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    have h1 : Fintype.card (S k) = Fintype.card V + Fintype.card (Vᶜ : Set (S k)) := by
      rw [← Fintype.card_congr (Equiv.sumCompl (· ∈ V)), Fintype.card_sum]
    rw [h1, two_mul, add_left_inj]
    apply Fintype.card_congr
    refine {
      toFun := fun ⟨s, hs⟩ => ⟨f s, (hV s).mp hs⟩,
      invFun := fun ⟨s, hs⟩ => ⟨f s, ?_⟩,
      left_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s,
      right_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s
    }
    have h := hV (f s); rw [hf_inv] at h; exact h.mpr hs
  have hzne : ∀ s : S k, s.1.2.2 ≠ 0 := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩ hz
    have h_eq := hS_prop.1; apply_fun (· % 4) at h_eq; rw [hz] at h_eq
    simp [Int.add_emod, Int.mul_emod] at h_eq; norm_num at h_eq
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    simp [T, linearInvo]; have := hzne ⟨⟨x, y, z⟩, hS_prop⟩; omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have h_xyz : x - y + z ≠ 0 := by
      intro h_xyz; have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        obtain ⟨h_eq, -, -⟩ := hS_prop
        calc (x + y) ^ 2 = 4 * x * y + (x - y) ^ 2 := by ring
        _ = 4 * x * y + z ^ 2 := by rw [show z = y - x by linarith]; ring
        _ = 4 * k + 1 := h_eq
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp; rw [Int.cast_pow, Int.natAbs_sq, hsq]; rfl
      have hp : Nat.Prime (4 * k + 1) := (inferInstance : Fact (4 * k + 1).Prime).out
      rw [← hsq_nat] at hp; exact Nat.not_prime_pow (by norm_num) hp
    simp [U, linearInvo]; omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
