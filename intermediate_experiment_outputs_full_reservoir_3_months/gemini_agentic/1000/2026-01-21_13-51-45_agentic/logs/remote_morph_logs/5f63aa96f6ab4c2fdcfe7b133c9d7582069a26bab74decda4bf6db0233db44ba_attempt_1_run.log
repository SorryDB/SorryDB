theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    have h1 : Fintype.card (S k) = Fintype.card (V : Set (S k)) + Fintype.card (Vᶜ : Set (S k)) := by
      rw [← Fintype.card_sum, Fintype.card_congr (Equiv.sumCompl (· ∈ V)).symm]
    rw [h1, two_mul, add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun ⟨s, hs⟩ => ⟨f s, (hV s).mp hs⟩,
      invFun := fun ⟨s, hs⟩ => ⟨f s, by have h := hV (f s); rw [hf_inv] at h; exact h.mpr hs⟩,
      left_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s,
      right_inv := fun ⟨s, hs⟩ => by ext; exact hf_inv s
    }
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩
    have hzne : z ≠ 0 := by
      intro hz; obtain ⟨h_eq, -, -⟩ := hS_prop
      apply_fun (· % 4) at h_eq; simp [hz, Int.add_emod, Int.mul_emod] at h_eq
    simp [T, linearInvo, hzne]; omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩
    have h_xyz : x - y + z ≠ 0 := by
      intro h0
      have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        obtain ⟨h_eq, -, -⟩ := hS_prop
        calc (x + y) ^ 2 = 4 * x * y + (x - y) ^ 2 := by ring
        _ = 4 * x * y + z ^ 2 := by rw [show z = y - x by linarith]; ring
        _ = 4 * k + 1 := h_eq
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        rw [← Int.natAbs_sq] at hsq; exact Int.ofNat_inj.mp hsq
      have hp : (4 * k + 1).Prime := sorry
      refine hp.not_unit ?_
      rw [← Nat.isUnit_iff, ← Nat.sq_isUnit_iff, hsq_nat]
      exact Nat.Prime.isUnit hp
    simp [U, linearInvo, h_xyz]; omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
