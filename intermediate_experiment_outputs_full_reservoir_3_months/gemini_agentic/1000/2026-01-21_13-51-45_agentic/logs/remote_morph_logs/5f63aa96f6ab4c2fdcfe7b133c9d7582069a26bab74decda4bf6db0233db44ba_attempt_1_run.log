theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have h (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    rw [← Fintype.card_congr (Equiv.sumCompl V).symm, Fintype.card_sum, ← two_mul]
    refine congr_arg₂ _ rfl (Fintype.card_congr (Equiv.ofBijective (fun s : V ↦ ⟨f s.1, (hV s.1).mp s.2⟩) ⟨fun s ↦ ⟨f s.1, ?_⟩, ?_, ?_⟩))
    · exact (hV (f s.1)).mpr (by simpa [show f (f s.1) = s.1 from congr_fun (linearInvo_sq k) s.1] using s.2)
    · intro s; simp [show f (f s.1) = s.1 from congr_fun (linearInvo_sq k) s.1]
    · intro s; simp [show f (f s.1) = s.1 from congr_fun (linearInvo_sq k) s.1]
  have hT s : s ∈ T k ↔ f s ∉ T k := by
    obtain ⟨⟨x, y, z⟩, hS⟩ := s; simp [T, linearInvo, S]
    have : z ≠ 0 := by
      intro h; have : 4 * (x * y - k) = 1 := by nlinarith [hS.1, h]
      have : 1 % 4 = (4 * (x * y - k)) % 4 := by rw [this]
      norm_num at this
    omega
  have hU s : s ∈ U k ↔ f s ∉ U k := by
    obtain ⟨⟨x, y, z⟩, hS⟩ := s; simp [U, linearInvo, S]
    have : x - y + z ≠ 0 := by
      intro h; have hsq : (x + y).abs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp; rw [Int.cast_pow, Int.cast_abs, ← Int.sq_abs, ← hS.1]; nlinarith
      exact Nat.not_prime_pow (by norm_num) (hsq ▸ hk.out)
    omega
  rw [← mul_left_inj' (two_ne_zero : (2 : ℕ) ≠ 0), h (T k) hT, h (U k) hU]
```
