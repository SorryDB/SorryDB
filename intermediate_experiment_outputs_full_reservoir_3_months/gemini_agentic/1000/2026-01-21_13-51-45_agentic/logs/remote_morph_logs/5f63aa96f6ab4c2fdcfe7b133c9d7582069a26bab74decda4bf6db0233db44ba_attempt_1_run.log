theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    rw [← Fintype.card_subtype_add_card_compl V, two_mul, add_left_inj]
    apply Fintype.card_congr
    refine {
      toFun := fun s => ⟨f s.1, (hV s.1).mp s.2⟩
      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩
      left_inv := fun s => by ext; exact hf_inv s.1
      right_inv := fun s => by ext; exact hf_inv s.1
    }
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have hz : z ≠ 0 := by
      intro hz; have h1 := hS_prop.1; rw [hz] at h1
      apply_fun (· % 4) at h1; simp [Int.add_emod, Int.mul_emod] at h1; norm_num at h1
    have hf : f s = ⟨⟨y, x, -z⟩, by simp [S]; exact ⟨by linarith [hS_prop.1], hS_prop.2.2, hS_prop.2.1⟩⟩ := rfl
    simp [T, hf, hz]; omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have h_xyz : x - y + z ≠ 0 := by
      intro h_xyz
      have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        rw [← hS_prop.1]; have : z = y - x := by linarith; rw [this]; ring
      have hp : (4 * k + 1).Prime := hk.out
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp; rw [Int.cast_pow, Int.natAbs_sq, hsq]; norm_cast
      have h_abs : (x + y).natAbs = 1 := by
        have h_sq_dvd : (x + y).natAbs * (x + y).natAbs ∣ 4 * k + 1 := by rw [← sq, hsq_nat]
        exact Nat.isUnit_iff.mp (hp.squarefree h_sq_dvd)
      have : 4 * k + 1 = 1 := by rw [← hsq_nat, h_abs, one_pow]
      exact hp.ne_one this
    have hf : f s = ⟨⟨y, x, -z⟩, by simp [S]; exact ⟨by linarith [hS_prop.1], hS_prop.2.2, hS_prop.2.1⟩⟩ := rfl
    simp [U, hf, h_xyz]; omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
