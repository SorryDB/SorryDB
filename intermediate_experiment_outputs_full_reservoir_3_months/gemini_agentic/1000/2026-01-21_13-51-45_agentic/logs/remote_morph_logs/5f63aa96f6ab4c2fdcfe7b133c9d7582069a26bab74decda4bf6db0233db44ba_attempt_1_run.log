      norm_num at h4
    simp [T, linearInvo] at *
    omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩
    have h_xyz : x - y + z ≠ 0 := by
      intro h_xyz
      have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        rw [← hS_prop.1]
        have : z = y - x := by linarith
        rw [this]
        ring
      have hp : (4 * k + 1).Prime := (inferInstance : Fact (4 * k + 1).Prime).out
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp
        rw [Int.cast_pow, Int.natAbs_sq, hsq]
