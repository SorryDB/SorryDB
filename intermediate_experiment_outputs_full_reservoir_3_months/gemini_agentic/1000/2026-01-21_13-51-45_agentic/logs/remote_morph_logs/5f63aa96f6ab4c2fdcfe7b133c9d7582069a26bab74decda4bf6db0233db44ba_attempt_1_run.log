theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hf_inv : ∀ s, f (f s) = s := fun s => by
    have := linearInvo_sq k
    change (linearInvo k ∘ linearInvo k) s = id s
    rw [this]
  attribute [local instance] Classical.propDecidable
  have h_half (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) :
      2 * Fintype.card ↑V = Fintype.card (S k) := by
    have : Fintype.card (S k) = Fintype.card ↑V + Fintype.card ↑Vᶜ :=
      Fintype.card_congr (Equiv.sumCompl V).symm |>.trans (Fintype.card_sum _ _)
    rw [this, two_mul, add_left_inj]
    apply Fintype.card_congr
    refine Equiv.ofBijective (fun (s : V) => (⟨f s.1, (hV s.1).mp s.2⟩ : Vᶜ)) ⟨?_, ?_⟩
    · intro s1 s2 heq; simp [Subtype.ext_iff] at heq
      apply Subtype.ext; simpa [hf_inv] using congr_arg f heq
    · intro s2; use ⟨f s2.1, (hV (f s2.1)).mpr (by simpa [hf_inv] using s2.2)⟩
      simp [hf_inv]
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [T, linearInvo, S]; have : z ≠ 0 := by
      intro hz; have := hS.1; rw [hz] at this; simp at this
      apply_fun (· % 4) at this; simp [Int.add_emod, Int.mul_emod] at this
    omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [U, linearInvo, S]; have : x - y + z ≠ 0 := by
      intro h; have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by nlinarith [hS.1, h]
      have : IsSquare (4 * k + 1 : ℕ) := ⟨(x + y).natAbs, by zify; rw [Int.natAbs_sq, h_sq]⟩
      exact hk.out.not_isSquare this
    omega
  rw [← mul_left_inj' (two_ne_zero : (2 : ℕ) ≠ 0), h_half (T k) hT, h_half (U k) hU]
