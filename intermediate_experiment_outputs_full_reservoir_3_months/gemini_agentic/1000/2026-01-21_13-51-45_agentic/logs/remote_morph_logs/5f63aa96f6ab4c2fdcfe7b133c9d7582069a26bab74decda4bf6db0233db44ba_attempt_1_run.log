theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    classical
    have h_eq : Fintype.card (S k) = Fintype.card V + Fintype.card (Vᶜ : Set (S k)) :=
      (Fintype.card_congr (Equiv.sumCompl V).symm).trans (Fintype.card_sum _ _)
    rw [h_eq, two_mul, add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun s => ⟨f s.1, (hV s.1).mp s.2⟩
      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩
      left_inv := fun s => by ext; simp [hf_inv]
      right_inv := fun s => by ext; simp [hf_inv]
    }
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩
    simp [T, linearInvo]
    have : z ≠ 0 := by
      intro hz
      have h1 := hS_prop.1
      rw [hz] at h1
      have : (4 * (x * y - k) : ℤ) = 1 := by linarith
      have h4 : (4 * (x * y - k) : ℤ) % 4 = 1 % 4 := congr_arg (· % 4) this
      simp at h4
    constructor <;> intro <;> linarith
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS_prop⟩
    simp [U, linearInvo]
    have : x - y + z ≠ 0 := by
      intro h_z
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        have : z = y - x := by linarith
        rw [this, ← hS_prop.1]
        ring
      have h_sq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp
        rw [Int.cast_pow, Int.natAbs_sq, h_sq]
        norm_cast
      exact hk.out.not_perfect_square ⟨(x + y).natAbs, by ring_nf; exact h_sq_nat⟩
    constructor <;> intro <;> linarith
  apply (Nat.mul_left_inj (show 0 < 2 by norm_num)).mpr
  rw [h_card (U k) hU, h_card (T k) hT]
