theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hf_inv (s : S k) : f (f s) = s := congr_fun (linearInvo_sq k) s
  have hp : Nat.Prime (4 * k + 1) := Fact.out hk
  have hS_z (s : S k) : s.1.2.2 ≠ 0 := by
    obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    intro hz; have h1 := hS_prop.1; rw [hz] at h1
    apply_fun (fun x => x % 4) at h1; simp [Int.add_emod, Int.mul_emod] at h1; norm_num at h1
  have hS_xyz (s : S k) : s.1.1 - s.1.2.1 + s.1.2.2 ≠ 0 := by
    obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    intro h_xyz; have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
      rw [← hS_prop.1]; have : z = y - x := by linarith; rw [this]; ring
    have h_sq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
      apply Int.ofNat_inj.mp; rw [Int.cast_pow, Int.natAbs_sq, hsq]; norm_cast
    exact hp.not_perfect_square ⟨(x + y).natAbs, h_sq_nat⟩
  classical
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    have h1 : Fintype.card (S k) = Fintype.card V + Fintype.card (Vᶜ : Set (S k)) :=
      (Fintype.card_subtype_add_card_compl (· ∈ V)).symm
    rw [h1, two_mul, add_left_inj]
    apply Fintype.card_congr
    refine {
      toFun := fun s => ⟨f s.1, (hV s.1).mp s.2⟩
      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩
      left_inv := fun s => by ext; exact hf_inv s.1
      right_inv := fun s => by ext; exact hf_inv s.1
    }
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro s; have hz := hS_z s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s; simp [T, linearInvo]
    constructor <;> intro <;> omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro s; have hxyz := hS_xyz s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s; simp [U, linearInvo]
    constructor <;> intro <;> omega
  rw [← Nat.mul_left_inj (show 0 < 2 by norm_num), h_card (U k) hU, h_card (T k) hT]
