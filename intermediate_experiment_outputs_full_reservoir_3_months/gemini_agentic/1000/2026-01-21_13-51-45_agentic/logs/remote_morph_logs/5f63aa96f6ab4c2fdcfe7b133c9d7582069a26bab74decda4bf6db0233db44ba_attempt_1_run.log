theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    classical
    have h_sum : Fintype.card (S k) = Fintype.card V + Fintype.card (Vᶜ : Set (S k)) := (Fintype.card_subtype_compl_add_card V).symm
    rw [h_sum, two_mul, add_left_inj]
    apply Fintype.card_congr
    let e : V ≃ (Vᶜ : Set (S k)) := {
      toFun := fun s => ⟨f s.1, (hV s.1).mp s.2⟩,
      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩,
      left_inv := fun s => by simp [hf_inv],
      right_inv := fun s => by simp [hf_inv]
    }
    exact e
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [T, linearInvo, S]
    have : z ≠ 0 := by
      intro hz; have hS1 := hS.1; rw [hz] at hS1; simp at hS1
      have : 4 * (x * y - k) = 1 := by nlinarith [hS1]
      omega
    omega
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [U, linearInvo, S]
    have : x - y + z ≠ 0 := by
      intro h
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by nlinarith [hS.1, h]
      have h_Nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.mp
        rw [Int.cast_pow, Int.natAbs_sq, h_sq]
        norm_cast
      have h_prime := hk.out
      rw [← h_Nat] at h_prime
      exact Nat.not_prime_pow (by norm_num) h_prime
    omega
  apply (Nat.mul_left_inj (show 0 < 2 from by norm_num)).mp
  rw [h_card (U k) hU, h_card (T k) hT]
