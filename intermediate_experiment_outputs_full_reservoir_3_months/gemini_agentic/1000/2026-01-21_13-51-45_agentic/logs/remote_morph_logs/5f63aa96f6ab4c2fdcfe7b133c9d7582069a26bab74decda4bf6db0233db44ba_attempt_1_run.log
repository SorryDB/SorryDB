theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hf_inv s : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (V : Set (S k)) (hV : ∀ s, s ∈ V ↔ f s ∉ V) : 2 * Fintype.card V = Fintype.card (S k) := by
    classical
    have h1 : Fintype.card (S k) = Fintype.card V + Fintype.card (Vᶜ : Set (S k)) := by
      rw [← Fintype.card_sum, ← Fintype.card_congr (Equiv.sumCompl V).symm]
    rw [h1, two_mul, add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun s => ⟨f s.1, (hV s.1).mp s.2⟩
      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩
      left_inv := fun s => by ext; exact hf_inv s.1
      right_inv := fun s => by ext; exact hf_inv s.1
    }
  have hS_z (s : S k) : s.val.2.2 ≠ 0 := by
    obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    intro hz; have h1 := hS_prop.1; rw [hz] at h1
    have : (4 * (x * y - k) : ℤ) = 1 := by linarith
    have h4 : (4 * (x * y - k) : ℤ) % 4 = 1 % 4 := congr_arg (· % 4) this
    norm_num at h4
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have hz := hS_z ⟨(x, y, z), hS_prop⟩
    simp [T, linearInvo]; omega
  have hS_xyz (s : S k) : s.val.1 - s.val.2.1 + s.val.2.2 ≠ 0 := by
    obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    intro h_xyz
    have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
      rw [← hS_prop.1]; have : z = y - x := by linarith; rw [this]; ring
    have h_sq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
      apply Int.ofNat_inj.mp; rw [Int.cast_pow, Int.natAbs_sq, h_sq]; norm_cast
    have h_prime : (4 * k + 1).Prime := hk.out
    have h_abs : (x + y).natAbs = 1 :=
      Nat.isUnit_iff.mp (h_prime.squarefree (x + y).natAbs (dvd_of_eq h_sq_nat))
    rw [h_abs] at h_sq_nat; norm_num at h_sq_nat
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS_prop⟩ := s
    have hxyz := hS_xyz ⟨(x, y, z), hS_prop⟩
    simp [U, linearInvo]; omega
  apply Nat.mul_left_cancel (show 2 ≠ 0 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
