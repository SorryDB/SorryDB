      invFun := fun s => ⟨f s.1, (hV (f s.1)).mpr (by simpa [hf_inv] using s.2)⟩,
      left_inv := fun s => by ext; simp [hf_inv],
      right_inv := fun s => by ext; simp [hf_inv]
