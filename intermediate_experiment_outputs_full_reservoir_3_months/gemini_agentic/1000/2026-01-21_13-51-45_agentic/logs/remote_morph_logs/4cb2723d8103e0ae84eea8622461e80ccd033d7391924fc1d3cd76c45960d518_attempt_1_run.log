let Y' := Field51_as_Nat c.Y
let Z' := Field51_as_Nat c.Z
let T' := Field51_as_Nat c.T
X' % p = (2 * X * Y) % p ∧
Y' % p = (Y^2 + X^2) % p ∧
(Z' + X^2) % p = Y^2 % p ∧
(T' + Z') % p = (2 * Z^2) % p
