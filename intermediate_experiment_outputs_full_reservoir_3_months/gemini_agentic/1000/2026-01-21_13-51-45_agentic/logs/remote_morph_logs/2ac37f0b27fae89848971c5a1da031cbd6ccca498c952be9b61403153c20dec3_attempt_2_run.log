      simp [hM0, initial, Factorization.sum]; omega
    · set d := P.n / P.M
      have h_p2 : p ^ 2 > P.n := by
        rw [Real.lt_sqrt (Nat.cast_nonneg P.n)] at hp'; exact_mod_cast hp'
      have h_smooth : ∀ m ∈ Multiset.Ico (P.n - d) P.n, p ∣ m → m ≠ 0 → m ∈ (P.n / P.L).smoothNumbers := by
        intro m hm hpdvd hm_pos
        rw [mem_smoothNumbers]
        refine ⟨hm_pos, fun q hq hqdvd ↦ ?_⟩
        by_cases hqp : q = p; · rwa [hqp]
        have h_qp : q * p ≤ m := hp_prime.mul_le_of_dvd_of_dvd hq hpdvd hqp
        have : (q : ℝ) < Real.sqrt P.n := by
          rw [Real.lt_sqrt (Nat.cast_nonneg _)]
          have : (q : ℝ) * p < p * p := calc
            (q : ℝ) * p ≤ m := by exact_mod_cast h_qp
            _ < P.n := by exact_mod_cast (Multiset.mem_Ico.mp hm).2
            _ < p * p := by exact_mod_cast h_p2
          exact (mul_lt_mul_right (by exact_mod_cast hp_prime.pos)).mp this
        exact this.le.trans (hp'.le.trans (by rw [Real.le_sqrt (Nat.cast_nonneg _) (Nat.cast_nonneg _)]; exact_mod_cast P.hL.le))
      have h_sum : (P.initial.a.map (·.factorization p)).sum ≥ (P.M : ℤ) * ((P.n / p : ℤ) / P.M - 1) := by
        unfold initial Factorization.sum
        simp only [Multiset.map_filter, Multiset.sum_filter, Multiset.map_join, Multiset.sum_join,
          Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
        let S := Multiset.Ico (P.n - d) P.n
        have h_val : ∀ m ∈ S, m.factorization p = if p ∣ m then 1 else 0 := fun m hm ↦ by
