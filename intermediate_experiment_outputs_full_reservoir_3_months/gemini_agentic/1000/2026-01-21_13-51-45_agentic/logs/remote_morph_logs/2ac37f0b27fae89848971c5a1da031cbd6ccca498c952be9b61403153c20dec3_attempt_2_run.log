          · rw [Nat.factorization_eq_zero_of_not_dvd hpdvd]
        have h_sc : (Multiset.map (·.factorization p) (S.filter (· ∈ (P.n / P.L).smoothNumbers))).sum =
            (S.filter (fun m ↦ m ∈ (P.n / P.L).smoothNumbers ∧ p ∣ m)).card := by
          rw [Multiset.map_filter, Multiset.sum_filter]; apply Multiset.sum_congr rfl; intro m hm
