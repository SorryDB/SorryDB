    rw [h_bal, ge_iff_le, sub_le_iff_le_add, ← Nat.cast_add, Nat.cast_le]
    set d := P.n / P.M
    have h_smooth : ∀ m ∈ Finset.Ico (P.n - d) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := by
      intro m hm hpdvd
      rw [mem_smoothNumbers']; refine ⟨by have := Nat.le_of_dvd hp_prime.pos hpdvd; linarith, fun q hq hqdvd ↦ ?_⟩
      by_cases hqp : q = p; · rwa [hqp]
      have : (q : ℝ) < Real.sqrt P.n := by
        rw [Real.lt_sqrt (Nat.cast_nonneg _)]; apply lt_of_mul_lt_mul_right (positivity : (p : ℝ) > 0)
        calc (q * p : ℝ) ≤ m := by exact_mod_cast Nat.mul_le_of_dvd_of_dvd hq hpdvd hqp
          _ < P.n := by exact_mod_cast (Finset.mem_Ico.1 hm).2
          _ < (p * p : ℝ) := by nlinarith
      exact this.le.trans (by rw [Real.le_div_iff₀ (by exact_mod_cast P.hL_pos)]; nlinarith [P.hL])
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card := by
      simp [Params.initial, Factorization.sum, Multiset.filter_join, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
      rw [← Finset.sum_multiset_sum, Finset.sum_replicate, smul_eq_mul]; congr
      rw [Multiset.map_filter, Multiset.sum_filter, Multiset.map_id, ← Finset.sum_multiset_sum, Finset.sum_filter]
      apply Finset.sum_congr rfl; intro m hm; simp only [Finset.mem_Ico] at hm
      by_cases hpdvd : p ∣ m
      · simp [h_smooth m hm hpdvd, hp_prime.factorization_eq_one_of_dvd hpdvd]
        intro h_p2; have : (p : ℝ)^2 < P.n := by exact_mod_cast (Finset.mem_Ico.1 hm).2.trans_le' (Nat.le_of_dvd hp_prime.pos h_p2)
        nlinarith
      · simp [Nat.factorization_eq_zero_of_not_dvd hpdvd]
    rw [h_sum]; set count := (Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card
    rcases P.M.eq_zero_or_pos with rfl | hM
    · have : P.n = 0 := by linarith [P.hL, P.hL_pos]; simp [this]
    · have h_cnt : count = (P.n - 1) / p - (P.n - d - 1) / p := by
        if hnd : P.n - d < P.n then
          exact Finset.filter_card_dvd_Ico (P.n - d) P.n hp_prime.pos
        else
          have : d = 0 := by linarith [Nat.sub_lt_self (by linarith [Nat.div_pos (by linarith [P.hL, P.hL_pos]) hM]) hnd]
          simp [this]
      if h_cnt_pos : count > 0 then linarith [Nat.mul_le_of_dvd_of_dvd (by linarith) (Nat.dvd_refl _) (by linarith)]
      else
        have : count = 0 := by linarith
        have : P.n / p < P.M := by
          have h_gap : (P.n - 1) / p = (P.n - d - 1) / p := by linarith
          have : d < p := by
            by_contra! h_dp; have h_mul : P.n - d + (p - 1) < P.n := by linarith [hp_prime.pos]
            have : (P.n - 1) / p > (P.n - d - 1) / p := by
              rw [Nat.div_lt_iff_lt_mul hp_prime.pos]; nlinarith [Nat.div_mul_add_mod (P.n - d - 1) p]
            linarith
          calc P.n / p ≤ (P.n - 1) / p + 1 := by if hn : P.n = 0 then linarith else exact Nat.div_le_div_right (by linarith)
            _ = (P.n - d - 1) / p + 1 := by rw [h_gap]
            _ ≤ (P.n - 1) / p + 1 := by gcongr; exact Nat.sub_le_sub_left (by linarith) _
