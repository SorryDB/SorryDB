@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hp_prime : p.Prime
  · have h_sqrt : (p : ℝ) > Real.sqrt P.n := hp'
    have h_bal : P.initial.balance p = (P.initial.a.map (·.factorization p)).sum - (P.n / p : ℤ) := by
      simp [Factorization.balance, Factorization.sum, factorial_factorization_eq_div hp_prime h_sqrt]
    rw [h_bal, ge_iff_le, sub_le_iff_le_add, ← Nat.cast_mul, ← Nat.cast_add, Nat.cast_le]
    have h_M : P.M > 0 := by by_contra! hM; simp [hM] at *; linarith [P.hL, P.hL_pos]
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
      simp [Params.initial, Factorization.sum, Multiset.filter_join, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul, Finset.filter_val]
      refine Multiset.sum_map_congr rfl fun m hm ↦ ?_
      have h_pm : p ∣ m := (Multiset.mem_filter.1 hm).2
      have h_smooth : m ∈ (P.n / P.L).smoothNumbers := by
        rw [mem_smoothNumbers']; refine ⟨by linarith [P.hL], fun q hq hqm ↦ ?_⟩
        by_cases hqp : q = p; · rw [hqp]; exact hp
        have : (q : ℝ) < Real.sqrt P.n := by
          rw [Real.lt_sqrt (Nat.cast_nonneg _)]; apply lt_of_mul_lt_mul_right (a := p)
          calc (q : ℝ) * p ≤ m := by exact_mod_cast Nat.mul_le_of_dvd_of_dvd hq h_pm hqp
            _ < P.n := by exact_mod_cast (Finset.mem_Ico.1 (Multiset.mem_join.1 (Multiset.mem_filter.1 hm).1).2.2).2
            _ < (p : ℝ) * p := by nlinarith
        exact this.le.trans (by rw [Real.le_div_iff₀ (by exact_mod_cast P.hL_pos)]; nlinarith [P.hL])
      simp [h_smooth, Nat.Prime.factorization_eq_one_of_dvd hp_prime h_pm]
      intro h_p2; have : (p : ℝ)^2 < P.n := by exact_mod_cast (Finset.mem_Ico.1 (Multiset.mem_join.1 (Multiset.mem_filter.1 hm).1).2.2).2.trans_le' (Nat.le_of_dvd (by linarith) h_p2)
      nlinarith
    rw [h_sum, ← Nat.mul_succ]; apply Nat.div_le_of_le_mul; rw [Nat.mul_comm, ← Nat.mul_assoc]
    calc P.n ≤ P.M * (P.n / P.M) + P.M := by rw [Nat.div_add_mod P.n P.M]; linarith [Nat.mod_lt P.n h_M]
      _ ≤ P.M * (((Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card + 1) * p) := by
        apply Nat.mul_le_mul_left; set d := P.n / P.M
        calc d ≤ (d / p + 1) * p := by linarith [Nat.div_add_mod d p, Nat.mod_lt d hp_prime.pos]
          _ ≤ ((Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card + 1) * p := by
            apply Nat.mul_le_mul_right; apply Nat.add_le_add_right;
            have : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card ≥ d / p := sorry
            exact this
  · simp [Factorization.balance, Factorization.sum, factorization_eq_zero_of_not_prime _ hp_prime]
