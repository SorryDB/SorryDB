  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hp_prime : p.Prime
  · have h_sqrt : (p : ℝ) > Real.sqrt P.n := hp'
    have h_bal : P.initial.balance p = (P.initial.a.map (·.factorization p)).sum - (P.n / p : ℤ) := by
      simp [Factorization.balance, Factorization.sum, factorial_factorization_eq_div hp_prime h_sqrt]
    rw [h_bal]
    rcases P.M.eq_zero_or_pos with rfl | hM
    · have h_p_le_n : p ≤ P.n := hp.trans (Nat.div_le_self _ _)
      have h_n_p_pos : P.n / p ≥ 1 := Nat.div_pos h_p_le_n hp_prime.pos
      simp [Params.initial, Factorization.sum]; linarith
    · set d := P.n / P.M
      have h_smooth : ∀ m ∈ Finset.Ico (P.n - d) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := by
        intro m hm hpdvd
        rw [mem_smoothNumbers']; refine ⟨pos_of_gt (lt_of_le_of_lt (Nat.sub_le P.n d) hm.1), fun q hq hqdvd ↦ ?_⟩
        by_cases hqp : q = p; · rwa [hqp]
        have hq_lt : (q : ℝ) < Real.sqrt P.n := by
          rw [Real.lt_sqrt (Nat.cast_nonneg _)]; apply lt_of_mul_lt_mul_right (positivity : (p : ℝ) > 0)
          calc (q * p : ℝ) ≤ m := by exact_mod_cast Nat.mul_le_of_dvd_of_dvd hq hpdvd hqp
            _ < P.n := by exact_mod_cast hm.2
            _ < (p * p : ℝ) := by nlinarith
        exact hq_lt.le.trans (hp'.le.trans hp)
      have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card := by
        unfold Params.initial Factorization.sum
        simp only [Multiset.map_filter, Multiset.sum_filter, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
        congr 1; rw [Multiset.Ico, ← Multiset.sum_eq_sum_map_id, Multiset.sum_filter]
        apply Multiset.sum_congr rfl; intro m hm; simp only [Multiset.mem_Ico] at hm
        by_cases hpdvd : p ∣ m
        · have hsm : m ∈ (P.n / P.L).smoothNumbers := h_smooth m hm hpdvd
          simp [hsm, hp_prime.factorization_eq_one_of_dvd hpdvd]
          intro h_p2; have : (p : ℝ)^2 < P.n := by exact_mod_cast hm.2.trans_le' (Nat.le_of_dvd hp_prime.pos h_p2)
          nlinarith
        · simp [Nat.factorization_eq_zero_of_not_dvd hpdvd]
      rw [h_sum]; set count := (Finset.filter (p ∣ ·) (Finset.Ico (P.n - d) P.n)).card
      have h_count_ge : count ≥ d / p := by
        have h_len : (Finset.Ico (P.n - d) P.n).card = d := by rw [Finset.card_Ico, Nat.sub_sub_self (Nat.div_le_self _ _)]
        have := Nat.card_filter_dvd_le (P.n - d) P.n hp_prime.pos; rw [h_len] at this; omega
      have h_final : (P.M : ℤ) * (d / p) ≥ (P.n / p : ℤ) - P.M + 1 := by
        have : P.M * (P.n / P.M / p) = (P.n - P.n % P.M) / p := by
          rw [Nat.div_div_eq_div_mul, Nat.mul_div_assoc _ (Nat.dvd_refl _), Nat.div_mul_cancel (Nat.dvd_sub_mod P.n)]
        have h1 : (P.n - P.n % P.M) / p + P.M ≥ P.n / p + 1 := by
          have h2 : (P.n - P.n % P.M) + P.M * p ≥ P.n + p := by
            have : P.n % P.M < P.M := Nat.mod_lt _ hM
            linarith [hp_prime.pos]
          exact Nat.le_div_iff_mul_le (hp_prime.pos) |>.mpr h2
        zify; linarith
      linarith
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hp_prime]
