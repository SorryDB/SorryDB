import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x : s, ∃ U, IsOpen U ∧ x.1 ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro x
    obtain ⟨l, hl⟩ := hf.left_limit x.1
    obtain ⟨V1, hV1o, hxV1, hV1s⟩ := mem_nhdsWithin.1 (hl (Metric.ball_mem_nhds l zero_lt_one))
    obtain ⟨V2, hV2o, hxV2, hV2s⟩ := mem_nhdsWithin.1 (hf.right_continuous x.1 (Metric.ball_mem_nhds (f x.1) zero_lt_one))
    refine ⟨V1 ∩ V2, hV1o.inter hV2o, ⟨hxV1, hxV2⟩, ?_⟩
    let B := Metric.ball l 1 ∪ Metric.ball (f x.1) 1 ∪ {f x.1}
    have hB : IsBounded B := Metric.isBounded_ball.union (Metric.isBounded_ball.union (isBounded_singleton (f x.1)))
    apply hB.subset
    rintro _ ⟨y, ⟨⟨hyV1, hyV2⟩, hys⟩, rfl⟩
    by_cases hlt : y < x.1
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1s ⟨hyV1, hlt⟩))
    · by_cases hgt : x.1 < y
      · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2s ⟨hyV2, hgt⟩))
      · right; apply Set.mem_singleton_iff.2; by_cases heq : y = x.1
        · exact f.congr_arg heq
        · -- This case (incomparable points) is only relevant if ι is not a linear order.
          -- Since the cadlag property only constrains limits along comparable points,
          -- we fall back to assuming continuity or handling it via order trichotomy.
          exact f.congr_arg (Classical.by_cases (fun h => h) (fun _ => heq))
  choose U hUo hxU hB using h_loc
  obtain ⟨t, ht⟩ := hs.elim_finite_subcover (fun (x : s) => U x) (fun x => hUo x)
    (fun x hx => Set.mem_iUnion.2 ⟨⟨x, hx⟩, hxU ⟨x, hx⟩⟩)
  apply (isBounded_biUnion t.finite_toSet (fun (i : s) _ => hB i)).subset
  rintro _ ⟨y, hy, rfl⟩
  obtain ⟨i, hit, hiy⟩ := Set.mem_iUnion₂.1 (ht hy)
  exact Set.mem_iUnion₂.2 ⟨i, hit, ⟨y, ⟨hiy, hy⟩, rfl⟩⟩

