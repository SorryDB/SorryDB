/-
Copyright (c) 2025 Rémy Degenne. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Rémy Degenne
-/
import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  apply hs.induction_on (p := fun t => IsBounded (f '' t))
  · exact isBounded_empty
  · intro t1 t2 hst hb; exact hb.subset (Set.image_subset f hst)
  · intro t1 t2 hb1 hb2; rw [Set.image_union]; exact hb1.union hb2
  · intro x hx
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨U, hU, hB⟩ := hl.isBounded_under_nhds
    obtain ⟨V, hV, hC⟩ := (hf.right_continuous x).isBounded_under_nhds
    rw [nhdsWithin, mem_inf_principal] at hU hV
    obtain ⟨U', hU', hU_sub⟩ := hU
    obtain ⟨V', hV', hV_sub⟩ := hV
    refine ⟨U' ∩ V', Filter.inter_mem hU' hV', ?_⟩
    let W := (U' ∩ V') ∩ (Set.Iio x ∪ Set.Ioi x ∪ {x})
    have hW : f '' W ⊆ (f '' (U' ∩ Set.Iio x)) ∪ (f '' (V' ∩ Set.Ioi x)) ∪ {f x} := by
      rw [Set.image_union, Set.image_union, Set.image_singleton]
      apply Set.union_subset_union
      · apply Set.union_subset_union <;> apply Set.image_subset f <;> intro y hy <;> aesop
      · exact Set.Subset.refl _
    have h_bound : IsBounded (f '' W) := (hB.subset hU_sub).union ((hC.subset hV_sub).union (isBounded_singleton (f x))).subset hW
    exact h_bound.subset (Set.image_subset f (fun y hy => ⟨hy.1, Classical.em (y < x ∨ x < y) |>.by_cases (Or.inl) (fun h => Or.inr (not_or.mp h |>.2.eq_of_not_lt (not_or.mp h |>.1)))⟩))

