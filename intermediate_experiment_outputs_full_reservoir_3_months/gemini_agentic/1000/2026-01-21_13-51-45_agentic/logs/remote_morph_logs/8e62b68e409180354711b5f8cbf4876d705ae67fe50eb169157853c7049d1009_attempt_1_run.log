import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  let p (x : ι) : Prop := ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s))
  have h_loc : ∀ x ∈ s, p x := by
    intro x hx
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨U1, hU1, hB1⟩ := hl.isBounded_under_nhds
    obtain ⟨U2, hU2, hB2⟩ := (hf.right_continuous x).isBounded_under_nhds
    rw [mem_nhdsWithin_iff_exists_mem_nhds] at hU1 hU2
    obtain ⟨V1, hV1, hV1_sub⟩ := hU1
    obtain ⟨V2, hV2, hV2_sub⟩ := hU2
    refine ⟨V1 ∩ V2, inter_mem hV1 hV2, ?_⟩
    let W := V1 ∩ V2 ∩ s
    have hW : W ⊆ (V1 ∩ Set.Iio x) ∪ (V2 ∩ Set.Ioi x) ∪ {x} := by
      intro y hy
      obtain ⟨⟨hyV1, hyV2⟩, hys⟩ := hy
      by_cases hlt : y < x
      · left; left; exact ⟨hyV1, hlt⟩
      · by_cases hgt : x < y
        · left; right; exact ⟨hyV2, hgt⟩
        · right; rw [Set.mem_singleton_iff]; exact (not_lt.1 hlt).eq_of_not_lt hgt
    refine (hB1.subset (Set.image_subset f (fun y hy => hV1_sub ⟨hy.1, hy.2⟩))).union ?_
    refine (hB2.subset (Set.image_subset f (fun y hy => hV2_sub ⟨hy.1, hy.2⟩))).union ?_
    exact isBounded_singleton (f x)
  choose U hU hB using h_loc
  obtain ⟨t, hts, ht_cover⟩ := hs.exists_finite_subcover (fun x _ => interior (U x)) (fun x _ => isOpen_interior) (fun x hx => mem_interior_iff_mem_nhds.m² (hU x hx))
  have h_img : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    intro y hy
    obtain ⟨x, hxt, hxu⟩ := Set.mem_unionᵢ₂.1 (ht_cover hy)
    exact Set.mem_unionᵢ₂.2 ⟨x, hxt, Set.mem_image_of_mem f ⟨interior_subset hxu, hy⟩⟩
  exact (isBounded_bunionᵢ t.finite_toSet (fun x hxt => hB x (hts x hxt))).subset h_img

