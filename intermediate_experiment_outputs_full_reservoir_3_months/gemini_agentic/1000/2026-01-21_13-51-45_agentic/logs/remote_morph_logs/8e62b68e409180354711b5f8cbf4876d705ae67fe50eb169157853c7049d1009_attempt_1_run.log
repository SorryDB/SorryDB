import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x : s, ∃ U, IsOpen U ∧ x.1 ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro ⟨x, hx⟩
    obtain ⟨l, hl⟩ := hf.left_limit x
    have h1 := hl (Metric.ball_mem_nhds l 1)
    have h2 := hf.right_continuous x (Metric.ball_mem_nhds (f x) 1)
    rcases Filter.mem_inf_principal.1 h1 with ⟨V1, hV1, hV1_sub⟩
    rcases Filter.mem_inf_principal.1 h2 with ⟨V2, hV2, hV2_sub⟩
    obtain ⟨U, hU_sub, hU_open, hxU⟩ := (nhds_basis_opens x).mem_iff.1 (Filter.inter_mem hV1 hV2)
    refine ⟨U, hU_open, hxU, ?_⟩
    let B := Metric.ball l 1 ∪ Metric.ball (f x) 1 ∪ {f x}
    have hB : IsBounded B := Metric.isBounded_ball.union (Metric.isBounded_ball.union (isBounded_singleton (f x)))
    apply hB.subset
    rintro _ ⟨y, ⟨hyU, hys⟩, rfl⟩
    by_cases hlt : y < x
    · left; left; apply hV1_sub; exact ⟨hU_sub hyU, hlt⟩
    · by_cases hgt : x < y
      · left; right; apply hV2_sub; exact ⟨hU_sub hyU, hgt⟩
      · right; exact Set.mem_singleton_iff.2 (not_lt.1 hlt |>.eq_of_not_lt hgt)
  choose U hU_open hxU hB using h_loc
  obtain ⟨t, ht_cover⟩ := IsCompact.elim_finite_subcover hs U (fun x => hU_open x) (fun x hx => Set.mem_iUnion.2 ⟨⟨x, hx⟩, hxU ⟨x, hx⟩⟩)
  have h_img_sub : f '' s ⊆ ⋃ i ∈ t, f '' (U i ∩ s) := by
    rintro _ ⟨y, hys, rfl⟩
    obtain ⟨i, hit, hiy⟩ := Set.mem_iUnion₂.1 (ht_cover hys)
    exact Set.mem_iUnion₂.2 ⟨i, hit, ⟨hiy, hys, rfl⟩⟩
  exact (isBounded_biUnion t.finite_toSet (fun i _ => hB i)).subset h_img_sub

