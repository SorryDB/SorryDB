    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := by
    intro x hx
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.1 (hl (Metric.ball_mem_nhds l zero_lt_one))
    obtain ⟨V2, hV2, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.1 (hf.right_continuous x (Metric.ball_mem_nhds (f x) zero_lt_one))
    refine ⟨V1 ∩ V2, inter_mem hV1 hV2, ?_⟩
    let V := V1 ∩ V2
    have h_img : f '' (V ∩ s) ⊆ Metric.ball l 1 ∪ Metric.ball (f x) 1 ∪ {f x} := by
      rintro _ ⟨z, ⟨hzV, hzs⟩, rfl⟩
      by_cases hlt : z < x
      · left; left; apply hV1_sub; exact ⟨hzV.1, hlt⟩
      · by_cases hgt : x < z
        · left; right; apply hV2_sub; exact ⟨hzV.2, hgt⟩
        · right; exact Set.mem_singleton _
    exact (Metric.isBounded_ball.union (Metric.isBounded_ball.union (isBounded_singleton (f x)))).subset h_img
  choose U hU hB using h_loc
  have h_cover_s : s ⊆ ⋃ x ∈ s, interior (U x) := fun x hx => Set.mem_unionᵢ₂.2 ⟨x, hx, mem_interior_iff_mem_nhds.2 (hU x hx)⟩
  obtain ⟨t, ht_cover⟩ := hs.elim_finite_subcover (fun x => interior (U x)) (fun _ => isOpen_interior) h_cover_s
  have h_img_sub : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    rintro _ ⟨z, hzs, rfl⟩
    obtain ⟨x, hxt, hxz⟩ := Set.mem_unionᵢ₂.1 (ht_cover hzs)
