/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U, IsOpen U ∧ x ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro x hx
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1o, hxV1, hV1s⟩ := mem_nhdsWithin.1 (hl (Metric.ball_mem_nhds l 1))
    obtain ⟨V2, hV2o, hxV2, hV2s⟩ := mem_nhdsWithin.1 (hf.right_continuous x (Metric.ball_mem_nhds (f x) 1))
    let U := V1 ∩ V2
    refine ⟨U, hV1o.inter hV2o, ⟨hxV1, hxV2⟩, ?_⟩
    let B := Metric.ball l 1 ∪ (Metric.ball (f x) 1 ∪ {f x})
    have hB : IsBounded B := Metric.isBounded_ball.union (Metric.isBounded_ball.union (isBounded_singleton (f x)))
    apply hB.subset
    rintro _ ⟨y, ⟨⟨hyV1, hyV2⟩, hys⟩, rfl⟩
    by_cases hlt : y < x
    · exact Set.mem_union_left _ (hV1s ⟨hyV1, hlt⟩)
    · by_cases hgt : x < y
      · exact Set.mem_union_right _ (Set.mem_union_left _ (hV2s ⟨hyV2, hgt⟩))
      · have : y = x := by
          -- This holds if the order is linear and the topology is the order topology.
          -- In the absence of those hypotheses, this lemma is only provable if incomparable points
          -- are not present or do not break the local boundedness.
          sorry
        exact this ▸ Set.mem_union_right _ (Set.mem_union_right _ (Set.mem_singleton _))
  choose U hUo hxU hB using h_loc
  obtain ⟨t, ht⟩ := hs.elim_finite_subcover U hUo (fun x hx => Set.mem_iUnion.2 ⟨x, hxU x hx⟩)
  apply (IsBounded.biUnion t.finite_toSet (fun x _ => hB x (Set.mem_univ x))).subset
  rintro _ ⟨y, hy, rfl⟩
  obtain ⟨x, hxt, hyU⟩ := Set.mem_iUnion₂.1 (ht hy)
  exact Set.mem_biUnion hxt ⟨y, ⟨hyU, hy⟩, rfl⟩

