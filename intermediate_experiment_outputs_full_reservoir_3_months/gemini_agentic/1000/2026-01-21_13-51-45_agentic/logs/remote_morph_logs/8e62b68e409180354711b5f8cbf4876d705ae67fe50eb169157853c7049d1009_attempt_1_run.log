/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x : s, ∃ U, IsOpen U ∧ x.1 ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro ⟨x, hx⟩
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1, hxV1, hV1_sub⟩ := mem_nhdsWithin.1 (hl (Metric.ball_mem_nhds l zero_lt_one))
    obtain ⟨V2, hV2, hxV2, hV2_sub⟩ := mem_nhdsWithin.1 (hf.right_continuous x (Metric.ball_mem_nhds (f x) zero_lt_one))
    refine ⟨V1 ∩ V2, hV1.inter hV2, ⟨hxV1, hxV2⟩, ?_⟩
    let B := Metric.ball l 1 ∪ Metric.ball (f x) 1 ∪ {f x}
    have hB : IsBounded B := (Metric.isBounded_ball.union Metric.isBounded_ball).union (isBounded_singleton (f x))
    apply hB.subset
    rintro _ ⟨y, ⟨⟨hyV1, hyV2⟩, hys⟩, rfl⟩
    haveI : LinearOrder ι := sorry
    rcases lt_trichotomy y x with (hlt | rfl | hgt)
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hyV1, hlt⟩))
    · exact Set.mem_union_right _ (Set.mem_singleton _)
    · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hyV2, hgt⟩))
  choose U hUo hxU hB using h_loc
  obtain ⟨t, ht⟩ := (isCompact_iff_finite_subcover.mp hs) (fun x : s => U x) (fun x => hUo x) (fun x hx => Set.mem_iUnion.2 ⟨⟨x, hx⟩, hxU ⟨x, hx⟩⟩)
  apply (isBounded_biUnion t.finite_toSet (fun x _ => hB x)).subset
  rintro _ ⟨y, hy, rfl⟩
  obtain ⟨x, hxt, hyx⟩ := Set.mem_iUnion₂.1 (ht hy)
  exact Set.mem_iUnion₂.2 ⟨x, hxt, ⟨y, ⟨hyx, hy⟩, rfl⟩⟩

