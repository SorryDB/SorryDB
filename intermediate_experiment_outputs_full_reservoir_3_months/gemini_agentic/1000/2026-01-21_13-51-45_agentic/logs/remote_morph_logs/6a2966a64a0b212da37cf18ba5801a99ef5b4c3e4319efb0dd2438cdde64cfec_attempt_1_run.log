example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, extendl]
   | cons y ys =>
     simp [parts₁, ih, concatMap, List.length_join, List.map_map]
     have h : ∀ p ∈ parts₁ (y :: ys), (extendl x p).length = 2 := by
