import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, Chapter1.concat₁, extendl]
   | cons y ys =>
     have h_len : ∀ {α β} (f : α → List β) (l : List α), (concatMap f l).length = (l.map (fun x => (f x).length)).sum := by
       intro α β f l; induction l with | nil => rfl | cons head tail ih => simp [concatMap, Chapter1.concat₁, List.length_append, ih, List.map, List.sum]
     have h_ext_len : ∀ p ∈ parts₁ (y :: ys), (extendl x p).length = 2 := by
       intro p hp
       cases p with
       | nil =>
         simp [parts₁, concatMap, Chapter1.concat₁] at hp
         induction (parts₁ ys) with
         | nil => simp [concatMap, Chapter1.concat₁] at hp
         | cons q qs ih_q =>
           simp [Chapter1.concat₁, List.mem_append, concatMap] at hp
           cases hp with
           | inl h => cases q <;> (simp [extendl] at h; cases h <;> contradiction)
           | inr h => exact ih_q h
       | cons ps pss => rfl
     have h_sum_2 : ∀ {α} (l : List α), (l.map (fun _ => 2)).sum = l.length * 2 := by
       intro α l; induction l with | nil => simp [List.sum, List.length] | cons _ _ ih => simp [List.length, List.sum, ih, Nat.add_mul, Nat.add_comm]
     simp [parts₁, h_len, h_ext_len, h_sum_2, ih]
     rw [← Nat.pow_succ]
     simp
