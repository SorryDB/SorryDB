import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁, List.length]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, extendl, concatMap, Chapter1.concat₁, List.length]
   | cons y ys =>
     have hl {α β} (f : α → List β) (L : List α) (h : ∀ p ∈ L, (f p).length = 2) :
       (concatMap f L).length = L.length * 2 := by
       induction L with
       | nil => rfl
       | cons q L ihL =>
         simp [concatMap, Chapter1.concat₁, List.length_append]
         rw [h q (List.mem_cons_self _ _), ihL (λ r hr => h r (List.mem_cons_of_mem _ hr))]
         simp [Nat.mul_succ, Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]
     have h_p_ne : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       rw [show parts₁ (y :: ys) = concatMap (extendl y) (parts₁ ys) from rfl] at hp
       induction (parts₁ ys) with
       | nil => simp [concatMap] at hp
       | cons q qs ihq =>
         simp [concatMap, Chapter1.concat₁, List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q with
           | nil => simp [extendl] at h; subst h; simp
           | cons qh qt => simp [extendl] at h; cases h <;> (subst h; simp)
         | inr h => exact ihq h
     have h_ext_len : ∀ q ∈ parts₁ (y :: ys), (extendl x q).length = 2 := by
       intro q hq
       specialize h_p_ne q hq
       cases q with
       | nil => contradiction
       | cons qh qt => rfl
     rw [show parts₁ (x :: y :: ys) = concatMap (extendl x) (parts₁ (y :: ys)) from rfl]
     rw [hl (extendl x) (parts₁ (y :: ys)) h_ext_len]
     simp [List.length] at *
     rw [ih, Nat.mul_comm, ← Nat.pow_succ]
