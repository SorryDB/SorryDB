example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil =>
     simp [parts₁, extendl, concatMap, Chapter1.concat₁, List.length]
   | cons y ys =>
     rw [parts₁]
