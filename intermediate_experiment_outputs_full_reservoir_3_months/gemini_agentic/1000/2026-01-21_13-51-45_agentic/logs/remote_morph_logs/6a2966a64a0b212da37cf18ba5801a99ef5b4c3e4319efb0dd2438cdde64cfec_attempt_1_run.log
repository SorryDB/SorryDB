import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, extendl, concatMap, Chapter1.concat₁, List.length]
   | cons y ys =>
     have h_p_ne : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       cases ys with
       | nil => simp [parts₁, extendl, concatMap, Chapter1.concat₁] at hp; subst hp; simp
       | cons z zs =>
         rw [show parts₁ (y :: z :: zs) = concatMap (extendl y) (parts₁ (z :: zs)) from rfl] at hp
         have h_ext_ne : ∀ q r, r ∈ extendl y q → r ≠ [] := by
           intro q r hr; cases q with
           | nil => simp [extendl] at hr; subst hr; simp
           | cons qh qt => simp [extendl] at hr; cases hr <;> { subst hr; simp }
         induction (parts₁ (z :: zs)) with
         | nil => simp [concatMap, Chapter1.concat₁] at hp
         | cons r rs ih_rs =>
           rw [show concatMap (extendl y) (r :: rs) = extendl y r ++ concatMap (extendl y) rs from rfl] at hp
           cases (List.mem_append.1 hp) with
           | inl h => exact h_ext_ne r p h
           | inr h => exact ih_rs h
     rw [show parts₁ (x :: y :: ys) = concatMap (extendl x) (parts₁ (y :: ys)) from rfl]
     have hl : (concatMap (extendl x) (parts₁ (y :: ys))).length = (parts₁ (y :: ys)).length * 2 := by
       let L := parts₁ (y :: ys)
       have h_len : ∀ p ∈ L, (extendl x p).length = 2 := by
         intro p hp; cases p with
         | nil => exact (h_p_ne p hp).elim
         | cons ph pt => rfl
       induction L with
       | nil => simp [concatMap, Chapter1.concat₁]
       | cons r rs ih_rs =>
         rw [show concatMap (extendl x) (r :: rs) = extendl x r ++ concatMap (extendl x) rs from rfl]
         simp [List.length_append, h_len r (by simp), ih_rs (λ p hp => h_len p (by simp [hp]))]
         simp [Nat.mul_succ, Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]
     simp [List.length] at *
     rw [hl, ih, Nat.mul_comm, ← Nat.pow_succ]
