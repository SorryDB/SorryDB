       | cons z zs =>
         rw [parts₁] at hp
         have h_ext_ne : ∀ {q r}, r ∈ extendl y q → r ≠ [] := by
           intro q r hr
           cases q with
           | nil => simp [extendl] at hr; subst hr; simp
           | cons ph pt => simp [extendl] at hr; cases hr <;> { subst hr; simp }
         let f := extendl y
         have h_cm_ne : ∀ {L}, p ∈ concatMap f L → p ≠ [] := by
           intro L hp'
