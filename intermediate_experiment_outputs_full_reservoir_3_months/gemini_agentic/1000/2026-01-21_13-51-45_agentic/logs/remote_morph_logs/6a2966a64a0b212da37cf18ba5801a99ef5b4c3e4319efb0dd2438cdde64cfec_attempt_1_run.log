 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, Chapter1.concat₁, extendl, List.length]
   | cons y ys =>
     have h_len2 {α β} (f : α → List β) (L : List α) (h : ∀ p ∈ L, (f p).length = 2) :
       (concatMap f L).length = L.length * 2 := by
       induction L with
       | nil => simp [concatMap, Chapter1.concat₁, List.length]
       | cons q L ihL =>
