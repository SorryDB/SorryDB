import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, List.length]
   | cons y ys =>
     rw [parts₁]
     have h_ext_ne : ∀ y q r, r ∈ extendl y q → r ≠ [] := by
       intro y q r hr
       cases q with
       | nil => simp [extendl] at hr; subst hr; simp
       | cons qh qt =>
         simp [extendl] at hr
         cases hr with
         | inl h => subst h; simp
         | inr h => subst h; simp
     have h_p_ne : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       cases ys with
       | nil => simp [parts₁] at hp; subst hp; simp
       | cons z zs =>
         rw [parts₁] at hp
         let f := extendl y
         let L := parts₁ (z :: zs)
         have h_cm_ne (L : List (Partition Nat)) : p ∈ concatMap f L → p ≠ [] := by
           induction L with
           | nil => simp [concatMap, Chapter1.concat₁]
           | cons r rs ih_rs =>
             rw [show concatMap f (r :: rs) = f r ++ concatMap f rs from rfl]
             simp [List.mem_append]
             intro h; cases h with | inl h => exact h_ext_ne y r p h | inr h => exact ih_rs h
         exact h_cm_ne L hp
     have hl (L : List (Partition Nat)) : (∀ p ∈ L, (extendl x p).length = 2) → (concatMap (extendl x) L).length = L.length * 2 := by
       intro h_f
       induction L with
       | nil => rfl
       | cons r rs ih_rs =>
         rw [show concatMap (extendl x) (r :: rs) = extendl x r ++ concatMap (extendl x) rs from rfl]
         rw [List.length_append, h_f r (by simp), ih_rs (by intro p hp; exact h_f p (by simp [hp]))]
         simp [Nat.mul_succ, Nat.add_comm, Nat.add_assoc]
     have h_f : ∀ p ∈ parts₁ (y :: ys), (extendl x p).length = 2 := by
       intro p hp; cases p with | nil => exact (h_p_ne p hp).elim | cons ph pt => rfl
     simp [List.length] at *
     rw [hl (parts₁ (y :: ys)) h_f, ih, ← Nat.pow_succ]
