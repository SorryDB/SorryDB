import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, Chapter1.concat₁, extendl, List.foldr, List.length_append]
   | cons y ys =>
     have h_len : ∀ {α} (l : List (List α)), (Chapter1.concat₁ l).length = (l.map List.length).sum := by
       intro α l; induction l with | nil => rfl | cons _ _ ih => simp [Chapter1.concat₁, List.length_append, ih]
     have h_ext : ∀ p ∈ parts₁ (y :: ys), (extendl x p).length = 2 := by
       intro p hp; cases p
       · rw [parts₁, concatMap, Chapter1.concat₁] at hp
         induction (parts₁ ys) with
         | nil => simp [List.foldr] at hp
         | cons q qs ihq =>
           simp [List.foldr, List.mem_append, List.mem_map] at hp
           cases hp with
           | inl h => cases q <;> simp [extendl] at h <;> cases h <;> contradiction
           | inr h => exact ihq h
       · rfl
     have h_sum : ∀ {α} (l : List α) (n : Nat), (l.map (λ _ => n)).sum = l.length * n := by
       intro α l n; induction l with | nil => rfl | cons _ _ ih => simp [List.length, List.sum, Nat.add_mul, ih, Nat.add_comm]
     simp [parts₁, concatMap, h_len, h_ext, h_sum, ih, Nat.pow_succ]
