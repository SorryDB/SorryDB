import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons y ys ih =>
   cases ys with
   | nil => simp [parts₁, concatMap, extendl]
   | cons z zs =>
     simp [parts₁, ih, Nat.pow_succ, concatMap, List.length_flatten, List.map_map]
     have h : ∀ ps ∈ parts₁ (y :: List.cons z zs), (extendl y ps).length = 2 := by
       intro ps hps
       cases ps
       · simp [parts₁, concatMap, extendl] at hps
         rcases hps with ⟨_, _, h⟩; cases h <;> contradiction
       · rfl
     simp [h]
```
