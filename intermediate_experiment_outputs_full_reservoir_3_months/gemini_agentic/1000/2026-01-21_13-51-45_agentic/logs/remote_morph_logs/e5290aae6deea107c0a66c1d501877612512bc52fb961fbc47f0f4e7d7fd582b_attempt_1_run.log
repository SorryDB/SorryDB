example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  induction sl using dropWhileSL.induct p with
  | h1 sl h =>
    simp [dropWhileSL, h, fromSL, nil, isEmpty, sl.lhs, sl.rhs]
  | h2 sl h1 h2 =>
    unfold dropWhileSL; simp [h1, h2]
    have hh : (fromSL sl).head? = headSL sl := by
      cases sl; rename_i l r ok; simp [headSL, fromSL]
      split <;> [simp_all; cases ok.1 (by rfl) <;> (rename_i h; simp [h]); simp]
    rw [h2] at hh; simp [List.head?_eq_none.1 hh, nil, fromSL, dropWhile]
  | h3 sl h1 hsl h2 p_hsl ih =>
    unfold dropWhileSL; simp [h1, h2, p_hsl, ih]
    have ⟨l, r, ok⟩ := sl
    have hh : (fromSL ⟨l, r, ok⟩).head? = some hsl := by
      simp [headSL, fromSL] at h2 ⊢; split at h2 <;> [contradiction; (rename_i y ys; simp at h2; subst y; cases ok.1 (by rfl) with | inl h => simp [h] at ys | inr h => (simp at h; subst ys; simp)); (rename_i x xs; simp at h2; subst x; simp)]
    have ht : (fromSL ⟨l, r, ok⟩).tail = fromSL (tailSL ⟨l, r, ok⟩) := by
      unfold tailSL; simp; split_ifs with hl hl2
      · simp [List.isEmpty_iff] at hl; subst l
        cases ok.1 (by rfl) with | inl hr => simp [hr, fromSL, nil] | inr hr =>
          have ⟨y, hy⟩ : ∃ y, r = [y] := by cases r <;> simp_all; rename_i x xs; cases xs <;> simp_all
          simp [hy, fromSL, nil]
      · have ⟨a, ha⟩ : ∃ a, l = [a] := by cases l <;> simp_all; rename_i x xs; cases xs <;> simp_all
        simp [ha, fromSL, splitInTwoSL]; exact List.take_append_drop (r.reverse.length / 2) r.reverse
      · simp [fromSL]
    match hfs : fromSL ⟨l, r, ok⟩ with
    | [] => simp [hfs] at hh
    | x :: xs => simp [hfs] at hh ht; subst x xs; simp [dropWhile, p_hsl]
  | h4 sl h1 hsl h2 p_hsl =>
    unfold dropWhileSL; simp [h1, h2, p_hsl]
    have ⟨l, r, ok⟩ := sl
    have hh : (fromSL ⟨l, r, ok⟩).head? = some hsl := by
