/--Theorem: A context-free derivation tree has a number of leaves equal to
  the length of the result word.-/
theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  induction dt.depth using Nat.strong_induction_on generalizing dt
  next n ih =>
    cases dt; rename_i tree valid
    cases tree with
    | leaf o =>
      cases o <;> (unfold ContextFreeGrammar.DerivationTree.result ContextFreeGrammar.DerivationTree.collectLeaves' ContextFreeGrammar.PreDerivationTree.result; (try simp [Word.len, Word.mk, Word.eps_len_0]); rfl)
    | inner var children prodRule =>
      let dtree : G.DerivationTree := ⟨ContextFreeGrammar.PreDerivationTree.inner var children prodRule, valid⟩
      unfold ContextFreeGrammar.DerivationTree.result ContextFreeGrammar.DerivationTree.collectLeaves'
      simp (config := {zeta := false}) only [Word.len, ContextFreeGrammar.PreDerivationTree.result]
      let rec go (ts : G.NEPreDerivationTreeList) (v : ts.treeValid) :
        Word.len ts.result = (ts.collectLeaves dtree v).length := by
        match ts with
        | .nil t =>
          simp [ContextFreeGrammar.NEPreDerivationTreeList.result, ContextFreeGrammar.NEPreDerivationTreeList.collectLeaves]
          let c := ContextFreeGrammar.DerivationTree.fromChild dtree t (by simp [ContextFreeGrammar.DerivationTree.children, ContextFreeGrammar.NEPreDerivationTreeList.asList])
          rw [ih c.depth (ContextFreeGrammar.child_less_depth dtree c (by simp [ContextFreeGrammar.DerivationTree.children, ContextFreeGrammar.NEPreDerivationTreeList.asList])) c]
          rfl
        | .cons t ts' =>
          simp [ContextFreeGrammar.NEPreDerivationTreeList.result, ContextFreeGrammar.NEPreDerivationTreeList.collectLeaves, Word.len, List.length_append]
          let c := ContextFreeGrammar.DerivationTree.fromChild dtree t (by simp [ContextFreeGrammar.DerivationTree.children, ContextFreeGrammar.NEPreDerivationTreeList.asList])
          rw [ih c.depth (ContextFreeGrammar.child_less_depth dtree c (by simp [ContextFreeGrammar.DerivationTree.children, ContextFreeGrammar.NEPreDerivationTreeList.asList])) c]
          rw [go ts' (by cases ts <;> cases v <;> assumption)]
      apply go children valid
