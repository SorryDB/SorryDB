lemma vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  let v i j s := x i + y j + z s
  let M s := (1 / 2 : ℝ) • v 0 0 s + (1 / 2 : ℝ) • v 1 1 s
  have hM s : M s = (1 / 2 : ℝ) • v 0 1 s + (1 / 2 : ℝ) • v 1 0 s := by
    simp [v, M, smul_add]; abel
  let s1 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1)}
  have hM1 : M s1 ∈ C := hC ((hxy 0 0 s1).mpr (by simp [s1])) ((hxy 1 1 s1).mpr (by simp [s1]))
    (by norm_num) (by norm_num) (by norm_num)
  let s2 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0)}
  have hM2 : M s2 ∈ C := by
    rw [hM s2]
    exact hC ((hxy 0 1 s2).mpr (by simp [s2])) ((hxy 1 0 s2).mpr (by simp [s2]))
      (by norm_num) (by norm_num) (by norm_num)
  let s3 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (0, 1)}
  have hM3 : M s3 ∈ C := hC ((hxy 0 0 s3).mpr (by simp [s3])) ((hxy 1 1 s3).mpr (by simp [s3]))
    (by norm_num) (by norm_num) (by norm_num)
  let s4 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (1, 0)}
  have hM4 : M s4 ∈ C := hC ((hxy 0 0 s4).mpr (by simp [s4])) ((hxy 1 1 s4).mpr (by simp [s4]))
    (by norm_num) (by norm_num) (by norm_num)
  let P (k : Fin 4) : Fin 2 → ℝ := match k with
    | 0 => ![0, 0]
    | 1 => ![1, 1]
    | 2 => ![0, 1]
    | 3 => ![1, 0]
  let s' : Set (Fin 4) → Set (Fin 2 × Fin 2) := fun s =>
    (if 0 ∈ s then {(0,0)} else ∅) ∪ (if 1 ∈ s then {(1,1)} else ∅) ∪
    (if 2 ∈ s then {(0,1)} else ∅) ∪ (if 3 ∈ s then {(1,0)} else ∅)
  let C' : Set (Fin 2 → ℝ) := {p | ∃ s, p = P 0 + (fun _ => 0) ∧ (0 : Fin 2 × Fin 2) ∈ s' ∅}
  have hC' : Convex ℝ C' := by sorry
  exact vc_lt_four_of_convex_r2 hC' (x := P) (y := fun _ => ![0, 0]) (by sorry)
