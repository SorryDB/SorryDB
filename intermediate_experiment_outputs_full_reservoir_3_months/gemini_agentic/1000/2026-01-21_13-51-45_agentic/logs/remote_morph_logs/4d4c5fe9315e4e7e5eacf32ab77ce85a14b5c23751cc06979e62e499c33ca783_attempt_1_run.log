      rcases this with h0 | h1 | h2 <;> rw [h0, h1, h2] at h3 <;> norm_num at h3
    omega
  have hk2_gt_2n : (k : ℤ) ^ 2 > 2 * (n : ℤ) := by
    rcases hm_ge_1 with rfl | hm_ge_5
