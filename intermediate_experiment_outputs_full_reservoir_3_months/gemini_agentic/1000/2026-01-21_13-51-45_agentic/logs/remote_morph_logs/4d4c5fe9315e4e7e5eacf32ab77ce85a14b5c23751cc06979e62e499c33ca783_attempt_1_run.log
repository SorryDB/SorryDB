        have h2 : m * k ≥ 5 * 1 := by apply Int.mul_le_mul <;> linarith
        linarith
      exact pos_of_mul_pos_left this (by linarith)
  have hp_real : (p : ℝ) = 2 * (n : ℝ) + (k : ℝ) := by push_cast; linarith
  rw [hp_real, add_gt_add_iff_left]
  apply Real.sqrt_lt_iff.mpr
  constructor <;> [linarith; constructor] <;> norm_cast <;> linarith
