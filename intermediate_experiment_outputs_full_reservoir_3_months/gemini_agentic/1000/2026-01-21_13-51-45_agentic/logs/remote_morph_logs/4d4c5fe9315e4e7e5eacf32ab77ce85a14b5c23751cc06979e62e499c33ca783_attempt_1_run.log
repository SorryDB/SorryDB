import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h_inf := Nat.exists_infinite_primes_four_k_one
  obtain ⟨p, hp, hp_mod, hp_gt⟩ := h_inf (max 14 (N ^ 2 + 1))
  have hp_gt_13 : p > 13 := by omega
  have hp_odd : p % 2 = 1 := by
    have : p % 4 = 1 := hp_mod
    rw [← Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4)]
    rw [this]; norm_num
  obtain ⟨x, hx_sq⟩ := hp.exists_sq_eq_neg_one_mod hp_mod
  let n_0 := x % p
  let n := if n_0 < p / 2 then n_0 else p - n_0
  have hn_sq : n ^ 2 % p = p - 1 := by
    have hn0_sq : n_0 ^ 2 % p = p - 1 := by
      rw [Nat.pow_mod, hx_sq]; rfl
    dsimp [n]; split
    · exact hn0_sq
    · rw [Nat.pow_two, Nat.mul_mod, Nat.sub_mod hp.pos, Nat.sub_mod hp.pos]
      simp [hn0_sq, Nat.mod_self]
  have hn_lt_p2 : n < p / 2 := by
    dsimp [n]; split
    · assumption
    · have h_n0_lt_p : n_0 < p := Nat.mod_lt _ hp.pos
      have h_n0_ge_p2 : n_0 ≥ p / 2 := by omega
      have h_n0_ne_p2 : n_0 ≠ p / 2 := by
        intro h; have := hp_odd; rw [h] at this; norm_num at this
      omega
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    rw [Nat.dvd_iff_mod_eq_zero, Nat.add_mod, hn_sq]
    simp [Nat.mod_self]
  have hn_ge_N : n ≥ N := by
    have h_n2_p : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.add_pos_left (Nat.zero_le _) (by norm_num)) hn_dvd
    have : p > N ^ 2 := by omega
    have : n ^ 2 > N ^ 2 - 1 := by omega
    omega
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  set k := p - 2 * n
  have hk_pos : k > 0 := by omega
  have hk_odd : k % 2 = 1 := by
    rw [Nat.sub_mod (by omega), hp_odd]; simp
  have hp_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p - 2 * n) ^ 2 + 4 := rfl
    have : (p - 2 * n) ^ 2 + 4 ≡ (- (2 * n)) ^ 2 + 4 [MOD p] := Nat.ModEq.pow _ (by dsimp [Nat.ModEq]; omega)
    have : 4 * n ^ 2 + 4 = 4 * (n ^ 2 + 1) := by ring
    have h1 : (p - 2 * n) ^ 2 + 4 ≡ 4 * n ^ 2 + 4 [MOD p] := by
      rw [neg_pow_two]; exact this
    have h2 : 4 * (n ^ 2 + 1) ≡ 0 [MOD p] := Nat.modEq_zero_iff_dvd.mpr (Nat.dvd_mul_left _ hn_dvd)
    exact Nat.modEq_zero_iff_dvd.mp (h1.trans h2)
  have hk_gt_4 : k > 4 := by
    have h_k_ne : k ≠ 1 ∧ k ≠ 3 := by
      constructor <;> intro h <;> rw [h] at hp_dvd_k2_4 <;> have := Nat.le_of_dvd (by norm_num) hp_dvd_k2_4 <;> omega
    have : k ≠ 2 ∧ k ≠ 4 := by
      constructor <;> intro h <;> rw [h] at hk_odd <;> norm_num at hk_odd
    omega
  have hk2_gt_2n : (k : ℝ) ^ 2 > 2 * (n : ℝ) := by
    have : (k : ℝ) ^ 2 + 4 ≥ (p : ℝ) := Nat.cast_le.mpr (Nat.le_of_dvd (by omega) hp_dvd_k2_4)
    have : (p : ℝ) = 2 * n + k := by simp [k]; omega
    rw [this]; have : (k : ℝ) ^ 2 + k > (k : ℝ) ^ 2 + 4 := by
      rw [pow_two]; have : k > 4 := hk_gt_4; nlinarith
    nlinarith
  have : (p : ℝ) - 2 * n = k := by simp [k]; omega
  rw [← sub_gt_iff_gt_add, this, Real.gt_sqrt (Nat.cast_nonneg _) (by simp [hk_pos])]
  exact hk2_gt_2n

