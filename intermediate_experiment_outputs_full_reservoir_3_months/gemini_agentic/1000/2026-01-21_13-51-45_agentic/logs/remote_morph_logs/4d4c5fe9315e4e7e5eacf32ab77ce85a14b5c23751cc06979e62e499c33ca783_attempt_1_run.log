/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + 31
  let X := (M !)^2 + 1
  have hX : X > 1 := by
    have hM : M ! ≥ 1 := Nat.factorial_pos M
    calc X > (M !)^2 := Nat.lt_succ_self _
         _ ≥ 1^2 := Nat.pow_le_pow_left hM 2
         _ = 1 := rfl
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt hX)
  have hpgtM : p > M := by
    by_contra hle
    have hpM : p ∣ M ! := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have : p ∣ 1 := (Nat.dvd_add_iff_right (dvd_pow hpM (by norm_num))).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp_odd : p % 2 = 1 := by
    have : p > 2 := by linarith
    rcases hp.eq_two_or_odd with h2 | h_odd
    · absurd this; linarith
    · exact Nat.odd_iff.mp h_odd
  let n0 := (M !) % p
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have : (n0 ^ 2 + 1) % p = ((M !)^2 + 1) % p := by
      rw [Nat.add_mod, Nat.pow_mod, Nat.mod_mod]
    rw [Nat.modEq_zero_iff_dvd.mp (Nat.modEq_zero_iff_dvd.mpr hpdvd)] at this
    exact Nat.modEq_zero_iff_dvd.mpr this
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    dsimp [n]; split_ifs with h_n0_le
    · exact hn0_dvd
    · zify
      have : (↑n : ℤ) = ↑p - ↑n0 := by rw [Int.ofNat_sub (Nat.le_of_lt (Nat.mod_lt _ hp.pos))]
      rw [this]
      have : (↑p - ↑n0 : ℤ) ^ 2 + 1 = ↑p * (↑p - 2 * ↑n0) + (↑n0 ^ 2 + 1) := by ring
      rw [this]
      apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr hn0_dvd)
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by norm_num) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 31 := by linarith
    nlinarith
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k : ℤ := (p : ℤ) - 2 * n
  have hk_pos : k > 0 := by
    have h2n_le_p : 2 * n ≤ p := by
      dsimp [n]; split_ifs with h
      · exact Nat.mul_le_of_le_div 2 h
      · have : n0 < p := Nat.mod_lt _ hp.pos; linarith
    have h2n_ne_p : 2 * n ≠ p := by intro h; rw [← h] at hp_odd; norm_num at hp_odd
    linarith
  have hp_dvd_k2_4 : (p : ℤ) ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p : ℤ) * ((p : ℤ) - 4 * n) + 4 * (n ^ 2 + 1) := by ring
    rw [this]
    apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr (Nat.dvd_mul_right hn_dvd 4))
  let m : ℤ := (k ^ 2 + 4) / p
  have hm_eq : m * p = k ^ 2 + 4 := Int.mul_ediv_cancel' hp_dvd_k2_4
  have hm_ge_1 : m = 1 ∨ m ≥ 5 := by
    have hm_pos : m > 0 := by have : k^2 + 4 > 0 := by nlinarith; linarith
    have hm_odd : m % 2 = 1 := by
      have : (m * p) % 2 = (k ^ 2 + 4) % 2 := by rw [← hm_eq]
      have : (p : ℤ) % 2 = 1 := by norm_cast
      have : k % 2 = 1 := by have : (k + 2 * n) % 2 = (p : ℤ) % 2 := by ring_nf; simp; rw [this]; exact this
      omega
    have hm_ne_3 : m ≠ 3 := by
      intro h; rw [h] at hm_eq
      have : (k ^ 2 + 4) % 3 = (3 * p) % 3 := by rw [← hm_eq]
      simp at this; have : (k ^ 2 + 1) % 3 = 0 := by omega
      have : (k : ℤ) % 3 = 0 ∨ (k : ℤ) % 3 = 1 ∨ (k : ℤ) % 3 = 2 := by omega
      rcases this with h0 | h1 | h2 <;> rw [h0, h1, h2] at this <;> norm_num at this
    omega
  have hk2_gt_2n : (k : ℤ) ^ 2 > 2 * n := by
    rcases hm_ge_1 with rfl | hm_ge_5
    · have : (p : ℤ) = k ^ 2 + 4 := by linarith
      have : 2 * n = k ^ 2 - k + 4 := by linarith
      have : k ^ 2 + 4 > 31 := by linarith
      nlinarith
    · have : m * (k ^ 2 - 2 * n) = (m - 1) * k ^ 2 + m * k - 4 := by
        have : (p : ℤ) = 2 * n + k := by linarith
        rw [← hm_eq, this]; ring
      have : m * (k ^ 2 - 2 * n) > 0 := by rw [this]; have : k ≥ 1 := by linarith; nlinarith
      exact pos_of_mul_pos_left this (by linarith)
  have hp_real : (p : ℝ) = 2 * (n : ℝ) + (k : ℝ) := by norm_cast; linarith
  rw [hp_real, add_gt_add_iff_left]
  apply Real.sqrt_lt_iff.mpr
  constructor
  · norm_cast; linarith
  · constructor
    · norm_cast; linarith
    · norm_cast; exact hk2_gt_2n
