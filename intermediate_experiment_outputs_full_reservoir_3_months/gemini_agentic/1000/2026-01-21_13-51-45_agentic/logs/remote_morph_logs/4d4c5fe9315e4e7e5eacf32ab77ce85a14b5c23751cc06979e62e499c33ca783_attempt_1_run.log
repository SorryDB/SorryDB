import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + 101
  let X := (M !)^2 + 1
  have hX : X ≥ 2 := by
    have hM : M ! ≥ 1 := Nat.factorial_pos M
    calc (M !)^2 + 1 ≥ 1^2 + 1 := Nat.add_le_add_right (Nat.pow_le_pow_left hM 2) 1
         _ = 2 := rfl
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt (by linarith [hX]))
  have hpgtM : p > M := by
    by_contra hle
    have hpM : p ∣ M ! := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have hpdvdM2 : p ∣ (M !)^2 := dvd_pow hpM (by norm_num)
    have : p ∣ 1 := (Nat.dvd_add_iff_right hpdvdM2).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp_odd : p % 2 = 1 := Nat.odd_iff.mp (hp.odd_of_gt_two (by linarith))
  let n0 := (M !) % p
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have h1 : n0 ≡ M ! [MOD p] := Nat.mod_modEq (M !) p
    have h2 : n0 ^ 2 + 1 ≡ (M !)^2 + 1 [MOD p] := (h1.pow 2).add_right 1
    exact Nat.modEq_zero_iff_dvd.mp (h2.trans (Nat.modEq_zero_iff_dvd.mpr hpdvd))
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    dsimp [n]; split_ifs with h_n0_le
    · exact hn0_dvd
    · have h_n0_lt_p : n0 < p := Nat.mod_lt _ hp.pos
      apply Int.ofNat_dvd.mp; push_cast
      have : (n : ℤ) = (p : ℤ) - (n0 : ℤ) := by
        rw [Int.ofNat_sub (Nat.le_of_lt h_n0_lt_p)]
      rw [this]
      have : ((p : ℤ) - n0) ^ 2 + 1 = (p : ℤ) * ((p : ℤ) - 2 * n0) + (n0 ^ 2 + 1) := by ring
      rw [this]
      apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr hn0_dvd)
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.zero_lt_succ _) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 101 := by linarith
    have : n ^ 2 > N ^ 2 := by linarith
    exact (Nat.pow_lt_pow_iff_left (by norm_num)).mp this |>.le
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k : ℤ := (p : ℤ) - 2 * (n : ℤ)
  have hk_pos : k > 0 := by
    have h_n0_lt_p : n0 < p := Nat.mod_lt _ hp.pos
    dsimp [n]; split_ifs with h_n0_le
    · have : p % 2 = 1 := hp_odd; omega
    · omega
  have hp_dvd_k2_4 : (p : ℤ) ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p : ℤ) * (p - 4 * n) + 4 * (n ^ 2 + 1) := by ring
    rw [this]
    apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr (Nat.dvd_mul_right hn_dvd 4))
  let m : ℤ := (k ^ 2 + 4) / (p : ℤ)
  have hm_eq : m * (p : ℤ) = k ^ 2 + 4 := Int.mul_ediv_cancel' hp_dvd_k2_4
  have hm_ge_1 : m = 1 ∨ m ≥ 5 := by
    have hm_pos : m > 0 := by
      have : k ^ 2 + 4 > 0 := by nlinarith
      have : m * (p : ℤ) > 0 := by linarith [hm_eq]
      exact pos_of_mul_pos_left this (by linarith)
    have hm_odd : m % 2 = 1 := by
      have h1 : (m * (p : ℤ)) % 2 = (k ^ 2 + 4) % 2 := by rw [← hm_eq]
      have h2 : (p : ℤ) % 2 = 1 := by rw [← Int.ofNat_mod, hp_odd]; rfl
      have h3 : (k : ℤ) % 2 = 1 := by
        rw [show (k : ℤ) = (p : ℤ) - 2 * n by rfl, Int.sub_emod, h2]
        simp; norm_num
      rw [Int.mul_emod, h2] at h1; rw [Int.add_emod, Int.pow_emod, h3] at h1
      simp at h1; exact h1
    have hm_ne_3 : m ≠ 3 := by
      intro h; rw [h] at hm_eq
      have h3 : (k ^ 2 + 4) % 3 = (3 * (p : ℤ)) % 3 := by rw [← hm_eq]
