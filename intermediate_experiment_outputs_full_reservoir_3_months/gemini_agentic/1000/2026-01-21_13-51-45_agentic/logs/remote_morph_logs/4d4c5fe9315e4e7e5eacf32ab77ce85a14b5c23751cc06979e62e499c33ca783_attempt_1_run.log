    apply Int.ofNat_dvd.mp
    have : (k : ℤ) = (p : ℤ) - 2 * n := by rw [Int.ofNat_sub]; omega
    have : (k : ℤ) ^ 2 + 4 = (p : ℤ) ^ 2 - 2 * p * (2 * n) + 4 * (n ^ 2 + 1) := by rw [this]; ring
    rw [this]
    apply Int.dvd_add
    · apply Int.dvd_sub (Int.dvd_pow_self _ (by omega)) (Int.dvd_mul_right _ _)
    · exact Int.ofNat_dvd.mpr (Nat.dvd_mul_left p hn_dvd)
  let m := (k ^ 2 + 4) / p
  have hk_sq_4 : k ^ 2 + 4 = m * p := (Nat.div_mul_cancel hp_dvd_k2_4).symm
  have hk2_gt_2n : 2 * n < k ^ 2 := by
    have hm_odd : m % 2 = 1 := by
      have : (m * p) % 2 = (k ^ 2 + 4) % 2 := by rw [← hk_sq_4]
      have hmp : (m * p) % 2 = m % 2 := by rw [Nat.mul_mod, hp_odd]; simp
