import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2) 14
  let X := (Nat.factorial M) ^ 2 + 1
  have hX : X > 1 := by
    have : Nat.factorial M ≥ 1 := Nat.factorial_pos M
    nlinarith
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd hX
  have hpgtM : p > M := by
    by_contra hle
    have : p ∣ Nat.factorial M := Nat.dvd_factorial (Nat.Prime.pos hp) (Nat.le_of_not_gt hle)
    have : p ∣ 1 := (Nat.dvd_add_iff_right (Nat.dvd_pow this (by norm_num))).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp13 : p > 13 := by omega
  let n0 := (Nat.factorial M) % p
  have hn0_sq : n0 ^ 2 % p = p - 1 := by
    have : ((Nat.factorial M) ^ 2 + 1) % p = 0 := Nat.dvd_iff_mod_eq_zero.mp hpdvd
    have : ((Nat.factorial M) ^ 2 % p + 1) % p = 0 := by
      rw [← this, Nat.add_mod, Nat.mod_self, Nat.mod_mod]
    have hM2p : (Nat.factorial M) ^ 2 % p < p := Nat.mod_lt _ hp.pos
    omega
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_sq : n ^ 2 % p = p - 1 := by
    dsimp [n]; split
    · exact hn0_sq
    · rw [Nat.pow_two, Nat.mul_mod, Nat.sub_mod hp.pos, Nat.sub_mod hp.pos]
      simp [hn0_sq, Nat.mod_self]
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    rw [Nat.dvd_iff_mod_eq_zero, Nat.add_mod, hn_sq]
    simp [hp.pos]
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by norm_num) hn_dvd
    have : n ^ 2 ≥ p - 1 := by omega
    have : n ^ 2 ≥ M := by omega
    exact Nat.le_of_pow_le_pow_left (by norm_num) (by omega)
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  have hp_odd : p % 2 = 1 := hp.mod_two_eq_one (by omega)
  have hn_lt_p2 : n < p / 2 := by
    dsimp [n]; split
    · have : n0 ≠ p / 2 := by
        intro h; have : 2 * n0 = p := by omega
        have : 2 ∣ p := ⟨n0, this.symm⟩
        have : p = 2 := hp.eq_two_of_dvd this
        omega
      omega
    · have : n0 < p := Nat.mod_lt _ hp.pos
      omega
  let k := p - 2 * n
  have hk_pos : k > 0 := by omega
  have hk_odd : k % 2 = 1 := by
    rw [Nat.sub_mod (by omega), hp_odd]; simp
  have hp_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    have : (k : ℤ) ^ 2 + 4 = (p - 2 * n : ℤ) ^ 2 + 4 := by
      rw [← Int.ofNat_sub (by omega)]; rfl
    have : (k : ℤ) ^ 2 + 4 = p ^ 2 - 4 * p * n + 4 * (n ^ 2 + 1) := by
      rw [this]; ring
    rw [this]
    apply Int.dvd_add
    · apply Int.dvd_sub (Int.dvd_pow_self (p : ℤ) (by norm_num)) (Int.dvd_mul_right (p : ℤ) (4 * n))
    · exact Int.ofNat_dvd.mpr (Nat.dvd_mul_left p hn_dvd)
  let m := (k ^ 2 + 4) / p
  have hk_sq_4 : k ^ 2 + 4 = m * p := (Nat.div_mul_cancel hp_dvd_k2_4).symm
  have hk2_gt_2n : k ^ 2 > 2 * n := by
    have hmk : (2 * m * n : ℤ) = (k : ℤ) ^ 2 - (m * k : ℤ) + 4 := by
      have : (m * (2 * n + k) : ℤ) = (k : ℤ) ^ 2 + 4 := by
        rw [← hk_sq_4]; simp [k, Nat.sub_add_cancel (by omega)]
      linarith
    have hm_odd : m % 2 = 1 := by
      have : (m * p) % 2 = 1 := by rw [← hk_sq_4, Nat.add_mod, Nat.pow_two, Nat.mul_mod, hk_odd]; norm_num
      exact Nat.odd_mul.mp this |>.1
    have hm_ne_3 : m ≠ 3 := by
      intro hm3
      have : (k ^ 2 + 4) % 3 = (3 * p) % 3 := by rw [← hk_sq_4, hm3]
      simp at this
      have : (k ^ 2 + 4) % 3 = 2 := by
        have : k % 3 = 1 ∨ k % 3 = 2 := by
          have : k % 3 ≠ 0 := by intro h0; rw [h0] at this; norm_num at this
          omega
        rcases this with h1 | h2 <;> rw [Nat.add_mod, Nat.pow_two, h1, h2] <;> norm_num
      omega
    if hm1 : m = 1 then
      have : p = k ^ 2 + 4 := by rw [← hk_sq_4, hm1]; simp
      have : k ≥ 5 := by
        have : k ^ 2 > 9 := by omega
        have : k > 3 := Nat.le_of_pow_le_pow_left (by norm_num) (by omega)
        omega
      zify [hmk, hm1]; linarith
    else
      have : m ≥ 5 := by omega
      zify [hmk]; nlinarith
  rw [← sub_gt_iff_gt_add, show (p : ℝ) - 2 * n = k by simp [k]; omega]
  exact (Real.gt_sqrt (Nat.cast_nonneg _) (Nat.cast_pos.mpr hk_pos)).mpr (Nat.cast_lt.mpr hk2_gt_2n)

