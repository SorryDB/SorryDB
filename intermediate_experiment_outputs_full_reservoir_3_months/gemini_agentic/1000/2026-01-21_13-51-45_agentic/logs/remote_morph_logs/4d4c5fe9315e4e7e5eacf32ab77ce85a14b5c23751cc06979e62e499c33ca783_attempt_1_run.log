import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2) 14
  let X := (Nat.factorial M) ^ 2 + 1
  have hX : X > 1 := by
    have h1 : Nat.factorial M ≥ 1 := Nat.factorial_pos M
    calc X > (Nat.factorial M) ^ 2 := Nat.lt_succ_self _
         _ ≥ 1^2 := Nat.pow_le_pow_left h1 2
         _ = 1 := rfl
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt hX)
  have hpgtM : p > M := by
    by_contra hle
    have : p ∣ Nat.factorial M := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have : p ∣ 1 := (Nat.dvd_add_iff_right (Nat.dvd_pow this (by norm_num))).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp_odd : p % 2 = 1 := by
    have : p > 2 := by omega
    rcases hp.eq_two_or_odd with h2 | h_odd
    · omega
    · exact Nat.odd_iff.mp h_odd
  let n0 := (Nat.factorial M) % p
  have hn0_sq : n0 ^ 2 % p = p - 1 := by
    have : (n0 ^ 2 + 1) % p = 0 := by
      rw [Nat.add_mod, Nat.pow_mod, ← Nat.add_mod]
      exact Nat.mod_eq_zero_of_dvd hpdvd
    have hlt : n0 ^ 2 % p < p := Nat.mod_lt _ hp.pos
    omega
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    rw [Nat.dvd_iff_mod_eq_zero, Nat.add_mod]
    have : n ^ 2 % p = p - 1 := by
      have h1 : (n ^ 2 : ℤ) ≡ (n0 ^ 2 : ℤ) [ZMOD p] := by
        dsimp [n]; split
        · rfl
        · apply Int.ModEq.pow
          rw [Int.modEq_iff_add_dvd]
          simp
      have h2 : (n ^ 2 % p : ℤ) = (n0 ^ 2 % p : ℤ) := by
        rw [← Int.ofNat_mod, ← Int.ofNat_mod, (Int.ModEq.mod_iff p).mp h1]
      exact_mod_cast (h2.trans (by exact_mod_cast hn0_sq))
    rw [this, Nat.mod_self, Nat.mod_mod]
    omega
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) hn_dvd
    have : n ^ 2 ≥ p - 1 := by omega
    have : n ^ 2 ≥ N ^ 2 := by omega
    rw [← Nat.mul_self_le_mul_self_iff]
    exact this
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k := p - 2 * n
  have hk_pos : k > 0 := by
    have : n ≤ p / 2 := by dsimp [n]; split <;> omega
    have : 2 * n ≤ p := Nat.mul_le_of_le_div 2 this
    have : 2 * n ≠ p := by intro h; rw [← h] at hp_odd; norm_num at hp_odd
    omega
  have hp_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    zify
    have : ((k : ℤ) ^ 2 + 4) % (p : ℤ) = ((p - 2 * n : ℤ) ^ 2 + 4) % (p : ℤ) := by rw [Int.ofNat_sub (by omega)]
    rw [this, Int.modEq_iff_add_dvd]
    have : (p - 2 * (n : ℤ)) ^ 2 + 4 ≡ (-2 * n) ^ 2 + 4 [ZMOD p] := by
      apply Int.ModEq.add_right; apply Int.ModEq.pow; simp [Int.modEq_iff_add_dvd]
    rw [Int.modEq_iff_add_dvd] at this ⊢
    have : (-2 * (n : ℤ)) ^ 2 + 4 = 4 * (n ^ 2 + 1) := by ring
    rw [this]
    exact Int.ofNat_dvd.mpr (Nat.dvd_mul_left p hn_dvd)
  let m := (k ^ 2 + 4) / p
  have hk_sq_4 : k ^ 2 + 4 = m * p := (Nat.div_mul_cancel hp_dvd_k2_4).symm
  have hk2_gt_2n : 2 * n < k ^ 2 := by
    have hm_pos : m > 0 := Nat.pos_of_mul_pos_left (by omega)
    have : (2 * m * n : ℤ) = k ^ 2 - m * k + 4 := by
      have : m * (2 * n + k) = k ^ 2 + 4 := by rw [← hk_sq_4, Nat.add_sub_cancel' (by omega)]
      zify at this; linarith
    have h_m_k2_2n : (m : ℤ) * (k ^ 2 - 2 * n) = (m - 1) * k ^ 2 + m * k - 4 := by linarith
    have : (m - 1 : ℤ) * k ^ 2 + m * k - 4 > 0 := by
      if hm1 : m = 1 then
        simp [hm1]
        have : k ^ 2 = p - 4 := by have : p = k ^ 2 + 4 := by rw [← hk_sq_4, hm1]; simp
                                   omega
        have : k ^ 2 > 9 := by omega
        have : k > 3 := by have : k * k > 3 * 3 := by exact_mod_cast this
                           omega
        omega
      else
        have hm_odd : m % 2 = 1 := by
          have : (m * p) % 2 = (k ^ 2 + 4) % 2 := by rw [← hk_sq_4]
          have : k % 2 = 1 := by have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.add_sub_cancel' (by omega)]
                                rw [Nat.add_mod, Nat.mul_mod_right] at this; omega
          rw [Nat.mul_mod, Nat.add_mod, Nat.pow_mod, this] at this; omega
        have : m ≥ 3 := by omega
        have : (m - 1 : ℤ) * k ^ 2 + m * k - 4 ≥ (3 - 1) * 1 ^ 2 + 3 * 1 - 4 := by
          apply add_le_add
          · apply mul_le_mul_of_nonneg_left (by exact_mod_cast (Nat.one_le_pow 2 k hk_pos)) (by omega)
          · omega
        omega
    have : (m : ℤ) * (k ^ 2 - 2 * (n : ℤ)) > 0 := by rw [h_m_k2_2n]; exact this
    exact (mul_pos_iff_of_pos (by exact_mod_cast hm_pos)).mp this
  have : (p : ℝ) = 2 * n + k := by rw [show (p : ℝ) = ↑(2 * n + k) by congr; omega]; simp
  rw [this, add_gt_add_iff_left]
  exact (Real.sqrt_lt (Nat.cast_nonneg (2 * n))).mpr (by exact_mod_cast hk2_gt_2n)

