import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + 101
  let X := (M !)^2 + 1
  have hX : X ≥ 2 := by
    have hM : M ! ≥ 1 := Nat.factorial_pos M
    calc (M !)^2 + 1 ≥ 1^2 + 1 := Nat.add_le_add_right (Nat.pow_le_pow_left hM 2) 1
         _ = 2 := rfl
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt (by linarith))
  have hpgtM : p > M := by
    by_contra hle
    have hpM : p ∣ M ! := hp.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have hpdvdM2 : p ∣ (M !)^2 := hpM.pow 2
    have : p ∣ 1 := (Nat.dvd_add_iff_right hpdvdM2).mp hpdvd
    exact hp.not_dvd_one this
  have hp_odd_nat : p % 2 = 1 := by
    rcases hp.eq_two_or_odd with h2 | ho
    · linarith [hpgtM, M]
    · exact Nat.odd_iff.mp ho
  let n0 := (M !) % p
  have h_n0_lt_p : n0 < p := Nat.mod_lt _ hp.pos
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have h1 : n0 ≡ M ! [MOD p] := Nat.mod_modEq (M !) p
    have h2 : n0 ^ 2 + 1 ≡ (M !)^2 + 1 [MOD p] := (h1.pow 2).add_right 1
    exact Nat.modEq_zero_iff_dvd.mp (h2.trans (Nat.modEq_zero_iff_dvd.mpr hpdvd))
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    if h : n0 ≤ p / 2 then
      rw [if_pos h]; exact hn0_dvd
    else
      rw [if_neg h]
      apply Int.ofNat_dvd.mp; push_cast
      have : (n : ℤ) = (p : ℤ) - (n0 : ℤ) := by rw [Int.ofNat_sub h_n0_lt_p.le]
      rw [this]
      have : ((p : ℤ) - n0) ^ 2 + 1 = (p : ℤ) * ((p : ℤ) - 2 * n0) + (n0 ^ 2 + 1) := by ring
      rw [this]
      apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr hn0_dvd)
  have hn_ge_N : n ≥ N := by
    have : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by positivity) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 101 := by linarith [hpgtM, M]
    have : n ^ 2 > N ^ 2 := by linarith
    exact (Nat.pow_lt_pow_iff_left (by norm_num)).mp this |>.le
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k : ℤ := (p : ℤ) - 2 * (n : ℤ)
  have hk_pos : k > 0 := by
    if h : n0 ≤ p / 2 then
      have : n = n0 := if_pos h
      have : p % 2 = 1 := hp_odd_nat; omega
    else
      have : n = p - n0 := if_neg h
      have : n0 < p := h_n0_lt_p; omega
  have hp_dvd_k2_4 : (p : ℤ) ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p : ℤ) * ((p : ℤ) - 4 * (n : ℤ)) + 4 * ((n : ℤ) ^ 2 + 1) := by ring
    rw [this]
    apply dvd_add (dvd_mul_right (p : ℤ) _) (Int.ofNat_dvd.mpr (hn_dvd.mul_right 4))
  let m : ℤ := (k ^ 2 + 4) / (p : ℤ)
  have hm_eq : m * (p : ℤ) = k ^ 2 + 4 := Int.ediv_mul_cancel hp_dvd_k2_4
  have hm_ge_1 : m = 1 ∨ m ≥ 5 := by
    have hm_pos : m > 0 := by
      have : m * (p : ℤ) = k ^ 2 + 4 := hm_eq
      have : m * (p : ℤ) > 0 := by linarith
      exact pos_of_mul_pos_left this (by linarith)
    have hm_odd : m % 2 = 1 := by
      have h1 : (m * (p : ℤ)) % 2 = (k ^ 2 + 4) % 2 := by rw [← hm_eq]
      have h2 : (p : ℤ) % 2 = 1 := by rw [Int.ofNat_mod, hp_odd_nat]; rfl
      have h3 : (k : ℤ) % 2 = 1 := by
        rw [show (k : ℤ) = (p : ℤ) - 2 * n by rfl, Int.sub_emod, h2]
