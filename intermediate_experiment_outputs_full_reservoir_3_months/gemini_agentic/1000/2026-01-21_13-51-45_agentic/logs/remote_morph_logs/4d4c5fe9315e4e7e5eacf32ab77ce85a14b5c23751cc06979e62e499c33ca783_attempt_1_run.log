import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2) 14
  let X := (Nat.factorial M) ^ 2 + 1
  have hX : X > 1 := by
    have hM : Nat.factorial M ≥ 1 := Nat.factorial_pos M
    calc X > (Nat.factorial M) ^ 2 := Nat.lt_succ_self _
         _ ≥ 1 ^ 2 := Nat.pow_le_pow_left hM 2
         _ = 1 := rfl
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt hX)
  have hpgtM : p > M := by
    by_contra hle
    have : p ∣ Nat.factorial M := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have : p ∣ 1 := (Nat.dvd_add_iff_right (Nat.dvd_pow this (by norm_num))).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp2 : p ≠ 2 := by omega
  have hp_odd : p % 2 = 1 := Nat.odd_iff.mp (hp.eq_two_or_odd.resolve_left hp2)
  let n0 := (Nat.factorial M) % p
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have : n0 ^ 2 + 1 ≡ (Nat.factorial M) ^ 2 + 1 [MOD p] :=
      Nat.ModEq.add_right 1 (Nat.ModEq.pow 2 (Nat.mod_modEq _ _))
    exact Nat.modEq_zero_iff_dvd.mp (Nat.ModEq.trans this (Nat.modEq_zero_iff_dvd.mpr hpdvd))
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    dsimp [n]; split
    · exact hn0_dvd
    · zify; have : (↑p - ↑n0 : ℤ) ^ 2 + 1 = ↑p * (↑p - 2 * ↑n0) + (↑n0 ^ 2 + 1) := by ring
      rw [this]; apply Int.dvd_add (Int.dvd_mul_right _ _) (Int.ofNat_dvd.mpr hn0_dvd)
  have hn_ge_N : n ≥ N := by
    have hnp : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by norm_num) hn_dvd
    have : n ^ 2 ≥ N ^ 2 := by omega
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) this
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k := p - 2 * n
  have hk_pos : k > 0 := by
    have : n ≤ p / 2 := by dsimp [n]; split <;> omega
    have : 2 * n ≤ p := Nat.mul_le_of_le_div 2 this
    have : 2 * n ≠ p := by intro h; rw [← h] at hp_odd; norm_num at hp_odd
    omega
  have hp_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    zify [k]
    have : (↑p - 2 * ↑n : ℤ) ^ 2 + 4 = ↑p * (↑p - 4 * ↑n) + 4 * (↑n ^ 2 + 1) := by ring
    rw [this]; apply Int.dvd_add (Int.dvd_mul_right _ _) (Int.ofNat_dvd.mpr (Nat.dvd_mul_left p hn_dvd))
  let m := (k ^ 2 + 4) / p
  have hk_sq_4 : k ^ 2 + 4 = m * p := (Nat.div_mul_cancel hp_dvd_k2_4).symm
  have hk2_gt_2n : 2 * n < k ^ 2 := by
    have hm_pos : m > 0 := Nat.pos_of_mul_pos_left (by omega : m * p > 0)
    have hm_odd : m % 2 = 1 := by
      have : (m * p) % 2 = (k ^ 2 + 4) % 2 := by rw [← hk_sq_4]
      have : p % 2 = 1 := hp_odd
      have : k % 2 = 1 := by have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.add_sub_cancel' (by omega)]
                            rw [Nat.add_mod, Nat.mul_mod_right] at this; omega
      omega
    have hm_ne_3 : m ≠ 3 := by
      intro hm3; have : (k ^ 2 + 4) % 3 = (3 * p) % 3 := by rw [hk_sq_4, hm3]
      have h30 : (k ^ 2 + 1) % 3 = 0 := by rw [Nat.mul_mod_right] at this; omega
      have : k % 3 = 0 ∨ k % 3 = 1 ∨ k % 3 = 2 := by omega
      rcases this with h0 | h1 | h2 <;> rw [h0, h1, h2] at h30 <;> norm_num at h30
    have h_pos : (↑m - 1) * (↑k ^ 2 : ℤ) + ↑m * ↑k - 4 > 0 := by
      rcases (by omega : m = 1 ∨ m ≥ 5) with rfl | hm5
      · simp; have : (k : ℤ) ≥ 5 := by
          have : k ^ 2 = p - 4 := by omega
          have : k ^ 2 ≥ 13 := by omega
          have : k % 2 = 1 := by have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.add_sub_cancel' (by omega)]
                                 rw [Nat.add_mod, Nat.mul_mod_right] at this; omega
          rcases (by omega : k = 1 ∨ k = 2 ∨ k = 3 ∨ k ≥ 4) with rfl|rfl|rfl|h_ge_4 <;> norm_num at this
          rcases (by omega : k = 4 ∨ k ≥ 5) with rfl|h_ge_5 <;> norm_num at this; exact_mod_cast h_ge_5
        omega
      · have : (k : ℤ) ≥ 1 := by exact_mod_cast hk_pos
        have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
        nlinarith
    have : (m : ℤ) * (k ^ 2 - 2 * n) = (m - 1 : ℤ) * k ^ 2 + m * k - 4 := by zify [k]; linarith [hk_sq_4]
    have : (m : ℤ) * (k ^ 2 - 2 * n) > 0 := by rw [this]; exact h_pos
    exact (mul_pos_iff_of_pos (by exact_mod_cast hm_pos)).mp this
  have : (p : ℝ) = 2 * n + k := by exact_mod_cast (by omega)
  rw [this, Nat.cast_add, Nat.cast_mul, add_gt_add_iff_left]
  exact (Real.sqrt_lt (Nat.cast_nonneg (2 * n))).mpr (by simp [hk_pos]; exact_mod_cast hk2_gt_2n)

