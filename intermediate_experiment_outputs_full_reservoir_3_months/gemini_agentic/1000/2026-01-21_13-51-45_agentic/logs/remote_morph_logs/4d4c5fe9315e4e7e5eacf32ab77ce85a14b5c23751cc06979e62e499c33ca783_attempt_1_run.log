import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 5) 30
  let X := (Nat.factorial M) ^ 2 + 1
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (by
    have hM : M ! ≥ 1 := Nat.factorial_pos M
    calc X > M ! ^ 2 := Nat.lt_succ_self _
         _ ≥ 1 ^ 2 := Nat.pow_le_pow_left hM 2
         _ = 1 := rfl)
  have hpgtM : p > M := by
    by_contra hle
    have : p ∣ Nat.factorial M := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have : p ∣ 1 := (Nat.dvd_add_iff_right (dvd_pow this (by norm_num))).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp2 : p ≠ 2 := by omega
  have hp_odd : p % 2 = 1 := by
    rcases hp.eq_two_or_odd with h2 | h_odd
    · exact (hp2 h2).elim
    · exact Nat.odd_iff.mp h_odd
  let n0 := (Nat.factorial M) % p
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have : n0 ^ 2 + 1 ≡ (Nat.factorial M) ^ 2 + 1 [MOD p] :=
      Nat.ModEq.add_right 1 (Nat.ModEq.pow 2 (Nat.mod_modEq (Nat.factorial M) p))
    exact Nat.modEq_zero_iff_dvd.mp (Nat.ModEq.trans this (Nat.modEq_zero_iff_dvd.mpr hpdvd))
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    dsimp [n]; split
    · exact hn0_dvd
    · have : (p - n0 : ℤ) ^ 2 + 1 = (p : ℤ) * (p - 2 * n0) + (n0 ^ 2 + 1) := by ring
      have h_int : (p : ℤ) ∣ (p - n0 : ℤ) ^ 2 + 1 := by
        rw [this]; apply dvd_add (dvd_mul_right _ _) (by exact_mod_cast hn0_dvd)
      have : (p - n0 : ℤ) = (n : ℤ) := by rw [Int.ofNat_sub (by omega)]; rfl
      rw [← this] at hn0_dvd; exact_mod_cast h_int
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by norm_num) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 5 := by omega
    omega
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k := p - 2 * n
  have hk_pos : k > 0 := by
    have : 2 * n ≤ p := by
      if h : n0 ≤ p / 2 then simp [n, h]; exact Nat.mul_le_of_le_div 2 h
      else simp [n, h]; have : n0 > p / 2 := by omega; have : p - n0 < p - p / 2 := by omega
           have : p / 2 + 1 > (p : ℚ) / 2 := by simp; ring_nf; norm_num
           omega
    have : 2 * n ≠ p := by intro h; rw [← h] at hp_odd; norm_num at hp_odd
    omega
  have hp_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    have : (p - 2 * n : ℤ) ^ 2 + 4 = (p : ℤ) * (p - 4 * n) + 4 * (n ^ 2 + 1) := by ring
    have h : (p : ℤ) ∣ (p - 2 * n : ℤ) ^ 2 + 4 := by
      rw [this]; apply dvd_add (dvd_mul_right _ _) (by exact_mod_cast (Nat.dvd_mul_left p hn_dvd))
    have : (p - 2 * n : ℤ) = (k : ℤ) := by rw [Int.ofNat_sub (by dsimp [n]; split <;> omega)]
    rw [this] at h; exact_mod_cast h
  let m := (k ^ 2 + 4) / p
  have hk_sq_4 : k ^ 2 + 4 = m * p := (Nat.div_mul_cancel hp_dvd_k2_4).symm
  have hk2_gt_2n : 2 * n < k ^ 2 := by
    have hm_pos : m > 0 := Nat.pos_of_mul_pos_right (by omega : 0 < m * p) hp.pos
    have hm_odd : m % 2 = 1 := by
      have : (m * p) % 2 = (k ^ 2 + 4) % 2 := by rw [← hk_sq_4]
      have : k % 2 = 1 := by
        have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel (by dsimp [n]; split <;> omega)]
        rw [Nat.add_mod, Nat.mul_mod_right, hp_odd] at this; exact this
      rw [Nat.mul_mod, hp_odd, Nat.add_mod, Nat.pow_mod, this] at this; norm_num at this; exact this
    have hm_ne_3 : m ≠ 3 := by
      intro hm3; have : (k ^ 2 + 4) % 3 = (3 * p) % 3 := by rw [hk_sq_4, hm3]
      have h3 : (k ^ 2 + 1) % 3 = 0 := by omega
      have : k % 3 = 0 ∨ k % 3 = 1 ∨ k % 3 = 2 := by omega
      rcases this with h0 | h1 | h2 <;> rw [h0, h1, h2] at h3 <;> norm_num at h3
    have h_pos : (m - 1 : ℤ) * k ^ 2 + m * k - 4 > 0 := by
      rcases (by omega : m = 1 ∨ m ≥ 5) with rfl | hm5
      · simp; have : k ^ 2 = p - 4 := by omega
        have : k ≥ 7 := by
          have : k ^ 2 > 26 := by omega
          have : k % 2 = 1 := by
            have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel (by dsimp [n]; split <;> omega)]
            omega
