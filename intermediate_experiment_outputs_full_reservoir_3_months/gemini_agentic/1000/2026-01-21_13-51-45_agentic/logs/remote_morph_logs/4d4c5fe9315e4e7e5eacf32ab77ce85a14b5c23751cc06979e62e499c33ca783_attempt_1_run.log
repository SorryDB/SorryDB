        have : (k : ℤ) ≥ 1 := by exact_mod_cast hk_pos
        nlinarith
    have h_mk2_2n : (m : ℤ) * (k ^ 2 - 2 * n) = (m - 1 : ℤ) * k ^ 2 + m * k - 4 := by
      have h1 : (m : ℤ) * p = k ^ 2 + 4 := by exact_mod_cast hk_sq_4
      have h2 : (p : ℤ) = 2 * n + k := by exact_mod_cast (Nat.sub_add_cancel (by dsimp [n]; split <;> omega))
      rw [← h1, h2]; ring
    rw [← h_mk2_2n] at h_pos
    exact (Int.mul_pos_iff_of_pos_left (by exact_mod_cast hm_pos)).mp h_pos
  have : (p : ℝ) = 2 * n + k := by exact_mod_cast (Nat.sub_add_cancel (by dsimp [n]; split <;> omega))
  rw [this, Nat.cast_add, Nat.cast_mul, add_gt_add_iff_left]
  exact (Real.sqrt_lt (Nat.cast_nonneg (2 * n))).mpr (by exact_mod_cast hk2_gt_2n)
