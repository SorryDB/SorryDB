  have hn_dvd : p ∣ n ^ 2 + 1 := by
    have h_int : (p : ℤ) ∣ (n : ℤ) ^ 2 + 1 := by
      dsimp [n]
      split_ifs with h_n0_le
      · exact Int.ofNat_dvd.mpr hn0_dvd
      · have : (n : ℤ) = (p : ℤ) - (n0 : ℤ) := by rw [Int.ofNat_sub (by linarith)]
        rw [this]
