import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + 100
  let X := (M !)^2 + 1
  have hX : X ≥ 2 := by
    have hM : M ! ≥ 1 := Nat.factorial_pos M
    nlinarith
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_and_dvd (Nat.ne_of_gt (by linarith [hX]))
  have hpgtM : p > M := by
    by_contra hle
    have hpM : p ∣ M ! := Nat.dvd_factorial hp.pos (Nat.le_of_not_gt hle)
    have hpdvdM2 : p ∣ (M !)^2 := dvd_pow hpM (by norm_num)
    have : p ∣ 1 := (Nat.dvd_add_iff_right hpdvdM2).mp hpdvd
    exact Nat.Prime.not_dvd_one hp this
  have hp_odd : p % 2 = 1 := by
    have : p > 2 := by linarith
    exact hp.eq_two_or_odd.resolve_left (by linarith) |> Nat.odd_iff.mp
  let n0 := (M !) % p
  have hn0_dvd : p ∣ n0 ^ 2 + 1 := by
    have : n0 ≡ M ! [MOD p] := Nat.mod_modEq (M !) p
    have h_mod : n0 ^ 2 + 1 ≡ (M !)^2 + 1 [MOD p] := this.pow 2 |>.add_right 1
    exact Nat.mod_zero_iff_dvd.mp (h_mod.trans (Nat.mod_zero_iff_dvd.mpr hpdvd))
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    dsimp [n]; split_ifs with h_n0_le
    · exact hn0_dvd
    · have : (n : ℤ) = (p : ℤ) - (n0 : ℤ) := by
        rw [Int.ofNat_sub (Nat.le_of_lt (Nat.mod_lt _ hp.pos))]
      apply Int.ofNat_dvd.mp; rw [this]
      have : ((p : ℤ) - n0) ^ 2 + 1 = (p : ℤ) * ((p : ℤ) - 2 * n0) + (n0 ^ 2 + 1) := by ring
      rw [this]; apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr hn0_dvd)
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 100 := by linarith
    nlinarith
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  let k : ℤ := (p : ℤ) - 2 * (n : ℤ)
  have hk_pos : k > 0 := by
    have h2n_lt_p : 2 * n < p := by
      dsimp [n]; split_ifs with h_n0_le
      · have : 2 * n0 ≤ 2 * (p / 2) := Nat.mul_le_mul_left 2 h_n0_le
        exact this.trans_lt (Nat.div_two_mul_lt_of_odd (Nat.odd_iff.mpr hp_odd))
      · have : n0 < p := Nat.mod_lt _ hp.pos
        linarith
    linarith
  have hp_dvd_k2_4 : (p : ℤ) ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p : ℤ) * (p - 4 * n) + 4 * (n ^ 2 + 1) := by ring
    rw [this]; apply dvd_add (dvd_mul_right _ _) (Int.ofNat_dvd.mpr (dvd_mul_right hn_dvd 4))
  let m : ℤ := (k ^ 2 + 4) / (p : ℤ)
  have hm_eq : m * p = k ^ 2 + 4 := Int.ediv_mul_cancel hp_dvd_k2_4
  have hm_ge_1 : m = 1 ∨ m ≥ 5 := by
    have hm_pos : m > 0 := by
      have : k ^ 2 + 4 > 0 := by nlinarith
      have : m * (p : ℤ) > 0 := by linarith [hm_eq]
      exact pos_of_mul_pos_left this (by linarith)
    have hm_odd : m % 2 = 1 := by
      have : (m * p : ℤ) % 2 = (k ^ 2 + 4) % 2 := by rw [← hm_eq]
      rw [Int.mul_emod, Int.add_emod, Int.pow_emod] at this
      have h_p_odd : (p : ℤ) % 2 = 1 := by rw [← Int.ofNat_mod, hp_odd]; rfl
      have h_k_odd : (k : ℤ) % 2 = 1 := by rw [show (k : ℤ) = (p : ℤ) - 2 * n by rfl, Int.sub_emod, h_p_odd]; norm_num
      rw [h_p_odd, h_k_odd] at this; norm_num at this; exact this
    have hm_ne_3 : m ≠ 3 := by
      intro h; rw [h] at hm_eq
      have : (k ^ 2 + 4) % 3 = (3 * p) % 3 := by rw [← hm_eq]
      rw [Int.mul_emod] at this; norm_num at this
      have h_k_mod : (k ^ 2 + 1) % 3 = 0 := by rw [← Int.add_emod, this]; norm_num
