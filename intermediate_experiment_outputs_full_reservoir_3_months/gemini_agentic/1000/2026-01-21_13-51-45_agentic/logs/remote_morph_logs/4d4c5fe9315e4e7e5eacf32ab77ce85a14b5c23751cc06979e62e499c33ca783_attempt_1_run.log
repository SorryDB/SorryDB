    rcases hm_ge_1 with rfl | hm_ge_5
    · have : (p : ℤ) = k ^ 2 + 4 := by linarith
      have : 2 * (n : ℤ) = (p : ℤ) - k := by linarith
      rw [‹(p : ℤ) = k ^ 2 + 4›] at this
      have : k ^ 2 - 2 * n = k - 4 := by linarith
      have : k ^ 2 + 4 > 100 := by linarith
      have : k ≥ 10 := by nlinarith
      linarith
    · have : m * (k ^ 2 - 2 * n) = (m - 1) * k ^ 2 + m * k - 4 := by
        have : (p : ℤ) = 2 * n + k := by linarith
        rw [← hm_eq, this]; ring
