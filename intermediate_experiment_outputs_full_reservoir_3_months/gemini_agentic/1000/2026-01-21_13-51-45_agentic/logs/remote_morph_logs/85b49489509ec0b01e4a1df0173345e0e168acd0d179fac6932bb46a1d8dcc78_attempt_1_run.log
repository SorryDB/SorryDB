theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ)∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  constructor
  · rw [le_div_iff (by exact_mod_cast k.factorial_pos)]
    norm_cast
    rw [← Nat.descFactorial_eq_factorial_mul_choose]
    apply Nat.descFactorial_le_pow
  · apply div_le_div_of_nonneg_left (by positivity) (by positivity)
    norm_cast
    rcases k with _ | k
    · simp
    · induction' k with k ih
      · simp
      · rw [Nat.factorial_succ, pow_succ]
        exact Nat.mul_le_mul (by omega) ih
```
