namespace LessEqThan
/-
template LessEqThan(n) {
    signal input in[2];
    signal output out;

    component lt = LessThan(n);

    lt.in[0] <== in[0];
    lt.in[1] <== in[1]+1;
    lt.out ==> out;
}
-/
def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp_all only [circuit_norm, LessThan.circuit, Prod.mk.injEq]
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy' : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    rw [ZMod.val_add_of_lt hy', ZMod.val_one] at h_holds
    by_cases hy : y.val + 1 = 2^n
    case neg =>
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]
    case pos =>
      have h_le : ZMod.val x ≤ ZMod.val y := Nat.le_of_lt_succ (by rwa [hy])
      simp [h_le]
      have h_LT_holds : Holds (LessThan.circuit n hn) i env (x, y + 1) := by
        simp [LessThan.circuit, circuit_norm] at *
        assumption
      rcases h_LT_holds with ⟨h_LT_main, -⟩
      simp [LessThan.main, Num2Bits.circuit, circuit_norm] at h_LT_main
      rcases h_LT_main with ⟨bits, h_nb, h_out⟩
      have h_nb_spec := h_nb.2 (by
        simp [hy, ZMod.val_pow, ZMod.val_ofNat_of_lt (Fact.out : p.Prime), ZMod.val_ofNat_of_lt (Fact.out : p > 2)]
        have h_2n_p : 2^n < p := lt_of_le_of_lt (by gcongr; repeat linarith) hn
        simp [ZMod.val_ofNat_of_lt h_2n_p]
        exact lt_trans assumptions.1 (by gcongr; repeat linarith))
      rw [h_out, h_nb_spec]
      simp [fieldToBits, toBits, Nat.testBit_eq_false_of_lt assumptions.1, circuit_norm, hy]

  completeness := by
    circuit_proof_start
    simp_all [circuit_norm, LessThan.circuit]
