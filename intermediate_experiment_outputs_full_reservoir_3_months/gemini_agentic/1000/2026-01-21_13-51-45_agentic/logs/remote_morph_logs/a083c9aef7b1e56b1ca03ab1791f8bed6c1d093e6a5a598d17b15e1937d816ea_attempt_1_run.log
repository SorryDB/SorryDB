theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x => simp [fastCheckMem, mem, beq_iff_eq]
  | node v left right ih_l ih_r =>
    simp [fastCheckMem, mem]
    split_ifs with h1 h2
    · simp [beq_iff_eq.mp h1, h.2.2.2.2]
    · rw [ih_l h.2.2.1]
      exact ⟨Or.inl, fun | .inl hl => hl | .inr hr => (not_le_of_gt h2 (h.2.1 label hr)).elim⟩
    · rw [ih_r h.2.2.2.1]; simp [beq_iff_eq] at h1; simp at h2
      exact ⟨Or.inr, fun | .inl hl => h2 (lt_of_le_of_ne (h.1 label hl) h1.symm) | .inr hr => hr⟩
```
