      (fun ω ↦ min_le_right _ _)).congr (hτk.mono fun ω h ↦ by simp [stoppedValue, h])
  have h_measZ : AEStronglyMeasurable (stoppedValue X (τ ⊓ σ)) P :=
    (measurable_stoppedValue (hX1.1.progMeasurable_of_rightContinuous hX2) (hτ.min hσ)).aestronglyMeasurable
