    stronglyMeasurable_condExp.aestronglyMeasurable ?_
  intro s hs _
  rw [setIntegral_condExp h_intY (hσ.measurableSpace_le s hs)]
  exact Submartingale.setIntegral_stoppedValue_min_le_stoppedValue hX1 hX2 hσ hτ hτk hs
