    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]
    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}
    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  letI : MeasurableSpace E := borel E
  letI : BorelSpace E := ⟨rfl⟩
  have h_intY : Integrable (stoppedValue X τ) P := by
    set τ' := τ ⊓ fun _ ↦ (k : WithTop ι)
    have hτ'st : IsStoppingTime 𝓕 τ' := hτ.min (isStoppingTime_const 𝓕 k)
    have hτ'le : ∀ ω, τ' ω ≤ k := fun ω ↦ min_le_right _ _
    refine (integrable_stoppedValue_of_le hX1.integrable hX1 hX2 hτ'st hτ'le).congr ?_
    filter_upwards [hτk] with ω hω
