  have h_intZ : Integrable (stoppedValue X (τ ⊓ σ)) P := by
    set σ' := (τ ⊓ σ) ⊓ fun _ ↦ (k : WithTop ι)
    have hσ'st : IsStoppingTime 𝓕 σ' := (hτ.min hσ).min (isStoppingTime_const 𝓕 k)
    have hσ'le : ∀ ω, σ' ω ≤ k := fun ω ↦ min_le_right _ _
    refine (integrable_stoppedValue_of_le hX1.integrable hX1 hX2 hσ'st hσ'le).congr ?_
    filter_upwards [hτk] with ω hω
    simp only [stoppedValue, min_assoc]
    rw [min_eq_left]
    exact (min_le_left (τ ω) (σ ω)).trans hω
  have h_measZ : AEStronglyMeasurable[hσ.measurableSpace] (stoppedValue X (τ ⊓ σ)) P :=
    ((stronglyMeasurable_stoppedValue (hX1.adapted.progMeasurable_of_rightContinuous hX2)
      (hτ.min hσ)).mono ((hτ.min hσ).measurableSpace_mono hσ (fun ω ↦ min_le_right _ _))
      le_rfl).aestronglyMeasurable
  refine ae_le_condExp_of_forall_setIntegral_le h_intZ h_intY h_measZ
    stronglyMeasurable_condExp.aestronglyMeasurable ?_
  intro s hs
  rw [setIntegral_condExp h_intY (hσ.measurableSpace_le s hs)]
  exact Submartingale.setIntegral_stoppedValue_min_le_stoppedValue hX1 hX2 hσ hτ hτk hs

