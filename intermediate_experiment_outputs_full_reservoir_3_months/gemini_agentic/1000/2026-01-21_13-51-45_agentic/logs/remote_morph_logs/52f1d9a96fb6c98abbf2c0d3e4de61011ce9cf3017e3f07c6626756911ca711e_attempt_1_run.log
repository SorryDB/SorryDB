    have h_abc_expr : a * b * c = 4 * (y * z + z * x + x * y - 2 * x * y * z) - 1 := by
      dsimp [a, b, c]; nlinarith [h₁]
    have h_abc_le : a * b * c ≤ 1 / 27 := by
