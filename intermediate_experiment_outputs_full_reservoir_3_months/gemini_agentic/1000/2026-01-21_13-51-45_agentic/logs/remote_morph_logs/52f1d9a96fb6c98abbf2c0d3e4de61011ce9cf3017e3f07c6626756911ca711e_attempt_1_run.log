import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
    have : x ≤ 1 ∧ y ≤ 1 ∧ z ≤ 1 := by linarith [h₀.1, h₀.2.1, h₀.2.2, h₁]
    nlinarith [h₀.1, h₀.2.1, h₀.2.2]
  · let a := 1 - 2 * x
    let b := 1 - 2 * y
    let c := 1 - 2 * z
    have h_abc : a * b * c = 4 * (y * z + z * x + x * y - 2 * x * y * z) - 1 := by
      calc a * b * c
        _ = (1 - 2 * x) * (1 - 2 * y) * (1 - 2 * z) := rfl
        _ = 1 - 2 * (x + y + z) + 4 * (y * z + z * x + x * y) - 8 * x * y * z := by ring
        _ = 4 * (y * z + z * x + x * y - 2 * x * y * z) - 1 := by rw [h₁]; ring
    have h_abc_le : a * b * c ≤ 1 / 27 := by
      by_cases ha : a < 0
      · have : b > 0 ∧ c > 0 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
        nlinarith
      · by_cases hb : b < 0
        · have : a ≥ 0 ∧ c > 0 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
          nlinarith
        · by_cases hc : c < 0
          · have : a ≥ 0 ∧ b ≥ 0 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
            nlinarith
          · have ha_ge : a ≥ 0 ∧ a ≤ 1 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
            have hb_ge : b ≥ 0 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
            have hc_ge : c ≥ 0 := by linarith [h₁, h₀.1, h₀.2.1, h₀.2.2]
            have hbc : b * c ≤ (1 - a) * (1 - a) / 4 := by
              have : 0 ≤ (b - c) * (b - c) := by nlinarith
              have : b + c = 1 - a := by linarith
              linarith
            have : a * b * c ≤ a * ((1 - a) * (1 - a) / 4) := by nlinarith
            have h_le : a * ((1 - a) * (1 - a) / 4) ≤ 1 / 27 := by
              have : 1 / 27 - a * ((1 - a) * (1 - a) / 4) = -(3 * a - 1) * (3 * a - 1) * (3 * a - 4) / 108 := by ring
              have : (3 * a - 1) * (3 * a - 1) * (3 * a - 4) ≤ 0 := by
                have : (3 * a - 1) * (3 * a - 1) ≥ 0 := by nlinarith
                linarith [ha_ge.2]
              linarith
            linarith
    linarith [h_abc, h_abc_le]
