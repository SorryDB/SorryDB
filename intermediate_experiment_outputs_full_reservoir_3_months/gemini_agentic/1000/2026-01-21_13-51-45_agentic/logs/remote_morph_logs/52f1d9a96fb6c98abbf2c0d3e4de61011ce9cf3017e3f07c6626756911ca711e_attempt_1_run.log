        · have : a * b * c ≤ 0 := by
            have ha' : 0 ≤ a := by linarith
            have hc : 0 ≤ c := by linarith
            rw [show a * b * c = b * (a * c) by ring]
            exact mul_nonpos_of_nonpos_of_nonneg (le_of_lt hb) (mul_nonneg ha' hc)
          linarith
        · by_cases hc : c < 0
          · have : a * b * c ≤ 0 := by
              have ha' : 0 ≤ a := by linarith
              have hb' : 0 ≤ b := by linarith
              rw [show a * b * c = c * (a * b) by ring]
              exact mul_nonpos_of_nonpos_of_nonneg (le_of_lt hc) (mul_nonneg ha' hb')
            linarith
          · have ha0 : 0 ≤ a := by linarith
            have hb0 : 0 ≤ b := by linarith
            have hc0 : 0 ≤ c := by linarith
            have hbc : b * c ≤ ((b + c) / 2) ^ 2 := by
              have : 0 ≤ (b - c) ^ 2 := pow_two_nonneg (b - c)
              linarith
            have h_abc_le_a_expr : a * b * c ≤ a * ((1 - a) / 2) ^ 2 := by
              rw [mul_assoc, show b + c = 1 - a by linarith]
              exact mul_le_mul_of_nonneg_left hbc ha0
            have h_max : a * ((1 - a) / 2) ^ 2 ≤ 1 / 27 := by
              have h_diff : 1 / 27 - a * (1 - a) ^ 2 / 4 = (1 - 3 * a) ^ 2 * (4 - 3 * a) / 108 := by ring
              have h_sq : 0 ≤ (1 - 3 * a) ^ 2 := pow_two_nonneg (1 - 3 * a)
              have h_43a : 0 ≤ 4 - 3 * a := by linarith
              have h_pos : 0 ≤ (1 - 3 * a) ^ 2 * (4 - 3 * a) / 108 :=
                div_nonneg (mul_nonneg h_sq h_43a) (by linarith)
              linarith
            linarith
    linarith
