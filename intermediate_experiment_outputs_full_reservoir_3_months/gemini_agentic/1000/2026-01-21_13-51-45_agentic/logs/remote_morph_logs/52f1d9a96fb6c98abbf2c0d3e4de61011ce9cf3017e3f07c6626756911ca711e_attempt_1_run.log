/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have hx1 : x ≤ 1 := by linarith
    have hy1 : y ≤ 1 := by linarith
    have hz1 : z ≤ 1 := by linarith
    calc 0 ≤ x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by
          repeat apply add_nonneg
          · apply mul_nonneg (mul_nonneg h₀.1 h₀.2.1); linarith
          · apply mul_nonneg (mul_nonneg h₀.2.1 h₀.2.2); linarith
          · apply mul_nonneg (mul_nonneg h₀.2.2 h₀.1); linarith
          · apply mul_nonneg (mul_nonneg h₀.1 h₀.2.1); exact h₀.2.2
         _ = y * z + z * x + x * y - 2 * x * y * z := by ring
  · let a := 1 - 2 * x
    let b := 1 - 2 * y
    let c := 1 - 2 * z
    have h_abc_expr : a * b * c = 4 * (y * z + z * x + x * y - 2 * x * y * z) - 1 := by
      dsimp [a, b, c]
      calc (1 - 2 * x) * (1 - 2 * y) * (1 - 2 * z)
        _ = 1 - 2 * (x + y + z) + 4 * (x * y + y * z + z * x) - 8 * x * y * z := by ring
        _ = 1 - 2 * 1 + 4 * (x * y + y * z + z * x) - 8 * x * y * z := by rw [h₁]
        _ = 4 * (y * z + z * x + x * y - 2 * x * y * z) - 1 := by ring
    have h_abc_le : a * b * c ≤ 1 / 27 := by
      by_cases ha : a < 0
      · have : a * b * c ≤ 0 := by
          have hb : 0 ≤ b := by linarith
          have hc : 0 ≤ c := by linarith
          exact mul_nonpos_of_nonpos_of_nonneg (le_of_lt ha) (mul_nonneg hb hc)
        linarith
