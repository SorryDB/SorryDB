@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have hx1 : x ≤ 1 := by linarith
    have hy1 : y ≤ 1 := by linarith
    have hz1 : z ≤ 1 := by linarith
    rw [show y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z by ring]
    have : 0 ≤ x * y * (1 - z) := by nlinarith
    have : 0 ≤ y * z * (1 - x) := by nlinarith
    have : 0 ≤ z * x * (1 - y) := by nlinarith
    have : 0 ≤ x * y * z := by nlinarith
    linarith
  · let a := 1 - 2 * x; let b := 1 - 2 * y; let c := 1 - 2 * z
    have h_abc_expr : a * b * c = 1 - 2 * (x + y + z) + 4 * (x * y + y * z + z * x) - 8 * x * y * z := by dsimp [a, b, c]; ring
    rw [h₁] at h_abc_expr
    have h_abc_le : a * b * c ≤ 1 / 27 := by
      have ha1 : a ≤ 1 := by linarith
      have hb1 : b ≤ 1 := by linarith
      have hc1 : c ≤ 1 := by linarith
      by_cases h_pos : 0 ≤ a ∧ 0 ≤ b ∧ 0 ≤ c
      · have h_sum : a + b + c = 1 := by linarith
        have hbc : b * c ≤ ((b + c) / 2) ^ 2 := by
          have : 0 ≤ (b - c) ^ 2 := pow_two_nonneg (b - c)
          linarith
        have : a * b * c ≤ a * ((1 - a) / 2) ^ 2 := by
          have : b + c = 1 - a := by linarith
          nlinarith [h_pos.1]
        have : a * ((1 - a) / 2) ^ 2 ≤ 1 / 27 := by
          have : 1 / 27 - a * (1 - a) ^ 2 / 4 = (1 - 3 * a) ^ 2 * (4 - 3 * a) / 108 := by ring
          have : 4 - 3 * a ≥ 0 := by linarith
          have : (1 - 3 * a) ^ 2 ≥ 0 := pow_two_nonneg (1 - 3 * a)
          linarith
        linarith
      · push_neg at h_pos
        have : a * b * c ≤ 0 := by
