import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · rcases h₀ with ⟨hx, hy, hz⟩
    have h_expr : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
    rw [h_expr]
    repeat apply add_nonneg
    · apply mul_nonneg (mul_nonneg hx hy); linarith
    · apply mul_nonneg (mul_nonneg hy hz); linarith
    · apply mul_nonneg (mul_nonneg hz hx); linarith
    · exact mul_nonneg (mul_nonneg hx hy) hz
  · rcases h₀ with ⟨hx, hy, hz⟩
    by_cases h_z_le : z ≤ 1 / 2
    · have hxy : x * y ≤ (x + y) ^ 2 / 4 := by nlinarith
      have hf : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - 2 * z) + z * (1 - z) := by
        rw [← h₁]; ring
      have h_le : x * y * (1 - 2 * z) ≤ (1 - z) ^ 2 / 4 * (1 - 2 * z) := by
        have h12z : 0 ≤ 1 - 2 * z := by linarith
        have hxy_le : x * y ≤ (1 - z) ^ 2 / 4 := by
          have : x + y = 1 - z := by linarith
          linarith [hxy]
        exact mul_le_mul_of_nonneg_right hxy_le h12z
      have h_final : (1 - z) ^ 2 / 4 * (1 - 2 * z) + z * (1 - z) ≤ 7 / 27 := by
        have h_diff : 7 / 27 - ((1 - z) ^ 2 / 4 * (1 - 2 * z) + z * (1 - z)) = (3 * z - 1) ^ 2 * (6 * z + 1) / 108 := by ring
        have h_pos : 0 ≤ (3 * z - 1) ^ 2 * (6 * z + 1) / 108 := by
          apply div_nonneg
          · apply mul_nonneg (pow_two_nonneg _)
            linarith
          · linarith
        linarith
      rw [hf]
      linarith
    · have h_z_gt : 1 / 2 < z := by linarith
      have hf : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - 2 * z) + z * (1 - z) := by
        rw [← h₁]; ring
      have h_term1 : x * y * (1 - 2 * z) ≤ 0 := by
        have : 1 - 2 * z ≤ 0 := by linarith
        have : 0 ≤ x * y := mul_nonneg hx hy
        exact mul_nonpos_of_nonneg_of_nonpos this (by linarith)
      have h_term2 : z * (1 - z) ≤ 7 / 27 := by
        have : z * (1 - z) ≤ 1 / 4 := by nlinarith [pow_two_nonneg (z - 1 / 2)]
        have : (1 / 4 : ℝ) ≤ 7 / 27 := by norm_num
        linarith
      rw [hf]
      linarith

