  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have hn_pos : 0 < P.n := by nlinarith [P.hL, P.hL_pos]
  by_cases hprime : p.Prime
  · have h_bal_le : P.initial.balance p ≤ P.M * (Real.log P.n / Real.log p) := by
      unfold Factorization.balance Factorization.sum Params.initial
      have hsum : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (P.n.factorial.factorization p - (P.n - P.n / P.M).factorial.factorization p) := by
        norm_cast; simp only [Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
        gcongr; apply Multiset.sum_le_sum; intro m hm
        rw [Multiset.mem_filter] at hm; exact hm.1
      have h_diff : (P.n.factorial.factorization p : ℤ) - ((P.n - P.n / P.M).factorial.factorization p : ℤ) ≤ (P.n / P.M) / (p - 1) + Real.log P.n / Real.log p := sorry
      sorry
    have h_log_p : Real.log p ≥ Real.log 2 := Real.log_le_log (by norm_num) (by exact_mod_cast hprime.two_le)
    have : Real.log P.n / Real.log p ≤ Real.log P.n / Real.log 2 := by
      gcongr; exact Real.log_pos (by norm_num)
    sorry
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    positivity
