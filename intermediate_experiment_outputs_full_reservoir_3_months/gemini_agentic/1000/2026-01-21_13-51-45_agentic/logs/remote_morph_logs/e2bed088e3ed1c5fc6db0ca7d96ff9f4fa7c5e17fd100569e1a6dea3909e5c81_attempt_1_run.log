          exact mul_le_mul_of_nonneg_left (Int.ofNat_le.mpr this) (Int.ofNat_zero_le M)
        linarith [Int.ofNat_le.mpr (Nat.mul_div_le_div n M (p ^ k))]
      apply h_sum_le_M.trans
      simp only [Finset.sum_const, Finset.card_Ico, nsmul_eq_mul, sub_add_cancel]
      apply (mul_le_mul_of_nonneg_left (Int.ofNat_le.mpr (Nat.log_mono p (by linarith))) (Int.ofNat_zero_le M)).trans
      sorry
    exact (sub_le_sub_right h_sum_le _).trans (by exact_mod_cast h_diff_le)
