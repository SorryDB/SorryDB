@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · let n := P.n; let M := P.M; let n0 := n - n / M
    unfold Factorization.balance Factorization.sum; push_cast
    have hleS : P.initial.a ≤ (Multiset.replicate M (Multiset.Ico n0 n)).join := Multiset.filter_le _ _
    have h_sum_le : (P.initial.a.map (fun m ↦ (m.factorization p : ℤ))).sum ≤
        (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) := by
      let S := (Multiset.replicate M (Multiset.Ico n0 n)).join
      have h_sum_S : (S.map (fun m ↦ (m.factorization p : ℤ))).sum =
          (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) := by
        simp only [S, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, nsmul_eq_mul]
        have h_dvd : n0.factorial ∣ n.factorial := Nat.factorial_dvd_factorial (Nat.sub_le_self n (n/M))
        rw [← Int.ofNat_sub (Nat.factorization_le_of_dvd h_dvd (Nat.factorial_ne_zero n))]
        rw [Nat.factorization_div h_dvd, factorization_multiset_prod]
        · rw [Multiset.prod_Ico, Nat.factorial_div (Nat.sub_le_self n (n/M))]
        · intro x hx; rw [Multiset.mem_Ico] at hx; exact (Nat.pos_of_mem_Ico hx).ne'
      rw [← h_sum_S]
      let f_val (m : ℕ) := (m.factorization p : ℤ)
      have : (P.initial.a.map f_val) ≤ (S.map f_val) := Multiset.map_le_map hleS
      obtain ⟨k, hk⟩ := Multiset.le_iff_exists_add.mp this
      rw [hk, Multiset.sum_add]
      have : 0 ≤ k.sum := Multiset.sum_nonneg (fun x hx ↦ by
        obtain ⟨m, _, rfl⟩ := Multiset.mem_map.mp hx
        exact Int.ofNat_zero_le _)
      linarith
    have h_diff_le : (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) - ↑(n.factorial.factorization p) ≤ (M : ℤ) * Real.log n := by
      let v (x : ℕ) := (x.factorial.factorization p : ℤ)
      have h_v_sub (x y : ℕ) : v x - v y = (∑ k ∈ Finset.Ico 1 (Nat.log p x + 1), (x / p^k - y / p^k : ℤ)) := by
        simp only [v, factorization_def hprime (Nat.factorial_ne_zero _), padicValNat_factorial, Int.ofNat_sum]
        rw [Finset.sum_extend_by_zero (s := Finset.Ico 1 (Nat.log p x + 1))]
        · rw [Finset.sum_sub_distrib]
        · intro k hk; simp only [Finset.mem_Ico, not_and, not_lt] at hk; exact Nat.div_eq_zero_of_lt (Nat.pow_lt_of_lt_log p x (hk (Nat.one_le_log p hprime.two_le.trans_lt' (by nlinarith [P.hL, P.hL_pos]))))
      rw [h_v_sub n n0]
      let K := Nat.log p n
      have h_sum : (M : ℤ) * (∑ k ∈ Finset.Ico 1 (K + 1), (n / p^k - n0 / p^k : ℤ)) - v n ≤ (M : ℤ) * K := by
        simp only [v, factorization_def hprime (Nat.factorial_ne_zero _), padicValNat_factorial, Int.ofNat_sum,
          Finset.mul_sum, ← Finset.sum_sub_distrib]
        apply Finset.sum_le_sum; intro k hk
        have h_bound : (n / p^k - n0 / p^k : ℤ) ≤ (n / M / p^k : ℤ) + 1 := by
          have : n / p^k - n0 / p^k ≤ (n - n0) / p^k + 1 := Nat.div_sub_div_le_div_add_one n n0 (p^k)
          rwa [Nat.sub_sub_self (Nat.div_le_self n M)] at this
        nlinarith [Nat.mul_div_le_div n M (p^k)]
      apply ((h_sum.trans (by exact_mod_cast Nat.mul_le_mul_left M (Nat.log_le_log_div p n))).trans)
      apply mul_le_mul_of_nonneg_left _ (Nat.cast_nonneg M)
      rw [Real.le_div_iff (Real.log_pos (by exact_mod_cast hprime.two_le)), mul_one]
      exact Real.log_le_log (by norm_num) (by exact_mod_cast hprime.two_le)
    exact (sub_le_sub_right h_sum_le _).trans (by exact_mod_cast h_diff_le)
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    have : 1 < P.n := by nlinarith [P.hL, P.hL_pos]
    positivity
