@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · have hlogp : 0 < Real.log p := Real.log_pos (by exact_mod_cast hprime.one_lt)
    have hn_pos : 0 < (P.n : ℝ) := by
      have := Nat.lt_of_lt_of_le (Nat.mul_pos P.hL_pos P.hL_pos) P.hL.le
      exact_mod_cast this
    have hlog_n : 0 ≤ Real.log P.n := Real.log_nonneg (by linarith)
    set n := P.n
    set M := P.M
    set n0 := n - n / M
    unfold Factorization.balance Factorization.sum
    push_cast
    have h_dvd : n0.factorial ∣ n.factorial := Nat.factorial_dvd_factorial (tsub_le_self n (n / M))
    have h_sum_le : (P.initial.a.map (fun m ↦ (m.factorization p : ℤ))).sum ≤
        M * ((n.factorial.factorization p : ℤ) - (n0.factorial.factorization p : ℤ)) := by
      set S := (replicate M (Multiset.Ico n0 n)).join
      have hle : P.initial.a ≤ S := Multiset.filter_le _ _
      have h_sum_S : (S.map (fun m ↦ (m.factorization p : ℤ))).sum =
          M * ((n.factorial.factorization p : ℤ) - (n0.factorial.factorization p : ℤ)) := by
        simp only [S, map_join, sum_join, map_replicate, Multiset.sum_replicate, smul_eq_mul]
        rw [← Int.ofNat_sub (Nat.factorization_le_of_dvd h_dvd (Nat.factorial_ne_zero n))]
        simp only [Int.ofNat_sub]
        congr 1
        rw [Nat.factorization_div h_dvd, factorization_multiset_prod]
        · rw [Multiset.prod_Ico, Nat.factorial_div (tsub_le_self n (n / M))]
        · intro x hx; rw [Multiset.mem_Ico] at hx; exact (Nat.pos_of_mem_Ico hx).ne' rfl
      exact_mod_cast (Multiset.sum_le_sum (Multiset.map_le_map hle)).trans (by rw [← h_sum_S]; simp)
    have h_bal_le : (P.initial.balance p : ℝ) ≤ M * (Real.log n / Real.log p + 1) - (n / p / M) := by
      -- This is a placeholder for the Legendre-based bound.
      -- The key is that the balance is at most M * log_p(n).
      sorry
    -- For small p, the log_p(n) term is dominant, but for the score, log_p(n) * log(p) = log(n).
    -- The loose bound M * log(n) is used in the blueprint.
    sorry
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    have hn_pos : (0 : ℝ) < P.n := by
      have := Nat.lt_of_lt_of_le (Nat.mul_pos P.hL_pos P.hL_pos) P.hL.le
      exact_mod_cast this
    positivity
