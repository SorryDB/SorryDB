    have h_sum_le : (P.initial.a.map (fun m ↦ (m.factorization p : ℤ))).sum ≤
        (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) := by
      let S := (Multiset.replicate M (Multiset.Ico n0 n)).join
      have h_sum_S : (S.map (fun m ↦ (m.factorization p : ℤ))).sum =
          (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) := by
        simp only [S, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, nsmul_eq_mul]
        have h_dvd : n0.factorial ∣ n.factorial := Nat.factorial_dvd_factorial (Nat.sub_le n (n / M))
        have : (n.factorial.factorization p : ℤ) - (n0.factorial.factorization p : ℤ) =
            ((Multiset.Ico n0 n).map (fun m ↦ (m.factorization p : ℤ))).sum := by
          rw [← Int.ofNat_sub (Nat.factorization_mono h_dvd p), Nat.factorization_div h_dvd, factorization_multiset_prod]
          · rw [Multiset.prod_Ico, Nat.factorial_div (Nat.sub_le n (n / M))]
          · intro x hx; rw [Multiset.mem_Ico] at hx; exact (Nat.pos_of_mem_Ico hx).ne'
        rw [this]
      exact (Multiset.sum_le_sum (Multiset.map_le_map hleS)).trans (le_of_eq h_sum_S)
    have h_diff_le : (M : ℤ) * (↑(n.factorial.factorization p) - ↑(n0.factorial.factorization p)) - ↑(n.factorial.factorization p) ≤ (M : ℤ) * Real.log n := by
      have h_legendre (x : ℕ) : (x.factorial.factorization p : ℤ) = ∑ k ∈ Finset.Ico 1 (x.log p + 1), (x / p ^ k : ℤ) := by
        rw [Nat.factorization_factorial hprime, Int.ofNat_sum]; rfl
      rw [h_legendre n, h_legendre n0]
      have h_sum_sub : (∑ k ∈ Finset.Ico 1 (n.log p + 1), (n / p ^ k : ℤ)) - (∑ k ∈ Finset.Ico 1 (n0.log p + 1), (n0 / p ^ k : ℤ)) =
          ∑ k ∈ Finset.Ico 1 (n.log p + 1), (n / p ^ k - n0 / p ^ k : ℤ) := by
        rw [Finset.sum_sub_distrib]
        congr 1
        apply Finset.sum_subset (Finset.Ico_subset_Ico le_rfl (Nat.log_mono p (Nat.sub_le n (n / M)) |>.trans (Nat.le_succ _)))
        intro k hk hk'
        simp only [Finset.mem_Ico] at hk hk'
        simp [Nat.div_eq_zero_of_lt (Nat.pow_lt_of_lt_log p n0 (by linarith))]
      rw [h_sum_sub, Finset.mul_sum, ← Finset.sum_sub_distrib]
      have h_sum_le_M : ∑ k ∈ Finset.Ico 1 (n.log p + 1), ((M : ℤ) * (n / p ^ k - n0 / p ^ k) - (n / p ^ k)) ≤
          ∑ k ∈ Finset.Ico 1 (n.log p + 1), (M : ℤ) := by
        apply Finset.sum_le_sum; intro k hk
        have : n / p ^ k - n0 / p ^ k ≤ (n - n0) / p ^ k + 1 := Nat.div_sub_div_le_div_add_one n n0 (p ^ k)
        have : (M : ℤ) * (n / p ^ k - n0 / p ^ k) ≤ (M : ℤ) * ((n / M) / p ^ k + 1) := by
