  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · set n := P.n
    set M := P.M
    set n0 := n - n / M
    have h_sum_le : (P.initial.a.map (fun m ↦ (m.factorization p : ℤ))).sum ≤
        M * ((n.factorial.factorization p : ℤ) - (n0.factorial.factorization p : ℤ)) := by
      set S := (replicate M (Multiset.Ico n0 n)).join
      have hle : P.initial.a ≤ S := by unfold Params.initial; exact Multiset.filter_le _ _
      have h_sum_S : (S.map (fun m ↦ (m.factorization p : ℤ))).sum =
          M * ((n.factorial.factorization p : ℤ) - (n0.factorial.factorization p : ℤ)) := by
        simp only [S, map_join, sum_join, map_replicate, Multiset.sum_replicate, smul_eq_mul]
        have h_dvd : n0.factorial ∣ n.factorial := Nat.factorial_dvd_factorial (tsub_le_self n (n / M))
        rw [← Int.ofNat_sub (Nat.factorization_le_of_dvd h_dvd (Nat.factorial_ne_zero n))]
        simp only [Int.ofNat_sub]
        congr 1
        rw [Nat.factorization_div h_dvd, factorization_multiset_prod]
        · rw [Multiset.prod_Ico, Nat.factorial_div (tsub_le_self n (n / M))]
        · intro h; rw [Multiset.mem_Ico] at h; exact (Nat.pos_of_mem_Ico h).ne' rfl
      have h_sum_le_nat : (P.initial.a.map (·.factorization p)).sum ≤ (S.map (·.factorization p)).sum :=
        Multiset.sum_le_sum (Multiset.map_le_map hle)
      simp only [Multiset.map_map, Function.comp_apply]
