    let f : Eucl n ≃ₜ Eucl n :=
      { e.toEquiv with
        continuous_toFun := e.toLinearMap.continuous_of_finiteDimensional
        continuous_invFun := e.symm.toLinearMap.continuous_of_finiteDimensional }
    exact f.isOpenMap U hU
  exact IsOpenMap.locallyCompactSpace hπ continuous_quotient_mk' Quotient.surjective_mk'

