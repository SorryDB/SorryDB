lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  rintro v ⟨e, heM, hev⟩
  by_cases heP : e ∈ P.edgeSet
  · have hf : v ≠ P.first := fun hf ↦ h.first_not_in (hf ▸ ⟨e, heM, hev⟩)
    have hl : v ≠ P.last := fun hl ↦ h.last_not_in (hl ▸ ⟨e, heM, hev⟩)
    obtain ⟨e', he'P, hve', hne⟩ := h.toIsPath.exists_edge_at_of_not_first_last hf hl hev heP
    exact ⟨e', Or.inr ⟨he'P, fun he'M ↦ hne (hM.subsingleton_inc v ⟨heM, hev⟩ ⟨he'M, hve'⟩)⟩, hve'⟩
  · exact ⟨e, Or.inl ⟨heM, heP⟩, hev⟩
```
