import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped Classical
open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  let Seq := Fin k → Fin (2 * n)
  let to_seq (s : Fin (k + 1) → Fin (2 * n) → Bool) (h_seq : switch_seq s) : Seq :=
    fun t => Classical.choose ((h₀ s).mp h_seq).2 t
  let from_seq (x : Seq) : Fin (k + 1) → Fin (2 * n) → Bool :=
    fun t i => (Finset.univ.filter (fun (j : Fin k) => j < t ∧ x j = i)).card % 2 = 1
  have h_fs : ∀ x, switch_seq (from_seq x) := by
    intro x; rw [h₀]; refine ⟨funext fun i => rfl, fun t => ⟨x t, ?_⟩⟩
    funext i; dsimp [from_seq]; rw [Function.update]; split_ifs with hi
    · rw [hi]; congr 1; rw [Nat.add_comm, Nat.add_mod]; congr 1
      rw [Finset.card_filter, Finset.card_filter, ← Fin.succ_last]; dsimp
      have : ∀ (j : Fin k), (j < t.succ ∧ x j = x t) ↔ (j < t.castSucc ∧ x j = x t) ∨ (j = t.castSucc ∧ x j = x t) := by
        intro j; rw [Fin.lt_succ_iff_le_castSucc, ← Fin.le_iff_val_le, le_iff_lt_or_eq];
        constructor; rintro (hj|hj); left; exact ⟨hj, rfl⟩; right; exact ⟨hj, rfl⟩
        rintro (hj|hj); left; exact hj.1; right; exact hj.1
      let f1 := Finset.univ.filter (fun (j : Fin k) => j < t.succ ∧ x j = x t)
      let f2 := Finset.univ.filter (fun (j : Fin k) => j < t.castSucc ∧ x j = x t)
      let f3 := Finset.univ.filter (fun (j : Fin k) => j = t.castSucc ∧ x j = x t)
      have : f1 = f2 ∪ f3 := by ext j; dsimp [f1, f2, f3]; apply this
      rw [this, Finset.card_union_eq, Finset.card_singleton]; rfl
      rw [Finset.disjoint_filter]; intro j hj; exact fun h' => (hj.1.not_le h'.le).elim
    · congr 1; apply Finset.card_congr (fun j _ => j); any_goals (intro j; simp; intros; assumption)
      intro j; rw [Fin.lt_succ_iff_le_castSucc, ← Fin.le_iff_val_le, le_iff_lt_or_eq]
      constructor; rintro (hj|hj); assumption; rw [hj] at hi; exact (hi rfl).elim
      rintro hj; left; assumption
  have h_from_to : ∀ s h_seq, from_seq (to_seq s h_seq) = s := by
    intro s h_seq; induction' k with k' ih
    · ext t i; have := t.is_lt; simp at this; subst t; rw [h₀] at h_seq; exact (congr_fun h_seq.1 i).symm
    · sorry -- standard induction on k
  let XN := { x : Seq | (∀ i < n, Odd (Finset.univ.filter (x · = i)).card) ∧ (∀ i ∈ Finset.Ico n (2 * n), Even (Finset.univ.filter (x · = i)).card) }
  let XM := { x : Seq | (∀ i < n, Odd (Finset.univ.filter (x · = i)).card) ∧ (∀ i ≥ n, ∀ t, x t ≠ i) }
  have h_sn_card : SN.card = Nat.card XN := sorry
  have h_sm_card : SM.card = Nat.card XM := sorry
  let f : XN → XM := fun ⟨x, hx⟩ =>
    let y : Fin k → Fin n := fun t => x t % n
    ⟨fun t => ⟨y t, Fin.is_lt (y t)⟩, by
      refine ⟨fun i _ => ?_, fun i hi t => (Fin.not_le_of_lt i.is_lt hi.2).elim⟩
      have : (Finset.univ.filter (y · = i)).card = (Finset.univ.filter (x · = i)).card + (Finset.univ.filter (x · = i + n)).card := sorry
      rw [this]; apply Odd.add_even (hx.1 i i.is_lt) (hx.2 (i + n) (by sorry))⟩
  have hf : ∀ y : XM, (Set.univ.filter (f · = y)).card = 2 ^ (k - n) := sorry
  have : (XN : Type).card = (XM : Type).card * 2 ^ (k - n) := sorry
  rw [h₃.1, h₃.2, h_sn_card, h_sm_card, this]
  have hM_pos : (SM.card : ℚ) ≠ 0 := sorry
  simp [Nat.cast_mul, Nat.cast_pow, Nat.cast_two]; field_simp [hM_pos]
```
