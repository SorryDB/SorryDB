      intro s' hs'; sorry
    have h_map : ∀ s ∈ SN, f s ∈ SM := by
      intro s hs; sorry
    have h_total := Finset.card_eq_sum_card_fiber h_map
    simp [h_fiber] at h_total
    exact ⟨h_total, hSM_pos⟩
  field_simp [h_rel.2]
  norm_cast
  simp [h_rel.1, mul_comm]

