import Lean

namespace BitVec

def bb (x : BitVec w) : BitVec w :=
  (iunfoldr (fun i _ => ((), x.getLsbD i)) ()).snd

theorem self_eq_bb (x : BitVec w) : x = x.bb := by
  unfold bb
  rw [iunfoldr_replace_snd (λ _ => ()) (init:=rfl)]
  intro i
  rfl

-- def beq (x : BitVec w) (y : BitVec w) : Bool :=
--   go w
-- where
--   go : Nat → Bool
--     | 0     => x.getLsb 0 == y.getLsb 0
--     | i + 1 => go i && x.getLsb i == y.getLsb i

-- TODO: fix reconstruction associativity of ∧ to use above version
def beq (x : BitVec w) (y : BitVec w) : Bool :=
  go (w - 1)
where
  go : Nat → Bool
    | 0     => x.getLsbD (w - 1) == y.getLsbD (w - 1)
    | i + 1 => x.getLsbD ((w - 1) - (i + 1)) == y.getLsbD ((w - 1) - (i + 1)) && go i

def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · intro h; subst h; induction w - 1 with
    | zero => simp [beq, beq.go]
    | succ i ih => simp [beq, beq.go, ih]
  · intro h; apply BitVec.eq_of_getLsbD; intro i
    if hi : i < w then
      let rec s j (h' : beq.go x y j = true) k (hk : k ≤ j) : x.getLsbD ((w - 1) - k) = y.getLsbD ((w - 1) - k) := by
        induction j with
        | zero =>
          simp [beq.go] at h'; have : k = 0 := Nat.le_zero.1 hk; subst this
          exact Bool.beq_eq_true_iff.1 h'
        | succ j ih =>
          simp [beq.go] at h'; have ⟨h1, h2⟩ := Bool.and_eq_true.1 h'
          if hkj : k = j + 1 then subst hkj; exact Bool.beq_eq_true_iff.1 h1
          else exact ih h2 k (Nat.le_of_lt_succ (Nat.lt_of_le_of_ne hk hkj))
      have := s (w - 1) h ((w - 1) - i) (Nat.sub_le _ _)
      rwa [Nat.sub_sub_self (Nat.le_sub_one_of_lt hi)] at this
    else rw [getLsbD, getLsbD]; simp [hi]
