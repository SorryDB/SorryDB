def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext
  constructor
  · intro h
    subst h
    unfold beq
    induction (w - 1) with
    | zero => simp [beq.go]
    | succ i ih => simp [beq.go, ih]
  · intro h
    apply BitVec.eq_of_getLsbD
    intro i
    if hi : i < w then
      unfold beq at h
      let rec s j (hj : beq.go x y j = true) k (hk : k ≤ j) : x.getLsbD ((w - 1) - k) = y.getLsbD ((w - 1) - k) :=
        match j with
        | 0 => by
            simp [beq.go] at hj
            have : k = 0 := Nat.le_zero.1 hk
            rw [this]
            exact Bool.beq_eq_true_iff.1 hj
        | j + 1 => by
            simp [beq.go] at hj
            have ⟨h1, h2⟩ := Bool.and_eq_true.1 hj
            if hkj : k = j + 1 then
              rw [hkj]
              exact Bool.beq_eq_true_iff.1 h1
            else
              have hkj' : k ≤ j := Nat.le_of_lt_succ (Nat.lt_of_le_of_ne hk hkj)
              exact s j h2 k hkj'
      have h_idx := s (w - 1) h ((w - 1) - i) (Nat.sub_le _ _)
      rwa [Nat.sub_sub_self (Nat.le_sub_one_of_lt hi)] at h_idx
    else
      have hx : x.getLsbD i = false := by simp [BitVec.getLsbD, hi]
      have hy : y.getLsbD i = false := by simp [BitVec.getLsbD, hi]
      rw [hx, hy]
