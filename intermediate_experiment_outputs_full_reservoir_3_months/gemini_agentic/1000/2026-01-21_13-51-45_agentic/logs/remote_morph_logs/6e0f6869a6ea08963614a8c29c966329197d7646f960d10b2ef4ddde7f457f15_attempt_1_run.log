def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext
  constructor
  · intro h
    subst h
    unfold beq
    let n := w - 1
    induction n with
    | zero =>
      simp [beq.go]
    | succ i ih =>
      simp [beq.go, ih]
  · intro h
    apply BitVec.eq_of_getLsbD
    intro i
    if hi : i < w then
      let n := w - 1
      unfold beq at h
      let rec s (j : Nat) (hj : beq.go x y j = true) (k : Nat) (hk : k ≤ j) : x.getLsbD (n - k) = y.getLsbD (n - k) :=
        match j with
        | 0 => by
            simp [beq.go] at hj
            have : k = 0 := Nat.le_zero.1 hk
            subst this
            exact Bool.beq_eq_true_iff.1 hj
        | j' + 1 => by
            simp [beq.go] at hj
            if hkj : k = j' + 1 then
              subst hkj
              exact Bool.beq_eq_true_iff.1 hj.1
            else
              have h_le : k ≤ j' := Nat.le_of_lt_succ (Nat.lt_of_le_of_ne hk hkj)
              exact s j' hj.2 k h_le
      have hi_eq : i = n - (n - i) := (Nat.sub_sub_self (Nat.le_sub_one_of_lt hi)).symm
      rw [hi_eq]
      exact s n h (n - i) (Nat.sub_le n i)
    else
      have hx : x.getLsbD i = false := by simp [BitVec.getLsbD, hi]
      have hy : y.getLsbD i = false := by simp [BitVec.getLsbD, hi]
      rw [hx, hy]

