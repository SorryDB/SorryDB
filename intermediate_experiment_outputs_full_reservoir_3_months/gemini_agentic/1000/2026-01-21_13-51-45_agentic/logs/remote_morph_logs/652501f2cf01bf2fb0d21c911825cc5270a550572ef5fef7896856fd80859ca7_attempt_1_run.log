    let ci (i : Fin 127) : ‚Ą§ := (‚ÜĎ((c >>> (2 * i.val)) &&& 1) : ‚Ą§) + 2 * (‚ÜĎ((c >>> (2 * i.val + 1)) &&& 1) : ‚Ą§)
    let pi (i : Fin 127) : ‚Ą§ := if si i > ci i then (2^128 - 2^i.val) else if si i < ci i then 2^i.val else 0
    have h_pi (i : Fin 127) : env.get (offset + i.val) = (pi i : F p) := by
      have h := congr_arg (fun v => v[i.val]) h_parts
      simp at h; rw [h]
      have h_in j (hj) : Expression.eval env (input_var[j]'hj) = input[j] := by
        have hh := congr_arg (fun v => v[j]) h_eval
        simp at hh; exact hh
