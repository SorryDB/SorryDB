    · intro h; have : P = A := dist_eq_zero.mp h; subst this
      exact AffineIndependent.not_mem_interior_convexHull hABC 0 hP
    · intro h; have : P = B := dist_eq_zero.mp h; subst this
      exact AffineIndependent.not_mem_interior_convexHull hABC 1 hP
    · intro h; have : P = C := dist_eq_zero.mp h; subst this
      exact AffineIndependent.not_mem_interior_convexHull hABC 2 hP

  have h_sin_prod : Real.sin x₁ * Real.sin x₂ * Real.sin x₃ = Real.sin y₁ * Real.sin y₂ * Real.sin y₃ := by
    have s1 : dist P A * Real.sin x₁ = dist P B * Real.sin y₁ := 
      EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P A B
    have s2 : dist P B * Real.sin x₂ = dist P C * Real.sin y₂ := 
      EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P B C
    have s3 : dist P C * Real.sin x₃ = dist P A * Real.sin y₃ := 
      EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P C A
    have h_mul : dist P A * dist P B * dist P C ≠ 0 := by
      repeat' apply mul_ne_zero
      exact h_dist_pos.1; exact h_dist_pos.2.1; exact h_dist_pos.2.2
    apply mul_left_cancel₀ h_mul
    calc (dist P A * dist P B * dist P C) * (Real.sin x₁ * Real.sin x₂ * Real.sin x₃)
      _ = (dist P A * Real.sin x₁) * (dist P B * Real.sin x₂) * (dist P C * Real.sin x₃) := by ring
      _ = (dist P B * Real.sin y₁) * (dist P C * Real.sin y₂) * (dist P A * Real.sin y₃) := by rw [s1, s2, s3]
      _ = (dist P A * dist P B * dist P C) * (Real.sin y₁ * Real.sin y₂ * Real.sin y₃) := by ring

