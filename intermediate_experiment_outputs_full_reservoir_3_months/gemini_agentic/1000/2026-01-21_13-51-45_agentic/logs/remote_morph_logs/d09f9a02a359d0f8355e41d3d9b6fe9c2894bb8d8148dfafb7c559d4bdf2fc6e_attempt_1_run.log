import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨h1, h2, h3⟩

  let x₁ := ∠ P A B; let x₂ := ∠ P B C; let x₃ := ∠ P C A
  let y₁ := ∠ P B A; let y₂ := ∠ P C B; let y₃ := ∠ P A C

  have h_sin_prod : sin x₁ * sin x₂ * sin x₃ = sin y₁ * sin y₂ * sin y₃ := by
    have s1 : dist P A * sin x₁ = dist P B * sin y₁ := by
      rw [x₁, y₁, ← dist_sin_angle_eq_dist_sin_angle P A B]
    have s2 : dist P B * sin x₂ = dist P C * sin y₂ := by
      rw [x₂, y₂, ← dist_sin_angle_eq_dist_sin_angle P B C]
    have s3 : dist P C * sin x₃ = dist P A * sin y₃ := by
      rw [x₃, y₃, ← dist_sin_angle_eq_dist_sin_angle P C A]
    have h_dist_pos : dist P A ≠ 0 ∧ dist P B ≠ 0 ∧ dist P C ≠ 0 := by
      have h_int : P ∉ {A, B, C} := by
        intro hf; apply interior_subset hP; simp [hf]
      simp at h_int; exact ⟨dist_ne_zero.mpr h_int.1, dist_ne_zero.mpr h_int.2.1, dist_ne_zero.mpr h_int.2.2⟩
    have h_mul_pos : dist P A * dist P B * dist P C ≠ 0 := by
      apply mul_ne_zero; apply mul_ne_zero <;> (try apply h_dist_pos.1; try apply h_dist_pos.2.1; try apply h_dist_pos.2.2)
    apply mul_right_cancel₀ h_mul_pos
    calc (sin x₁ * sin x₂ * sin x₃) * (dist P A * dist P B * dist P C)
      _ = (dist P B * sin x₁) * (dist P C * sin x₂) * (dist P A * sin x₃) := by ring
      _ = (dist P A * sin y₁) * (dist P B * sin y₂) * (dist P C * sin y₃) := by rw [s1, s2, s3]; ring
      _ = (sin y₁ * sin y₂ * sin y₃) * (dist P A * dist P B * dist P C) := by ring

  have hx_pos : x₁ > 0 ∧ x₂ > 0 ∧ x₃ > 0 := sorry
  have hy_pos : y₁ > 0 ∧ y₂ > 0 ∧ y₃ > 0 := sorry
  have h_sum : x₁ + x₂ + x₃ + y₁ + y₂ + y₃ = π := sorry

  have h_sin_x_prod : sin x₁ * sin x₂ * sin x₃ > 1 / 8 := by
    have hx_range : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), x > π / 6 ∧ x < 2 * π / 3 := by
      intro x hx; rcases hx with rfl|rfl|rfl <;> (constructor; assumption; linarith [h1, h2, h3, h_sum, hy_pos.1, hy_pos.2.1, hy_pos.2.2])
    have h_sin_gt : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), sin x > 1 / 2 := by
      intro x hx; rw [← sin_pi_six]
      apply sin_gt_sin_of_lt_of_le_pi_half (by linarith [(hx_range x hx).1])
      · linarith [(hx_range x hx).1]
      · linarith [(hx_range x hx).2]
    have sx1 := h_sin_gt x₁ (by simp); have sx2 := h_sin_gt x₂ (by simp); have sx3 := h_sin_gt x₃ (by simp)
    nlinarith [sin_pos_of_mem_Ioo (by linarith [(hx_range x₁ (by simp)).1, (hx_range x₁ (by simp)).2]) (by linarith)]

  have h_sum_y : y₁ + y₂ + y₃ < π / 2 := by linarith [h1, h2, h3, h_sum]
  have h_sin_y_prod : sin y₁ * sin y₂ * sin y₃ < 1 / 8 := by
    have h_sin_y_jensen : sin y₁ * sin y₂ * sin y₃ ≤ (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 := sorry
    have h_sin_max : sin ((y₁ + y₂ + y₃) / 3) < 1 / 2 := by
      rw [← sin_pi_six]; apply sin_lt_sin_of_lt_of_le_pi_half <;> linarith [hy_pos.1, hy_pos.2.1, hy_pos.2.2]
    have h_sin_max_pow : (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 < (1 / 2) ^ 3 := pow_lt_pow_left h_sin_max (by linarith) (by linarith)
    exact h_sin_y_jensen.trans_lt h_sin_max_pow

  linarith

end Imo1991P5
