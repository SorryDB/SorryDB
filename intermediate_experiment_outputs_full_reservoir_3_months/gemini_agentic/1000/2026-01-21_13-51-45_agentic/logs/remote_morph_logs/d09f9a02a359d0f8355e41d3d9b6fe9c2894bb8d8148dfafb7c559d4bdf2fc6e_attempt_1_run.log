import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨h1, h2, h3⟩
  have hP_ne_A : P ≠ A := by
    rintro rfl; exact (interior_subset hP) (subset_convexHull _ _ (Set.mem_insert _ _))
  have hP_ne_B : P ≠ B := by
    rintro rfl; exact (interior_subset hP) (subset_convexHull _ _ (Set.mem_insert_of_mem _ (Set.mem_insert _ _)))
  have hP_ne_C : P ≠ C := by
    rintro rfl; exact (interior_subset hP) (subset_convexHull _ _ (Set.mem_insert_of_mem _ (Set.mem_insert_of_mem _ (Set.mem_singleton _))))

  let x₁ := ∠ P A B; let x₂ := ∠ P B C; let x₃ := ∠ P C A
  let y₁ := ∠ P B A; let y₂ := ∠ P C B; let y₃ := ∠ P A C

  have h_sin_prod : sin x₁ * sin x₂ * sin x₃ = sin y₁ * sin y₂ * sin y₃ := by
    have s1 : dist P A * sin x₁ = dist P B * sin y₁ := by
      rw [angle_comm, ← dist_sin_angle_eq_dist_sin_angle A P B, angle_comm P B A]
    have s2 : dist P B * sin x₂ = dist P C * sin y₂ := by
      rw [angle_comm, ← dist_sin_angle_eq_dist_sin_angle B P C, angle_comm P C B]
    have s3 : dist P C * sin x₃ = dist P A * sin y₃ := by
      rw [angle_comm, ← dist_sin_angle_eq_dist_sin_angle C P A, angle_comm P A C]
    have h_pos : dist P A * dist P B * dist P C ≠ 0 := by
      repeat' apply mul_ne_zero
      all_goals exact dist_ne_zero.mpr (by assumption)
    apply mul_right_cancel₀ h_pos
    linear_combination s1 * s2 * s3

  have h_sum : x₁ + x₂ + x₃ + y₁ + y₂ + y₃ = π := by
    have h_angA : x₁ + y₃ = ∠ B A C := sorry
    have h_angB : x₂ + y₁ = ∠ C B A := sorry
    have h_angC : x₃ + y₂ = ∠ A C B := sorry
    rw [← h_angA, ← h_angB, ← h_angC, add_assoc, add_comm y₃, ← add_assoc, add_assoc x₁, add_assoc x₁,
        add_comm x₂ y₁, add_comm x₃ y₂]
    have h_sum_abc : ∠ B A C + ∠ C B A + ∠ A C B = π := angle_sum_eq_pi hABC
    linarith

  have hx_range : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), x > π / 6 ∧ x < 2 * π / 3 := by
    intro x hx; constructor
    · rcases hx with rfl|rfl|rfl <;> assumption
    · have hx_pos : ∀ z ∈ ({x₁, x₂, x₃, y₁, y₂, y₃} : Set ℝ), z > 0 := sorry
      rcases hx with rfl|rfl|rfl <;> linarith [h1, h2, h3, hx_pos y₁, hx_pos y₂, hx_pos y₃]

  have h_sin_x_prod : sin x₁ * sin x₂ * sin x₃ > 1 / 8 := by
    have h_sin_gt : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), sin x > 1 / 2 := by
      intro x hx
      have r := hx_range x hx
      rw [← sin_pi_six]
      apply sin_gt_sin_of_lt_of_le_pi_half (by linarith) (by linarith) (by linarith)
    have s1 := h_sin_gt x₁ (by simp)
    have s2 := h_sin_gt x₂ (by simp)
    have s3 := h_sin_gt x₃ (by simp)
