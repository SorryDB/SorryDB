import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨h1, h2, h3⟩
  let x₁ := ∠ P A B; let x₂ := ∠ P B C; let x₃ := ∠ P C A
  let y₁ := ∠ P B A; let y₂ := ∠ P C B; let y₃ := ∠ P A C

  have hPA : dist P A ≠ 0 := dist_ne_zero.mpr (by rintro rfl; exact interior_subset hP (subset_convexHull ℝ {A, B, C} (Set.mem_insert A {B, C})))
  have hPB : dist P B ≠ 0 := dist_ne_zero.mpr (by rintro rfl; exact interior_subset hP (subset_convexHull ℝ {A, B, C} (Set.mem_insert_of_mem A (Set.mem_insert B {C}))))
  have hPC : dist P C ≠ 0 := dist_ne_zero.mpr (by rintro rfl; exact interior_subset hP (subset_convexHull ℝ {A, B, C} (Set.mem_insert_of_mem A (Set.mem_insert_of_mem B (Set.mem_singleton C)))))

  have h_sin_prod : sin x₁ * sin x₂ * sin x₃ = sin y₁ * sin y₂ * sin y₃ := by
    have s1 : dist P A * sin x₁ = dist P B * sin y₁ := by rw [x₁, y₁, ← dist_mul_sin_angle_eq_dist_mul_sin_angle P A B]
    have s2 : dist P B * sin x₂ = dist P C * sin y₂ := by rw [x₂, y₂, ← dist_mul_sin_angle_eq_dist_mul_sin_angle P B C]
    have s3 : dist P C * sin x₃ = dist P A * sin y₃ := by rw [x₃, y₃, ← dist_mul_sin_angle_eq_dist_mul_sin_angle P C A]
    have h_prod : dist P A * dist P B * dist P C ≠ 0 := by repeat' apply mul_ne_zero <;> assumption
    apply mul_left_cancel₀ h_prod
    calc (dist P A * dist P B * dist P C) * (sin x₁ * sin x₂ * sin x₃)
      _ = (dist P A * sin x₁) * (dist P B * sin x₂) * (dist P C * sin x₃) := by ring
      _ = (dist P B * sin y₁) * (dist P C * sin y₂) * (dist P A * sin y₃) := by rw [s1, s2, s3]
      _ = (dist P A * dist P B * dist P C) * (sin y₁ * sin y₂ * sin y₃) := by ring

  have hx_pos : x₁ > 0 ∧ x₂ > 0 ∧ x₃ > 0 := ⟨angle_pos_of_mem_interior_angle (interior_subset hP) (by sorry), by sorry, by sorry⟩
  have hy_pos : y₁ > 0 ∧ y₂ > 0 ∧ y₃ > 0 := by sorry
  have h_sum : x₁ + y₁ + x₂ + y₂ + x₃ + y₃ = π := by sorry

  have h_sin_x_prod : sin x₁ * sin x₂ * sin x₃ > 1 / 8 := by
    have hx_range : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), x > π / 6 ∧ x < 2 * π / 3 := by
      intro x hx; rcases hx with rfl | rfl | rfl
      · constructor; exact h1; linarith [h2, h3, h_sum, hy_pos]
      · constructor; exact h2; linarith [h1, h3, h_sum, hy_pos]
      · constructor; exact h3; linarith [h1, h2, h_sum, hy_pos]
    have h_sin_gt : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), sin x > 1 / 2 := by
      intro x hx; rw [← sin_pi_six]
      apply sin_gt_sin_of_lt_of_le_pi_half (by linarith [(hx_range x hx).1]) (by linarith [(hx_range x hx).1])
      linarith [hx_range x hx, pi_half_le_two_pi_third]
    have sx1 := h_sin_gt x₁ (by simp); have sx2 := h_sin_gt x₂ (by simp); have sx3 := h_sin_gt x₃ (by simp)
    have sp1 : sin x₁ > 0 := by linarith; have sp2 : sin x₂ > 0 := by linarith
    nlinarith

  have h_sum_y : y₁ + y₂ + y₃ < π / 2 := by linarith [h1, h2, h3, h_sum]
  have h_sin_y_prod : sin y₁ * sin y₂ * sin y₃ < 1 / 8 := by
    have h_jensen : sin y₁ * sin y₂ * sin y₃ ≤ (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 := by
      have h_concave : ConcaveOn ℝ (Set.Icc 0 (π / 2)) sin := concaveOn_sin_Icc.subset (Set.Icc_subset_Icc (by linarith) (by linarith [pi_pos])) (interior_subset (by sorry))
      -- Jensen's for n=3 is tedious but true.
      sorry
    have h_sin_max : sin ((y₁ + y₂ + y₃) / 3) < 1 / 2 := by
      rw [← sin_pi_six]; apply sin_lt_sin_of_lt_of_le_pi_half <;> linarith [hy_pos.1, hy_pos.2.1, hy_pos.2.2, h_sum_y]
    have h_sin_max_pow : (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 < (1 / 2) ^ 3 := pow_lt_pow_left h_sin_max (by linarith) (by linarith)
    exact h_jensen.trans_lt h_sin_max_pow

  linarith
```
