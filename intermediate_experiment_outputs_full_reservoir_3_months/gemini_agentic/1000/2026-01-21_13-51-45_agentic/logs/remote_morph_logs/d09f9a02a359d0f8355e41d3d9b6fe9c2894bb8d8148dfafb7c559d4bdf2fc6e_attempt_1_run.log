    have s1 : dist P A * Real.sin y₁ = dist P B * Real.sin x₁ :=
      EuclideanGeometry.dist_left_mul_sin_angle_right_eq_dist_right_mul_sin_angle_left P A B
    have s2 : dist P B * Real.sin y₂ = dist P C * Real.sin x₂ :=
      EuclideanGeometry.dist_left_mul_sin_angle_right_eq_dist_right_mul_sin_angle_left P B C
    have s3 : dist P C * Real.sin y₃ = dist P A * Real.sin x₃ :=
      EuclideanGeometry.dist_left_mul_sin_angle_right_eq_dist_right_mul_sin_angle_left P C A
    have h_mul : dist P A * dist P B * dist P C ≠ 0 := by
      repeat' apply mul_ne_zero
      exact h_dist_pos.1; exact h_dist_pos.2.1; exact h_dist_pos.2.2
    apply mul_left_cancel₀ h_mul
    calc (dist P A * dist P B * dist P C) * (Real.sin x₁ * Real.sin x₂ * Real.sin x₃)
      _ = (dist P B * Real.sin x₁) * (dist P C * Real.sin x₂) * (dist P A * Real.sin x₃) := by ring
      _ = (dist P A * Real.sin y₁) * (dist P B * Real.sin y₂) * (dist P C * Real.sin y₃) := by rw [s1, s2, s3]; ring
      _ = (dist P A * dist P B * dist P C) * (Real.sin y₁ * Real.sin y₂ * Real.sin y₃) := by ring

  have hy_pos : 0 < y₁ ∧ 0 < y₂ ∧ 0 < y₃ := sorry
  have h_sum : x₁ + x₂ + x₃ + y₁ + y₂ + y₃ = π := sorry

