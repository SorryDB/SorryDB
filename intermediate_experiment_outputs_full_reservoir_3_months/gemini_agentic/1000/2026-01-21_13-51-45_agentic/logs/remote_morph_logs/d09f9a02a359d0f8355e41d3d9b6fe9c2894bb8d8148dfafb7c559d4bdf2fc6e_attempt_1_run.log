problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨h1, h2, h3⟩
  let x₁ := ∠ P A B; let x₂ := ∠ P B C; let x₃ := ∠ P C A
  let y₁ := ∠ P B A; let y₂ := ∠ P C B; let y₃ := ∠ P A C

  have h_dist_pos : dist P A ≠ 0 ∧ dist P B ≠ 0 ∧ dist P C ≠ 0 := by
    constructor
    · intro hA; have : P = A := dist_eq_zero.mp hA; subst this
      exact hABC.not_mem_interior_convexHull 0 hP
    constructor
    · intro hB; have : P = B := dist_eq_zero.mp hB; subst this
      exact hABC.not_mem_interior_convexHull 1 hP
    · intro hC; have : P = C := dist_eq_zero.mp hC; subst this
      exact hABC.not_mem_interior_convexHull 2 hP

  have h_sin_prod : sin x₁ * sin x₂ * sin x₃ = sin y₁ * sin y₂ * sin y₃ := by
    have s1 : dist P A * sin x₁ = dist P B * sin y₁ := EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P A B
    have s2 : dist P B * sin x₂ = dist P C * sin y₂ := EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P B C
    have s3 : dist P C * sin x₃ = dist P A * sin y₃ := EuclideanGeometry.dist_mul_sin_angle_eq_dist_mul_sin_angle P C A
    have h_mul : dist P A * dist P B * dist P C ≠ 0 := by
      repeat' apply mul_ne_zero
      exact h_dist_pos.1; exact h_dist_pos.2.1; exact h_dist_pos.2.2
    apply mul_left_cancel₀ h_mul
    calc (dist P A * dist P B * dist P C) * (sin x₁ * sin x₂ * sin x₃)
      _ = (dist P A * sin x₁) * (dist P B * sin x₂) * (dist P C * sin x₃) := by ring
      _ = (dist P B * sin y₁) * (dist P C * sin y₂) * (dist P A * sin y₃) := by rw [s1, s2, s3]
      _ = (dist P A * dist P B * dist P C) * (sin y₁ * sin y₂ * sin y₃) := by ring

  have hy_pos : 0 < y₁ ∧ 0 < y₂ ∧ 0 < y₃ := sorry
  have h_sum : x₁ + x₂ + x₃ + y₁ + y₂ + y₃ = π := sorry

  have h_sin_x_prod : 1 / 8 < sin x₁ * sin x₂ * sin x₃ := by
    have h_sin_gt : ∀ x ∈ ({x₁, x₂, x₃} : Set ℝ), sin x > 1 / 2 := by
      intro x hx
      have h_range : π / 6 < x ∧ x < 2 * π / 3 := by
        rcases hx with rfl | rfl | rfl
        · constructor; exact h1; linarith [h2, h3, h_sum, hy_pos]
        · constructor; exact h2; linarith [h1, h3, h_sum, hy_pos]
        · constructor; exact h3; linarith [h1, h2, h_sum, hy_pos]
      cases le_or_gt x (π / 2) with
      | inl hle =>
        rw [← Real.sin_pi_div_six]
        apply Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith) h_range.1 hle
      | inr hgt =>
        rw [← Real.sin_pi_sub, ← Real.sin_pi_div_six]
        apply Real.sin_lt_sin_of_lt_of_le_pi_div_two <;> linarith
    have sx1 := h_sin_gt x₁ (by simp); have sx2 := h_sin_gt x₂ (by simp); have sx3 := h_sin_gt x₃ (by simp)
    have sp1 : 0 < sin x₁ := by linarith; have sp2 : 0 < sin x₂ := by linarith; have sp3 : 0 < sin x₃ := by linarith
    have h12 : 1 / 4 < sin x₁ * sin x₂ := by nlinarith
    nlinarith

  have h_sin_y_prod : sin y₁ * sin y₂ * sin y₃ < 1 / 8 := by
    have h_sum_y : y₁ + y₂ + y₃ < π / 2 := by linarith [h1, h2, h3, h_sum]
    have h_jensen : sin y₁ * sin y₂ * sin y₃ ≤ (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 := sorry
    have h_sin_max : sin ((y₁ + y₂ + y₃) / 3) < 1 / 2 := by
      rw [← Real.sin_pi_div_six]
      apply Real.sin_lt_sin_of_lt_of_le_pi_div_two <;> linarith [hy_pos.1, hy_pos.2.1, hy_pos.2.2]
    have h_sin_pos : 0 ≤ sin ((y₁ + y₂ + y₃) / 3) := by
      apply Real.sin_nonneg_of_mem_Icc; constructor <;> linarith [hy_pos.1, hy_pos.2.1, hy_pos.2.2]
    have h_sin_max_pow : (sin ((y₁ + y₂ + y₃) / 3)) ^ 3 < (1 / 2 : ℝ) ^ 3 := by
      apply pow_lt_pow_of_lt_left h_sin_max h_sin_pos (by norm_num)
    have : (1 / 2 : ℝ) ^ 3 = 1 / 8 := by norm_num
    linarith

  linarith [h_sin_prod, h_sin_x_prod, h_sin_y_prod]
