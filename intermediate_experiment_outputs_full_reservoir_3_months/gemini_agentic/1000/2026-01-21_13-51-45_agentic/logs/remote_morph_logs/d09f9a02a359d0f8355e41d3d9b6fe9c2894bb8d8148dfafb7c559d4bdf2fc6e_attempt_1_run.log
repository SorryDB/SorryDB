import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨h1, h2, h3⟩
  have hP_ne_A : P ≠ A := by
    rintro rfl; exact interior_subset (convexHull_subset_convexHull (Set.subset_insert _ _) (Set.subset_insert _ _)) hP
  let x₁ := ∠ P A B; let x₂ := ∠ P B C; let x₃ := ∠ P C A
  let y₁ := ∠ P B A; let y₂ := ∠ P C B; let y₃ := ∠ P A C
  have h_sin_prod : sin x₁ * sin x₂ * sin x₃ = sin y₁ * sin y₂ * sin y₃ := by
    have s1 : dist P B * sin y₁ = dist P A * sin x₁ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P A B, angle_comm P B A]
    have s2 : dist P C * sin y₂ = dist P B * sin x₂ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P B C, angle_comm P C B]
    have s3 : dist P A * sin y₃ = dist P C * sin x₃ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P C A, angle_comm P A C]
    have h_pos : dist P A * dist P B * dist P C ≠ 0 := by
      repeat' apply mul_ne_zero
      all_goals exact dist_ne_zero.mpr (by rintro rfl; exact hP_ne_A (by assumption))
    apply mul_right_cancel₀ h_pos
    linear_combination s1 * s2 * s3
  have h_sum : x₁ + y₃ + (x₂ + y₁) + (x₃ + y₂) = π := by
    rw [← angle_add_angle_of_mem_interior_angle A B C P hP,
        ← angle_add_angle_of_mem_interior_angle B C A P hP,
        ← angle_add_angle_of_mem_interior_angle C A B P hP,
        angle_comm P A B, angle_comm P B C, angle_comm P C A]
    exact angle_sum_eq_pi hABC
  have hx_range : ∀ x ∈ [x₁, x₂, x₃], x > π / 6 ∧ x < 5 * π / 6 := by
    intro x hx; constructor
    · rcases hx with rfl|rfl|rfl <;> assumption
    · have h_sum_sub : x < π - 2 * (π / 6) := by
        rcases hx with rfl|rfl|rfl <;> linarith [h1, h2, h3, angle_pos_of_mem_interior hABC hP]
      linarith
  have h_sin_x_prod : sin x₁ * sin x₂ * sin x₃ > 1 / 8 := by
    have h_sin_x : ∀ x ∈ [x₁, x₂, x₃], sin x > 1 / 2 := by
      intro x hx; apply sin_gt_half_of_pi_six_lt_lt_five_pi_six (hx_range x hx).1 (hx_range x hx).2
    have s1 := h_sin_x x₁ (by left; rfl)
    have s2 := h_sin_x x₂ (by right; left; rfl)
    have s3 := h_sin_x x₃ (by right; right; rfl)
    linarith [sin_pos_of_mem_interior hABC hP]
  have h_sum_y : y₁ + y₂ + y₃ < π / 2 := by linarith
  have h_sin_y_prod : sin y₁ * sin y₂ * sin y₃ < 1 / 8 := by
    have y_pos : ∀ y ∈ [y₁, y₂, y₃], y > 0 := by
      intro y hy; rcases hy with rfl|rfl|rfl <;> exact angle_pos_of_mem_interior hABC hP
    have h_sin_y : sin y₁ * sin y₂ * sin y₃ ≤ sin ((y₁ + y₂ + y₃) / 3) ^ 3 := by
      apply log_sin_jensen y_pos (by linarith)
    have h_sin_max : sin ((y₁ + y₂ + y₃) / 3) < 1 / 2 := by
      apply sin_lt_sin_of_lt_of_le_pi_half <;> linarith
    have h_sin_max_pow : sin ((y₁ + y₂ + y₃) / 3) ^ 3 < (1 / 2) ^ 3 := pow_lt_pow_left h_sin_max (by linarith) (by linarith)
    exact h_sin_y.trans_lt h_sin_max_pow
  linarith [h_sin_prod, h_sin_x_prod, h_sin_y_prod]

end Imo1991P5

