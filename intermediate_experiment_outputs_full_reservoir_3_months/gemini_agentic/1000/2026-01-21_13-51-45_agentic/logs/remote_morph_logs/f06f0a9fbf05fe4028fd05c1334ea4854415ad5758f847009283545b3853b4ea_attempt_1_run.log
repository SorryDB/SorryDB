import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_apply, tsum_fintype]
  simp only [PMF.uniformOfFintype_apply, DigitSeq, Fintype.card_fun, Fintype.card_fin,
    Set.indicator_apply, Set.mem_setOf_eq, Finset.sum_ite, Finset.sum_const, nsmul_eq_mul, 
    mul_one, Finset.sum_const_zero, add_zero, ite_self]
  let S := Finset.univ (α := DigitSeq n)
  haveI : DecidablePred (is_good_seq (n:=n)) := fun s ↦ Nat.decidableDvd 10 _
  let Ac := S.filter (fun s ↦ ∀ i, ¬ 2 ∣ to_nat_digit (s i))
  let Bc := S.filter (fun s ↦ ∀ i, ¬ 5 ∣ to_nat_digit (s i))
  have hS : S.card = 9^n := by simp [S, DigitSeq]
  have hAc : Ac.card = 5^n := by
    let D := Finset.univ.filter (fun d : Digit ↦ ¬ 2 ∣ to_nat_digit d)
    have : D.card = 5 := by decide
    have : Ac = Fintype.piFinset (fun _ : Fin n ↦ D) := by ext; simp [Ac, D, Fintype.mem_piFinset]
    rw [this, Fintype.card_piFinset, Finset.prod_const]; simp [this]
  have hBc : Bc.card = 8^n := by
    let D := Finset.univ.filter (fun d : Digit ↦ ¬ 5 ∣ to_nat_digit d)
    have : D.card = 8 := by decide
    have : Bc = Fintype.piFinset (fun _ : Fin n ↦ D) := by ext; simp [Bc, D, Fintype.mem_piFinset]
    rw [this, Fintype.card_piFinset, Finset.prod_const]; simp [this]
  have hAcBc : (Ac ∩ Bc).card = 4^n := by
    let D := Finset.univ.filter (fun d : Digit ↦ ¬ 2 ∣ to_nat_digit d ∧ ¬ 5 ∣ to_nat_digit d)
    have : D.card = 4 := by decide
    have : Ac ∩ Bc = Fintype.piFinset (fun _ : Fin n ↦ D) := by ext; simp [Ac, Bc, D, Fintype.mem_piFinset]
    rw [this, Fintype.card_piFinset, Finset.prod_const]; simp [this]
  have h_good : S.filter is_good_seq = S \ (Ac ∪ Bc) := by
    ext s; simp only [is_good_seq, Ac, Bc, Finset.mem_filter, Finset.mem_univ, Finset.mem_sdiff,
      Finset.mem_union, true_and, not_or, not_forall, not_not]
    rw [Nat.Coprime.mul_dvd_iff_and_dvd (by decide)]
    simp [Nat.Prime.dvd_prod_iff Nat.prime_two, Nat.Prime.dvd_prod_iff Nat.prime_five, to_nat_digit]
  have h_card_good : (S.filter is_good_seq).card = 9^n + 4^n - (8^n + 5^n) := by
    rw [h_good, Finset.card_sdiff (Finset.subset_univ _), Finset.card_union, hS, hAc, hBc, hAcBc]
    omega
  have h9 : (9 : ENNReal) ^ n ≠ 0 := ENNReal.pow_ne_zero (by simp) n
  have h9' : (9 : ENNReal) ^ n ≠ ⊤ := ENNReal.pow_ne_top (ENNReal.nat_ne_top 9) n
  rw [← Finset.card_filter, h_card_good]
  simp only [ENNReal.ofNat_sub, ENNReal.ofNat_add, ENNReal.ofNat_pow]
  field_simp [h9, h9']
  have h_ineq : 8^n + 5^n ≤ 9^n + 4^n := by
    induction n with
    | zero => simp
    | succ n ih =>
      repeat rw [pow_succ]
      have : 9 * 9^n + 4 * 4^n = 9 * (9^n + 4^n) - 5 * 4^n := by omega
      have : 8 * 8^n + 5 * 5^n ≤ 8 * (8^n + 5^n) := by omega
      omega
  rw [← ENNReal.ofNat_add, ENNReal.add_sub_cancel' (by simp [h_ineq]), ENNReal.ofNat_add]
  field_simp [h9, h9']

