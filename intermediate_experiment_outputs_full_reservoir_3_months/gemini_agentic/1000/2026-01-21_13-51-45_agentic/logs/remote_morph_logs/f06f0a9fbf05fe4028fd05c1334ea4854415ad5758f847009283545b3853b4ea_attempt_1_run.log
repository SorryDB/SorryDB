Released under Apache 2.0 license as described in the file LICENSE.
Authors: Shalev Wengrowsky
-/

import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype, good_seqs]
  simp only [DigitSeq, Fintype.card_fun, Fintype.card_fin, Set.mem_setOf_eq, ENNReal.ofNat_pow]
  let S := Finset.univ (α := DigitSeq n)
  let Aᶜ := S.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 2 ≠ 0)
  let Bᶜ := S.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 5 ≠ 0)
  have h_good : S.filter (fun s ↦ is_good_seq s) = S \ (Aᶜ ∪ Bᶜ) := by
    ext s; simp [is_good_seq, Nat.prime_two.dvd_prod_iff, Nat.prime_five.dvd_prod_iff, to_nat_digit]
    rw [← Nat.coprime_two_five.mul_dvd_iff_and_dvd, not_not]
  have h_card_S : S.card = 9 ^ n := by simp [S, DigitSeq]
  have h_card_Ac : Aᶜ.card = 5 ^ n := by
    simp [Aᶜ, DigitSeq, Finset.card_univ, Fintype.card_fun, Fintype.card_fin]
    have : (Finset.univ.filter fun d : Digit ↦ to_nat_digit d % 2 ≠ 0).card = 5 := by
      decide
    rw [Finset.card_filter_univ_pi, this, Finset.card_univ, Fintype.card_fin]
  have h_card_Bc : Bᶜ.card = 8 ^ n := by
    simp [Bᶜ, DigitSeq, Finset.card_univ, Fintype.card_fun, Fintype.card_fin]
    have : (Finset.univ.filter fun d : Digit ↦ to_nat_digit d % 5 ≠ 0).card = 8 := by
      decide
    rw [Finset.card_filter_univ_pi, this, Finset.card_univ, Fintype.card_fin]
  have h_card_AcBc : (Aᶜ ∩ Bᶜ).card = 4 ^ n := by
    simp [Aᶜ, Bᶜ, DigitSeq, Finset.card_univ, Fintype.card_fun, Fintype.card_fin, ← Finset.filter_and]
    have : (Finset.univ.filter fun d : Digit ↦ to_nat_digit d % 2 ≠ 0 ∧ to_nat_digit d % 5 ≠ 0).card = 4 := by
      decide
    rw [Finset.card_filter_univ_pi, this, Finset.card_univ, Fintype.card_fin]
  have h_card_Ac_union_Bc : (Aᶜ ∪ Bᶜ).card = 5 ^ n + 8 ^ n - 4 ^ n := by
    rw [Finset.card_union, h_card_Ac, h_card_Bc, h_card_AcBc]
  have h_card_good : (S.filter is_good_seq).card = 9 ^ n - (5 ^ n + 8 ^ n - 4 ^ n) := by
    rw [h_good, Finset.card_sdiff (Finset.subset_univ _), h_card_S, h_card_Ac_union_Bc]
  rw [h_card_good, ENNReal.ofNat_sub, ENNReal.ofNat_sub]
  · field_simp [ENNReal.ofNat_pow]
    ring_nf
  · exact Nat.pow_le_pow_of_le_left (by decide) n
  · apply Nat.le_sub_of_add_le
    rw [add_comm, ← h_card_Ac_union_Bc]
    exact Finset.card_le_univ (Aᶜ ∪ Bᶜ)

