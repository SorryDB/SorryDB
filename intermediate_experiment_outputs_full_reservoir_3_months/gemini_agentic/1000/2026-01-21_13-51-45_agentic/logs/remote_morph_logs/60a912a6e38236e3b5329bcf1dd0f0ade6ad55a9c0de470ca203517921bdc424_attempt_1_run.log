lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  let H := G - X
  have hH : ∀ x, H.inessential x := by
    intro x
    by_cases hxV : x ∈ V(H)
    · have h_not : ν(H - x) ≠ ν(G) - (X ∪ {x}).encard := fun h ↦
        (hX.2 h (subset_union_left _ _) : X = X ∪ {x}) (by simpa [hxV] using Set.mem_union_right X (Set.mem_singleton x))
      have h_le : ν(H - x) ≤ ν(H) := sorry
      have h_ge : ν(H) ≤ ν(H - x) + 1 := sorry
      have h_eq : ν(H - x) = ν(H) := by
        rw [← hX.1, encard_union_eq_add_encard_of_disjoint (Set.disjoint_left.mpr (by simp [hxV])) (Set.singleton_finite x), encard_singleton] at h_not
        exact h_le.antisymm (by contrapose! h_not; exact (h_ge.antisymm (Order.not_lt.mp h_not)).trans (by simp))
      obtain ⟨M, hM_max⟩ := exists_max_matching H
      have : ∃ M', H.IsMaxMatching M' ∧ x ∉ V(H, M') := by
        rw [← IsMaxMatching.encard hM_max, ← h_eq] at hM_max
        sorry
      exact ⟨this.choose, this.choose_spec.1, this.choose_spec.2⟩
    · exact inessential_of_not_mem hxV
  obtain ⟨M, hM, hcomp⟩ := foo_of_forall_inessential hH
  have hM_max : H.IsMaxMatching M := ⟨hM, sorry⟩
  have h_enc : 2 * M.encard + (OddComponents H).encard = (V(G) \ X).encard := sorry
  rw [← hM_max.encard, ← h_enc, ENat.add_sub_cancel (by sorry)]
  rfl
