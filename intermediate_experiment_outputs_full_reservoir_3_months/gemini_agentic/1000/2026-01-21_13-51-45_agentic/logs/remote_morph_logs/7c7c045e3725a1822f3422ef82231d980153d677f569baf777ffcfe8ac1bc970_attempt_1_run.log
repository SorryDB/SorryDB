theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  rw [ctble_iff_set_nat_equinum]
  apply Iff.intro
  · intro h
    obtain ⟨A, f, hf⟩ := h
    obtain ⟨f1, g1, h1, h2⟩ := (equinum_iff_inverse_pair A U).mp ⟨f, hf.1, hf.2⟩
    exists (λ u => (g1 u).val)
    intro u1 u2 heq
    have h3 : g1 u1 = g1 u2 := Subtype.ext heq
    rw [← (congr_fun h1 u1), ← (congr_fun h1 u2), h3]
  · intro ⟨f, hf⟩
    let A := range f
    exists A
    let g : U → A := λ u => ⟨f u, ⟨u, rfl⟩⟩
    have g_1to1 : one_to_one g := λ _ _ heq => hf (congr_arg Subtype.val heq)
    have g_onto : onto g := λ ⟨n, hn⟩ => let ⟨u, hu⟩ := hn; ⟨u, Subtype.ext hu⟩
    obtain ⟨gU, gA, h1, h2⟩ := (equinum_iff_inverse_pair U A).mp ⟨g, g_1to1, g_onto⟩
    exact (equinum_iff_inverse_pair A U).mpr ⟨gA, gU, h2, h1⟩
