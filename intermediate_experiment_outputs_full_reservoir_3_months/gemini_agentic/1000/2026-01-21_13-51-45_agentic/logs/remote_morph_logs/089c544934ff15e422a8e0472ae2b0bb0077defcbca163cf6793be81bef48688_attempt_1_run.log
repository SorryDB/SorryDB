lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  have h_fin : (G - Y).OddComponents.encard ≠ ⊤ := by
    apply (Set.Finite.subset (Set.Finite.image _ (G - Y).finite_comps) (Set.subset_univ _)).encard_lt_top.ne
  rw [ENat.le_sub_iff_add_le h_fin, MatchingNumber, ← ENat.mul_sSup]
  · apply sSup_le
    rintro _ ⟨M, hM, rfl⟩
    have h_link : ∀ e ∈ M, G.IsLink e ∨ G.IsLoop e := fun e he ↦ G.isLink_or_isLoop (hM.subset he)
    have h_v_m : (V(G, M)).encard ≤ 2 * M.encard := by
      rw [V_matching_encard_eq_sum hM]
      apply ENat.sum_le_sum
      intro e he
      cases h_link e he <;> simp_all [IsLink.encard_V, IsLoop.encard_V, (by norm_num : 1 ≤ 2)]
    have h_count : (G - Y).OddComponents.encard + (V(G, M) \ Y).encard ≤ (V(G) \ Y).encard := sorry
    have h_y_count : (V(G, M) ∩ Y).encard ≤ Y.encard := encard_le_encard (Set.inter_subset_right _ _)
    calc 2 * M.encard + (G - Y).OddComponents.encard
      _ ≥ V(G, M).encard + (G - Y).OddComponents.encard := add_le_add_right h_v_m _
      _ = (V(G, M) \ Y).encard + (V(G, M) ∩ Y).encard + (G - Y).OddComponents.encard := by rw [encard_diff_add_encard_inter]
      _ ≤ (V(G, M) \ Y).encard + Y.encard + (G - Y).OddComponents.encard := add_le_add_right (add_le_add_left h_y_count _) _
      _ = ((V(G, M) \ Y).encard + (G - Y).OddComponents.encard) + Y.encard := by rw [add_assoc, add_comm (Y.encard), ← add_assoc]
      _ ≤ (V(G) \ Y).encard + Y.encard := add_le_add_right h_count _
      _ = V(G).encard + Y.encard := by rw [encard_diff_add_encard_inter, encard_inter_comm, encard_inter_vSet_left]
  · use 0, ∅, by simp [isMatching_iff]
