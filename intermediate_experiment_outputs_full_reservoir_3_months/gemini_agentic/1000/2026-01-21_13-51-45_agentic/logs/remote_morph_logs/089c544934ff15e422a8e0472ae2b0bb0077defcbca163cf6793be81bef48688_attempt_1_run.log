lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  have h_odd_fin : (G - Y).OddComponents.encard ≠ ⊤ := by
    have hV : V(G).Finite := (inferInstance : G.Finite).finite_V
    have : (G - Y).OddComponents.encard ≤ V(G).encard := sorry
    exact (hV.encard_lt_top.trans_le' this).ne
  rw [ENat.le_sub_iff_add_le h_odd_fin, MatchingNumber]
  have h_nonempty : {n | ∃ M, G.IsMatching M ∧ n = M.encard}.Nonempty := ⟨0, ∅, by simp [isMatching_iff]⟩
  rw [← ENat.mul_sSup h_nonempty]
  apply sSup_le
  rintro _ ⟨M, hM, rfl⟩
  have h_v_m : V(G, M).encard ≤ 2 * M.encard := sorry
  have h_odd_count : (G - Y).OddComponents.encard ≤ (V(G) \ (V(G, M) ∪ Y)).encard + (V(G, M) ∩ Y).encard := sorry
  have h_Y_count : (V(G, M) ∩ Y).encard ≤ Y.encard := encard_le_encard (Set.inter_subset_right _ _)
  calc 2 * M.encard + (G - Y).OddComponents.encard
    _ ≥ V(G, M).encard + (G - Y).OddComponents.encard := add_le_add_right h_v_m _
    _ = (V(G, M) \ Y).encard + (V(G, M) ∩ Y).encard + (G - Y).OddComponents.encard := by
      rw [encard_diff_add_encard_inter V(G, M) Y]
    _ ≤ (V(G, M) \ Y).encard + (V(G, M) ∩ Y).encard + ((V(G) \ (V(G, M) ∪ Y)).encard + (V(G, M) ∩ Y).encard) :=
      add_le_add_left h_odd_count _
    _ = ((V(G, M) \ Y).encard + (V(G) \ (V(G, M) ∪ Y)).encard) + 2 * (V(G, M) ∩ Y).encard := by
      rw [add_assoc, add_comm (V(G, M) ∩ Y).encard, ← add_assoc, ← add_assoc, two_mul]
    _ ≤ (V(G) \ Y).encard + 2 * Y.encard := by
      refine add_le_add ?_ (mul_le_mul_left' h_Y_count 2)
      rw [← encard_union_of_disjoint (disjoint_sdiff_left.mono_right (Set.diff_subset _ _))]
      apply encard_le_encard
      intro x hx
      cases hx with
      | inl h1 => exact ⟨h1.1, h1.2⟩
      | inr h2 => exact ⟨h2.1, fun h => h2.2 (Or.inl h)⟩
    _ = (V(G) \ Y).encard + Y.encard + Y.encard := by rw [two_mul, add_assoc]
    _ = V(G).encard + Y.encard := by
      rw [encard_diff_add_encard_inter V(G) Y, encard_inter_comm, encard_inter_vSet_left]
