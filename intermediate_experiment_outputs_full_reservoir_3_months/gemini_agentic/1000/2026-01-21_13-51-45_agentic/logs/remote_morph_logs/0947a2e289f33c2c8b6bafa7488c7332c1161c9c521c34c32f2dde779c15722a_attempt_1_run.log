lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  rw [integral_of_le pi_pos.le, integral_of_le (by norm_num), ← image_cos_Icc]
  rw [integral_image_eq_integral_abs_deriv_smul measurableSet_Icc injOn_cos_Icc (fun x _ => hasDerivAt_cos x)]
  apply set_integral_congr measurableSet_Icc
  intro x hx
  rw [abs_neg, abs_sin_eq_sin hx, smul_eq_mul]
```
