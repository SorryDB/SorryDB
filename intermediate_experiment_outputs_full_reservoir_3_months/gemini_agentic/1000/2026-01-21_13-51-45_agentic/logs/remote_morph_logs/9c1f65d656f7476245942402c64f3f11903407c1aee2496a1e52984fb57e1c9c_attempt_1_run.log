  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have : ↑(Γ ∪ Δ) ⊆ construction T hT m := by
    intro x hx; simp at hx; rcases hx with hx | hx;
    . apply monotone_construction (le_max_left _ _); apply hΓ₁ hx;
    . apply monotone_construction (le_max_right _ _); apply hΔ₁ hx;
  have this : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) ➝ ξ ∈ T.theory := by
    apply T.imp_closed ?_ $ T.andIR hΓ₂ hΔ₂;
    apply T.L_subset; apply Logic.iff_provable.mp; simp;
  let Λ := insert (φ ⋎ ψ) (Γ ∪ Δ)
  obtain ⟨k, hk⟩ := by simpa [construction_omega, Set.mem_iUnion] using hφψ
  let i := max m k
  have hi : ↑Λ ⊆ construction T hT i := by
    intro x hx; simp [Λ] at hx; rcases hx with rfl | hx
    · apply monotone_construction (le_max_right m k); exact hk
    · apply monotone_construction (le_max_left m k); exact this✝ hx
  have h_ent : Λ.conj ➝ ξ ∈ T.theory := by
    apply T.mem_trans (χ := ξ) ?_ this
    apply T.mem_of_provable; apply Logic.iff_provable.mp; simp
  have h_not_entail : ∀ (j : ℕ) (Λ' : Finset (Formula ℕ)), ↑Λ' ⊆ construction T hT j → Λ'.conj ➝ ξ ∈ T.theory → False := by
    intro j; induction j with
    | zero =>
      intro Λ' hΛ' h_ent'; apply hT;
      have h_imp_conj : χ ➝ Λ'.conj ∈ T.theory := by
        induction Λ' using Finset.induction_on with
        | empty => apply T.mem_of_provable; simp
        | insert δ' Λ'' _ ih_inner =>
          have hδ' : χ ➝ δ' ∈ T.theory := hΛ' (Finset.mem_insert_self δ' Λ'');
          have hΛ'' : χ ➝ Λ''.conj ∈ T.theory := ih_inner (λ x hx => hΛ' (Finset.mem_insert_of_mem hx));
          apply T.imp_closed (φ := (χ ➝ δ') ⋏ (χ ➝ Λ''.conj)) (by apply T.L_subset; apply Logic.iff_provable.mp; simp) (T.andIR hδ' hΛ'');
      exact T.mem_trans h_imp_conj h_ent';
    | succ j ih =>
      intro Λ' hΛ' h_ent';
      have h_subset_prev : ↑Λ' ⊆ construction T hT (j + 1) := hΛ';
      dsimp [construction] at h_subset_prev;
      split at h_subset_prev;
      · rename_i δ h_decode; split_ifs with h_cond at h_subset_prev;
        · by_cases hδ : δ ∈ Λ';
          · apply h_cond (Λ'.erase δ);
            · intro x hx;
              have h_in := h_subset_prev (Finset.mem_erase.mp hx).2;
              simp [Finset.mem_insert, (Finset.mem_erase.mp hx).1] at h_in; assumption;
            · apply T.imp_closed (φ := Λ'.conj) (by apply T.L_subset; apply Logic.iff_provable.mp; simp [hδ]) h_ent';
          · apply ih Λ' (λ x hx => by have h_in := h_subset_prev hx; simp [Finset.mem_insert, hδ] at h_in; assumption) h_ent';
        · apply ih Λ' h_subset_prev h_ent';
      · apply ih Λ' h_subset_prev h_ent';
  exact h_not_entail i Λ hi h_ent;
