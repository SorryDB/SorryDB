      intro Γ hΓ; contrapose! hT;
      have : χ ➝ Γ.conj ∈ T.theory := by
        induction Γ using Finset.induction_on with
        | empty => apply T.mem_of_provable; apply Logic.iff_provable.mpr; simp;
        | insert δ Γ' _ ih =>
          simp at hΓ; apply T.imp_closed ?_ (T.andIR hΓ.1 (ih hΓ.2));
          apply T.L_subset; apply Logic.iff_provable.mp; simp;
      exact T.mem_trans this hT;
    | succ i ih =>
