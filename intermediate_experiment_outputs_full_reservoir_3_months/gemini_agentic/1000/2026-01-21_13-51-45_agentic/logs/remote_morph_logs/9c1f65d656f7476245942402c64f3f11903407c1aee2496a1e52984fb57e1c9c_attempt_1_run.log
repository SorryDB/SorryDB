              . exact h_in;
            . apply T.imp_closed ?_ h_ent;
              apply T.L_subset; apply Logic.iff_provable.mp; simp;
          . apply ih Γ _ h_ent;
            intro x hx;
            have := hΓ (Finset.mem_insert_of_mem hx);
            rcases this with rfl | h_in;
            . exfalso; exact hδ hx;
            . exact h_in;
        . exact ih Γ hΓ;
