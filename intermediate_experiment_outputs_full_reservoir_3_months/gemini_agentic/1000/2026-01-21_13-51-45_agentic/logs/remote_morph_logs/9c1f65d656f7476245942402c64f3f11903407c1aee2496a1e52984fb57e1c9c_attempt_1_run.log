lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have : ↑(Γ ∪ Δ) ⊆ construction T hT m := by sorry;
  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) ➝ ξ ∈ T.theory := by
    apply T.imp_closed ?_ $ T.andIR hΓ₂ hΔ₂;
    sorry;
  let Θ := (Γ ∪ Δ).insert (φ ⋎ ψ)
  have hΘ : ↑Θ ⊆ construction_omega T hT := by
    intro f hf; simp [Θ] at hf;
    rcases hf with (hf | hf | hf)
    · exact ⋃ i, construction T hT i |> (Set.mem_iUnion.mpr ⟨encode φ, hΓ₁ hf⟩)
    · exact ⋃ i, construction T hT i |> (Set.mem_iUnion.mpr ⟨encode ψ, hΔ₁ hf⟩)
    · exact hf ▸ hφψ
  obtain ⟨δ, hδ, hmax⟩ := Θ.exists_maximal_image encode (by simp)
  have h_not_δ : δ ∉ construction_omega T hT := by
    apply not_of_mem_construction_omega (Γ := Θ.erase δ)
    · intro x hx; obtain ⟨hx1, hx2⟩ := Finset.mem_erase.mp hx;
      apply monotone_construction (hmax x hx1)
      obtain ⟨i, hi⟩ := by simpa [construction_omega] using hΘ hx1;
      exact hi;
    · apply T.imp_closed (φ := Θ.conj) ?_ (T.L_subset $ Logic.iff_provable.mp $ by simp)
      · apply Deduction.ctx; sorry
  exact h_not_δ (hΘ hδ)
