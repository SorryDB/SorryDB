      have h_even : Even n := Nat.not_odd_iff_even.mp h_not_odd
      have h_off : s.offDiag.card = n * (n - 1) := by
        rw [Finset.offDiag_card, hcard, Nat.mul_sub_left_distrib, Nat.mul_one]
      have h_max : ∀ P ∈ s, (s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card ≤ n - 2 := by
        intro P hP; rw [← hcard]; exact h_all.2 s hB hCF (hcard.symm ▸ h_even) P hP
      have h_union : s.offDiag ⊆ s.biUnion (fun P => s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)) := by
        intro x hx; obtain ⟨A, B⟩ := x; have hx_copy := hx; rw [Finset.mem_offDiag] at hx
        obtain ⟨hA, hB_mem, hne⟩ := hx; obtain ⟨C, hC_mem, hC_dist⟩ := (hb₀ s).mp hB A hA B hB_mem hne
        simp only [Finset.mem_biUnion, Finset.mem_filter]; exact ⟨C, hC_mem, hx_copy, by rwa [dist_comm, dist_comm C]⟩
      have h_total_le : s.offDiag.card ≤ n * (n - 2) := by
