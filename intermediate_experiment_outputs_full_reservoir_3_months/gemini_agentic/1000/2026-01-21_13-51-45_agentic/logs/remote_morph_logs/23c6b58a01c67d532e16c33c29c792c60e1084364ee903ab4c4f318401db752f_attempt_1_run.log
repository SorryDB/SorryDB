import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    rcases Nat.even_or_odd n with h | h
    · -- n is even: regular (n-1)-gon plus its center, with radius chosen such that R is some side length
      sorry
    · -- n is odd: regular n-gon
      sorry
  · ext n
    constructor
    · rintro ⟨h3, s, hB, hCF, hcard⟩
      constructor; exact h3
      by_contra h_odd
      have h_even : Even n := Nat.even_iff_not_odd.mpr h_odd
      rw [hb₀] at hB
      rw [hb₁] at hCF
      let pairs := s.offDiag
      let f : (p : EuclideanSpace ℝ (Fin 2) × EuclideanSpace ℝ (Fin 2)) → p ∈ pairs → s :=
        fun p hp =>
        let ⟨hA, hB_mem, hAB_neq⟩ := Finset.mem_offDiag.mp hp
        let h_ex := hB p.1 hA p.2 hB_mem hAB_neq
        ⟨Classical.choose h_ex, (Classical.choose_spec h_ex).1⟩
      have h_fiber : ∀ P ∈ s, (pairs.filter (fun p => f p (by assumption) = P)).card ≤ n - 2 := by
        intro P hP
        -- The center-free condition implies that for each P, the distances to other points are at most 2-to-1.
        -- If n is even, n-1 is odd, so there's at least one point at a unique distance from P.
        -- Thus, at most n-2 ordered pairs (A, B) satisfy dist(P, A) = dist(P, B).
        sorry
      have h_total : pairs.card ≤ n * (n - 2) := by
        have : pairs.card = ∑ P in s, (pairs.filter (fun p => f p (by assumption) = P)).card := by
          sorry
        rw [this, hcard]
        refine Finset.sum_le_card_nsmul s (n - 2) ?_
        intro P hP; exact h_fiber P hP
      have h_pairs_card : pairs.card = n * (n - 1) := by
        rw [Finset.offDiag_card, hcard, Nat.mul_sub_left_distrib, Nat.mul_one]
      rw [h_pairs_card] at h_total
      have : n - 1 ≤ n - 2 := Nat.le_of_mul_le_mul_left h_total (by linarith)
      linarith
    · rintro ⟨h3, h_odd⟩
      constructor; exact h3
      -- Construction: a regular n-gon is both balanced and center-free for odd n >= 3
      sorry

