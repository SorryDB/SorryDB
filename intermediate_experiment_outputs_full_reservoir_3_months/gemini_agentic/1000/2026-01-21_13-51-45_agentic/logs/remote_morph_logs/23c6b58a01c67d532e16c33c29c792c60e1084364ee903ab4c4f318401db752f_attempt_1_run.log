          _ ≤ ∑ P ∈ s, (s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card := Finset.card_biUnion_le
          _ ≤ ∑ P ∈ s, (n - 2) := Finset.sum_le_sum (fun P hP => h_max P hP)
          _ = n * (n - 2) := by rw [Finset.sum_const, hcard, Nat.nsmul_eq_mul]
