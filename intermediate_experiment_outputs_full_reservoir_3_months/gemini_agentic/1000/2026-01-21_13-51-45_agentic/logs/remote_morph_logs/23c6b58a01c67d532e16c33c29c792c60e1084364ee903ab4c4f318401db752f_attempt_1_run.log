import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    rcases Nat.even_or_odd n with h | h
    · -- Even case: Construction exists (e.g., points on two specific circles)
      sorry
    · -- Odd case: Regular n-gon works
      sorry
  · ext n
    constructor
    · rintro ⟨h3, s, hB, hCF, hcard⟩
      refine ⟨h3, ?_⟩
      by_contra h_not_odd
      have h_even : Even n := Nat.not_odd_iff_even.mp h_not_odd
      let pairs := s.offDiag
      let f : (p : EuclideanSpace ℝ (Fin 2) × EuclideanSpace ℝ (Fin 2)) → p ∈ pairs → s :=
        fun p hp =>
          let ⟨hA, ⟨hB_mem, hAB_neq⟩⟩ := Finset.mem_offDiag.mp hp
          let h_ex := (hb₀ s).mp hB p.1 hA p.2 hB_mem hAB_neq
          ⟨Classical.choose h_ex, (Classical.choose_spec h_ex).1⟩
      let fiber (P : EuclideanSpace ℝ (Fin 2)) := pairs.attach.filter (fun p => (f p.1 p.2 : EuclideanSpace ℝ (Fin 2)) = P)
      have h_total : pairs.card = ∑ P in s, (fiber P).card := by
        sorry
      have h_fiber_card : ∀ P ∈ s, (fiber P).card ≤ n - 2 := by
        intro P hP
        -- For each P, dist(P, .) takes any value at most twice (center-free).
        -- With n-1 other points and n-1 being odd, at least one point has a unique distance from P.
        -- Thus there are at most (n-2) ordered pairs (A, B) such that dist(P, A) = dist(P, B).
        sorry
      have h_total_le : pairs.card ≤ n * (n - 2) := by
        rw [h_total, hcard]
        sorry
      have h_card : pairs.card = n * (n - 1) := by
        rw [Finset.offDiag_card, hcard]; rfl
      rw [h_card] at h_total_le
      have : n - 1 ≤ n - 2 := Nat.le_of_mul_le_mul_left h_total_le (by linarith)
      linarith
    · rintro ⟨h3, h_odd⟩
      refine ⟨h3, ?_⟩
      -- A regular n-gon is both balanced and center-free for any odd n ≥ 3.
      sorry

