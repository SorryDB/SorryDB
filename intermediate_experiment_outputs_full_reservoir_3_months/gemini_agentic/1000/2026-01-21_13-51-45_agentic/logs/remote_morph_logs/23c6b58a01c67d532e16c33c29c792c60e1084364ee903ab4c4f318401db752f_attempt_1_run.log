import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    rcases Nat.even_or_odd n with h_even | h_odd
    · -- For even n, a balanced set exists (e.g., using two regular polygons with common center).
      sorry
    · -- For odd n, a regular n-gon is a balanced set.
      sorry
  · ext n
    constructor
    · rintro ⟨h3, s, hB, hCF, hcard⟩
      refine ⟨h3, ?_⟩
      by_contra h_not_odd
      have h_even : Even n := Nat.not_odd_iff_even.mp h_not_odd
      have h_off : s.offDiag.card = n * (n - 1) := by
        rw [Finset.offDiag_card, hcard]
        try rw [Nat.mul_sub_left_distrib, Nat.mul_one]
      have h_max : ∀ P ∈ s, (s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card ≤ n - 2 := by
        intro P hP
        -- Due to center-free property, each distance from P occurs at most twice.
        -- Thus, each distance d yields at most one pair (A, B) in s \ {P}.
        -- Since |s \ {P}| = n-1 is odd, at least one point is not paired.
        sorry
      have h_union : s.offDiag ⊆ s.biUnion (fun P => s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)) := by
        intro x hx
        obtain ⟨A, B⟩ := x
        have hx_copy := hx
        rw [Finset.mem_offDiag] at hx
        obtain ⟨hA, hB_mem, hne⟩ := hx
        obtain ⟨C, hC_mem, hC_dist⟩ := (hb₀ s).mp hB A hA B hB_mem hne
        simp only [Finset.mem_biUnion, Finset.mem_filter]
        exact ⟨C, hC_mem, hx_copy, by rwa [dist_comm, dist_comm C]⟩
      have h_total_le : s.offDiag.card ≤ n * (n - 2) := by
        calc s.offDiag.card
          _ ≤ (s.biUnion fun P => s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card := Finset.card_le_card h_union
          _ ≤ ∑ P ∈ s, (s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card := Finset.card_biUnion_le
          _ ≤ ∑ P ∈ s, (n - 2) := Finset.sum_le_sum (fun P hP => h_max P hP)
          _ = n * (n - 2) := by rw [Finset.sum_const, hcard, Nat.nsmul_eq_mul]
      have h_contr : n * (n - 1) ≤ n * (n - 2) := h_off.symm ▸ h_total_le
      have h_pos : 0 < n := by linarith
      have h_le : n - 1 ≤ n - 2 := Nat.le_of_mul_le_mul_left h_contr h_pos
      have h_lt : n - 2 < n - 1 := Nat.sub_lt_sub_left (by linarith) (by linarith)
      exact (Nat.lt_le_asymm h_lt h_le).elim
    · rintro ⟨h3, h_odd⟩
      refine ⟨h3, ?_⟩
      -- A regular n-gon is balanced and center-free for any odd n ≥ 3.
      sorry
