  have h_all : (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n ∧ (Odd n → center_free s)) ∧ (∀ s : Finset (EuclideanSpace ℝ (Fin 2)), Balanced s → center_free s → Even s.card → ∀ P ∈ s, (s.offDiag.filter (fun ab => dist P ab.1 = dist P ab.2)).card ≤ s.card - 2) := sorry
  constructor
  · intro n hn; obtain ⟨s, hB, hc, _⟩ := h_all.1 n hn; exact ⟨s, hB, hc⟩
  · ext n; constructor
    · rintro ⟨h3, s, hB, hCF, hcard⟩
      refine ⟨h3, ?_⟩
