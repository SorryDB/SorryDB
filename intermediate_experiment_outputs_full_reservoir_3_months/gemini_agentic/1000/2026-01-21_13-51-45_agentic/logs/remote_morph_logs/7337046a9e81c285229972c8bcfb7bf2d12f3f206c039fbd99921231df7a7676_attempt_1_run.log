lemma refinement_lt_of_exists_ne_singleton (B : ∀ N hN, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine ⟨refinement_le B hB hB' hB'', fun h_ref => ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  have h_subset : B N hN ⊆ {N} := by
    intro x hx
    have x_in_ref : x ∈ refinement B hB hB' hB'' :=
      Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hx⟩⟩
    rcases h_ref x_in_ref with ⟨S, hS, hx_eq⟩
    have x_le_N : x ≤ N := by rw [hB N hN]; exact le_sSup hx
    have S_sub_N : S ⊆ {N} := by
      intro s hs
      have s_in_D : s ∈ D := hS hs
      have s_le_N : s ≤ N := (hx_eq.symm ▸ le_sSup hs : s ≤ x).trans x_le_N
      by_contra h_sne
      have h_disj := D.sSupIndep.disjoint_sSup s_in_D (Set.singleton_subset_iff.mpr hN) h_sne
      rw [sSup_singleton] at h_disj
      exact D.not_bot_mem (h_disj.eq_bot_of_le s_le_N ▸ s_in_D)
    rcases Set.subset_singleton_iff_eq.mp S_sub_N with rfl | rfl
    · have : x = ⊥ := by rw [hx_eq, sSup_empty]
      exact hB'' N hN (this ▸ hx)
    · rw [hx_eq, sSup_singleton]
      exact Set.mem_singleton N
  have h_nonempty : (B N hN).Nonempty := by
    rw [Set.nonempty_iff_ne_empty]
    intro h_empty
    have : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]
    exact D.not_bot_mem (this ▸ hN)
  exact h_ne (Set.subset_singleton_iff_eq.mp h_subset |>.resolve_left h_nonempty.ne_empty)
