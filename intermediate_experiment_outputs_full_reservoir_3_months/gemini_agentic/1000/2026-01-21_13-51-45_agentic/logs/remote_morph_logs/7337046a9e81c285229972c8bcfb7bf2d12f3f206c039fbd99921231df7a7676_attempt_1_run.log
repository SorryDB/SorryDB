/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  rcases H with ⟨N, hN, h_ne⟩
  have h_B_sub : B N hN ⊆ {N} := by
    intro x hx
    have hx_D : x ∈ D := by
      have hx_ref : x ∈ (refinement B hB hB' hB'').carrier := by
        simp only [Set.mem_iUnion]
        exact ⟨N, hN, hx⟩
      rwa [h_eq]
    have hx_le : x ≤ N := (hB N hN).symm ▸ le_sSup hx
    have hx_ne_bot : x ≠ ⊥ := fun h_bot => hB'' N hN (h_bot ▸ hx)
    exact Set.mem_singleton_iff.mpr (D.sSupIndep.eq_of_le hx_D hN hx_le hx_ne_bot)
  have h_B_eq : B N hN = {N} := by
    rcases Set.subset_singleton_iff_eq.mp h_B_sub with h_empty | h_singleton
    · have : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]
      exact (D.not_bot_mem (this ▸ hN)).elim
    · exact h_singleton
  exact h_ne h_B_eq

end Indecomposable

end DirectSumDecomposition
```
