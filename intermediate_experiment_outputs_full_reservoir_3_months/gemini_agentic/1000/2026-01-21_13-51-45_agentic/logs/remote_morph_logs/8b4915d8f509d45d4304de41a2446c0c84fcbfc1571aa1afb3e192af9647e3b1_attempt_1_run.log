/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')
  intro h_eq
  rcases H with ⟨N, hN, hne⟩
  have h_sub : B N hN ⊆ D.carrier := by
    intro N' hN'
    rw [← congr_arg carrier h_eq]
    exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'⟩⟩
  have h_all : ∀ N' ∈ B N hN, N' = N := by
    intro N' hN'
    by_contra h_ne_N
    have hN'leN : N' ≤ N := (hB N hN).symm ▸ le_sSup hN'
    have hN'leDiff : N' ≤ sSup (D.carrier \ {N'}) :=
      le_sSup_of_le (show N ∈ D.carrier \ {N'} from ⟨hN, h_ne_N.symm⟩) hN'leN
    have : N' = ⊥ := le_bot_iff.mp (disjoint_iff_inf_le.mp (D.sSupIndep N' (h_sub hN')) ⟨le_refl N', hN'leDiff⟩)
    exact hB'' N hN (this ▸ hN')
  have h_ne_empty : (B N hN).Nonempty := by
    rw [Set.nonempty_iff_ne_empty]
    intro h_e
    have : N = ⊥ := (hB N hN).trans (h_e ▸ sSup_empty)
    exact D.not_bot_mem (this ▸ hN)
  apply hne
  ext N'
  simp only [Set.mem_singleton_iff]
  constructor
  · exact h_all N'
  · intro h_N'N; subst h_N'N
    rcases h_ne_empty with ⟨N'', hN''⟩
    rwa [h_all N'' hN''] at hN''

```
