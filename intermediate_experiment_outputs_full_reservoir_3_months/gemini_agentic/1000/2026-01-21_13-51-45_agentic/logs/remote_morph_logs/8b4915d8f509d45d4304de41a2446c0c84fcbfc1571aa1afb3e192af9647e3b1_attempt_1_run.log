/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')
  intro h_eq
  rcases H with ⟨N, hN, hne⟩
  have h_sub : B N hN ⊆ D.carrier := by
    intro N' hN'
    have h_carrier_eq : (refinement B hB hB' hB'').carrier = D.carrier := congr_arg carrier h_eq
    rw [← h_carrier_eq]
    exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'⟩⟩
  have h_all : ∀ N' ∈ B N hN, N' = N := by
    intro N' hN'
    have hN'leN : N' ≤ N := (hB N hN).symm ▸ le_sSup hN'
    by_contra h_ne
    have h_disj : Disjoint N' (sSup {N}) :=
      sSupIndep.disjoint_sSup D.sSupIndep' (h_sub hN') (Set.singleton_subset_iff.mpr hN) h_ne
    rw [sSup_singleton] at h_disj
    have h_bot : N' = ⊥ := h_disj.eq_bot_of_le hN'leN
    exact hB'' N hN (h_bot ▸ hN')
  apply hne
  ext N'
  constructor
  · exact h_all N'
  · intro h
    have h_ne_empty : (B N hN).Nonempty := by
      by_contra h_empty
      have h_bot : N = ⊥ := (hB N hN).trans (Set.not_nonempty_iff_eq_empty.mp h_empty ▸ sSup_empty)
      exact D.not_bot_mem (h_bot ▸ hN)
    rcases h_ne_empty with ⟨N'', hN''⟩
    have : N'' = N := h_all N'' hN''
    rw [Set.mem_singleton_iff] at h
    rwa [h, ← this]
