/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ‚Č§ S.length := by
  -- Let N be the number of agents. For each agent j ‚Č† k, we track two events:
  -- 1. The first call that carries agent j's secret to agent k (E_j).
  -- 2. The last call that carries agent k's secret to agent j (L_j).
  -- There are 2 * (n - 1) such events in total.
  -- In a no-hearing-own-secret (noHo) sequence, each call not involving k can
  -- contribute to at most one of these 2n-2 events.
  -- Each call involving k can contribute to at most two of these events (one incoming, one outgoing).
  -- Therefore, the total number of distinct calls is at least:
  -- (Total events - 2 * calls_with_k) / 1 + calls_with_k
  -- Which simplifies to: 2 * (n - 1) ‚Č§ S.length + v S k.
  rcases n with _| _| n
  ¬∑ simp [v]
  ¬∑ simp [v]
  ¬∑ have h_exp := exp_needs_n_min_one_calls S h
    have h_known := known_needs_n_min_one_calls S h2
    induction S generalizing k
    ¬∑ simp [after, isExpert, initialState] at h
      specialize h ‚ü®(k.1 + 1) % (n + 2), Nat.mod_lt _ (by omega)‚ü©
      simp [initialState] at h; omega
    ¬∑ simp [v, countP] at *
      split_ifs <;> omega
