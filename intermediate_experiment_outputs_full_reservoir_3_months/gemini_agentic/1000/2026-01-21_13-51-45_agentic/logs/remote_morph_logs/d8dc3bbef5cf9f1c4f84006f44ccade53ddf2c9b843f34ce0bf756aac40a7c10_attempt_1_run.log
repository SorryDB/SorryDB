  : B ∈ Knave ∧ C ∈ Knight := by 
  have BKnave : B ∈ Knave
  set_knave_to_knight
  intro BKnight
  have CKnave := stCn.mpr BKnight
  have stA := stB.mp BKnight
  have AKnave : A ∈ Knave
  set_knave_to_knight
  intro AKnight
  have KnightCard := stA.mp AKnight
  rw [Finset.card_eq_one] at KnightCard
  have ⟨a,ha⟩ := KnightCard 
  rw [ha] at AKnight
  rw [ha] at BKnight
  rw [Finset.mem_singleton] at AKnight
  rw [Finset.mem_singleton] at BKnight
  rw [←AKnight] at BKnight
  contradiction
  set_knave_to_knight at AKnave
  simp [AKnave] at stA
  apply stA
  rw [Finset.card_eq_one]
  use B
  ext x; cases x <;> (set_knave_to_knight at CKnave; simp [AKnave, BKnight, CKnave])
  constructor; assumption; exact stC.mpr BKnave
```
