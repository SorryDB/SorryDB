theorem permanent_conjecture (M : Matrix (Fin n) (Fin n) ℝ) :
    M ∈ doublyStochastic ℝ (Fin n) → permanent M ≥ (n.factorial)/(n ^ n) := by
  intro hM
  cases n with
  | zero =>
    simp [permanent, Nat.factorial]
  | succ n =>
    cases n with
    | zero =>
      simp [permanent, Nat.factorial]
      have h := congr_fun hM.right.left 0
      simp [mulVec, dotProduct, Finset.sum_singleton] at h
      simp [h]
    | succ n =>
      sorry
