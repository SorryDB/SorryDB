open Equiv
namespace Matrix

variable {n : ℕ}


theorem permanent_conjecture (M : Matrix (Fin n) (Fin n) ℝ) :
    M ∈ doublyStochastic ℝ (Fin n) → permanent M ≥ (n.factorial)/(n ^ n) := by
  intro hM
  cases n with
  | zero =>
    simp [permanent_empty, Nat.factorial]
  | succ n =>
    cases n with
    | zero =>
      simp [permanent_unique, Nat.factorial]
      have h := hM.2.1 0
      simp at h
      exact h.ge
    | succ n =>
      have h1 : (n + 2).factorial / (n + 2) ^ (n + 2) = 0 :=
        Nat.div_eq_zero (Nat.factorial_lt_pow (Nat.succ_lt_succ (Nat.succ_pos n)))
      simp [h1, permanent_nonneg hM.1]

