import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  obtain ⟨U, hU1, hU2⟩ := NoSmallSubgroups.exists_is_trivial (G := Circle)
  have : (ContinuousMonoidHom.toContinuousMap ⁻¹' (ContinuousMap.gen Set.univ U) : Set (PontryaginDual M)) = {1} := by
    ext f
    simp only [Set.mem_preimage, ContinuousMap.mem_gen_univ, Set.mem_singleton_iff]
    refine ⟨fun hf ↦ ?_, fun hf ↦ by simp [hf, mem_of_mem_nhds hU1]⟩
    ext x
    obtain ⟨H, hH⟩ := IsCompact.isSubgroup (s := MonoidHom.range f.toMonoidHom) (isCompact_range f.continuous)
    have : H = ⊥ := hU2 H (hH.symm ▸ hf)
    simpa [this, ← hH] using Set.mem_range_self x
  exact this ▸ (ContinuousMonoidHom.continuous_toContinuousMap.isOpen_preimage _ (ContinuousMap.isOpen_gen_univ hU1))

end PontryaginDual
```
