  rw [discreteTopology_iff_isOpen_singleton_one]
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hV : IsOpen {f : ContinuousMap M Circle | Set.range f ⊆ U} :=
    ContinuousMap.isOpen_set_mapsTo isCompact_univ hU
  have hW : IsOpen (ContinuousMonoidHom.toContinuousMap ⁻¹' {f : ContinuousMap M Circle | Set.range f ⊆ U}) :=
    continuous_induced_dom.isOpen_preimage _ hV
  suffices (ContinuousMonoidHom.toContinuousMap ⁻¹' {f : ContinuousMap M Circle | Set.range f ⊆ U}) = {1} from this ▸ hW
  ext f
  simp only [Set.mem_preimage, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
