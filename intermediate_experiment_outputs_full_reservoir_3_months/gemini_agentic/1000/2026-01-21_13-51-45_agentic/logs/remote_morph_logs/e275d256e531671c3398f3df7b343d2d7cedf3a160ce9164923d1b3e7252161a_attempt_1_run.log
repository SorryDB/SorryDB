      obtain ⟨z, hz, h_nz⟩ := H.exists_ne_one_of_nontrivial h_ne
      -- A subgroup of the circle group contained in the right half-plane must be trivial.
      -- If z ≠ 1, some power z^n has non-positive real part.
      -- We use the fact that the only subgroup in the right half-plane is ⊥.
      refine h_nz (Subgroup.mem_bot.1 ?_)
      let fz : ℤ → H := fun n ↦ ⟨z ^ n, H.zpow_mem hz n⟩
      have : ∀ n, 0 < ((fz n : Circle) : ℂ).re := fun n ↦ hH (fz n).2
      -- This is a standard fact for the circle group: Re(z^n) > 0 for all n implies z = 1.
      -- Since there's no direct lemma, we use the fact that the only such subgroup is ⊥.
      exact (Subgroup.eq_bot_of_subset_re_pos hH).symm ▸ hz
    exact Subgroup.mem_bot.1 (h_bot ▸ (⟨x, rfl⟩ : f x ∈ H))
  · rintro rfl x
    simp only [ContinuousMonoidHom.one_apply, Circle.coe_one, Complex.one_re, zero_lt_one]

end PontryaginDual
