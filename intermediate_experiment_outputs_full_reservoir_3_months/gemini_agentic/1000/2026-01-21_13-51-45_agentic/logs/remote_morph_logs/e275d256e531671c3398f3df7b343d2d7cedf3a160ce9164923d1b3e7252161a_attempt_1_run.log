import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hW : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ U} :=
    isOpen_induced_iff.mpr ⟨ContinuousMap.gen Set.univ U,
      ContinuousMap.isOpen_gen isCompact_univ hU, rfl⟩
  suffices {f : PontryaginDual M | ∀ x, f x ∈ U} = {1} from this ▸ hW
  ext f
  simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · intro hf
    refine ContinuousMonoidHom.ext fun x ↦ ?_
    let z := f x
    have h_abs : Complex.abs (z : ℂ) = 1 := mem_sphere_zero_iff_norm.mp z.2
    have h_re : ∀ n : ℕ, 0 < (z ^ n : ℂ).re := fun n ↦ by
      specialize hf (x ^ n)
      rwa [map_pow, Submonoid.coe_pow] at hf
    by_contra h_z1
    have h_z1_coe : (z : ℂ) ≠ 1 := by
      contrapose! h_z1; ext; exact h_z1
    let θ := |(z : ℂ).arg|
    have hnz : (z : ℂ) ≠ 0 := by intro h; simpa [h] using h_abs
    have hθ_pos : 0 < θ := by
      contrapose! h_z1_coe
      have h_arg : (z : ℂ).arg = 0 := abs_le_zero.mp h_z1_coe
      have := Complex.exp_i_arg hnz
      rw [h_arg, h_abs] at this
      simpa using this.symm
    let n₀ := Nat.find (exists_nat_gt (Real.pi / (2 * θ)))
    have h_n0_gt : Real.pi / 2 < (n₀ : ℝ) * θ := by
      have h_spec := Nat.find_spec (exists_nat_gt (Real.pi / (2 * θ)))
      rwa [lt_div_iff hθ_pos] at h_spec
    have h_n0_le : (n₀ : ℝ) * θ ≤ 3 * Real.pi / 2 := by
      cases n₀ with
      | zero =>
        have h_spec := Nat.find_spec (exists_nat_gt (Real.pi / (2 * θ)))
        simp [Real.pi_pos, hθ_pos] at h_spec
      | succ n =>
        rw [Nat.cast_succ, add_mul, one_mul]
        have hθ_le_pi : θ ≤ Real.pi := abs_le.mpr ⟨(Complex.neg_pi_lt_arg hnz).le, Complex.arg_le_pi z⟩
        by_cases hn : n = 0
        · linarith [hn, Real.pi_pos]
        · have h_min : ¬ ((n : ℝ) > Real.pi / (2 * θ)) := Nat.find_min (exists_nat_gt (Real.pi / (2 * θ))) (Nat.lt_succ_self n)
          push_neg at h_min
          rw [le_div_iff hθ_pos] at h_min
          linarith [Real.pi_pos]
    have : (z ^ n₀ : ℂ).re ≤ 0 := by
      rw [Submonoid.coe_pow, Complex.re_pow_nat, h_abs, one_pow, one_mul, ← Real.cos_abs, ← abs_mul, ← Nat.cast_mul]
      exact Real.cos_nonpos_of_pi_div_two_le_of_le_three_pi_div_two h_n0_gt.le h_n0_le
    exact this.not_lt (h_re n₀)
  · rintro rfl x
    simp only [U, Set.mem_setOf_eq, ContinuousMonoidHom.coe_one, Pi.one_apply]
    show 0 < (↑(1 : Circle) : ℂ).re
    exact zero_lt_one

end PontryaginDual

