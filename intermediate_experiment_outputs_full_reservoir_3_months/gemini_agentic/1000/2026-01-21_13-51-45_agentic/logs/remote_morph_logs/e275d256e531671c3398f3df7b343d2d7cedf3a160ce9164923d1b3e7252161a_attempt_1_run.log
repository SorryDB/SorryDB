    apply continuous_induced_dom.isOpen_preimage
    apply (ContinuousMap.isBasis_compactOpen M Circle).isOpen
    exact ⟨⟨Set.univ, isCompact_univ⟩, ⟨U, hU⟩, rfl⟩
  suffices {f : PontryaginDual M | ∀ x, f x ∈ U} = {1} from this ▸ hW
  ext f
  simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · intro hf
    refine ContinuousMonoidHom.ext fun x ↦ ?_
    by_contra hx
    obtain ⟨n, hn⟩ := Circle.exists_pow_re_nonpos hx
    let m := n.natAbs
    have h_re : (f x ^ n : ℂ).re = (f x ^ m : ℂ).re := by
      cases n with
      | ofNat n => rfl
      | negSucc n =>
        simp only [zpow_negSucc, Int.natAbs_negSucc, Circle.coe_inv, Complex.conj_re, Circle.coe_pow]
    have : (f (x ^ m) : ℂ).re > 0 := hf (x ^ m)
    rw [map_pow, Circle.coe_pow, ← h_re] at this
    exact hn.not_lt this
  · rintro rfl x
    simp only [U, Set.mem_setOf_eq, ContinuousMonoidHom.coe_one, Pi.one_apply, Circle.coe_one,
      Complex.one_re, zero_lt_one]

end PontryaginDual
