  have hV : IsOpen {f : M →c Circle | Set.range f ⊆ U} := isOpen_set_mapsTo isCompact_univ hU
  have hW : IsOpen (ContinuousMonoidHom.toContinuousMap ⁻¹' {f : M →c Circle | Set.range f ⊆ U}) :=
    continuous_induced_dom.isOpen_preimage _ hV
  suffices (ContinuousMonoidHom.toContinuousMap ⁻¹' {f : M →c Circle | Set.range f ⊆ U}) = {1} from this ▸ hW
  ext f
  simp only [Set.mem_preimage, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · intro hf
    ext x
    let S : Submonoid Circle := Submonoid.range f.toMonoidHom
    have hS : IsCompact (S : Set Circle) := by
      rw [Submonoid.coe_range]
