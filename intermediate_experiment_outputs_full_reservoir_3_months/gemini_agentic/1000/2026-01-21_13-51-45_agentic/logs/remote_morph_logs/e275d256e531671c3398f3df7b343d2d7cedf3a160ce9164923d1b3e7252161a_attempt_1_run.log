  ext f
  simp only [Set.mem_preimage, ContinuousMap.mem_gen, Set.subset_def, Set.mem_univ,
    forall_true_left, Set.mem_singleton_iff]
  constructor
  · intro hf
    ext x
    let S := Submonoid.range (f : M →* Circle)
    have hS : IsCompact (S : Set Circle) := isCompact_range f.continuous
    let hG := IsCompact.isGroup_of_submonoid hS
    let H : Subgroup Circle := { S with inv_mem' := hG.inv_mem }
    have hH : (H : Set Circle) ⊆ U := by
      rintro z ⟨y, rfl⟩
      exact hf y
