```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := Complex.continuous_re.comp continuous_induced_dom |>.isOpen_preimage _ isOpen_pos
  have hV : IsOpen {f : PontryaginDual M | Set.range f ⊆ U} := ContinuousMap.isOpen_gen isCompact_univ hU
  suffices {f : PontryaginDual M | Set.range f ⊆ U} = {1} from this ▸ hV
  ext f; simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
  refine ⟨fun hf ↦ ?_, fun hf ↦ by simp [hf, Circle.val_one, Complex.one_re, zero_lt_one]⟩
  ext x
  let S : Submonoid Circle := f.toMonoidHom.range
  have hS : IsCompact (S : Set Circle) := by
    convert isCompact_range f.continuous
    exact MonoidHom.coe_range f.toMonoidHom
  obtain ⟨H, hH⟩ := submonoid_is_group_of_compact S hS
  have hHU : (H : Set Circle) ⊆ U := hH.symm ▸ hf
  have hHbot : H = ⊥ := by
    by_contra hHbot
    obtain ⟨z, hzH, hz1⟩ := H.bot_or_exists_ne_one.resolve_left hHbot
    let θ := Complex.arg (z : ℂ)
    have hθ : θ ≠ 0 := by
      intro h; apply hz1; ext; rw [Circle.val_one]; exact Complex.arg_eq_zero_iff.mp h
    have h_pow : ∀ n : ℕ, 0 < (z ^ (n : ℤ) : ℂ).re := fun n ↦ by
      have : z ^ (n : ℤ) ∈ H := H.zpow_mem hzH
      exact hHU this
    obtain ⟨n, hn⟩ : ∃ n : ℤ, ¬ (0 < (z ^ n : ℂ).re) := by
      obtain ⟨n, hn1, hn2⟩ := exists_int_pow_near_minus_one z hz1
      exact ⟨n, by rw [hn1]; norm_num⟩
    exact hn (h_pow _)
  have hfx : f x ∈ H := by rw [hH]; exact Set.mem_range_self x
  rw [hHbot] at hfx
  exact hfx

end PontryaginDual
```
