    let H : Subgroup Circle := Submonoid.toSubgroup S (IsCompact.isGroup_of_submonoid hS).inv_mem
    have hH : (H : Set Circle) ⊆ U := hf
    by_contra hx
    have hxH : f x ∈ H := Set.mem_range_self x
    have hx_ne : f x ≠ 1 := hx
    let n : ℤ := 4
    have h_pow (z : Circle) (hz : z ∈ H) (n : ℤ) : z ^ n ∈ H := H.zpow_mem hz n
