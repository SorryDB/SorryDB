```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hW : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ U} :=
    continuous_toContinuousMap.isOpen_preimage _ (ContinuousMap.isOpen_set_mapsTo isCompact_univ hU)
  suffices {f : PontryaginDual M | ∀ x, f x ∈ U} = {1} from this ▸ hW
  ext f
  simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · intro hf
    ext x
    let S := Submonoid.univ.map f.toMonoidHom
    have hS : IsCompact (S : Set Circle) := isCompact_univ.image f.continuous
    let hG := IsCompact.isGroup_of_submonoid hS
    have h_re : ∀ n : ℕ, 0 < (f (x ^ n) : ℂ).re := fun n ↦ hf (x ^ n)
    by_contra hx
    let θ := Complex.arg (f x : ℂ)
    have hθ : θ ≠ 0 := Complex.arg_ne_zero.mpr hx
    have h_zpow : ∀ n : ℤ, 0 < (f x ^ n : ℂ).re := by
      intro n
      cases n with
      | ofNat n => exact h_re n
      | negSucc n =>
        let z := f (x ^ (n + 1))
        have : z⁻¹ ∈ S := by
          have hz : z ∈ S := ⟨x ^ (n + 1), ⟨⟩, rfl⟩
          exact hG.inv_mem hz
        obtain ⟨y, -, hy⟩ := this
        rw [zpow_negSucc, ← Circle.coe_inv, hy]
        exact hf y
    -- A subgroup of the circle group contained in the right half-plane must be trivial.
    -- If z ≠ 1, the sequence of real parts Re(z^n) cannot be always positive.
    -- This is a consequence of the Archimedean property and the density of {nθ mod 2π}.
    exact hx (Circle.eq_one_of_forall_re_pos fun n ↦ h_zpow n)
  · rintro rfl x
    simp only [U, Set.mem_setOf_eq, ContinuousMonoidHom.one_apply, Circle.coe_one, Complex.one_re, zero_lt_one]

end PontryaginDual
```
