import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_induced_dom).isOpen_preimage _ isOpen_Ioi
  let V := ContinuousMap.gen (Set.univ : Set M) U
  have hV : IsOpen V := ContinuousMap.isOpen_gen isCompact_univ hU
  have hW : IsOpen (ContinuousMonoidHom.toContinuousMap ⁻¹' V : Set (PontryaginDual M)) :=
    continuous_induced_dom.isOpen_preimage _ hV
  suffices (ContinuousMonoidHom.toContinuousMap ⁻¹' V : Set (PontryaginDual M)) = {1} from this ▸ hW
  ext f
  simp only [Set.mem_preimage, ContinuousMap.mem_gen, Set.mem_univ, Set.forall_true_left, Set.mem_singleton_iff]
  constructor
  · intro hf
    ext x
    by_contra hx
    obtain ⟨n, hn⟩ : ∃ n : ℤ, (f x ^ n : ℂ).re ≤ 0 := by
      obtain ⟨n, hn_neg⟩ := Circle.exists_zpow_re_neg hx
      exact ⟨n, hn_neg.le⟩
    let m := n.natAbs
    have h_re : (f x ^ m : ℂ).re = (f x ^ n : ℂ).re := by
      cases n with
      | ofNat n => rfl
      | negSucc n =>
        simp only [Int.negSucc_coe, zpow_neg, zpow_natCast, Circle.coe_inv, Complex.conj_re, Int.natAbs_negSucc]
    have h_fm : (f (x ^ m) : ℂ).re ≤ 0 := by
      rw [← map_pow, h_re]
      exact hn
    have h_in_U : 0 < (f (x ^ m) : ℂ).re := hf (x ^ m)
    exact h_fm.not_lt h_in_U
  · rintro rfl x
    simp only [ContinuousMonoidHom.one_apply, Circle.coe_one, Complex.one_re, zero_lt_one]

end PontryaginDual
```
