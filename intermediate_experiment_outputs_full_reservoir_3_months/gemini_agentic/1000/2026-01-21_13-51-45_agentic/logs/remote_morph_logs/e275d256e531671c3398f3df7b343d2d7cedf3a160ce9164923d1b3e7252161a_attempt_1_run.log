import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  obtain ⟨U, hU_one, hU_sub⟩ := NoSmallSubgroups.exists_nhds_one_subgroup_eq_bot (G := Circle)
  obtain ⟨V, hV_sub, hV_open, hV_one⟩ := _root_.mem_nhds_iff.mp hU_one
  let W : Set (PontryaginDual M) := ContinuousMonoidHom.toContinuousMap ⁻¹' (ContinuousMap.gen Set.univ V)
  have hW_open : IsOpen W := (ContinuousMap.isOpen_gen_univ hV_open).preimage ContinuousMonoidHom.continuous_toContinuousMap
  suffices W = {1} from this ▸ hW_open
  refine Set.ext fun f ↦ ⟨fun hf ↦ ?_, fun hf ↦ by simp [hf, hV_one, W, ContinuousMap.mem_gen_univ]⟩
  refine ContinuousMonoidHom.ext fun x ↦ ?_
  let S : Submonoid Circle := f.toMonoidHom.range
  have hS : IsCompact (S : Set Circle) := by
    rw [MonoidHom.coe_range]
    exact isCompact_range f.continuous
  have hS_group : IsGroup (S : Set Circle) := IsCompact.isGroup_of_submonoid hS
