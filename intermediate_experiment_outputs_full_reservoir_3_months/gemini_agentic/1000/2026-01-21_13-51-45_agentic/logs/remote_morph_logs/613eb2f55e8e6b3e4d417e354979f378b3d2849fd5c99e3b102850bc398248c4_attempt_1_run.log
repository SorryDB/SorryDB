          exact h_pw.head ha
        · rintro ⟨h1, h2⟩; exact ⟨h1 y (List.mem_cons_self _ _), h2⟩

  have h_mem_sub {l : List Int} {s : List Int} : s ∈ subsequences l ↔ s.Sublist l := by
