  let allSubseq := (List.foldl (fun acc x => acc ++ List.map (fun sub => x :: sub) acc) [[]] xs).map List.reverse
  let lens2 := (allSubseq.filter (fun l => List.Pairwise (· < ·) l)).map (fun l => l.length)
  let res := List.foldl max 0 lens1

  have h_is_inc (s : List Int) : isStrictlyIncreasing s ↔ List.Pairwise (· < ·) s := by
    induction s with
    | nil => simp [isStrictlyIncreasing, List.Pairwise]
    | cons y s ih =>
      cases s with
      | nil => simp [isStrictlyIncreasing, List.Pairwise]
      | cons z s =>
        simp [isStrictlyIncreasing, ih, List.pairwise_cons]
        constructor
        · rintro ⟨h1, h2⟩
          refine ⟨?_, h2⟩
          intro a ha
          induction ha with
          | head => exact h1
          | tail _ ha' ih' =>
            have h_inc_zs : List.Pairwise (· < ·) (z :: s) := by rwa [ih] at h2
            exact Int.lt_trans h1 (h_inc_zs.left a ha')
        · rintro ⟨h1, h2⟩
          exact ⟨h1 z (List.mem_cons_self z s), ih.mpr h2⟩

  have h_mem_s1 (s : List Int) : s ∈ subsequences xs ↔ s.Sublist xs := by
    induction xs generalizing s with
    | nil =>
      simp [subsequences]
      constructor <;> intro h
      · subst s; exact List.Sublist.nil
      · cases h; rfl
    | cons y ys ih =>
      simp [subsequences, ih]
      constructor
      · rintro (h | ⟨s', hs', rfl⟩)
        · exact List.Sublist.trans ((ih s).mp h) (List.Sublist.cons y (List.Sublist.refl ys))
        · exact List.Sublist.cons_cons y ((ih s').mp hs')
      · intro h; cases h with
        | nil => left; exact (ih []).mpr List.Sublist.nil
        | cons _ _ h' => left; exact (ih s).mpr h'
        | cons_cons _ _ h' => right; use _; constructor; exact (ih _).mpr h'; rfl

  have h_mem_s2 (s : List Int) : s ∈ allSubseq ↔ s.Sublist xs := by
    simp [allSubseq]
    constructor
    · rintro ⟨s', hs', rfl⟩
      induction xs using List.reverseRecOn generalizing s' with
      | nil => simp at hs'; subst s'; exact List.Sublist.nil
      | append ys y ih =>
        simp [List.foldl_append] at hs'
        cases hs' with
        | inl h => exact List.Sublist.trans (ih _ h) (List.sublist_append_left ys [y])
        | inr h => rcases h with ⟨s'', hs'', rfl⟩; simp; exact List.Sublist.append (ih _ hs'') (List.Sublist.refl [y])
    · intro h
      induction xs using List.reverseRecOn generalizing s h with
      | nil => cases h; use []; simp
      | append ys y ih =>
        rw [List.sublist_append_iff] at h
        rcases h with ⟨s1, s2, h1, h2, rfl⟩
        cases s2 with
        | nil =>
          specialize ih _ h1; rcases ih with ⟨s', hs', rfl⟩
          use s'; simp [List.foldl_append, hs']
        | cons y' rs =>
          cases rs with
          | nil =>
            simp at h2; subst y'
            specialize ih _ h1; rcases ih with ⟨s', hs', rfl⟩
            use (y :: s'); simp [List.foldl_append, hs']
          | cons y'' rs' =>
            have h_len := List.Sublist.length_le h2
            simp [List.length] at h_len

  have h_lens_eq : ∀ n, n ∈ lens1 ↔ n ∈ lens2 := by
    intro n; simp [lens1, lens2, h_is_inc, h_mem_s1, h_mem_s2]
    constructor <;> rintro ⟨s, h_sub, h_inc, rfl⟩ <;> use s <;> simp [*]

  have h_res_max : ∀ n ∈ lens1, n ≤ res := by
    intro n hn
    have : ∀ (l : List Nat) a, n ∈ l ∨ n ≤ a → n ≤ List.foldl max a l := by
      intro l a h; induction l generalizing a with
      | nil => cases h with | inl h' => cases h' | inr h' => exact h'
      | cons m ms ih' =>
        simp; apply ih'; cases h with
        | inl h' =>
          cases h' with
          | head => right; apply Nat.le_max_left
          | tail _ h'' => left; exact h''
        | inr h' =>
          right; exact Nat.le_trans h' (Nat.le_max_right m a)
    apply this; left; exact hn

  have h_res_in : res ∈ lens1 := by
    have h0 : 0 ∈ lens1 := by
      use []; simp [lens1, h_is_inc, h_mem_s1, List.Sublist.nil]
    have : ∀ (l : List Nat) a, a ∈ l → List.foldl max a l ∈ l := by
      intro l a ha; induction l generalizing a with
      | nil => exact ha
      | cons m ms ih' =>
        simp; by_cases h : m ≤ a
        · rw [max, if_pos h]; apply ih'; exact ha
        · rw [max, if_neg h]; apply ih'; left; rfl
    apply this; exact h0

  constructor
  · rw [← h_lens_eq]; exact h_res_in
  · simp [List.all_iff_forall_mem]; intro n hn; apply h_res_max; rwa [h_lens_eq]
  -- !benchmark @end proof
