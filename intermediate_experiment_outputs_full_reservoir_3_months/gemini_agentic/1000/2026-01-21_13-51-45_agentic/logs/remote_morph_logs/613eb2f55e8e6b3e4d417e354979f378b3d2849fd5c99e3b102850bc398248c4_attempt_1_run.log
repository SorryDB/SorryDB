theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold longestIncreasingSubseqLength longestIncreasingSubseqLength_postcond
  let lens1 := (List.filter isStrictlyIncreasing (subsequences xs)).map (·.length)
  let result := List.foldl Nat.max 0 lens1
  let g L := List.foldl (fun acc x => acc ++ List.map (fun sub => x :: sub) acc) [[]] L
  let allSubseq := (g xs).map List.reverse
  let lens2 := (allSubseq.filter (fun l => List.Pairwise (· < ·) l)).map (·.length)

  have h_is_inc (s : List Int) : isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by
    induction s with
    | nil => simp [isStrictlyIncreasing, List.Pairwise]
    | cons x s ih =>
      cases s with
      | nil => simp [isStrictlyIncreasing, List.Pairwise]
      | cons y s =>
        simp [isStrictlyIncreasing, List.Pairwise, ih, List.pairwise_cons]
        constructor
        · intro h; split at h
          · rcases (ih.mp h) with ⟨h_pw, h_res⟩
            refine ⟨And.intro ?_ h_pw, h_pw⟩
            intro a ha; have h_y_pw : (y :: s).Pairwise (· < ·) := by rwa [ih] at h
            exact Int.lt_trans ‹x < y› (h_y_pw.head ha)
          · contradiction
        · intro h; rcases List.pairwise_cons.mp h with ⟨h1, h2⟩
          simp [h1 y (List.mem_cons_self _ _), ih.mpr h2]

  have h_mem_sub s : s ∈ subsequences xs ↔ s.Sublist xs := by
    induction xs generalizing s with
    | nil => simp [subsequences]; constructor <;> (intro h; first | subst s; exact List.Sublist.slnil | cases h; rfl)
    | cons x xs ih =>
      simp [subsequences, ih]; constructor
      · rintro (h | ⟨s', h, rfl⟩)
        · exact (ih s).mp h |>.cons x
        · exact (ih s').mp h |>.cons₂ x
      · intro h; cases h with
        | slnil => left; exact (ih []).mpr List.Sublist.slnil
        | cons h' _ => left; exact (ih s).mpr h'
        | cons₂ h' _ => right; use s.tail; constructor
          · exact (ih s.tail).mpr h'
          · simp [List.cons_tail h]

  have h_mem_all s : s ∈ allSubseq ↔ s.Sublist xs := by
    have h_g : ∀ L s, s ∈ g L ↔ s.reverse.Sublist L := by
      intro L; induction L using List.reverseRecOn with
      | nil => simp [g]; intro s; constructor <;> intro h; subst s; exact List.Sublist.slnil; cases h; rfl
      | append_single L x ih =>
        intro s; simp [g, List.foldl_append]; constructor
        · rintro (h | ⟨s', h, rfl⟩)
          · exact (ih s h).cons x
          · rw [List.reverse_cons]; apply List.Sublist.append (ih s' h) (List.Sublist.refl [x])
        · intro h; rw [List.sublist_append_iff] at h
          rcases h with ⟨s1, s2, h1, h2, rfl⟩
          cases s2 with
          | nil => left; exact (ih s1.reverse).mpr (by simp [h1])
          | cons x' t =>
            cases t with
            | nil => simp at h2; subst x'; right; use s1.reverse; simp; exact (ih s1.reverse).mpr (by simp [h1])
            | cons x'' t' => cases List.Sublist.length_le h2
    simp [allSubseq, h_g]; constructor <;> intro h <;> rwa [List.reverse_reverse] at h

  have h_lens_eq n : n ∈ lens1 ↔ n ∈ lens2 := by
    simp [lens1, lens2, h_is_inc, h_mem_sub, h_mem_all]
    constructor <;> rintro ⟨s, h1, h2, rfl⟩ <;> use s <;> simp [*]

  have h_res_max n (hn : n ∈ lens1) : n ≤ result := by
    have h_max_le : ∀ l a, n ∈ l ∨ n ≤ a → n ≤ List.foldl Nat.max a l := by
      intro l; induction l with
      | nil => intro a h; cases h with | inl h' => cases h' | inr h' => exact h'
      | cons m ms ih =>
        intro a h; simp [List.foldl]; apply ih
        cases h with
        | inl h' =>
          cases h' with
          | head => right; apply Nat.le_max_right
          | tail _ h'' => left; exact h''
        | inr h' => right; apply Nat.le_trans h'; apply Nat.le_max_left
    apply h_max_le lens1 0; left; exact hn

  have h_res_mem : result ∈ lens1 := by
    have h0 : 0 ∈ lens1 := by use []; simp [h_is_inc, h_mem_sub, List.Sublist.slnil]
    have h_max_mem : ∀ l a, a ∈ l → List.foldl Nat.max a l ∈ l := by
      intro l; induction l with
      | nil => simp
      | cons m ms ih =>
        intro a ha; simp [List.foldl]; apply ih
        by_cases h : a ≤ m
        · rw [Nat.max_def, if_pos h]; right; exact List.mem_cons_self _ _
        · rw [Nat.max_def, if_neg h]; left; exact ha
    exact h_max_mem lens1 0 h0

  constructor
  · rw [List.contains_iff_mem, ← h_lens_eq]; exact h_res_mem
  · rw [List.all_eq_true]; intro n hn; apply h_res_max; rwa [h_lens_eq]
  -- !benchmark @end proof
