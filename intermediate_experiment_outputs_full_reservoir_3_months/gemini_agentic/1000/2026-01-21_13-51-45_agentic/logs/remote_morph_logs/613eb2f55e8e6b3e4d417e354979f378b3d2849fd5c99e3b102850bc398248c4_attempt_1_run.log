    constructor
    · rintro ⟨t, ht, rfl⟩; rcases h_fold.mp ht with ⟨u, rfl, t', hs, rfl⟩; simp at *; exact hs.reverse
    · intro h; use s.reverse; simp; apply h_fold.mpr; use [], (by simp), s.reverse; simp [h.reverse_iff]

