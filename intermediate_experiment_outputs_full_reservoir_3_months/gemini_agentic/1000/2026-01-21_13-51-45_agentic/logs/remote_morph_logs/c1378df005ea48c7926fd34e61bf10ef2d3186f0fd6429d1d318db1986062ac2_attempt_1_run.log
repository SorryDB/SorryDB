    rcases Finset.univ.eq_empty_or_nonempty with h | h
    · use 1, 1, zero_lt_one, zero_lt_one; intro x
      haveI : IsEmpty ι := ⟨fun i => h.not_mem (Finset.mem_univ i)⟩
