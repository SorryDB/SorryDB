          _ ≤ re ⟪x i, x i⟫_𝕜 := (hcd i (x i)).1
          _ ≤ ∑ j, re ⟪x j, x j⟫_𝕜 := Finset.single_le_sum (fun j _ => inner_self_nonneg) (Finset.mem_univ i)
