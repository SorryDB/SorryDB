instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner x y := ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    choose c d hc hd hcd using fun i => AdjointSpace.inner_top_equiv_norm (𝕜 := 𝕜) (E := E i)
    rcases Finset.univ.eq_empty_or_nonempty with h | h
    · use 1, 1, zero_lt_one, zero_lt_one; intro x
      have : x = 0 := funext (fun i => (h.not_mem (Finset.mem_univ i)).elim)
      simp [this, Inner.inner]
