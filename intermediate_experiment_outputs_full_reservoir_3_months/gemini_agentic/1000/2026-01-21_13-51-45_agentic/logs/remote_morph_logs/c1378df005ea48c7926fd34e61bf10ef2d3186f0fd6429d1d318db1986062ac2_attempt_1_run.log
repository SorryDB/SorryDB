      refine ⟨Finset.inf'_pos h (fun i _ => hc i), Finset.sum_pos (fun i _ => hd i) h, fun x => ⟨?_, ?_⟩⟩
      · obtain ⟨i, -, hi⟩ := Finset.univ.exists_mem_eq_sup (fun i => ‖x i‖) h
        have hx : ‖x‖ = ‖x i‖ := by rw [Pi.norm_def, ← hi, Finset.sup_univ_eq_iSup]
        calc Finset.univ.inf' h c * ‖x‖ ^ 2 = Finset.univ.inf' h c * ‖x i‖ ^ 2 := by rw [hx]
