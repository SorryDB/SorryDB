open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    choose c d hc hd hcd using fun i => AdjointSpace.inner_top_equiv_norm (𝕜 := 𝕜) (E := E i)
    rcases univ.eq_empty_or_nonempty with h | h
    · use 1, 1, zero_lt_one, zero_lt_one; simp [h, inner]
    · use univ.inf' h c, ∑ i, d i
      refine ⟨Finset.inf'_pos h _ (fun i _ => hc i), Finset.sum_pos (fun i _ => hd i) h, fun x => ⟨?_, ?_⟩⟩
      · obtain ⟨i, -, hi⟩ := univ.exists_mem_eq_sup (fun i => ‖x i‖₊) h
        have hx : ‖x‖ = ‖x i‖ := congr_arg NNReal.toReal hi
        calc univ.inf' h c * ‖x‖ ^ 2 = univ.inf' h c * ‖x i‖ ^ 2 := by rw [hx]
          _ ≤ c i * ‖x i‖ ^ 2 := mul_le_mul_of_nonneg_right (Finset.inf'_le _ _ (mem_univ _) h) (pow_two_nonneg _)
          _ ≤ re ⟪x i, x i⟫_𝕜 := (hcd i (x i)).1
          _ ≤ ∑ j, re ⟪x j, x j⟫_𝕜 := Finset.single_le_sum (fun _ _ => inner_self_nonneg) (mem_univ _)
          _ = re ⟪x, x⟫_𝕜 := by simp [inner, RCLike.re_sum]
      · simp only [inner, RCLike.re_sum]
        calc ∑ i, re ⟪x i, x i⟫_𝕜 ≤ ∑ i, d i * ‖x i‖ ^ 2 := Finset.sum_le_sum (fun i _ => (hcd i (x i)).2)
          _ ≤ ∑ i, d i * ‖x‖ ^ 2 := Finset.sum_le_sum (fun i _ => mul_le_mul_of_nonneg_left (pow_le_pow_left (norm_nonneg _) (norm_le_pi_norm x i) 2) (hd i).le)
          _ = (∑ i, d i) * ‖x‖ ^ 2 := by rw [Finset.sum_mul]
```
