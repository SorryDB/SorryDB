      let f : (Fin m → ι × ι) → (ι → ℕ) := fun I i ↦ #{k | (I k).1 = i} + #{k | (I k).2 = i}
      have hf : ∀ I ∈ A ×ˢ A ^^ m, f I ∈ piAntidiag A (2 * m) := by
        intro I hI
        simp only [mem_piAntidiag, mem_piFinset, mem_product] at hI ⊢
        constructor
        · intro i hi
