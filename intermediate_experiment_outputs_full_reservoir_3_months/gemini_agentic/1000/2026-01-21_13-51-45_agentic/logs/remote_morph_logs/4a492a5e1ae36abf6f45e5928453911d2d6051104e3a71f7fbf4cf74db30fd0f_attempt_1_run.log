          rcases hi with ⟨k, rfl⟩ | ⟨k, rfl⟩ <;> [exact (hI k).1; exact (hI k).2]
        · simp only [f, sum_add_distrib, ← card_univ, ← card_sigma, add_self, mul_comm]
      rw [sum_fiberwise_of_maps_to hf]
      refine sum_congr rfl (fun w hw ↦ ?_)
      simp only [EvenIndex, mem_filter, mem_piAntidiag] at hw ⊢
      simp only [hw.2, if_pos, integral_const_mul, mul_comm, Nat.cast_inj]
      let e : (Fin m → ι × ι) ≃ (Fin (2 * m) → ι) :=
        (Equiv.piCongrRight fun _ ↦ Equiv.piFinTwo (fun _ ↦ ι)).trans
          ((Equiv.piCurry ..).symm.trans (Equiv.piCongrLeft _ (Equiv.finProdFinEquiv (mul_comm m 2))))
      have he : ∀ I, f I = fun i ↦ #{k | e I k = i} := by
