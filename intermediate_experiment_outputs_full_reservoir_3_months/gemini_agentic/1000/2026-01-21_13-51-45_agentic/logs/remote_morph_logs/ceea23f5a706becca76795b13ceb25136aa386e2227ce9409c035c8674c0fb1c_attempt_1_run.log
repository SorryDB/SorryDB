theorem IsOpen.dsmooth_iff_smoothOn {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [FiniteDimensional ℝ E] {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E'] [NormedSpace ℝ E'] [FiniteDimensional ℝ E']
    {H' : Type*} [TopologicalSpace H'] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_, ContMDiffOn.dsmooth_restrict⟩
  rw [contMDiffWithinAt_iff_contMDiffAt hs hxs, contMDiffAt_iff_contDiffAt_extChartAt]
  obtain ⟨n, ⟨L⟩⟩ := FiniteDimensional.exists_continuousLinearEquiv_pi ℝ E
  let L' : Eucl n ≃L[ℝ] E := (WithLp.continuousLinearEquiv ℝ 2 (Fin n → ℝ)).trans L.symm
  set e := extChartAt I x
  set v := e x
  set w := L'.symm v
  have hU : IsOpen (L' ⁻¹' (e.target ∩ e.symm ⁻¹' s)) :=
    L'.continuous.isOpen_preimage _ (e.open_target.inter (e.continuousOn_symm.preimage_isOpen_of_isOpen e.open_target hs))
  have hw : w ∈ L' ⁻¹' (e.target ∩ e.symm ⁻¹' s) := by
    simp [w, v, e.map_source (mem_extChartAt_source I x), hxs]
  obtain ⟨g, hg_cont, hg_id, hg_range⟩ := exists_contDiff_id_on_nhds hU hw
  let p := e.symm ∘ L' ∘ g
  have hp : ContMDiff (𝓡 n) I ∞ p :=
    (contMDiffOn_extChartAt_symm I x).comp_contMDiff (L'.contDiff.comp hg_cont).contMDiff (fun z ↦ (hg_range z).1)
  let ps : Eucl n → s := fun z ↦ ⟨p z, (hg_range z).2⟩
  have hps : IsPlot[m.toDiffeology.induced s] ps := isPlot_induced_iff.2 (isPlot_iff_contMDiff I M |>.2 hp)
  have hf_plot : ContMDiff (𝓡 n) I' ∞ (f ∘ p) := hf ps hps
  set e' := extChartAt I' (f x)
  have h_eq : e' ∘ f ∘ e.symm =ᶠ[𝓝 v] (e' ∘ f ∘ p) ∘ L'.symm := by
    filter_upwards [L'.symm.continuousAt.preimage_mem_nhds hg_id] with y hy
    simp only [Function.comp_apply, L'.apply_symm_apply, hy]
  constructor
  · have h_eq_f : f =ᶠ[𝓝 x] (f ∘ p) ∘ L'.symm ∘ e := by
      filter_upwards [e.open_source.mem_nhds (mem_extChartAt_source I x),
        e.continuousAt.preimage_mem_nhds (L'.symm.continuousAt.preimage_mem_nhds hg_id)] with y hy1 hy2
      simp only [Function.comp_apply, L'.apply_symm_apply, hy2, e.left_inv hy1]
    exact h_eq_f.continuousAt_iff.2 (hf_plot.continuous.continuousAt.comp (L'.symm.continuous.continuousAt.comp e.continuousAt))
  · rw [hI.isOpen_range.nhdsWithin_eq (mem_extChartAt_target I x)]
    exact h_eq.contDiffAt_iff.2 ((contMDiffAt_iff_contDiffAt_extChartAt.1 hf_plot.contMDiffAt).2.comp w L'.symm.contDiff.contDiffAt)

