    let n := FiniteDimensional.finrank ℝ E
    let L := ContinuousLinearEquiv.ofFiniteDimensional E (EuclideanSpace ℝ (Fin n)) (by simp)
    let v := e x; have hv : v ∈ e.target := mem_extChartAt_target I x
    let U := e.target ∩ e.symm ⁻¹' s
