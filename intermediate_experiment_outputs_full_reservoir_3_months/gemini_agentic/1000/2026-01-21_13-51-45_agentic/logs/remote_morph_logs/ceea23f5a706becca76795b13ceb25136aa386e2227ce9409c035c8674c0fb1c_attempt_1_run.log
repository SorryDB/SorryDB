    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_, ContMDiffOn.dsmooth_restrict⟩
  rw [contMDiffWithinAt_iff_contMDiffAt hs hxs, contMDiffAt_iff_contDiffAt_extChartAt]
  set e := extChartAt I x
  set e' := extChartAt I' (f x)
  let n := FiniteDimensional.finrank ℝ E
  let L := ContinuousLinearEquiv.ofFiniteDimensional (EuclideanSpace ℝ (Fin n)) E (by simp [n])
  let v := e x; let w := L.symm v
  have hU : IsOpen (e.target ∩ e.symm ⁻¹' s) := e.continuousOn_symm.preimage_isOpen_of_isOpen e.open_target hs
  have hU' : w ∈ L ⁻¹' (e.target ∩ e.symm ⁻¹' s) := by simp [w, v, mem_extChartAt_target I x, hxs]
  obtain ⟨g, hg_cont, hg_id, hg_range⟩ := exists_contDiff_is_id_on_nhds_and_range_subset (hU.preimage L.continuous) hU'
  let p := e.symm ∘ L ∘ g
  have hp : ContMDiff (𝓡 n) I ∞ p := (contMDiffOn_extChartAt_symm I x).comp_contMDiff (L.contDiff.comp hg_cont).contMDiff (fun z ↦ (hg_range (mem_range_self z)).1)
  let ps : Eucl n → s := fun z ↦ ⟨p z, (hg_range (mem_range_self z)).2⟩
  have hps_plot : IsPlot[m.toDiffeology.induced s] ps := isPlot_induced_iff.2 ((isPlot_iff_contMDiff I M).2 hp)
  have hf_plot : ContMDiff (𝓡 n) I' ∞ (f ∘ p) := hf ps hps_plot
  constructor
  · have h_eq : f =ᶠ[𝓝 x] (f ∘ p) ∘ L.symm ∘ e := by
      filter_upwards [e.open_source.mem_nhds (mem_extChartAt_source I x), e.continuousAt.preimage_mem_nhds (L.symm.continuousAt.preimage_mem_nhds hg_id)] with y hy1 hy2
      simp only [Function.comp_apply, L.apply_symm_apply, hy2, e.left_inv hy1]
    exact h_eq.continuousAt_iff.2 (hf_plot.continuous.continuousAt.comp (L.symm.continuous.comp e.continuousAt))
  · have h_eq : e' ∘ f ∘ e.symm =ᶠ[𝓝 v] (e' ∘ f ∘ p) ∘ L.symm := by
      filter_upwards [L.symm.continuousAt hg_id] with y hy
      simp only [Function.comp_apply, L.apply_symm_apply, hy]
    exact h_eq.contDiffAt_iff.2 ((contMDiffAt_iff_contDiffAt_extChartAt.1 hf_plot.contMDiffAt).2.comp v L.symm.contDiffAt)
