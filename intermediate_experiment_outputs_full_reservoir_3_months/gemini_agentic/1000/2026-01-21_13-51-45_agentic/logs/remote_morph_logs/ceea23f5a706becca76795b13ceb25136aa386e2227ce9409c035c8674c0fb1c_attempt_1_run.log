  let n := Module.finrank ℝ E
  let L : Eucl n ≃L[ℝ] E := ContinuousLinearEquiv.ofFinrankEq (by simp [n, Eucl])
  obtain ⟨r, hr, hrU⟩ := Metric.isOpen_iff.1 ((L.continuous.comp (continuous_sub_right v)).preimage hU) 0 (by simp [v, hxs])
  obtain ⟨ρ, hρ_cont, hρ_supp, hρ_one⟩ := exists_contDiff_zero_one_nhds (Metric.ball 0 r) 0 Metric.isOpen_ball (Metric.mem_ball_self hr)
