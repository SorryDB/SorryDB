  let f := Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat
  have hf1 (q : ℚ) : f (j₁ (q ⊗ₜ[ℤ] 1)) = q ⊗ₜ[ℤ] (1 : 𝓞^) := rfl
  have hf2 (z' : 𝓞^) : f (j₂ z') = 1 ⊗ₜ[ℤ] z' := by
    simp [j₂, f, AlgHom.comp_apply, AlgEquiv.toAlgHom_eq_coe, AlgEquiv.apply_symm_apply, Algebra.TensorProduct.includeRight_apply]
  suffices ∃ (N : ℕ+) (z' : 𝓞^), f z = (N : ℚ)⁻¹ ⊗ₜ[ℤ] z' by
    obtain ⟨N, z', h⟩ := this
    use N, z'
    apply f.injective
    rw [map_mul f, hf1, hf2, h, Algebra.TensorProduct.tmul_mul_tmul, mul_one, one_mul]
  induction f z using TensorProduct.induction_on with
