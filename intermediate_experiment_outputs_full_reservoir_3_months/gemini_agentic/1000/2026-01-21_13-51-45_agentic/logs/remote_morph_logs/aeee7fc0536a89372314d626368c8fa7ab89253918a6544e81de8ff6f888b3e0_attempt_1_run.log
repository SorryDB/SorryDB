  have hf1 (q : ℚ) : f (j₁ (q ⊗ₜ[ℤ] 1)) = q ⊗ₜ[ℤ] 1 := by
    rw [Algebra.TensorProduct.assoc_tmul, Algebra.TensorProduct.one_def]
    rfl
  have hf2 (z' : 𝓞^) : f (j₂ z') = 1 ⊗ₜ[ℤ] z' := by
    change f (f.symm (1 ⊗ₜ[ℤ] z')) = 1 ⊗ₜ[ℤ] z'
    simp
  suffices ∃ (N : ℕ+) (z' : 𝓞^), f z = (N : ℚ)⁻¹ ⊗ₜ[ℤ] z' by
    obtain ⟨N, z', h⟩ := this
    use N, z'
    apply f.injective
    rw [map_mul, hf1, hf2, Algebra.TensorProduct.tmul_mul_tmul, mul_one, one_mul, h]
  induction f z using TensorProduct.induction_on with
  | zero => use 1, 0; simp
  | tmul q z' =>
    use ⟨q.den, q.den_pos⟩, q.num • z'
    rw [← TensorProduct.tmul_smul, ← TensorProduct.smul_tmul]
    congr
    · field_simp [Rat.num_div_den]
  | add x y hx hy =>
    obtain ⟨Nx, zx, hx⟩ := hx
    obtain ⟨Ny, zy, hy⟩ := hy
    use Nx * Ny, (Ny : ℤ) • zx + (Nx : ℤ) • zy
    rw [hx, hy, TensorProduct.tmul_add, ← TensorProduct.tmul_smul, ← TensorProduct.tmul_smul]
    congr 1
    · field_simp [Nx.ne_zero, Ny.ne_zero]; ring
    · field_simp [Nx.ne_zero, Ny.ne_zero]; ring

end HurwitzRatHat
