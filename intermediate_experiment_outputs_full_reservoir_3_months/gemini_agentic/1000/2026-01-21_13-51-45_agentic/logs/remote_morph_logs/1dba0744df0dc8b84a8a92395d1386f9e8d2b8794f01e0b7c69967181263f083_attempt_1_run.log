import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n : ℕ := 70
  let s := Finset.Icc 1 n
  let P : Polynomial ℝ := Polynomial.C (5/4) * (∏ k ∈ s, (Polynomial.X - Polynomial.C (k : ℝ))) -
    ∑ k ∈ s, (Polynomial.C (k : ℝ) * ∏ j ∈ s.erase k, (Polynomial.X - Polynomial.C (j : ℝ)))
  have h_roots_exist : ∀ k ∈ Finset.range n, ∃ r_val,
    (k < n - 1 → r_val ∈ Set.Ioo (k + 1 : ℝ) (k + 2 : ℝ)) ∧
    (k = n - 1 → r_val ∈ Set.Ioi (n : ℝ)) ∧ P.IsRoot r_val := by sorry
  choose r_val hr_val using h_roots_exist
  let l (k : ℕ) : ℝ := (k + 1 : ℝ)
  let r (k : ℕ) : ℝ := if h : k < n then r_val k h else 0
  use l, r, n
  have h_r_prop : ∀ k < n, l k < r k ∧ (k < n - 1 → r k < l (k + 1)) ∧ P.IsRoot (r k) := by
    intro k hk; simp [l, r, hk]; exact ⟨(hr_val k hk).1 hk, (hr_val k hk).2.1, (hr_val k hk).2.2⟩
  refine ⟨λ k hk ↦ (h_r_prop k hk).1, λ k hk ↦ (h_r_prop k hk).2.1, ?_, ?_⟩
  · have h_sum_l : ∑ k ∈ Finset.range n, l k = 2485 := by
      simp [l, n, Finset.sum_range_add_one, Finset.sum_range_id]; norm_num
    have h_sum_roots : ∑ k ∈ Finset.range n, r k = 4473 := by
      -- sum of roots = (9/4 * 2485) / (5/4) = 9/5 * 2485 = 4473
      sorry
    rw [Finset.sum_sub_distrib, h_sum_roots, h_sum_l]; norm_num
  · sorry
