import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let l (k : ℕ) : ℝ := (k : ℝ) + 1
  let f (x : ℝ) : ℝ := ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)
  have h_cont : ContinuousOn f {x | ∀ k ∈ Finset.Icc 1 70, x ≠ k} := by
    apply continuousOn_sum
    intro k hk
    apply ContinuousOn.div
    · exact continuousOn_const
    · apply ContinuousOn.sub
      · exact continuousOn_id
      · exact continuousOn_const
    · intro x hx; exact sub_ne_zero.2 (hx k hk)
  have h_mono : ∀ k ∈ Finset.Icc 1 70, StrictAntiOn (λ x => (k : ℝ) / (x - k)) {x | x > k} := by
    intro k _; intro x1 hx1 x2 hx2 hx12
    apply (div_lt_div_left (Nat.cast_pos.2 (Nat.succ_le_iff.1 (Finset.mem_Icc.1 ‹k ∈ Finset.Icc 1 70›).1)) _ _).2
    · exact sub_lt_sub_right hx12 _
    · exact sub_pos.2 hx1
    · exact sub_pos.2 hx2
  have h_r_ex : ∀ k ∈ Finset.Icc 1 70, ∃ r_k, r_k > (k : ℝ) ∧ (∀ j ∈ Finset.Icc 1 70, j > k → r_k < j) ∧ f r_k = 5/4 := by
    sorry
  let r (k : ℕ) : ℝ := if hk : k < 70 then (Classical.choose (h_r_ex (k+1) (Finset.mem_Icc.2 ⟨Nat.succ_le_succ (Nat.zero_le k), hk.trans_le (by norm_num)⟩))) else 0
  have h_rk : ∀ k < 70, r k > (k + 1 : ℝ) ∧ (∀ j ∈ Finset.Icc 1 70, j > k + 1 → r k < j) ∧ f (r k) = 5/4 := by
    intro k hk; dsimp [r]; rw [dif_pos hk]; exact Classical.choose_spec (h_r_ex (k+1) (Finset.mem_Icc.2 ⟨Nat.succ_le_succ (Nat.zero_le k), hk.trans_le (by norm_num)⟩))
  use l, r, n
  refine ⟨by intro k hk; exact (h_rk k hk).1, by intro k hk; exact (h_rk k (hk.trans (by norm_num))).2 (k + 2) (Finset.mem_Icc.2 ⟨by norm_num, by linarith⟩) (by linarith), ?_, ?_⟩
  · have h_sum_r : ∑ k ∈ Finset.range 70, r k = 4473 := by sorry
    have h_sum_l : ∑ k ∈ Finset.range 70, l k = 2485 := by norm_num [l]
    rw [Finset.sum_sub_distrib, h_sum_r, h_sum_l]; norm_num
  · rw [h₁]; ext x
    constructor
    · intro hx; sorry
    · intro hx; sorry
