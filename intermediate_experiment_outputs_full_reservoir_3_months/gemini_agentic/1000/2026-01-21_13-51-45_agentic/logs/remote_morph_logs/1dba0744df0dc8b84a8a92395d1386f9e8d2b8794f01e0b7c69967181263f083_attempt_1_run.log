import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let f (x : ℝ) := ∑ k in Finset.Icc 1 70, (k : ℝ) / (x - k)
  let n := 70
  let P : Polynomial ℝ := (Polynomial.C (5/4)) * (∏ k in Finset.Icc 1 n, (Polynomial.X - Polynomial.C (k : ℝ))) -
    (∑ k in Finset.Icc 1 n, (Polynomial.C (k : ℝ) * (∏ j in (Finset.Icc 1 n).erase k, (Polynomial.X - Polynomial.C (j : ℝ)))))
  have hP_deg : P.degree = n := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_mul, Polynomial.degree_C (by norm_num), zero_add, Polynomial.degree_prod]
      simp only [Polynomial.degree_X_sub_C, Finset.prod_const, Finset.card_Icc, Nat.card_Icc,
        tsub_zero, Polynomial.degree_prod, Finset.sum_const, Nat.smul_one, Polynomial.degree_X_sub_C]
      norm_num
    · rw [Polynomial.degree_sum_le]
      apply (Finset.sup_lt_iff (by norm_num)).mpr
      intro k hk
      rw [Polynomial.degree_mul, Polynomial.degree_prod]
      simp only [Polynomial.degree_C, Polynomial.degree_X_sub_C, Finset.sum_const, Finset.card_erase,
        Finset.card_Icc, Nat.card_Icc, tsub_zero, Nat.smul_one]
      · norm_num
      · rw [Polynomial.degree_C]; norm_num
  have h_root_exists : ∀ k ∈ Finset.Icc 1 n, ∃ x ∈ Set.Ioo (k : ℝ) (if k < n then (k + 1 : ℝ) else 10000), P.IsRoot x := by sorry
  have h_distinct_roots : ∃ r : ℕ → ℝ, (∀ k < n, l k < r k ∧ (k < n - 1 → r k < l (k + 1)) ∧ f (r k) = 5/4) ∧ (∀ k < n, P.IsRoot (r k)) := by sorry
  obtain ⟨r, hr_prop, hr_root⟩ := h_distinct_roots
  let l k := (k + 1 : ℝ)
  use l, r, n
  refine ⟨λ k hk ↦ (hr_prop k hk).1, λ k hk ↦ (hr_prop k (by omega)).2.1, ?_, ?_⟩
  · have h_sum_roots : ∑ k in Finset.range n, r k = 9 / 5 * ∑ k in Finset.Icc 1 n, (k : ℝ) := by
      have h_coeff_n : P.coeff n = 5 / 4 := by
        simp [P, hP_deg]
        have h1 : (∑ k in Finset.Icc 1 n, Polynomial.C (k : ℝ) * ∏ j in (Finset.Icc 1 n).erase k, (Polynomial.X - Polynomial.C (j : ℝ))).degree < n := by
          apply (Polynomial.degree_sum_le _ _).trans_lt
          simp [Finset.sup_lt_iff, Polynomial.degree_mul]
          intro k hk; norm_num; simp [Polynomial.degree_prod]; norm_num
        simp [Polynomial.coeff_sub, Polynomial.coeff_mul, Polynomial.coeff_C_mul, Polynomial.coeff_prod_X_sub_C, h1]
        rw [Polynomial.coeff_eq_zero_of_degree_lt h1]
        simp [Polynomial.coeff_prod_X_sub_C]
      have h_coeff_n_1 : P.coeff (n - 1) = -9 / 4 * ∑ k in Finset.Icc 1 n, (k : ℝ) := by sorry
      have h_root_sum := Polynomial.sum_roots_eq_neg_coeff_div_coeff (by
        have : P.roots.card = n := by rw [Polynomial.card_roots_of_degree_eq hP_deg]; sorry
        exact this)
      simp [h_coeff_n, h_coeff_n_1] at h_root_sum
      sorry
    rw [Finset.sum_range_sub, h_sum_roots]
    have h_sum_k : ∑ k in Finset.Icc 1 70, (k : ℝ) = 2485 := by norm_num
    have h_sum_l : ∑ k in Finset.range 70, l k = 2485 := by
      simp [l]; rw [Finset.sum_range_add_one]; norm_num
    rw [h_sum_k, h_sum_l]; norm_num
  · sorry
