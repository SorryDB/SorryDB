import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor; · rw [Nat.Prime.primeFactors (by norm_num)]; rfl
        constructor; · norm_num
        · norm_num
      else if hk1 : k = 1 then
        use 171; constructor; · norm_num
        constructor
        · have h171 : 171 = 3^2 * 19 := by norm_num
          rw [h171, Nat.primeFactors_mul (by norm_num) (by norm_num)]
          rw [Nat.Prime.primeFactors (by norm_num), Nat.primeFactors_pow 3 (by norm_num)]
          rw [Nat.Prime.primeFactors (by norm_num)]; rfl
        constructor
        · have h1 : 171 ∣ 2^9 + 1 := by norm_num
          have h2 : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact dvd_pow_add_pow_of_odd (2^9) 1 (by norm_num)
          exact h1.trans h2
        · norm_num
      else
        have h_n_gt_3 : n > 3 := by
          have : n.primeFactors.card = k := n_card
          have : k ≥ 2 := by omega
          have : n.primeFactors.card ≥ 2 := by omega
          have : n ≠ 1 ∧ n ≠ 3 := by
            constructor
            · intro h; subst h; norm_num at n_card; linarith
            · intro h; subst h; have : (3 : ℕ).primeFactors.card = 1 := by
                rw [Nat.Prime.primeFactors (by norm_num)]; rfl
              rw [this] at n_card; linarith
          omega
        obtain ⟨p, p_prime, p_div, p_min⟩ := Zsigmondy.exists_prime_factor 2 1 (2 * n) (Nat.coprime_one_right 2) (by norm_num) (by linarith) (by
          rw [Zsigmondy.IsException]; simp [show 2 * n ≠ 6 by linarith, show 2 * n ≠ 2 by linarith]
          exact ⟨⟨1, rfl⟩, rfl⟩)
        use n * p
        have p_odd : Odd p := by
          apply p_prime.odd_of_ne_two; intro hp2; subst hp2
          have : 2 ∣ 2 ^ (2 * n) - 1 := p_div
          norm_num at this
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_div
          exact (p_prime.dvd_or_dvd this).resolve_left (fun h => p_min n (by linarith) (by rw [Nat.pow_one]; exact h))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact p_div
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := by
            apply ZMod.pow_card_sub_one_eq_one p_prime
            intro h; rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; have := p_prime.one_lt; norm_num at h
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors_mul n_pos.ne.symm p_prime.ne_zero, n_card, p_prime.primeFactors]
          rw [Finset.card_insert_of_not_mem]
          · intro h; have := Nat.le_of_dvd n_pos (Nat.mem_primeFactors.mp h).2; linarith
        constructor
        · have h_dvd : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact dvd_pow_add_pow_of_odd (2^n) 1 p_odd
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) (n_div.trans h_dvd) (p_div_pow_plus_one.trans h_dvd)
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

