Released under Apache 2.0 license as described in the file LICENSE.
Authors:
-/

import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp [Odd]
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if h1 : n = 1 then
        use 3; constructor; norm_num; constructor; norm_num; constructor; norm_num; norm_num
      else if h3 : n = 3 then
        use 57; constructor; norm_num; constructor; norm_num; constructor; norm_num; norm_num
      else
        obtain ⟨p, hp_prime, hp_p, hp_not_n⟩ : ∃ p, Nat.Prime p ∧ p ∣ 2 ^ n + 1 ∧ p ∤ n := by
          obtain ⟨p, hp_prime, hp_p, -⟩ := Zsigmondy.exists_prime_factor_pow_plus_one 2 1 (by decide) (by decide) n (by linarith) (by intro h_exc; cases h_exc; case _ h => cases h.2; case _ h => contradiction)
          refine ⟨p, hp_prime, hp_p, ?_⟩
          -- Primitive prime divisor p of 2^n+1 satisfies ord_p(2) = 2n
          -- So p = 2mn + 1 > n, hence p does not divide n.
          sorry
        use n * p
        have p_odd : Odd p := hp_prime.odd_of_ne_two (by
          intro hp2; subst hp2; have : 2 ∣ 2 ^ n + 1 := hp_p;
          have : 2 ∣ 2 ^ n := Nat.dvd_pow_self 2 (by linarith);
          have : 2 ∣ 1 := (Nat.dvd_add_right_iff this).mpr hp_p;
          norm_num at this)
        refine ⟨by positivity, ?_, ?_, n_odd.mul p_odd⟩
        · rw [Nat.primeFactors_mul n_pos.ne' hp_prime.ne_zero, n_card]
          simp [hp_prime, hp_not_n]
        · have h_div_n : n ∣ 2 ^ (n * p) + 1 := n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
          have h_div_p : p ∣ 2 ^ (n * p) + 1 := hp_p.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
          exact Nat.coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n p hp_prime (by
            -- p > n because p is a primitive divisor of 2^n+1 for n > 3
            sorry
          )) h_div_n h_div_p
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
