import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp [Odd]
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; simp [n_card, hk, Nat.primeFactors_prime Nat.prime_three]; norm_num
      else if hk1 : k = 1 then
        use 171; simp [n_card, hk, hk1]
        refine ⟨by norm_num, ?_, ?_, by norm_num⟩
        · have : 171 = 3^2 * 19 := by norm_num
          rw [this, Nat.primeFactors_mul (by norm_num) (by norm_num), Nat.primeFactors_pow (by norm_num) (by norm_num)]
          simp [Nat.primeFactors_prime Nat.prime_three, Nat.primeFactors_prime (by norm_num : Nat.Prime 19)]
        · have : 171 = 9 * 19 := by norm_num
          rw [this]; apply Nat.coprime.mul_dvd_of_dvd_of_dvd (by norm_num)
          · exact Nat.dvd_trans (by norm_num : 9 ∣ 2^9 + 1) (Nat.pow_plus_one_dvd_pow_plus_one (2^9) (by norm_num))
          · exact Nat.dvd_trans (by norm_num : 19 ∣ 2^9 + 1) (Nat.pow_plus_one_dvd_pow_plus_one (2^9) (by norm_num))
      else
        have h2n : 2 * n > 6 := by
          have : k ≥ 2 := Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero hk1)
          have n_ge_15 : n ≥ 15 := by
            have : n.primeFactors.card ≥ 2 := by rwa [n_card]
            obtain ⟨p1, h1, p2, h2, hne⟩ := Finset.one_lt_card_iff.mp this
            have p1_odd : Odd p1 := n_odd.odd_of_dvd (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h1).1).dvd_nat_dist
            have p2_odd : Odd p2 := n_odd.odd_of_dvd (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h2).1).dvd_nat_dist
            have p1_ge_3 : p1 ≥ 3 := Nat.Prime.three_le (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h1).1) (p1_odd.ne_two)
            have p2_ge_3 : p2 ≥ 3 := Nat.Prime.three_le (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h2).1) (p2_odd.ne_two)
            have p1_mul_p2_dvd_n : p1 * p2 ∣ n := (Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime (min p1 p2) (max p1 p2) (if p1 < p2 then (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h2).1) else (Nat.primeFactors_prime (Nat.mem_primeFactors.mp h1).1)) (by apply Nat.lt_of_le_of_ne; apply Nat.min_le_max; intro h; apply hne; cases p1 < p2 <;> simp at h <;> assumption)) (Nat.mem_primeFactors.mp h1).2 (Nat.mem_primeFactors.mp h2).2)
            have h_ge : n ≥ p1 * p2 := Nat.le_of_dvd n_pos p1_mul_p2_dvd_n
            apply Nat.le_trans _ h_ge
            if hp12 : p1 < p2 then apply Nat.mul_le_mul p1_ge_3 (by linarith)
            else have : p2 < p1 := Nat.lt_of_le_of_ne (by linarith) hne.symm; apply Nat.mul_le_mul (by linarith) p2_ge_3
          linarith
        obtain ⟨p, hp_prime, hp_div, hp_not_div⟩ := Nat.exists_prime_factor_pow_sub_one 2 1 (2 * n) (by norm_num) (by norm_num) Nat.coprime_one_right (by linarith) (by linarith) (by simp; linarith)
        have p_div_n_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← sq_sub_one, ← pow_mul]; exact hp_div
          exact (hp_prime.dvd_or_dvd this).resolve_left (hp_not_div n (by linarith))
        have p_new : p ∉ n.primeFactors := by
          have : 2 * n ∣ p - 1 := (Nat.prime_iff_isDomain.mp hp_prime).orderOf_dvd_card_sub_one (p := p) 2
          -- orderOf 2 modulo p is exactly 2n, so p-1 is a multiple of 2n.
          -- Hence p > 2n, so p cannot divide n.
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (ZMod.pow_eq_one_iff_dvd.mpr hp_div)
            intro m hm; rw [ZMod.pow_eq_one_iff_dvd]; exact hp_not_div m hm
          have : 2 * n ∣ p - 1 := by rw [← h_ord]; apply orderOf_dvd_card_sub_one
          have : p > n := by linarith [Nat.Prime.one_lt hp_prime]
          simp [Nat.mem_primeFactors, n_pos.ne']; intro; linarith
        refine ⟨by positivity, ?_, ?_, n_odd.mul (hp_prime.odd_of_ne_two (fun h => by rw [h] at hp_div; norm_num at hp_div))⟩
        · rw [Nat.primeFactors_mul n_pos.ne' hp_prime.ne_zero, n_card]
          simp [p_new, hp_prime]
        · have h_div_p : p ∣ 2 ^ (n * p) + 1 := p_div_n_plus_one.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) (hp_prime.odd_of_ne_two (fun h => by rw [h] at hp_div; norm_num at hp_div)))
          have h_div_n : n ∣ 2 ^ (n * p) + 1 := n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) (hp_prime.odd_of_ne_two (fun h => by rw [h] at hp_div; norm_num at hp_div)))
          exact Nat.coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n p hp_prime (by linarith [Nat.Prime.one_lt hp_prime])) h_div_n h_div_p
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
