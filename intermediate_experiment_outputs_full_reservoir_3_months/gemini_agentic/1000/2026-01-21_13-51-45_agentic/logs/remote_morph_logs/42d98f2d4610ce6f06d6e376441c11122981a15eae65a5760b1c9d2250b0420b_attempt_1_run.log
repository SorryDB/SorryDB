          rw [Nat.primeFactors_prime (by norm_num : Nat.Prime 19)]
          simp
        constructor
        · have h_dvd1 : 171 ∣ 2^9 + 1 := by norm_num
          have h_dvd2 : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact_mod_cast dvd_pow_add_pow_of_odd (2 ^ 9 : ℤ) (1 : ℤ) (by norm_num : Odd 19)
          exact h_dvd1.trans h_dvd2
        · norm_num
