import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 9
        constructor; · norm_num
        constructor
        · have h9 : 9 = 3^2 := by norm_num
          rw [h9, Nat.primeFactors_pow 3 (by norm_num), Nat.primeFactors_prime Nat.prime_three]
          simp
        constructor; · norm_num
        · norm_num
      else
        have n_ge_9 : n ≥ 9 := by
          have : n.primeFactors.card ≥ 1 := by omega
          have h_odd : Odd n := n_odd
          have : n > 1 := by
            intro h_one; subst h_one; norm_num at n_card; omega
          have : n ≥ 3 := by
            rcases n with (_ | _ | _ | m) <;> omega
          if hn : n = 3 then
            norm_num [hn, Nat.primeFactors_prime Nat.prime_three] at n_card
            omega
          else if hn : n = 5 then
             norm_num [hn, Nat.primeFactors_prime (by norm_num : Nat.Prime 5)] at n_card
             omega
          else if hn : n = 7 then
             norm_num [hn, Nat.primeFactors_prime (by norm_num : Nat.Prime 7)] at n_card
             omega
          else
            omega
        obtain ⟨p, p_prime, p_dvd_2n, p_min⟩ := Nat.exists_prime_factor_pow_sub_one 2 (2 * n) (by norm_num) (by linarith) (by
          rw [Nat.isZsigmondyException_two]; linarith)
        use n * p
        have p_odd : Odd p := p_prime.odd_of_ne_two (λ hp2 => by
          subst hp2; have := Nat.dvd_of_mod_eq_zero p_dvd_2n; norm_num at this)
        have p_dvd_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_dvd_2n
          exact (p_prime.dvd_or_dvd this).resolve_left (λ h => p_min n (by linarith) (by exact_mod_cast h))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_dvd_2n
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_min m hm
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one p_prime (λ h => by
            rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; norm_num at h; exact p_prime.not_dvd_one h)
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors_mul n_pos.ne' p_prime.ne_zero, Nat.primeFactors_prime p_prime,
            Finset.card_union_of_disjoint, n_card, Finset.card_singleton]
          · rw [Finset.disjoint_singleton_right]
            intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
        constructor
        · have h1 : n ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n ≡ -1 [MOD n] := Nat.modEq_zero_iff_dvd.mpr n_div
            have : (2 ^ n) ^ p ≡ (-1 : ℤ) ^ p [ZMOD n] := by
              have : (2 ^ n : ℤ) ≡ -1 [ZMOD n] := by
                rw [Int.modEq_iff_add_dvd]; simp; exact_mod_cast n_div
              exact Int.ModEq.pow p this
            have : (2 ^ n : ℤ) ^ p ≡ -1 [ZMOD n] := by
              rwa [Int.neg_one_pow_eq_or p] at this; cases this <;> omega
            rw [← Nat.pow_mul]
            exact_mod_cast Int.modEq_iff_add_dvd.mp (by rwa [Int.neg_one_pow_eq_or p]; cases p_odd <;> simp)
          have h2 : p ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n ≡ -1 [MOD p] := Nat.modEq_zero_iff_dvd.mpr p_dvd_pow_plus_one
            have : (2 ^ n) ^ p ≡ (-1 : ℤ) ^ p [ZMOD p] := by
              have : (2 ^ n : ℤ) ≡ -1 [ZMOD p] := by
                rw [Int.modEq_iff_add_dvd]; simp; exact_mod_cast p_dvd_pow_plus_one
              exact Int.ModEq.pow p this
            have : (2 ^ n : ℤ) ^ p ≡ -1 [ZMOD p] := by
              rwa [Int.neg_one_pow_eq_or p] at this; cases this <;> omega
            rw [← Nat.pow_mul]
            exact_mod_cast Int.modEq_iff_add_dvd.mp (by rwa [Int.neg_one_pow_eq_or p]; cases p_odd <;> simp)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) h1 h2
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

