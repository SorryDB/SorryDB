import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3
        constructor; · norm_num
        constructor; · simp [Nat.primeFactors, Nat.factorization_prime Nat.prime_three]
        constructor; · norm_num
        · norm_num
      else if hk1 : k = 1 then
        use 171
        constructor; · norm_num
        constructor
        · have h171 : 171 = 3^2 * 19 := by norm_num
          have h3 : Nat.Prime 3 := Nat.prime_three
          have h19 : Nat.Prime 19 := by norm_num
          simp [h171, Nat.primeFactors, Nat.factorization_mul (by norm_num) (by norm_num),
            Nat.factorization_pow, Nat.Prime.factorization h3, Nat.Prime.factorization h19]
          rw [Finset.card_insert_of_not_mem]; · simp; · simp
        constructor
        · have h_dvd : 171 ∣ 2^9 + 1 := by norm_num
          have h_pow : (2^9 : ℤ) ^ 19 ≡ (-1 : ℤ) ^ 19 [ZMOD 171] := by
            apply Int.ModEq.pow
            rw [Int.modEq_iff_dvd]; simp; exact_mod_cast h_dvd
          rw [← Nat.pow_mul, Int.modEq_iff_dvd] at h_pow
          norm_num at h_pow; exact_mod_cast h_pow
        · norm_num
      else
        have n_gt_3 : 3 < n := by
          have h_card : 2 ≤ n.primeFactors.card := by omega
          have : ∃ p ∈ n.primeFactors, ∃ q ∈ n.primeFactors, p ≠ q := by
            simpa [Finset.one_lt_card_iff] using h_card
          obtain ⟨p, hp, q, hq, hpq⟩ := this
          have p_prime : p.Prime := Nat.prime_of_mem_primeFactors hp
          have q_prime : q.Prime := Nat.prime_of_mem_primeFactors hq
          have p_odd : Odd p := n_odd.odd_of_dvd (Nat.dvd_of_mem_primeFactors hp)
          have q_odd : Odd q := n_odd.odd_of_dvd (Nat.dvd_of_mem_primeFactors hq)
          have p_ge_3 : 3 ≤ p := p_prime.three_le p_odd
          have q_ge_3 : 3 ≤ q := q_prime.three_le q_odd
          have : 3 * 5 ≤ p * q ∨ 5 * 3 ≤ p * q := by
            if hp3 : p = 3 then
              have q_ge_5 : 5 ≤ q := q_prime.five_le q_odd.ne_two (by linarith)
              left; linarith
            else
              have p_ge_5 : 5 ≤ p := p_prime.five_le p_odd.ne_two (by linarith)
              right; linarith
          have : p * q ∣ n := Nat.mul_dvd_of_coprime (Nat.Prime.coprime_iff_ne p_prime q_prime).mpr (Nat.dvd_of_mem_primeFactors hp) (Nat.dvd_of_mem_primeFactors hq)
          have : p * q ≤ n := Nat.le_of_dvd n_pos this
          linarith
        have h_ex : ¬Nat.IsZsigmondyException 2 (2 * n) := by
          rw [Nat.isZsigmondyException_two]; linarith
        obtain ⟨p, p_prime, p_dvd_2n, p_min⟩ := Nat.exists_prime_factor_pow_sub_one 2 (2 * n) (by norm_num) (by linarith) h_ex
        use n * p
        have p_odd : Odd p := p_prime.odd_of_ne_two (λ hp2 => by subst hp2; norm_num at p_dvd_2n)
        have p_dvd_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_dvd_2n
          apply (p_prime.dvd_or_dvd this).resolve_left
          intro h_dvd
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_dvd_2n
            · intro m hm h_m_dvd; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm h_m_dvd
          have : 2 * n ∣ n := h_ord ▸ orderOf_dvd_iff_pow_eq_one.mpr (by rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast h_dvd)
          linarith
        have p_gt_n : p > n := by
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one p_prime (by
            intro h; rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; norm_num at h; exact p_prime.not_dvd_one h)
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_dvd_2n
            · intro m hm h_m_dvd; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm h_m_dvd
          have : 2 * n ∣ p - 1 := h_ord ▸ orderOf_dvd_of_pow_eq_one h_flt
          have : 2 * n ≤ p - 1 := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors, Nat.factorization_mul n_pos.ne' p_prime.ne_zero, Nat.Prime.factorization p_prime, Finsupp.support_add_eq_union]
          · rw [Finset.card_union_of_disjoint, n_card, Finset.card_singleton]
            · rw [Finset.disjoint_singleton_right]
              intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
          · rw [Finsupp.support_single_ne_zero p_prime.ne_zero.ne', Finset.disjoint_singleton_right]
            intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
        constructor
        · have h1 : n ∣ 2 ^ (n * p) + 1 := by
            have : (2 ^ n : ℤ) ≡ -1 [ZMOD n] := by rw [Int.modEq_iff_dvd]; simp; exact_mod_cast n_div
            have h_pow : (2 ^ n : ℤ) ^ p ≡ (-1 : ℤ) ^ p [ZMOD n] := Int.ModEq.pow p this
            rw [← Nat.pow_mul, Int.modEq_iff_dvd, p_odd.neg_one_pow] at h_pow; exact_mod_cast h_pow
          have h2 : p ∣ 2 ^ (n * p) + 1 := by
            have : (2 ^ n : ℤ) ≡ -1 [ZMOD p] := by rw [Int.modEq_iff_dvd]; simp; exact_mod_cast p_dvd_pow_plus_one
            have h_pow : (2 ^ n : ℤ) ^ p ≡ (-1 : ℤ) ^ p [ZMOD p] := Int.ModEq.pow p this
            rw [← Nat.pow_mul, Int.modEq_iff_dvd, p_odd.neg_one_pow] at h_pow; exact_mod_cast h_pow
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) h1 h2
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, _⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

```
