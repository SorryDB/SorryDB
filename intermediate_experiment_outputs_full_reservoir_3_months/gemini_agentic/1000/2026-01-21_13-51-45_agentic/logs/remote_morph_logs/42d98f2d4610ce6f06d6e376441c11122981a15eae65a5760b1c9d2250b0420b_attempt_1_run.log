import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
      if hk0 : k = 0 then
        use 3; constructor; · norm_num
        constructor
        · rw [Nat.primeFactors_prime (by norm_num)]; simp
        · norm_num
      else if hk1 : k = 1 then
        use 171; constructor; · norm_num
        constructor
        · have h171 : 171 = 3^2 * 19 := by norm_num
          rw [h171, Nat.primeFactors_mul (by norm_num) (by norm_num),
            Nat.primeFactors_prime (by norm_num), Nat.primeFactors_pow 3 (by norm_num),
            Nat.primeFactors_prime (by norm_num : Nat.Prime 19)]
          rfl
        · have h9 : 9 ∣ 2^9 + 1 := by norm_num
          have h19 : 19 ∣ 2^9 + 1 := by norm_num
          have h171 : 171 ∣ 2^9 + 1 := Nat.Coprime.mul_dvd_of_dvd_of_dvd (by norm_num) h9 h19
          have hpow : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact_mod_cast (add_dvd_pow_add_pow (2^9 : ℤ) 1 (by norm_num : Odd 19))
          exact h171.trans hpow
      else
        have n_gt_3 : 3 < n := by
          have : n.primeFactors.card = k := n_card
          have : k ≥ 2 := by omega
          have : n.primeFactors.card ≥ 2 := by omega
          have h_odd : Odd n := by
            apply Nat.odd_iff.mpr
            have : (2^n + 1) % 2 = 1 := by
              rw [Nat.add_mod, Nat.pow_mod]
              norm_num
              cases n <;> norm_num
            exact Nat.mod_one_of_dvd n_pos this
          have : ∃ p q, p ∈ n.primeFactors ∧ q ∈ n.primeFactors ∧ p ≠ q := by
            simpa [Finset.one_lt_card_iff] using (by omega : 1 < n.primeFactors.card)
          obtain ⟨p, q, hp, hq, hpq⟩ := this
          have hp_prime : p.Prime := Nat.prime_of_mem_primeFactors hp
          have hq_prime : q.Prime := Nat.prime_of_mem_primeFactors hq
          have hp_odd : Odd p := hp_prime.odd_of_ne_two (λ h => by
            have : 2 ∣ n := by rw [← h]; exact Nat.dvd_of_mem_primeFactors hp
            have : ¬ 2 ∣ n := Nat.odd_iff.not.mpr (Nat.odd_iff.mp h_odd)
            contradiction)
          have hq_odd : Odd q := hq_prime.odd_of_ne_two (λ h => by
            have : 2 ∣ n := by rw [← h]; exact Nat.dvd_of_mem_primeFactors hq
            have : ¬ 2 ∣ n := Nat.odd_iff.not.mpr (Nat.odd_iff.mp h_odd)
            contradiction)
          have : n ≥ p * q := Nat.mul_dvd_le n_pos.ne' (Nat.mul_dvd_of_coprime (Nat.Prime.coprime_iff_ne hp_prime hq_prime).mpr (Nat.dvd_of_mem_primeFactors hp) (Nat.dvd_of_mem_primeFactors hq))
          have hp_ge_3 : p ≥ 3 := hp_prime.three_le hp_odd
          have hq_ge_3 : q ≥ 3 := hq_prime.three_le hq_odd
          have : p * q ≥ 3 * 5 := by
            if h : p < q then
              have : q ≥ 5 := hq_prime.five_le (hq_prime.odd_of_ne_two (by intro hq2; linarith))
              linarith
            else
              have : p > q := by linarith
              have : p ≥ 5 := hp_prime.five_le (hp_prime.odd_of_ne_two (by intro hp2; linarith))
              linarith
          linarith
        obtain ⟨p, p_prime, p_dvd, h_order⟩ := Nat.exists_prime_factor_pow_sub_one 2 (2 * n) (by norm_num) (by linarith) (by
          rw [Nat.isZsigmondyException_two]; linarith)
        use n * p
        have p_odd : Odd p := p_prime.odd_of_ne_two (λ hp2 => by subst hp2; norm_num at p_dvd)
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_dvd
          exact (p_prime.dvd_or_dvd this).resolve_left (λ h => h_order n (by linarith) (by exact_mod_cast h))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_dvd
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast h_order m hm
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one p_prime (λ h => by
            rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; norm_num at h; exact p_prime.not_dvd_one h)
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors_mul n_pos.ne' p_prime.ne_zero, Nat.primeFactors_prime p_prime,
            Finset.card_union_of_disjoint, n_card, Finset.card_singleton]
          · rw [Finset.disjoint_singleton_right]
            intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
        constructor
        · have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact_mod_cast (add_dvd_pow_add_pow (2^n : ℤ) 1 p_odd)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (p_prime.coprime_iff_not_dvd.mpr (by linarith)) (n_div.trans this) (p_div_pow_plus_one.trans this)
  obtain ⟨n, n_pos, n_card, n_div⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
```
