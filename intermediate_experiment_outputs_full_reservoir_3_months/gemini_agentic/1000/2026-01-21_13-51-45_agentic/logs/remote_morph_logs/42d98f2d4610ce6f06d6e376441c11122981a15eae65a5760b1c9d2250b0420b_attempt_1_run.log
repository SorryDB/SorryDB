import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n by
    obtain ⟨n, h⟩ := this 2000; exact ⟨n, h.1, h.2.1, h.2.2.1⟩
  intro k
  induction' k with k ih
  · use 1; simp [Odd]
  · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
    if h1 : n = 1 then
      use 3; simp [h1, n_card, Odd]; norm_num
    else if h3 : n = 3 then
      use 171; simp [n_card, h3]
      refine ⟨by norm_num, ?_, ?_, by norm_num⟩
      · have : 171 = 3^2 * 19 := by norm_num
        rw [this, Nat.primeFactors_mul (by norm_num) (by norm_num), Nat.primeFactors_pow (by norm_num) (by norm_num)]
        rw [Nat.primeFactors_of_prime (by norm_num : Nat.Prime 3), Nat.primeFactors_of_prime (by norm_num : Nat.Prime 19)]
        simp
      · have : 171 = 9 * 19 := by norm_num
        rw [this]
        apply Nat.Coprime.mul_dvd_of_dvd_of_dvd (by norm_num)
        · exact Nat.dvd_trans (by norm_num : 9 ∣ 2^9 + 1) (Nat.pow_plus_one_dvd_pow_plus_one (2^9) (by norm_num))
        · exact Nat.dvd_trans (by norm_num : 19 ∣ 2^9 + 1) (Nat.pow_plus_one_dvd_pow_plus_one (2^9) (by norm_num))
    else
      have h_2n_gt : 2 * n > 6 := by
        have : n ≠ 0 := n_pos.ne'
        have : n ≠ 1 := h1
        have : n ≠ 2 := n_odd.ne_two
        have : n ≠ 3 := h3
        have : n ≠ 4 := by intro h; rw [h] at n_odd; norm_num at n_odd
        omega
      obtain ⟨p, hp_prime, hp_div, hp_min⟩ := Zsigmondy.exists_prime_factor_pow_sub_one 2 1 (2 * n) (by norm_num) (by norm_num) Nat.coprime_one_right (by linarith) (by linarith) (by linarith)
      have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
        have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← sq_sub_one, ← pow_mul]; exact hp_div
        exact (hp_prime.dvd_or_dvd this).resolve_left (hp_min n (by linarith))
      have p_odd : Odd p := hp_prime.odd_of_ne_two (fun hp2 => by
        have : p ∣ 2 ^ n + 1 := p_div_pow_plus_one
        rw [hp2] at this
        have : Even (2 ^ n + 1) := Nat.even_iff_2_dvd.mpr this
        have : Odd (2 ^ n + 1) := (Nat.even_pow.mpr ⟨even_two, n_pos.ne'⟩).add_odd Odd.one
        exact Nat.odd_iff_not_even.mp this ‹Even (2 ^ n + 1)›)
      have p_gt_n : p > n := by
        have h_ord : orderOf (2 : ZMod p) = 2 * n := by
          apply orderOf_eq_of_pow_and_forall_lt_pow (ZMod.pow_eq_one_iff_dvd.mpr hp_div)
          intro m hm; rw [ZMod.pow_eq_one_iff_dvd]; exact hp_min m hm
        have : 2 * n ∣ p - 1 := by rw [← h_ord]; apply orderOf_dvd_card_sub_one
        have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [hp_prime.one_lt]) this
        linarith
      use n * p
      refine ⟨by positivity, ?_, ?_, n_odd.mul p_odd⟩
      · rw [Nat.primeFactors_mul n_pos.ne' hp_prime.ne_zero, Nat.primeFactors_of_prime hp_prime, n_card]
        rw [Finset.card_insert_of_not_mem]
        intro h_mem; have : p ∣ n := Nat.mem_primeFactors.mp h_mem |>.2
        linarith [Nat.le_of_dvd n_pos this]
      · have h1 : n ∣ 2 ^ (n * p) + 1 := n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
        have h2 : p ∣ 2 ^ (n * p) + 1 := p_div_pow_plus_one.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
        exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n p hp_prime p_gt_n) h1 h2

```
