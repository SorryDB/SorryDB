import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
      if hk0 : k = 0 then
        use 3; constructor; · norm_num
        constructor; · simp [Nat.primeFactors, Nat.factorization_prime Nat.prime_three]
        · norm_num
      else if hk1 : k = 1 then
        use 171; constructor; · norm_num
        constructor; · norm_num [Nat.primeFactors, Nat.factorization_mul, Nat.factorization_pow, Nat.factorization_prime]
        · have h1 : 171 ∣ 2^9 + 1 := by norm_num
          have h2 : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact_mod_cast (Odd.add_dvd_pow_add_pow (2^9 : ℤ) 1 (by norm_num : Odd 19))
          exact h1.trans h2
      else
        have n_odd : Odd n := by
          apply Nat.odd_iff.mpr
          have : (2 ^ n + 1) % 2 = 1 := by
            rw [Nat.add_mod, Nat.pow_mod]
            norm_num; cases n <;> norm_num
          exact Nat.mod_one_of_dvd n_pos (n_div.trans_mod this)
        have h_zsig : ∃ p, Nat.Prime p ∧ p ∣ 2 ^ (2 * n) - 1 ∧ ∀ m < 2 * n, m ∣ 2 * n → ¬p ∣ 2 ^ m - 1 := by
          sorry
        obtain ⟨p, p_prime, p_dvd_2n, p_min⟩ := h_zsig
        use n * p
        have p_odd : Odd p := p_prime.odd_of_ne_two (λ hp2 => by subst hp2; norm_num at p_dvd_2n)
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_dvd_2n
          exact (p_prime.dvd_or_dvd this).resolve_left (λ h => p_min n (by linarith) (by exact_mod_cast h))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_dvd_2n
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact_mod_cast p_min m (Nat.gcd_dvd_right m (2 * n))
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one p_prime (λ h => by
            rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; norm_num at h; exact p_prime.not_dvd_one h)
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · simp [Nat.primeFactors, Nat.factorization_mul n_pos.ne' p_prime.ne_zero, Nat.Prime.factorization p_prime]
          rw [Finset.card_union_of_disjoint, n_card, Finset.card_singleton]
          rw [Finset.disjoint_singleton_right]
          intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
        constructor
        · have h1 : n ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact_mod_cast (Odd.add_dvd_pow_add_pow (2^n : ℤ) 1 p_odd).trans_left (by exact_mod_cast n_div)
          have h2 : p ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact_mod_cast (Odd.add_dvd_pow_add_pow (2^n : ℤ) 1 p_odd).trans_left (by exact_mod_cast p_div_pow_plus_one)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) h1 h2
  obtain ⟨n, n_pos, n_card, n_div⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

