import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp [Odd]
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor; · rw [Nat.Prime.primeFactors_eq_singleton Nat.prime_three]; simp
        constructor; · norm_num
        norm_num
      else if hk1 : k = 1 then
        use 171
        have h171 : 171 = 9 * 19 := by norm_num
        constructor; · norm_num
        constructor
        · rw [h171, Nat.primeFactors_mul (by norm_num) (by norm_num)]
          rw [Nat.primeFactors_pow (by norm_num) (by norm_num), Nat.Prime.primeFactors_eq_singleton Nat.prime_three]
          rw [Nat.Prime.primeFactors_eq_singleton (by norm_num)]
          simp
        constructor
        · rw [h171]; apply Nat.Coprime.mul_dvd_of_dvd_of_dvd (by norm_num)
          · exact (by norm_num : 9 ∣ 2^9+1).trans (Nat.pow_plus_one_dvd_pow_plus_one 2 (Nat.dvd_mul_right 9 19) (by norm_num))
          · exact (by norm_num : 19 ∣ 2^9+1).trans (Nat.pow_plus_one_dvd_pow_plus_one 2 (Nat.dvd_mul_right 9 19) (by norm_num))
        · norm_num
      else
        have h_n_ge_15 : n ≥ 15 := by
          have : n.primeFactors.card ≥ 2 := by rw [n_card]; exact Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero hk1)
          obtain ⟨p1, h1, p2, h2, hne⟩ := Finset.one_lt_card_iff.mp this
          have p1_prime := (Nat.mem_primeFactors.mp h1).1
          have p2_prime := (Nat.mem_primeFactors.mp h2).1
          have p1_odd := n_odd.odd_of_dvd (Nat.mem_primeFactors.mp h1).2.1
          have p2_odd := n_odd.odd_of_dvd (Nat.mem_primeFactors.mp h2).2.1
          have p1_ge_3 := p1_prime.three_le p1_odd.ne_two
          have p2_ge_3 := p2_prime.three_le p2_odd.ne_two
          have h_coprime : p1.Coprime p2 := (p1_prime.coprime_iff_not_dvd p2_prime.ne_one).mpr (p2_prime.not_dvd_iff_ne.mpr hne.symm)
          have : p1 * p2 ∣ n := Nat.Coprime.mul_dvd_of_dvd_of_dvd h_coprime (Nat.mem_primeFactors.mp h1).2.1 (Nat.mem_primeFactors.mp h2).2.1
          have h_prod : p1 * p2 ≥ 15 := by
            cases p1_prime.eq_or_lt_of_le p1_ge_3 with
            | h1 => subst h1; have : p2 ≥ 5 := p2_prime.five_le_of_ne_two_of_ne_three p2_odd.ne_two (by intro h; subst h; exact hne rfl); linarith
            | h2 => have : p1 ≥ 5 := p1_prime.five_le_of_ne_two_of_ne_three p1_odd.ne_two (by linarith); linarith
          exact Nat.le_trans h_prod (Nat.le_of_dvd n_pos this)
        obtain ⟨p, hp_prime, hp_div, hp_min⟩ :=
          Zsigmondy.exists_prime_factor 2 1 (2 * n) (by norm_num) (by norm_num)
            Nat.coprime_one_right (by linarith) (by simp [Zsigmondy.IsException]; linarith)
        use n * p
        have p_odd : Odd p := hp_prime.odd_of_ne_two (fun h => by subst h; norm_num at hp_div)
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← sq_sub_one, ← pow_mul]; exact hp_div
          exact (hp_prime.dvd_or_dvd this).resolve_left (hp_min n (by linarith))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (ZMod.pow_eq_one_iff_dvd.mpr hp_div)
            intro m hm; rw [ZMod.pow_eq_one_iff_dvd]; exact hp_min m hm
          have : 2 * n ∣ p - 1 := by rw [← h_ord]; apply orderOf_dvd_card_sub_one
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [hp_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors_mul n_pos.ne' hp_prime.ne_zero, n_card, Nat.Prime.primeFactors_eq_singleton hp_prime]
          rw [Finset.card_insert_of_not_mem]
          · intro h; have := Nat.le_of_dvd n_pos (Nat.mem_primeFactors.mp h).2.1; linarith
        constructor
        · have h1 : n ∣ 2 ^ (n * p) + 1 := n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one 2 (Nat.dvd_mul_right n p) p_odd)
          have h2 : p ∣ 2 ^ (n * p) + 1 := p_div_pow_plus_one.trans (Nat.pow_plus_one_dvd_pow_plus_one 2 (Nat.dvd_mul_right n p) p_odd)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n hp_prime) h1 h2
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
