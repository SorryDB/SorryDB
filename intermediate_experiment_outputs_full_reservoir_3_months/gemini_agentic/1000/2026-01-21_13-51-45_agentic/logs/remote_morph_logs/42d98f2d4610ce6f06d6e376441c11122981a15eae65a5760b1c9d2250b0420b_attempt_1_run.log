import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction k with
    | zero => use 1; simp [Odd]
    | succ k ih =>
      obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      by_cases h1 : n = 1
      · use 3; simp [h1, Odd]; constructor; rfl; decide
      · by_cases h3 : n = 3
        · use 171; simp [h3, n_card, Odd]; constructor; rfl; decide
        · have h_gt : 1 < 2 * n := by linarith
          have h_n6 : 2 * n ≠ 6 := by
            intro hn; apply h3; linarith
          obtain ⟨p, hp_prime, hp_order⟩ := Nat.exists_prime_factor_order_eq h_gt h_n6
          use n * p
          have p_pos : 0 < p := hp_prime.pos
          have p_odd : Odd p := by
            refine hp_prime.odd_of_ne_two ?_
            intro hp2; rw [hp2] at hp_order
            have : orderOf (2 : ZMod 2) = 0 := by
              rw [orderOf_eq_zero_iff]
              intro h; simp [ZMod.ext_iff] at h
            rw [this] at hp_order; linarith
          have p_div_2n : (2 : ZMod p) ^ (2 * n) = 1 := by
            rw [← hp_order, ZMod.pow_orderOf_eq_one]
          have p_not_div_n : (2 : ZMod p) ^ n ≠ 1 := by
            rw [← hp_order]; apply orderOf_not_dvd; linarith
          have p_div_pow_plus_one : (2 : ZMod p) ^ n = -1 := by
            have : ((2 : ZMod p) ^ n - 1) * ((2 : ZMod p) ^ n + 1) = 0 := by
              rw [← sq_sub_one, ← pow_mul]; exact sub_eq_zero.mpr p_div_2n
            cases' (ZMod.prime_iff_isDomain.mp hp_prime).mul_eq_zero.mp this with h h
            · contradiction
            · exact add_eq_zero_iff_eq_neg.mp h
          have p_new : p ∉ n.primeFactors := by
            have : 2 * n ∣ p - 1 := by rw [← hp_order]; apply orderOf_dvd_card_sub_one
            have : p > n := by linarith [Nat.prime.one_lt hp_prime]
            simp [Nat.mem_primeFactors, n_pos.ne']; intro; linarith
          refine ⟨by positivity, ?_, ?_, n_odd.mul p_odd⟩
          · rw [Nat.primeFactors_mul n_pos.ne' p_pos.ne', n_card]
            simp [p_new, hp_prime]
          · have h_div_p : p ∣ 2 ^ (n * p) + 1 := by
              have : p ∣ 2 ^ n + 1 := by
                rw [← ZMod.natCast_zmod_eq_zero_iff_dvd, Nat.cast_add, Nat.cast_pow, Nat.cast_one]
                exact add_eq_zero_iff_eq_neg.mpr p_div_pow_plus_one
              exact this.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
            have h_div_n : n ∣ 2 ^ (n * p) + 1 :=
              n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one (2 ^ n) p_odd)
            exact Nat.dvd_trans (Nat.coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n p hp_prime (by linarith)) h_div_n h_div_p) (by rfl)
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

