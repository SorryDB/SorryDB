    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor; · rw [Nat.primeFactors_prime Nat.prime_three]; simp
        constructor; · norm_num
        norm_num
      else if hk1 : k = 1 then
        use 171
        have h171 : 171 = 3^2 * 19 := by norm_num
        constructor; · norm_num
        constructor
        · rw [h171, Nat.primeFactors_mul (by norm_num) (by norm_num)]
