import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor
        · ext q; rw [Nat.mem_primeFactors, (by norm_num : 3 ≠ 0)]; simp [Nat.prime_three]
          constructor
          · rintro ⟨hq_p, hq_dvd⟩; exact (Nat.prime_three.dvd_iff_eq hq_p).mp hq_dvd
          · intro hq; subst hq; exact ⟨Nat.prime_three, dvd_rfl⟩
        constructor; · norm_num
        norm_num
      else if hk1 : k = 1 then
        use 171; constructor; · norm_num
        constructor
        · have : (171 : ℕ).primeFactors = {3, 19} := by
            ext q; rw [Nat.mem_primeFactors, show 171 = 3^2 * 19 by norm_num, (by norm_num : 3^2 * 19 ≠ 0), Nat.Prime.dvd_mul, Nat.Prime.dvd_pow_iff (by norm_num), Nat.mem_insert, Nat.mem_singleton]
            constructor
            · rintro ⟨hq_p, hq_dvd⟩; cases hq_dvd with | inl h => left; exact (Nat.prime_three.dvd_iff_eq hq_p).mp h | inr h => right; exact ((by norm_num : Nat.Prime 19).dvd_iff_eq hq_p).mp h
            · rintro (h | h); subst h; exact ⟨by norm_num, by left; exact dvd_rfl⟩; subst h; exact ⟨by norm_num, by right; exact dvd_rfl⟩
          rw [this]; rfl
        constructor
        · have h1 : 171 ∣ 2^9 + 1 := by norm_num
          have h2 : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact_mod_cast (Int.add_dvd_pow_add_pow (2^9 : ℤ) 1 (show Odd 19 by norm_num))
          exact h1.trans h2
        · norm_num
      else
        have h_n_gt_3 : n > 3 := by
          have : n.primeFactors.card = k := n_card
          have : k ≥ 2 := by omega
          have : n.primeFactors.card ≥ 2 := by omega
          have : n ≠ 0 ∧ n ≠ 1 ∧ n ≠ 2 ∧ n ≠ 3 := by
            constructor; · linarith
            constructor; · intro h; subst h; norm_num at n_card; linarith
            constructor; · intro h; subst h; norm_num at n_card; linarith
            intro h; subst h; have : (3 : ℕ).primeFactors.card = 1 := by
              ext q; rw [Nat.mem_primeFactors]; simp [Nat.prime_three]
              exact ⟨Nat.prime_three, dvd_rfl⟩
            rw [this] at n_card; linarith
          omega
        have h_ex : ¬Nat.IsZsigmondyException 2 (2 * n) := by
          rw [Nat.IsZsigmondyException]
          simp [show 2 * n ≠ 1 by linarith, show 2 * n ≠ 2 by linarith, show 2 * n ≠ 6 by linarith]
        obtain ⟨p, p_prime, p_div, p_min⟩ := Nat.exists_prime_factor_pow_sub_one (by norm_num) (by linarith) h_ex
        use n * p
        have p_odd : Odd p := by
          apply p_prime.odd_of_ne_two; intro hp2; subst hp2
          have : 2 ∣ 2 ^ (2 * n) - 1 := p_div
          norm_num at this
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_div
          exact (p_prime.dvd_or_dvd this).resolve_left (fun h => p_min n (by linarith) (by rw [ZMod.pow_eq_one_iff_dvd]; exact h))
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact p_div
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := by
            apply ZMod.pow_card_sub_one_eq_one p_prime
            intro h; rw [h] at p_div; norm_num at p_div
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · have p_nin_n : p ∉ n.primeFactors := by
            intro h_mem; have := Nat.le_of_dvd n_pos (Nat.mem_primeFactors.mp h_mem).2; linarith
          have h_mul : (n * p).primeFactors = insert p n.primeFactors := by
            ext q; rw [Nat.mem_primeFactors, (by positivity : n * p ≠ 0), Nat.Prime.dvd_mul, ← Nat.mem_primeFactors, Nat.mem_primeFactors, Nat.mem_singleton]
            constructor; · rintro ⟨hq_p, hq_dvd⟩; cases hq_dvd with | inl h => right; exact (p_prime.dvd_iff_eq hq_p).mp h | inr h => left; exact ⟨hq_p, h⟩
            · rintro (h | h); exact ⟨(Nat.mem_primeFactors.mp h).1, Or.inr (Nat.mem_primeFactors.mp h).2⟩; subst h; exact ⟨p_prime, Or.inl dvd_rfl⟩
          rw [h_mul, Finset.card_insert_of_not_mem p_nin_n, n_card]; rfl
        constructor
        · have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact_mod_cast (Int.add_dvd_pow_add_pow (2^n : ℤ) 1 p_odd)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) (n_div.trans this) (p_div_pow_plus_one.trans this)
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
