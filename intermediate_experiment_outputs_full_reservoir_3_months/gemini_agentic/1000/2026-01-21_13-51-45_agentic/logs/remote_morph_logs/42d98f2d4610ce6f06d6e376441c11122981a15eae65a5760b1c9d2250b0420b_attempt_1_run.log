import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor; · rw [Nat.primeFactors_prime Nat.prime_three]; simp
        constructor; · norm_num
        norm_num
      else if hk1 : k = 1 then
        use 171
        have h171 : 171 = 9 * 19 := by norm_num
        have h171p : 171 = 3^2 * 19 := by norm_num
        constructor; · norm_num
        constructor
        · rw [h171p, Nat.primeFactors_mul (by norm_num) (by norm_num)]
          rw [Nat.primeFactors_pow (by norm_num) (by norm_num), Nat.primeFactors_prime Nat.prime_three]
          rw [Nat.primeFactors_prime (by norm_num : Nat.Prime 19)]
          simp
        constructor
        · have h : 171 ∣ 2^9 + 1 := by norm_num
          have h_odd : Odd 19 := by norm_num
          have h_dvd : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [h171, Nat.pow_mul, ← Int.natAbs_dvd_natAbs_iff]
            push_cast; exact dvd_pow_add_pow_of_odd (2 ^ 9 : ℤ) (1 : ℤ) h_odd
          exact h.trans h_dvd
        · norm_num
      else
        have h_n_ne_3 : n ≠ 3 := by
          intro h; rw [h] at n_card; simp [Nat.primeFactors_prime Nat.prime_three] at n_card
          exact hk1 n_card
        have h_ex : ¬(2 * n = 2 ∧ IsPowerOfTwo (2 + 1)) ∧ ¬(2 = 2 ∧ 1 = 1 ∧ 2 * n = 6) := by
          constructor
          · simp [IsPowerOfTwo]; norm_num
          · simp [h_n_ne_3]
        obtain ⟨p, p_prime, p_div, p_min⟩ := Zsigmondy.exists_prime_factor (by norm_num) (by norm_num) (Nat.coprime_one_right 2) (by linarith [n_pos]) h_ex
        use n * p
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have h1 : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_div
          exact (p_prime.dvd_or_dvd h1).resolve_left (fun h2 => p_min n (by linarith) h2)
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith [p_prime.one_lt])
            · rw [ZMod.pow_eq_one_iff_dvd]; exact p_div
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm
          have h_dvd_p_sub_1 : 2 * n ∣ p - 1 := by
            rw [← h_ord]
            apply orderOf_dvd_of_pow_eq_one
            rw [ZMod.pow_eq_one_iff_dvd]
            exact Nat.mod_one_iff_dvd.mp (Nat.Prime.mod_pow_p_sub_one_eq_one p_prime (by norm_num; linarith [p_prime.one_lt]))
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) h_dvd_p_sub_1
          linarith
        have p_odd : Odd p := p_prime.odd_of_ne_two (fun h_eq_2 => by
          have : 2 ∣ 2 ^ (2 * n) - 1 := by rw [← h_eq_2]; exact p_div
          norm_num at this)
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors_mul n_pos.ne' p_prime.ne_zero, n_card, Nat.primeFactors_prime p_prime]
          rw [Finset.card_insert_of_not_mem]
          · intro h; have := Nat.le_of_dvd n_pos (Nat.mem_primeFactors.mp h).2; linarith
        constructor
        · have h_dvd_n : n ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
              rw [Nat.pow_mul, ← Int.natAbs_dvd_natAbs_iff]
              push_cast; exact dvd_pow_add_pow_of_odd (2 ^ n : ℤ) (1 : ℤ) p_odd
            exact n_div.trans this
          have h_dvd_p : p ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
              rw [Nat.pow_mul, ← Int.natAbs_dvd_natAbs_iff]
              push_cast; exact dvd_pow_add_pow_of_odd (2 ^ n : ℤ) (1 : ℤ) p_odd
            exact p_div_pow_plus_one.trans this
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) h_dvd_n h_dvd_p
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩
