import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  have h_exists : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 ∧ Odd n := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_div, n_odd⟩ := ih
      if hk : k = 0 then
        use 3; constructor; · norm_num
        constructor
        · rw [Nat.primeFactors, Nat.factorization_prime Nat.prime_three, Finsupp.support_single_ne_zero _ (by norm_num)]; simp
        constructor; · norm_num
        · norm_num
      else if hk1 : k = 1 then
        use 171; constructor; · norm_num
        constructor
        · have h171 : 171 = 3^2 * 19 := by norm_num
          rw [Nat.primeFactors, h171, Nat.factorization_mul (by norm_num) (by norm_num),
            Nat.factorization_pow, Nat.factorization_prime Nat.prime_three,
            Nat.factorization_prime (by norm_num : Nat.Prime 19)]
          simp; rw [show ({3, 19} : Finset ℕ).card = 2 by rfl]; omega
        constructor
        · have h1 : 9 ∣ 2^9 + 1 := by norm_num
          have h2 : 19 ∣ 2^9 + 1 := by norm_num
          have h3 : 171 ∣ 2^9 + 1 := by
            apply Nat.dvd_of_mul_dvd_mul_left (show 0 < 1 by norm_num)
            rw [show 1 * 171 = 9 * 19 by norm_num]
            exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (by norm_num) h1 h2
          have h4 : 2^9 + 1 ∣ 2^171 + 1 := by
            rw [show 171 = 9 * 19 by norm_num, Nat.pow_mul]
            exact_mod_cast (Odd.add_dvd_pow_add_pow (2^9 : ℤ) 1 (show Odd 19 by norm_num))
          exact h3.trans h4
        · norm_num
      else
        have h_n_ge_15 : n ≥ 15 := by
          have : n.primeFactors.card = k := n_card
          have : k ≥ 2 := by omega
          have : n.primeFactors.card ≥ 2 := by omega
          have : ∃ p q, p ∈ n.primeFactors ∧ q ∈ n.primeFactors ∧ p ≠ q := by
            simpa [Finset.one_lt_card_iff] using (by omega : 1 < n.primeFactors.card)
          obtain ⟨p, q, hp, hq, hpq⟩ := this
          have hp_prime : p.Prime := Nat.prime_of_mem_primeFactors hp
          have hq_prime : q.Prime := Nat.prime_of_mem_primeFactors hq
          have hp_odd : Odd p := hp_prime.odd_of_ne_two (λ h => by
            have : 2 ∣ n := by rw [← h]; exact Nat.dvd_of_mem_primeFactors hp
            have : ¬ 2 ∣ n := Nat.odd_iff.mp n_odd
            contradiction)
          have hq_odd : Odd q := hq_prime.odd_of_ne_two (λ h => by
            have : 2 ∣ n := by rw [← h]; exact Nat.dvd_of_mem_primeFactors hq
            have : ¬ 2 ∣ n := Nat.odd_iff.mp n_odd
            contradiction)
          have hp_ge_3 : p ≥ 3 := hp_prime.three_le hp_odd
          have hq_ge_3 : q ≥ 3 := hq_prime.three_le hq_odd
          have : n ≥ p * q := Nat.mul_dvd_le n_pos.ne' (Nat.mul_dvd_of_coprime hp_prime.coprime_iff_ne.mpr (Nat.dvd_of_mem_primeFactors hp) (Nat.dvd_of_mem_primeFactors hq))
          have : p * q ≥ 3 * 5 := by
            if h : p < q then
              have : q ≥ 5 := hq_prime.five_le (hq_prime.odd_of_ne_two (by intro hq2; linarith))
              linarith
            else
              have : p > q := by linarith
              have : p ≥ 5 := hp_prime.five_le (hp_prime.odd_of_ne_two (by intro hp2; linarith))
              linarith
          linarith
        have h_ex : ¬Nat.IsZsigmondyException 2 (2 * n) := by
          rw [Nat.isZsigmondyException_two]; omega
        obtain ⟨p, p_prime, p_div, p_min⟩ := Nat.exists_prime_factor_pow_sub_one 2 (2 * n) (by norm_num) (by linarith) h_ex
        use n * p
        have p_odd : Odd p := p_prime.odd_of_ne_two (λ hp2 => by subst hp2; norm_num at p_div)
        have p_div_pow_plus_one : p ∣ 2 ^ n + 1 := by
          have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two_sub_one, ← Nat.pow_mul]; exact p_div
          exact (p_prime.dvd_or_dvd this).resolve_left (λ h => p_min n (by linarith) (by linarith) h)
        have p_gt_n : p > n := by
          have h_ord : orderOf (2 : ZMod p) = 2 * n := by
            apply orderOf_eq_of_pow_and_forall_lt_pow (by linarith)
            · rw [ZMod.pow_eq_one_iff_dvd]; exact p_div
            · intro m _ hm; rw [ZMod.pow_eq_one_iff_dvd]; exact p_min m hm (by linarith)
          have h_flt : (2 : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one p_prime (λ h => by
            rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; have := p_prime.one_lt; norm_num at h)
          have : 2 * n ∣ p - 1 := orderOf_dvd_of_pow_eq_one h_flt
          have : p - 1 ≥ 2 * n := Nat.le_of_dvd (by linarith [p_prime.one_lt]) this
          linarith
        constructor; · positivity
        constructor
        · rw [Nat.primeFactors, Nat.factorization_mul n_pos.ne' p_prime.ne_zero, Finsupp.support_add, Finset.card_union_of_disjoint]
          · rw [Nat.Prime.factorization_support p_prime, Finset.card_singleton, ← Nat.primeFactors, n_card]; omega
          · rw [Nat.Prime.factorization_support p_prime]; intro x; simp
            intro h; have := Nat.le_of_dvd n_pos (Nat.dvd_of_mem_primeFactors h); linarith
        constructor
        · have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
            rw [Nat.pow_mul]; exact_mod_cast (Odd.add_dvd_pow_add_pow (2^n : ℤ) 1 p_odd)
          exact Nat.Coprime.mul_dvd_of_dvd_of_dvd (Nat.coprime_of_lt_prime n_pos p_gt_n p_prime) (n_div.trans this) (p_div_pow_plus_one.trans this)
        · exact n_odd.mul p_odd
  obtain ⟨n, n_pos, n_card, n_div, -⟩ := h_exists 2000
  exact ⟨n, n_pos, n_card, n_div⟩

