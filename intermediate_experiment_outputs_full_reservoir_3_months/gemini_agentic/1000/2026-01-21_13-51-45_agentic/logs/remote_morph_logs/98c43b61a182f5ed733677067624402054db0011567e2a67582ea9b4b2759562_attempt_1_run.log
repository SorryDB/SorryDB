        exact mul_nonneg (sub_nonneg.2 (hc₁ i hi)) (hw₀ k (mem_erase.2 ⟨hki.symm, hk⟩))
      have := (sum_eq_one_iff_of_nonneg hW_pos).1 hW_sum hj
      rw [hWj1] at this
