theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def]
  apply Fintype.card_eq_zero_iff.mpr
  rw [isEmpty_iff]
  intro ⟨p, hp⟩
  have h_sum : ∑ i, (p i : Fin 8) = 4 := by
    rw [hE] at hp
    exact add_left_cancel hp
  let f : Fin 8 →+ ZMod 2 := {
    toFun := fun x => (x.val : ZMod 2),
    map_zero' := rfl,
    map_add' := fun x y => by
      apply ZMod.ext
      simp [ZMod.val_natCast, Fin.add_def, Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8)]
  }
  have h_pi : ∀ i, f (p i : Fin 8) = 1 := by
    intro i
    rcases Int.units_eq_one_or_neg_one (p i) with h | h
    · rw [h]; rfl
    · rw [h]; rfl
  have hf : f (∑ i, (p i : Fin 8)) = f 4 := by
    rw [h_sum]
  rw [map_sum] at hf
  simp [h_pi, Finset.sum_const, Finset.card_univ, Fintype.card_fin] at hf
  have h_odd : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by
    have : 2 * n - 1 = 2 * (n - 1) + 1 := by omega
    rw [this]
    simp
  have h_f4 : f 4 = 0 := rfl
  rw [h_odd, h_f4] at hf
  exact one_ne_zero hf
```
