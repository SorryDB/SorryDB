    rw [hE] at hp
    exact add_left_cancel hp
  let f : Fin 8 →+ ZMod 2 := {
    toFun := fun x => (x.val : ZMod 2),
    map_zero' := rfl,
    map_add' := fun x y => by
      simp only [Fin.add_def]
