theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def]
  apply Fintype.card_eq_zero_iff.mpr
  rw [isEmpty_iff]
  intro ⟨p, hp⟩
  have h_sum : ∑ i, (p i : Fin 8) = 4 := by
    rw [hE] at hp
    exact add_left_cancel hp
  let f : Fin 8 →+ ZMod 2 := {
    toFun := fun x => (x.val : ZMod 2),
    map_zero' := rfl,
    map_add' := fun x y => by
      simp [Fin.add_def]
      apply ZMod.int_cast_eq_int_cast_iff.mpr
      use -((x.val + y.val : ℕ) / 8 : ℤ) * 4
      push_cast
      simp
      rw [← Nat.mod_add_div (x.val + y.val) 8]
      simp
  }
  have h_pi : ∀ i, f (p i : Fin 8) = 1 := by
    intro i
    have h_unit : (p i : ℤ) = 1 ∨ (p i : ℤ) = -1 := Int.isUnit_iff.mp (p i).isUnit
    rcases h_unit with h | h
    · have : (p i : Fin 8) = 1 := by rw [h]; rfl
      rw [this]; rfl
    · have : (p i : Fin 8) = 7 := by rw [h]; rfl
      rw [this]; rfl
  have hf : f (∑ i, (p i : Fin 8)) = f 4 := by rw [h_sum]
  simp [map_sum, h_pi, Finset.sum_const, Finset.card_univ, Fintype.card_fin] at hf
  have h_odd : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by
    have h1 : 2 * n - 1 = 2 * (n - 1) + 1 := by omega
    rw [h1, Nat.cast_add, Nat.cast_mul]
    simp
  rw [h_odd] at hf
  exact one_ne_zero hf
