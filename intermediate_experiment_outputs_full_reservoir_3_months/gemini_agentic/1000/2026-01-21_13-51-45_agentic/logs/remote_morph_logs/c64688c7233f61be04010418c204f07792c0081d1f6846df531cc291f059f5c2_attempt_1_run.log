        rw [Nat.mod_eq_of_lt h2acc]
        have hx2acc : x.val + 2 * acc.val < p := by linarith
        rw [Nat.mod_eq_of_lt hx2acc]
        linarith
  have h_final := h_acc args.toList 0 hb'
  simp only [ZMod.val_zero, zero_add, one_mul] at h_final
  simp [List.foldl_toArray', h_final]
