  simp only [Exp.eval, bits2num, Vector.foldl]
  have hb' : ∀ x ∈ args.toList, x.val ≤ 1 := by
    intro x hx
    rw [Vector.mem_toList_iff] at hx
    rcases hx with ⟨i, rfl⟩
    have h := hb i.val i.isLt
    rcases h with h | h <;> simp [h, ZMod.val_zero, ZMod.val_one]
  let f := fun (acc : ZMod p) (b : ZMod p) => b + 2 * acc
  have h_acc : ∀ (L : List (ZMod p)) (acc : ZMod p), (∀ x ∈ L, x.val ≤ 1) →
    (L.foldl f acc).val < (acc.val + 1) * 2^L.length := by
    intro L; induction L with
    | nil => intro acc hx; simp only [List.foldl_nil, List.length_nil, Nat.pow_zero, Nat.mul_one, Nat.lt_succ_self]
