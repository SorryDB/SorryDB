lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  ¬e.eval.val < 2 ^ w → ¬(assert_bits args ∧ e = Exp.c (bits2num args)) := by
  intros w args e h; contrapose! h; rcases h with ⟨hb, rfl⟩
  simp only [Exp.eval, bits2num, Vector.foldl]
  let v := args.toArray
  have hb' (i : Fin v.size) : v[i].val ≤ 1 := by
    have h := Vector.all_eq_true.1 hb ⟨i.val, i.isLt.trans_eq (by simp)⟩
    simp [beq_iff_eq] at h; rcases h with h | h <;> simp [h, ZMod.val_zero, ZMod.val_one]
  have : v.foldl (fun acc b => b + 2 * acc) 0 |>.val < 2^v.size := by
    induction v using Array.induction_on with
    | h₁ => simp; apply Nat.zero_lt_one
    | h₂ bs b ih =>
      simp [Array.foldl_push, Array.size_push]; rw [ZMod.val_add, ZMod.val_mul, ZMod.val_nat_cast]
      apply Nat.lt_of_le_of_lt (Nat.mod_le _ p)
      apply Nat.lt_of_le_of_lt (Nat.mod_le _ p)
      specialize ih (fun i => hb' i.castSucc)
      have := hb' ⟨bs.size, by simp⟩
      linarith [pow_succ 2 bs.size]
  rw [show v.size = w from by simp] at this; exact this
