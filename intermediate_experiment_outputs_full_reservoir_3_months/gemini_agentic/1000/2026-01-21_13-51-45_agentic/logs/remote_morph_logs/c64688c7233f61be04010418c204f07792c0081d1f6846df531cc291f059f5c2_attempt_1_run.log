      apply ih.trans_le
      rw [Nat.mul_comm _ 2]; apply Nat.mul_le_mul_right
      have hx_val : x.val ≤ 1 := by
        have h := hx x (List.mem_cons_self x xs)
        rcases h with h | h <;> simp [h, ZMod.val_zero, ZMod.val_one]
      apply Nat.succ_le_of_lt
      by_cases hp : p < 2 * (acc.val + 1)
      · exact (ZMod.val_lt _).trans_le hp
