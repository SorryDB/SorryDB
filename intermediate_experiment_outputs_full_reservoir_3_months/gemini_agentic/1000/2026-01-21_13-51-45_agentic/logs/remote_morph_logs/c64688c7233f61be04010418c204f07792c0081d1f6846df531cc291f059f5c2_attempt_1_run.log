lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = Exp.c (bits2num args)) := by
  intros w args e h; contrapose! h; rcases h with ⟨hb, rfl⟩
  simp only [Exp.eval, bits2num, Vector.foldl]
  let f := fun (acc : ZMod p) (b : ZMod p) => b + 2 * acc
  have hb' : ∀ x ∈ args.toList, x = 0 ∨ x = 1 := by
    simpa [assert_bits, List.all_eq_true, beq_iff_eq] using hb
  have h_acc : ∀ (L : List (ZMod p)) (acc : ZMod p), (∀ x ∈ L, x = 0 ∨ x = 1) →
    (L.foldl f acc).val < 2^L.length + acc.val * 2^L.length := by
    intro L; induction L with
    | nil => intro acc hx; simp [Nat.pow_zero, Nat.mul_one, Nat.lt_add_one_self]
    | cons x xs ih =>
      intro acc hx
      specialize ih (x + 2 * acc) (fun y hy => hx y (List.mem_cons_of_mem x hy))
      apply ih.trans_le
      have hx_val : x.val ≤ 1 := by
        rcases hx x (List.mem_cons_self _ _) with rfl | rfl <;> simp [ZMod.val_zero, ZMod.val_one]
      have h_step : (x + 2 * acc).val ≤ 1 + 2 * acc.val := by
        apply (ZMod.val_add x (2 * acc)).trans
        apply Nat.add_le_add hx_val
        apply (ZMod.val_mul 2 acc).trans
        apply (Nat.mod_le _ _).trans
        apply Nat.mul_le_mul_right; apply Nat.mod_le
      simp only [List.length_cons, Nat.pow_succ, ← Nat.add_mul, Nat.one_mul]
      apply Nat.mul_le_mul_right
      rw [Nat.add_assoc, Nat.add_comm 2]; apply Nat.add_le_add_left
      rw [Nat.add_comm]; exact h_step
  have h_final := h_acc args.toList 0 hb'
  simpa [Vector.toList_length] using h_final
