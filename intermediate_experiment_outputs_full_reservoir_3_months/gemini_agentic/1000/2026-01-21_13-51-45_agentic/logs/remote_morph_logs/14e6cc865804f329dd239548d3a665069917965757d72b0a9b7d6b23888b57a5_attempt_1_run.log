def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N, hN, hx⟩
    have hBN : sSup (B N hN \ {x}) ≤ N := (sSup_mono (Set.diff_subset _ _)).trans (hB N hN).symm.le
    have : a ≤ sSup (B N hN \ {x}) := by
      have haN : a ≤ N := ha.trans ((le_sSup hx).trans (hB N hN).symm.le)
      have : a ≤ N ⊓ (sSup (B N hN \ {x}) ⊔ sSup (D.carrier \ {N})) := by
        refine le_inf haN (ha'.trans (sSup_le ?_))
        rintro y ⟨hy_mem, hy_ne_x⟩
        simp only [Set.mem_iUnion] at hy_mem
        rcases hy_mem with ⟨N', hN', hyB⟩
        obtain rfl | h_ne := Decidable.eq_or_ne N' N
        · exact le_sup_of_le_left (le_sSup ⟨hyB, hy_ne_x⟩)
        · exact le_sup_of_le_right (le_sSup_of_le ⟨hN', h_ne⟩ ((le_sSup hyB).trans (hB N' hN').symm.le))
      rwa [inf_sup_assoc_of_le hBN, (disjoint_iff_inf_le.mp (D.sSupIndep' hN)), sup_bot_eq] at this
    exact (disjoint_iff_inf_le.mp (hB' N hN hx)) (le_inf ha this)
