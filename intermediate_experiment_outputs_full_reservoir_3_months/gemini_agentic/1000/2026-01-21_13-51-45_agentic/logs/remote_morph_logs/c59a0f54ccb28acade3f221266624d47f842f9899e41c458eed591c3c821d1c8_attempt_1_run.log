    by_cases ε ∈ language.1
    case pos =>
      --Ignoriere den Fall ε ∈ L
      sorry
    case neg h_eps_not_in_language =>
      -- Forme um: Sprache ist kontextfrei
      have property := language.2
      simp [Language.is_context_free] at property
      cases property
      case intro nt property =>
