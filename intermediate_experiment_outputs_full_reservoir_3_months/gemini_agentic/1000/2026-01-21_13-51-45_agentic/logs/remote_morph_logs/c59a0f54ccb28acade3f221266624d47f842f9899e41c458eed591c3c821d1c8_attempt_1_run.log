          --Binärbaum) entfernt ist
          --• Also kann der Baum unterhalb dieses Vorkommens maximal 2|V| = n Blätter haben
          --(dies sind die Symbole in vwx)
          obtain ⟨u, v, w, x, y, h_z, h_vx, h_vwx, h_pump⟩ : ∃ (u v w x y : Word α),
            ↑z = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ 2 ^ (↑cfg_CNF).V.card ∧
            ∀ (k : ℕ), u * v ^ k * w * x ^ k * y ∈ ↑language := sorry
          exact ⟨u, v, w, x, y, h_z, h_vx, h_vwx, h_pump⟩
