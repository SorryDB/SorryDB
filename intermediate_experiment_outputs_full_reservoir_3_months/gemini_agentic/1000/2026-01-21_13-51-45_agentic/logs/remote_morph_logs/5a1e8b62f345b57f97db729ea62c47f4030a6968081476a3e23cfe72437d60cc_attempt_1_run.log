import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have h_app (L x) : Nat.ofDigits 2 (L ++ [x]) = Nat.ofDigits 2 L + x * 2^L.length := by
    induction L with | nil => simp [Nat.ofDigits] | cons y ys ih => simp [Nat.ofDigits, ih, Nat.pow_succ, mul_add, add_assoc]; ring
  have h_gn (n) (hn : n > 0) : g (2 * n) = g n := by
    simp [g, Nat.digits_def n hn, Nat.digits_def (2 * n) (by linarith)]; rw [h_app]; simp
  have h_go n : g (2 * n + 1) = g n + 2^(Nat.digits 2 n).length := by
    by_cases hn : n = 0 <;> simp [g, hn, Nat.digits_def, h_app]
  have h_L n (hn : n > 0) : (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 := by
    simp [Nat.digits_def n hn, Nat.digits_def (2 * n) (by linarith)]
  have h_Lo n : (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 := by
    by_cases hn : n = 0 <;> simp [Nat.digits_def, hn]
  have h_fg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on
    next n ih =>
      if hn1 : n = 1 then rw [hn1, h₁, h_go 0]; simp
      else if hn3 : n = 3 then rw [hn3, h₂, h_go 1]; simp [g, Nat.digits_def]
      else if he : n % 2 = 0 then
        have h_eq : n = 2 * (n / 2) := Nat.div_add_mod n 2 |>.symm.trans (by simp [he])
        rw [h_eq, h₃ (n / 2) (by linarith), ih (n / 2) (by linarith) (by linarith), h_gn (n / 2) (by linarith)]
      else if ho1 : n % 4 = 1 then
        let m := n / 4; have hm : n = 4 * m + 1 := Nat.div_add_mod n 4 |>.symm.trans (by simp [ho1])
        have hm_pos : m > 0 := by linarith
        rw [hm, h₄ m hm_pos, ih (2 * m + 1) (by linarith) (by linarith), ih m (by linarith) hm_pos, h_go (2 * m), h_gn m hm_pos, h_L m hm_pos, h_go m, h_go (2 * m), h_gn m hm_pos, h_L m hm_pos]; ring
      else if ho3 : n % 4 = 3 then
        let m := n / 4; have hm : n = 4 * m + 3 := Nat.div_add_mod n 4 |>.symm.trans (by simp [ho3])
        have hm_pos : m > 0 := by linarith
        rw [hm, h₅ m hm_pos, ih (2 * m + 1) (by linarith) (by linarith), ih m (by linarith) hm_pos, h_go (2 * m + 1), h_Lo (2 * m), h_gn m hm_pos, h_L m hm_pos, h_go m, h_go (2 * m + 1), h_Lo (2 * m), h_gn m hm_pos, h_L m hm_pos]; ring
      else
        have : n % 2 = 1 := Nat.mod_two_ne_zero_iff_mod_two_eq_one.1 (by linarith)
