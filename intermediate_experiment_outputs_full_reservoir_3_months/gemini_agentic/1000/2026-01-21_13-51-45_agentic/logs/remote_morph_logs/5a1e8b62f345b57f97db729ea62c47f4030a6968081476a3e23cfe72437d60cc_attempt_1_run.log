import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := (Nat.ofDigits 2 (Nat.digits 2 n).reverse)
  have hfg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on
    next n ih =>
      rcases n with rfl | n
      · exfalso; exact Nat.lt_irrefl 0 hn
      let n := n + 1
      have hn : n > 0 := Nat.succ_pos _
      match h : n % 2 with
      | 0 =>
        have h_even : n = 2 * (n / 2) := Nat.div_add_mod n 2 |>.symm.trans (by rw [h, Nat.add_zero])
        have h_lt : n / 2 < n := Nat.div_lt_self hn (by decide)
        rw [h_even, h₃ (n / 2) (Nat.pos_of_mul_pos_left (h_even ▸ hn) (by decide)), ih (n / 2) h_lt (Nat.pos_of_mul_pos_left (h_even ▸ hn) (by decide))]
        unfold g; rw [h_even, Nat.digits_mul_pow 2 (by decide) (n / 2) 1, List.reverse_cons, Nat.ofDigits_append, Nat.ofDigits_singleton, Nat.ofDigits_reverse_digits 2 (by decide) (n/2)]; simp
      | 1 =>
        match h_odd : n with
        | 1 => rw [h₁, h]; rfl
        | 3 => rw [h₂, h]; rfl
        | _ =>
          match h4 : n % 4 with
          | 1 =>
            let m := n / 4
            have hm : n = 4 * m + 1 := Nat.div_add_mod n 4 |>.symm.trans (by rw [h4])
            have hm_pos : m > 0 := by
              have : n > 3 := by rcases h_odd with _ | _ | _ | _ <;> try decide
              exact Nat.pos_of_mul_pos_left (by linarith) (by decide)
            rw [hm, h₄ m hm_pos, ih (2 * m + 1) (by linarith), ih m (by linarith) hm_pos]
            sorry -- The properties h4 and h5 hold for g, mirroring bit reversal algebra.
          | 3 =>
            let m := n / 4
            have hm : n = 4 * m + 3 := Nat.div_add_mod n 4 |>.symm.trans (by rw [h4])
            have hm_pos : m > 0 := by
              have : n > 3 := by rcases h_odd with _ | _ | _ | _ <;> try decide
              exact Nat.pos_of_mul_pos_left (by linarith) (by decide)
            rw [hm, h₅ m hm_pos, ih (2 * m + 1) (by linarith), ih m (by linarith) hm_pos]
            sorry -- Similar bit reversal properties for g.
          | _ => exfalso; have := Nat.mod_two_ne_zero_of_mod_four_ne_zero_and_two n; linarith
  have h_fp : ∀ n > 0, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn; rw [hfg n hn]
    constructor
    · intro hg; have := Nat.ofDigits_reverse_digits 2 (by decide) n
      rw [hg] at this; exact Nat.digits_unique 2 (by decide) _ _ (by decide) (by decide) this
    · intro h_pal; rw [h_pal, Nat.ofDigits_digits]
  let P := (Finset.Icc 1 1988).filter (fun n => (Nat.digits 2 n).reverse = Nat.digits 2 n)
  have : (Finset.Icc 1 1988).filter (fun n => f n = n) = P := by
    apply Finset.ext; intro n; rw [Finset.mem_filter, Finset.mem_filter]
    constructor <;> intro h <;> use h.1
    · rw [h_fp n (by exact (Finset.mem_Icc.1 h.1).1)] at h; exact h.2
    · rw [h_fp n (by exact (Finset.mem_Icc.1 h.1).1)]; exact h.2
  rw [this]; clear hfg h_fp this
  -- Count palindromes: L=1 (1), L=2 (1), L=3 (2), L=4 (2), L=5 (4), L=6 (4), L=7 (8), L=8 (8), L=9 (16), L=10 (16), L=11 (30).
  -- Total: 1+1+2+2+4+4+8+8+16+16+30 = 92.
  exact (by sorry)

