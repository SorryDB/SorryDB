import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g n := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have h_app (L : List ℕ) (x : ℕ) : Nat.ofDigits 2 (L ++ [x]) = Nat.ofDigits 2 L + x * 2 ^ L.length := by
    induction L with
    | nil => simp [Nat.ofDigits]
    | cons y ys ih => simp [Nat.ofDigits, ih, Nat.pow_succ, mul_add, add_assoc]; ring
  have hg_even (n : ℕ) (hn : n > 0) : g (2 * n) = g n := by
    simp [g, Nat.digits_add 2 (by decide) 0 n (by decide) (Or.inr hn.ne.symm), List.reverse_cons, h_app]
  have hg_odd (n : ℕ) : g (2 * n + 1) = g n + 2 ^ (Nat.digits 2 n).length := by
    simp [g, Nat.digits_add 2 (by decide) 1 n (by decide) (Or.inl (by decide)), List.reverse_cons, h_app]
  have hg1 : g 1 = 1 := by simp [g, Nat.digits, Nat.ofDigits]
  have hg3 : g 3 = 3 := by simp [g, Nat.digits, Nat.ofDigits]
  have hfg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      if n1 : n = 1 then rw [n1, h₁, hg1]
      else if n3 : n = 3 then rw [n3, h₂, hg3]
      else if he : n % 2 = 0 then
        have m_pos : n / 2 > 0 := Nat.pos_of_ne_zero (fun h => by
          have := Nat.div_add_mod n 2; rw [h, he] at this; simp at this; rw [this] at hn; linarith)
        rw [Nat.div_add_mod n 2 |>.symm, he, add_zero, h₃ _ m_pos, ih (n / 2) (Nat.div_lt_self hn (by decide)) m_pos, hg_even (n / 2) m_pos]
      else if ho1 : n % 4 = 1 then
        let m := n / 4; have hm : n = 4 * m + 1 := (Nat.div_add_mod n 4).symm.trans (by rw [ho1])
        have m_pos : m > 0 := Nat.pos_of_ne_zero (fun h0 => by rw [h0] at hm; exact n1 (by simp at hm; exact hm))
        have Lm : (Nat.digits 2 (2 * m)).length = (Nat.digits 2 m).length + 1 := by
          simp [Nat.digits_add 2 (by decide) 0 m (by decide) (Or.inr m_pos.ne.symm)]
        rw [hm, h₄ m m_pos, ih (2 * m + 1) (by linarith) (by linarith), ih m (by linarith) m_pos, hg_odd (2 * m), hg_even m m_pos, Lm, hg_odd m]; ring
      else
        have ho3 : n % 4 = 3 := by
          have h2 : n % 2 = 1 := Nat.mod_two_ne_zero.1 (by rwa [Nat.mod_two_ne_zero])
          have h4 : n % 4 < 4 := Nat.mod_lt n (by decide)
          have := Nat.mod_mod_of_dvd n (by decide : 2 ∣ 4)
          revert this h2 ho1 h4; generalize n % 4 = k; intro h1 h2 h3 h4; interval_cases k <;> simp_all
        let m := n / 4; have hm : n = 4 * m + 3 := (Nat.div_add_mod n 4).symm.trans (by rw [ho3])
        have m_pos : m > 0 := Nat.pos_of_ne_zero (fun h0 => by rw [h0] at hm; exact n3 (by simp at hm; exact hm))
        have Lm1 : (Nat.digits 2 (2 * m + 1)).length = (Nat.digits 2 m).length + 1 := by
          simp [Nat.digits_add 2 (by decide) 1 m (by decide) (Or.inl (by decide))]
        rw [hm, h₅ m m_pos, ih (2 * m + 1) (by linarith) (by linarith), ih m (by linarith) m_pos, hg_odd (2 * m + 1), Lm1, hg_odd m]; ring
  rw [Finset.filter_congr (fun n hn => by rw [hfg n (Finset.mem_Icc.1 hn).1])]
  exact by decide

