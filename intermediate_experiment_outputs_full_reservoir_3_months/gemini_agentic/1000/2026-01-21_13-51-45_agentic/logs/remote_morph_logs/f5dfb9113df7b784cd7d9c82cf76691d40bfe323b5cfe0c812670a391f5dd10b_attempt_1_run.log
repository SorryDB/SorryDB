  have hScard := calc
    (#S : ℝ) ≤ #(A⁻¹ * A) := by gcongr
    _ ≤ K ^ 2 * #A := sorry
  obtain ⟨F, hFA, hFcard, hASF⟩ : ∃ F ⊆ A, #F ≤ 2 * K ∧ A ⊆ S * F := sorry
  refine ⟨S ^ 2, by gcongr, ?_, ?_, ?_⟩
  · rw [show 2 ^ 12 * K ^ 36 = (2 ^ 4 * K ^ 12) ^ 3 by ring, coe_pow]
