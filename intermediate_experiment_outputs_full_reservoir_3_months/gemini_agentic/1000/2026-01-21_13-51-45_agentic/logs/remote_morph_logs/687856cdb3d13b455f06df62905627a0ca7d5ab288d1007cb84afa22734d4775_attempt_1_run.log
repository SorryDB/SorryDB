    rw [h_infDist, show p -ᵥ w = (p -ᵥ q0) - a • u from by rw [vsub_vadd_eq_vsub_sub],
      inner_sub_right, inner_smul_right, real_inner_self_eq_norm_sq, hu, one_sq, mul_one]
    exact h_dist p hp

