import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 32, by norm_num, fun {n} hn {S} hS hdist ↦ ?_⟩
  have hV : finrank ℝ V = 2 := Fact.out
  haveI : Nontrivial V := Module.finrank_pos_iff.mpr (hV.symm ▸ by norm_num)
  have hSne : S.Nonempty := by rw [← Finset.card_pos, hS]; exact Nat.pos_of_gt hn
  let q0 := hSne.some
  have : ∃ (u : V) (hu : ‖u‖ = 1) (a : ℝ),
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner u (p₁ -ᵥ q0) < a ∧ a < inner u (p₂ -ᵥ q0)) ∧
    ∀ p ∈ S, (1 / 32) * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner u (p -ᵥ q0) - a| := by
    sorry
  obtain ⟨u, hu, a, h_gap, h_dist⟩ := this
  let l := AffineSubspace.mk' (q0 +ᵥ a • u) (Submodule.orthogonal (Submodule.span ℝ {u}))
  use l
  refine ⟨?_, ?_, ?_⟩
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal, hV, Submodule.finrank_span_singleton]
    · norm_num
    · intro hu0; rw [hu0, norm_zero] at hu; norm_num at hu
  · obtain ⟨p1, p2, hp1, hp2, h1, h2⟩ := h_gap
    use p1, p2, hp1, hp2
    have hl : l.directionᗮ = Submodule.span ℝ {u} := by
      rw [AffineSubspace.direction_mk', Submodule.orthogonal_orthogonal]
      exact Submodule.isClosed_span_singleton u
    let f : P → ℝ := fun p ↦ inner u (p -ᵥ q0)
    have h_pos : 0 < inner u u := by
      rw [inner_self_eq_norm_sq_to_K, hu, sq, one_mul]
      exact zero_lt_one
    let v := (inner u u)⁻¹ • u
    have hv : inner v u = 1 := by
      rw [inner_smul_left, inner_self_eq_norm_sq_to_K, hu, sq, one_mul, inv_mul_cancel]
      exact one_ne_zero
    let w := q0 +ᵥ a • u
    have hw : l = AffineSubspace.mk' w l.direction := rfl
    have h_side (p : P) : l.side p = inner u (p -ᵥ w) := sorry
    rw [AffineSubspace.sOppSide_iff_side_sub_side_pos]
    sorry
  · intro p hp
    have h_dist_p := h_dist p hp
    have : Metric.infDist p l = |inner u (p -ᵥ q0) - a| := sorry
    rwa [this]
