import Mathlib


open scoped Finset
open Module InnerProductSpace

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 32, by norm_num, fun {n} hn {S} hS hdist ↦ ?_⟩
  let c : ℝ := 1 / 32
  have hV : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := .of_finrank_eq_succ hV
  have hSne : S.Nonempty := Finset.card_pos.mp (hS.symm ▸ Nat.zero_lt_of_lt hn)
  obtain ⟨q0, _⟩ := hSne
  obtain ⟨u, hu, a, h_gap, h_dist⟩ : ∃ (u : V) (hu : ‖u‖ = 1) (a : ℝ),
    (∃ p1 p2, p1 ∈ S ∧ p2 ∈ S ∧ inner (𝕜 := ℝ) u (p1 -ᵥ q0) < a ∧ a < inner (𝕜 := ℝ) u (p2 -ᵥ q0)) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner (𝕜 := ℝ) u (p -ᵥ q0) - a| := by
    sorry
  let w : P := a • u +ᵥ q0
  let W := (Submodule.span ℝ {u}).orthogonal
  let l : AffineSubspace ℝ P := AffineSubspace.mk' w W
  use l
  have hu_ne : u ≠ 0 := by intro h; rw [h, norm_zero] at hu; norm_num at hu
  have hldir : l.direction = W := AffineSubspace.direction_mk' w W
  refine ⟨?_, ?_, ?_⟩
  · rw [hldir, ← W.finrank_add_finrank_orthogonal, Submodule.finrank_span_singleton hu_ne, hV]
    norm_num
  · obtain ⟨p1, p2, hp1, hp2, h1, h2⟩ := h_gap
    use p1, p2, hp1, hp2
    sorry
  · intro p hp
    have h_infDist : Metric.infDist p l = |inner (𝕜 := ℝ) u (p -ᵥ w)| := by
      rw [infDist_affineSubspace_eq_norm_orthogonalProjection_orthogonal l p w (AffineSubspace.self_mem_mk' w _),
        hldir, Submodule.orthogonal_orthogonal, norm_orthogonalProjection_span_singleton, hu, div_one]
      rfl
    rw [h_infDist, show p -ᵥ w = (p -ᵥ q0) - a • u from by rw [w, vsub_vadd_eq_vsub_sub],
      inner_sub_right, inner_smul_right, inner_self_eq_norm_sq u, hu, one_sq, mul_one]
    exact h_dist p hp
