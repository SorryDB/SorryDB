theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 32, by norm_num, fun {n} hn {S} hS hdist ↦ ?_⟩
  let c : ℝ := 1 / 32
  have hV : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := FiniteDimensional.of_finrank_eq_succ (n := 1) hV
  have hSne : S.Nonempty := Finset.card_pos.mp (hS.symm ▸ Nat.zero_lt_of_lt hn)
  obtain ⟨q0, _⟩ := hSne
  obtain ⟨u, hu, a, h_gap, h_dist⟩ : ∃ (u : V) (hu : ‖u‖ = 1) (a : ℝ),
    (∃ p1 p2, p1 ∈ S ∧ p2 ∈ S ∧ inner u (p1 -ᵥ q0) < a ∧ a < inner u (p2 -ᵥ q0)) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner u (p -ᵥ q0) - a| := by
    sorry
  let w : P := a • u +ᵥ q0
  let W : Submodule ℝ V := (Submodule.span ℝ {u}).orthogonal
  let l : AffineSubspace ℝ P := AffineSubspace.mk' w W
  have hu_ne : u ≠ 0 := by intro h; rw [h, norm_zero] at hu; linarith
  have hW : l.direction = W := AffineSubspace.direction_mk' w W
  use l
  refine ⟨?_, ?_, ?_⟩
  · rw [hW, ← Submodule.finrank_add_finrank_orthogonal (Submodule.span ℝ {u}),
      Submodule.finrank_span_singleton hu_ne, hV]
    norm_num
  · obtain ⟨p1, p2, hp1, hp2, h1, h2⟩ := h_gap
    use p1, p2, hp1, hp2
    have hf1 : inner u (p1 -ᵥ w) < 0 := by
      rw [show p1 -ᵥ w = (p1 -ᵥ q0) - a • u from by rw [vsub_vadd_eq_vsub_sub],
        inner_sub_right, inner_smul_right, real_inner_self_eq_norm_sq, hu, one_sq, mul_one]
      linarith
    have hf2 : 0 < inner u (p2 -ᵥ w) := by
      rw [show p2 -ᵥ w = (p2 -ᵥ q0) - a • u from by rw [vsub_vadd_eq_vsub_sub],
        inner_sub_right, inner_smul_right, real_inner_self_eq_norm_sq, hu, one_sq, mul_one]
      linarith
    have h1l : p1 ∉ l := by
      intro h; have := AffineSubspace.mem_mk' w W h
      simp [W, Submodule.mem_orthogonal, real_inner_comm] at this
      specialize this u (Submodule.mem_span_singleton_self u); rw [this] at hf1; linarith
    have h2l : p2 ∉ l := by
      intro h; have := AffineSubspace.mem_mk' w W h
      simp [W, Submodule.mem_orthogonal, real_inner_comm] at this
      specialize this u (Submodule.mem_span_singleton_self u); rw [this] at hf2; linarith
    refine ⟨h1l, h2l, ?_⟩
    let t := (- inner u (p1 -ᵥ w)) / (inner u (p2 -ᵥ w) - inner u (p1 -ᵥ w))
    have ht0 : 0 < t := div_pos (neg_pos.mpr hf1) (sub_pos.mpr (by linarith))
    have ht1 : t < 1 := (div_lt_one (sub_pos.mpr (by linarith))).mpr (by linarith)
    use (1 - t) • p1 + t • p2
    refine ⟨⟨1 - t, t, by linarith, ht0.le, ht1.le, rfl⟩, ?_⟩
    apply AffineSubspace.mem_mk' w W
    simp [W, Submodule.mem_orthogonal, real_inner_comm]
    intro v hv; rw [Submodule.mem_span_singleton] at hv; obtain ⟨r, rfl⟩ := hv
    rw [inner_smul_right, inner_add_right, inner_smul_left, inner_smul_left,
      show p1 -ᵥ w = (1 : ℝ) • (p1 -ᵥ w) from (one_smul ℝ _).symm,
      show p2 -ᵥ w = (1 : ℝ) • (p2 -ᵥ w) from (one_smul ℝ _).symm]
    field_simp [t]; ring
  · intro p hp
    have h_infDist : Metric.infDist p l = |inner u (p -ᵥ w)| := by
      rw [← dist_eq_infDist (AffineSubspace.nonempty_mk' w W),
        AffineSubspace.dist_eq_norm_orthogonalProjection (AffineSubspace.self_mem_mk' w W),
