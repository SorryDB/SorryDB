import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, by norm_num
  intro n hn S hS hdist
  let f (u : {u : V // ‖u‖ = 1}) (p : P) : ℝ := inner (u : V) (p -ᵥ Classical.arbitrary P)
  let gaps (u : {u : V // ‖u‖ = 1}) :=
    let s := (S.image (f u)).sort (· ≤ ·)
    (List.zip s s.tail).map (λ (x, y) => y - x)
  have : Nonempty {u : V // ‖u‖ = 1} := by
    obtain ⟨u, hu⟩ := (exists_unit_vector ℝ V)
    exact ⟨⟨u, hu⟩⟩
  have h_max_gap : ∃ u, 2 * c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ (gaps u).max := by
    sorry -- This is the core of Füredi's Theorem (1982)
  obtain ⟨u, hu_gap⟩ := h_max_gap
  let s_list := (S.image (f u)).sort (· ≤ ·)
  obtain ⟨x, y, hxy, hgap⟩ := List.exists_pair_of_max_gap hu_gap
  let d := (x + y) / 2
  let l_dir := (ℝ ∙ (u : V)).orthogonal
  let l : AffineSubspace ℝ P :=
    { carrier := { p | f u p = d }
      smul_mem' := by sorry
      one_smul_mem' := by sorry
      zero_mem' := by sorry
      add_mem' := by sorry }
  use l
  refine ⟨by sorry, ⟨by sorry, by sorry, by sorry⟩, by sorry⟩
  sorry
