    · exact k.elim0
    · have : 0 < 0 := by linarith
      exact Nat.lt_irrefl 0 this
    · have h0 : (0 : Fin (n + 2)) = k := h 0
      have h1 : (1 : Fin (n + 2)) = k := h 1
      subst h0
      simp at h1
