      subst h0
      simp at h1
  | cons c S' IH =>
    -- To prove that everyone knows k's secret, we follow the cardinality of
    -- the set of agents who know it. Each call increases this by at most 1.
    -- To reach n agents from the initial 1 (k), at least n-1 calls are required.
    -- The Baker and Shostak (1972) proof uses this to show that for minimal 
    -- expert sequences, the total number of calls must be at least 2n-4.
    exact exp_needs_n_min_one_calls (c :: S') h
