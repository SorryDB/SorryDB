lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  refine ⟨fun h ↦ h.uniformIntegrable.comp (fun t ↦ ⟨fun _ ↦ t, isStoppingTime_const 𝓕 t,
    fun _ ↦ WithTop.coe_ne_top t⟩), fun h ↦ ?_⟩
  let Y := fun t ω ↦ ‖X t ω‖
  have hY_sub : Submartingale Y 𝓕 P := hX1.submartingale_convex_comp
    convexOn_norm continuous_norm (fun t ↦ (hX1.integrable t).norm)
  have hY_cont : ∀ ω, RightContinuous (Y · ω) := fun ω t ↦ (hX2 ω t).norm
  have hY_nonneg : 0 ≤ Y := fun t ω ↦ norm_nonneg _
  rw [uniformIntegrable_iff_norm one_ne_zero ENNReal.one_ne_top
    (fun t ↦ (hX1.integrable t).aestronglyMeasurable)] at h
  have hY_classD := (MeasureTheory.Submartingale.classD_iff_uniformIntegrable
    hY_sub hY_cont hY_nonneg).mpr h
  have h_prog : ProgMeasurable 𝓕 X := hX1.adapted.progMeasurable_of_rightContinuous hX2
  refine ⟨h_prog, ?_⟩
  rw [uniformIntegrable_iff_norm one_ne_zero ENNReal.one_ne_top]
  · exact hY_classD.uniformIntegrable
  · exact fun τ ↦ (h_prog.stronglyMeasurable_stoppedValue τ.2.1 τ.2.2).aestronglyMeasurable
```
