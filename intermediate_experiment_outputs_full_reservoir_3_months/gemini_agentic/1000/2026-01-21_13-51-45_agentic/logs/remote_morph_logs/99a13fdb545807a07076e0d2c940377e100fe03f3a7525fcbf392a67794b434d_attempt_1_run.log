lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable
    [IsFiniteMeasure P] [PseudoMetrizableSpace ι] [BorelSpace ι]
    (hX1 : Martingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  refine ⟨fun hD ↦ ?_, fun hUI ↦ ?_⟩
  · let f (t : ι) : {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} :=
      ⟨fun _ ↦ t, isStoppingTime_const 𝓕 t, fun _ ↦ WithTop.coe_ne_top t⟩
    have : X = (fun τ ↦ stoppedValue X τ.1) ∘ f := by
      ext t ω
      simp [f, stoppedValue]
    rw [this]
    exact hD.uniformIntegrable.comp f
  · have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
    refine ⟨h_prog, ?_⟩
    let Y := fun t ω ↦ ‖X t ω‖
    have hY_sub : Submartingale Y 𝓕 P := hX1.submartingale_convex_comp
      (convexOn_norm convex_univ) continuous_norm (fun t ↦ (hX1.integrable t).norm)
    have hY_cont : ∀ ω, RightContinuous (Y · ω) := fun ω t ↦ (hX2 ω t).norm
    have hY_nonneg : 0 ≤ Y := fun t ω ↦ norm_nonneg _
    have hY_UI : UniformIntegrable Y 1 P :=
      (uniformIntegrable_iff_norm one_ne_zero ENNReal.one_ne_top
        (fun t ↦ (hX1.integrable t).aestronglyMeasurable)).mp hUI
    have hY_classD : ClassD Y 𝓕 P :=
      (MeasureTheory.Submartingale.classD_iff_uniformIntegrable hY_sub hY_cont hY_nonneg).mpr hY_UI
    rw [uniformIntegrable_iff_norm one_ne_zero ENNReal.one_ne_top]
    · exact hY_classD.uniformIntegrable
    · exact fun τ ↦ (h_prog.stronglyMeasurable_stoppedValue τ.2.1 τ.2.2).aestronglyMeasurable
```
