                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  letI := NumberField.instCompactSpaceAdicCompletionIntegers ℚ
  let I := Module.Basis.ofVectorSpaceIndex ℚ V
  let b := IntegralLattice.basis ℤ ℚ V
  letI : Finite I := FiniteDimensional.finite_basis_index ℚ V
  let K_v := IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v
  let O := IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ v
  let w (i : I) : V ⊗[ℚ] K_v := Aux.c_v_alg V v (b i ⊗ₜ 1)
  let g_lin : (I → K_v) →ₗ[K_v] V ⊗[ℚ] K_v := Basis.constr (Pi.basisFun K_v I) K_v w
  let g (c : I → O) : V ⊗[ℚ] K_v := g_lin (fun i ↦ (c i : K_v))
