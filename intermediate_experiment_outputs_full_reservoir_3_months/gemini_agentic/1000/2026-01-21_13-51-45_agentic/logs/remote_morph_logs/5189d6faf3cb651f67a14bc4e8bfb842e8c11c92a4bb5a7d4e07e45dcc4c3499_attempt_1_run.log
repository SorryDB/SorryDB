    · rintro ⟨c, rfl⟩
      use (Basis.baseChange O b).equivFun.symm c
      simp [g, g_lin, w, Basis.baseChange, Basis.constr, LinearMap.lTensor_apply, Basis.equivFun_symm_apply]
    · rintro ⟨y, rfl⟩
