variable {T Ω E : Type*} [LinearOrder T] [TopologicalSpace T] [OrderBot T]
  [OrderTopology T] [MeasurableSpace T] [BorelSpace T]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
