/-- The moment of inertia tensor of a solid sphere through its center of mass is
  `2/5 m R^2 * I`. -/
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  ext i j
  simp only [inertiaTensor, solidSphere, LinearMap.coe_mk, Matrix.smul_apply, Matrix.one_apply,
    smul_eq_mul, AddHom.coe_mk, ContMDiffMap.coeFn_mk]
  set vol := (volume : Measure (Space 3)).real (Metric.closedBall 0 R)
  have h_vol : vol ≠ 0 := by
    refine (measureReal_ne_zero_iff ?_).mpr ?_
    · apply Space.volume_closedBall_neq_top
    · apply Space.volume_closedBall_neq_zero (0 : Space 3)
      exact lt_of_le_of_ne R.2 (Ne.symm (by simpa using hr))
  by_cases hij : i = j
  · subst hij
    simp only [Matrix.one_apply_eq, if_true, mul_one]
    field_simp [h_vol]
    have h_int : ∫ x in Metric.closedBall 0 R, (∑ k, x k ^ 2) - (x i) ^ 2 ∂volume =
        (2 : ℝ) / 5 * R.1 ^ 2 * vol := sorry
    field_simp [h_int]
    ring
  · simp only [hij, ↓reduceIte, mul_zero, zero_mul, zero_sub]
    field_simp [h_vol]
    have h_int : ∫ x in Metric.closedBall 0 R, x i * x j ∂volume = 0 := sorry
    rw [integral_neg, h_int]
    simp
