    simp [hmpr]
    let Y := Field51_as_Nat e.Y
    let Z := Field51_as_Nat e.Z
    split_ifs with h_cond
    · simp [huv, hudi, hud, h_cond]
      sorry
    · simp [huv, hudi, hud, hun, h_cond]
      rw [mul_assoc, mul_comm _ (Z - Y), ← Nat.mul_mod, ← Nat.mul_mod]
      rw [hud] at hudi
      have : (Z + p - Y) % p = (Z - Y) % p := by sorry
      rw [this] at hudi
      simp [h_cond] at hudi
      rw [hudi, hun]
      simp
