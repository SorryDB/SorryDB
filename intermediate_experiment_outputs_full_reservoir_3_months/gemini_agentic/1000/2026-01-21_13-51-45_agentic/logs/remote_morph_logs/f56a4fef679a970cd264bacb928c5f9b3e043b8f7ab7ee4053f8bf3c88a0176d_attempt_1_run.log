          refine le_of_not_gt (fun hg ↦ ?_)
          have : τ_val ≤ s := hittingAfter_le hg (bot_le)
          exact hst.not_le this
        exact h_bound.trans (le_add_of_nonneg_right (norm_nonneg _))
    · have hst : (s : WithTop ι) < τ_val := lt_of_le_of_lt (WithTop.coe_le_coe.mpr hs) (not_le.mp hτt)
      rw [min_eq_left (le_of_lt hst)]
