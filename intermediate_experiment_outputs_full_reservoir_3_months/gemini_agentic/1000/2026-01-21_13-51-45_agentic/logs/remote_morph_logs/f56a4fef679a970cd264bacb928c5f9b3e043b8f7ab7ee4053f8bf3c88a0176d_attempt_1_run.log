lemma sup_stoppedProcess_hittingAfter_Ici_le {E : Type*} [NormedAddCommGroup E] [InfSet ι] [Bot ι]
    {X : ι → Ω → E} (t : ι) (K : ℝ) (ω : Ω) :
    ⨆ s ≤ t, ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ ≤
    K + Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
      (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω := by
  set τ := hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥
  have h_bound (s : ι) (hst : s ≤ t) : ‖stoppedProcess X τ s ω‖ ≤
      K + Set.indicator {ω | τ ω ≤ t} (fun ω ↦ ‖stoppedValue X τ ω‖) ω := by
    rw [stoppedProcess_apply]
    by_cases hτs : τ ω ≤ (s : WithTop ι)
    · have hτt : τ ω ≤ (t : WithTop ι) := hτs.trans (WithTop.coe_le_coe.mpr hst)
      rw [min_eq_right hτs, Set.indicator_of_mem hτt]
      exact le_add_of_nonneg_left (norm_nonneg _)
    · rw [min_eq_left (le_of_lt (not_le.mp hτs)), WithTop.untopA_coe]
      refine le_trans ?_ (le_add_of_nonneg_right (Set.indicator_nonneg (fun _ _ ↦ norm_nonneg _) _))
      by_cases hb : ⊥ < s
      · exact (less_hittingAfter (not_le.mp hτs) hb).le
      · have : s = ⊥ := le_bot_iff.mp (not_lt.mp hb)
        rw [this]
        by_cases hτ : τ ω = ⊥
        · exact (hτs (hτ.le)).elim
        · have : ⊥ < τ ω := hτ.bot_lt
          exact le_of_forall_pos_le_add fun ε hε ↦ sorry
  exact iSup₂_le h_bound
