  revert i h h' h'' cs args
  induction w with
  | zero => intros; contradiction
  | succ w ih =>
    intros args cs i hi h' h''
    let b := args.head; let bs := args.tail
    have h_args : args = Vector.cons b bs := Vector.cons_head_tail args
    rw [h_args, assert_bits_e]
    have h_foldl : Vector.foldl assert_bit_e cs (Vector.cons b bs) = Vector.foldl assert_bit_e (assert_bit_e cs b) bs := by
      let ⟨l, hl⟩ := args; cases l with | nil => contradiction | cons x xs => rfl
    rw [h_foldl]
    cases i with
    | zero =>
      have h_bad : (assert_bit_e cs b).eval = .n := by
        simp [assert_bit_e, Cs.eval, Exp.eval, h_args] at h' h'' ⊢
        intro hz; rcases mul_eq_zero.1 hz with h0 | h1
        · exact h' h0
        · rw [sub_eq_zero] at h1; exact h'' h1
      clear hi h' h'' ih i b h_args args
      induction w generalizing bs cs with
      | zero =>
        rw [assert_bits_e, Vector.foldl]
        let ⟨l, hl⟩ := bs; cases l with | nil => exact h_bad | cons x xs => contradiction
      | succ w ih' =>
        let b' := bs.head; let bs' := bs.tail
        rw [show bs = Vector.cons b' bs' by simp [Vector.cons_head_tail], ←assert_bits_e]
        apply ih' (cs := assert_bit_e cs b') (bs := bs')
        simp [assert_bit_e, Cs.eval, h_bad]
    | succ j =>
      rw [←assert_bits_e]
      apply ih bs (assert_bit_e cs b) j (Nat.lt_of_succ_lt_succ hi)
      · simp [h_args] at h'; exact h'
      · simp [h_args] at h''; exact h''
