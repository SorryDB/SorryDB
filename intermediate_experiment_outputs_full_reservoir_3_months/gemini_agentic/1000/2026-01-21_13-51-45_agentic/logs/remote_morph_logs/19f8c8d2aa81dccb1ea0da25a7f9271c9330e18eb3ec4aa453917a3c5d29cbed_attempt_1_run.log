lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  revert i h h' h'' cs
  induction w with
  | zero => intros; contradiction
  | succ w ih =>
    intros args cs i h h' h''
    rw [assert_bits_e, Vector.foldl_cons]
    if hi0 : i = 0 then
      subst hi0
      have h_eval_n : (assert_bit_e cs args.head).eval = .n := by
        simp [assert_bit_e, Cs.eval, h', h'']
        intro hz; rcases mul_eq_zero.1 hz with hz | hz <;> [contradiction; (rw [sub_eq_zero] at hz; contradiction)]
      let t := args.tail; let c := assert_bit_e cs args.head
      have : c.eval = .n := h_eval_n
      clear h' h'' h ih h_eval_n cs args
      induction w generalizing t c with
      | zero =>
        have : t = #v[] := by simp
        simp [assert_bits_e, Vector.foldl, this, *]
      | succ w ih_tail =>
        rw [assert_bits_e, Vector.foldl_cons]; apply ih_tail; simp [Cs.eval, *]; split <;> rfl
    else
      have hi : args[i] = args.tail[i - 1] := by
        rw [←Vector.get_cons_succ, ←Vector.cons_head_tail, Nat.succ_pred hi0]
      apply ih args.tail (assert_bit_e cs args.head) (i - 1) (Nat.lt_of_succ_lt_succ (by rwa [Nat.succ_pred hi0]))
      · rwa [hi] at h'
      · rwa [hi] at h''

end Clap
```
