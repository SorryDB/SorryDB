import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  let K (s : Set (Fin 4)) : Set (Fin 2 → ℝ) := {v | v + y s ∈ C}
  have hK (s : Set (Fin 4)) : Convex ℝ (K s) := hC.affine_preimage
    (AffineMap.id ℝ (Fin 2 → ℝ) + AffineMap.const ℝ (Fin 2 → ℝ) (y s))
  have h (i : Fin 4) (s : Set (Fin 4)) : x i ∈ K s ↔ i ∈ s := by
    simp [K, hxy, add_comm]
  /-
    In ℝ², any set of 4 points {x 0, x 1, x 2, x 3} has a Radon partition.
    Either one point is in the triangle of the others, or they form a convex quadrilateral.
    If $x_3$ is in the convex hull of $\{x_0, x_1, x_2\}$, then for $s = \{0, 1, 2\}$,
    the convexity of $K_s$ implies $x_3 \in K_s$, so $3 \in s$, a contradiction.
    If they form a convex quadrilateral $(x_0, x_1, x_2, x_3)$ in order, then the segments
    $[x_0, x_2]$ and $[x_1, x_3]$ intersect at a point $p$.
    This point $p$ must satisfy $p \in K_{\{0,2\}}$ and $p \in K_{\{1,3\}}$.
    The existence of such a point for every possible shattering translate of a convex set
    in $\mathbb{R}^2$ leads to a contradiction because the Venn diagram of 4 translates
    of a convex set in the plane has at most $4^2 - 4 + 2 = 14$ regions, whereas shattering
    requires $2^4 = 16$.
  -/
  have h_not_shattered : ¬ ∀ s : Set (Fin 4), ∃ v : Fin 2 → ℝ, ∀ i, x i + v ∈ C ↔ i ∈ s := by
    intro _
    -- This follows from the fact that the VC dimension of translates of a convex set in R² is 3.
    -- For any convex set C ⊆ ℝ², the family {C + v | v ∈ ℝ²} has VC dimension at most 3.
    -- This is a well-known result in computational geometry (e.g., by Kedem et al., 1986).
    sorry
  apply h_not_shattered
  intro s
  exact ⟨y s, hxy · s⟩
