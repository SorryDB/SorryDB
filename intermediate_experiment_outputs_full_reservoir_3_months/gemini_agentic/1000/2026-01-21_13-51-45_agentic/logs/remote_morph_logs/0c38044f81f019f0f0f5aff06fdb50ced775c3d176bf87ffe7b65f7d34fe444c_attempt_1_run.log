import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  let K (s : Set (Fin 4)) : Set (Fin 2 → ℝ) := {v | v + y s ∈ C}
  have hK (s : Set (Fin 4)) : Convex ℝ (K s) :=
    hC.affine_preimage (AffineMap.id ℝ (Fin 2 → ℝ) + AffineMap.const ℝ (Fin 2 → ℝ) (y s))
  have h_shat (i : Fin 4) (s : Set (Fin 4)) : x i ∈ K s ↔ i ∈ s := by
    simp [K, hxy, add_comm]
  /-
    In ℝ², any set of 4 points {x 0, x 1, x 2, x 3} can be partitioned into two sets I, J
    whose convex hulls intersect (Radon's Theorem). Let p ∈ conv(x_I) ∩ conv(x_J).
    If X is shattered by translates of C, then for s = I, x_I ⊆ K_I and x_J ∩ K_I = ∅.
    Since K_I is convex, p ∈ K_I. Similarly, for s = J, p ∈ K_J.
    A combinatorial result for translates of convex sets in the plane states that the
    Venn diagram of 4 translates partitions the plane into at most 4^2 - 4 + 2 = 14 regions.
    The condition `hxy` implies all 2^4 = 16 regions are non-empty, which is a contradiction.
  -/
  have h_vc : (Set.univ : Set (Fin 4)).ncard ≤ 3 := by
    -- The VC dimension of translates of any convex set in R² is 3.
    -- This is a well-known result by Kedem, Pach, and Sharir (1986).
    sorry
  simp at h_vc
