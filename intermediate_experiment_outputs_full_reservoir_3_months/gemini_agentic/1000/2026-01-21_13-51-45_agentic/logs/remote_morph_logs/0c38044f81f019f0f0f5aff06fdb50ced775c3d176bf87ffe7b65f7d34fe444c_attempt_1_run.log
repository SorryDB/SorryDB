  have hK (i : Fin 4) : Convex ℝ (K i) := hC.affine_preimage (AffineMap.id ℝ (Fin 2 → ℝ) - AffineMap.const ℝ (x i))
  have h (s : Set (Fin 4)) : (⋂ i ∈ s, K i) ∩ (⋂ i ∉ s, (K i)ᶜ) ≠ ∅ := by
    use y s
    simp only [Set.mem_inter_iff, Set.mem_iInter, Set.mem_compl_iff, K, Set.mem_preimage]
    exact ⟨fun i hi ↦ (hxy i s).1 hi, fun i hi ↦ (hxy i s).not.1 hi⟩
  have h_planar (i j k l : Fin 4) (h_dist : i ≠ j ∧ i ≠ k ∧ i ≠ l ∧ j ≠ k ∧ j ≠ l ∧ k ≠ l) : False := sorry
  sorry

