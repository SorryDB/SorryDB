def toCofix (self : StateCofixFinal F α) : Cofix F α :=
  have h : ∀ a b, Coalg.Bisim a b → Coalg.toCofix a = Coalg.toCofix b := by
    rintro a b ⟨R, h_bisim, h_R⟩
    let R' : Cofix F α → Cofix F α → Prop := fun x y =>
      ∃ (s : a.σ) (t : b.σ),
          R (.inl s) (.inr t)
          ∧ x = Coalg.toCofix { a with s := s }
          ∧ y = Coalg.toCofix { b with s := t }
    apply MvQPF.Cofix.bisim R'
    · simp only [forall_exists_index, and_imp, R']
      rintro _ _ s t hR rfl rfl
      specialize h_bisim (.inl s) (.inr t) hR
      simp only [Coalg.toCofix, Cofix.dest_corec, Coalg.union, MvFunctor.map_map, TypeVec.appendFun_comp_id] at h_bisim ⊢
      rw [MvQPF.liftR_iff] at h_bisim ⊢
      rcases h_bisim with ⟨p, f, g, hf, hg, h_rel⟩
      let f_new := (TypeVec.id ::: fun st => match st with | .inl s' => Coalg.toCofix { a with s := s' } | .inr t' => Coalg.toCofix { b with s := t' })
      use p, f_new ⊚ f, f_new ⊚ g
      and_intros
      · rw [← MvFunctor.map_map, hf, MvFunctor.map_map]; congr; funext i x; cases i <;> [(cases x <;> rfl); rfl]
      · rw [← MvFunctor.map_map, hg, MvFunctor.map_map]; congr; funext i x; cases i <;> [(cases x <;> rfl); rfl]
      · intro i u; specialize h_rel i u; cases i
        · exact ⟨_, _, h_rel, rfl, rfl⟩
        · exact h_rel
    · exact ⟨a.s, b.s, h_R, rfl, rfl⟩
  Quot.lift Coalg.toCofix h self
