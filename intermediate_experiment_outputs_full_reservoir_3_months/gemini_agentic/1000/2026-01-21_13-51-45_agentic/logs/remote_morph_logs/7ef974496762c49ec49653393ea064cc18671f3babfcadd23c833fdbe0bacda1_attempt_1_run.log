lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  refine Metric.uniformContinuous_iff.2 fun ε hε ↦ ?_
  let ε₃ := ε / 3
  have hε₃ : 0 < ε₃ := by positivity
  obtain ⟨l, hl⟩ := hf hε₃
  let K := Set.Icc (-1) (l + 1)
  have hK : IsCompact K := isCompact_Icc
  -- Continuity is actually part of the standard definition, but if not provided,
  -- we proceed with the standard proof for almost periodic functions.
  obtain ⟨δ, hδpos, hδ⟩ := Metric.uniformContinuousOn_iff.1
    (hK.uniformContinuousOn (hf.continuous.continuousOn)) hε₃
  refine ⟨min 1 δ, by positivity, fun {x y} hxy ↦ ?_⟩
  obtain ⟨τ, hτ, hτ_ap⟩ := hl (-x)
  have hxτ : x + τ ∈ K := by
    simp only [K, Set.mem_Icc]
    constructor
    · linarith [hτ.1]
    · linarith [hτ.2, hl.pos]
  have hyτ : y + τ ∈ K := by
    simp only [K, Set.mem_Icc]
    rw [dist_eq_norm] at hxy
    have : |y - x| < 1 := hxy.trans_le (min_le_left 1 δ)
    constructor
    · linarith [hτ.1, (abs_lt.1 this).1]
    · linarith [hτ.2, (abs_lt.1 this).2]
  calc dist (f x) (f y)
    _ ≤ dist (f x) (f (x + τ)) + dist (f (x + τ)) (f (y + τ)) + dist (f (y + τ)) (f y) := dist_triangle4 ..
    _ ≤ ε₃ + ε₃ + ε₃ := by
      gcongr
      · rw [dist_comm, dist_eq_norm]; exact hτ_ap x
      · exact hδ hxτ hyτ (by rwa [dist_add_right])
      · rw [dist_eq_norm]; exact hτ_ap y
    _ = ε := by field_simp; ring
