/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  obtain ⟨l, hl⟩ := hf (show 0 < ε / 3 from by positivity)
  have : 0 < l := hl.pos
  obtain ⟨δ, hδ, hf_δ⟩ := Metric.uniformContinuous_iff.1 (hf.continuous.uniformContinuousOn (Set.Icc (-1) (l + 1))) (show 0 < ε / 3 from by positivity)
  refine ⟨min 1 δ, by positivity, fun x y hxy ↦ ?_⟩
  obtain ⟨τ, ⟨hτ₀, hτl⟩, hτ⟩ := hl (-x)
  have hxτ : x + τ ∈ Set.Icc 0 l := by
    rw [Set.mem_Icc]; exact ⟨(neg_add_self x).symm.trans_le hτ₀, hτl.le⟩
  have hyτ : y + τ ∈ Set.Icc (-1) (l + 1) := by
    rw [Set.mem_Icc]
    constructor
    · calc -1 ≤ x + τ - 1 := by linarith [hxτ.1]
           _ ≤ x + τ - dist x y := by gcongr; exact hxy.le.trans (min_le_left 1 δ)
           _ ≤ y + τ := by rw [dist_eq_norm, ← sub_le_iff_le_add] at hxy; linarith [hxτ.1]
    · calc y + τ ≤ x + τ + dist x y := by rw [dist_eq_norm, ← sub_le_iff_le_add] at hxy; linarith [hxτ.1]
           _ ≤ l + 1 := by linarith [hxτ.2, hxy.le.trans (min_le_left 1 δ)]
  calc ‖f y - f x‖ ≤ ‖f y - f (y + τ)‖ + ‖f (y + τ) - f (x + τ)‖ + ‖f (x + τ) - f x‖ := by
        rw [dist_eq_norm] at *; exact norm_sub_le_norm_sub_add_norm_sub (f y) (f (y + τ)) (f x) |>.trans_le (add_le_add_right (norm_add_le ..) _)
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
        gcongr
        · exact hτ y
        · apply hf_δ
          · rw [Set.mem_Icc]; exact ⟨hxτ.1.trans (by linarith), hxτ.2.trans (by linarith)⟩
          · exact hyτ
          · rw [dist_eq_norm] at *; simpa using hxy.trans_le (min_le_right 1 δ)
        · exact hτ x
    _ = ε := by field_simp; ring
