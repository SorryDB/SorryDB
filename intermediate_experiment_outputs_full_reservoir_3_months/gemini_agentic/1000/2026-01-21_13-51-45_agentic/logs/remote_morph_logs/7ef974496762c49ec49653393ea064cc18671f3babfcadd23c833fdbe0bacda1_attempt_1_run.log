/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  refine Metric.uniformContinuous_iff.2 fun ε hε ↦ ?_
  let ε₄ := ε / 4
  have hε₄ : 0 < ε₄ := by positivity
  obtain ⟨l, hl⟩ := hf hε₄
  let K := Set.Icc (-1) (l + 1)
  have hK : IsCompact K := isCompact_Icc
  obtain ⟨δ, hδpos, hδ⟩ := Metric.uniformContinuousOn_iff.1
    (hK.uniformContinuousOn hf.continuous.continuousOn) hε₄
  refine ⟨min 1 δ, by positivity, fun {x y} hxy ↦ ?_⟩
  obtain ⟨y', hy', hτ_ap⟩ := hl (-x)
  let τ := -x + y'
  have hxτ : x + τ ∈ K := by
    simp only [K, Set.mem_Icc, τ]
    rw [add_comm, ← add_assoc, add_right_neg, zero_add]
    exact ⟨hy'.1.trans (by norm_num), hy'.2.le.trans (by linarith [hl.pos])⟩
  have hyτ : y + τ ∈ K := by
    simp only [K, Set.mem_Icc, τ]
    rw [dist_eq_norm] at hxy
    have : |y - x| < 1 := hxy.trans_le (min_le_left 1 δ)
    constructor
    · calc -1 < y - x := (abs_lt.1 this).1
          _ ≤ y - x + y' := by linarith [hy'.1]
          _ = y + τ := by rw [add_comm, ← add_assoc, add_right_neg, zero_add]
    · calc y + τ = y - x + y' := by rw [add_comm, ← add_assoc, add_right_neg, zero_add]
          _ < 1 + y' := by linarith [(abs_lt.1 this).2]
          _ < 1 + l := by linarith [hy'.2]
  calc dist (f x) (f y)
    _ ≤ dist (f x) (f (x + τ)) + dist (f (x + τ)) (f (y + τ)) + dist (f (y + τ)) (f y) := dist_triangle4 ..
    _ ≤ ε₄ + ε₄ + ε₄ := by
      gcongr
      · rw [dist_comm, dist_eq_norm]; exact hτ_ap x
      · exact hδ hxτ hyτ (by rwa [dist_add_right])
      · rw [dist_eq_norm]; exact hτ_ap y
    _ < ε := by linarith
