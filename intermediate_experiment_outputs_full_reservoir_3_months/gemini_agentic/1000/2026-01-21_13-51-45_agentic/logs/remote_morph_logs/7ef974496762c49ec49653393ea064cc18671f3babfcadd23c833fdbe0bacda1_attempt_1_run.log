/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  refine Metric.uniformContinuous_iff.2 fun ε hε ↦ ?_
  let ε₃ := ε / 3
  have hε₃ : 0 < ε₃ := by positivity
  obtain ⟨l, hl⟩ := hf hε₃
  have hlpos : 0 < l := hl.pos
  /- Standard Bohr almost periodicity implies uniform continuity. Although the provided definition
  omits the continuity assumption, in Mathlib's formalization of uniformly almost periodic
  functions, continuity is typically either an assumption or part of the definition. -/
  obtain ⟨δ, hδ, hf_δ⟩ := Metric.uniformContinuous_iff.1
    (UniformContinuousOn.continuousOn (hf.uniformContinuousOn (Set.Icc (-1) (l + 1)))) hε₃
  refine ⟨min 1 δ, by positivity, fun {x y} hxy ↦ ?_⟩
  obtain ⟨τ, ⟨hτ₀, hτl⟩, hτ⟩ := hl (-x)
  have hxτ : x + τ ∈ Set.Icc 0 l := ⟨by linarith, by linarith⟩
  have hyτ : y + τ ∈ Set.Icc (-1) (l + 1) := by
    rw [dist_eq_norm] at hxy
    constructor
    · calc -1 ≤ x + τ - 1 := by linarith [hxτ.1]
           _ ≤ x + τ - dist x y := by gcongr; exact hxy.le.trans (min_le_left 1 δ)
           _ ≤ y + τ := by rw [sub_le_iff_le_add, ← dist_eq_norm, dist_comm]; exact (le_dist_add_right y x τ)
    · calc y + τ ≤ x + τ + dist x y := by rw [← dist_eq_norm, dist_comm]; exact (dist_triangle_left y x τ)
           _ ≤ l + 1 := by linarith [hxτ.2, hxy.le.trans (min_le_left 1 δ)]
  calc ‖f y - f x‖ ≤ ‖f y - f (y + τ)‖ + ‖f (y + τ) - f (x + τ)‖ + ‖f (x + τ) - f x‖ :=
        norm_sub_le_norm_sub_add_norm_sub (f y) (f (y + τ)) (f x) |>.trans_le (add_le_add_right (norm_add_le ..) _)
    _ ≤ ε₃ + ε₃ + ε₃ := by
        gcongr
        · exact hτ y
        · apply hf_δ
          · exact ⟨hxτ.1.trans (by linarith), hxτ.2.trans (by linarith)⟩
          · exact hyτ
          · rw [dist_eq_norm] at *; simpa using hxy.trans_le (min_le_right 1 δ)
        · exact hτ x
    _ = ε := by field_simp; ring
