    have hi_lt : ⊥ < hX.localSeq n ω := h_lt
    simp [_root_.ProbabilityTheory.stoppedProcess, hi.le, hi_lt, Set.indicator_apply]
  have h_eq_t : X t ω = Y n t ω := by
    simp [_root_.ProbabilityTheory.stoppedProcess, hn.le, h_lt, Set.indicator_apply]
  exact (h_eq.continuousWithinAt_iff h_eq_t).mpr (hX.stoppedProcess n ω t)

end NormedSpace

end cadlag
