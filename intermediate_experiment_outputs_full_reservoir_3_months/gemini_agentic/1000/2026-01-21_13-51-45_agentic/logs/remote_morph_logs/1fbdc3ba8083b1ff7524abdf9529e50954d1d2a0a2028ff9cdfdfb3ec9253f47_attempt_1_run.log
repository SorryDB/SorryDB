    filter_upwards [WithTop.Iio_mem_nhds hn] with i hi
    rw [stoppedProcess_eq_of_le hi.le, Set.indicator_of_mem h_lt]
  exact (continuousWithinAt_congr_nhds h_eq).mp (hX.stoppedProcess n ω t)
