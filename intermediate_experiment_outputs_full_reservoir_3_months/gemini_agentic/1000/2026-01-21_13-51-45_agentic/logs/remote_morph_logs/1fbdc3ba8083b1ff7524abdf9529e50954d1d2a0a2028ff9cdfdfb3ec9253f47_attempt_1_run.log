lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  filter_upwards [hX.IsLocalizingSequence.tendsto_top] with ω hω
  intro t
  obtain ⟨n, hn⟩ : ∃ n, (t : WithTop ι) < hX.localSeq n ω :=
    (hω.eventually (Ioi_mem_nhds (WithTop.coe_lt_top t))).exists
  have h_lt : (⊥ : WithTop ι) < hX.localSeq n ω := (bot_le : (⊥ : WithTop ι) ≤ t).trans_lt hn
  let Y n := _root_.ProbabilityTheory.stoppedProcess (fun i ↦ {ω' | (⊥ : WithTop ι) < hX.localSeq n ω'}.indicator (X i)) (hX.localSeq n)
  have h_eq : (fun i ↦ X i ω) =ᶠ[𝓝[Set.Ioi t] t] (fun i ↦ Y n i ω) := by
    have h_mem : {i : ι | (i : WithTop ι) < hX.localSeq n ω} ∈ 𝓝 t :=
      WithTop.continuous_coe.continuousAt.preimage_mem_nhds (Iio_mem_nhds hn)
