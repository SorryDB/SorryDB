theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf hG
  unfold dedup
  suffices ∀ n set, cl ≈ dedup_ cr n set from this 0 []
  induction h_wf
  case nil => intros; simp [dedup_]; constructor
  case eq0 e_l cl_next e_r cr_next h_eval h_wf_next ih =>
    intros n set; simp [dedup_]
    split_ifs with h_mem
    · apply Circuit.Sim.trans
      · apply Circuit.Sim.eq0 h_eval (ih n set hG)
      · apply Circuit.Sim.eq0_skip
    · apply Circuit.Sim.eq0 h_eval (ih n (to_nat e_r :: set) hG)
  case lam k_l k_r h_wf_k ih =>
    intros n set; simp [dedup_]
    apply Circuit.Sim.lam; intro x
    apply ih x (n + 1) set (by simp [List.Forall, hG])
  case share e_l k_l e_r k_r h_eval h_wf_k ih =>
    intros n set; simp [dedup_]
    apply Circuit.Sim.share h_eval; intro x
    apply ih x (n + 1) set (by simp [List.Forall, hG])
  case is_zero e_l k_l e_r k_r h_eval h_wf_k ih =>
    intros n set; simp [dedup_]
    apply Circuit.Sim.is_zero h_eval; intro x
    apply ih x (n + 1) set (by simp [List.Forall, hG])
  next w e_l cl_next e_r cr_next h_eval h_wf_next ih =>
    intros n set; simp [dedup_]
    apply Circuit.Sim.assert_range h_eval (ih n (to_nat e_r :: set) hG)
