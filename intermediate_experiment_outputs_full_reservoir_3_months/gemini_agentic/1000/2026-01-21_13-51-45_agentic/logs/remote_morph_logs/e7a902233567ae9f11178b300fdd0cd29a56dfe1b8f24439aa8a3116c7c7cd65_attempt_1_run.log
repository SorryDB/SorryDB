theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  unfold dedup
  intros cl cr G h_wf h_G
  have h_aux : ∀ cl cr G, wf G cl cr → List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G → ∀ n set, (∀ e, to_nat e ∈ set → (to_var e).eval = 0) → cl ≈ dedup_ cr n set := by
    intro cl cr G h_wf
    induction h_wf <;> intros h_G n set h_set <;> simp [dedup_]
    case nil => constructor
    case eq0 e c cl h_eval h_wf ih =>
      split_ifs with h_mem
      · apply Sim.trans (Sim.eq0 h_eval (Sim.refl _)); apply ih h_G _ _ h_set
      · apply Sim.eq0 h_eval; apply ih h_G _ _
        intro e' h_e'; simp [List.mem_cons] at h_e'
        cases h_e' with | inl h => rwa [h] | inr h => apply h_set _ h
    case lam kl kr G_ G' h_wf ih =>
      apply Sim.lam; intro x; apply ih (by simp [List.Forall, *]) (n + 1) set h_set
    case share e kl kr G_ G' h_val h_wf ih =>
      apply Sim.share h_val; intro x; apply ih (by simp [List.Forall, *]) (n + 1) set h_set
    case is_zero e kl kr G_ G' h_val h_wf ih =>
      apply Sim.is_zero h_val; intro x; apply ih (by simp [List.Forall, *]) (n + 1) set h_set
    case assert_range w e c cl h_eval h_wf ih =>
      apply Sim.assert_range h_eval; apply ih h_G n (to_nat e :: set)
      intro e' h_e'; simp [List.mem_cons] at h_e'
      cases h_e' with | inl h => rwa [h] | inr h => apply h_set _ h
  apply h_aux _ _ _ 0 [] h_wf h_G
  simp
