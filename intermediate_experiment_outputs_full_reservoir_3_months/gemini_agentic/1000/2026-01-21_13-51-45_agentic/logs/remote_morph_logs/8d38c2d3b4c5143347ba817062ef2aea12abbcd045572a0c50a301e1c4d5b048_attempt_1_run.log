          have h1 P : (ℰ n (ρ⊗^S[n])).M.inner P ≤ 1 := MState.exp_val_le_one (proj_le_le_one _ _) (ℰ n (ρ⊗^S[n]))
          have h2 P : 0 ≤ (ℰ n (ρ⊗^S[n])).M.inner P := MState.exp_val_nonneg (proj_le_nonneg _ _) (ℰ n (ρ⊗^S[n]))
          have h3 : (ℰ n (ρ⊗^S[n])).M.inner (P2 ε2 n) ≤ (ℰ n (ρ⊗^S[n])).M.inner (P1 ε2 n) :=
            HermitianMat.inner_mono (ℰ n (ρ⊗^S[n])).zero_le (HermitianMat.proj_le_antitone_left (by gcongr; exact hε₀') _ _)
