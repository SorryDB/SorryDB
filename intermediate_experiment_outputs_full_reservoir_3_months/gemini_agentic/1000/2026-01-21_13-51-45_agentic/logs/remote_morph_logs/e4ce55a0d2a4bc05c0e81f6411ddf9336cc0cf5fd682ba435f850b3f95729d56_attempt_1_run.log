import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2025P2

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {M N A B C D P E F H : Pt} {Ω Γ : Sphere Pt} (Ω_center_eq_M : Ω.center = M)
    (Γ_center_eq_N : Γ.center = N) (Ω_radius_lt_Γ_radius : Ω.radius < Γ.radius)
    (A_mem_inter : A ∈ (Ω ∩ Γ : Set Pt)) (B_mem_inter : B ∈ (Ω ∩ Γ : Set Pt)) (A_ne_B : A ≠ B)
    (M_ne_N : M ≠ N) (C_mem_inter : C ∈ (line[ℝ, M, N] ∩ Ω : Set Pt))
    (D_mem_inter : D ∈ (line[ℝ, M, N] ∩ Γ : Set Pt)) (sbtw_C_M_N_D : [C, M, N, D].Sbtw ℝ)
    (affineIndependent_ACD : AffineIndependent ℝ ![A, C, D])
    (P_eq_circumcenter : P = (⟨_, affineIndependent_ACD⟩ : Triangle ℝ Pt).circumcenter)
    (E_mem_inter : E ∈ (line[ℝ, A, P] ∩ Ω : Set Pt)) (E_ne_A : E ≠ A)
    (F_mem_inter : F ∈ (line[ℝ, A, P] ∩ Γ : Set Pt)) (F_ne_A : F ≠ A)
    (affineIndependent_PMN : AffineIndependent ℝ ![P, M, N])
    (H_eq_orthocenter : H = Triangle.orthocenter (⟨_, affineIndependent_PMN⟩ : Triangle ℝ Pt)) :
    ∃ affineIndependent_BEF : AffineIndependent ℝ ![B, E, F],
      (⟨_, affineIndependent_BEF⟩ : Triangle ℝ Pt).circumsphere.IsTangent
        (AffineSubspace.mk' H line[ℝ, A, P].direction) := by
  have h_collinear_MN : Collinear ℝ {M, N} := collinear_pair ℝ M N
  have h_collinear_CDMN : Collinear ℝ {C, D, M, N} := sbtw_C_M_N_D.collinear
  have h_line_MN : line[ℝ, M, N] = affineSpan ℝ {M, N} := rfl
  have h_A_perp_MN : line[ℝ, M, N].orthogonalProjection A = line[ℝ, M, N].orthogonalProjection B := by
    have h_AB_perp_MN : dist M A = dist M B := by
      rw [← Ω_center_eq_M]
      exact (dist_center_mem_sphere Ω A_mem_inter.1).trans (dist_center_mem_sphere Ω B_mem_inter.1).symm
    have h_AB_perp_N : dist N A = dist N B := by
      rw [← Γ_center_eq_N]
      exact (dist_center_mem_sphere Γ A_mem_inter.2).trans (dist_center_mem_sphere Γ B_mem_inter.2).symm
    exact (dist_left_right_eq_orthogonalProjection_eq M_ne_N h_AB_perp_MN h_AB_perp_N)
  have h_B_reflection : B = reflection (affineSpan ℝ {M, N}) A := by
    rw [reflection_apply]
    have h_dist_proj : (orthogonalProjection (affineSpan ℝ {M, N}) A : Pt) = (orthogonalProjection (affineSpan ℝ {M, N}) B : Pt) := h_A_perp_MN
    have h_midpoint : (orthogonalProjection (affineSpan ℝ {M, N}) A : Pt) = midpoint ℝ A B := by
      apply (dist_left_right_eq_orthogonalProjection_eq M_ne_N _ _).symm
      · rw [dist_midpoint_left, dist_midpoint_right]
      · rw [dist_comm, dist_midpoint_right, dist_comm, dist_midpoint_left]
      · exact (dist_center_mem_sphere Ω A_mem_inter.1).trans (dist_center_mem_sphere Ω B_mem_inter.1).symm
      · exact (dist_center_mem_sphere Γ A_mem_inter.2).trans (dist_center_mem_sphere Γ B_mem_inter.2).symm
    rw [h_midpoint, ← mul_two, ← midpoint_vsub_left, vadd_vsub]
  have h_EF_on_line : E ∈ line[ℝ, A, P] ∧ F ∈ line[ℝ, A, P] := ⟨E_mem_inter.1, F_mem_inter.1⟩
  have h_B_not_on_AP : B ∉ line[ℝ, A, P] := by
    intro h_B_on_AP
    have h_A_B_on_AP : line[ℝ, A, B] ≤ line[ℝ, A, P] := (affineSpan_le_iff_mem ℝ).mpr (λ _ h_mem => by
      rcases (mem_affineSpan_pair ℝ h_mem) with ⟨r₁, r₂, h_sum, h_pt⟩
      rw [h_pt]; exact line[ℝ, A, P].vadd_mem (line[ℝ, A, P].smul_direction_mem r₂ (vsub_mem_direction A_mem_inter.1 h_B_on_AP)))
    sorry
  have h_BEF_indep : AffineIndependent ℝ ![B, E, F] := by
    apply affineIndependent_iff_not_collinear.mpr
    intro h_collinear
    have h_E_F_on_AP : E ∈ line[ℝ, A, P] ∧ F ∈ line[ℝ, A, P] := h_EF_on_line
    have h_E_ne_F : E ≠ F := sorry
    have h_line_EF : line[ℝ, E, F] = line[ℝ, A, P] := by
      apply line_eq_of_mem_left E_ne_A (h_EF_on_line.1)
      sorry
    exact h_B_not_on_AP (h_line_EF ▸ (collinear_iff_of_ne h_E_ne_F).mp h_collinear).2.2
  use h_BEF_indep
  sorry
