    rw [ h_quad_diff ] ; norm_num [ h_diag_zero, h_symm, Finset.mul_sum _ _ _, Finset.sum_mul _ _ _, mul_assoc, mul_comm, mul_left_comm ] ; ring;
    norm_num [ Finset.sum_add_distrib, Finset.mul_sum _ _ _, Finset.sum_mul _ _ _, mul_assoc, mul_comm, mul_left_comm ] ; ring;
    simpa only [ ← Finset.sum_mul _ _ _ ] using by ring;
  -- Let's simplify the linear term difference using the fact that `biasedUpdateState net x i` changes only the `i`-th component of `x`.
  have h_linear_diff : ∑ j, (net.thresholds j + net.bias j) * ((biasedUpdateState net x i j).toReal) = ∑ j, (net.thresholds j + net.bias j) * ((x j).toReal) + ((biasedUpdateState net x i i).toReal - (x i).toReal) * (net.thresholds i + net.bias i) := by
