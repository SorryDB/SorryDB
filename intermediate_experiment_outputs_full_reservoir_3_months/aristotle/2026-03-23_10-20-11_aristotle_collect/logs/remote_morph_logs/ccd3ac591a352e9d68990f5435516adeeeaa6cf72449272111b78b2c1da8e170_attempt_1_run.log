import NeuralNetworks.Hopfield.Basic

section BiasedHopfieldNetwork
open HopfieldState
variable {n : ℕ}
/--
`BiasedHopfieldNetwork` extends `HopfieldNetwork` by adding a bias term
to the local field.  The bias is a function of the neuron index.
-/
structure BiasedHopfieldNetwork (n : ℕ) extends HopfieldNetwork n where
  bias : Fin n → ℝ

/--
Local field for `BiasedHopfieldNetwork` includes the bias term.
`localField_biased(x, i) = (Wx)_i - threshold[i] + bias[i]`.
-/
def biasedLocalField (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n) : ℝ :=
  localField net.toHopfieldNetwork x i + net.bias i
  -- Equivalent, more expanded form:
  -- (weightsMatrix net.toHopfieldNetwork).mulVec (toRealVector x) i - net.thresholds i + net.bias i

/--
Asynchronous update rule for `BiasedHopfieldNetwork` using the biased local field.
-/
noncomputable def biasedUpdateState (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n) : HopfieldState n :=
  Function.update x i $
    let lf := biasedLocalField net x i
    if 0 < lf then SpinState.up
    else if lf < 0 then SpinState.down
    else x i

/--
Energy function for `BiasedHopfieldNetwork`.
A possible energy function for biased Hopfield network is:
`E(x) = -1/2 xᵀWx - bᵀx - cᵀx`, where `c` is the bias vector.
In our notation: `E(x) = -1/2 xᵀWx - (thresholds + bias)ᵀx`.
Or equivalently, we can absorb the bias into the thresholds: `thresholds' = thresholds - bias`.
Then `E(x) = -1/2 xᵀWx - thresholds'ᵀx`.
And `localField_biased(x, i) = (Wx)_i - thresholds'[i]`.

We keep the original thresholds and add a separate bias term in the energy function.
`E_biased(x) = -1/2 xᵀWx - bᵀx - biasᵀx = E(x) - biasᵀx`.
`E_biased(x) = -1/2 xᵀWx - Finset.sum Finset.univ (fun i => net.thresholds i * xVec i) - Finset.sum Finset.univ (fun i => net.bias i * xVec i)`
`E_biased(x) = -1/2 xᵀWx - Finset.sum Finset.univ (fun i => (net.thresholds i + net.bias i) * xVec i)`

**Refined Energy function for Biased Hopfield Network**:
`E_biased(x) = -1/2 xᵀWx - (thresholds + bias)ᵀx`.
-/
def biasedEnergy (net : BiasedHopfieldNetwork n) (x : HopfieldState n) : ℝ :=
  let hopfield_net := net.toHopfieldNetwork
  let xVec := toRealVector x;
  let W := weightsMatrix hopfield_net;
  let B := Matrix.toBilin' W;
  -0.5 * B xVec xVec - Finset.sum Finset.univ (fun i => (net.thresholds i + net.bias i) * xVec i)

/--
UpdateSeq for BiasedHopfieldNetwork.
-/
inductive BiasedUpdateSeq {n : ℕ} (net : BiasedHopfieldNetwork n) : HopfieldState n → Type
  | nil : (x : HopfieldState n) → BiasedUpdateSeq net x
  | cons : (x : HopfieldState n) → (i : Fin n) → BiasedUpdateSeq net (biasedUpdateState net x i) → BiasedUpdateSeq net x

namespace BiasedUpdateSeq
/--
Extract the final state from a biased update sequence.
-/
noncomputable def target {n : ℕ} {net : BiasedHopfieldNetwork n} {x : HopfieldState n}
  : BiasedUpdateSeq net x → HopfieldState n
  | nil x => x
  | cons _ _ s => s.target

/--
A state `x` is a fixed point under `BiasedHopfieldNetwork` if no single-neuron update changes the state.
-/
def biasedIsFixedPoint {n : ℕ} (net : BiasedHopfieldNetwork n) (x : HopfieldState n) : Prop :=
  ∀ i, biasedUpdateState net x i = x

/--
A state `x` converges to a fixed point `p` for BiasedHopfieldNetwork if there is an update
sequence from `x` that terminates at `p`, and `p` is a biased fixed point.
-/
def biasedConvergesTo {n : ℕ} (net : BiasedHopfieldNetwork n) (x p : HopfieldState n) : Prop :=
  ∃ (seq : BiasedUpdateSeq net x), seq.target = p ∧ biasedIsFixedPoint net p
end BiasedUpdateSeq

section BiasedEnergyDecrease

open HopfieldState BiasedUpdateSeq

variable {n : ℕ} (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n)

/--
Energy difference for BiasedHopfieldNetwork.
-/
noncomputable def biasedEnergyDiff (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n) : ℝ :=
  biasedEnergy net (biasedUpdateState net x i) - biasedEnergy net x

/-
PROBLEM
The original statement below is **false** as stated: the energy function uses
`-∑ (thresh + bias) * x` while `biasedLocalField = (Wx)_i - thresh_i + bias_i`,
giving opposite sign conventions for the threshold term.
Counterexample: `n = 1, W = 0, thresh = 1, bias = 0, x = up`
gives `biasedEnergyDiff = 2` but the RHS evaluates to `-2`.

lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
sorry

Corrected version: the effective field for the energy decrease theorem
    is `(Wx)_i + thresh_i + bias_i`, not `biasedLocalField = (Wx)_i - thresh_i + bias_i`.
    Equivalently, this uses `biasedLocalField + 2 * thresh_i`.

PROVIDED SOLUTION
The energy difference when updating neuron i is E(x') - E(x) where x' = biasedUpdateState net x i differs from x only at position i.

Key steps:
1. Unfold biasedEnergyDiff, biasedEnergy to get the raw expression in terms of Matrix.toBilin' and sums.
2. The bilinear form difference: since x' = Function.update x i (new_val), x' and x agree on all j ≠ i.
   B x' x' - B x x = 2 * d_i * (W *ᵥ x)_i where d_i = x'_i - x_i (using symmetry of W and W_ii = 0).
3. The linear term difference: -∑(thresh+bias)*(x'-x) = -(thresh_i + bias_i) * d_i.
4. Combining: ΔE = -d_i * (W *ᵥ x)_i - (thresh_i + bias_i) * d_i = -d_i * ((W *ᵥ x)_i + thresh_i + bias_i).
5. Note that biasedLocalField + 2*thresh = ((Wx)_i - thresh_i + bias_i) + 2*thresh_i = (Wx)_i + thresh_i + bias_i.
6. So ΔE = -d_i * (biasedLocalField + 2*thresh_i), which is the goal.

The proof likely needs to unfold definitions, split sums into the i-th term and the rest using Finset.sum_eq_add_sum_diff_singleton, use Function.update_same and Function.update_noteq, and simplify using weights_diag_zero and weights_symmetric. Use ring for the final algebraic simplification.
-/
lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) *
      (biasedLocalField net x i + 2 * net.thresholds i) := by
  -- Let's simplify the expression for the energy difference.
  -- We use the fact that `biasedUpdateState net x i` changes only the `i`-th component of `x` and the quadratic form property.
  have h_simp : ∀ j : Fin n, (biasedUpdateState net x i j).toReal = (if j = i then (if 0 < biasedLocalField net x i then 1 else if biasedLocalField net x i < 0 then -1 else (x i).toReal) else (x j).toReal) := by
    unfold biasedUpdateState; aesop;
  -- By definition of `biasedEnergy`, we can expand both terms in the energy difference.
  have h_expand : biasedEnergy net (biasedUpdateState net x i) = -0.5 * (∑ j, ∑ k, (net.toHopfieldNetwork.weights.val j k) * ((biasedUpdateState net x i j).toReal) * ((biasedUpdateState net x i k).toReal)) - ∑ j, (net.thresholds j + net.bias j) * ((biasedUpdateState net x i j).toReal) := by
    unfold biasedEnergy;
    norm_num +zetaDelta at *;
    erw [ Matrix.toBilin'_apply' ];
    simp +decide [ Matrix.mulVec, dotProduct, Finset.mul_sum _ _ _, mul_assoc, mul_comm, mul_left_comm ];
    exact Finset.sum_congr rfl fun _ _ => Finset.sum_congr rfl fun _ _ => by ring!;
  have h_expand_x : biasedEnergy net x = -0.5 * (∑ j, ∑ k, (net.toHopfieldNetwork.weights.val j k) * ((x j).toReal) * ((x k).toReal)) - ∑ j, (net.thresholds j + net.bias j) * ((x j).toReal) := by
    unfold biasedEnergy;
    unfold Matrix.toBilin';
    unfold LinearMap.BilinForm.toMatrix';
    unfold LinearMap.toMatrix₂'; norm_num [ Matrix.mulVec, dotProduct ] ;
    erw [ Matrix.toLinearMapₛₗ₂'_apply ] ; norm_num [ Matrix.mulVec, dotProduct ] ; ring!;
    exact Finset.sum_congr rfl fun _ _ => Finset.sum_congr rfl fun _ _ => by ring!;
  -- Let's simplify the quadratic form difference using the fact that `biasedUpdateState net x i` changes only the `i`-th component of `x`.
  have h_quad_diff : ∑ j, ∑ k, (net.toHopfieldNetwork.weights.val j k) * ((biasedUpdateState net x i j).toReal) * ((biasedUpdateState net x i k).toReal) = ∑ j, ∑ k, (net.toHopfieldNetwork.weights.val j k) * ((x j).toReal) * ((x k).toReal) + 2 * ((biasedUpdateState net x i i).toReal - (x i).toReal) * (∑ k, (net.toHopfieldNetwork.weights.val i k) * ((x k).toReal)) := by
    have h_quad_diff : ∑ j, ∑ k, (net.toHopfieldNetwork.weights.val j k) * ((biasedUpdateState net x i j).toReal) * ((biasedUpdateState net x i k).toReal) = ∑ j ∈ Finset.univ.erase i, ∑ k ∈ Finset.univ.erase i, (net.toHopfieldNetwork.weights.val j k) * ((x j).toReal) * ((x k).toReal) + ∑ j ∈ Finset.univ.erase i, (net.toHopfieldNetwork.weights.val j i) * ((x j).toReal) * ((biasedUpdateState net x i i).toReal) + ∑ k ∈ Finset.univ.erase i, (net.toHopfieldNetwork.weights.val i k) * ((biasedUpdateState net x i i).toReal) * ((x k).toReal) + (net.toHopfieldNetwork.weights.val i i) * ((biasedUpdateState net x i i).toReal) * ((biasedUpdateState net x i i).toReal) := by
      simp +decide [ Finset.sum_add_distrib, Finset.sum_ite, Finset.filter_ne', Finset.filter_eq', * ];
      split_ifs <;> ring;
    have h_diag_zero : (net.toHopfieldNetwork.weights.val i i) = 0 := by
      convert congr_fun ( net.toHopfieldNetwork.weights.2.2 ) i using 1;
    have h_symm : ∀ j k : Fin n, (net.toHopfieldNetwork.weights.val j k) = (net.toHopfieldNetwork.weights.val k j) := by
