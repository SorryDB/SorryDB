  simp only [IntervalIntegrable, MeasureTheory.IntegrableOn]
  constructor <;> intro ⟨h1, h2⟩ <;> constructor
  · exact (MeasureTheory.integrable_smul_iff hr f).mpr h1
  · exact (MeasureTheory.integrable_smul_iff hr f).mpr h2
  · exact (MeasureTheory.integrable_smul_iff hr f).mp h1
  · exact (MeasureTheory.integrable_smul_iff hr f).mp h2

