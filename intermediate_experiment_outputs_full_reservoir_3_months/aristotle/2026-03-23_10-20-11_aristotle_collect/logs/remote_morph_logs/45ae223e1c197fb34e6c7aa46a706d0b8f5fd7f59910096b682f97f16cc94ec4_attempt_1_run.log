    have c24 : f a = 0 := by simpa [Function.mem_support] using c23
    simpa [c22] using c24
  have c3 : ∫ x in I, A * √(4 * v - (x - μ) ^ 2) = A * ∫ x in I, √(4 * v - (x - μ) ^ 2) := by
