        have c5121 : ∫ (x : ℝ) in 0..π, F₁ x = ∫ (x : ℝ) in 0..π, F₂ x := by rw [c5120]
        dsimp [F₁, F₂] at c5121; dsimp [F₁]; rw [c5121]
