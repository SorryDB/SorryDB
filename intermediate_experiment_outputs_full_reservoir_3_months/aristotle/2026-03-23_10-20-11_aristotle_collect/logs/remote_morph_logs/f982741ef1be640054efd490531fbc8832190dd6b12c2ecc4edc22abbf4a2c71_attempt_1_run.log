/-- The \tilde{Пғ}_n defined in Lemma 6, also in equation (S40) in Lemma 7. -/
noncomputable def Lemma6_Пғn (m : в„•) (Пғf : MState (H i)) (ПғвӮҳ : MState (H (i ^ m))) : (n : в„•) вҶ’ MState (H (i ^ n)) :=
