theorem Lemma6_Пғn_IsFree {ПғвӮҒ : MState (H i)} {ПғвӮҳ : (m : в„•) вҶ’ MState (H (i ^ m))} (hПғвӮҒ_free : IsFree ПғвӮҒ)
    (hПғвӮҳ : вҲҖ (m : в„•), ПғвӮҳ m вҲҲ IsFree) (m n : в„•) : Lemma6_Пғn m ПғвӮҒ (ПғвӮҳ m) n вҲҲ IsFree := by
  rw [Lemma6_Пғn, relabel_cast_isFree]
  В· apply free_prod --pick a better name / alias for this
    В· exact (hПғвӮҳ m).npow (n / m)
    В· exact hПғвӮҒ_free.npow (n % m)
  В· rw [вҶҗ pow_mul, вҶҗ spacePow_add, Nat.div_add_mod n m]

--Didn't end up actually needing this for the proof, but I suppose it's a good fact to have
--all the same. On the 1D Hilbert space, the optimal hypothesis testing rate is simply 1 - Оө,
--since there's nothing to learn. (More generally this would hold whenever ПҒ=Пғ.)
--PULLOUT to HypothesisTesting.lean
theorem optimalHypothesisRate_unique {d : Type*} [Fintype d] [DecidableEq d]
    (Оө : Prob) (ПҒ Пғ : MState d) [Unique d] : ОІ_ Оө(ПҒвҖ–{Пғ}) = 1 - Оө := by
  obtain rfl := Unique.eq_default ПҒ
  obtain rfl := Unique.eq_default Пғ
  rw [OptimalHypothesisRate.of_singleton]
  apply le_antisymm
  В· refine iInf_le_of_le вҹЁ((1 - Оө : Prob) : в„қ) вҖў 1, вҹЁ?_, ?_, ?_вҹ©вҹ© ?_
    В· simp [MState.exp_val_sub]
    В· apply smul_nonneg ?_ zero_le_one
      simp
    В· apply smul_le_of_le_one_left zero_le_one
      simp
    В· simp [-Prob.coe_one_minus]
  В· simp
    intro a ha he1 ha0 ha1
    rw [MState.exp_val_sub, MState.exp_val_one, tsub_le_iff_right] at he1
    rw [вҶҗ tsub_le_iff_left, вҶҗ Prob.coe_one_minus] at he1
    exact he1

/-- Lemma 6 from the paper.
We _did_ end up doing the version that "works also in the case of Оө = 0", which is nice.
-/
private theorem Lemma6 {m : в„•} (hm : 0 < m) (ПҒ Пғf : MState (H i)) (ПғвӮҳ : MState (H (i ^ m)))
    (hПғf : Пғf.m.PosDef) {Оө : Prob} (hОө : Оө < 1) :
  Filter.atTop.limsup (fun n вҶҰ вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Lemma6_Пғn m Пғf ПғвӮҳ n}) / n) вүӨ рқҗғ(ПҒвҠ—^S[m]вҖ–ПғвӮҳ) / m
  := by

  set Пғn := Lemma6_Пғn m Пғf ПғвӮҳ with hПғn

  have h_add : вҲҖ Оұ n, DМғ_ Оұ(ПҒвҠ—^S[n]вҖ–Пғn n) = (n/m : в„•) * DМғ_ Оұ(ПҒвҠ—^S[m]вҖ–ПғвӮҳ) + (n%m : в„•) * DМғ_ Оұ(ПҒвҖ–Пғf):= by
    --"Break apart" Пғn, and apply additivity of `SandwichedRelRentropy`.
    intro Оұ n
    rw [hПғn, Lemma6_Пғn]
    have hnm_add := Nat.div_add_mod n m
    rw [statePow_rw hnm_add.symm, statePow_add_relabel]
    have hnm_eq : (i ^ (m * (n / m)) * i ^ (n % m)) = (i ^ m) ^ (n / m) * i ^ (n % m) := by
      rw [pow_mul]
    have h_Hn_eq : H (i ^ n) = H ((i ^ m) ^ (n / m) * i ^ (n % m)) := by
      rw [вҶҗ pow_mul, вҶҗ pow_add, hnm_add]
    simp only [MState.relabel_relabel, Equiv.cast_trans]
    rw [вҶҗ sandwichedRelRentropy_statePow]
    rw [вҶҗ sandwichedRelRentropy_statePow]
    rw [вҶҗ sandwichedRelRentropy_prodRelabel]

    gcongr
    В· rw [MState.eq_relabel_iff]
      simp only [MState.relabel_relabel, Equiv.cast_symm, Equiv.cast_trans]
      rw [prodRelabel_relabel_cast_prod _ _ _ ((pow_mul ..).symm) rfl]
      congr
      rw [statePow_mul_relabel]
      simp
    В· simp

  --This will probably need 1 < Оұ actually
  have h_Оұ : вҲҖ Оұ, (1 < Оұ) вҶ’ Filter.atTop.limsup (fun n вҶҰ вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғn n}) / n) вүӨ
      DМғ_ Оұ(ПҒвҠ—^S[m]вҖ–ПғвӮҳ) / m := by
    intro Оұ hОұ
    apply le_of_le_of_eq (b := Filter.atTop.limsup (fun n вҶҰ DМғ_ Оұ(ПҒвҠ—^S[n]вҖ–Пғn n) / n))
    В· --Apply the "[81] Lemma 5" to ПҒвҠ—^n and Пғn
      have h_lem5 (n) := OptimalHypothesisRate.Ref81Lem5 (ПҒвҠ—^S[n]) (Пғn n) Оө hОө Оұ hОұ

      --Upper-bound ОІ on the LHS with this lemma
      --Distribute the limsup over subtraction
      --The term on the right is a constant, divided by n, which converges to zero.
      --Dropping that leaves the identity
      generalize_proofs pf1 pf2 at h_lem5
      let x n :=  вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғn n})
      let y n := DМғ_ Оұ(ПҒвҠ—^S[n]вҖ–Пғn n)
      set z := вҖ”log (1 - Оө) * (ENNReal.ofNNReal вҹЁОұ, pf1вҹ©) / (ENNReal.ofNNReal вҹЁОұ - 1, pf2вҹ©)

      have hz : z вү  вҠӨ := by
        unfold z
        have hz1 : вҖ”log (1 - Оө) вү  вҠӨ := by
          --TODO: should be `bound`, ideally
          simp [Subtype.eq_iff]
          have : (Оө : в„қ) < 1 := hОө
