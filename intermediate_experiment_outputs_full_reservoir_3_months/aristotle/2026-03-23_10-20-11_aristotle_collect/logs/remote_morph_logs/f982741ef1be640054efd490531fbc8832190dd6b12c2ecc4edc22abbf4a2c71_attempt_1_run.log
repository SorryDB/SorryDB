        вҶҗ ENNReal.ofReal_mul (by simp)]
    rhs
    rw [вҶҗ ENNReal.toReal_sub_of_le hR1R2.le hR2]

    equals (1 - Оө'.val) * (R2 ПҒ Пғ - R1 ПҒ Оө).toReal =>
      unfold ОөвӮҖ
      field_simp [show 1 - Оө.val вү  0 from ne_of_gt (sub_pos.mpr hОө)]
      ring_nf
  rw [ENNReal.ofReal_mul (by simp), Prob.ofNNReal_toNNReal,
    ENNReal.ofReal_toReal (by simp [hR1, hR2]), Prob.coe_one_minus]

/-- Lemma 7 from the paper. We write `Оө'` for their `\tilde{Оө}`. -/
private theorem Lemma7 (ПҒ : MState (H i)) {Оө : Prob} (hОө : 0 < Оө вҲ§ Оө < 1) (Пғ : (n : в„•) вҶ’ IsFree (i := i ^ n)) :
    (R2 ПҒ Пғ вүҘ R1 ПҒ Оө) вҶ’
    вҲҖ Оө' : Prob, (hОө' : 0 < Оө' вҲ§ Оө' < Оө) вҶ’ -- Оө' is written as \tilde{Оө} in the paper.
    вҲғ Пғ' : (n : в„•) вҶ’ IsFree (i := i ^ n),
    R2 ПҒ Пғ' - R1 ПҒ Оө вүӨ .ofNNReal (1 - Оө' : Prob) * (R2 ПҒ Пғ - R1 ПҒ Оө)
    := by
  --This proof naturally splits out into LemmaS62:
  --  `lim inf nвҶ’вҲһ 1/n D(E_n(ПҒ^вҠ—n)вҖ–Пғ''_n) вҲ’ R1,Пө вүӨ (1 вҲ’ ЛңПө)(R2 вҲ’ R1,Пө).`
  --which is proved above. Here, set up the preliminiaries (appropriate finiteness
  -- conditions, nonzeroness, etc.) get S62, prove S61, and the conclusion is just `rw [S61] at S62`.

  --First deal with the easy case of R1 = R2.
  intro hR1R2 Оө' вҹЁhОө'вӮҒ, hОө'вӮӮвҹ©
  rw [ge_iff_le, le_iff_lt_or_eq, or_comm] at hR1R2
  rcases hR1R2 with hR1R2|hR1R2
  В· use Пғ
    simp [hR1R2]
  --This leaves us with the stronger statement that R1 < R2 strictly.
  --Before proceeding, let's reduce to the case that they're finite.
  have hR1 : R1 ПҒ Оө вү  вҠӨ := hR1R2.ne_top
  rcases eq_or_ne (R2 ПҒ Пғ) вҠӨ with hR2|hR2
  В· rw [hR2, ENNReal.top_sub hR1, ENNReal.mul_top', if_neg]
    В· simp
    В· have : Оө'.val < 1 := hОө'вӮӮ.trans hОө.2
      rcases Оө' with вҹЁОө', hОө'вӮҒ, hОө'вӮӮвҹ©
      simp only [Prob.toNNReal, Prob.coe_one_minus, ENNReal.coe_eq_zero]
      rw [Subtype.ext_iff, val_eq_coe, val_eq_coe, coe_zero, coe_mk]
      grind

  let ОөвӮҖ : в„қ := (R2 ПҒ Пғ - R1 ПҒ Оө).toReal * (Оө - Оө') / (1 - Оө)
  have hОөвӮҖ : 0 < ОөвӮҖ :=
    have := sub_pos.mpr (show Оө.val < 1 from hОө.2)
    have := sub_pos.mpr (show Оө'.val < Оө from hОө'вӮӮ)
    have : 0 < (SteinsLemma.R2 ПҒ Пғ - SteinsLemma.R1 ПҒ Оө).toReal :=
      ENNReal.toReal_pos (tsub_pos_of_lt hR1R2).ne' (ENNReal.sub_ne_top hR2)
    by positivity
  have hОөвӮҖ' : (R1 ПҒ Оө).toReal вүӨ (R2 ПҒ Пғ).toReal + ОөвӮҖ := by
    dsimp [ОөвӮҖ]
    rw [вҶҗ sub_nonneg]
    have _ := sub_pos.mpr (show Оө.val < 1 from hОө.2)
    have _ := sub_pos.mpr (show Оө'.val < Оө from hОө'вӮӮ)
    rw [ENNReal.toReal_sub_of_le hR1R2.le (by finiteness)]
    field_simp
    suffices h : 0 вүӨ ((R2 ПҒ Пғ).toReal - (R1 ПҒ Оө).toReal) * ((вҶ‘Оө - вҶ‘Оө') + (1 - вҶ‘Оө)) by
      convert h using 1
      В· exact zero_mul _
      В· ring_nf
    rw [вҶҗ ENNReal.toReal_sub_of_le hR1R2.le (by finiteness)]
    positivity

  -- m exists because R2 + ОөвӮҖ is strictly above R2, which is the liminf.
  obtain вҹЁm, hmвҹ© :=
    have h : R2 ПҒ Пғ < R2 ПҒ Пғ + .ofNNReal вҹЁОөвӮҖ, hОөвӮҖ.leвҹ© :=
      ENNReal.lt_add_right hR2 (by simp [вҶҗ NNReal.coe_eq_zero, hОөвӮҖ.ne'])
    (Filter.frequently_lt_of_liminf_lt (h := h)).forall_exists_of_atTop 1

  have qRel_Пғ''_le_Пғ' n : рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' ПҒ Оө m Пғ n) вүӨ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' ПҒ Оө m Пғ n) + ENNReal.ofReal (ПғвӮҒ_c i n) := by
    rw [вҶҗ Real.log_exp (ПғвӮҒ_c i n)]
    apply qRelEntropy_le_add_of_le_smul
    apply Пғ''_le_Пғ'

  have qRel_Пғ'_le_Пғ'' n : рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' ПҒ Оө m Пғ n) вүӨ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' ПҒ Оө m Пғ n) + ENNReal.ofReal (ПғвӮҒ_c i n) := by
    rw [вҶҗ Real.log_exp (ПғвӮҒ_c i n)]
    apply qRelEntropy_le_add_of_le_smul
    rw [вҶҗ inv_smul_le_iff_of_pos (by positivity), вҶҗ Real.exp_neg]
    apply Пғ'_le_Пғ''

  -- Definition of the pinching map w.r.t. Пғ'' in Eq. (S55)
  let в„° n := pinching_map (Пғ'' ПҒ Оө m Пғ n)

  -- Number of distinct eigenvalues of Пғ'' in Eq. (S56) is
  -- Fintype.card (spectrum в„қ (Пғ'' n).m), which is dвӮҷ in the paper.
  have hdle n : Fintype.card (spectrum в„қ (Пғ'' ПҒ Оө m Пғ n).m) вүӨ n + 1 := by
    rw [(Пғ'' ПҒ Оө m Пғ n).M.H.card_spectrum_eq_image (A := (Пғ'' ПҒ Оө m Пғ n).m)]
    rcases n.eq_zero_or_pos with rfl | hn
    В· have _ : Unique (H (i ^ 0)) := by
        rw [spacePow_zero]
        infer_instance
      simp
    rw [вҶҗ Set.ncard_coe_finset]
    simp only [Finset.coe_image, Finset.coe_univ, Set.image_univ]
    have eq : вҲғ (e : Equiv.Perm _), (Пғ'' ПҒ Оө m Пғ n).M.H.eigenvalues =
        (fun x вҶҰ (Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ * Real.exp (f_map i n x)) вҲҳ (Пғ' ПҒ Оө m Пғ n).M.H.eigenvalues вҲҳ e := by
      convert (Пғ' ПҒ Оө m Пғ n).M.cfc_eigenvalues (fun x вҶҰ (Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ * Real.exp (f_map i n x))
      rw [HermitianMat.cfc_const_mul, вҶҗ Пғ''_unnormalized, Пғ'']
    rcases eq with вҹЁeq, heqвҹ©
    rw [heq]
    simp only [Set.range_comp, MState.toMat_M, EquivLike.range_eq_univ, Set.image_univ, ge_iff_le]
    let S : Set в„қ := (fun x => Real.exp (f_map i n x)) '' Set.Icc ((ПғвӮҒ_mineig i ^ n) / 3) 1
    have h_card_subs : Set.ncard S вүӨ n + 1 вҲ§ S.Finite := by
      exact f_image_bound (ПғвӮҒ_mineig i) n (mineig_pos i) hn (log_le_f i) (f_le_log i)
    let SвӮӮ : Set в„қ := (fun x => (Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ * Real.exp (f_map i n x)) '' Set.Icc ((ПғвӮҒ_mineig i ^ n) / 3) 1
    obtain вҹЁh_card_subsвӮӮ, h_sвӮӮ_finiteвҹ© : Set.ncard SвӮӮ вүӨ n + 1 вҲ§ SвӮӮ.Finite := by
      have hSвӮӮ : SвӮӮ = ((Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ * В·) '' S := by
        simp [S, SвӮӮ, Set.image_image]
      constructor
      В· rw [hSвӮӮ]
        exact (Set.ncard_image_le h_card_subs.right).trans h_card_subs.left
      В· rw [hSвӮӮ]
        exact h_card_subs.right.image _
    refine (Set.ncard_le_ncard (t := (fun x => (Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ *
      Real.exp (f_map i n x)) '' Set.Icc (((ПғвӮҒ_mineig i) ^ n) / 3) 1) ?_ h_sвӮӮ_finite).trans h_card_subsвӮӮ
    apply Set.image_mono
    rintro _ вҹЁk, rflвҹ©
    refine вҹЁ?_, MState.eigenvalue_le_one _ _вҹ©
    refine le_trans ?_ (ciInf_le (Finite.bddBelow_range _) k)
    refine le_trans ?_ ((HermitianMat.H _).iInf_eigenvalues_le (hПғвӮҒ_le_Пғ' ПҒ Оө m Пғ n) _)
    dsimp [ПғвӮҒ_mineig, iInf]
    rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
    rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
    rw [spectrum.smul_eq_smul _ _ (CFC.spectrum_nonempty в„қ _ ((ПғвӮҒ i)вҠ—^S[n]).M.H)]
    rw [Real.sInf_smul_of_nonneg (by norm_num)]
    simp [MState.toMat_M, div_eq_inv_mul, sInf_spectrum_spacePow]

  have hdpos n : 0 < Fintype.card (spectrum в„қ (Пғ'' ПҒ Оө m Пғ n).m) := by
    rw [Fintype.card_pos_iff, Set.nonempty_coe_sort]
    apply IsSelfAdjoint.spectrum_nonempty
    exact (Пғ'' ПҒ Оө m Пғ n).M.H

  -- Eq. (S60)
  have qRel_ent_bound n : рқҗғ(ПҒвҠ—^S[n]вҖ–в„° n (ПҒвҠ—^S[n])) вүӨ ENNReal.ofReal (Real.log (n + 1)) := calc
    рқҗғ(ПҒвҠ—^S[n]вҖ–в„° n (ПҒвҠ—^S[n])) вүӨ ENNReal.ofReal (Real.log (Fintype.card (spectrum в„қ (Пғ'' ПҒ Оө m Пғ n).m))) :=
      qRelativeEnt_op_le (by simp [hdpos n]) (pinching_bound ..)
    _ вүӨ ENNReal.ofReal (Real.log (n + 1)) := by
      grw [hdle n]
      В· exact_mod_cast le_rfl
      В· simp [hdpos n]

  -- Eq. (S61)
  have hliminf : Filter.atTop.liminf (fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' ПҒ Оө m Пғ n) / n) =
                 Filter.atTop.liminf (fun n вҶҰ рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' ПҒ Оө m Пғ n) / n) := by
    trans Filter.atTop.liminf fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' ПҒ Оө m Пғ n) / n
    В· have hg : Filter.atTop.Tendsto (fun n вҶҰ ENNReal.ofReal (ПғвӮҒ_c i n) / n) (рқ“қ 0) := by
        rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
        В· simp [ENNReal.toReal_ofReal (ПғвӮҒ_c_pos i _).le]
          exact ПғвӮҒ_c_div_lim i
        В· rw [Filter.eventually_atTop]
          use 1
          intros
          finiteness
      apply le_antisymm
      В· nth_rw 2 [вҶҗ ENNReal.liminf_add_of_right_tendsto_zero hg]
        conv =>
          enter [2, 1, n]
          rw [Pi.add_apply, вҶҗ ENNReal.add_div]
        apply Filter.liminf_le_liminf (ОІ := в„қвүҘ0вҲһ)
        rw [Filter.eventually_atTop]
        use 1
        intro n _
        exact ENNReal.div_le_div (qRel_Пғ'_le_Пғ'' n) (by rfl)
      -- A copy of the В· above with Пғ' and Пғ'' swapped
      В· nth_rw 2 [вҶҗ ENNReal.liminf_add_of_right_tendsto_zero hg]
        conv =>
          enter [2, 1, n]
          rw [Pi.add_apply, вҶҗ ENNReal.add_div]
        apply Filter.liminf_le_liminf (ОІ := в„қвүҘ0вҲһ)
        rw [Filter.eventually_atTop]
        use 1
        intro n _
        exact ENNReal.div_le_div (qRel_Пғ''_le_Пғ' n) (by rfl)
    В· -- Eq (S59) has a minus sign, which gets complicated when one of the relative entropies is infinite.
      -- However, I don't think we need this version with the minus sign.
      have h_pinching := fun n вҶҰ pinching_pythagoras (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
      simp only [h_pinching, ENNReal.add_div, вҶҗ Pi.add_apply]
      conv_lhs =>
        apply ENNReal.liminf_add_of_left_tendsto_zero
        tactic =>
          apply tendsto_of_tendsto_of_tendsto_of_le_of_le
            (g := (0 : в„• вҶ’ в„қвүҘ0вҲһ)) (h := fun n вҶҰ ENNReal.ofReal (Real.log (n + 1)) / n)
          В· exact tendsto_const_nhds
          В·  -- Basically that lim_nвҶ’вҲһ log n / n = 0
            rw [вҶҗ Filter.tendsto_sub_atTop_iff_nat 1]
            apply Filter.Tendsto.congr' (fвӮҒ := fun (n : в„•) вҶҰ ENNReal.ofReal (Real.log n / (n - 1)))
            В· simp only [Filter.EventuallyEq, вҶҗ ENNReal.ofReal_natCast, Filter.eventually_atTop]
              use 2; intros b hb
              convert ENNReal.ofReal_div_of_pos (y := b - 1) (by rify at b hb; linarith)
              В· norm_cast
                omega
              В· norm_cast; symm; apply Int.subNatNat_of_le
                omega
            refine Filter.Tendsto.comp (g := fun r вҶҰ ENNReal.ofReal (Real.log r / (r - 1)))
              ?_ tendsto_natCast_atTop_atTop
            rw [вҶҗ ENNReal.ofReal_zero]
            apply ENNReal.tendsto_ofReal
            convert Real.tendsto_pow_log_div_mul_add_atTop 1 (-1) 1 (zero_ne_one.symm) using 3
            В· simp
            В· ring
          В· positivity
          В· intro n
            exact ENNReal.div_le_div (qRel_ent_bound n) le_rfl

  use fun n вҶҰ вҹЁПғ' ПҒ Оө m Пғ n, Пғ'_free ПҒ Оө m Пғ nвҹ©
  rw [R2, hliminf]
  exact EquationS62 ПҒ Пғ hОө'вӮҒ hОө'вӮӮ hОө.2 hR1R2 hR1 hR2 hОөвӮҖ hОөвӮҖ' m hm

/-- Lemma 7 gives us a way to repeatedly "improve" a sequence Пғ to one with a smaller gap between R2 and R1.
The paper paints this as pretty much immediate from Lemma7, but we need to handle the case where R2 is below
R1. -/
private noncomputable def Lemma7_improver (ПҒ : MState (H i)) {Оө : Prob} (hОө : 0 < Оө вҲ§ Оө < 1) {Оө' : Prob} (hОө' : 0 < Оө' вҲ§ Оө' < Оө) :
    --The parameters above are the "fixed" parameters that we'll improve
    --It takes one sequence of free states, `(n : в„•) вҶ’ IsFree (i := i ^ n)`, and gives a new one
    ((n : в„•) вҶ’ IsFree (i := i ^ n)) вҶ’ ((n : в„•) вҶ’ IsFree (i := i ^ n)) :=
  fun Пғ вҶҰ
    if h : R2 ПҒ Пғ вүҘ R1 ПҒ Оө then
      (Lemma7 ПҒ hОө Пғ h Оө' hОө').choose
    else
     Пғ --The gap was already 0 (or even, negative!) so leave it unchanged.

/-- The Lemma7_improver does its job at shrinking the gap. -/
theorem Lemma7_gap (ПҒ : MState (H i)) {Оө : Prob} (hОө : 0 < Оө вҲ§ Оө < 1) {Оө' : Prob} (hОө' : 0 < Оө' вҲ§ Оө' < Оө) :
    вҲҖ Пғ,
      letI Пғ' := Lemma7_improver ПҒ hОө hОө' Пғ;
      R2 ПҒ Пғ' - R1 ПҒ Оө вүӨ .ofNNReal (1 - Оө' : Prob) * (R2 ПҒ Пғ - R1 ПҒ Оө) := by
  intro Пғ
  dsimp [SteinsLemma.Lemma7_improver]
  split_ifs with h
  В· exact (SteinsLemma.Lemma7 ПҒ hОө Пғ h Оө' hОө').choose_spec
  В· push_neg at h
    rw [tsub_eq_zero_of_le h.le]
    exact zero_le _

end Lemma7

/-- Theorem 1 in https://arxiv.org/pdf/2408.02722v3 -/
theorem GeneralizedQSteinsLemma {i : О№} (ПҒ : MState (H i)) {Оө : Prob} (hОө : 0 < Оө вҲ§ Оө < 1) :
    Filter.atTop.Tendsto (fun n вҶҰ вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–IsFree) / n) (рқ“қ (рқ‘…бөЈвҲһ ПҒ)) := by

  --It suffices to show limsup LHS вүӨ RHS and liminf LHS вүҘ RHS.
  refine tendsto_of_le_liminf_of_limsup_le ?_ ?_
  В· -- the "key part" of the "opposite inequality".
    --We need to pick an Оө' (a \tilde{Оө} in the paper). The only constraint(?) is that it's strictly
    --less than Оө. We take Оө' := Оө/2.
     --TODO: Should we have an HDiv Prob Nat instance?
    let Оө' : Prob := вҹЁОө/2, by constructor <;> linarith [Оө.zero_le_coe, Оө.coe_le_one]вҹ©
    have hОө' : 0 < Оө' вҲ§ Оө' < Оө := by constructor <;> change (_ : в„қ) < (_ : в„қ) <;> simpa [Оө'] using hОө.1

    --Take some initial sequence ПғвӮҒ. We need to pick it so that `R2 ПҒ ПғвӮҒ` is finite, otherwise we can't "shrink"
    --it by applying Lemma 7. Taking the full-rank state of dimension `H i` and taking all powers of it, works.
    set ПғвӮҒ : (n : в„•) вҶ’ IsFree (i := i ^ n) := fun n вҶҰ
      вҹЁ(free_fullRank i).choose вҠ—^S[n], IsFree.npow (free_fullRank i).choose_spec.2 nвҹ© with hПғвӮҒ
    have hПғвӮҒ_top : R2 ПҒ ПғвӮҒ вү  вҠӨ := by
      rw [R2, вҶҗ Filter.liminf_nat_add _ 1]
      simp [ПғвӮҒ, mul_comm _ (qRelativeEnt _ _)]
      conv =>
        enter [1,1,1,n]
        rw [ENNReal.mul_div_cancel_right (by positivity) (by finiteness)]
      simp [qRelativeEnt_ne_top (free_fullRank i).choose_spec.1]
    clear hПғвӮҒ
    --Repeat the Lemma7 improvement process to drive the gap down
    let ПғвӮ– : в„• вҶ’ (n : в„•) вҶ’ IsFree (i := i ^ n) := fun k вҶҰ
      (Lemma7_improver ПҒ hОө hОө')^[k] ПғвӮҒ

    --The gap between R_{1,Оө} and R2 for `ПғвӮ– k` goes to 0 as `k вҶ’ вҲһ`.
    have hПғвӮ–_gap : Filter.atTop.Tendsto (fun k вҶҰ R2 ПҒ (ПғвӮ– k) - R1 ПҒ Оө) (рқ“қ 0) := by
      suffices h : вҲҖ (k : в„•), R2 ПҒ (ПғвӮ– k) - R1 ПҒ Оө вүӨ вҶ‘(1 - Оө')^k * (R2 ПҒ ПғвӮҒ - R1 ПҒ Оө) by
        refine tendsto_nhds_bot_mono' ?_ h
        conv =>
          enter [3, 1]
          equals 0 * (R2 ПҒ ПғвӮҒ - R1 ПҒ Оө) => simp
        apply ENNReal.Tendsto.mul_const
        В· simp only [ENNReal.tendsto_pow_atTop_nhds_zero_iff]
          --This should just be `simp` or `bound` at this point. TODO.
          simp [Prob.toNNReal, вҶҗ NNReal.coe_lt_coe, hОө'.1]
        В· right; exact ENNReal.sub_ne_top hПғвӮҒ_top
      suffices h : вҲҖ (m k : в„•), R2 ПҒ (ПғвӮ– (m + k)) - R1 ПҒ Оө вүӨ (1 - Оө')^k * (R2 ПҒ (ПғвӮ– m) - R1 ПҒ Оө) by
        convert h 0; simp
      intro m k; induction k generalizing m
      В· simp [ПғвӮ–]
      rename_i k ih
      have ПғвӮ–_succ (n) : ПғвӮ– (n + 1) = Lemma7_improver ПҒ hОө hОө' (ПғвӮ– n) :=
        Function.iterate_succ_apply' ..
      rw [вҶҗ add_assoc, ПғвӮ–_succ, pow_succ]
      grw [Lemma7_gap ПҒ hОө hОө' (ПғвӮ– (m + k)), ih m]
      ring_nf
      rfl

    replace hПғвӮ–_gap : Filter.atTop.liminf (fun k вҶҰ R2 ПҒ (ПғвӮ– k)) вүӨ R1 ПҒ Оө := by
      rw [ENNReal.tendsto_sub_const_nhds_zero_iff] at hПғвӮ–_gap
      grw [Filter.liminf_le_limsup, hПғвӮ–_gap]

    rw [R1] at hПғвӮ–_gap
    grw [вҶҗ hПғвӮ–_gap]; clear hПғвӮ–_gap

    have hReg := RelativeEntResource.tendsto_ennreal ПҒ
    replace hReg := hReg.liminf_eq
