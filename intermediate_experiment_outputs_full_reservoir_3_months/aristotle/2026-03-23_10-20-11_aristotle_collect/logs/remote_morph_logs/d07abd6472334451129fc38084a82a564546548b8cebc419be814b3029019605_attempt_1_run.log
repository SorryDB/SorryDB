/-
PROBLEM
8.

PROVIDED SOLUTION
We need to show Nat ∼ ↑{n : Int | even n}. Define a function f : Nat → {n : Int | even n} by f(k) = ⟨2 * fnz k, ...⟩. Since fnz : Nat → Int is a bijection (fnz_one_one, fnz_onto), the map k ↦ 2 * fnz(k) is a bijection from Nat to the even integers. To show one_to_one: if 2*fnz(k1) = 2*fnz(k2) then fnz(k1) = fnz(k2), then k1=k2 by fnz_one_one. To show onto: given even integer m, write m = 2*a, then a = fnz(k) for some k by fnz_onto, so m = 2*fnz(k) = f(k). Use denum_def to unfold, and equinum definition directly.
-/
theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  -- Define a bijection between the set of even integers and the set of natural numbers.
  have h_bij : ∃ f : {n : ℤ | even n} → ℕ, Function.Bijective f := by
    have h_bij : Nonempty ( {n : ℤ | even n} ≃ ℕ ) := by
      norm_num +zetaDelta at *;
      refine' Cardinal.eq.1 _;
      rw [ show { n : ℤ // even n } = ( Set.range fun n : ℤ => 2 * n ) from ?_ ];
      · rw [ Cardinal.mk_range_eq ] ; aesop;
        exact mul_right_injective₀ two_ne_zero;
      · congr with x ; simp +decide [ even_iff_two_dvd ] ; aesop;
    exact ⟨ _, Equiv.bijective h_bij.some ⟩;
  obtain ⟨ f, hf ⟩ := h_bij;
  obtain ⟨ g, hg ⟩ := hf;
  use Equiv.ofBijective f ⟨ g, hg ⟩ |> Equiv.symm;
  exact ⟨ Equiv.injective _, Equiv.surjective _ ⟩

