    comm g := by
      ext (u : Additive Lˣ)
      obtain ⟨u, rfl⟩ := Additive.ofMul.surjective u
      -- should follow from `valuation_ringEquiv`
      sorry
  }
  zero := by
    ext x
    exact (ker_v_ker (K := L) (ker_v L x)).mpr ⟨x, rfl⟩

