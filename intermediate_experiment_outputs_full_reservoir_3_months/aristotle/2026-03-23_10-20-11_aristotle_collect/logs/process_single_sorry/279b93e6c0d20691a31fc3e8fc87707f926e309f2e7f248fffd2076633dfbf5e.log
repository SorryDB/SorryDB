import Clean.Circuit
import Clean.Utils.Field
import Clean.Utils.Tactics

namespace Circomlib
variable {p : ℕ} [Fact p.Prime] [Fact (p > 2)]

/-
Original source code:
https://github.com/iden3/circomlib/blob/master/circuits/sha256/rotate.circom
-/

namespace RotR

/-
template RotR(n, r) {
    signal input inp[n];
    signal output out[n];

    for (var i = 0; i < n; i++) {
        out[i] <== inp[ (i+r)%n ];
    }
}
-/
def main (n r : ℕ) [NeZero n] (inp : Vector (Expression (F p)) n) := do
  let out <== Vector.mapFinRange n fun i => inp.get (i + Fin.ofNat n r)
  return out

def circuit (n r : ℕ) [NeZero n] : FormalCircuit (F p) (fields n) (fields n) where
  main := main n r

  localLength _ := n

  Spec input output := output = input.rotate r

  soundness := by
    circuit_proof_start
    rw [h_holds]
    ext i hi
    simp only [Vector.getElem_map, Vector.getElem_mapFinRange, Vector.getElem_rotate]
    conv_lhs => rw [show Vector.get input_var (⟨i, hi⟩ + Fin.ofNat n r) = input_var[(⟨i, hi⟩ + Fin.ofNat n r).val] from rfl]
    have hval : (⟨i, hi⟩ + Fin.ofNat n r : Fin n).val = (i + r) % n := by
      simp [Fin.add_def, Fin.ofNat, Fin.val_mk]
    simp only [hval]
    have hmod : (i + r) % n < n := Nat.mod_lt _ (by omega)
    have : (Vector.map (Expression.eval env) input_var)[(i + r) % n]'hmod = input[(i + r) % n]'hmod := by
      rw [h_input]
    simp [Vector.getElem_map] at this
    exact this

  completeness := by
    circuit_proof_start
    sorry

end RotR
end Circomlib

