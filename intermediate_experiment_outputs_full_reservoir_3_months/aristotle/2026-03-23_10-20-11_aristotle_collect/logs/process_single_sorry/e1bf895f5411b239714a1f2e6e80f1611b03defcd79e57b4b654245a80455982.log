import Mathlib.Data.QPF.Multivariate.Constructions.Cofix
import Mathlib.Logic.Small.Defs

namespace MvQPF
open MvFunctor
open TypeVec

universe u v w

variable {n} (F : TypeVec.{u} (n + 1) → Type u) [MvQPF F]

/-- A pointed coalgebra -/
structure Coalg (α : TypeVec.{u} n) : Type (u+1) where
  corec ::
    {σ : Type u}
    (dest' : σ → F (α ::: σ))
    (s : σ)

/-- info: @Coalg.corec n F α : {σ : Type u} → (σ → F (α ::: σ)) → σ → Coalg F α -/
#guard_msgs (whitespace := lax) in
  variable {α} in
  #check (@Coalg.corec _ F α)

variable {F} {α : TypeVec.{u} n}

namespace Coalg
variable {self : Coalg F α}

/-! ## Basic API -/

/-!
NOTE: we'd like to define a `dest` function like so:
```
def dest (self : StateCofix F α) : F (α ::: (StateCofix F α)) := _
```
However, this doesn't type-check, because of the universe bump in `StateCofix`,
so we content ourselves with having the current `dest` projection, which returns
a state in the current coalgebra.
-/

def dest (self : Coalg F α) : F (α ::: self.σ) := self.dest' self.s

/-! ## Bisim -/

def IsBisim (R : self.σ → self.σ → Prop) : Prop :=
    ∀ s t, R s t →
      LiftR (RelLast _ R) (self.dest' s) (self.dest' t)

/-
The following definition using `coinductive_fixpoint` fails
-/

-- def BisimStates' (self : StateCofix F α) : self.σ → self.σ → Prop :=
--   fun s t =>
--     let R := RelLast _ (BisimStates' self)
--     LiftR R (self.dest' s) (self.dest' t)
--   coinductive_fixpoint
-- ^^ Fails to show monotonicity
--    TODO: ask wojciech


/--
Given two pointed coalgebras `c` and `d`, return the disjoint union coalgebra which
embeds both coalgebras, with `c` as the designated point, together with the state
of the union coalgebra which represents `d`.
-/
def union (c d : Coalg F α) : Coalg F α where
  σ := c.σ ⊕ d.σ
  s := .inl c.s
  dest' s := match s with
          | .inl s => MvFunctor.map (TypeVec.id ::: .inl) (c.dest' s)
          | .inr s => MvFunctor.map (TypeVec.id ::: .inr) (d.dest' s)


def Bisim : Coalg F α → Coalg F α → Prop := fun c d =>
  let un := c.union d
  ∃ R, IsBisim (self := un) R ∧ R (.inl c.s) (.inr d.s)

infixl:60 " ~ " => Bisim

section UnionLemmas

theorem union_dest_eq_left (c d : Coalg F α) (s : c.σ) :
    (TypeVec.id ::: Sum.inl) <$$> c.dest' s = (c.union d).dest' (.inl s) :=
  rfl

theorem union_dest_eq_right (c d : Coalg F α) (s : d.σ) :
    (TypeVec.id ::: Sum.inr) <$$> d.dest' s = (c.union d).dest' (.inr s) :=
  rfl

end UnionLemmas

/-!
## Conversions to/from default Cofix type
-/

def toCofix (self : Coalg F α) : Cofix F α :=
  Cofix.corec self.dest' self.s

def ofCofix (fix : Cofix F α) : Coalg F α :=
  corec Cofix.dest fix

@[simp]
theorem toCofix_ofCofix (fix : Cofix F α) : toCofix (ofCofix fix) = fix := by
  simp only [toCofix, ofCofix]
  apply MvQPF.Cofix.bisim (fun s t => s = Cofix.corec Cofix.dest t)
  · rintro _ x rfl
    rw [Cofix.dest_corec, MvQPF.liftR_iff]
    let r := repr x.dest
    use r.fst
    use ((TypeVec.id ::: Cofix.corec Cofix.dest) ⊚ r.snd)
    use r.snd
    simp only [r]
    and_intros
    · change _ = abs (_ <$$> repr _)
      simp [abs_repr, abs_map]
    · simp [abs_repr]
    · intro i j
      cases i
      <;> rfl
  · rfl

theorem ofCofix_toCofix (self : Coalg F α) : ofCofix (toCofix self) ~ self := by
  simp only [toCofix, ofCofix]
  simp only [Bisim, union]
  use fun
    | .inl s, .inr t => s = Cofix.corec self.dest' t
    | _,  _ => False
  apply And.intro ?_ rfl
  simp only [IsBisim, Sum.forall, IsEmpty.forall_iff, implies_true, true_and, and_true]
  rintro _ s rfl
  rw [Cofix.dest_corec, MvFunctor.map_map, ← TypeVec.appendFun_comp_id]
  rw [MvQPF.liftR_iff]
  let r := repr (self.dest' s)
  use r.fst
  use ((TypeVec.id ::: Sum.inl ∘ Cofix.corec self.dest') ⊚ r.snd)
  use ((TypeVec.id ::: Sum.inr) ⊚ r.snd)
  simp only [r]
  and_intros
  · change _ = abs (_ <$$> repr (self.dest' s))
    simp [abs_map, abs_repr]
  · change _ = abs (_ <$$> repr (self.dest' s))
    simp [abs_map, abs_repr]
  · intro i j
    cases i <;> rfl

/-!
## Key helper: lifting LiftR through map
-/

/-
PROBLEM
If LiftR (RelLast α R) u v, then mapping both sides by (id ::: g) gives
    LiftR (RelLast α R') where R' is implied by R through g.

PROVIDED SOLUTION
Proof using liftR_iff and abs_map:

1. rw [liftR_iff] at h to get ⟨a₀, ff, gg, habs_u, habs_v, hrel⟩
2. rw [liftR_iff]
3. Use a₀ as the common shape
4. Use (TypeVec.id ::: g) ⊚ ff as the first filling
5. Use (TypeVec.id ::: g) ⊚ gg as the second filling
6. For the first abs equality:
   abs ⟨a₀, (id ::: g) ⊚ ff⟩ = (id ::: g) <$$> abs ⟨a₀, ff⟩   (by abs_map, reversed)
   = (id ::: g) <$$> u   (by habs_u)
7. Similarly for the second
8. For the relation: intro i j, then cases i using Fin2.recOn
   - For the last (fz): need RelLast α R' fz (((id ::: g) ⊚ ff) fz j) (((id ::: g) ⊚ gg) fz j)
     = R' (g (ff fz j)) (g (gg fz j))
     From hrel fz j we get RelLast α R fz (ff fz j) (gg fz j) = R (ff fz j) (gg fz j)
     Apply hR' to conclude
   - For non-last (fs i): need RelLast α R' (fs i) ... = Eq ...
     ((id ::: g) ⊚ ff) (fs i) j = id (ff (fs i) j) = ff (fs i) j
     ((id ::: g) ⊚ gg) (fs i) j = id (gg (fs i) j) = gg (fs i) j
     From hrel (fs i) j: RelLast α R (fs i) (ff (fs i) j) (gg (fs i) j) = (ff (fs i) j = gg (fs i) j)
     So they're equal, hence RelLast α R' gives Eq which is satisfied
-/
theorem liftR_map_last {β γ : Type u} (R : β → β → Prop)
    (R' : γ → γ → Prop) (g : β → γ)
    (hR' : ∀ x y, R x y → R' (g x) (g y))
    (u v : F (α ::: β))
    (h : LiftR (RelLast α R) u v) :
    LiftR (RelLast α R') ((TypeVec.id ::: g) <$$> u) ((TypeVec.id ::: g) <$$> v) := by
  revert u v h;
  intro u v huv
  rw [MvQPF.liftR_iff] at huv
  obtain ⟨a₀, ff, gg, habs_u, habs_v, hrel⟩ := huv
  rw [MvQPF.liftR_iff];
  refine' ⟨ a₀, _, _, _, _, _ ⟩;
  exact (TypeVec.id ::: g) ⊚ ff;
  exact ( TypeVec.id ::: g ) ⊚ gg;
  · rw [ habs_u, ← MvQPF.abs_map ];
    congr;
  · rw [ habs_v, ← MvQPF.abs_map ];
    rfl;
  · intro i j; specialize hrel i j; cases i using Fin2.recOn <;> aesop;

/-
PROBLEM
Special case: mapping the same value with two functions produces LiftR-related results
    if the functions are pointwise R'-related.

PROVIDED SOLUTION
Use liftR_iff. Let r = repr u. Then:
(id ::: g₁) <$$> u = abs ⟨r.1, (id ::: g₁) ⊚ r.2⟩ (by abs_map and abs_repr)
(id ::: g₂) <$$> u = abs ⟨r.1, (id ::: g₂) ⊚ r.2⟩
Use a₀ = r.1, ff = (id ::: g₁) ⊚ r.2, gg = (id ::: g₂) ⊚ r.2.
abs ⟨r.1, ff⟩ = (id ::: g₁) <$$> abs (repr u) = (id ::: g₁) <$$> u (by abs_repr).
For non-last i: ff i j = id (r.2 i j) = gg i j → RelLast gives Eq ✓
For last: R' (g₁ (r.2 last j)) (g₂ (r.2 last j)), which follows from hR' (r.2 last j).
-/
theorem liftR_map_pair {β γ : Type u}
    (R' : γ → γ → Prop) (g₁ g₂ : β → γ)
    (hR' : ∀ x, R' (g₁ x) (g₂ x))
    (u : F (α ::: β)) :
    LiftR (RelLast α R') ((TypeVec.id ::: g₁) <$$> u) ((TypeVec.id ::: g₂) <$$> u) := by
  rw [ MvQPF.liftR_iff ] at *;
  use (repr u).1;
  use ( TypeVec.id ::: g₁ ) ⊚ ( repr u ).snd, ( TypeVec.id ::: g₂ ) ⊚ ( repr u ).snd;
  refine' ⟨ _, _, _ ⟩;
  · -- By definition of abs and repr, we know that abs (repr u) = u.
    have h_abs_repr : abs (repr u) = u := abs_repr u;
    rw [ ← h_abs_repr ];
    rw [ ← MvQPF.abs_map ];
    exact (congrArg abs ∘ congrArg (map (TypeVec.id ::: g₁))) (congrArg repr (_root_.id (Eq.symm h_abs_repr)));
  · rw [ ← MvQPF.abs_repr u ];
    rw [ ← MvQPF.abs_map ];
    congr;
    exact Eq.symm (abs_repr u);
  · intro i j; cases i using Fin2.recOn <;> simp +decide [ *, TypeVec.RelLast ] ;
    · exact hR' _;
    · rfl

/-!
## Cofix lemmas for bisimulation
-/

/-
PROBLEM
Cofix.corec from the union coalgebra starting at a left state equals
    Cofix.corec from the left coalgebra directly.

PROVIDED SOLUTION
Use Cofix.bisim with R x y := ∃ s : a.σ, x = Cofix.corec a.dest' s ∧ y = Cofix.corec (a.union b).dest' (.inl s).
Apply it symmetrically (symm first).

For the coinduction step: given s, use Cofix.dest_corec to rewrite both sides, then use ← union_dest_eq_left to unfold the union dest', then use map_map. After rewriting, the goal becomes showing LiftR of two maps from the same source (a.dest' s). Use liftR_map_pair with g₁ = Cofix.corec a.dest' and g₂ = Cofix.corec (a.union b).dest' ∘ Sum.inl.
-/
theorem cofix_corec_union_left (a b : Coalg F α) (s : a.σ) :
    Cofix.corec (a.union b).dest' (.inl s) = Cofix.corec a.dest' s := by
  apply Eq.symm;
  apply Cofix.bisim;
  case r => exact fun x y => ∃ s : a.σ, x = Cofix.corec a.dest' s ∧ y = Cofix.corec ( a.union b ).dest' ( Sum.inl s );
  · rintro x y ⟨ s, rfl, rfl ⟩ ; simp +decide [ Cofix.dest_corec ] ;
    rw [ ← union_dest_eq_left, MvFunctor.map_map ];
    convert liftR_map_pair _ _ _ _ _ using 1;
    congr! 1;
    rotate_left;
    exact fun x => Cofix.corec ( a.union b ).dest' ( Sum.inl x );
    · exact fun x => ⟨ x, rfl, rfl ⟩;
    · exact eq_of_drop_last_eq rfl rfl;
  · use s

/-
PROBLEM
Cofix.corec from the union coalgebra starting at a right state equals
    Cofix.corec from the right coalgebra directly.

PROVIDED SOLUTION
Symmetric to cofix_corec_union_left. Use Cofix.bisim with R x y := ∃ t : b.σ, x = Cofix.corec b.dest' t ∧ y = Cofix.corec (a.union b).dest' (.inr t). Use liftR_map_pair after rewriting with dest_corec, union_dest_eq_right, and map_map.
-/
theorem cofix_corec_union_right (a b : Coalg F α) (t : b.σ) :
    Cofix.corec (a.union b).dest' (.inr t) = Cofix.corec b.dest' t := by
  -- Apply the bisimulation lemma with the relation R(x, y) = ∃ s : a.σ, x = Cofix.corec a.dest' s ∧ y = Cofix.corec (a.union b).dest' (.inl s).
  apply Eq.symm; exact (by
    apply Cofix.bisim;
    case r => exact fun x y => ∃ s : b.σ, x = Cofix.corec b.dest' s ∧ y = Cofix.corec ( a.union b ).dest' ( Sum.inr s );
    · rintro x y ⟨ s, rfl, rfl ⟩ ; simp +decide [ Cofix.dest_corec ] ;
      rw [ ← union_dest_eq_right ];
      convert liftR_map_pair _ _ _ _ _ using 1;
      rw [ MvFunctor.map_map ];
      congr! 1;
      rotate_left;
      exact fun x => Cofix.corec ( a.union b ).dest' ( Sum.inr x );
      · exact fun x => ⟨ x, rfl, rfl ⟩;
      · exact eq_of_drop_last_eq rfl rfl;
    · use t)

/-- If R is a bisimulation on the union and R relates two states, then
    their Cofix.corec values are equal. -/
theorem cofix_corec_bisim_eq (a b : Coalg F α)
    (R : (a.σ ⊕ b.σ) → (a.σ ⊕ b.σ) → Prop)
    (hR : IsBisim (self := a.union b) R)
    (x y : a.σ ⊕ b.σ) (hxy : R x y) :
    Cofix.corec (a.union b).dest' x = Cofix.corec (a.union b).dest' y := by
  apply Cofix.bisim
    (fun u v => ∃ s t, R s t ∧ u = Cofix.corec (a.union b).dest' s ∧ v = Cofix.corec (a.union b).dest' t)
  · rintro _ _ ⟨s, t, hst, rfl, rfl⟩
    rw [Cofix.dest_corec, Cofix.dest_corec]
    exact liftR_map_last R _ (Cofix.corec (a.union b).dest')
      (fun x' y' h => ⟨x', y', h, rfl, rfl⟩) _ _ (hR s t hst)
  · exact ⟨x, y, hxy, rfl, rfl⟩

/-- Two bisimilar coalgebras produce the same Cofix value. -/
theorem toCofix_eq_of_bisim (a b : Coalg F α) (h : a ~ b) :
    a.toCofix = b.toCofix := by
  obtain ⟨R, hR, hRinit⟩ := h
  simp only [toCofix]
  calc Cofix.corec a.dest' a.s
      = Cofix.corec (a.union b).dest' (.inl a.s) := (cofix_corec_union_left a b a.s).symm
    _ = Cofix.corec (a.union b).dest' (.inr b.s) := cofix_corec_bisim_eq a b R hR _ _ hRinit
    _ = Cofix.corec b.dest' b.s := cofix_corec_union_right a b b.s

end Coalg

variable (F) (α) in
def StateCofixFinal := Quot (Coalg.Bisim (F := F) (α := α))

namespace StateCofixFinal

/-!
## Basic API
-/

def corec {β} (f : β → F (α ::: β)) (init : β) : StateCofixFinal F α :=
  Quot.mk _ <| Coalg.corec f init

/-!
Now the big question is, how do we define `dest` for the final coalgebra here?
We can't refer to the state space, because that certainly wouldn't respect the
quotient, but we can't return a `StateCofixFinal` either, because of the universe
bump!

Hence, we need to shrink
-/

/-!
## Equivalence
-/

def toCofix (self : StateCofixFinal F α) : Cofix F α :=
  Quot.lift Coalg.toCofix (fun a b h => Coalg.toCofix_eq_of_bisim a b h) self

def ofCofix (fix : Cofix F α) : StateCofixFinal F α :=
  Quot.mk _ <| .ofCofix fix

@[simp]
theorem toCofix_ofCofix (fix : Cofix F α) : toCofix (ofCofix fix) = fix := by
  simp [ofCofix, toCofix]

@[simp]
theorem ofCofix_toCofix (self : StateCofixFinal F α) : ofCofix (toCofix self) = self := by
  simp only [ofCofix, toCofix]
  cases self using Quot.induction_on
  apply Quot.sound
  simpa using Coalg.ofCofix_toCofix _

def equivCofix : StateCofixFinal F α ≃ Cofix F α where
  toFun := toCofix
  invFun := ofCofix
  left_inv := ofCofix_toCofix
  right_inv := toCofix_ofCofix

instance : Small.{u} (StateCofixFinal F α) where
  equiv_small := ⟨_, ⟨equivCofix⟩⟩

end StateCofixFinal

section CShrink
variable (α : Type v) [Small.{w} α]

noncomputable
opaque CShrinkDef : Σ (β : Type w), α ≃ β := ⟨Shrink α, equivShrink _⟩

def CShrink := (CShrinkDef α).1

variable {α}

unsafe def CShrink.ofLargeImpl : α → CShrink α := unsafeCast
@[implemented_by CShrink.ofLargeImpl]
abbrev CShrink.ofLarge : α → CShrink α := (CShrinkDef _).2

unsafe def CShrink.toLargeImpl : CShrink α → α := unsafeCast
@[implemented_by CShrink.toLargeImpl]
abbrev CShrink.toLarge : CShrink α → α := (CShrinkDef _).2.invFun

end CShrink

variable (F) (α) in
def StateCofixShrunk := CShrink (StateCofixFinal F α)

namespace StateCofixShrunk

/-!
## Basic API

Note this is noncomputable (for now!) because of the Shrink
-/
section

protected def ofLarge : StateCofixFinal F α → StateCofixShrunk F α :=
  CShrink.ofLarge
protected def toLarge : StateCofixShrunk F α → StateCofixFinal F α :=
  CShrink.toLarge
open StateCofixShrunk (ofLarge toLarge)

def corec {β} (f : β → F (α ::: β)) (init : β) : StateCofixShrunk F α :=
  .ofLarge <| .corec f init

/-- corec f s equals the composition through Cofix -/
private theorem corec_eq_via_cofix {β} (f : β → F (α ::: β)) (s : β) :
    corec f s = ofLarge (StateCofixFinal.ofCofix (Cofix.corec f s)) := by
  simp only [corec, StateCofixFinal.corec, StateCofixFinal.ofCofix, Coalg.ofCofix]
  congr 1
  symm
  exact Quot.sound (Coalg.ofCofix_toCofix (Coalg.corec f s))

/-
PROVIDED SOLUTION
The proof factors through Cofix using the equivalence.

1. Have key : Coalg.toCofix a = Coalg.toCofix b from Coalg.toCofix_eq_of_bisim.
2. Let ψ : Cofix F α → StateCofixShrunk F α := ofLarge ∘ StateCofixFinal.ofCofix
3. corec f = ψ ∘ Cofix.corec f (by funext using corec_eq_via_cofix)
4. Rewrite both sides: map (id ::: corec a.dest') (a.dest' a.s) = map (id ::: ψ ∘ Cofix.corec a.dest') (a.dest' a.s)
   = map (id ::: ψ) (map (id ::: Cofix.corec a.dest') (a.dest' a.s))  [by map_map with appendFun_comp_id]
   = map (id ::: ψ) (Cofix.dest (Cofix.corec a.dest' a.s))  [by Cofix.dest_corec]
5. Similarly for b.
6. Since key says Cofix.corec a.dest' a.s = Cofix.corec b.dest' b.s, the result follows by congr.

Key steps: unfold Coalg.dest, use corec_eq_via_cofix to rewrite corec, use map_map (with appendFun_comp_id), use Cofix.dest_corec, and apply congrArg with key.
-/
private theorem dest_resp_bisim (a b : Coalg F α) (h_bisim : a ~ b) :
    (TypeVec.id ::: corec a.dest') <$$> a.dest = (TypeVec.id ::: corec b.dest') <$$> b.dest := by
  -- Let ψ : Cofix F α → StateCofixShrunk F α := ofLarge ∘ StateCofixFinal.ofCofix
  set ψ : Cofix F α → StateCofixShrunk F α := StateCofixShrunk.ofLarge ∘ StateCofixFinal.ofCofix;
  -- By definition of ψ, we know that ψ ∘ Cofix.corec a.dest' = corec a.dest' and ψ ∘ Cofix.corec b.dest' = corec b.dest'.
  have h_psi_corec : ψ ∘ Cofix.corec a.dest' = StateCofixShrunk.corec a.dest' ∧ ψ ∘ Cofix.corec b.dest' = StateCofixShrunk.corec b.dest' := by
    constructor <;> ext <;> simp +decide [ StateCofixShrunk.corec_eq_via_cofix ];
    · rfl;
    · rfl;
  -- By definition of ψ, we know that ψ ∘ Cofix.corec a.dest' = corec a.dest' and ψ ∘ Cofix.corec b.dest' = corec b.dest'. Therefore, we can rewrite the goal using these equalities.
  have h_rewrite : (TypeVec.id ::: ψ ∘ Cofix.corec a.dest') <$$> a.dest = (TypeVec.id ::: ψ ∘ Cofix.corec b.dest') <$$> b.dest := by
    have h_rewrite : (TypeVec.id ::: ψ) <$$> (TypeVec.id ::: Cofix.corec a.dest') <$$> a.dest = (TypeVec.id ::: ψ) <$$> (TypeVec.id ::: Cofix.corec b.dest') <$$> b.dest := by
      have h_rewrite : Cofix.corec a.dest' a.s = Cofix.corec b.dest' b.s := by
        convert Coalg.toCofix_eq_of_bisim a b h_bisim using 1;
      have h_rewrite : (TypeVec.id ::: Cofix.corec a.dest') <$$> a.dest = Cofix.dest (Cofix.corec a.dest' a.s) ∧ (TypeVec.id ::: Cofix.corec b.dest') <$$> b.dest = Cofix.dest (Cofix.corec b.dest' b.s) := by
        exact ⟨ Eq.symm (Cofix.dest_corec a.dest' a.s), Eq.symm (Cofix.dest_corec b.dest' b.s) ⟩;
      aesop;
    convert h_rewrite using 1;
    · simp +decide [ TypeVec.appendFun_comp_id ];
    · erw [ MvFunctor.map_map ];
      congr! 1;
      exact appendFun_comp_id (Cofix.corec b.dest') ψ;
  aesop

def dest (self : StateCofixShrunk F α) : F (α ::: (StateCofixShrunk F α)) :=
  let f self := (TypeVec.id ::: corec self.dest') <$$> self.dest
  have h : ∀ a b, a ~ b → f a = f b := dest_resp_bisim
  Quot.lift f h self.toLarge

/-!
## Equivalence

TODO: compose the existing equivalences to show the equivalence between `Cofix`
      and `StateCofixShrunk`.

TODO: we probably want to have some proof that relates the above `corec` to
      `Cofix.corec` and `dest` to `Cofix.dest`.
-/

end

end StateCofixShrunk

end MvQPF
