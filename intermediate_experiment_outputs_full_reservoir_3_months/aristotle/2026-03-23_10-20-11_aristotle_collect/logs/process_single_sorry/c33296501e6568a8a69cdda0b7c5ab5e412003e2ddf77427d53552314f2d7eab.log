import Mathlib

open scoped Finset

namespace IMO2025P4

/-- The answer: all n = 2^a * 3^b * m where a is odd, 2b > a, gcd(m, 30) = 1, m ≥ 1. -/
def answer : Set ℕ := {n | ∃ a b m : ℕ, 0 < a ∧ a % 2 = 1 ∧ 2 * b > a ∧
    0 < m ∧ Nat.Coprime m 30 ∧ n = 2 ^ a * 3 ^ b * m}

/-- The function computing the sum of the 3 largest proper divisors. -/
noncomputable def f (n : ℕ) : ℕ :=
  (((Nat.properDivisors n).sort (· ≤ ·)).reverse.take 3).sum

/-
PROBLEM
For n with at least 3 proper divisors, the sum of the 3 largest proper divisors
equals d₁ + d₂ + d₃ where d₁ > d₂ > d₃ are the 3 largest.

PROVIDED SOLUTION
We need to show that (sort ascending).reverse.take 3 gives [d₁, d₂, d₃].

The sorted ascending list has d₃, d₂, d₁ as the last 3 elements (since hmax says all other elements are ≤ d₃). After reversing, they become the first 3 elements: [d₁, d₂, d₃]. Taking 3 and summing gives d₁ + d₂ + d₃.

Key steps:
1. Show the sort of properDivisors is a permutation of its elements in ascending order.
2. Show d₁, d₂, d₃ are the last 3 elements of the ascending sort (since all others are ≤ d₃).
3. After reverse, they're the first 3 elements.
4. take 3 gives exactly [d₁, d₂, d₃].
5. Sum is d₁ + d₂ + d₃.

Use Finset.sort properties: Finset.mem_sort, the sorted list is sorted, and contains exactly the elements of the Finset.
-/
lemma top3_eq_of_three_largest {n d₁ d₂ d₃ : ℕ}
    (hd₁_mem : d₁ ∈ Nat.properDivisors n)
    (hd₂_mem : d₂ ∈ Nat.properDivisors n)
    (hd₃_mem : d₃ ∈ Nat.properDivisors n)
    (hd₁₂ : d₂ < d₁) (hd₂₃ : d₃ < d₂)
    (hmax : ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d < d₃ ∨ d = d₃) :
    f n = d₁ + d₂ + d₃ := by
  -- Let's denote the list of proper divisors of $n$ as $L$.
  set L := Nat.properDivisors n |>.sort (· ≤ ·) |>.reverse;
  -- Since $d₁$, $d₂$, and $d₃$ are the three largest proper divisors of $n$, they must be the first three elements of $L$.
  have hL_first_three : L.take 3 = [d₁, d₂, d₃] := by
    -- Since $d₁$, $d₂$, and $d₃$ are the three largest proper divisors of $n$, they must be the first three elements of $L$, which is the reversed sorted list of proper divisors.
    have hL_first_three : ∀ d ∈ L, d = d₁ ∨ d = d₂ ∨ d = d₃ ∨ d < d₃ := by
      norm_num +zetaDelta at *;
      grind +ring;
    have hL_first_three : L.Sorted (· ≥ ·) ∧ List.Nodup L ∧ d₁ ∈ L ∧ d₂ ∈ L ∧ d₃ ∈ L ∧ d₁ > d₂ ∧ d₂ > d₃ ∧ ∀ d ∈ L, d = d₁ ∨ d = d₂ ∨ d = d₃ ∨ d < d₃ := by
      simp +zetaDelta at *;
      exact ⟨ by exact List.pairwise_reverse.mpr <| Finset.pairwise_sort _ _, hd₁_mem, hd₂_mem, hd₃_mem, hd₁₂, hd₂₃, hL_first_three ⟩;
    rcases L with ( _ | ⟨ x, _ | ⟨ y, _ | ⟨ z, _ | L ⟩ ⟩ ⟩ ) <;> simp_all +decide;
    · grind;
    · omega;
    · simp_all +decide [ List.Sorted ];
      omega;
    · rcases hL_first_three with ⟨ h₁, h₂, h₃, h₄ ⟩;
      rcases h₃ with ( rfl | rfl | rfl | rfl | h₃ ) <;> simp_all +decide [ List.Sorted ];
      · grind;
      · omega;
      · omega;
      · omega;
      · grind;
  convert congr_arg List.sum hL_first_three using 1;
  simp +arith +decide

/-
PROBLEM
Fixed point: when v₂(n)=1, 3∣n, 5∤n, then f(n) = n.
More precisely: if n = 2*k with k odd, 3∣k, 5∤k, k ≥ 3, then f(n) = n.

PROVIDED SOLUTION
Use top3_eq_of_three_largest with d₁ = n/2, d₂ = n/3, d₃ = n/6.

1. Show d₁, d₂, d₃ ∈ properDivisors n:
   - n/2: Since 2|n, n/2 divides n and n/2 < n (since n ≥ 6 > 0).
   - n/3: Since 3|n (because 6|n since 2|n and 3|n), n/3 divides n and n/3 < n.
   - n/6: Since 6|n, n/6 divides n and n/6 < n.

2. Show d₁ > d₂ > d₃:
   - n/2 > n/3 since n > 0.
   - n/3 > n/6 since n > 0.

3. Show hmax: for any d ∈ properDivisors n with d ≠ n/2, d ≠ n/3, we have d ≤ n/6.
   A proper divisor d < n satisfies d | n, so n/d | n and n/d ≥ 2. The divisors d with d > n/6 correspond to n/d < 6, so n/d ∈ {2, 3, 4, 5}.
   - n/d = 2 gives d = n/2 (excluded)
   - n/d = 3 gives d = n/3 (excluded)
   - n/d = 4 gives d = n/4, but 4 ∤ n (since hv4), so this doesn't exist
   - n/d = 5 gives d = n/5, but 5 ∤ n (since h5), so this doesn't exist
   So d ≤ n/6.

4. Sum: n/2 + n/3 + n/6 = (3n + 2n + n)/6 = n (using the fact that 6 | n).
-/
lemma f_eq_self_of_fixed {n : ℕ} (hn : 0 < n) (hv2 : n % 2 = 0) (hv4 : ¬(4 ∣ n))
    (h3 : 3 ∣ n) (h5 : ¬(5 ∣ n)) (hcard : 3 ≤ (Nat.properDivisors n).card) :
    f n = n := by
  obtain ⟨ k, hk ⟩ := h3;
  -- Apply the `top3_eq_of_three_largest` lemma with $d_1 = n/2$, $d_2 = n/3$, and $d_3 = n/6$.
  have h_top3 : f n = n / 2 + n / 3 + n / 6 := by
    apply top3_eq_of_three_largest;
    all_goals norm_num; try omega;
    · exact ⟨ Nat.div_dvd_of_dvd <| Nat.dvd_of_mod_eq_zero hv2, Nat.div_lt_self hn <| by decide ⟩;
    · exact ⟨ Nat.div_dvd_of_dvd <| hk.symm ▸ dvd_mul_right _ _, Nat.div_lt_self hn <| by decide ⟩;
    · exact ⟨ Nat.div_dvd_of_dvd ( Nat.dvd_of_mod_eq_zero ( by omega ) ), Nat.div_lt_self ( by linarith ) ( by decide ) ⟩;
    · intro d hdn hdn' hdn'' hdn'''; rcases hdn with ⟨ c, rfl ⟩ ; rcases c with ( _ | _ | _ | _ | _ | _ | c ) <;> norm_num at * ;
      exact lt_or_eq_of_le ( Nat.le_div_iff_mul_le ( by norm_num ) |>.2 <| by nlinarith only [ hn ] );
  omega

/-
PROBLEM
For n divisible by 12, the three largest proper divisors are n/2, n/3, n/4
and their sum is 13*n/12.

PROVIDED SOLUTION
Use top3_eq_of_three_largest with d₁ = n/2, d₂ = n/3, d₃ = n/4.

1. Show d₁, d₂, d₃ ∈ properDivisors n:
   - Since 12|n, we have 2|n, 3|n, 4|n. So n/2, n/3, n/4 all divide n.
   - n > 0 implies n/2 < n, n/3 < n, n/4 < n.

2. Show d₁ > d₂ > d₃: n/2 > n/3 > n/4 follows from n > 0.

3. Show hmax: ∀ d ∈ properDivisors n, d ≠ n/2 → d ≠ n/3 → d ≤ n/4.
   If d > n/4 then n/d < 4 and n/d ≥ 2 (since d < n), so n/d ∈ {2, 3}.
   n/d = 2 → d = n/2 (excluded). n/d = 3 → d = n/3 (excluded).
   So d ≤ n/4.

Since 12|n: n/2 + n/3 + n/4 is the result.
-/
lemma f_eq_of_div12 {n : ℕ} (hn : 12 ∣ n) (hn_pos : 0 < n) :
    f n = n / 2 + n / 3 + n / 4 := by
  obtain ⟨ k, hk ⟩ := hn;
  convert top3_eq_of_three_largest _ _ _ _ _ _ using 1 <;> norm_num [ hk ];
  any_goals omega;
  · exact ⟨ Nat.div_dvd_of_dvd ( dvd_mul_of_dvd_left ( by decide ) _ ), Nat.div_lt_self ( by linarith ) ( by decide ) ⟩;
  · exact ⟨ Nat.div_dvd_of_dvd ( dvd_mul_of_dvd_left ( by decide ) _ ), Nat.div_lt_self ( by linarith ) ( by decide ) ⟩;
  · exact ⟨ Nat.div_dvd_of_dvd ( dvd_mul_of_dvd_left ( by decide ) _ ), Nat.div_lt_self ( by linarith ) ( by decide ) ⟩;
  · intro d h1 h2 h3 h4; rcases h1 with ⟨ c, hc ⟩ ; rcases c with ( _ | _ | _ | _ | _ | _ | c ) <;> simp_all +arith +decide;
    · omega;
    · exact lt_or_eq_of_le ( Nat.le_div_iff_mul_le zero_lt_four |>.2 <| by nlinarith only [ hn_pos ] )

/-
PROBLEM
n divisible by 12, the sum n/2 + n/3 + n/4 equals 13*n/12.

PROVIDED SOLUTION
Since 12 | n, write n = 12k. Then n/2 + n/3 + n/4 = 6k + 4k + 3k = 13k = 13*(12k)/12 = 13*n/12. Use omega or ring after substituting n = 12*k.
-/
lemma sum_div234 {n : ℕ} (h12 : 12 ∣ n) : n / 2 + n / 3 + n / 4 = 13 * n / 12 := by
  omega

