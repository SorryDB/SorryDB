lemma f_lt_of_even_no3 {n : ℕ} (hn_even : 2 ∣ n) (hn_no3 : ¬(3 ∣ n))
    (hcard : 3 ≤ (Nat.properDivisors n).card) :
    f n < n := by
  -- By definition of $f$, we know that $f(n)$ is the sum of the three largest proper divisors of $n$.
  obtain ⟨d₁, d₂, d₃, hd₁, hd₂, hd₃, hd₁₂, hd₂₃, hmax⟩ : ∃ d₁ d₂ d₃, d₁ ∈ Nat.properDivisors n ∧ d₂ ∈ Nat.properDivisors n ∧ d₃ ∈ Nat.properDivisors n ∧ d₁ > d₂ ∧ d₂ > d₃ ∧ (∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d < d₃ ∨ d = d₃) ∧ f n = d₁ + d₂ + d₃ := by
    -- By definition of $f$, we know that $f(n)$ is the sum of the three largest proper divisors of $n$. Let's denote these three largest proper divisors as $d₁$, $d₂$, and $d₃$.
    obtain ⟨d₁, d₂, d₃, hd₁, hd₂, hd₃, hd₁₂, hd₂₃, hmax⟩ : ∃ d₁ d₂ d₃, d₁ ∈ Nat.properDivisors n ∧ d₂ ∈ Nat.properDivisors n ∧ d₃ ∈ Nat.properDivisors n ∧ d₁ > d₂ ∧ d₂ > d₃ ∧ (∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d < d₃ ∨ d = d₃) := by
      -- Since there are at least three proper divisors, we can select the three largest ones.
      obtain ⟨d₁, hd₁⟩ : ∃ d₁ ∈ Nat.properDivisors n, ∀ d ∈ Nat.properDivisors n, d ≤ d₁ := by
        exact ⟨ Finset.max' _ <| Finset.card_pos.mp <| pos_of_gt hcard, Finset.max'_mem _ _, fun d hd => Finset.le_max' _ _ hd ⟩
      obtain ⟨d₂, hd₂, hd₂'⟩ : ∃ d₂ ∈ Nat.properDivisors n, d₂ ≠ d₁ ∧ ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≤ d₂ := by
        obtain ⟨d₂, hd₂⟩ : ∃ d₂ ∈ Nat.properDivisors n, d₂ ≠ d₁ := by
          exact Finset.exists_mem_ne ( lt_of_lt_of_le ( by decide ) hcard ) d₁;
        exact ⟨ Finset.max' ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩ ) |>.1, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩ ) |>.2, fun x hx hx' => Finset.le_max' _ _ <| by aesop ⟩
      obtain ⟨d₃, hd₃, hd₃'⟩ : ∃ d₃ ∈ Nat.properDivisors n, d₃ ≠ d₁ ∧ d₃ ≠ d₂ ∧ ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d ≤ d₃ := by
        obtain ⟨d₃, hd₃⟩ : ∃ d₃ ∈ Nat.properDivisors n, d₃ ≠ d₁ ∧ d₃ ≠ d₂ := by
          contrapose! hcard;
          exact lt_of_le_of_lt ( Finset.card_le_card ( show n.properDivisors ⊆ { d₁, d₂ } by intros x hx; by_cases hx' : x = d₁ <;> aesop ) ) ( by exact lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by norm_num ) );
        exact ⟨ Finset.max' ( n.properDivisors.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.1, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.2.1, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.2.2, fun x hx hx₁ hx₂ => Finset.le_max' _ _ <| by aesop ⟩;
      grind;
    use d₁, d₂, d₃, hd₁, hd₂, hd₃, hd₁₂, hd₂₃, hmax, top3_eq_of_three_largest hd₁ hd₂ hd₃ hd₁₂ hd₂₃ hmax ▸ rfl;
  -- Since $d₁$, $d₂$, and $d₃$ are the three largest proper divisors of $n$, we have $d₁ \leq n/2$, $d₂ \leq n/4$, and $d₃ \leq n/4$.
  have h_bounds : d₁ ≤ n / 2 ∧ d₂ ≤ n / 4 ∧ d₃ ≤ n / 4 := by
    have h_d1 : d₁ ≤ n / 2 := by
      rw [ Nat.le_div_iff_mul_le zero_lt_two ];
      obtain ⟨ k, hk ⟩ := Nat.mem_properDivisors.mp hd₁ |>.1;
      rcases k with ( _ | _ | k ) <;> simp_all +decide ; nlinarith
    have h_d2 : d₂ ≤ n / 4 := by
      rw [ Nat.le_div_iff_mul_le ] <;> norm_num;
      obtain ⟨ k, hk ⟩ := Nat.mem_properDivisors.mp hd₂ |>.1;
      rcases k with ( _ | _ | _ | _ | k ) <;> simp_all +arith +decide;
      · linarith;
      · nlinarith only [ hd₂ ]
    have h_d3 : d₃ ≤ n / 4 := by
      grind +ring
    exact ⟨h_d1, h_d2, h_d3⟩;
  omega

/-
PROBLEM
f preserves non-membership in answer for the 12-divisible case.

PROVIDED SOLUTION
Since 12|n and n > 0, by f_eq_of_div12, f(n) = n/2 + n/3 + n/4 = 13*n/12 (by sum_div234).

We need to show 13*n/12 ∉ answer. Write n = 2^a * 3^b * m with gcd(m, 6) = 1.

Since 12|n: a ≥ 2 and b ≥ 1. Then 13*n/12 = 13 * 2^(a-2) * 3^(b-1) * m.

Since gcd(13, 6) = 1: v₂(13*n/12) = a-2 and v₃(13*n/12) = b-1.

n ∉ answer means (using n = 2^a * 3^b * m with gcd(m,30)=1):
- Either a is even, or 2b ≤ a, or 5|m (i.e., gcd(m,30) ≠ 1).

For 13*n/12 ∈ answer: we'd need v₂ = a-2 is odd AND positive, 2*(b-1) > a-2, and 5 ∤ (13*m).

Case 1: a is even → a-2 is even → 13*n/12 ∉ answer.
Case 2: a is odd, 2b ≤ a → 2(b-1) = 2b-2 ≤ a-2 → 13*n/12 ∉ answer.
Case 3: 5|m → 5|(13*m) since gcd(5,13)=1... wait, 5|m means 5|(13*m), so gcd(13*m, 30) ≠ 1, so 13*n/12 ∉ answer.

Actually more carefully, 5|m means m is not coprime to 30, which means n's m-part is not coprime to 30. And 13*n/12 has m-part 13*m. Since 5|m, 5|(13m), so gcd(13m, 30) ≥ 5 ≠ 1. So 13*n/12 ∉ answer.

This is a straightforward case analysis but requires working with the answer set definition. The key is that the "not in answer" condition is preserved: if a is even it stays even (a-2 even), if 2b ≤ a then 2(b-1) ≤ a-2, and if 5|n then 5|(13n/12).
-/
lemma f_notin_answer_of_div12 {n : ℕ} (hn : 12 ∣ n) (hn_pos : 0 < n)
    (hn_notin : n ∉ answer) : f n ∉ answer := by
  rw [ f_eq_of_div12 hn hn_pos, sum_div234 hn ];
  contrapose! hn_notin;
  obtain ⟨ a, b, m, ha, hb, hab, hm, hgcd, h ⟩ := hn_notin;
  rw [ Nat.div_eq_iff_eq_mul_left ( by decide ) ] at h;
  · -- From the equation $13 * n = 2^a * 3^b * m * 12$, we can deduce that $13$ must divide $m$.
    have h_div_m : 13 ∣ m := by
      have h_div_m : 13 ∣ 2 ^ a * 3 ^ b * m := by
        grind;
      exact Or.resolve_left ( Nat.Prime.dvd_mul ( by norm_num ) |>.1 h_div_m ) ( by norm_num [ Nat.Prime.dvd_iff_one_le_factorization, * ] );
    -- Since $13 \mid m$, we can write $m = 13 * k$ for some integer $k$.
    obtain ⟨ k, rfl ⟩ : ∃ k, m = 13 * k := h_div_m;
    use a + 2, b + 1, k;
    exact ⟨ by linarith, by norm_num [ Nat.add_mod, hb ], by linarith, by linarith, Nat.Coprime.coprime_dvd_left ( dvd_mul_left _ _ ) hgcd, by ring_nf at *; linarith ⟩;
  · exact dvd_mul_of_dvd_right hn _

/-
PROBLEM
If n is odd with ≥3 proper divisors, then f(n) is also odd.

PROVIDED SOLUTION
If n is odd, then all divisors of n are odd (since any divisor of an odd number is odd). So all proper divisors are odd. The sum of any 3 odd numbers is odd. Therefore f(n) = sum of 3 largest proper divisors = sum of 3 odd numbers = odd.

More precisely: f(n) is a sum of elements from properDivisors n. Each element divides n, and since n is odd, each divisor is odd. The sum of the take 3 of the reverse of the sort gives a sum of at most 3 elements from properDivisors. Since hcard ≥ 3, we get exactly 3 odd numbers, and their sum is odd (odd + odd + odd = odd).

Key: if d | n and n is odd, then d is odd. This is Nat.Odd.of_dvd or similar.
-/
lemma f_odd_of_odd {n : ℕ} (hn_odd : ¬(2 ∣ n)) (hcard : 3 ≤ (Nat.properDivisors n).card) :
    ¬(2 ∣ f n) := by
  -- Since $n$ is odd, all its proper divisors are also odd.
  have h_odd_proper_divisors : ∀ d ∈ n.properDivisors, Odd d := by
    exact fun d hd => Nat.odd_iff.mpr ( Nat.mod_two_ne_zero.mp fun h => hn_odd <| dvd_trans ( Nat.dvd_of_mod_eq_zero h ) <| Nat.mem_properDivisors.mp hd |>.1 );
  -- Since $f(n)$ is the sum of the 3 largest proper divisors of $n$, and all proper divisors of $n$ are odd, $f(n)$ must also be odd.
  have h_sum_odd : ∀ {l : List ℕ}, (∀ d ∈ l, Odd d) → l.length ≥ 3 → Odd (l.take 3).sum := by
    intro l hl hl'; rcases l with ( _ | ⟨ a, _ | ⟨ b, _ | ⟨ c, _ | l ⟩ ⟩ ⟩ ) <;> simp_all +arith +decide [ parity_simps ] ;
    · grind;
    · grind;
  simp_all +decide [ ← even_iff_two_dvd, parity_simps ];
  aesop

/-
PROBLEM
Numbers in the answer set have ≥3 proper divisors.

PROVIDED SOLUTION
If n ∈ answer, then n = 2^a * 3^b * m with a ≥ 1, b ≥ 1, m ≥ 1. So 6 | n and n ≥ 6. The proper divisors of n include {1, 2, 3} (since 1 | n, 2 | n (because a≥1), 3 | n (because b≥1)). These are 3 distinct proper divisors (they're all < n since n ≥ 6), so card(properDivisors n) ≥ 3. Use Finset.card_le_card with the subset {1,2,3} ⊆ properDivisors n, and show 1,2,3 ∈ properDivisors n using Nat.mem_properDivisors.
-/
lemma card_properDivisors_ge_of_answer {n : ℕ} (hn : n ∈ answer) :
    3 ≤ (Nat.properDivisors n).card := by
  obtain ⟨ a, b, m, ha, hb, hab, hm, hsum ⟩ := hn;
  refine' le_trans _ ( Finset.card_mono <| show Nat.properDivisors n ≥ { 1, 2, 3 } from _ );
  · decide +revert;
  · simp_all +decide [ Finset.insert_subset_iff ];
    refine' ⟨ _, ⟨ _, _ ⟩, _, _ ⟩ <;> norm_num [ Nat.dvd_iff_mod_eq_zero, Nat.mul_mod, Nat.pow_mod, ha.ne', hb, hsum ];
    · exact one_lt_mul_of_lt_of_le ( one_lt_mul_of_lt_of_le ( one_lt_pow₀ ( by decide ) ha.ne' ) ( Nat.one_le_pow _ _ ( by decide ) ) ) hm;
    · nlinarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by decide ) ha, Nat.pow_le_pow_right ( show 1 ≤ 3 by decide ) ( show b ≥ 1 by linarith ), mul_pos ( pow_pos ( show 0 < 2 by decide ) a ) ( pow_pos ( show 0 < 3 by decide ) b ) ];
    · cases b <;> aesop;
    · nlinarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by decide ) ha, Nat.pow_le_pow_right ( show 1 ≤ 3 by decide ) ( show b ≥ 1 by linarith ), Nat.mul_le_mul_left ( 2 ^ a * 3 ^ b ) hm ]

/-
PROBLEM
Numbers in the answer set are positive.

PROVIDED SOLUTION
If n ∈ answer, then n = 2^a * 3^b * m with a ≥ 1, b ≥ 1, m ≥ 1. So n ≥ 2*3*1 = 6 > 0. Use positivity or omega after obtaining the existential witnesses.
-/
lemma pos_of_answer {n : ℕ} (hn : n ∈ answer) : 0 < n := by
  cases hn ; aesop

/-
PROBLEM
f maps answer to answer.

PROVIDED SOLUTION
If n ∈ answer, then n = 2^a * 3^b * m with a odd, a ≥ 1, 2b > a, gcd(m,30)=1, m ≥ 1.

Case 1: a = 1. Then n = 2 * 3^b * m with b ≥ 1, gcd(m,30)=1.
By f_eq_self_of_fixed, f(n) = n. So f(n) ∈ answer since n ∈ answer.
(Need to check: n % 2 = 0, ¬(4 | n) since a=1, 3 | n since b ≥ 1, ¬(5 | n) since gcd(m,30)=1 and a=1 so 5∤n.)

Case 2: a ≥ 3 (odd, so a ≥ 3). Then 4 | n and 3 | n, so 12 | n. By f_eq_of_div12 and sum_div234: f(n) = 13*n/12.

13*n/12 = 13 * 2^(a-2) * 3^(b-1) * m. This has:
- v₂ = a-2 (which is odd since a is odd, and a-2 ≥ 1 since a ≥ 3)
- v₃ = b-1
- 2*(b-1) > a-2 iff 2b-2 > a-2 iff 2b > a (which holds by hypothesis)
- The m-part is 13*m. gcd(13*m, 30) = gcd(m, 30) * gcd(13, 30/gcd(m,30))... actually gcd(13,30)=1 and gcd(m,30)=1, so gcd(13m, 30) = 1.
- 13*m > 0 since m > 0.

So f(n) = 2^(a-2) * 3^(b-1) * (13*m) ∈ answer.
-/
lemma f_mem_answer_of_mem {n : ℕ} (hn : n ∈ answer) : f n ∈ answer := by
  obtain ⟨a, b, m, ha, hb, h_coprime, hn_eq⟩ := hn
  have ha_odd : a % 2 = 1 := by
    exact hb
  have h2b_a : 2 * b > a := by
    linarith
  have hcoprime : Nat.Coprime m 30 := by
    exact hn_eq.2.1
  have hm_pos : 0 < m := by
    linarith
  have hn_eq' : n = 2 ^ a * 3 ^ b * m := by
    exact hn_eq.2.2
  have hcard : 3 ≤ Finset.card (Nat.properDivisors n) := by
    exact card_properDivisors_ge_of_answer ⟨ a, b, m, ha, hb, h2b_a, hm_pos, hcoprime, hn_eq' ⟩
  have h_pos : 0 < n := by
    exact hn_eq'.symm ▸ by positivity;
  generalize_proofs at *; (
  by_cases ha1 : a = 1
  generalize_proofs at *; (
  -- By Lemma f_eq_self_of_fixed, we have f(n) = n.
  have hf_eq_n : f n = n := by
    apply f_eq_self_of_fixed h_pos (by
    norm_num [ Nat.mul_mod, Nat.pow_mod, ha1, hn_eq' ]) (by
    -- Since $a = 1$, we have $n = 2 * 3^b * m$. Since $m$ is coprime with $30$, it cannot be divisible by $2$.
    have h_not_div4 : ¬(2 ∣ m) := by
      exact fun h => by have := Nat.dvd_gcd h ( by decide : 2 ∣ 30 ) ; simp_all +decide ;
    generalize_proofs at *; (
    simp_all +decide [ Nat.Prime.dvd_mul ];
    rw [ Nat.dvd_iff_mod_eq_zero ] ; norm_num [ Nat.mul_mod, Nat.pow_mod, h_not_div4 ] ; ring_nf ;
    rw [ ← Nat.mod_mod_of_dvd m ( by decide : 2 ∣ 4 ) ] at h_not_div4; have := Nat.mod_lt m zero_lt_four; interval_cases m % 4 <;> rcases Nat.even_or_odd' b with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *;)) (by
    exact hn_eq'.symm ▸ dvd_mul_of_dvd_left ( dvd_mul_of_dvd_right ( pow_dvd_pow _ ( show b ≥ 1 by linarith ) ) _ ) _) (by
    simp_all +decide [ Nat.Prime.dvd_mul ];
    exact ⟨ by norm_num [ Nat.Prime.dvd_iff_one_le_factorization ], by intro h; have := Nat.dvd_gcd h ( by norm_num : 5 ∣ 30 ) ; simp_all +decide ⟩) hcard
  generalize_proofs at *; (
  exact hf_eq_n.symm ▸ ⟨ a, b, m, ha, hb, h_coprime, hm_pos, hcoprime, hn_eq' ⟩));
  -- Since $a \geq 3$ (odd), $4 \mid n$ and $3 \mid n$, so $12 \mid n$. By $f_eq_of_div12$ and $sum_div234$: $f(n) = 13*n/12$.
  have h12_div : 12 ∣ n := by
    exact hn_eq'.symm ▸ dvd_mul_of_dvd_left ( dvd_trans ( by decide ) ( Nat.mul_dvd_mul ( pow_dvd_pow _ ( show a ≥ 2 by contrapose! ha1; linarith ) ) ( pow_dvd_pow _ ( show b ≥ 1 by linarith ) ) ) ) _;
  have hf_eq : f n = 13 * n / 12 := by
    rw [ f_eq_of_div12 h12_div h_pos, sum_div234 h12_div ]
  have hf_eq' : f n = 2 ^ (a - 2) * 3 ^ (b - 1) * (13 * m) := by
    rcases a with ( _ | _ | a ) <;> rcases b with ( _ | _ | b ) <;> simp_all +decide [ pow_succ', mul_assoc, mul_comm, mul_left_comm ] ; omega;
    exact Nat.div_eq_of_eq_mul_left ( by decide ) ( by ring )
  generalize_proofs at *; (
  use a - 2, b - 1, 13 * m; rcases a with ( _ | _ | a ) <;> rcases b with ( _ | _ | b ) <;> simp_all +decide [ Nat.pow_succ', mul_assoc ] ;
  · linarith [ Nat.mod_le ( a + 1 + 1 ) 2 ];
  · exact ⟨ Nat.pos_of_ne_zero ( by aesop_cat ), by omega, by omega, by exact Nat.Coprime.mul_left ( by decide ) hn_eq.2 ⟩))

/-
PROBLEM
Forward direction: every element of answer has an infinite valid sequence.

PROVIDED SOLUTION
Given n ∈ answer, construct the sequence a(i) by iterating f:
a(i) = Nat.recOn i n (fun _ x => f x)

Then a(0) = n. And a(i+1) = f(a(i)) by definition of f.

By f_mem_answer_of_mem, if a(i) ∈ answer then f(a(i)) ∈ answer. So by induction, all a(i) ∈ answer.

By pos_of_answer, all a(i) > 0 (since a(i) ∈ answer).
By card_properDivisors_ge_of_answer, all a(i) have ≥ 3 proper divisors.

The recurrence a(i+1) = f(a(i)) matches the required condition since f is defined as the sort-reverse-take-sum.

Use: ⟨fun i => Nat.rec n (fun _ x => f x) i, rfl, fun i => ...⟩

For the ∀ i part, prove by induction that Nat.rec n (fun _ x => f x) i ∈ answer using f_mem_answer_of_mem, then derive the three conditions from pos_of_answer and card_properDivisors_ge_of_answer.
-/
lemma answer_subset_lhs : answer ⊆ {a₁ | ∃ a : ℕ → ℕ, a 0 = a₁ ∧ ∀ i, 0 < a i ∧
    3 ≤ #(Nat.properDivisors (a i)) ∧
    a (i + 1) = (((Nat.properDivisors (a i)).sort (· ≤ ·)).reverse.take 3).sum} := by
  intro n hn
  use fun i => Nat.recOn i n (fun _ x => f x);
  -- By induction, we can show that all terms in the sequence are in the answer set.
  have h_ind : ∀ i, (Nat.recOn i n (fun _ x => f x)) ∈ answer := by
    exact fun i => Nat.recOn i hn fun i hi => f_mem_answer_of_mem hi;
  exact ⟨ rfl, fun i => ⟨ pos_of_answer ( h_ind i ), card_properDivisors_ge_of_answer ( h_ind i ), rfl ⟩ ⟩

/-
PROBLEM
If v₂=1, 3|n, 5∤n, n>0, then n ∈ answer.

PROVIDED SOLUTION
n is even (2|n), not divisible by 4, divisible by 3, not by 5.

Write n = 2*k where k is odd (since 4∤n). Then 3|k (since 3|n = 2k and 3∤2). And 5∤k (since 5∤n = 2k and 5∤2).

Let b = v₃(k) ≥ 1 (since 3|k). Let m = k / 3^b (the part coprime to 3). Then k = 3^b * m with gcd(m, 3) = 1. Also m is odd (since k is odd), so gcd(m, 2) = 1. And 5∤k implies 5∤m.

So gcd(m, 30) = gcd(m, 2*3*5) = 1 (since m is odd, coprime to 3, not divisible by 5).

n = 2 * 3^b * m with a = 1 (odd), b ≥ 1, 2b > 1 (since b ≥ 1 means 2b ≥ 2 > 1), gcd(m, 30) = 1, m ≥ 1 (since k > 0 implies m > 0).

Use ⟨1, b, m, ...⟩ to construct the answer witness. The factorization n = 2^1 * 3^b * m.
-/
lemma answer_of_v2_1_div3_not_div5 {n : ℕ} (hn : 0 < n) (hv2 : n % 2 = 0)
    (hv4 : ¬(4 ∣ n)) (h3 : 3 ∣ n) (h5 : ¬(5 ∣ n)) : n ∈ answer := by
  -- Write n = 2*k where k is odd (since 4∉n).
  obtain ⟨k, rfl⟩ : ∃ k, n = 2 * k := by
    exact Nat.dvd_of_mod_eq_zero hv2
  have hk_odd : Odd k := by
    exact Nat.odd_iff.mpr ( Nat.mod_two_ne_zero.mp fun h => hv4 <| dvd_trans ( by decide ) ( mul_dvd_mul_left 2 ( Nat.dvd_of_mod_eq_zero h ) ) )
  have hk_pos : k > 0 := by
    linarith
  have hk_not4 : ¬(2 ∣ k) := by
    simpa [ ← even_iff_two_dvd ] using hk_odd
  have hk_not5 : ¬(5 ∣ k) := by
    exact fun h => h5 <| dvd_mul_of_dvd_right h _
  have hk_div3 : 3 ∣ k := by
    omega
  have hk_card : 3 ≤ (Nat.properDivisors (2 * k)).card := by
    refine' Finset.two_lt_card.mpr _;
    refine' ⟨ 1, _, 2, _, 3, _, _, _ ⟩ <;> norm_num <;> omega;
  have hk_f : f (2 * k) = 2 * k := by
    convert f_eq_self_of_fixed _ _ _ _ _ _ using 1 <;> aesop
  have hk_f_mem : f (2 * k) ∈ answer := by
    -- Let $b = v₃(k)$ and $m = k / 3^b$.
    obtain ⟨b, hb⟩ : ∃ b, 3^b ∣ k ∧ ¬3^(b+1) ∣ k := by
      exact ⟨ Nat.factorization k 3, Nat.ordProj_dvd _ _, Nat.pow_succ_factorization_not_dvd hk_pos.ne' ( by decide ) ⟩
    obtain ⟨m, hm⟩ : ∃ m, k = 3^b * m ∧ ¬(3 ∣ m) := by
      exact ⟨ k / 3 ^ b, by rw [ Nat.mul_div_cancel' hb.1 ], by rw [ Nat.dvd_div_iff_mul_dvd hb.1 ] ; aesop ⟩
    have hm_pos : m > 0 := by
      grind
    have hm_not5 : ¬(5 ∣ m) := by
      exact fun h => hk_not5 <| hm.1.symm ▸ dvd_mul_of_dvd_right h _;
    have hm_coprime : Nat.Coprime m 6 := by
      exact Nat.Coprime.symm ( Nat.Coprime.mul_left ( Nat.prime_two.coprime_iff_not_dvd.mpr <| by simpa [ ← even_iff_two_dvd, parity_simps ] using hk_odd.of_dvd_nat <| hm.1.symm ▸ dvd_mul_left _ _ ) ( Nat.prime_three.coprime_iff_not_dvd.mpr hm.2 ) )
    have hm_coprime_30 : Nat.Coprime m 30 := by
      exact Nat.Coprime.mul_right hm_coprime ( Nat.Coprime.symm <| Nat.prime_iff.mpr ( by decide ) |> fun p => p.coprime_iff_not_dvd.mpr hm_not5 ) |> Nat.Coprime.coprime_dvd_right ( by decide ) ;
    have hm_f : f (2 * k) = 2 * 3^b * m := by
      rw [ hk_f, hm.1, mul_assoc ]
    have hm_mem : 2 * 3^b * m ∈ answer := by
      use 1, b, m;
      rcases b with ( _ | _ | b ) <;> simp_all +decide [ Nat.pow_succ', Nat.mul_assoc ];
      · exact hm_coprime_30;
      · exact ⟨ by linarith, hm_coprime_30 ⟩
    rw [hm_f]
    exact hm_mem
  have hk_mem : 2 * k ∈ answer := by
    rwa [ hk_f ] at hk_f_mem
  aesop

/-- f preserves non-membership in answer. -/
lemma f_notin_answer_general {n : ℕ} (hn_pos : 0 < n) (hn_notin : n ∉ answer)
    (hcard : 3 ≤ (Nat.properDivisors n).card) : f n ∉ answer := by
  sorry

/-
PROBLEM
No infinite valid sequence exists starting from an odd number.

PROVIDED SOLUTION
By strong induction on n (well-founded recursion on ℕ).

If n is odd and there exists an infinite valid sequence a with a(0) = n:
- a(0) = n is odd. By the sequence conditions, 3 ≤ #properDivisors(n).
- a(1) = f(n). By f_odd_of_odd, f(n) is odd. By f_lt_of_odd, f(n) < n.
- The sequence shifted by 1 (i.e., b(i) = a(i+1)) is a valid infinite sequence starting from f(n).
- By the induction hypothesis (since f(n) < n), no infinite valid sequence exists starting from f(n).
- Contradiction.

More concretely: use Nat.strongRecOn. Given n odd and hn: ∀ m < n, m odd → ¬(∃ ...), show ¬(∃ ...).
Suppose ⟨a, ha0, ha⟩. Then a(1) = f(n) is odd (by f_odd_of_odd applied with ha.2.1) and f(n) < n (by f_lt_of_odd). Define b(i) = a(i+1). Then b is an infinite valid sequence starting from f(n). But by IH, this is impossible. Contradiction.
-/
lemma no_infinite_seq_odd : ∀ n, ¬(2 ∣ n) →
    ¬(∃ a : ℕ → ℕ, a 0 = n ∧ ∀ i, 0 < a i ∧
    3 ≤ #(Nat.properDivisors (a i)) ∧
    a (i + 1) = (((Nat.properDivisors (a i)).sort (· ≤ ·)).reverse.take 3).sum) := by
  intros n hn_odd h_inf_seq
  obtain ⟨a, ha0, ha⟩ := h_inf_seq;
  -- By induction on $i$, we show that $a_i$ is odd for all $i$.
  have h_odd : ∀ i, ¬(2 ∣ a i) := by
    intro i
    induction' i with i ih;
    · aesop;
    · have := f_odd_of_odd ih ( ha i |>.2.1 ) ; aesop;
  -- By induction on $i$, we show that $a_i$ is strictly decreasing.
  have h_decreasing : StrictAnti a := by
    refine' strictAnti_nat_of_succ_lt _;
    exact fun i => by simpa [ ha i ] using f_lt_of_odd ( h_odd i ) ( ha i |>.2.1 ) ;
  exact absurd ( Set.infinite_range_of_injective h_decreasing.injective ) ( Set.not_infinite.mpr <| Set.finite_iff_bddAbove.mpr ⟨ a 0, by rintro x ⟨ i, rfl ⟩ ; exact h_decreasing.antitone <| Nat.zero_le _ ⟩ )

/-- Backward direction: only elements of answer have infinite valid sequences. -/
lemma lhs_subset_answer : {a₁ | ∃ a : ℕ → ℕ, a 0 = a₁ ∧ ∀ i, 0 < a i ∧
    3 ≤ #(Nat.properDivisors (a i)) ∧
    a (i + 1) = (((Nat.properDivisors (a i)).sort (· ≤ ·)).reverse.take 3).sum} ⊆ answer := by
  intro a₁ ⟨seq, hseq0, hseq⟩
  by_contra ha₁
  -- All terms are not in answer
  have h_notin : ∀ i, seq i ∉ answer := by
    intro i; induction i with
    | zero => exact hseq0 ▸ ha₁
    | succ i ih =>
      rw [show seq (i + 1) = f (seq i) from (hseq i).2.2]
      exact f_notin_answer_general (hseq i).1 ih (hseq i).2.1
  -- No term is odd (otherwise no_infinite_seq_odd gives contradiction)
  have h_even : ∀ i, 2 ∣ seq i := by
    intro i; by_contra h_odd
    exact no_infinite_seq_odd (seq i) h_odd ⟨fun j => seq (i + j), by simp, fun j => by
      constructor; exact (hseq (i + j)).1
      constructor; exact (hseq (i + j)).2.1
      exact (hseq (i + j)).2.2⟩
  -- Each term divisible by 3 with v₂=1 must have 5|n (otherwise ∈ answer)
  have h_v2_1_div3 : ∀ i, ¬(4 ∣ seq i) → 3 ∣ seq i → 5 ∣ seq i := by
    intro i h4 h3
    by_contra h5
    exact h_notin i (answer_of_v2_1_div3_not_div5 (hseq i).1
      (Nat.dvd_iff_mod_eq_zero.mp (h_even i)) h4 h3 h5)
  sorry

theorem result : {a₁ | ∃ a : ℕ → ℕ, a 0 = a₁ ∧ ∀ i, 0 < a i ∧ 3 ≤ #(Nat.properDivisors (a i)) ∧
    a (i + 1) = (((Nat.properDivisors (a i)).sort (· ≤ ·)).reverse.take 3).sum} = answer := by
  exact Set.Subset.antisymm lhs_subset_answer answer_subset_lhs

