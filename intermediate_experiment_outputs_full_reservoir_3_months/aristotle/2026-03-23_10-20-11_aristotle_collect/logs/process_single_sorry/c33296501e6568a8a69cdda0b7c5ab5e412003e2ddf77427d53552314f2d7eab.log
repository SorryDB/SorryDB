lemma f_lt_of_odd {n : ℕ} (hn_odd : ¬(2 ∣ n)) (hcard : 3 ≤ (Nat.properDivisors n).card) :
    f n < n := by
  -- Let $d_1 > d_2 > d_3$ be the three largest proper divisors of $n$.
  obtain ⟨d₁, d₂, d₃, hd₁, hd₂, hd₃, hd₁₂, hd₂₃, hd₃₁⟩ : ∃ d₁ d₂ d₃, d₁ ∈ Nat.properDivisors n ∧ d₂ ∈ Nat.properDivisors n ∧ d₃ ∈ Nat.properDivisors n ∧ d₂ < d₁ ∧ d₃ < d₂ ∧ ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d < d₃ ∨ d = d₃ := by
    -- Since there are at least three proper divisors, we can select the three largest ones.
    obtain ⟨d₁, hd₁⟩ : ∃ d₁ ∈ Nat.properDivisors n, ∀ d ∈ Nat.properDivisors n, d ≤ d₁ := by
      exact ⟨ Finset.max' _ <| Finset.card_pos.mp <| pos_of_gt hcard, Finset.max'_mem _ _, fun d hd => Finset.le_max' _ _ hd ⟩
    obtain ⟨d₂, hd₂, hd₂'⟩ : ∃ d₂ ∈ Nat.properDivisors n, d₂ ≠ d₁ ∧ ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≤ d₂ := by
      obtain ⟨d₂, hd₂⟩ : ∃ d₂ ∈ Nat.properDivisors n, d₂ ≠ d₁ := by
        exact Exists.imp ( by aesop ) ( Finset.exists_mem_ne ( lt_of_lt_of_le ( by decide ) hcard ) d₁ );
      exact ⟨ Finset.max' ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩ ) |>.1, Finset.mem_filter.mp ( Finset.max'_mem ( n.properDivisors.filter fun x => x ≠ d₁ ) ⟨ d₂, by aesop ⟩ ) |>.2, fun x hx hx' => Finset.le_max' _ _ <| by aesop ⟩
    obtain ⟨d₃, hd₃, hd₃'⟩ : ∃ d₃ ∈ Nat.properDivisors n, d₃ ≠ d₁ ∧ d₃ ≠ d₂ ∧ ∀ d ∈ Nat.properDivisors n, d ≠ d₁ → d ≠ d₂ → d ≤ d₃ := by
      obtain ⟨d₃, hd₃⟩ : ∃ d₃ ∈ Nat.properDivisors n, d₃ ≠ d₁ ∧ d₃ ≠ d₂ := by
        contrapose! hcard;
        exact lt_of_le_of_lt ( Finset.card_le_card ( show n.properDivisors ⊆ { d₁, d₂ } by intros x hx; by_cases hx' : x = d₁ <;> aesop ) ) ( by exact lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by norm_num ) );
      exact ⟨ Finset.max' ( Nat.properDivisors n |> Finset.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩, Finset.mem_filter.mp ( Finset.max'_mem ( Nat.properDivisors n |> Finset.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.1, Finset.mem_filter.mp ( Finset.max'_mem ( Nat.properDivisors n |> Finset.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.2.1, Finset.mem_filter.mp ( Finset.max'_mem ( Nat.properDivisors n |> Finset.filter fun x => x ≠ d₁ ∧ x ≠ d₂ ) ⟨ d₃, by aesop ⟩ ) |>.2.2, fun x hx hx' hx'' => Finset.le_max' _ _ <| by aesop ⟩;
    grind;
  -- Since $n$ is odd, the largest proper divisor $d₁$ is at most $n/3$.
  have hd₁_le_n_div_3 : d₁ ≤ n / 3 := by
    -- Since $d₁$ is a proper divisor of $n$, we have $n = d₁ * k$ for some integer $k$.
    obtain ⟨k, hk⟩ : ∃ k, n = d₁ * k := by
      exact Nat.mem_properDivisors.mp hd₁ |>.1;
    rw [ Nat.le_div_iff_mul_le ] <;> rcases k with ( _ | _ | _ | k ) <;> simp_all +decide ; nlinarith;
  rw [ top3_eq_of_three_largest hd₁ hd₂ hd₃ hd₁₂ hd₂₃ hd₃₁ ] ; omega;

/-
PROBLEM
For even n not divisible by 3 with ≥3 proper divisors, f(n) < n.

PROVIDED SOLUTION
For even n not divisible by 3 with ≥3 proper divisors, f(n) < n.

Since 2|n, the largest proper divisor d₁ = n/2.
Since 3∤n, the second largest proper divisor is at most n/4 (if 4|n) or n/p (where p ≥ 5 is the smallest odd prime factor, and p ≥ 5 > 4 so n/p < n/4; but wait n/4 is only a divisor if 4|n).

Case 1: 4|n. Then d₁ = n/2, d₂ ≤ n/4 (since the next divisor after n/2 is n/4 because there's no divisor between n/2 and n/4: any d with n/4 < d < n/2 would have 2 < n/d < 4, so n/d = 3, but 3∤n). So d₂ ≤ n/4 and d₃ ≤ n/4.
f(n) ≤ n/2 + n/4 + n/4 = n. But we need strict inequality: d₃ < d₂ (they're distinct in sorted order), so f(n) < n/2 + n/4 + n/4 = n.

Case 2: 4∤n, so n = 2m with m odd, 3∤m. The largest proper divisor is m = n/2. The second largest: this is either the largest proper divisor of 2m that is < m. Since 3∤n, the divisors of 2m in (n/4, n/2) = (m/2, m): any such d has n/d ∈ (2, 4), so n/d = 3, but 3∤n. So no divisor between m/2 and m (other than m itself). The next after m is ≤ m/2 = n/4. Wait, but 4∤n means n/4 isn't exact. Actually d₂ ≤ ⌊m/2⌋ < m/2 + 1 (in natural numbers).

