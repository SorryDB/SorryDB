/-
PROBLEM
5.

PROVIDED SOLUTION
Unfold the definitions of range, Ran, and graph, then show the two sets are equal by extensionality.
-/
example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  -- By definition of range, we have that range f = {y | ∃ x, f x = y}.
  ext y
  simp [range, Ran];
  simp +decide [ graph ]

