-- !benchmark @start import type=solution
import Mathlib.Data.List.Basic

-- !benchmark @end import

-- !benchmark @start solution_aux

-- !benchmark @end solution_aux

-- !benchmark @start precond_aux

-- !benchmark @end precond_aux
@[reducible]
def longestIncreasingSubseqLength_precond (xs : List Int) : Prop :=
  -- !benchmark @start precond
  True
  -- !benchmark @end precond


-- !benchmark @start code_aux
-- Generate all subsequences
def subsequences {α : Type} : List α → List (List α)
  | [] => [[]]
  | x :: xs =>
    let subs := subsequences xs
    subs ++ subs.map (fun s => x :: s)

-- Check if a list is strictly increasing
def isStrictlyIncreasing : List Int → Bool
  | [] => true
  | [_] => true
  | x :: y :: rest => if x < y then isStrictlyIncreasing (y :: rest) else false
-- !benchmark @end code_aux


def longestIncreasingSubseqLength (xs : List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) : Nat :=
  -- !benchmark @start code
  let subs := subsequences xs
  let increasing := subs.filter isStrictlyIncreasing
  increasing.foldl (fun acc s => max acc s.length) 0
  -- !benchmark @end code


-- !benchmark @start postcond_aux
-- !benchmark @end postcond_aux


@[reducible]
def longestIncreasingSubseqLength_postcond (xs : List Int) (result: Nat) (h_precond : longestIncreasingSubseqLength_precond (xs)) : Prop :=
  -- !benchmark @start postcond
  let allSubseq := (xs.foldl fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse
  let increasingSubseqLens := allSubseq.filter (fun l => List.Pairwise (· < ·) l) |>.map (·.length)
  increasingSubseqLens.contains result ∧ increasingSubseqLens.all (· ≤ result)
  -- !benchmark @end postcond


-- !benchmark @start proof_aux

-- Abbreviations for the two key lists
noncomputable def codeLens (xs : List Int) : List Nat :=
  ((subsequences xs).filter isStrictlyIncreasing).map (·.length)

noncomputable def postLens (xs : List Int) : List Nat :=
  (((xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse).filter
    (fun l => decide (List.Pairwise (· < ·) l))).map (·.length)

/-
PROBLEM
Helper 1: isStrictlyIncreasing agrees with decide (Pairwise (<))

PROVIDED SOLUTION
By induction on l.
- Base cases: l = [] and l = [x] are both trivially true (both sides are true).
- Inductive case: l = x :: y :: rest. isStrictlyIncreasing (x :: y :: rest) = if x < y then isStrictlyIncreasing (y :: rest) else false. And decide (Pairwise (· < ·) (x :: y :: rest)) = decide (x < y ∧ (∀ z ∈ y :: rest, x < z) ∧ Pairwise (· < ·) (y :: rest))... actually Pairwise for x :: y :: rest means (∀ z ∈ y :: rest, x < z) ∧ Pairwise (· < ·) (y :: rest). But since Pairwise (· < ·) (y :: rest) implies ∀ z ∈ rest, y < z, and x < y, we get x < z for all z ∈ rest by transitivity.

So the key insight: Pairwise (· < ·) (x :: y :: rest) ↔ x < y ∧ Pairwise (· < ·) (y :: rest). This is because if x < y and y < z for all z in the tail of (y :: rest), then x < z. This uses transitivity of <.

Use List.pairwise_cons and the inductive hypothesis.
-/
lemma isStrictlyIncreasing_eq_decide_pairwise (l : List Int) :
    isStrictlyIncreasing l = decide (List.Pairwise (· < ·) l) := by
      -- The definition of `isStrictlyIncreasing` is equivalent to `isStrictlyIncreasing'`, which is `List.Pairwise (· < ·)`.
      have h_eq : ∀ l : List ℤ, isStrictlyIncreasing l ↔ List.Pairwise (· < ·) l := by
        intros l; induction l <;> simp +decide [ * ] ;
        cases ‹List ℤ› <;> simp_all +decide [ isStrictlyIncreasing ];
        exact fun h1 h2 h3 a ha => lt_trans h3 ( h1 a ha );
      grind

/-
PROBLEM
Helper 2a: subsequences generates exactly the sublists

PROVIDED SOLUTION
By induction on xs.

Base case: xs = []. subsequences [] = [[]]. So s ∈ [[]] ↔ s = []. And s.Sublist [] ↔ s = [] (by List.sublist_nil). So both sides are equivalent to s = [].

Inductive case: xs = x :: rest. subsequences (x :: rest) = subsequences rest ++ (subsequences rest).map (x :: ·).
So s ∈ subsequences (x :: rest) ↔ s ∈ subsequences rest ∨ ∃ t ∈ subsequences rest, s = x :: t.
By IH, s ∈ subsequences rest ↔ s.Sublist rest.
So: s ∈ subsequences (x :: rest) ↔ s.Sublist rest ∨ ∃ t, t.Sublist rest ∧ s = x :: t.

And s.Sublist (x :: rest) ↔ s.Sublist rest ∨ ∃ t, t.Sublist rest ∧ s = x :: t (by the definition of Sublist: either we skip x, or we take x and s = x :: t with t.Sublist rest).

Use List.sublist_cons_iff or List.Sublist.cons and List.Sublist.cons₂ constructors.
-/
lemma mem_subsequences_iff_sublist (xs : List Int) (s : List Int) :
    s ∈ subsequences xs ↔ s.Sublist xs := by
      induction xs generalizing s <;> simp_all +decide [ subsequences ];
      grind

/-
PROBLEM
Helper 2b: foldl-based generator (after reversing) also generates exactly the sublists

PROVIDED SOLUTION
By induction on xs.

Base case: xs = []. foldl f [[]] [] = [[]], map reverse = [[]]. So s ∈ [[]] ↔ s = []. And s.Sublist [] ↔ s = []. Done.

Inductive case: xs = x :: rest.
(x :: rest).foldl f [[]] = rest.foldl f (f [[]] x) = rest.foldl f [[], [x]].

We need a generalized induction. The key invariant is:

For any init : List (List Int),
  s ∈ (xs.foldl f init).map reverse ↔
  ∃ t ∈ init.map reverse, ∃ u, u.Sublist xs ∧ s = u ++ t

Specifically, the foldl accumulates reversed prefixes. After processing xs, each element of the accumulator is some reversed subsequence of xs prepended to some initial element.

Actually, let me think of a cleaner invariant.

Generalized claim: for any acc : List (List Int),
  t ∈ (xs.foldl f acc) ↔ ∃ a ∈ acc, ∃ u, u.Sublist xs ∧ t = u.reverse ++ a

where f = fun acc x => acc ++ acc.map (fun sub => x :: sub).

Then for our case, acc = [[]], so:
  t ∈ (xs.foldl f [[]]) ↔ ∃ u, u.Sublist xs ∧ t = u.reverse ++ [] = u.reverse
  ↔ t.reverse.Sublist xs

So s ∈ (xs.foldl f [[]]).map reverse ↔ ∃ t, t ∈ xs.foldl f [[]] ∧ s = t.reverse
↔ ∃ t, t.reverse.Sublist xs ∧ s = t.reverse ↔ s.Sublist xs.

So prove by induction on xs the generalized claim about foldl.

Base: xs = []. foldl f acc [] = acc. t ∈ acc ↔ ∃ a ∈ acc, t = [].reverse ++ a (with u = []). Since [].Sublist [] and [].reverse ++ a = a. ✓

Step: xs = y :: ys. foldl f acc (y :: ys) = foldl f (acc ++ acc.map (y :: ·)) ys.
By IH on ys with acc' = acc ++ acc.map (y :: ·):
t ∈ foldl f acc' ys ↔ ∃ a ∈ acc', ∃ u, u.Sublist ys ∧ t = u.reverse ++ a.
Now a ∈ acc' means a ∈ acc ∨ ∃ b ∈ acc, a = y :: b.
Case 1: a ∈ acc, u.Sublist ys. Then t = u.reverse ++ a, and u.Sublist ys → u.Sublist (y :: ys) (by .cons). So ∃ a ∈ acc, ∃ u', u'.Sublist (y :: ys) ∧ t = u'.reverse ++ a with u' = u.
Case 2: a = y :: b, b ∈ acc, u.Sublist ys. Then t = u.reverse ++ (y :: b) = (u ++ [y]).reverse ++ b... wait, u.reverse ++ (y :: b) = u.reverse ++ [y] ++ b = (y :: u).reverse ++ b. And (y :: u).Sublist (y :: ys) ↔ u.Sublist ys (by .cons₂). So ∃ b ∈ acc, ∃ u' = y :: u, u'.Sublist (y :: ys) ∧ t = u'.reverse ++ b.

And conversely: if u'.Sublist (y :: ys), either u'.Sublist ys (case 1), or u' = y :: u with u.Sublist ys (case 2).

This is the right argument but it's quite involved. Let me write it as a separate generalized lemma.
-/
lemma mem_foldl_reverse_iff_sublist (xs : List Int) (s : List Int) :
    s ∈ ((xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse) ↔
    s.Sublist xs := by
      have h_rev : ∀ (l : List ℤ), List.foldl (fun acc x => acc ++ List.map (fun sub => x :: sub) acc) [[]] l = List.map List.reverse (List.sublists l) := by
        intro l; induction l using List.reverseRecOn <;> aesop;
      aesop

-- Helper 2: membership equivalence for the two subseq generators
lemma mem_subsequences_iff_mem_foldl (xs : List Int) (s : List Int) :
    s ∈ subsequences xs ↔
    s ∈ ((xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse) := by
  rw [mem_subsequences_iff_sublist, mem_foldl_reverse_iff_sublist]

/-
PROBLEM
Helper 3: the codeLens and postLens have the same elements

PROVIDED SOLUTION
Unfold codeLens and postLens. Use mem_subsequences_iff_mem_foldl and isStrictlyIncreasing_eq_decide_pairwise to show that the two filtered lists have the same membership.

A length n is in codeLens xs iff there exists s in (subsequences xs).filter(isStrictlyIncreasing) with s.length = n. By mem_subsequences_iff_mem_foldl, s ∈ subsequences xs ↔ s ∈ foldl(...).map reverse. By isStrictlyIncreasing_eq_decide_pairwise, isStrictlyIncreasing s = decide(Pairwise (<) s). So filtering by isStrictlyIncreasing on subsequences gives the same set as filtering by decide(Pairwise (<)) on foldl.map reverse. Hence the length maps have the same elements.
-/
lemma codeLens_iff_postLens (xs : List Int) (n : Nat) :
    n ∈ codeLens xs ↔ n ∈ postLens xs := by
      unfold codeLens postLens;
      -- Apply `mem_subsequences_iff_mem_foldl` to rewrite the membership in `codeLens` in terms of `foldl`.
      simp [mem_subsequences_iff_mem_foldl, isStrictlyIncreasing_eq_decide_pairwise]

/-
PROBLEM
Helper 4: codeLens is nonempty (empty list is always a subseq)

PROVIDED SOLUTION
The empty list [] is always in subsequences xs (by induction, it's in the first part of the split). And isStrictlyIncreasing [] = true. So [] is in the filtered list, hence its length 0 is in codeLens xs. Therefore codeLens xs ≠ [].
-/
lemma codeLens_nonempty (xs : List Int) : codeLens xs ≠ [] := by
  unfold codeLens;
  induction xs <;> simp_all +decide [ List.foldl ];
  obtain ⟨ x, hx₁, hx₂ ⟩ := ‹_›; use x; simp_all +decide [ subsequences ] ;

/-
PROBLEM
Helper 5a: foldl max 0 is in the list when nonempty

PROVIDED SOLUTION
By induction on l. For l = [a], foldl max 0 [a] = max 0 a. If a ≥ 0 (which it is since Nat), max 0 a = a ∈ [a]. For l = a :: rest (rest nonempty), foldl max 0 (a :: rest) = foldl max (max 0 a) rest. This is the max of (max 0 a) and all elements of rest. The result is either max 0 a (which is 0 or a) or some element of rest. In any case it's in a :: rest.

Actually more carefully: prove by induction that for any init and nonempty l, foldl max init l ∈ l ∨ foldl max init l = init. Then specialize with init = 0 and use that 0 ≤ every Nat to show that if foldl max 0 l = 0 then 0 must be in l (since all elements are ≥ 0, foldl max 0 l ≥ max of l, so if result is 0 then all elements are 0 and 0 ∈ l).
-/
lemma foldl_max_mem (l : List Nat) (hl : l ≠ []) :
    l.foldl max 0 ∈ l := by
      induction l using List.reverseRecOn ; aesop;
      grind +ring

/-
PROBLEM
Helper 5b: foldl max 0 is ≥ all elements

PROVIDED SOLUTION
By induction on l. The key property is that foldl max init (a :: rest) = foldl max (max init a) rest. Since max init a ≥ a, and foldl max is monotone in init, we get foldl max init l ≥ init and foldl max init l ≥ every element. More precisely, prove by induction: ∀ init l x, x ∈ l → x ≤ foldl max init l, and also init ≤ foldl max init l. These go by induction on l.
-/
lemma foldl_max_ge (l : List Nat) (x : Nat) (hx : x ∈ l) :
    x ≤ l.foldl max 0 := by
      induction l using List.reverseRecOn <;> aesop

/-
PROBLEM
!benchmark @end proof_aux

PROVIDED SOLUTION
Use the helper lemmas codeLens_iff_postLens, codeLens_nonempty, foldl_max_mem, foldl_max_ge.

The proof goes:
1. Unfold longestIncreasingSubseqLength_postcond and longestIncreasingSubseqLength. The result is `(subsequences xs).filter(isStrictlyIncreasing).foldl(fun acc s => max acc s.length) 0`.
2. The postcondition asks: `increasingSubseqLens.contains result ∧ increasingSubseqLens.all (· ≤ result)` where `increasingSubseqLens = postLens xs`.
3. Note that `result = codeLens(xs).foldl max 0` (since foldl (fun acc s => max acc s.length) 0 = (map length).foldl max 0).
4. For contains: By foldl_max_mem (codeLens_nonempty xs), result ∈ codeLens xs. By codeLens_iff_postLens, result ∈ postLens xs. So contains holds.
5. For all: Take any x ∈ postLens xs. By codeLens_iff_postLens (backwards), x ∈ codeLens xs. By foldl_max_ge, x ≤ result.
