import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  -- Since there are $2^{10} - 1$ nonempty subsets of $S$, but only $936$ possible sums, by the pigeonhole principle, there must be at least two distinct subsets with the same sum.
  have h_pigeonhole : ∃ A B : Finset ℕ, A ⊆ S ∧ B ⊆ S ∧ A ≠ B ∧ (∑ x ∈ A, x) = (∑ x ∈ B, x) := by
    by_contra h_contra;
    norm_num +zetaDelta at *;
    exact absurd ( Finset.card_le_card ( show Finset.image ( fun t : Finset ℕ => ∑ x ∈ t, x ) ( Finset.powerset S ) ⊆ Finset.Icc 0 ( 99 * 10 ) from Finset.image_subset_iff.mpr fun t ht => Finset.mem_Icc.mpr ⟨ Nat.zero_le _, by exact le_trans ( Finset.sum_le_sum_of_subset ( Finset.mem_powerset.mp ht ) ) ( by exact le_trans ( Finset.sum_le_sum fun _ _ => Finset.mem_Ico.mp ( h₁ ‹_› ) |>.2 |> Nat.le_of_lt_succ ) ( by norm_num [ h₀ ] ) ) ⟩ ) ) ( by rw [ Finset.card_image_of_injOn ( fun t ht t' ht' h => by specialize h_contra t ( Finset.mem_powerset.mp ht ) t' ( Finset.mem_powerset.mp ht' ) ; aesop ) ] ; norm_num [ h₀ ] );
  -- Let $A$ and $B$ be two distinct subsets of $S$ with the same sum.
  obtain ⟨A, B, hA, hB, hAB, hsum⟩ := h_pigeonhole;
  use A \ B, B \ A; simp_all +decide [ Finset.disjoint_iff_inter_eq_empty, Finset.sdiff_eq_inter_compl ];
  cases em ( A \ B = ∅ ) <;> cases em ( B \ A = ∅ ) <;> simp_all +decide [ Finset.subset_iff ];
  · exact False.elim <| hAB <| Finset.Subset.antisymm ‹_› ‹_›;
  · contrapose! hsum; simp_all +decide [ ← Finset.sum_sdiff ‹∀ x ∈ A, x ∈ B› ] ;
    grind;
  · have h_sum_eq : ∑ x ∈ A, x = ∑ x ∈ B, x + ∑ x ∈ A \ B, x := by
      rw [ add_comm, Finset.sum_sdiff <| by tauto ];
    simp_all +decide [ Finset.sum_eq_zero_iff_of_nonneg ];
    grind +ring;
  · simp_all +decide [ Finset.ext_iff ];
    exact ⟨ by obtain ⟨ x, hx₁, hx₂ ⟩ := ‹∃ x ∈ A, x∉B›; exact ⟨ x, by aesop ⟩, by obtain ⟨ x, hx₁, hx₂ ⟩ := ‹∃ x ∈ B, x∉A›; exact ⟨ x, by aesop ⟩, by rw [ show ∑ x ∈ A, x = ∑ x ∈ A \ B, x + ∑ x ∈ A ∩ B, x by rw [ ← Finset.sum_union ( Finset.disjoint_right.mpr fun x => by aesop ) ] ; congr; ext x; by_cases hx : x ∈ B <;> aesop, show ∑ x ∈ B, x = ∑ x ∈ B \ A, x + ∑ x ∈ A ∩ B, x by rw [ ← Finset.sum_union ( Finset.disjoint_right.mpr fun x => by aesop ) ] ; congr; ext x; by_cases hx : x ∈ A <;> aesop ] at hsum ; linarith ⟩
