variable
  {X} [NormedAddCommGroup X] [AdjointSpace 𝕜 X]
  {Y} [NormedAddCommGroup Y] [AdjointSpace 𝕜 Y]
  {ι : Type*} [Fintype ι]
  {E : ι → Type*} [∀ i, NormedAddCommGroup (E i)] [∀ i, AdjointSpace 𝕜 (E i)]

instance : AdjointSpace 𝕜 𝕜 where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp [norm_sq_eq_def]
  conj_symm := by simp[mul_comm]
  add_left := by simp[add_mul]
  smul_left := by simp[mul_assoc]

instance : Inner 𝕜 Unit where
  inner _ _ := 0

instance : AdjointSpace 𝕜 Unit where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp[Inner.inner]
  conj_symm := by simp[Inner.inner]
  add_left := by simp[Inner.inner]
  smul_left := by simp[Inner.inner]

instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    apply Exists.intro (cx*cx + cy*cy) -- todo: fix this constant
    apply Exists.intro (dx*dx + dy*dy) -- todo: fix this constant
    constructor
    · positivity
    constructor
    · positivity
    · intro (x,y)
      sorry
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
  smul_left := by simp[inner_smul_left,mul_add]

open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    by_cases h : Nonempty ι
    · choose! c d hc hd h using fun i => inner_top_equiv_norm (𝕜:=𝕜) (E:=E i)
      refine' ⟨ Finset.min' ( Finset.univ.image c ) ⟨ _, Finset.mem_image_of_mem c ( Finset.mem_univ ( Classical.arbitrary ι ) ) ⟩, ∑ i, d i, _, _, _ ⟩
      · simp +decide [ Finset.min', hc ]
      · exact Finset.sum_pos ( fun i _ => hd i ) Finset.univ_nonempty
      · intro x
        have h_lower : (Finset.min' (Finset.univ.image c) ⟨ _, Finset.mem_image_of_mem c ( Finset.mem_univ ( Classical.arbitrary ι ) ) ⟩ : ℝ) • ‖x‖^2 ≤ ∑ i, c i • ‖x i‖^2 := by
          have h_lower_bound : ∑ i, (c i) • ‖x i‖^2 ≥ ∑ i, (Finset.min' (Finset.univ.image c) ⟨ _, Finset.mem_image_of_mem c (Finset.mem_univ (Classical.arbitrary ι)) ⟩) • ‖x i‖^2 := by
            exact Finset.sum_le_sum fun i _ => mul_le_mul_of_nonneg_right ( Finset.min'_le _ _ ( Finset.mem_image_of_mem c ( Finset.mem_univ i ) ) ) ( sq_nonneg _ )
          have h_norm_sq : ‖x‖^2 ≤ ∑ i, ‖x i‖^2 := by
            have h_norm_sq : ‖x‖^2 ≤ ∑ i, ‖x i‖^2 := by
              have h_norm_sq : ∀ i, ‖x i‖^2 ≤ ∑ i, ‖x i‖^2 := by
                exact fun i => Finset.single_le_sum ( fun i _ => sq_nonneg ( ‖x i‖ ) ) ( Finset.mem_univ i )
              exact le_trans ( pow_le_pow_left₀ ( norm_nonneg _ ) ( show ‖x‖ ≤ ( ∑ i, ‖x i‖ ^ 2 ) ^ ( 1 / 2 : ℝ ) from by rw [ ← Real.sqrt_eq_rpow ] ; exact by simpa using pi_norm_le_iff_of_nonneg ( Real.sqrt_nonneg _ ) |>.2 fun i => Real.le_sqrt_of_sq_le ( h_norm_sq i ) ) _ ) ( by rw [ ← Real.sqrt_eq_rpow, Real.sq_sqrt ( Finset.sum_nonneg fun _ _ => sq_nonneg _ ) ] )
            exact h_norm_sq
          simp_all +decide [ ← Finset.mul_sum _ _ _, ← Finset.sum_mul ]
          exact le_trans ( mul_le_mul_of_nonneg_left h_norm_sq ( Finset.min'_mem ( Finset.image c Finset.univ ) ⟨ _, Finset.mem_image_of_mem c ( Finset.mem_univ ( Classical.arbitrary ι ) ) ⟩ |> fun h => by obtain ⟨ i, _, hi ⟩ := Finset.mem_image.mp h; exact hi ▸ le_of_lt ( hc i ) ) ) h_lower_bound
        have h_upper : ∑ i, d i • ‖x i‖^2 ≤ (∑ i, d i) • ‖x‖^2 := by
          simp +decide [ Finset.sum_smul, smul_pow ]
          rw [ Finset.sum_mul _ _ _ ]
          exact Finset.sum_le_sum fun i _ => mul_le_mul_of_nonneg_left ( pow_le_pow_left₀ ( norm_nonneg _ ) ( norm_le_pi_norm x i ) 2 ) ( le_of_lt ( hd i ) )
        simp_all +decide [ Finset.sum_apply, Complex.re ]
        exact ⟨ h_lower.trans ( Finset.sum_le_sum fun i _ => h i _ |>.1 ), le_trans ( Finset.sum_le_sum fun i _ => h i _ |>.2 ) h_upper ⟩
    · refine' ⟨ 1, 1, by norm_num, by norm_num, fun x => ⟨ _, _ ⟩ ⟩ <;> simp +decide [ Norm.norm ]
      · aesop
      · aesop
  conj_symm := by simp
  add_left := by simp[inner_add_left,Finset.sum_add_distrib]
  smul_left := by simp[inner_smul_left,Finset.mul_sum]


theorem inner_prod_split (x y : X×Y) : ⟪x,y⟫_𝕜 = ⟪x.1,y.1⟫_𝕜 + ⟪x.2,y.2⟫_𝕜 := by rfl

theorem inner_forall_split (f g : (i : ι) → E i) :
    ⟪f,g⟫_𝕜 = ∑ i, ⟪f i, g i⟫_𝕜 := by rfl

