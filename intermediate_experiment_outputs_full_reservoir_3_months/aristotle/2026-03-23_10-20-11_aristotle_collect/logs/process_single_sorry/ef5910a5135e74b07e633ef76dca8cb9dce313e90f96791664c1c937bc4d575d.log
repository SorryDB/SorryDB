  aemeasurable_snd := Measurable.aemeasurable (by fun_prop)
  map_eq := by
    rw [‚Üź (hasLaw_eval_eval_streamMeasure őĹ n a).map_eq,
      Measure.map_map (by fun_prop) (by fun_prop)]
    simp

lemma Integrable.congr_identDistrib {ő© ő©' : Type*}
    {mő© : MeasurableSpace ő©} {mő©' : MeasurableSpace ő©'}
    {őľ : Measure ő©} {őľ' : Measure ő©'} {X : ő© ‚Üí ‚ĄĚ} {Y : ő©' ‚Üí ‚ĄĚ}
    (hX : Integrable X őľ) (hXY : IdentDistrib X Y őľ őľ') :
    Integrable Y őľ' := by
  have hX' : Integrable id (őľ.map X) := by
    rwa [integrable_map_measure (by fun_prop) hXY.aemeasurable_fst]
  rw [hXY.map_eq] at hX'
  rwa [integrable_map_measure (by fun_prop) hXY.aemeasurable_snd] at hX'

lemma integrable_eval_streamMeasure (őĹ : Kernel őĪ ‚ĄĚ) [IsMarkovKernel őĹ] (n : ‚Ąē) (a : őĪ)
    (h_int : Integrable id (őĹ a)) :
    Integrable (fun h : ‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ ‚Ü¶ h n a) (Bandit.streamMeasure őĹ) :=
  Integrable.congr_identDistrib h_int (identDistrib_eval_eval_id_streamMeasure őĹ n a).symm

lemma integral_eval_streamMeasure (őĹ : Kernel őĪ ‚ĄĚ) [IsMarkovKernel őĹ] (n : ‚Ąē) (a : őĪ) :
    ‚ąę h, h n a ‚ąā(Bandit.streamMeasure őĹ) = (őĹ a)[id] := by
  calc ‚ąę h, h n a ‚ąā(Bandit.streamMeasure őĹ)
  _ = ‚ąę x, x ‚ąā((Bandit.streamMeasure őĹ).map (fun h ‚Ü¶ h n a)) := by
    rw [integral_map (Measurable.aemeasurable (by fun_prop)) (by fun_prop)]
  _ = (őĹ a)[id] := by simp [(hasLaw_eval_eval_streamMeasure őĹ n a).map_eq]

lemma iIndepFun_eval_streamMeasure' (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    iIndepFun (fun n ŌČ ‚Ü¶ ŌČ n) (Bandit.streamMeasure őĹ) :=
  iIndepFun_infinitePi (P := fun (_ : ‚Ąē) ‚Ü¶ Measure.infinitePi őĹ) (ő© := fun _ ‚Ü¶ őĪ ‚Üí R)
    (X := fun i u ‚Ü¶ u) (fun i ‚Ü¶ by fun_prop)

lemma iIndepFun_eval_streamMeasure'' (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (a : őĪ) :
    iIndepFun (fun n ŌČ ‚Ü¶ ŌČ n a) (Bandit.streamMeasure őĹ) :=
  (iIndepFun_eval_streamMeasure' őĹ).comp (g := fun i ŌČ ‚Ü¶ ŌČ a) (by fun_prop)

lemma iIndepFun_eval_streamMeasure (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    iIndepFun (fun (p : ‚Ąē √ó őĪ) ŌČ ‚Ü¶ ŌČ p.1 p.2) (Bandit.streamMeasure őĹ) :=
  iIndepFun_uncurry_infinitePi' (X := fun _ _ ‚Ü¶ id) (fun _ ‚Ü¶ őĹ) (by fun_prop)

lemma indepFun_eval_streamMeasure (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] {n m : ‚Ąē} {a b : őĪ}
    (h : n ‚Č† m ‚ą® a ‚Č† b) :
    IndepFun (fun ŌČ ‚Ü¶ ŌČ n a) (fun ŌČ ‚Ü¶ ŌČ m b) (Bandit.streamMeasure őĹ) := by
  change IndepFun (fun ŌČ ‚Ü¶ ŌČ (n, a).1 (n, a).2) (fun ŌČ ‚Ü¶ ŌČ (m, b).1 (m, b).2)
    (Bandit.streamMeasure őĹ)
  exact (iIndepFun_eval_streamMeasure őĹ).indepFun (by grind)

lemma indepFun_eval_streamMeasure' (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] {a b : őĪ} (h : a ‚Č† b) :
    IndepFun (fun ŌČ n ‚Ü¶ ŌČ n a) (fun ŌČ n ‚Ü¶ ŌČ n b) (Bandit.streamMeasure őĹ) :=
  indepFun_proj_infinitePi_infinitePi h

lemma indepFun_eval_snd_measure (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ]
    {a b : őĪ} (h : a ‚Č† b) :
    IndepFun (fun ŌČ n ‚Ü¶ ŌČ.2 n a) (fun ŌČ n ‚Ü¶ ŌČ.2 n b) (Bandit.measure alg őĹ) := by
  refine indepFun_snd_prod ?_ ?_ (indepFun_eval_streamMeasure' őĹ h) (Bandit.trajMeasure alg őĹ)
  ¬∑ exact Measurable.aemeasurable (by fun_prop)
  ¬∑ exact Measurable.aemeasurable (by fun_prop)

end StreamMeasure

section DetAlgorithm

variable {nextaction : (n : ‚Ąē) ‚Üí (Iic n ‚Üí őĪ √ó R) ‚Üí őĪ} {h_next : ‚ąÄ n, Measurable (nextaction n)}
  {action0 : őĪ} {őĹ : Kernel őĪ R} [IsMarkovKernel őĹ]

local notation "ūĚĒďt" => Bandit.trajMeasure (detAlgorithm nextaction h_next action0) őĹ

lemma HasLaw_action_zero_detAlgorithm : HasLaw (IT.action 0) (Measure.dirac action0) ūĚĒďt where
  map_eq := (IT.hasLaw_action_zero _ _).map_eq

lemma action_zero_detAlgorithm [MeasurableSingletonClass őĪ] :
    IT.action 0 =ŠĶź[ūĚĒďt] fun _ ‚Ü¶ action0 :=
  IT.action_zero_detAlgorithm

lemma action_detAlgorithm_ae_eq [StandardBorelSpace őĪ] [Nonempty őĪ]
    [StandardBorelSpace R] [Nonempty R] (n : ‚Ąē) :
    IT.action (n + 1) =ŠĶź[ūĚĒďt] fun h ‚Ü¶ nextaction n (fun i ‚Ü¶ h i) :=
  IT.action_detAlgorithm_ae_eq n

example [StandardBorelSpace őĪ] [Nonempty őĪ]
    [StandardBorelSpace R] [Nonempty R] :
    ‚ąÄŠĶź h ‚ąā(ūĚĒďt), IT.action 0 h = action0 ‚ąß
      ‚ąÄ n, IT.action (n + 1) h = nextaction n (fun i ‚Ü¶ h i) := by
  rw [eventually_and, ae_all_iff]
  exact ‚ü®action_zero_detAlgorithm, action_detAlgorithm_ae_eq‚ü©

end DetAlgorithm

namespace ArrayModel

open unitInterval

section Aux

-- from Mathlib PR #30112
theorem representation {őĪ ő≤ : Type*} {mőĪ : MeasurableSpace őĪ} {mő≤ : MeasurableSpace ő≤}
    [Nonempty ő≤] [StandardBorelSpace ő≤]
    (őļ : Kernel őĪ ő≤) [IsMarkovKernel őļ] :
    ‚ąÉ (f : őĪ ‚Üí I ‚Üí ő≤), Measurable (Function.uncurry f) ‚ąß ‚ąÄ a, volume.map (f a) = őļ a := sorry

theorem representation_measure {ő≤ : Type*} {mő≤ : MeasurableSpace ő≤}
    [Nonempty ő≤] [StandardBorelSpace ő≤]
    (őľ : Measure ő≤) [IsProbabilityMeasure őľ] :
    ‚ąÉ (f : I ‚Üí ő≤), Measurable f ‚ąß volume.map f = őľ := by
  obtain ‚ü®f, hf_meas, hf_map‚ü© := representation (Kernel.const Unit őľ)
  specialize hf_map ‚ü®‚ü©
  exact ‚ü®f ‚ü®‚ü©, by fun_prop, by simpa‚ü©

end Aux

variable (őĪ R) in
def probSpace : Type _ := (‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R)

instance {őĪ R : Type*} [MeasurableSpace R] : MeasurableSpace (probSpace őĪ R) :=
  inferInstanceAs (MeasurableSpace ((‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R)))

noncomputable
def arrayMeasure (őĹ : Kernel őĪ R) : Measure (probSpace őĪ R) :=
  (Measure.infinitePi fun _ ‚Ü¶ volume).prod (Bandit.streamMeasure őĹ)

instance (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] : IsProbabilityMeasure (arrayMeasure őĹ) :=
  Measure.prod.instIsProbabilityMeasure _ _

variable [Nonempty őĪ] [StandardBorelSpace őĪ]

noncomputable
def initAlgFunction (alg : Algorithm őĪ R) : I ‚Üí őĪ :=
  (representation_measure alg.p0).choose

lemma initAlgFunction_map (alg : Algorithm őĪ R) : volume.map (initAlgFunction alg) = alg.p0 :=
  (representation_measure alg.p0).choose_spec.2

@[fun_prop]
lemma measurable_initAlgFunction (alg : Algorithm őĪ R) :
    Measurable (initAlgFunction alg) := (representation_measure alg.p0).choose_spec.1

noncomputable
def algFunction (alg : Algorithm őĪ R) (n : ‚Ąē) :
    (Iic n ‚Üí őĪ √ó R) ‚Üí I ‚Üí őĪ :=
  (representation (alg.policy n)).choose

lemma algFunction_map (alg : Algorithm őĪ R) (n : ‚Ąē) (h : Iic n ‚Üí őĪ √ó R) :
      volume.map (algFunction alg n h) = alg.policy n h :=
  (representation (alg.policy n)).choose_spec.2 h

@[fun_prop]
lemma measurable_algFunction (alg : Algorithm őĪ R) (n : ‚Ąē) :
    Measurable (Function.uncurry (algFunction alg n)) :=
  (representation (alg.policy n)).choose_spec.1

noncomputable
def hist [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R) : (n : ‚Ąē) ‚Üí Iic n ‚Üí őĪ √ó R
| 0 => fun _ ‚Ü¶ (initAlgFunction alg (ŌČ.1 0), ŌČ.2 0 (initAlgFunction alg (ŌČ.1 0)))
| n + 1 =>
  let hn : Iic n ‚Üí őĪ √ó R := hist alg ŌČ n
  let a : őĪ := algFunction alg n hn (ŌČ.1 (n + 1))
  fun i ‚Ü¶ if hin : i ‚Č§ n then hn ‚ü®i, by simp [hin]‚ü© else (a, ŌČ.2 (pullCount' n hn a) a)

@[simp]
lemma hist_zero [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R) :
    hist alg ŌČ 0 = fun _ ‚Ü¶ (initAlgFunction alg (ŌČ.1 0), ŌČ.2 0 (initAlgFunction alg (ŌČ.1 0))) :=
  rfl

lemma hist_add_one [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R) (n : ‚Ąē) :
    let a : őĪ := algFunction alg n (hist alg ŌČ n) (ŌČ.1 (n + 1))
    hist alg ŌČ (n + 1) =
      fun (i : Iic (n + 1)) ‚Ü¶ if hin : i ‚Č§ n then hist alg ŌČ n ‚ü®i, by simp [hin]‚ü©
        else (a, ŌČ.2 (pullCount' n (hist alg ŌČ n) a) a) :=
  rfl

lemma hist_eq [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R) (n : ‚Ąē) :
    hist alg ŌČ n = fun i : Iic n ‚Ü¶ hist alg ŌČ i ‚ü®i.1, by simp‚ü© := by
  induction n with
  | zero =>
    ext i : 1
    simp only [hist]
    rw [Unique.eq_default i]
    simp [coe_default_Iic_zero]
  | succ n hn =>
    ext i : 1
    by_cases hin : i ‚Č§ n
    ¬∑ rw [hist_add_one]
      simp only [hin, ‚ÜďreduceDIte]
      rw [funext_iff] at hn
      simp_rw [hn]
    ¬∑ grind

lemma hist_add_one_eq_IicSuccProd' [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R)
    (n : ‚Ąē) :
    let a : őĪ := algFunction alg n (hist alg ŌČ n) (ŌČ.1 (n + 1))
    hist alg ŌČ (n + 1) =
      (MeasurableEquiv.IicSuccProd (fun _ ‚Ü¶ őĪ √ó R) n).symm
        (hist alg ŌČ n, (a, ŌČ.2 (pullCount' n (hist alg ŌČ n) a) a)) := by
  intro a
  rw [hist_add_one]
  ext i : 1
  simp only [Kernel.symm_IicSuccProd, MeasurableEquiv.prodCongr, MeasurableEquiv.refl_toEquiv,
    MeasurableEquiv.piSingleton, eq_rec_constant, MeasurableEquiv.IicProdIoc,
    MeasurableEquiv.trans_apply, MeasurableEquiv.coe_mk, Equiv.prodCongr_apply, Equiv.coe_refl,
    Equiv.coe_fn_mk, Prod.map_apply, id_eq]
  rfl

lemma measurable_action_add_one' [DecidableEq őĪ] {alg : Algorithm őĪ R}
    (n : ‚Ąē) (h : Measurable (hist alg ¬∑ n)) :
    Measurable (fun x ‚Ü¶ algFunction alg n (hist alg x n) (x.1 (n + 1))) := by fun_prop

instance : MeasurableEq őĪ := by
  letI := upgradeStandardBorel őĪ
  infer_instance

lemma measurable_pullCount'_action_add_one [DecidableEq őĪ] {alg : Algorithm őĪ R}
    (n : ‚Ąē) (h_hist : Measurable (hist alg ¬∑ n)) :
    Measurable (fun x ‚Ü¶
      pullCount' n (hist alg x n) (algFunction alg n (hist alg x n) (x.1 (n + 1)))) := by
  have h_alg_meas : Measurable (fun x ‚Ü¶ algFunction alg n (hist alg x n) (x.1 (n + 1))) :=
    measurable_action_add_one' n h_hist
  exact (measurable_uncurry_pullCount' (őĪ := őĪ) n).comp (h_hist.prodMk h_alg_meas)

@[fun_prop]
lemma measurable_hist [DecidableEq őĪ] [Countable őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    Measurable (fun ŌČ ‚Ü¶ hist alg ŌČ n) := by
  induction n with
  | zero =>
    simp_rw [hist_zero, measurable_pi_iff]
    refine fun _ ‚Ü¶ Measurable.prodMk (by fun_prop) ?_
    change Measurable ((fun x : őĪ √ó ((‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R)) ‚Ü¶ x.2.2 0 x.1) ‚ąė
        (fun x : (‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R) ‚Ü¶ (initAlgFunction alg (x.1 0), x)))
    have : Measurable (fun x : őĪ √ó ((‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R)) ‚Ü¶ x.2.2 0 x.1) :=
      measurable_from_prod_countable_right fun p ‚Ü¶ by simp only; fun_prop
    exact Measurable.comp (by fun_prop) (Measurable.prodMk (by fun_prop) (by fun_prop))
  | succ n hn =>
    refine measurable_pi_iff.mpr fun i ‚Ü¶ ?_
    by_cases hin : i ‚Č§ n
    ¬∑ simp only [hist, hin, ‚ÜďreduceDIte]
      rw [measurable_pi_iff] at hn
      exact hn ‚ü®i.1, by simp [hin]‚ü©
    ¬∑ simp only [hist, hin, ‚ÜďreduceDIte]
      refine Measurable.prodMk (by fun_prop) ?_
      change Measurable ((fun (x : (‚Ąē ‚Üí őĪ ‚Üí R) √ó ‚Ąē √ó őĪ) ‚Ü¶ x.1 x.2.1 x.2.2) ‚ąė
        (fun x ‚Ü¶ (x.2, pullCount' n (hist alg x n) (algFunction alg n (hist alg x n) (x.1 (n + 1))),
          (algFunction alg n (hist alg x n) (x.1 (n + 1))))))
      have h1 : Measurable (fun (x : (‚Ąē ‚Üí őĪ ‚Üí R) √ó ‚Ąē √ó őĪ) ‚Ü¶ x.1 x.2.1 x.2.2) :=
        measurable_from_prod_countable_left fun p : ‚Ąē √ó őĪ ‚Ü¶ (by simp only; fun_prop)
      refine Measurable.comp (by fun_prop) (Measurable.prodMk (by fun_prop) ?_)
      refine Measurable.prodMk ?_ (by fun_prop)
      exact measurable_pullCount'_action_add_one n hn

noncomputable
def action [DecidableEq őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) (ŌČ : probSpace őĪ R) : őĪ :=
  (hist alg ŌČ n ‚ü®n, by simp‚ü©).1

lemma action_zero [DecidableEq őĪ] (alg : Algorithm őĪ R) :
    action alg 0 = fun ŌČ ‚Ü¶ initAlgFunction alg (ŌČ.1 0) := by
  ext
  simp [action, hist_zero]

lemma action_add_one_eq [DecidableEq őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    action alg (n + 1) = fun ŌČ ‚Ü¶ algFunction alg n (hist alg ŌČ n) (ŌČ.1 (n + 1)) := by
  ext ŌČ
  rw [action, hist_add_one]
  simp only [add_le_iff_nonpos_right, nonpos_iff_eq_zero, one_ne_zero, ‚ÜďreduceDIte]

@[fun_prop]
lemma measurable_action [DecidableEq őĪ] [Countable őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    Measurable (action alg n) := by unfold action; fun_prop

noncomputable
def reward [DecidableEq őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) (ŌČ : probSpace őĪ R) : R :=
  (hist alg ŌČ n ‚ü®n, by simp‚ü©).2

lemma reward_zero [DecidableEq őĪ] (alg : Algorithm őĪ R) :
    reward alg 0 = fun ŌČ ‚Ü¶ ŌČ.2 0 (action alg 0 ŌČ) := by
  ext
  simp [reward, hist_zero, action_zero]

lemma reward_add_one [DecidableEq őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    reward alg (n + 1) =
      fun ŌČ ‚Ü¶ ŌČ.2 (pullCount' n (hist alg ŌČ n) (action alg (n + 1) ŌČ)) (action alg (n + 1) ŌČ) := by
  ext ŌČ
  simp [reward, hist_add_one, action_add_one_eq]

lemma reward_eq [DecidableEq őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    reward alg n = fun ŌČ ‚Ü¶ ŌČ.2 (pullCount (action alg) (action alg n ŌČ) n ŌČ) (action alg n ŌČ) := by
  cases n with
  | zero => ext; simp [reward_zero, action_zero]
  | succ n =>
    ext ŌČ
    rw [reward, hist_add_one]
    simp only [add_le_iff_nonpos_right, nonpos_iff_eq_zero, one_ne_zero, ‚ÜďreduceDIte]
    rw [action_add_one_eq, pullCount_eq_pullCount' (R' := reward alg) (by simp)]
    simp only [Nat.add_one_sub_one]
    rw [hist_eq]
    rfl

@[fun_prop]
lemma measurable_reward [DecidableEq őĪ] [Countable őĪ] (alg : Algorithm őĪ R) (n : ‚Ąē) :
    Measurable (reward alg n) := by unfold reward; fun_prop

lemma hist_add_one_eq_IicSuccProd [DecidableEq őĪ] (alg : Algorithm őĪ R) (ŌČ : probSpace őĪ R)
    (n : ‚Ąē) :
    hist alg ŌČ (n + 1) =
      (MeasurableEquiv.IicSuccProd (fun _ ‚Ü¶ őĪ √ó R) n).symm
        (hist alg ŌČ n, (action alg (n + 1) ŌČ, reward alg (n + 1) ŌČ)) := by
  rw [hist_add_one_eq_IicSuccProd', reward_add_one, action_add_one_eq]

variable [DecidableEq őĪ] [Countable őĪ]

lemma hasLaw_action_zero (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    HasLaw (action alg 0) alg.p0 (arrayMeasure őĹ) where
  map_eq := by
    calc (arrayMeasure őĹ).map (fun ŌČ ‚Ü¶ initAlgFunction alg (ŌČ.1 0))
    _ = ((arrayMeasure őĹ).fst.map (Function.eval 0)).map (initAlgFunction alg) := by
      rw [Measure.fst, Measure.map_map (by fun_prop) (by fun_prop),
        Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = (volume : Measure I).map (initAlgFunction alg) := by
      simp only [arrayMeasure, Measure.fst_prod]
      rw [(measurePreserving_eval_infinitePi (fun _ ‚Ü¶ volume) 0).map_eq]
    _ = alg.p0 := initAlgFunction_map alg

variable [StandardBorelSpace R] [Nonempty R]

omit [Nonempty őĪ] [StandardBorelSpace őĪ] [DecidableEq őĪ] [Countable őĪ]
  [StandardBorelSpace R] [Nonempty R] in
lemma indepFun_fst_snd (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    IndepFun Prod.fst Prod.snd (arrayMeasure őĹ) :=
  indepFun_prod measurable_id measurable_id

omit [Nonempty őĪ] [StandardBorelSpace őĪ] [DecidableEq őĪ] [Countable őĪ]
  [StandardBorelSpace R] [Nonempty R] in
lemma indepFun_fst_zero_snd_zero_action (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (a : őĪ) :
    IndepFun (fun ŌČ ‚Ü¶ ŌČ.1 0) (fun ŌČ ‚Ü¶ ŌČ.2 0 a) (arrayMeasure őĹ) :=
  indepFun_prod (X := fun ŌČ : ‚Ąē ‚Üí I ‚Ü¶ ŌČ 0) (Y := fun ŌČ : ‚Ąē ‚Üí őĪ ‚Üí R ‚Ü¶ ŌČ 0 a)
    (by fun_prop) (by fun_prop)

omit [Nonempty őĪ] [StandardBorelSpace őĪ] [DecidableEq őĪ] [Countable őĪ]
  [StandardBorelSpace R] [Nonempty R] in
lemma map_snd_apply_arrayMeasure {őĹ : Kernel őĪ R} [IsMarkovKernel őĹ] (n : ‚Ąē) (a : őĪ) :
    (arrayMeasure őĹ).map (fun ŌČ ‚Ü¶ ŌČ.2 n a) = őĹ a := by
  calc (arrayMeasure őĹ).map (fun ŌČ ‚Ü¶ ŌČ.2 n a)
  _ = (arrayMeasure őĹ).snd.map (fun ŌČ ‚Ü¶ ŌČ n a) := by
    rw [Measure.snd, Measure.map_map (by fun_prop) (by fun_prop)]
    rfl
  _ = őĹ a := by
    rw [arrayMeasure, Measure.snd_prod, Bandit.streamMeasure]
    have : (fun ŌČ ‚Ü¶ ŌČ n a) = (fun h : őĪ ‚Üí R ‚Ü¶ h a) ‚ąė (fun ŌČ : ‚Ąē ‚Üí őĪ ‚Üí R ‚Ü¶ ŌČ n) := rfl
    rw [this, ‚Üź Measure.map_map (by fun_prop) (by fun_prop), Measure.infinitePi_map_eval,
      Measure.infinitePi_map_eval]

lemma hasCondDistrib_reward_zero (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    HasCondDistrib (reward alg 0) (action alg 0) (stationaryEnv őĹ).őĹ0 (arrayMeasure őĹ) where
