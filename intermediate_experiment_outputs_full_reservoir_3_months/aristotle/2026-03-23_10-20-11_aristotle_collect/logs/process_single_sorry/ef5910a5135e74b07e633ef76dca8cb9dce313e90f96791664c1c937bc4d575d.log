    (n : ‚Ąē) :
    HasCondDistrib (reward alg (n + 1)) (fun ŌČ ‚Ü¶ (hist alg ŌČ n, action alg (n + 1) ŌČ))
      (őĹ.prodMkLeft _) (arrayMeasure őĹ) := by
  rw [reward_eq]
  refine ‚ü®?_, by fun_prop, ?_‚ü©
  ¬∑
    convert ( measurable_reward alg ( n + 1 ) ).aemeasurable using 1 ; exact ( reward_eq alg ( n + 1 ) ).symm ‚Ėł rfl;
  refine condDistrib_ae_eq_of_measure_eq_compProd _ ?_ ?_
  ¬∑
    -- The function ŌČ ‚Ü¶ ŌČ.2 (pullCount (action alg) (action alg (n + 1) ŌČ) (n + 1) ŌČ) (action alg (n + 1) ŌČ) is measurable because it is a composition of measurable functions.
    have h_measurable : Measurable (fun ŌČ : probSpace őĪ R => ŌČ.2 (pullCount (action alg) (action alg (n + 1) ŌČ) (n + 1) ŌČ) (action alg (n + 1) ŌČ)) := by
      have h_reward_measurable : Measurable (fun ŌČ : (‚Ąē ‚Üí I) √ó (‚Ąē ‚Üí őĪ ‚Üí R) => reward alg (n + 1) ŌČ) := by
        apply measurable_reward;
      convert h_reward_measurable using 1 ; exact?;
    exact h_measurable.aemeasurable
  sorry

lemma hasCondDistrib_action (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (n : ‚Ąē) :
    HasCondDistrib (action alg (n + 1))
      (fun ŌČ (i : Iic n) ‚Ü¶ (action alg i ŌČ, reward alg i ŌČ))
      (alg.policy n) (arrayMeasure őĹ) := by
  convert hasCondDistrib_action' alg őĹ n with ŌČ i
  ¬∑ simp only [action]
    rw [hist_eq _ _ n]
  ¬∑ simp only [reward]
    rw [hist_eq _ _ n]

lemma hasCondDistrib_reward (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ]
    (n : ‚Ąē) :
    HasCondDistrib (reward alg (n + 1))
      (fun ŌČ ‚Ü¶ (fun (i : Iic n) ‚Ü¶ (action alg i ŌČ, reward alg i ŌČ), action alg (n + 1) ŌČ))
      ((stationaryEnv őĹ).feedback n) (arrayMeasure őĹ) := by
  convert hasCondDistrib_reward' alg őĹ n with ŌČ i
