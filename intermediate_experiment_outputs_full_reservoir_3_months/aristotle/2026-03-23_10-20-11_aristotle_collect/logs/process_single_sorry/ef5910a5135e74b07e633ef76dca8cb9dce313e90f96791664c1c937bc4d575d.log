namespace Bandit

/-- Kernel describing the distribution of the next action-reward pair given the history up to
time `n`. -/
noncomputable
def stepKernel (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (n : ‚Ąē) :
    Kernel (Iic n ‚Üí őĪ √ó R) (őĪ √ó R) :=
  Learning.stepKernel alg (stationaryEnv őĹ) n
deriving IsMarkovKernel

@[simp]
lemma fst_stepKernel (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (n : ‚Ąē) :
    (stepKernel alg őĹ n).fst = alg.policy n := by
  rw [stepKernel, Learning.fst_stepKernel]

@[simp]
lemma snd_stepKernel (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] (n : ‚Ąē) :
    (stepKernel alg őĹ n).snd = őĹ ‚ąė‚āĖ alg.policy n := by
  rw [stepKernel, Learning.stepKernel, stationaryEnv_feedback, Kernel.snd_compProd_prodMkLeft]

/-- Measure on the sequence of actions pulled and rewards observed generated by the bandit. -/
noncomputable
def trajMeasure (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] : Measure (‚Ąē ‚Üí őĪ √ó R) :=
  Learning.trajMeasure alg (stationaryEnv őĹ)
deriving IsProbabilityMeasure

/-- Measure of an infinite stream of rewards from each action. -/
noncomputable
def streamMeasure (őĹ : Kernel őĪ R) : Measure (‚Ąē ‚Üí őĪ ‚Üí R) :=
  Measure.infinitePi fun _ ‚Ü¶ Measure.infinitePi őĹ

instance (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] : IsProbabilityMeasure (streamMeasure őĹ) := by
  unfold streamMeasure
  infer_instance

/-- Joint distribution of the sequence of action pulled and rewards, and a stream of independent
rewards from all actions. -/
noncomputable
def measure (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    Measure ((‚Ąē ‚Üí őĪ √ó R) √ó (‚Ąē ‚Üí őĪ ‚Üí R)) :=
  (trajMeasure alg őĹ).prod (streamMeasure őĹ)
deriving IsProbabilityMeasure

@[simp]
lemma fst_measure (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    (measure alg őĹ).fst = trajMeasure alg őĹ := by
  rw [measure, Measure.fst_prod]

@[simp]
lemma snd_measure (alg : Algorithm őĪ R) (őĹ : Kernel őĪ R) [IsMarkovKernel őĹ] :
    (measure alg őĹ).snd = streamMeasure őĹ := by
  rw [measure, Measure.snd_prod]

end Bandit

