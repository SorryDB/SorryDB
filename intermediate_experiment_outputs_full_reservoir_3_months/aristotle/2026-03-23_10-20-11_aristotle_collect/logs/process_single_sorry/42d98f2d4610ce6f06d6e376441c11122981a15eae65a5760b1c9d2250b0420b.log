import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

-- The key algebraic identity: for odd p, (2^m + 1) | (2^(m*p) + 1)
lemma pow_mul_add_one_dvd {m p : ℕ} (hp : Odd p) :
    2 ^ m + 1 ∣ 2 ^ (m * p) + 1 := by
  simpa only [one_pow, pow_mul] using hp.nat_add_dvd_pow_add_pow _ 1

-- m is odd if m > 0 and m | 2^m + 1
lemma odd_of_dvd_two_pow_add_one {m : ℕ} (hm0 : 0 < m) (hm : m ∣ 2 ^ m + 1) :
    Odd m := by
  exact Nat.odd_iff.mpr (Nat.mod_two_ne_zero.mp fun h => by
    have := Nat.dvd_trans (Nat.dvd_of_mod_eq_zero h) hm
    norm_num [Nat.dvd_add_right (dvd_pow_self _ hm0.ne')] at this)

-- If m | 2^m + 1 and p is prime, p is odd, p | 2^m + 1, Nat.Coprime p m,
-- then m * p | 2^(m*p) + 1
lemma mul_dvd_two_pow_mul_add_one {m p : ℕ} (hm : m ∣ 2 ^ m + 1)
    (hp : Nat.Prime p) (hpodd : p ≠ 2) (hpdvd : p ∣ 2 ^ m + 1)
    (hcop : Nat.Coprime p m) :
    m * p ∣ 2 ^ (m * p) + 1 := by
  have hodd : Odd p := hp.odd_of_ne_two hpodd
  have h1 : 2 ^ m + 1 ∣ 2 ^ (m * p) + 1 := pow_mul_add_one_dvd hodd
  have hm_dvd : m ∣ 2 ^ (m * p) + 1 := dvd_trans hm h1
  have hp_dvd : p ∣ 2 ^ (m * p) + 1 := dvd_trans hpdvd h1
  exact hcop.symm.mul_dvd_of_dvd_of_dvd hm_dvd hp_dvd

-- 9 divides 2^9 + 1
lemma nine_dvd : (9 : ℕ) ∣ 2 ^ 9 + 1 := by decide +revert

-- primeFactors of 9
lemma nine_primeFactors : (9 : ℕ).primeFactors = {3} := by native_decide

-- New prime is odd (since 2^m + 1 is odd)
lemma prime_dvd_odd {p m : ℕ} (hp : Nat.Prime p) (hpdvd : p ∣ 2 ^ m + 1)
    (hm0 : 0 < m) : p ≠ 2 := by
  intro h; subst h; exact absurd hpdvd.even (by norm_num [hm0.ne', parity_simps])

-- Adding a new coprime prime increases primeFactors.card by 1
lemma primeFactors_card_mul_prime {m p : ℕ} (hm : 0 < m) (hp : Nat.Prime p)
    (hndvd : ¬(p ∣ m)) :
    (m * p).primeFactors.card = m.primeFactors.card + 1 := by
  rw [Nat.primeFactors_mul, Finset.card_union] <;> aesop

/-
PROBLEM
Growth bound: for n ≥ 4, n < 2^n (actually much stronger, but this suffices)
More specifically: for m ≥ 9, m * 2^((m+1)/2) < 2^m
Equivalently: m < 2^((m-1)/2) for m ≥ 9

PROVIDED SOLUTION
By strong induction on m. For m = 9: (9-1)/2 = 4, 2^4 = 16 > 9. ✓
For m = 10: (10-1)/2 = 4, 2^4 = 16 > 10. ✓
For m = 11: 5, 2^5 = 32 > 11. ✓
For m ≥ 11: m+1 < 2^((m+1-1)/2) follows from m < 2^((m-1)/2) since 2^(m/2) grows by factor √2 > 1 at each step.

More precisely, for odd m: if m ≥ 9, then m < 2^((m-1)/2).
Base: m=9, 9 < 16 = 2^4.
Inductive step: if m < 2^((m-1)/2) for odd m ≥ 9, then m+2 < 2^((m+1)/2) since 2^((m+1)/2) = 2 · 2^((m-1)/2) > 2m ≥ m+2 (since m ≥ 2).
For even m: (m-1)/2 = (m-2)/2, and by the odd case for m-1 ≥ 9: m-1 < 2^((m-2)/2) = 2^((m-1)/2), so m ≤ 2^((m-1)/2)... wait we need strict inequality. m-1 < 2^((m-2)/2), and m < m-1+1 ≤ 2^((m-2)/2) + 1 ≤ 2^((m-1)/2) for m ≥ 10.
Actually, simplest: verify for m = 9,10,...,20 by norm_num, then for m ≥ 21 use Nat.lt_two_pow or similar exponential growth bound.
-/
lemma growth_bound (m : ℕ) (hm : 9 ≤ m) : m < 2 ^ ((m - 1) / 2) := by
  rcases Nat.even_or_odd' m with ⟨ k, rfl | rfl ⟩ <;> norm_num at *;
  · rcases k with ( _ | _ | _ | _ | _ | _ | _ | k ) <;> simp_all +arith +decide [ Nat.mul_succ, Nat.pow_succ' ];
    norm_num [ Nat.add_div ];
    exact Nat.recOn k ( by norm_num ) fun n ihn => by norm_num [ Nat.pow_succ' ] at ihn ⊢ ; linarith;
  · exact Nat.le_induction ( by decide ) ( fun n hn ih => by rw [ Nat.pow_succ' ] ; linarith ) _ ( show k ≥ 4 by linarith )

/-
PROBLEM
Prime sum bound: for distinct primes ≥ 3 in a Finset,
sum of (p+1)/2 ≤ (product of p + 1)/2
Equivalently: sum(p) + |S| - 1 ≤ product(p)
for distinct primes p ≥ 3 in S

PROVIDED SOLUTION
By Finset.induction on S.
Base case: ∑ = 0, ∏ = 1, 0 ≤ (1+1)/2 = 1. ✓
Inductive step: Let S' = insert p S with p ∉ S. Let P = ∏ S. By IH: ∑_S (q+1)/2 ≤ (P+1)/2.
Need: (p+1)/2 + ∑_S ≤ (p*P+1)/2.
Since p ≥ 3, P ≥ 1: if S = ∅, P = 1 and both sides equal (p+1)/2.
If S ≠ ∅, P ≥ 3 (product of primes ≥ 3), and (p+1)/2 + (P+1)/2 ≤ (p+P+2)/2.
Need (p+P+2)/2 ≤ (pP+1)/2, i.e., p+P+1 ≤ pP, i.e., (p-1)(P-1) ≥ 2.
Since p ≥ 3 and P ≥ 3: (p-1)(P-1) ≥ 4 ≥ 2. ✓
-/
lemma prime_sum_le_prod (S : Finset ℕ) (hS : ∀ p ∈ S, Nat.Prime p)
    (hS3 : ∀ p ∈ S, 3 ≤ p) :
    (∑ p ∈ S, ((p + 1) / 2 : ℕ)) ≤ ((∏ p ∈ S, p) + 1) / 2 := by
  -- By induction on the size of the set S.
  induction' S using Finset.induction with p S ih;
  · norm_num;
  · rw [ Finset.sum_insert ih, Finset.prod_insert ih ];
    rename_i h; specialize h ( fun q hq => hS q ( Finset.mem_insert_of_mem hq ) ) ( fun q hq => hS3 q ( Finset.mem_insert_of_mem hq ) ) ; rw [ Nat.le_div_iff_mul_le ] at * <;> norm_num at *;
    rcases S.eq_empty_or_nonempty with ( rfl | ⟨ q, hq ⟩ ) <;> norm_num at *;
    · linarith [ Nat.div_mul_le_self ( p + 1 ) 2 ];
    · nlinarith [ Nat.div_mul_le_self ( p + 1 ) 2, show ∏ x ∈ S, x ≥ 3 by exact le_trans ( hS3.2 q hq ) ( Nat.le_of_dvd ( Finset.prod_pos fun x hx => Nat.Prime.pos ( hS.2 x hx ) ) ( Finset.dvd_prod_of_mem _ hq ) ) ]

/-
PROBLEM
For m ≥ 9 with m | 2^m + 1, there exists a prime p | 2^m + 1 with p ∤ m.

PROVIDED SOLUTION
By contradiction. Assume ∀ p prime, p | 2^m+1 → p | m.

Step 1: m is odd (by odd_of_dvd_two_pow_add_one since m ≥ 9 > 0).

Step 2: Bound 2^m+1 ≤ m * 2^((m+1)/2).

Since all prime factors of 2^m+1 divide m, and m | 2^m+1:
  2^m + 1 = ∏_{q ∈ m.primeFactors} q^(factorization (2^m+1) q)
  = (∏_{q ∈ m.primeFactors} q^(factorization m q)) * (∏_{q ∈ m.primeFactors} q^(factorization (2^m+1) q - factorization m q))
  = m * (∏_{q ∈ m.primeFactors} q^(factorization (2^m+1) q - factorization m q))

For each prime q dividing m:
- q | 2^m + 1, so 2^m ≡ -1 (mod q), so ord_q(2) | 2m but ord_q(2) ∤ m
- ord_q(2) | q-1 (Fermat), so ord_q(2) ≤ q-1
- Since m odd and ord_q(2) | 2m, ord_q(2) ∤ m: ord_q(2) = 2*e where e | m and e ≤ (q-1)/2
- Then 2^e ≡ -1 (mod q), so q | 2^e + 1
- By LTE (Nat.emultiplicity_pow_add_pow with x=2^e, y=1, n=m/e which is odd):
  emultiplicity q (2^m + 1) = emultiplicity q (2^e + 1) + emultiplicity q (m/e)
- Since e < q (as e ≤ (q-1)/2 < q), q ∤ e, so v_q(m/e) = v_q(m)
- So v_q(2^m+1) - v_q(m) = v_q(2^e + 1)
- And q^(v_q(2^e+1)) ≤ 2^e + 1 ≤ 2^((q-1)/2) + 1 ≤ 2^((q+1)/2) (since 2^a + 1 ≤ 2^(a+1))

So ∏ q^(v_q(2^m+1) - v_q(m)) ≤ ∏ 2^((q+1)/2) = 2^(∑(q+1)/2).
By prime_sum_le_prod: ∑(q+1)/2 ≤ (∏ q + 1)/2 ≤ (m+1)/2 (since ∏q | m, so ∏q ≤ m).
So 2^m + 1 ≤ m * 2^((m+1)/2).

Step 3: Get contradiction using growth_bound.
m < 2^((m-1)/2) (by growth_bound).
So m * 2^((m+1)/2) < 2^((m-1)/2) * 2^((m+1)/2) = 2^((m-1)/2 + (m+1)/2).
Since (m-1)/2 + (m+1)/2 = m (for m odd) or m (for m even): = 2^m.
So 2^m + 1 ≤ m * 2^((m+1)/2) < 2^m < 2^m + 1. Contradiction.
-/
lemma exists_new_prime_factor {m : ℕ} (hm : m ∣ 2 ^ m + 1) (hm9 : 9 ≤ m) :
    ∃ p, Nat.Prime p ∧ p ∣ 2 ^ m + 1 ∧ ¬(p ∣ m) := by
  contrapose! hm9;
  -- By contradiction, assume that for all primes $p$ dividing $2^m + 1$, $p$ also divides $m$.
  by_contra h_contra
  have h_prod : 2 ^ m + 1 ≤ m * 2 ^ ((m + 1) / 2) := by
    -- For each prime q dividing m, we have q^(v_q(2^m+1) - v_q(m)) ≤ 2^((q+1)/2).
    have h_prime_bound : ∀ q ∈ Nat.primeFactors m, q ^ (Nat.factorization (2 ^ m + 1) q - Nat.factorization m q) ≤ 2 ^ ((q + 1) / 2) := by
      intros q hq
      have h_div : q ∣ 2 ^ m + 1 := by
        exact dvd_trans ( Nat.dvd_of_mem_primeFactors hq ) hm
      have h_div_m : q ∣ m := by
        exact hm9 q ( Nat.prime_of_mem_primeFactors hq ) h_div
      have h_ord : orderOf (2 : ZMod q) = 2 * (orderOf (2 : ZMod q) / 2) := by
        have h_ord : orderOf (2 : ZMod q) ∣ 2 * m ∧ ¬(orderOf (2 : ZMod q) ∣ m) := by
          have h_ord : orderOf (2 : ZMod q) ∣ 2 * m := by
            rw [ orderOf_dvd_iff_pow_eq_one ];
            simp_all +decide [ ← ZMod.natCast_eq_zero_iff, pow_mul' ];
            rw [ add_eq_zero_iff_eq_neg ] at h_div ; aesop
          have h_ord_not : ¬(orderOf (2 : ZMod q) ∣ m) := by
            simp_all +decide [ orderOf_dvd_iff_pow_eq_one ];
            intro h; haveI := Fact.mk hq.1; simp_all +decide [ ← ZMod.natCast_eq_zero_iff ] ;
            ring_nf at * ; aesop
          exact ⟨h_ord, h_ord_not⟩;
        rw [ Nat.mul_div_cancel' ( even_iff_two_dvd.mp _ ) ];
        exact Nat.even_iff.mpr ( Nat.mod_two_ne_one.mp fun h => h_ord.2 <| Nat.dvd_of_mod_eq_zero <| by rw [ Nat.mod_eq_zero_of_dvd ] ; exact Nat.Coprime.dvd_of_dvd_mul_left ( show Nat.Coprime ( orderOf ( 2 : ZMod q ) ) 2 from Nat.Coprime.symm <| Nat.prime_two.coprime_iff_not_dvd.mpr <| by rw [ Nat.dvd_iff_mod_eq_zero ] ; aesop ) h_ord.1 )
      have h_e : ∃ e, e ∣ m ∧ e ≤ (q - 1) / 2 ∧ q ∣ 2 ^ e + 1 := by
        have h_e : orderOf (2 : ZMod q) ∣ 2 * m ∧ ¬orderOf (2 : ZMod q) ∣ m := by
          have h_order : orderOf (2 : ZMod q) ∣ 2 * m := by
            rw [ orderOf_dvd_iff_pow_eq_one ];
            simp_all +decide [ ← ZMod.natCast_eq_zero_iff, pow_mul' ];
            rw [ add_eq_zero_iff_eq_neg ] at h_div ; aesop
          have h_not_div : ¬(orderOf (2 : ZMod q) ∣ m) := by
            rw [ orderOf_dvd_iff_pow_eq_one ] at *;
            intro h; haveI := Fact.mk ( Nat.prime_of_mem_primeFactors hq ) ; simp_all +decide [ ← ZMod.natCast_eq_zero_iff ] ;
            ring_nf at * ; aesop
          exact ⟨h_order, h_not_div⟩
        generalize_proofs at *; (
        -- Since orderOf (2 : ZMod q) divides 2 * m but not m, we can write orderOf (2 : ZMod q) = 2 * e where e divides m.
        obtain ⟨e, he₁, he₂⟩ : ∃ e, orderOf (2 : ZMod q) = 2 * e ∧ e ∣ m := by
          exact ⟨ orderOf ( 2 : ZMod q ) / 2, h_ord, Nat.dvd_of_mul_dvd_mul_left zero_lt_two <| by simpa [ ← h_ord ] using h_e.1 ⟩
        generalize_proofs at *; (
        refine' ⟨ e, he₂, _, _ ⟩
        generalize_proofs at *; (
        have h_e_le : e ≤ (q - 1) / 2 := by
          have h_order_div : orderOf (2 : ZMod q) ∣ q - 1 := by
            rw [ orderOf_dvd_iff_pow_eq_one ] at *;
            haveI := Fact.mk ( Nat.prime_of_mem_primeFactors hq ) ; rw [ ZMod.pow_card_sub_one_eq_one ] ; cases m <;> aesop;
          exact Nat.le_div_iff_mul_le zero_lt_two |>.2 ( by linarith [ Nat.le_of_dvd ( Nat.sub_pos_of_lt ( Nat.Prime.one_lt ( Nat.prime_of_mem_primeFactors hq ) ) ) h_order_div ] ) ;
        generalize_proofs at *; (
        exact h_e_le));
        have h_e : 2 ^ e ≡ -1 [ZMOD q] := by
          have h_order : 2 ^ (2 * e) ≡ 1 [ZMOD q] := by
            simp +decide [ ← ZMod.intCast_eq_intCast_iff, ← he₁, pow_orderOf_eq_one ]
          have h_not_order : ¬(2 ^ e ≡ 1 [ZMOD q]) := by
            intro h; have := orderOf_dvd_iff_pow_eq_one.mpr ( show ( 2 : ZMod q ) ^ e = 1 from by simpa [ ← ZMod.intCast_eq_intCast_iff ] using h ) ; simp_all +decide [ Nat.dvd_prime ] ;
            exact Nat.not_dvd_of_pos_of_lt ( Nat.pos_of_dvd_of_pos he₂ ( by linarith ) ) ( by linarith [ Nat.pos_of_dvd_of_pos he₂ ( by linarith ) ] ) this
          haveI := Fact.mk ( Nat.prime_of_mem_primeFactors hq ) ; simp_all +decide [ ← ZMod.intCast_eq_intCast_iff, pow_mul' ] ;
        generalize_proofs at *; (
        simpa [ ← Int.natCast_dvd_natCast ] using h_e.symm.dvd)))
      obtain ⟨e, he₁, he₂, he₃⟩ := h_e
      have h_emultiplicity : Nat.factorization (2 ^ m + 1) q = Nat.factorization (2 ^ e + 1) q + Nat.factorization m q := by
        obtain ⟨ k, rfl ⟩ := he₁; simp_all +decide [ pow_mul ] ;
        have h_emultiplicity : Nat.factorization ((2 ^ e) ^ k + 1) q = Nat.factorization (2 ^ e + 1) q + Nat.factorization k q := by
          have h_lte : ∀ {x y : ℕ}, Nat.Prime q → Odd q → q ∣ x + y → ¬(q ∣ x) → Odd k → Nat.factorization (x ^ k + y ^ k) q = Nat.factorization (x + y) q + Nat.factorization k q := by
            intros x y hq hq_odd hq_div hq_not_div_x hk_odd; haveI := Fact.mk hq; simp_all +decide [ ← ZMod.natCast_eq_zero_iff, Nat.factorization ] ;
            apply_rules [ padicValNat.pow_add_pow ];
            · simpa [ ← ZMod.natCast_eq_zero_iff ] using hq_div;
            · rwa [ ← ZMod.natCast_eq_zero_iff ] at *
          by_cases hk : Odd k <;> simp_all +decide [ ← even_iff_two_dvd, parity_simps ];
          · convert h_lte ( show Odd q from hq.1.odd_of_ne_two <| by rintro rfl; simp_all +decide [ ← even_iff_two_dvd, parity_simps ] ) ( show q ∣ 2 ^ e + 1 from he₃ ) ( show ¬q ∣ 2 ^ e from by intro h; have := Nat.dvd_gcd h he₃; aesop ) using 1 ; ring;
          · have := hm.even; simp_all +decide [ parity_simps ] ;
        have := hm9 q hq.1 h_div; simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd, Nat.Prime.dvd_mul ] ;
        exact Nat.factorization_eq_zero_of_not_dvd fun h => by have := Nat.le_of_dvd ( Nat.pos_of_ne_zero hq.2.1 ) h; omega;
      have h_prime_bound : q ^ (Nat.factorization (2 ^ e + 1) q) ≤ 2 ^ ((q + 1) / 2) := by
        have h_prime_bound : q ^ (Nat.factorization (2 ^ e + 1) q) ≤ 2 ^ e + 1 := by
          exact Nat.le_of_dvd ( Nat.succ_pos _ ) ( Nat.ordProj_dvd _ _ );
        refine le_trans h_prime_bound ?_;
        refine' Nat.succ_le_of_lt ( pow_lt_pow_right₀ ( by decide ) _ );
        cases Nat.Prime.eq_two_or_odd ( Nat.prime_of_mem_primeFactors hq ) <;> omega
      aesop;
    -- Therefore, $\prod_{q \in m.primeFactors} q^{v_q(2^m+1) - v_q(m)} \leq \prod_{q \in m.primeFactors} 2^{(q+1)/2}$.
    have h_prod_bound : (∏ q ∈ Nat.primeFactors m, q ^ (Nat.factorization (2 ^ m + 1) q - Nat.factorization m q)) ≤ 2 ^ (∑ q ∈ Nat.primeFactors m, (q + 1) / 2) := by
      simpa only [ Finset.prod_pow_eq_pow_sum ] using Finset.prod_le_prod' h_prime_bound;
    -- By combining the results from h_prod_bound and h_sum_bound, we get the desired inequality.
    have h_combined : (∏ q ∈ Nat.primeFactors m, q ^ (Nat.factorization (2 ^ m + 1) q - Nat.factorization m q)) ≤ 2 ^ ((m + 1) / 2) := by
      refine le_trans h_prod_bound ?_;
      gcongr;
      · norm_num;
      · have h_sum_bound : ∑ q ∈ Nat.primeFactors m, (q + 1) / 2 ≤ ((∏ q ∈ Nat.primeFactors m, q) + 1) / 2 := by
          apply prime_sum_le_prod;
          · grind;
          · intro p hp; contrapose! h_contra; interval_cases p <;> simp_all +decide ;
            exact absurd ( dvd_trans hp.1 hm ) ( by norm_num [ Nat.dvd_add_right ( dvd_pow_self _ hp.2 ) ] );
        exact h_sum_bound.trans ( Nat.div_le_div_right <| Nat.succ_le_succ <| Nat.le_of_dvd ( by linarith ) <| Nat.prod_primeFactors_dvd _ );
    have h_final : (∏ q ∈ Nat.primeFactors m, q ^ (Nat.factorization m q)) * (∏ q ∈ Nat.primeFactors m, q ^ (Nat.factorization (2 ^ m + 1) q - Nat.factorization m q)) = 2 ^ m + 1 := by
      conv_rhs => rw [ ← Nat.factorization_prod_pow_eq_self ( by positivity : ( 2 ^ m + 1 ) ≠ 0 ) ];
      rw [ ← Finset.prod_mul_distrib, Finsupp.prod_of_support_subset ];
      congr! 1;
      · rw [ ← pow_add, Nat.add_sub_of_le ( Nat.factorization_le_iff_dvd ( by aesop ) ( by aesop ) |>.2 hm _ ) ];
      · intro q hq; aesop;
      · aesop;
    rw [ ← h_final ];
    exact Nat.mul_le_mul ( Nat.le_of_eq <| Nat.factorization_prod_pow_eq_self <| by aesop_cat ) h_combined;
  -- By growth_bound, we have $m < 2^{(m-1)/2}$.
  have h_growth : m < 2 ^ ((m - 1) / 2) := by
    exact growth_bound m ( le_of_not_gt h_contra );
  rcases Nat.even_or_odd' m with ⟨ k, rfl | rfl ⟩ <;> norm_num [ Nat.add_div ] at *;
  · exact absurd ( congr_arg Even hm.choose_spec ) ( by norm_num [ Nat.even_add, Nat.even_pow ] ; aesop );
  · norm_num [ pow_succ', pow_mul' ] at * ; nlinarith [ pow_pos ( zero_lt_two' ℕ ) k ]

/-
PROBLEM
The main inductive construction

PROVIDED SOLUTION
By induction on k.
Base case k = 1: Take n = 9. 9 ≥ 9 ✓. primeFactors(9) = {3} has card 1 (by nine_primeFactors). 9 | 2^9 + 1 (by nine_dvd). ✓

Inductive step: Given n with 9 ≤ n, n.primeFactors.card = k, n | 2^n + 1.
By exists_new_prime_factor (using hm9 : 9 ≤ n), get p prime with p | 2^n + 1 and ¬(p | n).
p is odd (by prime_dvd_odd, since n ≥ 9 > 0).
p is coprime to n (since p is prime and p ∤ n: Nat.Prime.coprime_iff_not_dvd).
Set n' = n * p.
- n' ≥ 9: since n ≥ 9 and p ≥ 2: n' = n*p ≥ 9*2 = 18 ≥ 9.
- n'.primeFactors.card = k + 1: by primeFactors_card_mul_prime (n > 0 since n ≥ 9).
- n' | 2^(n') + 1: by mul_dvd_two_pow_mul_add_one.
-/
lemma exists_with_k_prime_factors :
    ∀ k : ℕ, 1 ≤ k →
    ∃ n : ℕ, 9 ≤ n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
  intro k hk;
  induction' hk with k hk ih;
  · exists 9;
  · obtain ⟨ n, hn₁, hn₂, hn₃ ⟩ := ih;
    obtain ⟨ p, hp₁, hp₂, hp₃ ⟩ := exists_new_prime_factor hn₃ hn₁;
    refine' ⟨ n * p, _, _, _ ⟩;
    · nlinarith [ hp₁.two_le ];
    · rw [ Nat.primeFactors_mul, Finset.card_union ] <;> aesop;
    · convert mul_dvd_two_pow_mul_add_one hn₃ hp₁ ( prime_dvd_odd hp₁ hp₂ ( by linarith ) ) hp₂ ( hp₁.coprime_iff_not_dvd.mpr hp₃ ) using 1

/-
PROVIDED SOLUTION
Since solution = true (abbrev), the goal reduces to showing the iff with True.
Use constructor.
Forward: intro _; rfl (or trivial, since true = true).
Backward: intro _; obtain ⟨n, hn1, hn2, hn3⟩ := exists_with_k_prime_factors 2000 (by norm_num); exact ⟨n, by linarith, hn2, hn3⟩.
-/
problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  by_contra h;
  convert exists_with_k_prime_factors 2000 ( by decide ) using 1;
  grind

end Imo2000P5
