private def bitmaskSubsets (l : List Int) : List (List Int) :=
  let n := l.length
  let masks := List.range (2^n)
  masks.map fun mask =>
    (List.range n).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
    ) []

/-
PROVIDED SOLUTION
Both bitmaskSubsets and List.sublists enumerate all 2^n subsequences in the same order (binary counting order). Try proving by induction on the list l. For the base case, both produce [[]]. For the inductive case l = a :: l', show that:
- bitmaskSubsets (a :: l') splits masks 0..2^(n+1)-1 into even masks (bit 0 = 0) giving sublists of l', and odd masks (bit 0 = 1) giving a :: sublists of l'.
- sublists (a :: l') = sublists l' ++ (sublists l').map (a :: ·) (or the interleaved version).

The key insight is that both produce the same interleaving. Check the definition of List.sublists in Lean 4 - it may use sublists' or a similar helper.

Alternatively, try proving this by showing both lists have the same elements at each index, using List.getElem or ext lemmas.
-/
private lemma bitmaskSubsets_eq_sublists : ∀ (l : List Int), bitmaskSubsets l = l.sublists := by
  intro l
  simp [bitmaskSubsets];
  -- By definition of `List.sublists`, it generates all possible subsets of `l`.
  have h_sublists_def : List.sublists l = List.map (fun mask => List.foldr (fun i acc => if (mask >>> i).land 1 = 1 then l[i]?.getD 0 :: acc else acc) [] (List.range l.length)) (List.range (2 ^ l.length)) := by
    have h_sublists_def : ∀ (l : List ℤ), List.sublists l = List.map (fun mask => List.foldr (fun i acc => if (mask >>> i).land 1 = 1 then l[i]?.getD 0 :: acc else acc) [] (List.range l.length)) (List.range (2 ^ l.length)) := by
      intro l;
      induction l <;> simp_all +decide [ List.sublists_cons ];
      rename_i k hk ih; simp_all +decide [ List.range_succ_eq_map, pow_succ' ] ;
      induction' 2 ^ hk.length with n ih <;> simp_all +decide [ List.range_succ, Nat.mul_succ ];
      simp +decide [ Nat.land, Nat.shiftRight_eq_div_pow ];
      norm_num [ Nat.add_mod, Nat.mul_mod, Nat.pow_mod, Nat.bitwise_of_ne_zero ];
      constructor <;> rw [ List.foldr_map ];
      · norm_num [ Nat.pow_succ', ← Nat.div_div_eq_div_mul ];
        cases n <;> simp +decide [ Nat.bitwise_of_ne_zero ];
      · norm_num [ Nat.add_div, Nat.pow_succ', ← Nat.div_div_eq_div_mul ]
    exact h_sublists_def l;
  exact h_sublists_def.symm

