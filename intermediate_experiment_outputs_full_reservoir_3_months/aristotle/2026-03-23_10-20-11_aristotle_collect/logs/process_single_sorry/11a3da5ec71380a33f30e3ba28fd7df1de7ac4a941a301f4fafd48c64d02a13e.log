theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  rw [ hasFiniteIntegral_iff_norm ];
  refine' lt_of_le_of_lt ( MeasureTheory.lintegral_mono_ae _ ) _;
  refine' fun x => ENNReal.ofReal ( ‖φ₀'' ( I / x )‖ * 1 * 1 );
  · filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioc ] with t ht ; rw [ show Φ₁ r t = I * ( φ₀'' ( I / t ) * ( I * t ) ^ 2 * Complex.exp ( Real.pi * I * r * ( -1 + I * t ) ) ) from ?_ ] ; norm_num [ mul_assoc, mul_comm, mul_left_comm, Complex.norm_exp ] ; ring_nf ;
    · exact mul_le_of_le_one_right ( by positivity ) ( ENNReal.ofReal_le_one.mpr ( by nlinarith [ ht.1, ht.2, Real.exp_le_one_iff.mpr ( show - ( t * r * Real.pi ) ≤ 0 by exact neg_nonpos.mpr ( mul_nonneg ( mul_nonneg ht.1.le hr ) Real.pi_pos.le ) ) ] ) );
    · rw [ show Φ₁ r t = I * ( φ₀'' ( -1 / ( z₁' t + 1 ) ) * ( z₁' t + 1 ) ^ 2 * cexp ( Real.pi * I * r * ( z₁' t ) ) ) from rfl ] ; rw [ show z₁' t = -1 + I * t from z₁'_eq_of_mem <| Set.Ioc_subset_Icc_self ht ] ; ring; norm_num [ Complex.normSq, Complex.div_re, Complex.div_im ] ; ring;
  · obtain ⟨C₀, hC₀_pos, hC₀⟩ : ∃ C₀ > 0, ∀ t : ℝ, 0 < t ∧ t ≤ 1 → ‖φ₀'' (I / t)‖ ≤ C₀ := by
      have := norm_φ₀_le;
      obtain ⟨ C₀, hC₀_pos, hC₀ ⟩ := this; use C₀; refine' ⟨ hC₀_pos, fun t ht => _ ⟩ ; specialize hC₀ ⟨ I / t, _ ⟩ ; aesop;
      convert hC₀ _ |> le_trans <| mul_le_of_le_one_right hC₀_pos.le <| Real.exp_le_one_iff.mpr _ using 1 <;> norm_num [ div_eq_mul_inv ] at *;
      · unfold φ₀''; aesop;
      · nlinarith [ mul_inv_cancel₀ ht.1.ne', mul_inv_cancel₀ ( pow_ne_zero 2 ht.1.ne' ) ];
      · exact mul_nonneg ( by positivity ) ( mul_nonneg ht.1.le ( mul_nonneg ( inv_nonneg.2 ht.1.le ) ( inv_nonneg.2 ht.1.le ) ) );
    refine' lt_of_le_of_lt ( MeasureTheory.setLIntegral_mono' measurableSet_Ioc fun x hx => ENNReal.ofReal_le_ofReal <| mul_le_mul_of_nonneg_right ( mul_le_mul_of_nonneg_right ( hC₀ x hx ) zero_le_one ) zero_le_one ) _ ; norm_num [ hC₀_pos ]

theorem Φ₂_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₂ r)
    (Icc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₂_contDiffOn.continuousOn measurableSet_Icc, ?_⟩
  sorry

