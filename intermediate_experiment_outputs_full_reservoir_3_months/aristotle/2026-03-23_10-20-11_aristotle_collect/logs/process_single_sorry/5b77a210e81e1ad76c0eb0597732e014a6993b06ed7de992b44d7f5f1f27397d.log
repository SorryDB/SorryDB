problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  -- Define the sequence $a_n$ such that $a_1 = 2$ and $a_{n+1}$ is chosen such that $2^{a_{n+1}} - 3$ is coprime with the product of all previous terms.
  have h_seq : ∃ (a : ℕ → ℕ), (∀ n, a (n + 1) > a n) ∧ (∀ n, 2 ^ (a (n + 1)) - 3 > 1) ∧ (∀ n, Nat.Coprime (2 ^ (a (n + 1)) - 3) (∏ i ∈ Finset.range n, (2 ^ (a (i + 1)) - 3))) := by
    -- Define the sequence $a_n$ such that $a_{n+1}$ is chosen such that $2^{a_{n+1}} - 3$ is coprime with the product of all previous terms.
    have h_seq_exists : ∀ n : ℕ, ∃ k > n, Nat.Coprime (2 ^ k - 3) (∏ i ∈ Finset.range n, (2 ^ (i + 2) - 3)) ∧ 2 ^ k - 3 > 1 := by
      intro n
      obtain ⟨k, hk⟩ : ∃ k > n, 2 ^ k ≡ 4 [MOD (∏ i ∈ Finset.range n, (2 ^ (i + 2) - 3))] ∧ 2 ^ k - 3 > 1 := by
        use 2 * (n + 2) * Nat.totient (∏ i ∈ Finset.range n, (2 ^ (i + 2) - 3)) + 2
        generalize_proofs at *; (
        refine' ⟨ _, _, _ ⟩
        all_goals generalize_proofs at *;
        · nlinarith [ show 0 < ( ∏ i ∈ Finset.range n, ( 2 ^ ( i + 2 ) - 3 ) |> Nat.totient ) from Nat.pos_of_ne_zero ( by exact ne_of_gt <| Nat.totient_pos.mpr <| Finset.prod_pos fun i hi => Nat.sub_pos_of_lt <| by linarith [ Nat.pow_le_pow_right two_pos <| show i + 2 ≥ 2 by linarith ] ) ];
        · -- By Euler's theorem, since $2$ and $\prod_{i=0}^{n-1} (2^{i+2} - 3)$ are coprime, we have $2^{\phi(\prod_{i=0}^{n-1} (2^{i+2} - 3))} \equiv 1 \pmod{\prod_{i=0}^{n-1} (2^{i+2} - 3)}$.
          have h_euler : 2 ^ Nat.totient (∏ i ∈ Finset.range n, (2 ^ (i + 2) - 3)) ≡ 1 [MOD ∏ i ∈ Finset.range n, (2 ^ (i + 2) - 3)] := by
            refine' Nat.ModEq.pow_totient _;
            refine' Nat.Coprime.prod_right fun i hi => _;
