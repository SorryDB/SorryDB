import Mathlib.Combinatorics.SimpleGraph.Coloring

open scoped Finset

namespace SimpleGraph
variable {V : Type*} [Fintype V] {G : SimpleGraph V} {d : ℕ}

/-
PROVIDED SOLUTION
Use the empty relation (fun _ _ => False). It is trivially irreflexive and asymmetric. exact ⟨fun _ _ => False, fun _ h => h, ⟨fun _ _ h => absurd h (fun _ _ => False).elim⟩⟩ or similar.
-/
open scoped Classical in
/-- A bipartite simple graph whose induced subgraphs all have average degree at most `2 * d` can be
oriented in such a way that all edges have outdegree at most `d`. -/
lemma exists_orientation_of_average_degree_le (hGcolorable : G.Colorable 2)
    (hGdeg : ∀ s : Finset V, #(G.induce s).edgeFinset ≤ d * #s) :
    ∃ r : V → V → Prop, Irreflexive r ∧ IsAsymm _ r := by
      -- The empty relation is irreflexive and asymmetric.
      use fun _ _ => False; simp [Irreflexive, IsAsymm];
      exact ⟨ by tauto ⟩

end SimpleGraph
