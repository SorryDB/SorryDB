import Mathlib
import Noperthedron.Global.Basic

open scoped RealInnerProductSpace

namespace GlobalTheorem

private abbrev E (n : ℕ) := EuclideanSpace ℝ (Fin n)

private noncomputable
def interpolator {n : ℕ} (x y : E n) (t : ℝ) : E n :=
  (1 - t) • x + t • y

private noncomputable
def interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) : ℝ → ℝ  :=
  f ∘ interpolator x y

private noncomputable
def Differentiable.interpolator {n : ℕ} (x y : E n) :
    Differentiable ℝ (interpolator x y)  := by
  unfold GlobalTheorem.interpolator
  fun_prop

private noncomputable
def Differentiable.interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) (fc : ContDiff ℝ 2 f) :
    Differentiable ℝ (interpolated x y f)  := by
  have := Differentiable.interpolator x y
  have := fc.differentiable two_ne_zero
  unfold GlobalTheorem.interpolated
  fun_prop

private noncomputable
def interpolated_deriv {n : ℕ} (x y : E n) (f : E n → ℝ) (t : ℝ) : ℝ :=
  ∑ i, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)

private noncomputable
def interpolated_deriv2 {n : ℕ} (x y : E n) (f : E n → ℝ) (t : ℝ) : ℝ :=
  ∑ i, ∑ j, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)

/-
PROVIDED SOLUTION
Rewrite `interpolator x y` as `fun t => x + t • (y - x)` (by showing these are extensionally equal: `(1-t)•x + t•y = x + t•(y-x)` via algebra). Then use `deriv_const_add` and `deriv_smul_const` to compute the derivative as `y - x`.
-/
private lemma deriv_interpolator {n : ℕ} (x y : E n) (t : ℝ) :
    deriv (interpolator x y) t = y - x := by
  -- Let's simplify the expression for the derivative.
  have h_deriv : deriv (fun t => (1 - t) • x + t • y) t = deriv (fun t => x + t • (y - x)) t := by
    exact congr_arg ( fun f => deriv f t ) ( funext fun t => by ext i; simpa using by ring );
  convert HasDerivAt.deriv ( hasDerivAt_const _ _ |> HasDerivAt.add <| hasDerivAt_id t |> HasDerivAt.smul_const <| y - x ) using 1 ; norm_num [ interpolator ] at * ; ring_nf at * ; aesop ( simp_config := { decide := true } ) ;
  · norm_num +zetaDelta at *;
  · exact x + t • ( y - x )

/-
PROVIDED SOLUTION
The key idea: `v = ∑ i, v i • EuclideanSpace.single i 1` (decomposition in the standard basis). Then by linearity of `fderiv ℝ f p` (which is a continuous linear map), `fderiv ℝ f p v = fderiv ℝ f p (∑ i, v i • e_i) = ∑ i, v i * fderiv ℝ f p (e_i)`.

Note: If f is not differentiable at p, then `fderiv ℝ f p = 0` and both sides are 0, so the equality still holds.

Use `ContinuousLinearMap.map_sum` and `ContinuousLinearMap.map_smul` for the linearity of fderiv applied to the sum. To decompose v, use `PiLp.ext` or show it via Finset.sum_single.
-/
private lemma fderiv_apply_eq_sum {n : ℕ} (f : E n → ℝ) (p v : E n) :
    fderiv ℝ f p v = ∑ i, v i * fderiv ℝ f p (EuclideanSpace.single i 1) := by
  have h_decomp : v = ∑ i : Fin n, (v i) • EuclideanSpace.single i 1 := by
    ext i; simp [Finset.sum_apply, Pi.single_apply];
  conv_lhs => rw [ h_decomp ];
  simp +decide [ mul_comm ]

/-
PROBLEM
The original statement lacked a differentiability hypothesis on `f`,
    which is needed for the chain rule. Added `Differentiable ℝ f`.

PROVIDED SOLUTION
Use `funext t`.

By the chain rule for `deriv` (use `deriv.scomp`):
`deriv (f ∘ g) t = deriv f (g t) ∘ deriv g t` — but this is for ℝ → ℝ functions, not for our case where g : ℝ → E n.

Instead, use `deriv_fderiv` to rewrite `deriv (f ∘ g) t = fderiv ℝ (f ∘ g) t 1`.

Then use `fderiv.comp` to get `fderiv ℝ (f ∘ g) t = (fderiv ℝ f (g t)).comp (fderiv ℝ g t)`.

So `deriv (f ∘ g) t = fderiv ℝ f (g t) (fderiv ℝ g t 1) = fderiv ℝ f (g t) (deriv g t)` (using `deriv_fderiv` backwards).

Then substitute `deriv g t = y - x` using `deriv_interpolator`.

Then use `fderiv_apply_eq_sum` to decompose `fderiv ℝ f p (y - x) = ∑ i, (y i - x i) * fderiv ℝ f p (e_i)`.

This equals `interpolated_deriv x y f t` by definition.

Key tactic sequence:
1. `funext t`
2. `simp only [interpolated, Function.comp, interpolated_deriv, nth_partial]`
3. `rw [deriv_fderiv]`
4. Use `fderiv.comp` with differentiability hypotheses
5. `rw [deriv_interpolator]`
6. `rw [fderiv_apply_eq_sum]`
7. The goal should close by `simp` or `congr`
-/
def deriv_interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) (hf : Differentiable ℝ f) :
    deriv (interpolated x y f) = interpolated_deriv x y f := by
  -- Apply the chain rule forandReturn scrutinize the derivative computation.
  funext t; have := hf; simp [interpolated, interpolator];
  rw [ deriv ];
  erw [ fderiv_comp ] <;> norm_num [ interpolator, this.differentiableAt ];
  · rw [ deriv_interpolator ];
    convert fderiv_apply_eq_sum f ( ( 1 - t ) • x + t • y ) ( y - x ) using 1;
  · exact Differentiable.interpolator x y |> Differentiable.differentiableAt |> DifferentiableAt.comp _ <| differentiableAt_id;

def deriv_interpolated2 {n : ℕ} (x y : E n) (f : E n → ℝ) :
    deriv (interpolated_deriv x y f) = interpolated_deriv2 x y f := by
  sorry

theorem bounded_partials_control_difference {n : ℕ} (f : E n → ℝ)
    (fc : ContDiff ℝ 2 f) (x y : E n)
    (ε : ℝ) (hε : ε > 0) (hdiff : (i : Fin n) → |x i - y i| ≤ ε)
    (mpb : mixed_partials_bounded f x) :
    |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
  let g₀ := interpolator x y
  let g := interpolated x y f

  let g' := interpolated_deriv x y f
  let g'' := interpolated_deriv2 x y f

  have f_diff : Differentiable ℝ f := fc.differentiable two_ne_zero
  have g₀_diff : Differentiable ℝ g₀ := Differentiable.interpolator x y
  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by sorry
  have g'_cont : Continuous g' := by sorry
  have g''_cont : Continuous g'' := by sorry

  have deriv_g_eq_g' : deriv g = g' := by
    unfold g g'; exact deriv_interpolated x y f f_diff
  have deriv_g'_eq_g'' : deriv g' = g'' := by
    unfold g' g''; exact deriv_interpolated2 x y f

  have int_g'_eq_sub (t : ℝ) : (∫ (s : ℝ) in 0..t, g' s) = g t - g 0 := by
    exact intervalIntegral.integral_deriv_eq_sub' g deriv_g_eq_g' (by fun_prop) (by fun_prop)

  have int_g''_eq_sub (t : ℝ) : (∫ (s : ℝ) in 0..t, g'' s) = g' t - g' 0 := by
    exact intervalIntegral.integral_deriv_eq_sub' g' deriv_g'_eq_g'' (by fun_prop) (by fun_prop)

  -- "and observe that"
  have hobs := by calc g 1 - g 0
      _ = ∫ (t : ℝ) in 0..1, g' t := by rw [int_g'_eq_sub]
      _ = ∫ (t : ℝ) in 0..1, g' 0 + ∫ (s : ℝ) in 0..t, g'' s := by
        conv => arg 2; arg 1; intro t; rw [int_g''_eq_sub]; simp
      _ = (∫ (t : ℝ) in 0..1, g' 0) + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
        rw [intervalIntegral.integral_add]
        · exact intervalIntegrable_const
        · conv => arg 1; intro t; rw [int_g''_eq_sub t]
          exact Continuous.intervalIntegrable (by fun_prop) 0 1
      _ = g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
        rw [intervalIntegral.integral_const]; simp

  --- "the chain rule imples that..."
  have bound1 : |g' 0| ≤ ε * ∑ i, |nth_partial i f x|  := by
    sorry

  -- "For the second derivative of g(t) we also get wit hthe chain rule"
  have bound2 : ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| ≤ (n^2 / 2) * ε^2 := by
    sorry

  have abs_int_le_int_abs {t : ℝ} (ht : 0 ≤ t) :
      |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| :=
    intervalIntegral.abs_integral_le_integral_abs ht

  -- This should be by monotonicity of integration applied to abs_int_le_int_abs
  have int_abs_int_le_int_int_abs : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s|
      ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
    sorry

  -- "Altogether one obtains"
  calc |f x - f y|
  _ = |g 0 - g 1| := by
    rw [show g 0 = f x by simp[g, interpolated, interpolator]]
    rw [show g 1 = f y by simp[g, interpolated, interpolator]]
  _ = |g 1 - g 0| := by rw [abs_sub_comm]
  _ = |g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := by rw [hobs]
  _ ≤ |g' 0| + |∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := abs_add_le _ _
  _ ≤ |g' 0| + ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| := by
    grw [intervalIntegral.abs_integral_le_integral_abs (by norm_num)]
  _ ≤ |g' 0| + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
    grw [int_abs_int_le_int_int_abs]
  _ ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by grw[bound1, bound2]
