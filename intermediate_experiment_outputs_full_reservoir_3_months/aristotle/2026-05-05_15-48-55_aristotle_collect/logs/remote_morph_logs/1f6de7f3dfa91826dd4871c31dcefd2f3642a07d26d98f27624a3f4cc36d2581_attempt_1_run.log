import Mathlib
import IMO.IMO2025P3_upper


namespace IMO2025P3

-- Bonza is already defined in IMO2025P3_upper

/-- The answer to be determined. -/
def answer : ℝ := 4

-- ============================================================
-- Upper bound
-- ============================================================

lemma upper_bound (f : ℕ+ → ℕ+) (hf : Bonza f) (n : ℕ+) :
    (f n : ℝ) ≤ 4 * (n : ℝ) := by
  by_cases hne : f = id ; aesop
  obtain ⟨ k, hk ⟩ := bonza_fn_pow2 f hf hne n
  have h_k_le : k ≤ n.val.factorization 2 + 2 := by
    have := bonza_v2_bound f hf hne n; simp_all +decide [ Nat.factorization_pow ]
  have h_f_n_le : (f n : ℕ) ≤ 4 * 2 ^ (n.val.factorization 2) := by
    exact hk.symm ▸ by
      rw [ show 4 * 2 ^ ( n.val.factorization 2 ) = 2 ^ ( n.val.factorization 2 + 2 ) by ring ]
      exact pow_le_pow_right₀ ( by decide ) h_k_le
  exact_mod_cast h_f_n_le.trans
    ( mul_le_mul_of_nonneg_left ( Nat.le_of_dvd n.pos ( Nat.ordProj_dvd _ _ ) ) zero_le_four )

-- ============================================================
-- Lower bound (witness function)
-- ============================================================

noncomputable def W : ℕ+ → ℕ+ := fun n =>
  if n.val % 2 = 1 then 1
  else if n.val = 2 then 2
  else ⟨2 ^ (n.val.factorization 2 + 2), Nat.pos_of_ne_zero (by positivity)⟩

lemma W_bonza : Bonza W := by
  intro a b;
  by_cases ha : a.val % 2 = 1 <;> by_cases hb : b.val % 2 = 1 <;> simp +decide [ *, W ];
  · have h_cong : (b : ℤ) ^ (a : ℕ) ≡ 1 [ZMOD 2 ^ (Nat.factorization a.val 2 + 2)] := by
      have h_odd_exp : ∀ k : ℕ, 1 ≤ k → (b : ℤ) ^ (2 ^ k) ≡ 1 [ZMOD 2 ^ (k + 2)] := by
        intro k hk
        induction' hk with k ih;
        · rw [ ← Nat.mod_add_div b 2, hb ] ; norm_num [ Int.ModEq, Int.add_emod, Int.mul_emod, pow_succ ] ; ring_nf; norm_num;
          have := Int.emod_nonneg ( ( b : ℤ ) / 2 ) ( by decide : ( 8 : ℤ ) ≠ 0 ) ; have := Int.emod_lt_of_pos ( ( b : ℤ ) / 2 ) ( by decide : ( 0 : ℤ ) < 8 ) ; interval_cases ( ( b : ℤ ) / 2 ) % 8 <;> trivial;
        · rw [ Int.modEq_comm, Int.modEq_iff_dvd ] at *;
          convert mul_dvd_mul ‹_› ( show ( 2 : ℤ ) ∣ ( b : ℤ ) ^ 2 ^ k + 1 from even_iff_two_dvd.mp <| by simpa [ parity_simps ] using Nat.odd_iff.mpr hb ) using 1 ; push_cast [ pow_succ, pow_mul ] ; ring;
      obtain ⟨k, m, hk, hm⟩ : ∃ k m : ℕ, 1 ≤ k ∧ a.val = 2 ^ k * m ∧ m % 2 = 1 := by
        use Nat.factorization a.val 2, a.val / 2 ^ Nat.factorization a.val 2;
        exact ⟨ Nat.pos_of_ne_zero fun h => by simp_all +decide [ Nat.factorization ], Eq.symm <| Nat.mul_div_cancel' <| Nat.ordProj_dvd _ _, Nat.mod_two_ne_zero.mp fun h => absurd ( Nat.dvd_of_mod_eq_zero h ) ( Nat.not_dvd_ordCompl ( by norm_num ) <| by aesop ) ⟩;
      simp_all +decide [ Nat.factorization_mul, show m ≠ 0 by aesop_cat ];
      rw [ Nat.factorization_eq_zero_of_not_dvd ( by omega ) ] ; simp_all +decide [ pow_mul ];
      simpa using Int.ModEq.pow _ ( h_odd_exp k hk );
    split_ifs <;> simp_all +decide [ Int.ModEq, Int.emod_eq_zero_of_dvd ];
    · grind;
    · exact Int.modEq_iff_dvd.mp h_cong.symm;
  · split_ifs <;> simp_all +decide [ ← even_iff_two_dvd, parity_simps ];
    · exact Nat.even_iff.mpr hb;
    · refine' dvd_sub ( pow_dvd_pow _ _ ) ( pow_dvd_pow _ _ );
      · rcases Nat.even_or_odd' a with ⟨ c, d | d ⟩ <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ];
        rcases c with ( _ | _ | c ) <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ];
        linarith [ show Nat.factorization ( c + 1 + 1 ) 2 ≤ c + 1 by exact Nat.le_of_lt_succ ( Nat.factorization_lt _ <| by linarith ) ];
      · exact le_of_lt ( Nat.recOn ( Nat.factorization a 2 ) ( by norm_num ) fun n ihn => by norm_num [ Nat.pow_succ ] at * ; linarith );
    · refine' dvd_sub _ _;
      · norm_cast;
        refine' dvd_trans ( pow_dvd_pow _ _ ) ( pow_dvd_pow_of_dvd ( Nat.dvd_of_mod_eq_zero hb ) _ );
        rcases Nat.even_or_odd' a with ⟨ c, d | d ⟩ <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ];
        rcases c with ( _ | _ | c ) <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ];
        linarith [ show Nat.factorization ( c + 1 + 1 ) 2 ≤ c + 1 by exact Nat.le_of_lt_succ ( Nat.factorization_lt _ <| by linarith ) ];
      · rw [ ← pow_mul ];
        refine' pow_dvd_pow _ _;
        induction' ( Nat.factorization a 2 ) with k ih <;> simp_all +decide [ Nat.pow_succ' ];
        · linarith;
        · grind

lemma W_four_val : (W 4 : ℕ) = 16 := by
  simp only [W]; norm_num
  have h1 : (4 : ℕ).factorization 2 = 2 := by
    rw [show (4 : ℕ) = 2^2 from by norm_num]
    rw [Nat.Prime.factorization_pow (by norm_num : Nat.Prime 2)]; simp
  rw [h1]; norm_num

-- ============================================================
-- Main theorem
-- ============================================================

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  refine ⟨fun f hf n => upper_bound f hf n, fun c hc => ?_⟩
  simp only [Set.mem_setOf_eq] at hc
  unfold answer
  by_contra h; push_neg at h
  have hW := hc W W_bonza 4
  have hval : (W 4 : ℝ) = 16 := by exact_mod_cast W_four_val
  rw [hval] at hW; norm_num at hW; linarith

end IMO2025P3

