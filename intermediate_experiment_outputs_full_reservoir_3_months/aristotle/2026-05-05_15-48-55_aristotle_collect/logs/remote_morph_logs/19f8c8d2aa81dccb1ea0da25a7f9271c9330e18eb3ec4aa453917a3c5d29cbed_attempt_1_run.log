lemma reduce {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)} :
  assert_bits args /\ e.eval = bits2num args ->
    (assert_bits_e args (.eq0 (bits2num_e args - e) cs)).eval = cs.eval := by
  rintro ⟨h₁, h₂⟩
  rw [reduce₁ h₁, reduce₂ h₂]

/-
PROVIDED SOLUTION
We need to show that if some args[i] is neither 0 nor 1, then assert_bits_e args cs evaluates to .n.

assert_bits_e folds assert_bit_e over the vector via Vector.foldl. assert_bit_e wraps the accumulator with .eq0 (b*(1-b)).

Key insight: We prove this by induction on w.

For the base case w=0: impossible since i < 0 is false.

For the inductive case w+1: The fold processes args as head :: tail. After one step of the fold, we have foldl assert_bit_e (assert_bit_e cs args.head) args.tail.

Case 1: i = 0, meaning args.head is the bad element. Then args.head * (1 - args.head) ≠ 0, so assert_bit_e cs args.head evaluates the eq0 check which fails. We need a helper lemma that says if the inner Cs evaluates to .n, then foldl of assert_bit_e over any remaining elements also evaluates to .n.

Case 2: i > 0, meaning the bad element is in the tail. By induction, foldl assert_bit_e (assert_bit_e cs args.head) args.tail evaluates to .n.

The key helper fact is: if cs.eval = .n, then (assert_bit_e cs b).eval = .n. This is because assert_bit_e cs b = .eq0 (b*(1-b)) cs, and Cs.eval (.eq0 e cs) checks if e.eval = 0; if yes, it recurses to cs.eval which is .n; if no, it directly returns .n. Either way, .n.

Then by a simple fold induction: if the accumulated cs.eval = .n, applying more assert_bit_e steps keeps it at .n.

Actually, wait - the fold direction matters. Vector.foldl applies elements left to right. Let me think about the structure more carefully.

assert_bits_e bs cs = Vector.foldl assert_bit_e cs bs

So for bs = [b₀, b₁, ..., bₙ₋₁], the result is:
assert_bit_e (... (assert_bit_e (assert_bit_e cs b₀) b₁) ...) bₙ₋₁

Evaluating from outside in: the outermost is the check for bₙ₋₁. If that passes, we check the next inner one, etc.

So Cs.eval of the whole thing: first check bₙ₋₁*(1-bₙ₋₁) = 0. If it passes, check bₙ₋₂*(1-bₙ₋₂) = 0, etc. If any check fails, return .n.

Since args[i] is not 0 and not 1, args[i]*(1-args[i]) ≠ 0. When we reach that check in the evaluation, it returns .n.

For the proof: we need to show that the outer checks either pass (and we recurse to eventually hit the failing check) or fail (returning .n directly). Either way the result is .n.

Strategy: Prove a helper that assert_bit_e wrapping preserves .n evaluation, then use induction to show that if any element fails, the whole fold gives .n.

Actually a cleaner approach: by strong induction, we can split the vector at position i. The elements after position i are checked first (outermost). If they all pass, we reach the check for args[i] which fails. If any of them also fail, that's fine too - we get .n either way.
-/
lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  -- Since `args[i]` is not 0 or 1, the check for `args[i]` will fail, leading to `denotation.n`.
  have h_check : ∀ (args : Vector (ZMod p) w) (i : ℕ) (h : i < w) (h' : args[i] ≠ 0) (h'' : args[i] ≠ 1), (assert_bits_e args cs).eval = .n := by
    intros args i h h' h'';
    have h_check : ∀ (args : Vector (ZMod p) w) (i : ℕ) (h : i < w) (h' : args[i] ≠ 0) (h'' : args[i] ≠ 1), (Vector.foldl (fun (acc : Cs p (ZMod p)) (b : ZMod p) => .eq0 (.v b * (.c 1 - .v b)) acc) cs args).eval = .n := by
      intros args i h h' h''; induction args using Vector.recOn ; simp_all +decide [ Vector.foldl ] ;
      -- Since `args[i]` is not 0 or 1, the check for `args[i]` will fail, leading to `denotation.n`. We can use the fact that `args[i]` is not 0 or 1 to show that the fold will eventually reach a point where the check fails.
      have h_fold : ∀ (args : List (ZMod p)) (cs : Cs p (ZMod p)), (∃ b ∈ args, b ≠ 0 ∧ b ≠ 1) → (List.foldl (fun (acc : Cs p (ZMod p)) (b : ZMod p) => Cs.eq0 (Exp.v b * (Exp.c 1 - Exp.v b)) acc) cs args).eval = .n := by
        intros args cs h; induction args using List.reverseRecOn <;> simp_all +decide [ List.foldl_append ] ;
        unfold Cs.eval; simp_all +decide [ Exp.eval ] ;
        grind +ring;
      convert h_fold ( Array.toList ‹_› ) cs _;
      · grind;
      · exact ⟨ _, by simp, h', h'' ⟩;
    exact h_check args i h h' h'';
  exact h_check args i h h' h''

lemma fail₂ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
    e.eval ≠ (bits2num args) -> (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
  intros w args e cs h
  unfold Cs.eval Exp.eval
  sorry

lemma fail : ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
 (¬ (assert_bits args /\ e.eval = bits2num args)) ->
 (assert_bits_e args (.eq0 (bits2num_e args - e) cs)).eval = denotation.n := by
  intros w args e cs h
  by_cases h' : assert_bits args
  · rw [reduce₁ h', fail₂ (by tauto)]
  · rw [fail₁ h']

lemma bits_good : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  e.eval.val < 2 ^ w -> assert_bits args /\ e = bits2num args := sorry

lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := sorry

theorem soundness : ∀ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs]
    constructor
  | lam k h =>
    simp [Circuit.eval,to_cs]
    constructor
    exact h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    split
    apply h
    constructor
  | share e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    apply rw_bisim.right
    intro x
    simp [Exp.eval]
    split
    have hmy : x = Exp.eval e := by grind
    rw [<-hmy]
    apply h
    constructor
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    split
    case is_zero.h.h.isTrue he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          have hmy : o=1 := by grind
          rw [hmy]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
    case is_zero.h.h.isFalse he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          rw [hmul]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
  | assert_range w e c h =>
    simp [Circuit.eval,to_cs]
    apply rw_bisim_uncurry
    intros args
    split
    case _ ew =>
      rw [reduce]
      apply h
      sorry
      -- apply bits_good
      -- assumption
    case _ lt w =>
      rw [fail]
      constructor
      sorry
      -- apply bits_bad
      -- assumption

theorem soundness' : ∀ (c:Circuit' p),
  rw_bisim (Circuit.eval' c) (Cs.eval' (to_cs' c)) := by
  intro c
  apply soundness

def completeness : ∀ (c:Circuit p (ZMod p)),
  Circuit.eval c = Cs.eval (wrap (to_wg c) (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs,to_wg,wrap]
    constructor
  | lam k h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    funext
    apply h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    exact h
    constructor
  | share e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    apply h
  | is_zero e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    case is_zero.isTrue he0 =>
      simp
      split <;> apply h
    case is_zero.isFalse he0 =>
      split
      case isTrue he0' =>
        apply h
      case isFalse he0' =>
        simp [*] at *
  | assert_range e c h =>
    sorry
