import Mathlib

open scoped Cardinal
open Classical

namespace IMO2022P6

/-- A cell of the board. -/
abbrev Cell (n : ℕ) : Type := Fin n × Fin n

/-- A Nordic square. -/
abbrev NordicSquare (n : ℕ) : Type := Cell n ≃ Finset.Icc 1 (n ^ 2)

/-- Whether two cells are adjacent. -/
def Adjacent {n : ℕ} (x y : Cell n) : Prop :=
  Nat.dist x.1 y.1 + Nat.dist x.2 y.2 = 1

/-- The definition of a valley from the problem. -/
def NordicSquare.Valley {n : ℕ} (ns : NordicSquare n) (c : Cell n) : Prop :=
  ∀ c' : Cell n, Adjacent c c' → (ns c : ℕ) < (ns c' : ℕ)

/-- The definition of an uphill path from the problem. -/
structure NordicSquare.UphillPath {n : ℕ} (ns : NordicSquare n) where
  /-- The cells on the path. -/
  cells : List (Cell n)
  nonempty : cells ≠ []
  first_valley : ns.Valley (cells.head nonempty)
  adjacent : cells.IsChain Adjacent
  increasing : cells.IsChain fun x y ↦ (ns x : ℕ) < (ns y : ℕ)

/-
PROBLEM
The set of achievable uphill path counts is nonempty.

PROVIDED SOLUTION
Take any Nordic square ns (there exists one since Cell n and Finset.Icc 1 n² have the same cardinality for n ≥ 1). Then #ns.UphillPath is a cardinal. We need to show it equals some natural number (i.e., it's finite).

Every uphill path has strictly increasing values from {1,...,n²}, so the path length is at most n². The number of cells is n². So the number of possible uphill paths is bounded by the number of sublists of cells of length at most n² that satisfy the conditions — which is finite. Hence UphillPath is a finite type, so its cardinal equals some natural number.

For the existence of a Nordic square: Since Fintype.card (Cell n) = n² = Fintype.card (Finset.Icc 1 (n²)) (for n ≥ 1), there exists an equivalence by Fintype.equivOfCardEq.

For finiteness of UphillPath: the type embeds into List (Cell n) via the .cells field. Since Cell n is finite, List (Cell n) of bounded length is finite. Every uphill path has a chain of strictly increasing values bounded by n², so length ≤ n². Thus UphillPath embeds into Fin n² → Option (Cell n) or similar, which is finite.

Alternative: show UphillPath is a subtype of {l : List (Cell n) // l.length ≤ n²}, which is a Fintype. Then use Cardinal.mk_lt_aleph0 and Cardinal.lt_aleph0_iff_finite.
-/
lemma achievable_nonempty (n : ℕ+) :
    ∃ k : ℕ, ∃ ns : NordicSquare n, #ns.UphillPath = ↑k := by
      by_contra! h_contra;
      have h_finite : ∀ ns : NordicSquare n, Set.Finite {p : List (Cell n) | ∃ q : NordicSquare.UphillPath ns, q.cells = p} := by
        intro ns
        have h_finite : Set.Finite {p : List (Cell n) | p.length ≤ n^2} := by
          exact?;
        refine' h_finite.subset fun p hp => _;
        obtain ⟨ q, rfl ⟩ := hp;
        have h_distinct : List.Nodup q.cells := by
          have h_distinct : List.Nodup (List.map (fun c => (ns c : ℕ)) q.cells) := by
            have h_distinct : List.IsChain (fun x y => x < y) (List.map (fun c => (ns c : ℕ)) q.cells) := by
              rw [ List.isChain_iff_get ] at *;
              intro i; have := q.increasing; simp_all +decide [ List.isChain_iff_get ] ;
              convert this ⟨ i, _ ⟩;
              exact Nat.lt_of_lt_of_le i.2 ( by simp );
            exact List.isChain_iff_pairwise.mp h_distinct |> fun h => h.nodup;
          exact List.Nodup.of_map ( fun c => ( ns c : ℕ ) ) h_distinct;
        simpa [ sq ] using List.toFinset_card_of_nodup h_distinct ▸ Finset.card_le_univ _ |> le_trans <| by simp +decide [ sq ] ;
      -- Since the set of uphill paths is finite, its cardinality must be a natural number.
      have h_card_nat : ∀ ns : NordicSquare n, ∃ k : ℕ, #ns.UphillPath = k := by
        intro ns
        have h_card_nat : Set.Finite {p : List (Cell n) | ∃ q : NordicSquare.UphillPath ns, q.cells = p} := h_finite ns
        have h_card_nat : Finite (NordicSquare.UphillPath ns) := by
          have h_card_nat : Function.Injective (fun q : NordicSquare.UphillPath ns => q.cells) := by
            intro q₁ q₂ h_eq; cases q₁; cases q₂; aesop;
          exact Set.finite_univ_iff.mp ( Set.Finite.subset ( ‹Set.Finite { p : List ( Cell n ) | ∃ q : NordicSquare.UphillPath ns, q.cells = p } ›.preimage fun q => by tauto ) fun q _ => ⟨ q, rfl ⟩ );
        haveI := Fintype.ofFinite ( IMO2022P6.NordicSquare.UphillPath ns ) ; exact ⟨ _, Cardinal.mk_fintype _ ⟩ ;
      exact h_contra ( Classical.choose ( h_card_nat ( Fintype.equivOfCardEq ( by simp +decide [ sq ] ) ) ) ) ( Fintype.equivOfCardEq ( by simp +decide [ sq ] ) ) ( Classical.choose_spec ( h_card_nat ( Fintype.equivOfCardEq ( by simp +decide [ sq ] ) ) ) )

/-- The answer to be determined. -/
noncomputable def answer : ℕ+ → ℕ := fun n =>
  Nat.find (achievable_nonempty n)

/-
PROVIDED SOLUTION
Since answer n = Nat.find (achievable_nonempty n), we have:
1. Nat.find_spec gives: ∃ ns, #ns.UphillPath = ↑(answer n), so answer n ∈ S.
2. Nat.find_min' gives: for any k with ∃ ns, #ns.UphillPath = ↑k, answer n ≤ k.

So IsLeast S (answer n) = ⟨answer n ∈ S, ∀ k ∈ S, answer n ≤ k⟩. Both parts follow from the Nat.find properties.

Use constructor to split into the two goals, then use Nat.find_spec for membership and Nat.find_min' for the lower bound.
-/
theorem result {n : ℕ+} :
    IsLeast {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} (answer n) := by
  constructor;
  · exact Nat.find_spec ( achievable_nonempty n );
  · exact fun k hk => Nat.find_min' _ hk

end IMO2022P6
