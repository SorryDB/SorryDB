    have : О“.conj вһқ Оҫ вҲҲ construction_omega T hT := by sorry;
    sorry;

lemma construction_omega_prime :
  letI U := construction_omega T hT
  ПҶ вӢҺ ПҲ вҲҲ U вҶ’ ПҶ вҲҲ U вҲЁ ПҲ вҲҲ U := by
