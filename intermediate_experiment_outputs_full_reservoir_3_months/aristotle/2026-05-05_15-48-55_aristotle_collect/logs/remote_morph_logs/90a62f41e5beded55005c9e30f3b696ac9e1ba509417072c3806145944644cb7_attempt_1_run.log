import Mathlib

import ProblemExtraction
import Compfiles.Imo2002P3Helper

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := {(2, 1), (5, 3)}

lemma forward_5_3 : Set.Infinite {a : ℤ | 0 < a ∧ a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1} := by
  refine Set.infinite_of_forall_exists_gt ?_
  intro a
  use max a 3 + 1
  simp [Set.mem_setOf_eq]
  exact ⟨(max a 3 + 1) ^ 2 - (max a 3 + 1) + 1, by ring⟩

lemma forward_2_1 : Set.Infinite {a : ℤ | 0 < a ∧ a ^ 1 + a ^ 2 - 1 ∣ a ^ 2 + a - 1} :=
  Set.Infinite.mono (fun x hx => by simpa [add_comm, add_assoc, add_left_comm]) (Set.Ioi_infinite 0)

lemma case_n_ge_m (m n : ℕ) (hmn : m ≤ n) :
    Set.Finite {a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1} := by
  have h_div : ∀ a : ℤ, 2 ≤ a → ¬(a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1) := by
    intro a ha; intro H; have := Int.le_of_dvd (by linarith [pow_pos (zero_lt_two.trans_le ha) m,
      pow_pos (zero_lt_two.trans_le ha) n]) H
    nlinarith [pow_pos (zero_lt_two.trans_le ha) m,
      pow_le_pow_right₀ (by linarith : 1 ≤ a) hmn]
  exact Set.Finite.subset (Set.finite_Icc 0 1) (by rintro a ⟨ha₁, ha₂⟩;
    exact ⟨by linarith, by linarith [show a ≤ 1 by
      exact le_of_not_gt fun ha₃ => h_div a (by linarith) ha₂]⟩)

lemma case_n_zero (m : ℕ) :
    Set.Finite {a : ℤ | 0 < a ∧ a ^ 0 + a ^ 2 - 1 ∣ a ^ m + a - 1} := by
  refine Set.Finite.subset (Set.finite_Icc 0 1) ?_
  intro a ha; obtain ⟨ha_pos, ha_div⟩ := ha
  rcases m with (_ | _ | m) <;> norm_num [pow_succ'] at *
  · exact ⟨ha_pos.le, by nlinarith [Int.le_of_dvd ha_pos ha_div]⟩
  · exact ⟨ha_pos.le, by nlinarith [Int.le_of_dvd (by linarith) ha_div]⟩
  · exact ⟨ha_pos.le, by obtain ⟨k, hk⟩ := ha_div;
      nlinarith [show k = a ^ m by nlinarith [pow_pos ha_pos m]]⟩

lemma reverse_direction (m n : ℕ) (hmn : (m, n) ∉ ({(2, 1), (5, 3)} : Set (ℕ × ℕ))) :
    ¬ Set.Infinite {a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1} := by
  rw [Set.not_infinite]
  rcases Nat.eq_or_lt_of_le (Nat.zero_le n) with rfl | hn
  · exact case_n_zero m
  rcases le_or_lt m n with hle | hlt
  · exact case_n_ge_m m n hle
  · rcases le_or_lt n 3 with hn3 | hn3
    · interval_cases n
      · exact case_n_one m (by intro h; apply hmn; simp [Set.mem_insert_iff]; left; exact ⟨h, rfl⟩)
      · exact case_n_two m
      · exact case_n_three m (by intro h; apply hmn; simp [Set.mem_insert_iff]; right; exact ⟨h, rfl⟩)
    · exact case_n_ge_four m n (by omega) hlt

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  unfold solution
  constructor
  · intro hmn
    simp only [Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq] at hmn
    rcases hmn with ⟨rfl, rfl⟩ | ⟨rfl, rfl⟩
    · exact forward_2_1
    · exact forward_5_3
  · intro hinf
    by_contra h
    exact reverse_direction m n h hinf

end Imo2002P3

