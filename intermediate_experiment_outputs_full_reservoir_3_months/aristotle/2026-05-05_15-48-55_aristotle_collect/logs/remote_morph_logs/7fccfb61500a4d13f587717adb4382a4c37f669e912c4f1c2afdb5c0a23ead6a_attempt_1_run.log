import Mathlib.MeasureTheory.Integral.IntervalAverage
import MiscYD.PhD.VCDim.UnifAP.Defs

/-!
# Fourier analysis of uniformly almost periodic functions
-/

open Filter MeasureTheory
open scoped Topology

variable {Λ : ℝ} {f : ℝ → ℂ}

variable (f) in
/-- The **mean** of an uniformly almost periodic function `f` is the limit of its average on
`[0, X]` as `X → +∞`. -/
noncomputable def mean : ℂ := limUnder atTop fun X ↦ ⨍ x in (0)..X, f x

/-
PROVIDED SOLUTION
We compute:
(T+τ)·⨍[0,T+τ] f = ∫₀^{T+τ} f = ∫₀^T f + ∫_T^{T+τ} f = T·⨍[0,T] f + ∫_T^{T+τ} f

So ⨍[0,T+τ] f - ⨍[0,T] f = (1/(T+τ))(∫_T^{T+τ} f - τ·⨍[0,T] f)

‖⨍[0,T+τ] f - ⨍[0,T] f‖ ≤ (1/(T+τ))(‖∫_T^{T+τ} f‖ + τ·‖⨍[0,T] f‖)
                             ≤ (1/(T+τ))(τC + τC) = 2τC/(T+τ) ≤ 2Cτ/T

Key steps:
1. Use intervalIntegral.integral_add_adjacent_intervals to split
2. Bound ‖∫_T^{T+τ} f‖ ≤ τC using norm_integral_le_of_norm_le_const
3. Bound ‖⨍[0,T] f‖ ≤ C similarly
4. Combine with the average formula
-/
private lemma norm_intervalAverage_shift_sub {C : ℝ} (hC : ∀ x, ‖f x‖ ≤ C) (hC₀ : 0 ≤ C)
    (hfint : ∀ a b : ℝ, IntervalIntegrable f volume a b) {T τ : ℝ} (hT : 0 < T) (hτ : 0 ≤ τ) :
    ‖(⨍ x in (0)..(T + τ), f x) - ⨍ x in (0)..T, f x‖ ≤ 2 * C * τ / T := by
      -- Using the triangle inequality and the bounds on the integrals, we get:
      have h_triangle : ‖(⨍ x in (0)..T + τ, f x) - ⨍ x in (0)..T, f x‖ ≤ (1 / (T + τ)) * ‖∫ x in (T)..T + τ, f x‖ + τ / (T * (T + τ)) * ‖∫ x in (0)..T, f x‖ := by
        have h_triangle : ‖(⨍ x in (0)..T + τ, f x) - ⨍ x in (0)..T, f x‖ = ‖(∫ x in (T)..T + τ, f x) / (T + τ) - (∫ x in (0)..T, f x) * τ / (T * (T + τ))‖ := by
          have h_triangle : (⨍ x in (0)..T + τ, f x) = (∫ x in (0)..T + τ, f x) / (T + τ) ∧ (⨍ x in (0)..T, f x) = (∫ x in (0)..T, f x) / T := by
            simp +decide [ div_eq_inv_mul, intervalIntegral.integral_of_le, hT.le, hτ ];
            simp +decide [ intervalIntegral.integral_of_le ( by linarith : 0 ≤ T + τ ), MeasureTheory.average_eq ];
            simp +decide [ hT.le, hτ, Set.uIoc_of_le ( by linarith : 0 ≤ T + τ ) ];
            exact Or.inl ( mod_cast max_eq_left ( by linarith ) );
          rw [ h_triangle.1, h_triangle.2 ] ; rw [ show ( ∫ x in ( 0 : ℝ )..T + τ, f x ) = ( ∫ x in ( 0 : ℝ )..T, f x ) + ( ∫ x in ( T : ℝ )..T + τ, f x ) from ?_ ] ; ring;
          · field_simp;
            rw [ div_sub_div ] <;> ring <;> norm_cast <;> linarith;
          · rw [ intervalIntegral.integral_add_adjacent_intervals ] <;> apply_rules [ hfint ];
        convert norm_sub_le ( ( ∫ x in T..T + τ, f x ) / ( T + τ ) ) ( ( ∫ x in ( 0 : ℝ )..T, f x ) * τ / ( T * ( T + τ ) ) ) using 1 ; norm_num [ div_eq_inv_mul ] ; ring;
        norm_cast ; norm_num [ abs_of_nonneg, hT.le, hτ ] ; ring;
        rw [ abs_of_nonneg ( by positivity ) ] ; ring;
      -- Using the bounds on the integrals, we get:
      have h_integral_bounds : ‖∫ x in (T)..T + τ, f x‖ ≤ τ * C ∧ ‖∫ x in (0)..T, f x‖ ≤ T * C := by
        constructor <;> rw [ intervalIntegral.integral_of_le ( by linarith ) ];
        · refine' le_trans ( MeasureTheory.norm_integral_le_integral_norm _ ) ( le_trans ( MeasureTheory.integral_mono_of_nonneg _ _ _ ) _ ) <;> norm_num [ hτ ];
          exacts [ fun _ => C, Filter.eventually_inf_principal.mpr <| Filter.Eventually.of_forall fun x hx => norm_nonneg _, Continuous.integrableOn_Ioc <| by continuity, Filter.eventually_inf_principal.mpr <| Filter.Eventually.of_forall fun x hx => hC x, by simp +decide [ hτ ] ];
        · refine' le_trans ( MeasureTheory.norm_integral_le_integral_norm ( f ) ) ( le_trans ( MeasureTheory.integral_mono_of_nonneg _ _ _ ) _ );
          exacts [ fun _ => C, Filter.Eventually.of_forall fun _ => norm_nonneg _, Continuous.integrableOn_Ioc ( by continuity ), Filter.Eventually.of_forall fun _ => hC _, by simp +decide [ hT.le ] ];
      refine le_trans h_triangle ?_;
      field_simp;
      nlinarith [ mul_nonneg hT.le hτ, mul_nonneg hT.le hC₀, mul_nonneg hτ hC₀ ]

/-
PROVIDED SOLUTION
M(nT) - M(T) = (1/(nT)) Σ_{k=0}^{n-1} (∫_{kT}^{(k+1)T} f - ∫_0^T f)

For each block k: ∫_{kT}^{(k+1)T} f(x) dx = ∫_0^T f(x + kT) dx (by substitution via integral_comp_add_right).
By relative density, ∃ σ_k ∈ [0,l) with kT+σ_k an AP: ‖f(y+kT+σ_k)-f(y)‖ ≤ δ for all y.
So f(x+kT) = f((x-σ_k)+(kT+σ_k)) and ‖f(x+kT) - f(x-σ_k)‖ ≤ δ.
Thus |∫_0^T f(x+kT)dx - ∫_0^T f(x-σ_k)dx| ≤ Tδ.
And ∫_0^T f(x-σ_k)dx = ∫_{-σ_k}^{T-σ_k} f, which differs from ∫_0^T f by at most 2lC (boundary terms of size σ_k·C each).
So |∫_{kT}^{(k+1)T} f - ∫_0^T f| ≤ Tδ + 2lC.
Summing and dividing: ‖M(nT)-M(T)‖ ≤ (1/(nT))·n·(Tδ+2lC) = δ + 2lC/T.

Same proof as before - decompose ∫_0^{nT} into n blocks, bound each block's error using almost periodicity and boundary terms, sum and divide.

Decompose ∫_0^{nT} into n blocks ∫_{kT}^{(k+1)T}. Each block: use substitution (integral_comp_add_right) to get ∫_0^T f(x+kT)dx, then use the almost period to compare with ∫_0^T f(x)dx. The error per block is Tδ+2lC. Sum over n blocks and divide by nT to get δ + 2lC/T.
-/
set_option maxHeartbeats 3200000 in
private lemma norm_intervalAverage_multiple_sub {C δ l : ℝ} (hC : ∀ x, ‖f x‖ ≤ C) (hC₀ : 0 ≤ C)
    (hfint : ∀ a b : ℝ, IntervalIntegrable f volume a b)
    (hδ : IsRelDenseWith {t | IsLinftyAP δ t f} l)
    {T : ℝ} (hT : 0 < T) (n : ℕ) (hn : 0 < n) :
    ‖(⨍ x in (0)..(n * T), f x) - ⨍ x in (0)..T, f x‖ ≤ δ + 2 * l * C / T := by
      -- For each block k, we have |∫_{kT}^{(k+1)T} f(x)dx - ∫_0^T f(x)dx| ≤ Tδ + 2lC.
      have h_block : ∀ k : ℕ, k < n → ‖(∫ x in (k * T)..((k + 1) * T), f x) - (∫ x in (0)..T, f x)‖ ≤ T * δ + 2 * l * C := by
        -- By relative density, for each $k < n$, there exists $\sigma_k \in [0, l)$ such that $kT + \sigma_k$ is an almost period of $f$.
        intro k hk
        obtain ⟨σ_k, hσ_k⟩ : ∃ σ_k ∈ Set.Ico 0 l, IsLinftyAP δ (k * T + σ_k) f := by
          have := hδ ( k * T ) ; aesop;
        -- Using the almost periodicity, we have $\left| \int_0^T f(x + kT + \sigma_k) \, dx - \int_0^T f(x) \, dx \right| \leq T \delta$.
        have h_almost_periodic : ‖(∫ x in (0)..T, f (x + k * T + σ_k)) - (∫ x in (0)..T, f x)‖ ≤ T * δ := by
          rw [ ← intervalIntegral.integral_sub ];
          · refine' le_trans ( intervalIntegral.norm_integral_le_of_norm_le_const _ ) _;
            exacts [ δ, fun x hx => by simpa [ add_assoc ] using hσ_k.2 x, by rw [ abs_of_nonneg ( by linarith ) ] ; linarith ];
          · convert hfint ( 0 + k * T + σ_k ) ( T + k * T + σ_k ) |> fun h => h.comp_add_right ( k * T + σ_k ) using 1;
            · ac_rfl;
            · ring;
            · ring;
          · exact hfint _ _;
        -- Using the substitution $u = x + kT + \sigma_k$, we get $\int_0^T f(x + kT + \sigma_k) \, dx = \int_{kT + \sigma_k}^{(k+1)T + \sigma_k} f(u) \, du$.
        have h_substitution : ∫ x in (0)..T, f (x + k * T + σ_k) = ∫ x in (k * T + σ_k)..((k + 1) * T + σ_k), f x := by
          convert intervalIntegral.integral_comp_add_right _ ( k * T + σ_k ) using 2 <;> ring;
          ac_rfl;
        -- Using the triangle inequality, we can bound the difference between the integrals.
        have h_triangle : ‖(∫ x in (k * T)..((k + 1) * T), f x) - (∫ x in (k * T + σ_k)..((k + 1) * T + σ_k), f x)‖ ≤ ‖(∫ x in (k * T)..(k * T + σ_k), f x)‖ + ‖(∫ x in ((k + 1) * T)..((k + 1) * T + σ_k), f x)‖ := by
          rw [ show ( ∫ x in ( k : ℝ ) * T.. ( k + 1 ) * T, f x ) = ( ∫ x in ( k : ℝ ) * T.. ( k : ℝ ) * T + σ_k, f x ) + ( ∫ x in ( k : ℝ ) * T + σ_k.. ( k + 1 ) * T, f x ) from ?_, show ( ∫ x in ( k : ℝ ) * T + σ_k.. ( k + 1 ) * T + σ_k, f x ) = ( ∫ x in ( k : ℝ ) * T + σ_k.. ( k + 1 ) * T, f x ) + ( ∫ x in ( k + 1 ) * T.. ( k + 1 ) * T + σ_k, f x ) from ?_ ];
          · convert norm_sub_le ( ∫ x in ( k : ℝ ) * T.. ( k : ℝ ) * T + σ_k, f x ) ( ∫ x in ( k + 1 : ℝ ) * T.. ( k + 1 : ℝ ) * T + σ_k, f x ) using 2 ; ring;
          · rw [ intervalIntegral.integral_add_adjacent_intervals ] <;> apply_rules [ hfint ];
          · rw [ intervalIntegral.integral_add_adjacent_intervals ] <;> apply_rules [ hfint ];
        -- Using the bound on the integral, we have $\left| \int_{kT}^{kT+\sigma_k} f(x) \, dx \right| \leq \sigma_k C$ and $\left| \int_{(k+1)T}^{(k+1)T+\sigma_k} f(x) \, dx \right| \leq \sigma_k C$.
        have h_integral_bound : ‖(∫ x in (k * T)..(k * T + σ_k), f x)‖ ≤ σ_k * C ∧ ‖(∫ x in ((k + 1) * T)..((k + 1) * T + σ_k), f x)‖ ≤ σ_k * C := by
          constructor <;> rw [ intervalIntegral.integral_of_le ( by linarith [ hσ_k.1.1 ] ) ];
          · refine' le_trans ( MeasureTheory.norm_integral_le_integral_norm _ ) ( le_trans ( MeasureTheory.integral_mono_of_nonneg _ _ _ ) _ );
            refine' fun x => C;
            · exact Filter.Eventually.of_forall fun x => norm_nonneg _;
            · norm_num;
            · filter_upwards [ ] using hC;
            · norm_num [ hσ_k.1.1 ];
          · refine' le_trans ( MeasureTheory.norm_integral_le_integral_norm _ ) _;
            refine' le_trans ( MeasureTheory.integral_mono_of_nonneg _ _ _ ) _;
            refine' fun x => C;
            · exact Filter.Eventually.of_forall fun x => norm_nonneg _;
            · norm_num;
            · filter_upwards [ ] using hC;
            · norm_num [ add_mul, hσ_k.1.1 ];
        simp_all +decide [ add_mul ];
        exact le_trans ( by simpa using norm_add_le ( ( ∫ x in ( k : ℝ ) * T.. ( k : ℝ ) * T + T, f x ) - ∫ x in ( k : ℝ ) * T + σ_k.. ( k : ℝ ) * T + T + σ_k, f x ) ( ( ∫ x in ( k : ℝ ) * T + σ_k.. ( k : ℝ ) * T + T + σ_k, f x ) - ∫ x in ( 0 : ℝ )..T, f x ) ) ( by nlinarith );
      -- Summing the errors over all blocks and dividing by $nT$, we get the desired bound.
      have h_sum : ‖(∫ x in (0)..(n * T), f x) - n * (∫ x in (0)..T, f x)‖ ≤ n * (T * δ + 2 * l * C) := by
        convert norm_sum_le _ _ |> le_trans <| Finset.sum_le_sum fun i hi => h_block i ( Finset.mem_range.mp hi ) using 1;
        · congr! 1;
          refine' Nat.recOn n _ _ <;> simp_all +decide [ add_mul, Finset.sum_range_succ ];
          intro n hn; rw [ ← hn, intervalIntegral.integral_add_adjacent_intervals ] <;> apply_rules [ hfint ] ;
        · norm_num [ mul_comm ];
          ring;
      simp_all +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm, intervalIntegral.integral_comp_mul_right, ne_of_gt ];
      simp_all +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm, MeasureTheory.integral_const_mul, MeasureTheory.integral_mul_const, hn.ne', hT.ne', intervalIntegral.integral_of_le ( show 0 ≤ T * n by positivity ), intervalIntegral.integral_of_le ( show 0 ≤ T by positivity ), MeasureTheory.average_eq ];
      simp_all +decide [ mul_assoc, mul_comm, mul_left_comm, ← intervalIntegral.integral_of_le, le_of_lt hT, ne_of_gt hT, ne_of_gt ( Nat.cast_pos.mpr hn ), MeasureTheory.measureReal_def ];
      field_simp;
      rw [ div_sub', div_div, norm_div ] <;> norm_num [ hn.ne' ];
      rw [ abs_of_pos hT, mul_div, div_le_iff₀ ] <;> nlinarith [ show ( n : ℝ ) ≥ 1 by norm_cast ]

private lemma cauchy_arith {ε δ l C T T₀ s : ℝ}
    (hε : 0 < ε) (hδ : δ = ε / 7) (hl0 : 0 < l) (hC0 : 0 < C)
    (hT : 0 < T) (hT₀ : 0 < T₀) (hTge : T₀ ≤ T)
    (hT₀bd : 2 * l * C / T₀ < δ)
    (hshift : s < δ)
    (hkey : ‖(⨍ x in (0)..T, f x) - ⨍ x in (0)..T₀, f x‖ ≤
      (δ + 2 * l * C / T) + s + (δ + 2 * l * C / T₀)) :
    ‖(⨍ x in (0)..T, f x) - ⨍ x in (0)..T₀, f x‖ < ε := by
  have h1 : 2 * l * C / T ≤ 2 * l * C / T₀ :=
    div_le_div_of_nonneg_left (by positivity : (0 : ℝ) ≤ 2 * l * C) hT₀ hTge
  linarith

set_option maxHeartbeats 800000 in
lemma IsUnifAlmostPeriodic.cauchySeq_mean (hf : IsUnifAlmostPeriodic f) :
    CauchySeq (fun X ↦ ⨍ x in (0)..X, f x) := by
  rw [Metric.cauchySeq_iff']
  intro ε hε
  obtain ⟨C₀, hC₀⟩ := hf.exists_forall_le
  set C := max C₀ 1
  have hCb : ∀ x, ‖f x‖ ≤ C := fun x => le_trans (hC₀ x) (le_max_left _ _)
  have hC0 : (0 : ℝ) < C := lt_of_lt_of_le one_pos (le_max_right _ _)
  set δ := ε / 7
  have hδ : 0 < δ := by positivity
  obtain ⟨l, hl⟩ := hf hδ
  have hl0 : 0 < l := hl.pos
  have hfint : ∀ a b : ℝ, IntervalIntegrable f volume a b :=
    fun a b => hf.uniformContinuous.continuous.intervalIntegrable a b
  set T₀ := 14 * l * C / ε + 1
  have hT₀ : 0 < T₀ := by positivity
  have hT₀bd : 2 * l * C / T₀ < δ := by
    rw [div_lt_iff₀ hT₀]
    have : δ * T₀ = 2 * l * C + δ := by simp only [T₀, δ]; field_simp; ring
    linarith
  refine ⟨T₀, fun T hTge => ?_⟩
  have hT : 0 < T := lt_of_lt_of_le hT₀ hTge
  rw [dist_eq_norm]
  -- n₁ = ⌈2CT/(δT₀)⌉ + 1
  set n₁ := Nat.ceil (2 * C * T / (δ * T₀)) + 1
  have hn₁ : 0 < n₁ := Nat.succ_pos _
  have hn₁r : (0 : ℝ) < (n₁ : ℝ) := Nat.cast_pos.mpr hn₁
  have hn₁bd : (n₁ : ℝ) * T₀ > 2 * C * T / δ := by
    have h1 : ((Nat.ceil (2 * C * T / (δ * T₀)) + 1 : ℕ) : ℝ) > 2 * C * T / (δ * T₀) := by
      push_cast
      exact lt_of_le_of_lt (Nat.le_ceil _) (by linarith)
    have h2 : 2 * C * T / (δ * T₀) * T₀ = 2 * C * T / δ := by
      field_simp
    nlinarith
  -- n₂ = ⌈n₁*T₀/T⌉
  set n₂ := Nat.ceil ((n₁ : ℝ) * T₀ / T)
  have hn₂ : 0 < n₂ := Nat.ceil_pos.mpr (div_pos (mul_pos hn₁r hT₀) hT)
  have hn₂ge : (n₂ : ℝ) * T ≥ (n₁ : ℝ) * T₀ := by
    rw [ge_iff_le, ← div_le_iff₀ hT]
    exact Nat.le_ceil _
  have hn₂lt : (n₂ : ℝ) * T < (n₁ : ℝ) * T₀ + T := by
    have h1 : 0 ≤ (n₁ : ℝ) * T₀ / T :=
      div_nonneg (mul_nonneg (Nat.cast_nonneg _) hT₀.le) hT.le
    have h2 := Nat.ceil_lt_add_one h1
    have h3 := mul_lt_mul_of_pos_right h2 hT
    rwa [add_mul, div_mul_cancel₀ _ hT.ne', one_mul] at h3
  -- Shift bound
  have hshift_bd : 2 * C * ((n₂ : ℝ) * T - (n₁ : ℝ) * T₀) / ((n₁ : ℝ) * T₀) < δ := by
    have h1 : (n₂ : ℝ) * T - (n₁ : ℝ) * T₀ < T := by linarith
    have h2 : 0 < (n₁ : ℝ) * T₀ := mul_pos hn₁r hT₀
    rw [div_lt_iff₀ h2]
    have h3 : δ * ((n₁ : ℝ) * T₀) > 2 * C * T := by
      rwa [gt_iff_lt, ← div_lt_iff₀' hδ]
    nlinarith [sub_nonneg.mpr hn₂ge]
  -- Triangle inequality
  have key : ‖(⨍ x in (0)..T, f x) - ⨍ x in (0)..T₀, f x‖ ≤
      (δ + 2 * l * C / T) +
      (2 * C * ((n₂ : ℝ) * T - (n₁ : ℝ) * T₀) / ((n₁ : ℝ) * T₀)) +
      (δ + 2 * l * C / T₀) := by
    have hsplit : (⨍ x in (0)..T, f x) - ⨍ x in (0)..T₀, f x =
        ((⨍ x in (0)..T, f x) - ⨍ x in (0)..((n₂ : ℝ) * T), f x)
        + ((⨍ x in (0)..((n₂ : ℝ) * T), f x) - ⨍ x in (0)..((n₁ : ℝ) * T₀), f x)
        + ((⨍ x in (0)..((n₁ : ℝ) * T₀), f x) - ⨍ x in (0)..T₀, f x) := by ring
    rw [hsplit]
    calc ‖((⨍ x in (0)..T, f x) - ⨍ x in (0)..((n₂ : ℝ) * T), f x)
        + ((⨍ x in (0)..((n₂ : ℝ) * T), f x) - ⨍ x in (0)..((n₁ : ℝ) * T₀), f x)
        + ((⨍ x in (0)..((n₁ : ℝ) * T₀), f x) - ⨍ x in (0)..T₀, f x)‖
      _ ≤ ‖(⨍ x in (0)..T, f x) - ⨍ x in (0)..((n₂ : ℝ) * T), f x‖
          + ‖(⨍ x in (0)..((n₂ : ℝ) * T), f x) - ⨍ x in (0)..((n₁ : ℝ) * T₀), f x‖
          + ‖(⨍ x in (0)..((n₁ : ℝ) * T₀), f x) - ⨍ x in (0)..T₀, f x‖ := norm_add₃_le ..
      _ ≤ _ := by
        gcongr
        · rw [norm_sub_rev]
          exact norm_intervalAverage_multiple_sub hCb hC0.le hfint hl hT n₂ hn₂
        · show ‖(⨍ x in (0)..((n₂ : ℝ) * T), f x) - ⨍ x in (0)..((n₁ : ℝ) * T₀), f x‖ ≤ _
          have hrw : (n₂ : ℝ) * T = (n₁ : ℝ) * T₀ + ((n₂ : ℝ) * T - (n₁ : ℝ) * T₀) := by ring
          rw [hrw]
          convert norm_intervalAverage_shift_sub hCb hC0.le hfint (mul_pos hn₁r hT₀)
            (sub_nonneg.mpr hn₂ge) using 2
          ring
        · exact norm_intervalAverage_multiple_sub hCb hC0.le hfint hl hT₀ n₁ hn₁
  exact cauchy_arith hε rfl hl0 hC0 hT hT₀ hTge hT₀bd hshift_bd key

lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) :=
  hf.cauchySeq_mean.tendsto_limUnder

variable (Λ f) in
/-- The **Fourier coefficient** at `Λ` of an uniformly almost periodic function `f` is the mean of
`x ↦ f x * exp (-iΛx)`. -/
noncomputable def fourierCoeff : ℂ := mean fun x ↦ f x * .exp (-.I * Λ * x)

/-- The **Fourier exponents** of an uniformly almost periodic function `f` are at most countable. -/
lemma IsUnifAlmostPeriodic.countable_fourierCoeff_ne_zero : {Λ | fourierCoeff Λ f ≠ 0}.Countable :=
