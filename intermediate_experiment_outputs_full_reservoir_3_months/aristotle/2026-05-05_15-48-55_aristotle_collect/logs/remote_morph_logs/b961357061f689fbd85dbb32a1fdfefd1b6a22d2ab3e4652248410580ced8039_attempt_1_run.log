import Mathlib

/-!
# Toric ideals

This file defines toric ideals.
-/

open AlgebraicGeometry CategoryTheory.Limits
open scoped SpecOfNotation

namespace AddMonoidAlgebra
variable {M G R k H : Type*} [AddCommMonoid M] [AddCommGroup G] [AddCommGroup H]
  {f : (⊤ : AddSubmonoid M).LocalizationMap G} {g : (⊤ : AddSubmonoid M).LocalizationMap H}
  {s : AddSubmonoid G} {x : M × M}

section CommRing
variable [CommRing R] {I : Ideal R[M]}

variable (f s) in
/-- The monoid ideal corresponding to a submonoid `s` of the Grothendieck group of a monoid is an
ideal generated by binomials whose exponents differ by an element of `s`. -/
def monoidIdeal : Ideal R[M] := .span <| (fun (a, b) ↦ single a 1 - single b 1) '' s.subPairs f

variable (f g s) in
lemma monoidIdeal_comap :
    monoidIdeal g (s.comap (g.addEquivOfLocalizations f)) = (monoidIdeal f s : Ideal R[M]) := by
  unfold monoidIdeal
  congr!
  exact AddSubmonoid.subPairs_comap ..

/-- An ideal is toric if it's prime and a group ideal. -/
@[mk_iff isToricIdeal_iff_exists_monoidIdeal_eq']
class IsToricIdeal (I : Ideal R[M]) extends I.IsPrime where
  /-- Use `IsToricIdeal.exists_monoidIdeal_eq` instead. -/
  exists_monoidIdeal_eq' :
    ∃ s : AddSubgroup (AddLocalization (⊤ : AddSubmonoid M)),
      monoidIdeal (AddLocalization.addMonoidOf (⊤ : AddSubmonoid M)) s.toAddSubmonoid = I

variable (f) in
lemma isToricIdeal_iff_exists_monoidIdeal_eq :
    IsToricIdeal I ↔ I.IsPrime ∧ ∃ s : AddSubgroup G, monoidIdeal f s.toAddSubmonoid = I := by
  rw [isToricIdeal_iff_exists_monoidIdeal_eq']
  congr! 1
  refine (f.addEquivOfLocalizations <|
    AddLocalization.addMonoidOf _).comapAddSubgroup.toEquiv.exists_congr fun s ↦ ?_
  congr! 1
  simpa using (monoidIdeal_comap ..).symm

namespace IsToricIdeal

alias ⟨exists_monoidIdeal_eq, of_exists_monoidIdeal_eq⟩ := isToricIdeal_iff_exists_monoidIdeal_eq

end IsToricIdeal
end CommRing

section
variable [Field k] [IsAlgClosed k] {I : Ideal k[M]}

private lemma single_one_not_mem_of_prime_binomial
    (hI : I.IsPrime)
    (s : Set (M × M))
    (hsI : Ideal.span ((fun p ↦ single p.1 (1 : k) - single p.2 1) '' s) = I)
    (m : M) : single m (1 : k) ∉ I := by
  have h_eval : ∀ p ∈ Ideal.span (Set.image
      (fun (p : M × M) => AddMonoidAlgebra.single p.1 1 - AddMonoidAlgebra.single p.2 1) s),
      (AddMonoidAlgebra.lift k k M (1 : Multiplicative M →* k)) p = 0 := by
    intro p hp; induction hp using Submodule.span_induction ; aesop;
    · simp +decide [ AddMonoidAlgebra.lift ];
    · aesop;
    · simp_all +decide [ Algebra.smul_def ];
  contrapose! h_eval; aesop;

private lemma binomial_mem_of_Grothendieck_eq
    (hI : I.IsPrime)
    (s : Set (M × M))
    (hsI : Ideal.span ((fun p ↦ single p.1 (1 : k) - single p.2 1) '' s) = I)
    (f : (⊤ : AddSubmonoid M).LocalizationMap G)
    {a b a' b' : M}
    (hmem : single a' (1 : k) - single b' 1 ∈ I)
    (heq : f a - f b = f a' - f b') :
    single a (1 : k) - single b 1 ∈ I := by
  have h_eq : ∃ c : M, a + b' + c = a' + b + c := by
    have h_eq : f (a + b') = f (a' + b) := by grind
    have := f.eq_iff_exists.1 h_eq
    exact ⟨this.choose, by simpa [add_comm, add_left_comm, add_assoc] using this.choose_spec⟩
  obtain ⟨c, hc⟩ := h_eq
  have h_eq' : (single a 1 * single b' 1 * single c 1 : k[M]) -
      (single a' 1 * single b 1 * single c 1 : k[M]) ∈ I := by
    simp_all +decide [← add_assoc, mul_assoc, ← map_add]
  have h_eq'' : (single a 1 - single b 1) * (single b' 1 * single c 1) ∈ I := by
    convert I.add_mem h_eq' (I.mul_mem_left (single c 1 * single b 1) hmem) using 1; ring
  have h_not_in_I : single b' 1 * single c 1 ∉ I := by
    have h_not_in_I : single b' 1 ∉ I ∧ single c 1 ∉ I :=
      ⟨single_one_not_mem_of_prime_binomial hI s hsI b',
       single_one_not_mem_of_prime_binomial hI s hsI c⟩
    exact fun h => h_not_in_I.1 (hI.mem_or_mem h |>.resolve_right h_not_in_I.2)
  exact hI.mem_or_mem h_eq'' |> Or.resolve_right <| by simpa using h_not_in_I

/-
PROBLEM
The core existence result: given a prime ideal `I` generated by pure binomials,
there exists a subgroup `S` of the Grothendieck group such that `monoidIdeal f S = I`.

PROVIDED SOLUTION
Define S = AddSubgroup.closure ((fun p : M × M ↦ f p.1 - f p.2) '' s).
Use `⟨S, ?_⟩` and prove `monoidIdeal f S.toAddSubmonoid = I` using `le_antisymm`.

Direction I ≤ monoidIdeal (i.e., I ⊆ monoidIdeal):
- Rewrite ← hsI to get Ideal.span(binomials '' s) ≤ monoidIdeal.
- Use Ideal.span_le. For each generator `single a 1 - single b 1` with `(a,b) ∈ s`:
- f(a) - f(b) is in the image set, hence in S via AddSubgroup.subset_closure.
- So (a,b) ∈ subPairs f S.toAddSubmonoid (by definition of subPairs and mem_subPairs).
- Hence single a 1 - single b 1 ∈ monoidIdeal via Ideal.subset_span applied to the image element.

Direction monoidIdeal ≤ I:
- Use Ideal.span_le. For each `single a 1 - single b 1` with `(a,b) ∈ subPairs f S.toAddSubmonoid`:
- We have f(a) - f(b) ∈ S = closure((fun p ↦ f p.1 - f p.2) '' s).
- Define P := {g : G | ∀ a b : M, f a - f b = g → single a (1:k) - single b 1 ∈ I}.
- Show P is an AddSubgroup using AddSubgroup.mk':
  * 0 ∈ P: If f a - f b = 0, use `binomial_mem_of_Grothendieck_eq` with a' = 0, b' = 0.
    single 0 1 - single 0 1 = 0 ∈ I. And f 0 - f 0 = 0 = f a - f b. ✓
  * Closed under + and neg: If g₁, g₂ ∈ P and we need g₁ + g₂ ∈ P:
    For f a - f b = g₁ + g₂, use f.surj to get witnesses for g₁ and g₂.
    f.surj g₁ gives ⟨⟨a₁, ⟨b₁, _⟩⟩, h₁⟩ with g₁ + f b₁ = f a₁, so g₁ = f a₁ - f b₁.
    By g₁ ∈ P, single a₁ 1 - single b₁ 1 ∈ I. Similarly for g₂ → a₂, b₂.
    Then single (a₁+a₂) 1 - single (b₁+b₂) 1 ∈ I (it equals
      single a₁ 1 * (single a₂ 1 - single b₂ 1) + (single a₁ 1 - single b₁ 1) * single b₂ 1,
      both terms in I).
    Also f(a₁+a₂) - f(b₁+b₂) = g₁ + g₂ = f a - f b.
    Apply binomial_mem_of_Grothendieck_eq with a'=a₁+a₂, b'=b₁+b₂. ✓
  * For negation: if g ∈ P and f a - f b = -g, find a', b' with f a' - f b' = g.
    Then single a' 1 - single b' 1 ∈ I, so -(single a' 1 - single b' 1) = single b' 1 - single a' 1 ∈ I.
    f a - f b = -g = -(f a' - f b') = f b' - f a'.
    Apply binomial_mem_of_Grothendieck_eq with a'=b', b'=a'. ✓
- Show (fun p ↦ f p.1 - f p.2) '' s ⊆ P:
  For (a', b') ∈ s, f a' - f b' ∈ P means: ∀ a b, f a - f b = f a' - f b' → single a 1 - single b 1 ∈ I.
  Since (a', b') ∈ s, single a' 1 - single b' 1 ∈ hsI ▸ Ideal.subset_span ⟨(a',b'), ..⟩, i.e., in I.
  Apply binomial_mem_of_Grothendieck_eq. ✓
- Since (fun p ↦ f p.1 - f p.2) '' s ⊆ P and P is a subgroup, S = closure(...) ≤ P.
  Use AddSubgroup.closure_le.
- So for (a,b) ∈ subPairs, f a - f b ∈ S ⊆ P, hence single a 1 - single b 1 ∈ I. ✓
-/
private lemma exists_addSubgroup_monoidIdeal_eq
    (hI : I.IsPrime)
    (s : Set (M × M))
    (hsI : Ideal.span ((fun p ↦ single p.1 (1 : k) - single p.2 1) '' s) = I)
    (f : (⊤ : AddSubmonoid M).LocalizationMap G) :
    ∃ S : AddSubgroup G, monoidIdeal f S.toAddSubmonoid = I := by
  -- Define S = AddSubgroup.closure ((fun p : M × M ↦ f p.1 - f p.2) '' s).
  set S := AddSubgroup.closure ((fun p : M × M ↦ f p.1 - f p.2) '' s) with hS_def;
  -- Show that $S \subseteq P$.
  have hS_subset_P : ∀ g ∈ S, ∀ a b : M, f a - f b = g → single a (1 : k) - single b 1 ∈ I := by
    -- Show that $P$ is an AddSubgroup.
    have hP_subgroup : ∀ g₁ g₂ : G, (∀ a b : M, f a - f b = g₁ → single a (1 : k) - single b 1 ∈ I) → (∀ a b : M, f a - f b = g₂ → single a (1 : k) - single b 1 ∈ I) → (∀ a b : M, f a - f b = g₁ + g₂ → single a (1 : k) - single b 1 ∈ I) := by
      intro g₁ g₂ hg₁ hg₂ a b hab
      obtain ⟨a₁, b₁, ha₁⟩ : ∃ a₁ b₁ : M, f a₁ - f b₁ = g₁ := by
        have := f.surj g₁;
        exact ⟨ this.choose.1, this.choose.2, by rw [ ← this.choose_spec, add_sub_cancel_right ] ⟩
      obtain ⟨a₂, b₂, ha₂⟩ : ∃ a₂ b₂ : M, f a₂ - f b₂ = g₂ := by
        have := f.surj g₂;
        grind
      have h_sum : (single (a₁ + a₂) (1 : k) - single (b₁ + b₂) 1 : k[M]) ∈ I := by
        convert I.add_mem ( I.mul_mem_left ( single a₁ 1 ) ( hg₂ a₂ b₂ ha₂ ) ) ( I.mul_mem_left ( single b₂ 1 ) ( hg₁ a₁ b₁ ha₁ ) ) using 1 ; simp +decide [ sub_mul, mul_sub ] ; ring!;
        simp +decide [ add_comm, sub_add_sub_comm ]
      have h_neg : (single a 1 - single b 1 : k[M]) ∈ I := by
        apply binomial_mem_of_Grothendieck_eq hI s hsI f h_sum;
        simp_all +decide [ sub_eq_iff_eq_add ];
        abel1
      exact h_neg;
    have hP_subgroup : ∀ g : G, (∀ a b : M, f a - f b = g → single a (1 : k) - single b 1 ∈ I) → (∀ a b : M, f a - f b = -g → single a (1 : k) - single b 1 ∈ I) := by
      intro g hg a b hab
      obtain ⟨a', b', h_eq⟩ : ∃ a' b' : M, f a' - f b' = g := by
        exact ⟨ b, a, by rw [ ← neg_sub, hab, neg_neg ] ⟩
      have h_neg : (single b' (1 : k) - single a' 1 : k[M]) ∈ I := by
        simpa using I.neg_mem ( hg a' b' h_eq )
      have h_final : (single a (1 : k) - single b 1 : k[M]) ∈ I := by
        convert binomial_mem_of_Grothendieck_eq hI s hsI f h_neg _ using 1;
        rw [ hab, ← neg_sub, h_eq ]
      exact h_final;
    intro g hg
    induction' hg using AddSubgroup.closure_induction with g hg ih;
    · rcases hg with ⟨ p, hp, rfl ⟩;
      intro a b hab;
      exact hsI ▸ Ideal.subset_span ( Set.mem_image_of_mem _ hp ) |> fun h => binomial_mem_of_Grothendieck_eq hI s hsI f h hab;
    · intro a b hab
      have h_zero : single a (1 : k) - single b 1 ∈ I := by
        have h_zero : single 0 (1 : k) - single 0 1 ∈ I := by
          simp +decide [ sub_self ];
        convert binomial_mem_of_Grothendieck_eq hI s hsI f h_zero _ using 1 ; simp +decide [ hab ]
      exact h_zero;
    · grind;
    · exact hP_subgroup _ ‹_›;
  refine' ⟨ S, _ ⟩;
  refine' le_antisymm _ _ <;> simp_all +decide [ monoidIdeal ];
  · exact Ideal.span_le.mpr ( Set.image_subset_iff.mpr fun p hp => hS_subset_P _ ( by simpa using hp ) _ _ rfl );
  · rw [ ← hsI ];
    refine' Ideal.span_mono _;
    rintro _ ⟨ p, hp, rfl ⟩ ; use ( p.1, p.2 ) ; aesop;

lemma isToricIdeal_iff_exists_span_single_sub_single :
    IsToricIdeal I
      ↔ I.IsPrime ∧ ∃ s : Set (M × M), .span ((fun (a, b) ↦ single a 1 - single b 1) '' s) = I where
  mp := by rintro ⟨s, rfl⟩; exact ⟨inferInstance, _, rfl⟩
  mpr := by
    let G := AddLocalization (⊤ : AddSubmonoid M)
    rintro ⟨_, s, hsI⟩
    letI V := Spec(k[M] ⧸ I)
    let : V.Over Spec(k[M]) := sorry
    let : Spec(k[G]).Over Spec(k[M]) := sorry
    let VinterT := pullback (V ↘ Spec(k[M])) (Spec(k[G]) ↘ Spec(k[M]))
    refine ⟨?_⟩
    exact exists_addSubgroup_monoidIdeal_eq ‹_› s hsI _

end

end AddMonoidAlgebra

