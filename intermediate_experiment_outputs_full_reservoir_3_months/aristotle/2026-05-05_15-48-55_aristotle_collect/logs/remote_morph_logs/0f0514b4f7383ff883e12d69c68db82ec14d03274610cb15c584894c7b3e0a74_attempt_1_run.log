import Mathlib.Data.List.Basic
import Mathlib.Tactic

/-!
## Quicksort Algorithm (Pivot from Head)

Quicksort is a divide-and-conquer sorting algorithm known for its efficiency. It works by recursively partitioning the list around a chosen element (pivot) and then sorting the sub-lists.

Our implementation of quicksort for lists follows the following steps:

* If the list is empty, return the empty list.
* Otherwise, let `pivot` be the first element (`head`) of the list.
* Let `smaller` be the list of elements smaller (`‚Č§`) than `pivot` and `larger` be the list of elements larger (`>`) than `pivot`.
* Recursively sort `smaller` and `larger` lists and concatenate them with `pivot` in between.

We begin by defining `smaller` and `larger` lists. We define them as abbreviations so that they are automatically unfolded by Lean.
-/

variable {őĪ : Type}[LinearOrder őĪ]

@[grind, simp]
def smaller (pivot : őĪ) (l : List őĪ) : List őĪ :=
  l.filter (fun x => x ‚Č§  pivot)

@[grind, simp]
def larger (pivot : őĪ) (l : List őĪ) : List őĪ :=
  l.filter (fun x => pivot < x)

partial def naiveQuickSort : List őĪ ‚Üí List őĪ
  | [] => []
  | pivot :: l =>
    (naiveQuickSort (smaller pivot l)) ++
    pivot :: (naiveQuickSort (larger pivot l))

def quickSort : List őĪ ‚Üí List őĪ
  | [] => []
  | pivot :: l =>
    have hs : (smaller pivot l).length < (pivot :: l).length := by
      grind
    have hl : (larger pivot l).length < (pivot :: l).length := by
      grind
    (quickSort (smaller pivot l)) ++ pivot :: (quickSort (larger pivot l))
termination_by l => l.length


@[simp, grind .]
theorem quickSort_nil : quickSort ([] : List őĪ) = [] := by
  simp [quickSort]

@[simp, grind .]
theorem quickSort_cons (pivot : őĪ) (l : List őĪ) :
    quickSort (pivot :: l) = (quickSort (smaller pivot l)) ++
    pivot :: (quickSort (larger pivot l)) := by
  simp [quickSort]

@[grind .]
theorem mem_iff_below_or_above_pivot (pivot : őĪ)
  (l : List őĪ)(x : őĪ) :
    x ‚ąą l ‚ÜĒ x ‚ąą smaller pivot l ‚ą® x ‚ąą larger pivot l := by grind

@[grind =_]
theorem mem_iff_mem_quickSort (l: List őĪ)(x : őĪ) :
    x ‚ąą l ‚ÜĒ x ‚ąą quickSort l := by
  cases l with
  | nil => simp
  | cons pivot l =>
    have : (smaller pivot l).length < (pivot :: l).length := by
      grind
    have : (larger pivot l).length < (pivot :: l).length := by
      grind
    have ih‚āĀ := mem_iff_mem_quickSort (smaller pivot l)
    have ih‚āā := mem_iff_mem_quickSort (larger pivot l)
    grind
termination_by l.length

section Count
/-!
### Exercises

Prove that quickSort preserves the count of each element. A useful lemma was not annotated with `grind` so this is done below.
-/
attribute [grind .] List.count_eq_zero_of_not_mem


@[grind .]
theorem count_sum_above_below_pivot (pivot : őĪ)
  (l : List őĪ)(x : őĪ) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  induction l with
  | nil => simp
  | cons h t ih =>
    simp only [smaller, larger] at ih ‚äĘ
    rw [List.filter_cons, List.filter_cons, List.count_cons]
    by_cases hle : (decide (h ‚Č§ pivot)) = true <;> by_cases hlt : (decide (pivot < h)) = true
    ¬∑ simp [decide_eq_true_eq] at hle hlt; exact absurd (lt_of_lt_of_le hlt hle) (lt_irrefl _)
    ¬∑ simp [hle, hlt, List.count_cons]; omega
    ¬∑ simp [hle, hlt, List.count_cons]; omega
    ¬∑ simp_all [decide_eq_true_eq, not_le]

theorem count_eq_count_quickSort (l : List őĪ)
  (x : őĪ) :
    l.count x = (quickSort l).count x := by
  cases l with
  | nil => simp
  | cons pivot l =>
    rw [quickSort_cons, List.count_cons, List.count_append, List.count_cons]
    have hs : (smaller pivot l).length < (pivot :: l).length := by grind
    have hl : (larger pivot l).length < (pivot :: l).length := by grind
    have ih1 := count_eq_count_quickSort (smaller pivot l) x
    have ih2 := count_eq_count_quickSort (larger pivot l) x
    rw [‚Üź ih1, ‚Üź ih2]
    have := count_sum_above_below_pivot pivot l x
    omega
  termination_by l.length
end Count

section Sorted
inductive Sorted : List őĪ ‚Üí Prop
  | nil : Sorted []
  | singleton (x : őĪ) : Sorted [x]
  | step (x y : őĪ) (l : List őĪ) (hxy: x ‚Č§ y)
      (tail_sorted: Sorted (y :: l)) : Sorted (x :: y :: l)

@[grind .]
theorem head_le_of_sorted  (a: őĪ) (l : List őĪ) :
  Sorted (a :: l) ‚Üí ‚ąÄ x ‚ąą l, a ‚Č§ x := by
  intro h
  match h with
  | Sorted.singleton .. => simp
  | Sorted.step .(a) y l hxy tail_sorted =>
    have ih := head_le_of_sorted y l tail_sorted
    grind

@[grind .]
theorem cons_sorted (l : List őĪ) :  Sorted l ‚Üí (a : őĪ) ‚Üí
  (‚ąÄ y ‚ąą l, a ‚Č§ y) ‚Üí Sorted (a :: l)  := by
  intro h‚āĀ a h‚āÄ
  match l with
  | [] =>
    apply Sorted.singleton
  | x :: l' =>
    grind [Sorted.step]

theorem sorted_sandwitch (l‚āĀ : List őĪ) (h‚āĀ : Sorted l‚āĀ)
    (l‚āā : List őĪ) (h‚āā : Sorted l‚āā)
    (bound : őĪ)
    (h_bound‚āĀ : ‚ąÄ x ‚ąą l‚āĀ, x ‚Č§ bound)
    (h_bound‚āā : ‚ąÄ x ‚ąą l‚āā, bound ‚Č§ x) :
    Sorted (l‚āĀ ++ bound :: l‚āā) := by
    induction h‚āĀ with
    | nil => grind
    | singleton x =>
      grind [Sorted.step]
    | step x y l hxy tail_sorted ih =>
      grind [Sorted.step]

theorem quickSort_sorted (l : List őĪ) : Sorted (quickSort l) := by
  cases l with
  | nil =>
    simp [quickSort_nil]
    apply Sorted.nil
  | cons pivot l =>
    rw [quickSort_cons]
    have : (smaller pivot l).length < (pivot :: l).length :=
        by grind
    have : (larger pivot l).length < (pivot :: l).length :=
        by grind
    have h_small :=
      quickSort_sorted (smaller pivot l)
    have h_large :=
      quickSort_sorted (larger pivot l)
    apply sorted_sandwitch <;> grind
termination_by l.length


@[grind .]
def monotone (l : List őĪ) : Prop := ‚ąÄ i j,
  (h‚āĀ: i < j) ‚Üí (h‚āā : j < l.length) ‚Üí
    l[i]' (by grind) ‚Č§ l[j]' (by grind)

theorem monotone_of_sorted (l : List őĪ)
  (h : Sorted l) : monotone l := by
  induction h with
  | nil => grind
  | singleton x =>
    grind
  | step x y l hxy tail_sorted ih =>
    intro i j h‚āĀ h‚āā
    cases i with
    | zero =>
      cases j with
      | zero => contradiction
      | succ j' =>
        trans y <;> grind
    | succ i' =>
      cases j with
      | zero => contradiction
      | succ j' => grind

@[grind .]
theorem tail_monotone_of_monotone {y: őĪ}
  {ys : List őĪ} (h : monotone (y :: ys)) :
  monotone ys := by
  intro i j h‚āĀ h‚āā
  have h‚āĀ' : i + 1 < j + 1 := by
    grind
  have h‚āā' : j + 1 < (ys.length + 1) := by
    grind
  specialize h (i + 1) (j + 1) h‚āĀ' h‚āā'
  grind

theorem sorted_of_monotone (l : List őĪ)
  (h : monotone l) : Sorted l := by
  induction l with
  | nil => apply Sorted.nil
  | cons x xs ih =>
    cases xs with
    | nil => apply Sorted.singleton
    | cons y ys =>
      apply Sorted.step
      ¬∑ apply h 0 1 (by simp) (by simp)
      ¬∑ grind
end Sorted

