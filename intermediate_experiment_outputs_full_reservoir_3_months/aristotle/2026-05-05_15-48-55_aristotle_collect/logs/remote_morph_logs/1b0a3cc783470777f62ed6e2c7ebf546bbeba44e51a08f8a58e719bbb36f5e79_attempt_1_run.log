import FLT.DedekindDomain.FiniteAdeleRing.BaseChange
import FLT.HaarMeasure.HaarChar.FiniteDimensional
import FLT.Mathlib.MeasureTheory.Constructions.BorelSpace.AdicCompletion
import FLT.Mathlib.NumberTheory.NumberField.FiniteAdeleRing
import Mathlib.Algebra.Central.Basic
/-!

# Haar character of the finite adele ring of a number field

We prove the crucial result that left and right multiplication by an element of `D ⊗[K] 𝔸_K^f`
scale Haar measure by the same factor, if D is a finite-dimensional central simple `K`-alegbra.

-/

open NumberField

open scoped TensorProduct

variable (K : Type*) [Field K] [NumberField K]

variable (B : Type*) [Ring B] [Algebra K B] [FiniteDimensional K B]

open scoped TensorProduct

open NumberField MeasureTheory

-- in FLT#823
instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) := by
      refine' ⟨ fun x hx => _ ⟩;
      have h_comm : ∀ (b : B), x * (1 ⊗ₜ[k] b) = (1 ⊗ₜ[k] b) * x := by
        intro b
        have := hx.comm (1 ⊗ₜ[k] b);
        exact this.eq;
      have h_x_in_A_k : x ∈ (Algebra.TensorProduct.map (AlgHom.id k A) (Subalgebra.center k B).val).range := by
        have h_centralizer : Subalgebra.centralizer k (Algebra.TensorProduct.includeRight : B →ₐ[k] A ⊗[k] B).range = (Algebra.TensorProduct.map (AlgHom.id k A) (Subalgebra.center k B).val).range := by
          apply Subalgebra.centralizer_range_includeRight_eq_center_tensorProduct;
        rw [ ← h_centralizer ];
        intro y hy; aesop;
      obtain ⟨ y, rfl ⟩ := h_x_in_A_k;
      refine' TensorProduct.induction_on y _ _ _;
      · exact ⟨ 0, by simp +decide ⟩;
      · rintro a ⟨ b, hb ⟩;
        have hb_k : b ∈ Set.range (algebraMap k B) := by
          aesop;
        obtain ⟨ c, rfl ⟩ := hb_k; use a * algebraMap k A c; simp +decide [ mul_comm ] ;
        simp +decide [ Algebra.algebraMap_eq_smul_one, TensorProduct.smul_tmul' ];
      · rintro x y ⟨ a, ha ⟩ ⟨ b, hb ⟩ ; use a + b; simp +decide [ ha, hb, add_mul, mul_add ] ;
        simp_all +decide [ add_mul, mul_add, TensorProduct.add_tmul ]


-- in FLT#823
instance (v : IsDedekindDomain.HeightOneSpectrum (𝓞 K)) :
    LocallyCompactSpace (v.adicCompletion K) := sorry

-- in FLT#823
instance (k A B : Type*) [Field k] [Ring A] [Ring B] [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] [IsSimpleRing A] [IsSimpleRing B] : IsSimpleRing (B ⊗[k] A) :=
  IsSimpleRing.of_ringEquiv
    (Algebra.TensorProduct.comm k A B).toRingEquiv inferInstance

