module

public import Mathlib.Data.Nat.Choose.Multinomial
public import Mathlib.Probability.IdentDistrib

/-!
# The Marcinkiewicz-Zygmund inequality

This file proves the Marcinkiewicz-Zygmund inequality.

The Marcinkiewicz-Zygmund inequality states that, if `XвӮҒ, ... XвӮҗ вҲҲ L^p` are independent random
variables of mean zero valued in some inner product space, then the `L^p`-norm of `XвӮҒ + ... + XвӮҗ` is
at most `CвӮҡ` times the `L^(p/2)`-norm of `|XвӮҒ|ВІ + ... + |XвӮҗ|ВІ`, where `CвӮҡ` is a constant depending
on `p` alone.

## Notation

Throughout this file, `A ^^ n` denotes `A Г— ... Г— A` (with `n` factors). Formally, this is
`Fintype.piFinset fun _ : Fin n вҶҰ A`.

## TODO

We currently only prove the inequality for `p = 2 * m` an even natural number. The general `p` case
can be obtained from this specific one by nesting of Lp norms.
-/

open Finset Fintype Function Nat MeasureTheory ProbabilityTheory Real
open scoped NNReal ENNReal

variable {О№ О© E : Type*} {A : Finset О№} {m n : в„•} [MeasurableSpace О©] {Ој : Measure О©}
  [IsFiniteMeasure Ој] [mE : MeasurableSpace E] [NormedAddCommGroup E] [InnerProductSpace в„қ E]
  {X : О№ вҶ’ О© вҶ’ E}

local notation:70 A:70 " ^^ " n:71 => Fintype.piFinset fun _ : Fin n вҶҰ A

/-- The constant appearing in the Marcinkiewicz-Zygmund inequality for symmetric random variables.
-/
noncomputable def marcinkiewiczZygmundSymmConst (p : в„қвүҘ0) : в„қ := (p / 2) ^ (p / 2 : в„қ)

/-- The **Marcinkiewicz-Zygmund inequality** for symmetric random variables, with a slightly better
constant than `marcinkiewicz_zygmund`. -/
theorem marcinkiewicz_zygmund_symmetric (iIndepFun_X : iIndepFun X Ој)
    (identDistrib_neg_X : вҲҖ i, IdentDistrib (X i) (-X i) Ој Ој)
    (memLp_X : вҲҖ i вҲҲ A, MemLp (X i) (2 * m) Ој) :
    вҲ« Пү, вҖ–вҲ‘ i вҲҲ A, X i ПүвҖ– ^ (2 * m) вҲӮОј вүӨ
      marcinkiewiczZygmundSymmConst (2 * m) * вҲ« Пү, (вҲ‘ i вҲҲ A, вҖ–X i ПүвҖ– ^ 2) ^ m вҲӮОј := by
  have : DecidableEq О№ := Classical.decEq _
  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I вҲҲ A Г—Лў A ^^ m) :
    Integrable (fun Пү вҶҰ вҲҸ k, вҖ–X (I k).1 ПүвҖ– * вҖ–X (I k).2 ПүвҖ–) Ој := by
    sorry
  have integrable_prod_inner_X I (hI : I вҲҲ A Г—Лў A ^^ m) :
    Integrable (fun Пү вҶҰ вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү)) Ој := sorry
  -- Call a family of indices `iвӮҒ, ..., iвӮҷ, jвӮҒ, ..., jвӮҷ` *even* if each `i вҲҲ A` appears an even
  -- number of times among the `2n` indices.
  let EvenIndex (I : Fin m вҶ’ О№ Г— О№) : Prop :=
    вҲҖ i вҲҲ A, Even (#{k | (I k).1 = i} + #{k | (I k).2 = i})
  -- Now, let the calculation begin...
  calc
    вҲ« Пү, вҖ–вҲ‘ i вҲҲ A, X i ПүвҖ– ^ (2 * m) вҲӮОј
    -- Expand out the power of the sum into a sum over families of indices
    -- `iвӮҒ, ..., iвӮҷ, jвӮҒ, ..., jвӮҷ` of `вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ©`. Push the integral inside the sum.
    _ = вҲ‘ I вҲҲ A Г—Лў A ^^ m, вҲ« Пү, вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј := by
      simp_rw [pow_mul, вҶҗ real_inner_self_eq_norm_sq, sum_inner, inner_sum, вҶҗ sum_product',
        Finset.sum_pow', integral_finset_sum _ integrable_prod_inner_X]
    -- Show that the terms coming from odd families of indices `iвӮҒ, ..., iвӮҷ, jвӮҒ, ..., jвӮҷ` integrate
    -- to zero.
    _ = вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, вҲ« Пү, вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј := by
      rw [Finset.sum_filter_of_ne]
      -- Assume that `I = (iвӮҒ, ..., iвӮҷ, jвӮҒ, ..., jвӮҷ)` is an odd family.
      -- Say `i` appears an odd number of times in it.
      rintro I hI hI' i hi
      contrapose! hI'
      replace hI' : Odd (#{k | (I k).1 = i} + #{k | (I k).2 = i}) := by simpa using hI'
      -- Let `Y` be the family of random variables `X` where `X i` has been replaced by `-X i`.
      let Y : О№ вҶ’ О© вҶ’ E := update X i (-X i)
      -- By the assumption that `X i` is symmetric, we get that `X j` and `Y j` are identically
      -- distributed for all `j`.
      have identDistrib_X_Y j : IdentDistrib (X j) (Y j) Ој Ој := by
        obtain rfl | hji := eq_or_ne j i
        В· simpa [Y] using identDistrib_neg_X _
        В· simpa [Y, hji] using .refl (identDistrib_neg_X _).aemeasurable_fst
      -- To show that `рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ© = 0`, we will show
      -- `рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ© = рқ”ј вҲҸ k, вҹЁY iвӮ–, Y jвӮ–вҹ© = -рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ©`.
      rw [вҶҗ neg_eq_self, вҶҗ integral_neg, eq_comm]
      calc
        -- `рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ© = рқ”ј вҲҸ k, вҹЁY iвӮ–, Y jвӮ–вҹ©` because `рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ©` and
        -- `вҲҸ k, вҹЁY iвӮ–, Y jвӮ–вҹ©` are identically distributed.
        вҲ« Пү, вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј
        _ = вҲ« Пү, вҲҸ k, inner в„қ (Y (I k).1 Пү) (Y (I k).2 Пү) вҲӮОј := by
          refine IdentDistrib.integral_eq ?_
          sorry -- TODO: Upstream result from PFR
        -- `рқ”ј вҲҸ k, вҹЁY iвӮ–, Y jвӮ–вҹ© = -рқ”ј вҲҸ k, вҹЁX iвӮ–, X jвӮ–вҹ©` by the assumption that `i` appears an odd
        -- number of times in `I`.
        _ = вҲ« Пү, -вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј := by
          congr with Пү
          calc
            вҲҸ k, inner в„қ (Y (I k).1 Пү) (Y (I k).2 Пү)
            _ = вҲҸ k, (if (I k).1 = i then -1 else 1) * (if (I k).2 = i then -1 else 1) *
                inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) := by
              congr! with k; split_ifs with hkвӮҒ hkвӮӮ hkвӮӮ <;> simp [hkвӮҒ, hkвӮӮ, Y]
            _ = -вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) := by
              rw [prod_mul_distrib, prod_mul_distrib]
              simp [prod_ite, вҶҗ pow_add, hI']
    -- Upper bound the sum by its absolute value and push the absolute value inside.
    _ вүӨ |вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, вҲ« Пү, вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј| :=
      le_abs_self _
    _ вүӨ вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, |вҲ« Пү, вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү) вҲӮОј| :=
      abs_sum_le_sum_abs ..
    _ вүӨ вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, вҲ« Пү, |вҲҸ k, inner в„қ (X (I k).1 Пү) (X (I k).2 Пү)| вҲӮОј := by
      gcongr with I; exact abs_integral_le_integral_abs
    _ = вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, вҲ« Пү, вҲҸ k, |inner в„қ (X (I k).1 Пү) (X (I k).2 Пү)| вҲӮОј := by
      simp_rw [abs_prod]
    -- Finish pushing the absolute value inside using Cauchy-Schwarz.
    _ вүӨ вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I, вҲ« Пү, вҲҸ k, вҖ–X (I k).1 ПүвҖ– * вҖ–X (I k).2 ПүвҖ– вҲӮОј := by
      gcongr with I hI
      В· simpa [abs_prod] using (integrable_prod_inner_X I <| filter_subset _ _ hI).abs
      В· exact integrable_prod_norm_X I <| filter_subset _ _ hI
      rintro Пү
      dsimp
      gcongr with k
      exact abs_real_inner_le_norm ..
    -- Rewrite the sum of `рқ”ј вҲҸ k, вҖ–X iвӮ– ПүвҖ– * вҖ–X jвӮ– ПүвҖ–` over even families of indices
    -- `iвӮҒ, ..., iвӮҷ, jвӮҒ, ..., jвӮҷ` into the sum over `wвӮҒ + ... + wвӮҗ = m` of
    -- `(2m choose 2wвӮҒ, ..., 2wвӮҗ) * рқ”ј вҲҸ i, вҖ–X iвҖ– ^ wбөў`.
    _ = вҲ‘ I вҲҲ A Г—Лў A ^^ m with EvenIndex I,
          вҲ« Пү, вҲҸ i вҲҲ A, вҖ–X i ПүвҖ– ^ (#{k | (I k).1 = i} + #{k | (I k).2 = i}) вҲӮОј := by
      congr! with I hI Пү
      simp only [mem_filter, mem_piFinset, mem_product, forall_and] at hI
      simp_rw [pow_add, prod_mul_distrib, вҶҗ prod_const]
      rw [prod_fiberwise_of_maps_to', prod_fiberwise_of_maps_to']
      В· simpa using hI.1.2
      В· simpa using hI.1.1
    _ = вҲ‘ w вҲҲ piAntidiag A (2 * m) with вҲҖ i вҲҲ A, 2 вҲЈ w i,
          multinomial A w * вҲ« Пү, вҲҸ i вҲҲ A, вҖ–X i ПүвҖ– ^ w i вҲӮОј := by
      sorry
    _ = вҲ‘ w вҲҲ (piAntidiag A m).map
          вҹЁ(2 вҖў В·), fun _ _ h вҶҰ funext fun i вҶҰ mul_right_injectiveвӮҖ two_ne_zero (congr_fun h i)вҹ©,
        multinomial A w * вҲ« Пү, вҲҸ i вҲҲ A, вҖ–X i ПүвҖ– ^ w i вҲӮОј := by
      rw [map_nsmul_piAntidiag _ _ two_ne_zero]
    _ = вҲ‘ w вҲҲ piAntidiag A m, multinomial A (2 вҖў w) * вҲ« Пү, вҲҸ i вҲҲ A, вҖ–X i ПүвҖ– ^ (2 * w i) вҲӮОј := by
      simp
    -- Use the fact that `(2m choose 2wвӮҒ, ..., 2wвӮҗ) вүӨ m ^ m * (m choose wвӮҒ, ..., wвӮҗ)`.
    _ вүӨ вҲ‘ w вҲҲ piAntidiag A m, marcinkiewiczZygmundSymmConst (2 * m) * multinomial A w *
          вҲ« Пү, вҲҸ i вҲҲ A, вҖ–X i ПүвҖ– ^ (2 * w i) вҲӮОј := by
      gcongr with w hw
      calc
        (multinomial A (2 вҖў w) : в„қ)
        _ вүӨ ((вҲ‘ i вҲҲ A, w i) ^ вҲ‘ i вҲҲ A, w i) * multinomial A w :=
          mod_cast multinomial_two_mul_le_mul_multinomial
        _ = marcinkiewiczZygmundSymmConst (2 * m) * multinomial A w := by
          simp [(mem_piAntidiag.1 hw).1, marcinkiewiczZygmundSymmConst]
    -- Put the sum back together.
    _ = marcinkiewiczZygmundSymmConst (2 * m) * вҲ« Пү, (вҲ‘ i вҲҲ A, вҖ–X i ПүвҖ– ^ 2) ^ m вҲӮОј := by
      simp_rw [sum_pow_eq_sum_piAntidiag, вҶҗ pow_mul, вҶҗ integral_const_mul, mul_sum, вҶҗ mul_assoc]
      rw [integral_finset_sum]
      rintro w hw
      exact .const_mul sorry _

/-- The constant appearing in the Marcinkiewicz-Zygmund inequality for random variables with zero
mean. -/
noncomputable def marcinkiewiczZygmundConst (p : в„қвүҘ0) : в„қ :=
  2 ^ (p / 2 : в„қ) * marcinkiewiczZygmundSymmConst p

/-- The **Marcinkiewicz-Zygmund inequality** for random variables with zero mean.

For symmetric random variables, `marcinkiewicz_zygmund` provides a slightly better constant. -/
theorem marcinkiewicz_zygmund (iIndepFun_X : iIndepFun X Ој)
    (integral_X : вҲҖ i, вҲ« Пү, X i Пү вҲӮОј = 0)
    (memLp_X : вҲҖ i вҲҲ A, MemLp (X i) (2 * m) Ој) :
    вҲ« Пү, вҖ–вҲ‘ i вҲҲ A, X i ПүвҖ– ^ (2 * m) вҲӮОј вүӨ
      marcinkiewiczZygmundConst (2 * m) * вҲ« Пү, (вҲ‘ i вҲҲ A, вҖ–X i ПүвҖ– ^ 2) ^ m вҲӮОј := by
  let XвӮҒ i : О© Г— О© вҶ’ E := X i вҲҳ Prod.fst
  let XвӮӮ i : О© Г— О© вҶ’ E := X i вҲҳ Prod.snd
  let X' i : О© Г— О© вҶ’ E := XвӮҒ i - XвӮӮ i
  have : DecidableEq О№ := Classical.decEq _
