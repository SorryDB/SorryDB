module

public import Mathlib
public import SpectralThm.RieszMarkovKakutani.Complex
public import SpectralThm.Resolutions
-- public import SpectralThm.WStarAlgebra.BorelFunctionalCalculus

/-!
# The Spectral Theorem

-/

@[expose] public section

open InnerProductSpace ContinuousLinearMap ZeroAtInfty ZeroAtInftyContinuousMap MeasureTheory

noncomputable section

variable {H : Type*} [NormedAddCommGroup H] [InnerProductSpace ‚Ąā H] [CompleteSpace H]
  {a : H ‚ÜíL[‚Ąā] H} (ha : IsSelfAdjoint a)

variable (f : C((spectrum ‚Ąā a), ‚Ąā))

/-- For `x y : H`, consider `b => ‚ü™x, b y‚üę_‚Ąā` as a bounded linear functional in `b`. -/
def toLinearFunctional (x y : H) : (H ‚ÜíL[‚Ąā] H) ‚ÜíL[‚Ąā] ‚Ąā
    := compSL (H ‚ÜíL[‚Ąā] H) _ _ _ _ (innerSL ‚Ąā x) (apply' H _ y)

@[simp]
lemma toLinearFunctional_apply (x y : H) {b : H ‚ÜíL[‚Ąā] H}:
    toLinearFunctional x y b = ‚ü™x, (b y)‚üę_‚Ąā := rfl

/-- The linear functional `b => ‚ü™x, b y‚üę_‚Ąā` is bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`. -/
lemma toLinearFunctional_bounded (x y : H) : ‚ÄĖtoLinearFunctional x y‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
  grw [ContinuousLinearMap.opNorm_le_bound]
  . positivity
  . intro a
    simp only [toLinearFunctional_apply]
    grw [norm_inner_le_norm, ContinuousLinearMap.le_opNorm]
    apply le_of_eq
    ring

/-- Let `a` a normal bounded operator. By the continuous functional calculus, there is an injective
homomorphism from `C((spectrum ‚Ąā a), ‚Ąā)` to  `H ‚ÜíL[‚Ąā] H`, informally denoted by `f => f(a)`. This
definition just makes it a continuous linear map.
cf. Rudin "Functional Analysis" Theorem 11.18, the proof of Theorem 12.23, first paragraph.
-/
def cfcCLM : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíL[‚Ąā] H ‚ÜíL[‚Ąā] H
    := ((cfcHom ha.isStarNormal : C((spectrum ‚Ąā a), ‚Ąā) ‚Üí‚čÜ‚āź H ‚ÜíL[‚Ąā] H).toLinearMap).mkContinuous 1
        ( by simp only [AlgHom.toLinearMap_apply, StarAlgHom.coe_toAlgHom, one_mul];
              exact fun f => le_of_eq (norm_cfcHom a f))

/-- The same map `f => f(a)` as a continuous algebra homomorphism.
-/
def cfcCAH : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíA[‚Ąā] H ‚ÜíL[‚Ąā] H
    := ContinuousAlgHom.mk (cfcHom ha.isStarNormal : C((spectrum ‚Ąā a), ‚Ąā) ‚Üí‚čÜ‚āź H ‚ÜíL[‚Ąā] H).toAlgHom
        (by apply @continuous_of_linear_of_bound _ _ _ _ _ _ _ _ _ (cfcHom ha.isStarNormal).toAlgHom.map_add'
              (cfcHom ha.isStarNormal).toLinearMap.map_smul' 1
            simp only [AlgHom.toRingHom_eq_coe, RingHom.toMonoidHom_eq_coe,
              AlgHom.toRingHom_toMonoidHom, OneHom.toFun_eq_coe, MonoidHom.toOneHom_coe,
              MonoidHom.coe_coe, StarAlgHom.coe_toAlgHom, one_mul]
            exact fun f => le_of_eq (norm_cfcHom a f))

@[simp]
lemma cfcCLM_apply (f : C((spectrum ‚Ąā a), ‚Ąā)) : cfcCLM ha f = cfcHom ha.isStarNormal f := rfl

/-- The composition of the linear functional and the continuous functional,
`f => ‚ü™x, f(a) y‚üę_‚Ąā` as a continuous linear functional. -/
def cfc_toLinearFunctional (x y : H) : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíL[‚Ąā] ‚Ąā
    := compSL C(spectrum ‚Ąā a, ‚Ąā) _ _ _ _ (toLinearFunctional x y) (cfcCLM ha)

@[simp]
lemma cfc_toLinearFunctional_apply (f : C((spectrum ‚Ąā a), ‚Ąā)) (x y : H) :
    cfc_toLinearFunctional ha x y f = ‚ü™x, (cfcHom ha.isStarNormal f y)‚üę_‚Ąā := rfl

/-- For each pair `x y : H`, the linear map `f => ‚ü™x, f(a) y‚üę_‚Ąā`has norm `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`.
This follows from the bound `toLinearFunctional_bounded` and the fact that
`f => f(a)` is an isometry, `norm_cfcHom`. -/
lemma cfc_toLinearFunctional_bound (x y : H) : ‚ÄĖcfc_toLinearFunctional ha x y‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
  apply ContinuousLinearMap.opNorm_le_bound
  ¬∑ positivity
  ¬∑ intro f
    simp only [cfc_toLinearFunctional_apply]
    calc
      ‚ÄĖ‚ü™x, ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y‚üę_‚Ąā‚ÄĖ
        ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y‚ÄĖ := norm_inner_le_norm x
          (((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y)
      _ ‚Č§ ‚ÄĖx‚ÄĖ * (‚ÄĖ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‚ÄĖ * ‚ÄĖy‚ÄĖ) :=
        mul_le_mul_of_nonneg_left (le_opNorm ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y)
          (norm_nonneg x)
      _ = ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‚ÄĖ := by ring
      _ = ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ := by rw [norm_cfcHom a f]

/-- For each pair `x y : H`, one obtains a complex measure `E_{a, x ,y}` from the continuous linear
functional `f => ‚ü™x, f(a) y‚üę_‚Ąā` by the Riesz-Markov-Kakutani theorem.
cf. Rudin "Functiona Analysis" the proof of Theorem 12.22, above formula (5).
-/
def cfc_toComplexMeasure (x y : H) := ComplexRMK.rieszMeasure (compSL C‚āÄ((spectrum ‚Ąā a), ‚Ąā)
  C((spectrum ‚Ąā a), ‚Ąā) ‚Ąā _ _ (cfc_toLinearFunctional ha x y)
  (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE
  (spectrum ‚Ąā a) ‚Ąā ‚Ąā _ _ _ _ _ _).symm.toContinuousLinearMap)

/-- The integral of `f` against `E_{a, x,y}` is bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ`. -/
lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ‚Ąā a), ‚Ąā)) :
    ‚ÄĖ(cfc_toComplexMeasure ha x y).integral f‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ := by
  sorry

/-- The complex measure `E_{a, x,y}` has the total variation bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`.
Rudin "Real and complex analysis" Theorem 6.19 (2), combined with the bound by
`cfc_toLinearFunctional_bound`.-/
lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖx‚ÄĖ‚āĎ * ‚ÄĖy‚ÄĖ‚āĎ := by
  sorry

/-- The integral of a Borel function `f` against `E_{a, x ,y}` is bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`.
We should have an analogue of `MeasureTheory.lintegral_le_const` for `ComplexMeasure.integral`.
-/
lemma bfc_bounded (x y : H) {C : ‚ĄĚ} {f : (spectrum ‚Ąā a) ‚Üí ‚Ąā}  (hf_bounded : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C)
    (hX : @Measurable _ _ (borel (spectrum ‚Ąā a)) _ f) :
    ‚ÄĖ(cfc_toComplexMeasure ha x y).integral f‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * C := by
  sorry

/-- The linear functional from bounded Borel functions `f` to `‚ąę f z ‚ąāE_{a, x, y} z` as a bounded
linear functional (bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`). All the remaining properties should follow from
the definition and `bfc_bounded`. -/
def toBoundedBilin {C : ‚ĄĚ} (f : (spectrum ‚Ąā a) ‚Üí ‚Ąā)
  --(hf_bounded : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C) (hf_measurable : @Measurable _ _ (borel (spectrum ‚Ąā a)) _ f)
  : H ‚ÜíL‚čÜ[‚Ąā] H ‚ÜíL[‚Ąā] ‚Ąā where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := sorry
                map_smul' := sorry
                cont := sorry }
  map_add' := sorry
  map_smul' := sorry
  cont := sorry

/-- The integral of an indicator function against a complex measure equals the measure of the set. -/
lemma ComplexMeasure.integral_indicator_one {őĪ : Type*} [MeasurableSpace őĪ]
    (őľ : ComplexMeasure őĪ) (s : Set őĪ) (hs : MeasurableSet s) :
    őľ.integral (s.indicator (1 : őĪ ‚Üí ‚Ąā)) = őľ s := by
  sorry

set_option maxHeartbeats 800000 in
lemma toResolutionOfIdentity_m_iUnion' (x y : H) (w : ‚Ąē ‚Üí Set (spectrum ‚Ąā a))
    (hw : ‚ąÄ (i : ‚Ąē), MeasurableSet (w i))
    (hd : Pairwise (Function.onFun Disjoint w)) :
    HasSum
      (fun i =>
        ‚ü™x, (continuousLinearMapOfBilin (@toBoundedBilin _ _ _ _ _ ha 1 ((w i).indicator 1))) y‚üę_‚Ąā)
      (‚ü™x, (continuousLinearMapOfBilin (@toBoundedBilin _ _ _ _ _ ha 1 ((‚čÉ i, w i).indicator 1))) y‚üę_‚Ąā) := by
  -- Step 1: rewrite inner products using continuousLinearMapOfBilin_apply and inner_conj_symm
  have key : ‚ąÄ (s : Set (spectrum ‚Ąā a)),
    @inner ‚Ąā H _ x ((continuousLinearMapOfBilin (@toBoundedBilin _ _ _ _ _ ha 1 (s.indicator 1))) y) =
    starRingEnd ‚Ąā ((@toBoundedBilin _ _ _ _ _ ha 1 (s.indicator 1)) y x) := by
    intro s
    rw [‚Üź inner_conj_symm, continuousLinearMapOfBilin_apply]
  simp_rw [key]
  -- Step 2: reduce to HasSum for the bilinear form values, then pull out conj
  have h : HasSum (fun i => ((@toBoundedBilin _ _ _ _ _ ha 1 ((w i).indicator 1)) y) x)
      (((@toBoundedBilin _ _ _ _ _ ha 1 ((‚čÉ i, w i).indicator 1)) y) x) := by
    -- By definition, each term is (cfc_toComplexMeasure ha y x).integral ((w i).indicator 1)
    change HasSum
      (fun i => (cfc_toComplexMeasure ha y x).integral ((w i).indicator 1))
      ((cfc_toComplexMeasure ha y x).integral ((‚čÉ i, w i).indicator 1))
    -- Using integral_indicator_one, these equal the measure values
    set őľ := cfc_toComplexMeasure ha y x with hőľ
    have hfun : (fun i => őľ.integral ((w i).indicator 1)) = (fun i => őľ (w i)) :=
      funext (fun i => ComplexMeasure.integral_indicator_one őľ _ (hw i))
    have hlim : őľ.integral ((‚čÉ i, w i).indicator 1) = őľ (‚čÉ i, w i) :=
      ComplexMeasure.integral_indicator_one őľ _ (MeasurableSet.iUnion hw)
    rw [hfun, hlim]
    -- Now it's just m_iUnion' of the complex measure
    exact őľ.m_iUnion' hw hd
  exact h.map (starRingEnd ‚Ąā) Complex.continuous_conj

/-- For each indicator function `Ōá s` of a set `s`, the bounded sesquilinear form
`x, y => ‚ąę f z ‚ąāE_{a, x ,y} z` gives an orthogonal projection `E_{a} s`. Define the map
`s => E_{a} s` as a resolution of identity`.
Probably `s` should be restricted to measurable set (otherwise defined to be `0`) to assure
`not_measurable'`.
cf. Rudin "Functional Analysis" Theorem 12.22, the definition (9) and later.
-/
def toResolutionOfIdentity : ResolutionOfIdentity (spectrum ‚Ąā a) H where
  measureOf' s := InnerProductSpace.continuousLinearMapOfBilin
    (@toBoundedBilin _ _ _ _ _ ha 1 (Set.indicator s (1 : (spectrum ‚Ąā a) ‚Üí ‚Ąā)))
  isOrthogonalProjection' := sorry
  empty' := by
    ext
    simp [continuousLinearMapOfBilin, toBoundedBilin, cfc_toComplexMeasure, ComplexMeasure.integral]
    rfl
  not_measurable' := sorry
  m_Union' := sorry
  m_Inter' := sorry
  m_iUnion' := fun hw hd => toResolutionOfIdentity_m_iUnion' ha _ _ _ hw hd

/-- From a resolution of identity `E_{a}` and for each `x y : H`, the map `s => ‚ü™x, E_{a} s y‚üę_‚Ąā`
gives complex measure. The integraion of the identity map against it gives back the expectation
value `‚ü™x, a y‚üę_‚Ąā`. Check that
`‚ü™x, cfcHom ha f y‚üę_‚Ąā = (toComplexMeasure (toResolutionOfIdentity ha) x y).integral f` for step
functions `f`, and infer that it holds for all Borel/continuous functions. Apply it to the identity
map.
cf. Rudin "Functional Analysis" Theorem 12.21, Theorem 12.22.
-/
theorem SpectralDecomposition (x y : H) :
    ‚ü™x, a y‚üę_‚Ąā = (toComplexMeasure (toResolutionOfIdentity ha) x y).integral
    (Function.Embedding.subtype (spectrum ‚Ąā a)) := by
  sorry

