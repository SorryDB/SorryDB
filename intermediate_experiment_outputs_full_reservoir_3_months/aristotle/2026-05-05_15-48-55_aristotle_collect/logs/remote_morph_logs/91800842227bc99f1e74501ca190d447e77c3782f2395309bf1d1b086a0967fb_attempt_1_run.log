import Clap.Circuit
import Clap.Simulation
import Clap.Id
import Mathlib

namespace Clap

/-
  This file introduces an optimization to remove duplicate checks.
  The current version eliminates any `eq0` with an expression that has
  already been met before. The same optimization should be applicable
  to boolean checks, limb checks and other lookup arguments with minor
  modifications.

  Dedup is extremely valuable as it allows to write composable
  circuits with many redundant checks without having to pay the price
  in term of constraints.
-/

namespace Dedup

variable {F : Type}
variable [Field F] [DecidableEq F]

def to_nat {var} (e:Exp F (Nat × var)) : Exp F Nat :=
  match e with
  | .v (v,_) => .v v
  | .c f => .c f
  | .add l r => to_nat l + to_nat r
  | .mul l r => to_nat l * to_nat r
  | .sub l r => to_nat l - to_nat r

def to_var {var} (e:Exp F (Nat × var)) : Exp F var :=
  match e with
  | .v (_,v) => .v v
  | .c f => .c f
  | .add l r => to_var l + to_var r
  | .mul l r => to_var l * to_var r
  | .sub l r => to_var l - to_var r

def beq : (e1 e2 : Exp F Nat) -> Bool
  | .v n1, .v n2
  | .c n1, .c n2 => n1 = n2
  | .add ll lr, .add rl rr => beq ll rl && beq lr rr
  | .mul ll lr, .mul rl rr => beq ll rl && beq lr rr
  | .sub ll lr, .sub rl rr => beq ll rl && beq lr rr
  | _,_ => false

def dedup_ {var} (c:Circuit F (Nat × var)) (n:Nat) (set: List (Exp F Nat)) : Circuit F var :=
  match c with
  | .nil => .nil
  | .eq0 e c =>
    if (to_nat e) ∈ set
    then dedup_ c n set
    else .eq0 (to_var e) (dedup_ c n ((to_nat e)::set))
  | .lam k => .lam (fun x => dedup_ (k (n,x)) (n+1) set)
  | .share e k => .share (to_var e) (fun x => dedup_ (k (n,x)) (n+1) set)
  | .is_zero e k => .is_zero (to_var e) (fun x => dedup_ (k (n,x)) (n+1) set)

def dedup {var} (c:Circuit F (Nat × var)) : Circuit F var := dedup_ c 0 []

def dedup' (c:Circuit' F) : Circuit' F := fun var => dedup (c (Nat × var))

namespace Test

abbrev F7 := Clap.F7.F

def a        : Circuit' F7 := fun _ => .lam (fun x => .eq0 (.v x + .c 1) (.eq0 (.v x + .c 2) (.eq0 (.v x + .c 1) .nil )))
def expected : Circuit' F7 := fun _ => .lam (fun x => .eq0 (.v x + .c 1) (.eq0 (.v x + .c 2) .nil ))

#guard s!"{dedup' a Nat}" = s!"{expected Nat}"

end Test

open Id

-- Nat variables appearing in an Exp F Nat
def vars_of : Exp F Nat → List Nat
  | .v n => [n]
  | .c _ => []
  | .add l r => vars_of l ++ vars_of r
  | .mul l r => vars_of l ++ vars_of r
  | .sub l r => vars_of l ++ vars_of r

/-
PROBLEM
Helper: to_var preserves expression semantics under wf_e

PROVIDED SOLUTION
By induction on el (analogous to unwrap_e_sem_pre in Clap.Id).
- Case v: wf_e gives {l:=x, r:=(n,f)} ∈ G. to_var (.v (n,f)) = .v f. Need x = f, which comes from Forall condition (entry.l = entry.r.snd).
- Case c: to_var (.c c) = .c c. Trivial.
- Case add/mul/sub: Use Exp.add_congr/mul_congr/sub_congr with IH.
-/
lemma to_var_sem_pre : ∀ (el : Exp F F) (er : Exp F (ℕ × F)) G,
  wf_e G el er →
  List.Forall (fun (entry : Entry F (ℕ × F)) => entry.l = entry.r.snd) G →
  el ≈ Dedup.to_var er := by
    introv h1 h2;
    induction' h1 with er hl hr ih1 ih2;
    · rw [ List.forall_iff_forall_mem ] at h2; specialize h2 { l := er, r := hl } hr; aesop;
    · rfl;
    · exact Exp.add_congr ‹_› ‹_›;
    · exact Exp.mul_congr ‹_› ‹_›;
    · apply Exp.sub_congr; assumption; assumption

/-
PROBLEM
Helper: two expressions with the same to_nat evaluate equally under injective G

PROVIDED SOLUTION
By induction on wf_e G el er, with wf_e G el' er' and to_nat er = to_nat er' as hypotheses.
- Case v: er = .v (m,f) so to_nat er = .v m. Since to_nat er' = .v m, er' must be .v (m,f') for some f'. So wf_e G el' (.v (m,f')) is wf_e.v giving {l:=el'_val, r:=(m,f')} ∈ G. Similarly {l:=el_val, r:=(m,f)} ∈ G. By G injectivity (same fst = m), el_val = el'_val. So el.eval = el_val = el'_val = el'.eval.
- Case c: er = .c c, to_nat er = .c c, to_nat er' = .c c so er' = .c c. el = .c c, el' = .c c. Evals are equal.
- Case add: er = .add l r, to_nat er = .add (to_nat l) (to_nat r). From to_nat er = to_nat er', er' = .add l' r' with to_nat l = to_nat l' and to_nat r = to_nat r'. Cases on wf_e for er' (must be wf_e.add). Use IH on both parts.
- Similarly for mul, sub.
Key: use `cases` on wf_e G el' er' and the injectivity of Exp constructors from to_nat er = to_nat er' to determine the structure of er'.
-/
lemma wf_e_eval_eq_of_to_nat_eq :
  ∀ G (el el' : Exp F F) (er er' : Exp F (ℕ × F)),
  wf_e G el er → wf_e G el' er' → to_nat er = to_nat er' →
  (∀ (e1 : Entry F (ℕ × F)), e1 ∈ G → ∀ (e2 : Entry F (ℕ × F)),
    e2 ∈ G → e1.r.fst = e2.r.fst → e1.l = e2.l) →
  el.eval = el'.eval := by
    intros G el el' er er' h1 h2 h3 h4;
    induction' h1 with el er h1 ih generalizing el' er';
    · cases' h2 with er' h2 h2';
      · simp [to_nat] at h3; simp [Exp.eval]; exact h4 _ h1 _ h2' h3;
      · cases h3;
      · cases h3;
      · cases h3;
      · cases h3;
    · cases h2;
      · cases h3;
      · cases h3 ; rfl;
      · cases h3;
      · cases h3;
      · cases h3;
    · cases h2;
      · cases h3;
      · cases h3;
      · rename_i e1 e2 e1' e2' h1 h2 h3 h4 h5 h6;
        rename_i e1' e2';
        rename_i h7 h8;
        rename_i h9 h10;
        have h11 : to_nat h10 = to_nat e2' := by
          injection h3
        have h12 : to_nat h7 = to_nat h4 := by
          injection h3;
        exact congr_arg₂ ( · + · ) ( e1' _ _ h5 h11 ) ( h8 _ _ h6 h12 );
      · cases h3;
      · cases h3;
    · cases h2 <;> simp_all +decide [ Exp.eval ];
      · cases h3;
      · cases h3;
      · cases h3;
      · rename_i e1 e2 e1' e2' h1 h2 h3 h4;
        rename_i h5 h6;
        rename_i h7 h8;
        rename_i h9 h10;
        rw [ e1 _ _ h6, e2 _ _ h4 ];
        · injection h3;
        · injection h3;
      · cases h3;
    · cases h2;
      · cases h3;
      · cases h3;
      · cases h3;
      · cases h3;
      · rename_i e1 e2 e1' e2' h1 h2 ih1 ih2;
        rename_i e3 e4 e3' e4' h3 h4 ih3 ih4;
        simp_all +decide [ Exp.eval ];
        rw [ e1 _ _ ih1, e2 _ _ ih2 ];
        · injection h3;
        · injection h3

/-
PROBLEM
Helper: nat variables in wf_e expressions are bounded by G freshness

PROVIDED SOLUTION
By induction on wf_e G el er.
- Case v: wf_e.v G x (m,f) hmem gives {l:=x, r:=(m,f)} ∈ G. vars_of (to_nat (.v (m,f))) = vars_of (.v m) = [m]. Need m < n, which follows from the freshness hypothesis applied to the entry.
- Case c: vars_of (to_nat (.c c)) = vars_of (.c c) = []. Vacuously true.
- Case add/mul/sub: vars_of (to_nat (.add l r)) = vars_of (to_nat l) ++ vars_of (to_nat r). Use List.mem_append and IH on both sides.
-/
lemma wf_e_vars_bounded :
  ∀ G (el : Exp F F) (er : Exp F (ℕ × F)) n,
  wf_e G el er → (∀ (entry : Entry F (ℕ × F)), entry ∈ G → entry.r.fst < n) →
  ∀ m ∈ vars_of (to_nat er), m < n := by
    intro G el er n h₁ h₂ m hm;
    induction' h₁ with r rfl r' hr h₁ h₂ h₁ h₂ h₃ h₄ h₅ h₆;
    · convert h₂ _ r';
      cases hm ; aesop;
      contradiction;
    · cases hm;
    · exact List.mem_append.mp hm |> Or.rec ( fun h => h₅ h ) fun h => h₆ h;
    · cases List.mem_append.mp hm <;> aesop;
    · exact Classical.not_not.1 fun h => h ( List.mem_append.1 hm |> Or.rec ( fun h => by aesop ) fun h => by aesop )

/-
PROBLEM
Helper: wf_e weakening - remove irrelevant head entry from context

PROVIDED SOLUTION
By induction on wf_e (new_entry :: G) el er.
- Case v: wf_e.v gives {l:=x, r:=(m,f)} ∈ (new_entry :: G). vars_of (to_nat (.v (m,f))) = [m], so m ≠ new_entry.r.fst by hypothesis. Since {l:=x, r:=(m,f)} ∈ new_entry :: G and (m,f) ≠ new_entry.r (different fst), we get {l:=x, r:=(m,f)} ∈ G. Apply wf_e.v.
- Case c: Directly apply wf_e.c.
- Case add/mul/sub: The vars of to_nat (.add l r) = vars_of(to_nat l) ++ vars_of(to_nat r). By hypothesis, all vars in both sides are ≠ new_entry.r.fst. Apply IH on both sides and use wf_e.add/mul/sub.
-/
lemma wf_e_weaken :
  ∀ G (new_entry : Entry F (ℕ × F)) (el : Exp F F) (er : Exp F (ℕ × F)),
  wf_e (new_entry :: G) el er →
  (∀ m ∈ vars_of (to_nat er), m ≠ new_entry.r.fst) →
  wf_e G el er := by
    intro G new_entry el er h1 h2;
    induction' h1 with h1 h2 h3 h4 h5;
    · cases h3 <;> simp_all +decide [ List.mem_cons ];
      · exact False.elim <| h2 _ ( List.mem_singleton_self _ ) rfl;
      · exact?;
    · constructor;
    · apply_rules [ wf_e.add, h5, ‹_› ];
      · intro m hm; specialize h2 m; simp_all +decide [ vars_of ] ;
        exact h2 ( by rw [ show to_nat ( _ |> Exp.add <| _ ) = to_nat _ + to_nat _ from rfl ] ; exact List.mem_append_left _ hm );
      · exact ‹ ( ∀ m ∈ vars_of ( to_nat _ ), m ≠ new_entry.r.1 ) → wf_e G _ _ › ( fun m hm => h2 m <| by
          exact List.mem_append_right _ hm );
    · apply_rules [ wf_e.mul ];
      · intro m hm; specialize h2 m; simp_all +decide [ vars_of ] ;
        exact h2 ( List.mem_append_left _ hm );
      · exact fun m hm => h2 m <| List.mem_append_right _ hm;
    · rename_i e1 e2 e1' e2' h1 h2 ih1 ih2;
      exact wf_e.sub _ _ _ _ _ ( ih1 fun m hm => h2 m <| by
        exact List.mem_append_left _ hm ) ( ih2 fun m hm => h2 m <| by
        exact List.mem_append_right _ hm )

-- G-extension invariant lemmas for dedup_sem_gen
omit [Field F] [DecidableEq F] in
private lemma extend_eq (G : List (Entry F (ℕ × F))) (n : ℕ) (x : F)
    (h_eq : ∀ entry ∈ G, (entry : Entry F (ℕ × F)).l = entry.r.snd) :
    ∀ entry ∈ ({l := x, r := (n, x)} :: G), (entry : Entry F (ℕ × F)).l = entry.r.snd := by
  intro entry hmem
  rcases List.mem_cons.mp hmem with rfl | h
  · rfl
  · exact h_eq entry h

omit [Field F] [DecidableEq F] in
private lemma extend_fresh (G : List (Entry F (ℕ × F))) (n : ℕ) (x : F)
    (h_fresh : ∀ entry ∈ G, (entry : Entry F (ℕ × F)).r.fst < n) :
    ∀ entry ∈ ({l := x, r := (n, x)} :: G), (entry : Entry F (ℕ × F)).r.fst < n + 1 := by
  intro entry hmem
  rcases List.mem_cons.mp hmem with rfl | h
  · exact Nat.lt_succ_of_le (Nat.le_refl n)
  · exact Nat.lt_succ_of_lt (h_fresh entry h)

/-
PROVIDED SOLUTION
Case split on membership of e1 and e2 in the cons list. If both in the head: e1.l = e2.l because both are x. If one in head (tag n) and one in tail (tag < n by h_fresh): the tags can't be equal, contradiction. If both in tail: use h_inj.
-/
omit [Field F] [DecidableEq F] in
private lemma extend_inj (G : List (Entry F (ℕ × F))) (n : ℕ) (x : F)
    (h_fresh : ∀ entry ∈ G, (entry : Entry F (ℕ × F)).r.fst < n)
    (h_inj : ∀ e1 ∈ G, ∀ e2 ∈ G, (e1 : Entry F (ℕ × F)).r.fst = e2.r.fst → e1.l = e2.l) :
    ∀ e1 ∈ ({l := x, r := (n, x)} :: G), ∀ e2 ∈ ({l := x, r := (n, x)} :: G),
    (e1 : Entry F (ℕ × F)).r.fst = e2.r.fst → e1.l = e2.l := by
      grind

private lemma extend_sv (G : List (Entry F (ℕ × F))) (n : ℕ) (x : F)
    (set : List (Exp F ℕ))
    (h_sv : ∀ t ∈ set, ∀ (el : Exp F F) (er : Exp F (ℕ × F)),
      wf_e G el er → to_nat er = t → el.eval = 0)
    (h_sf : ∀ t ∈ set, ∀ m ∈ vars_of t, m < n) :
    ∀ t ∈ set, ∀ (el : Exp F F) (er : Exp F (ℕ × F)),
    wf_e ({l := x, r := (n, x)} :: G) el er → to_nat er = t → el.eval = 0 := by
  intro t ht el' er' hwf_e' htn
  exact h_sv t ht el' er' (wf_e_weaken _ _ _ _ hwf_e'
    (fun m hm => by have := h_sf t ht m (htn ▸ hm); show m ≠ n; omega)) htn

omit [Field F] [DecidableEq F] in
private lemma extend_sf (_G : List (Entry F (ℕ × F))) (n : ℕ)
    (set : List (Exp F ℕ))
    (h_sf : ∀ t ∈ set, ∀ m ∈ vars_of t, m < n) :
    ∀ t ∈ set, ∀ m ∈ vars_of t, m < n + 1 := by
  intro t ht m hm; exact Nat.lt_succ_of_lt (h_sf t ht m hm)

-- Generalized dedup correctness theorem
theorem dedup_sem_gen :
  ∀ (cl : Circuit F F) (cr : Circuit F (ℕ × F)) G,
  wf G cl cr →
  ∀ n set,
  (∀ (entry : Entry F (ℕ × F)), entry ∈ G → entry.l = entry.r.snd) →
  (∀ (entry : Entry F (ℕ × F)), entry ∈ G → entry.r.fst < n) →
  (∀ (e1 : Entry F (ℕ × F)), e1 ∈ G → ∀ (e2 : Entry F (ℕ × F)),
    e2 ∈ G → e1.r.fst = e2.r.fst → e1.l = e2.l) →
  (∀ t ∈ set, ∀ (el : Exp F F) (er : Exp F (ℕ × F)),
    wf_e G el er → to_nat er = t → el.eval = 0) →
  (∀ t ∈ set, ∀ m ∈ vars_of t, m < n) →
  cl ≈ dedup_ cr n set := by
  intro cl cr G hwf
  induction hwf with
  | nil => intro n set _ _ _ _ _; rfl
  | @eq0 G el er cl cr hwf_e hwf_cl ih =>
    intro n set h_eq h_fresh h_inj h_sv h_sf
    change (Circuit.eq0 el cl).eval = (dedup_ (Circuit.eq0 er cr) n set).eval
    simp only [dedup_]
    split_ifs with hmem
    · -- to_nat er ∈ set: the eq0 check is redundant
      have h0 : el.eval = 0 := h_sv _ hmem _ _ hwf_e rfl
      rw [Circuit.eval_eq0, if_pos h0]
      exact ih n set h_eq h_fresh h_inj h_sv h_sf
    · -- to_nat er ∉ set: keep the eq0
      have heval : el.eval = (to_var er).eval :=
        to_var_sem_pre _ _ _ hwf_e (List.forall_iff_forall_mem.mpr h_eq)
      simp only [Circuit.eval_eq0, heval]
      split_ifs with h0
      · have h0' : el.eval = 0 := by rw [heval]; exact h0
        exact ih n _ h_eq h_fresh h_inj
          (fun t ht el' er' hwf_e' htn => by
            rcases List.mem_cons.mp ht with rfl | ht'
            · rw [wf_e_eval_eq_of_to_nat_eq _ _ _ _ _ hwf_e' hwf_e htn h_inj]; exact h0'
            · exact h_sv t ht' el' er' hwf_e' htn)
          (fun t ht m hm => by
            rcases List.mem_cons.mp ht with rfl | ht'
            · exact wf_e_vars_bounded _ _ _ _ hwf_e h_fresh _ hm
            · exact h_sf t ht' m hm)
      · rfl
  | @lam G kl kr h ih =>
    intro n set h_eq h_fresh h_inj h_sv h_sf
    change (Circuit.lam kl).eval = (dedup_ (Circuit.lam kr) n set).eval
    simp only [dedup_, Circuit.eval_lam]
    congr 1; funext x
    exact ih x (n, x) (n + 1) set
      (extend_eq G n x h_eq) (extend_fresh G n x h_fresh)
      (extend_inj G n x h_fresh h_inj) (extend_sv G n x set h_sv h_sf)
      (extend_sf G n set h_sf)
  | @share G el er kl kr hwf_e h ih =>
    intro n set h_eq h_fresh h_inj h_sv h_sf
    change (Circuit.share el kl).eval = (dedup_ (Circuit.share er kr) n set).eval
    simp only [dedup_, Circuit.eval_share]
    have heval : el.eval = (to_var er).eval :=
      to_var_sem_pre _ _ _ hwf_e (List.forall_iff_forall_mem.mpr h_eq)
    rw [heval]
    exact ih ((to_var er).eval) (n, (to_var er).eval) (n + 1) set
      (extend_eq G n _ h_eq) (extend_fresh G n _ h_fresh)
      (extend_inj G n _ h_fresh h_inj) (extend_sv G n _ set h_sv h_sf)
      (extend_sf G n set h_sf)
  | @is_zero G el er kl kr hwf_e h ih =>
    intro n set h_eq h_fresh h_inj h_sv h_sf
    change (Circuit.is_zero el kl).eval = (dedup_ (Circuit.is_zero er kr) n set).eval
    simp only [dedup_, Circuit.eval_is_zero]
    have heval : el.eval = (to_var er).eval :=
      to_var_sem_pre _ _ _ hwf_e (List.forall_iff_forall_mem.mpr h_eq)
    rw [heval]
    split <;> (
      apply ih _ (n, _) (n + 1) set
        (extend_eq G n _ h_eq) (extend_fresh G n _ h_fresh)
        (extend_inj G n _ h_fresh h_inj) (extend_sv G n _ set h_sv h_sf)
        (extend_sf G n set h_sf))

/-- The original statement `∀ G, wf G cl cr → Forall ... G → cl ≈ dedup cr` is false for
    non-empty G because nat tags in G can collide with dedup's internal counter (which
    starts at 0), causing incorrect deduplication of distinct constraints. For example,
    a free variable with nat tag 0 and a bound variable assigned tag 0 by the counter
    would be treated as duplicates even though they may have different values.
    The corrected version restricts to G = [] (closed circuits), matching the intended
    use in `dedup_sem_pre'`. -/
-- Original (false) statement:
-- theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
--   wf G cl cr ->
--     List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
--       cl ≈ (dedup cr) := sorry
theorem dedup_sem_pre : ∀ (cl : Circuit F F) (cr : Circuit F (ℕ × F)),
  wf ([] : List (Entry F (ℕ × F))) cl cr →
  cl ≈ (dedup cr) := by
  intro cl cr hwf
  exact dedup_sem_gen cl cr [] hwf 0 []
    (fun _ h => absurd h List.not_mem_nil)
    (fun _ h => absurd h List.not_mem_nil)
    (fun _ h => absurd h List.not_mem_nil)
    (fun _ h => absurd h List.not_mem_nil)
    (fun _ h => absurd h List.not_mem_nil)

