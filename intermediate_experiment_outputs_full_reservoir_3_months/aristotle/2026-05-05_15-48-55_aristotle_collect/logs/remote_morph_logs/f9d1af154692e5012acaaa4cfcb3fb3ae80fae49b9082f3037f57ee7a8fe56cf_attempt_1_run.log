  simp_rw [S, sigma, subsingleton_convert hMT hNT, ‚Üê hsigma]
  refine and_congr ?_ ?_
  . refine forall_congr' fun p => ?_
    constructor
    . rintro hp‚ÇÅ hp
      apply hp‚ÇÅ
      rw [Set.mem_inter_iff] at hp
      simp [show p.asIdeal.primeHeight = 1 by simpa using hp.2]
    . rintro hp hp‚ÇÅ
