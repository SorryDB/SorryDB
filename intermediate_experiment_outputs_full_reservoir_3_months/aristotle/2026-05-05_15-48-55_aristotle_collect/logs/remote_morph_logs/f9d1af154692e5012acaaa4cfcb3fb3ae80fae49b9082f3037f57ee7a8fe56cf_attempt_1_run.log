          simpa using @hMT x
        obtain ‚ü®‚ü®s, hsne‚ü©, hs‚ü© := @hK_is_torsion ‚ü®m, hm‚ü©
        use s, ?_, by simpa using hs
        have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp‚ÇÅ
        rw [Set.disjoint_right] at this
        apply this
        simpa
  . refine forall_congr' fun p => ?_
    constructor
    . rintro hp‚ÇÅ hp
      apply hp‚ÇÅ
      rw [Set.mem_inter_iff] at hp
      simp [show p.asIdeal.primeHeight = 1 by simpa using hp.2]
    . rintro hp hp‚ÇÅ
