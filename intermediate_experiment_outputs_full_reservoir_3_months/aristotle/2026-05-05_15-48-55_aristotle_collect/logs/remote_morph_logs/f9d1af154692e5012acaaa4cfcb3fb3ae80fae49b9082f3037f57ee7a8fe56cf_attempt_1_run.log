/-!

## Krull domain

-/

/-- An integral domain `A` is a Krull domain if it satisfies the following properties:

- `A‚Çö` is a discrete valuation ring for every height one prime `p` of `A`.
- The intersection of all such `A‚Çö` is equal to `A`.
- Any nonzero element of `A` is contained in only a finitely many height one primes of `A`.

See <https://en.wikipedia.org/wiki/Krull_ring>. -/
class IsKrullDomain (A : Type*) [CommRing A] [IsDomain A] : Prop where
  isDiscreteValuationRing_localization (p : PrimeSpectrum A) :
    p.1.primeHeight = 1 ‚Üí IsDiscreteValuationRing (Localization p.1.primeCompl)
  biInf_eq_bot (A) : ‚®Ö p ‚àà {p : PrimeSpectrum A | p.1.primeHeight = 1},
    Localization.subalgebra (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors = ‚ä•
  finite (a : A) :
    a ‚âÝ 0 ‚Üí {p : PrimeSpectrum A | p.1.primeHeight = 1 ‚àß a ‚àà p.1}.Finite

instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  by_contra h_not_integrally_closed
  obtain ‚ü®x, hx‚ü© : ‚àÉ x : FractionRing A, IsIntegral A x ‚àß x ‚àâ Set.range (algebraMap A (FractionRing A)) := by
    contrapose! h_not_integrally_closed with h_integrally_closed
    constructor
    ¬∑ exact IsFractionRing.injective A (FractionRing A)
    ¬∑ exact fun { x } => ‚ü®fun hx => h_integrally_closed x hx, fun ‚ü®y, hy‚ü© => hy ‚ñ∏ isIntegral_algebraMap‚ü©
  have hx_in_localizations : ‚àÄ p : PrimeSpectrum A, p.1.primeHeight = 1 ‚Üí x ‚àà (Localization.subalgebra (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors) := by
    intro p hp
    have hx_local : IsIntegral (Localization p.1.primeCompl) x := by
      obtain ‚ü®f, hf‚ü© := hx.1
      refine' ‚ü®f.map (algebraMap A (Localization p.asIdeal.primeCompl)), _, _‚ü©
      ¬∑ exact hf.1.map _
      ¬∑ simp_all +decide [Polynomial.eval‚ÇÇ_map]
        convert hf.2 using 1
        congr! 2
        ext; simp +decide [Algebra.algebraMap_eq_smul_one]
    have hx_local_closed : IsIntegrallyClosed (Localization p.1.primeCompl) := by
      have := ‚ÄπIsKrullDomain A‚Ä∫.isDiscreteValuationRing_localization p hp
      infer_instance
    convert hx_local_closed.isIntegral_iff.mp hx_local
    simp +decide [Localization.subalgebra]
    simp +decide [Localization.mapToFractionRing, SetLike.ext_iff]
    constructor <;> rintro ‚ü®y, hy‚ü©
    ¬∑ obtain ‚ü®s, hs, rfl‚ü© := hy
      refine' ‚ü®Localization.mk y ‚ü®s, hs‚ü©, _‚ü©
      simp +decide [Localization.mk_eq_mk', div_eq_mul_inv]
      erw [IsLocalization.lift_mk']; aesop
    ¬∑ obtain ‚ü®a, s, hs, rfl‚ü© := IsLocalization.mk'_surjective p.asIdeal.primeCompl y
      refine' ‚ü®a.1, a.2, a.2.2, _‚ü©
      convert hy.symm using 1
      erw [IsLocalization.lift_mk']; aesop
  have hx_in_inf : x ‚àà ‚®Ö p ‚àà {p : PrimeSpectrum A | p.1.primeHeight = 1}, Localization.subalgebra (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors := by
    aesop
  have hx_in_bot : x ‚àà (‚ä• : Subalgebra A (FractionRing A)) := by
    convert hx_in_inf using 1
    convert (IsKrullDomain.biInf_eq_bot A).symm using 1
  exact hx.2 (by rcases hx_in_bot with ‚ü®y, rfl‚ü©; exact ‚ü®y, rfl‚ü©)

