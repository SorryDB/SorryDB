import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

/-
PROVIDED SOLUTION
Key insight: f is uniquely determined by the recurrences. First prove by strong induction that f(n) is uniquely determined for all n. Then since f is unique, it suffices to exhibit one function satisfying all the conditions and count its fixed points up to 1988. The fixed points are exactly the odd numbers whose binary representation has every maximal block of consecutive 1s having odd length. There are 92 such numbers up to 1988. The uniqueness proof uses: f(1)=1, f(3)=3 are given; f(2n)=f(n) reduces to smaller input; f(4n+1) and f(4n+3) reduce to f(2n+1) and f(n), both smaller than 4n+1 or 4n+3.
-/
problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  -- By induction, we can show that $f(n)$ is equal to the binary number formed by reversing the binary representation of $n$.
  have h_ind : ∀ n : ℕ+, f n = ⟨Nat.ofDigits 2 (List.reverse (Nat.digits 2 n.val)), by
    rw [ Nat.ofDigits_eq_foldr ];
    induction' n using PNat.strongInductionOn with n ih; rcases Nat.even_or_odd' n with ⟨ k, hk | hk ⟩ <;> norm_num [ Nat.add_mod, Nat.mul_mod, hk ];
    · rcases k with ( _ | k ) <;> simp_all +decide [ Nat.mul_mod ];
      convert ih ⟨ k + 1, Nat.succ_pos _ ⟩ ( show ( k + 1 : ℕ ) < n from by linarith ) using 1;
    · induction' ( Nat.digits 2 ( ( 2 * k + 1 ) / 2 ) ) using List.reverseRecOn <;> aesop⟩ := by
    all_goals generalize_proofs at *;
    intro n; induction' n using PNat.strongInductionOn with n ih; rcases Nat.even_or_odd' n with ⟨ c, d | d ⟩ <;> simp_all +decide [ Nat.ofDigits, Nat.add_div ] ;
    · rcases c with ( _ | c ) <;> simp_all +decide [ Nat.ofDigits_eq_foldr ];
      · norm_num at d;
      · simp_all +decide [ show n = 2 * ⟨ c + 1, Nat.succ_pos _ ⟩ from PNat.eq d ];
    · rcases Nat.even_or_odd' c with ⟨ k, rfl | rfl ⟩ <;> simp_all +decide [ Nat.add_div ];
      · rcases k with ( _ | k ) <;> simp_all +decide [ Nat.ofDigits ];
        · simp_all +decide [ show n = 1 from PNat.eq d ];
        · simp_all +decide [ show n = ⟨ 2 * ( 2 * ( k + 1 ) ) + 1, Nat.succ_pos _ ⟩ from PNat.eq d ];
          have := h₃ ⟨ k + 1, Nat.succ_pos _ ⟩ ; simp_all +decide [ show ( 4 * ⟨ k + 1, Nat.succ_pos _ ⟩ + 1 : ℕ+ ) = 2 * ( 2 * ⟨ k + 1, Nat.succ_pos _ ⟩ ) + 1 from by ring ] ;
          erw [ ih ⟨ k + 1, Nat.succ_pos _ ⟩ ( Nat.lt_succ_of_le <| by linarith ), ih ⟨ 2 * ( k + 1 ) + 1, Nat.succ_pos _ ⟩ ( Nat.lt_succ_of_le <| by linarith ) ] at this; simp_all +decide [ Nat.ofDigits_append, Nat.ofDigits ] ;
          erw [ ← PNat.coe_inj ] at * ; simp_all +decide [ Nat.add_div ];
          simp_all +decide [ Nat.ofDigits_append, Nat.ofDigits_singleton, pow_succ' ] ; linarith!;
      · rcases k with ( _ | k ) <;> simp_all +decide [ Nat.add_mod, Nat.mul_mod ];
        · simp_all +decide [ show n = 3 by exact PNat.eq d ];
          exact?;
        · simp_all +decide [ show n = ⟨ 2 * ( 2 * ( k + 1 ) + 1 ) + 1, Nat.succ_pos _ ⟩ from PNat.eq d ];
          have := h₄ ⟨ k + 1, Nat.succ_pos _ ⟩ ; simp_all +decide [ show ( 4 * ⟨ k + 1, Nat.succ_pos _ ⟩ + 3 : ℕ+ ) = 2 * ( 2 * ⟨ k + 1, Nat.succ_pos _ ⟩ + 1 ) + 1 from by ring ] ;
          erw [ ih ⟨ k + 1, Nat.succ_pos _ ⟩ ( Nat.lt_succ_of_le <| by simp +arith +decide ) ] at this; erw [ ih ⟨ 2 * ( k + 1 ) + 1, Nat.succ_pos _ ⟩ ( Nat.lt_succ_of_le <| by simp +arith +decide ) ] at this; simp_all +decide [ Nat.ofDigits_append, Nat.ofDigits ] ;
          erw [ ← PNat.coe_inj ] at * ; simp_all +decide [ Nat.add_div ];
          simp_all +decide [ Nat.ofDigits_append, Nat.ofDigits_singleton, pow_succ' ] ; linarith!
  generalize_proofs at *;
  simp_all +decide [ ← PNat.coe_inj ];
  convert Set.ncard_eq_toFinset_card' ( Set.Icc 1 1988 ∩ { n : ℕ | Nat.ofDigits 2 ( List.reverse ( Nat.digits 2 ( n / 2 ) ) ++ [ n % 2 ] ) = n } ) using 2;
  fapply Set.ncard_congr;
  use fun n hn => n;
  · exact fun n hn => ⟨ ⟨ PNat.pos n, hn.1 ⟩, hn.2 ⟩;
  · exact fun a b ha hb h => PNat.eq h;
  · exact fun n hn => ⟨ ⟨ n, hn.1.1 ⟩, ⟨ hn.1.2, hn.2 ⟩, rfl ⟩

end Imo1988P3
