import Mathlib
import FormalConjectures.Util.Answer
import FormalConjectures.Util.Attributes.Attributes

/-!
# Erdős Problem 757

*References:*
 - [erdosproblems.com/757](https://www.erdosproblems.com/757)
 - [GyLe95] Gyárfás, András and Lehel, Jenő, Linear sets with five distinct differences among any
    four elements. J. Combin. Theory Ser. B (1995), 108-118.
-/

open scoped Pointwise
open Filter

namespace Erdos757

/-- A Sidon set is a set such that all pairwise sums of elements are distinct apart from
coincidences forced by the commutativity of addition. -/
def IsSidon {α : Type*} [AddCommMonoid α] {S : Type*} [Membership α S] (A : S) : Prop :=
  ∀ᵉ (i₁ ∈ A) (j₁ ∈ A) (i₂ ∈ A) (j₂ ∈ A),
    i₁ + i₂ = j₁ + j₂ → (i₁ = j₁ ∧ i₂ = j₂) ∨ (i₁ = j₂ ∧ i₂ = j₁)

/-- We say that `c` is admissible if for any finit set `A` such that for any subset `B` of size `4`,
`(B - B).card = 11`, there exists a Sidon subset `S` of size at least `c * A.ncard`. -/
def IsAdmissible (c : ℝ) : Prop := ∀ {A : Set ℝ}, A.Finite → (∀ B ⊆ A,
  B.ncard = 4 → (B - B).ncard = 11) → ∃ S ⊆ A, IsSidon S ∧ c * A.ncard ≤ (S.ncard : ℝ)

/-- The set of admissible constants is bounded above by 1. -/
lemma bddAbove_isAdmissible : BddAbove {c : ℝ | IsAdmissible c} := by
  use 1;
  rintro c hc
  specialize hc (Set.finite_singleton 0) (by
  intro B hB hB'; have := Set.ncard_le_ncard hB; simp_all +decide ;)
  obtain ⟨ S, hS₁, hS₂, hS₃ ⟩ := hc
  have hS₄ : S.ncard ≤ 1 := by
    exact le_trans ( Set.ncard_le_ncard hS₁ ) ( by norm_num )
  norm_num at * ; linarith [ show ( S.ncard : ℝ ) ≤ 1 by norm_cast ]

/-- Any two-element set of distinct reals is Sidon. -/
lemma isSidon_pair {a b : ℝ} (hab : a ≠ b) : IsSidon ({a, b} : Set ℝ) := by
  simp +decide [ IsSidon, hab ]
  exact ⟨ fun h => hab <| by linarith, fun h => by linarith ⟩

/-- Any singleton set is Sidon. -/
lemma isSidon_singleton (a : ℝ) : IsSidon ({a} : Set ℝ) := by
  simp [IsSidon]

/-- The empty set is Sidon. -/
lemma isSidon_empty : IsSidon (∅ : Set ℝ) := by
  unfold IsSidon; aesop

/-- If A has the 11-difference property and |A| = 4, then there exists a 3-element Sidon subset. -/
lemma exists_sidon_three_of_four {A : Set ℝ} (hA : A.Finite) (hcard : A.ncard = 4)
    (hdiff : (A - A).ncard = 11) :
    ∃ S ⊆ A, IsSidon S ∧ S.ncard = 3 := by
  obtain ⟨a, b, c, d, ha, hb, hc, hd, hdist⟩ : ∃ a b c d : ℝ, a ∈ A ∧ b ∈ A ∧ c ∈ A ∧ d ∈ A ∧ a < b ∧ b < c ∧ c < d ∧ A = {a, b, c, d} := by
    obtain ⟨E, hE⟩ : ∃ E : Finset ℝ, A = E ∧ E.card = 4 := by
      exact ⟨ hA.toFinset, by simpa, by simpa [ ← Set.ncard_coe_finset ] using hcard ⟩;
    obtain ⟨s, hs⟩ : ∃ s : Fin 4 → ℝ, (∀ i, s i ∈ E) ∧ StrictMono s ∧ E = Finset.image s Finset.univ := by
      use fun i => E.orderEmbOfFin ( by aesop ) i;
      simp +decide [ StrictMono ]
    use s 0, s 1, s 2, s 3; simp_all +decide [ Fin.univ_succ ] ; aesop
  by_cases h_all_nonSidon : (∀ i j k : ℝ, i ∈ A → j ∈ A → k ∈ A → i ≠ j → j ≠ k → i ≠ k → (2 * i = j + k ∨ 2 * j = i + k ∨ 2 * k = i + j));
  · grind
  · obtain ⟨i, j, k, hi, hj, hk, hij, hjk, hik, h_not_ap⟩ : ∃ i j k : ℝ, i ∈ A ∧ j ∈ A ∧ k ∈ A ∧ i ≠ j ∧ j ≠ k ∧ i ≠ k ∧ ¬(2 * i = j + k ∨ 2 * j = i + k ∨ 2 * k = i + j) := by
      grind +ring
    refine' ⟨ { i, j, k }, _, _, _ ⟩ <;> simp_all +decide [ Set.Subset.antisymm_iff, Set.subset_def ]
    intro x hx y hy z hz t ht h; simp_all +decide [ IsSidon ]
    grind +ring

/-- A 4-element set with ordered gaps (p,q,r), where all positive, has exactly one collision
among its 6 positive differences iff one of these holds (with non-degeneracy conditions):
- Type A: p = q, r ≠ p, r ≠ 2p
- Type C: q = r, p ≠ q, p ≠ 2q
- Type D: p = q + r, q ≠ r
- Type E: r = p + q, p ≠ q
Type B (p = r) always gives 2 collisions and is excluded. -/
def ExactlyOneCollision (p q r : ℝ) : Prop :=
  (p = q ∧ p ≠ r ∧ r ≠ 2 * p) ∨
  (q = r ∧ p ≠ q ∧ p ≠ 2 * q) ∨
  (p = q + r ∧ q ≠ r) ∨
  (r = p + q ∧ p ≠ q)

/-
PROBLEM
The pure arithmetic content: no positive gaps x₁,x₂,x₃,x₄ can satisfy exactly one collision
in each of the 5 four-element subsets of 5 ordered points.

PROVIDED SOLUTION
Unfold ExactlyOneCollision everywhere, then case split on hS₁ (4 cases: A, C, D, E).

Case E (last disjunct of hS₁: x₃ = x₁+x₂, x₁≠x₂):
  In hS₂ = ExactlyOneCollision x₁ x₂ (x₃+x₄), substitute x₃=x₁+x₂ to get ExactlyOneCollision x₁ x₂ (x₁+x₂+x₄).
  Check each disjunct of hS₂:
  - x₁=x₂: contradicts x₁≠x₂.
  - x₂=x₁+x₂+x₄: gives x₁+x₄=0, contradicts positivity.
  - x₁=x₂+x₁+x₂+x₄: gives 2x₂+x₄=0, contradicts positivity.
  - x₁+x₂+x₄=x₁+x₂: gives x₄=0, contradicts positivity.
  All 4 options impossible → False.

Case A (first disjunct: x₁=x₂, x₁≠x₃, x₃≠2*x₁):
  Substitute x₂=x₁. hS₃ = ExactlyOneCollision x₁ (x₁+x₃) x₄.
  Check: p=q gives x₁=x₁+x₃ → x₃=0 impossible. p=q+r gives x₁=x₁+x₃+x₄ → impossible.
  So hS₃ is either q=r (x₁+x₃=x₄) or r=p+q (x₄=2x₁+x₃).

  Sub-case x₁+x₃=x₄:
    hS₄ = ExactlyOneCollision 2x₁ x₃ (x₁+x₃).
    - p=q: 2x₁=x₃, contradicts x₃≠2x₁.
    - q=r: x₃=x₁+x₃ → x₁=0 impossible.
    - p=q+r: 2x₁=x₃+x₁+x₃=x₁+2x₃ → x₁=2x₃. Then x₃+x₄=x₃+x₁+x₃=2x₃+2x₃=4x₃=2*2x₃=2x₁. But hS₂ requires x₃+x₄≠2x₁ (from non-degen of type A). Contradiction.
    - r=p+q: x₁+x₃=2x₁+x₃ → x₁=0 impossible.

  Sub-case x₄=2x₁+x₃:
    hS₅ = ExactlyOneCollision x₁ x₃ (2x₁+x₃).
    - p=q: x₁=x₃, contradicts x₁≠x₃.
    - q=r: x₃=2x₁+x₃ → 2x₁=0 impossible.
    - p=q+r: x₁=x₃+2x₁+x₃ → x₁+2x₃=0 impossible.
    - r=p+q: 2x₁+x₃=x₁+x₃ → x₁=0 impossible.
    All impossible → False.

Case C (second disjunct: x₂=x₃, x₁≠x₂, x₁≠2x₂):
  Substitute x₃=x₂. hS₃ = ExactlyOneCollision x₁ 2x₂ x₄.
  - p=q: x₁=2x₂, contradicts x₁≠2x₂.
  - q=r: 2x₂=x₄. Need non-degen p≠q: x₁≠2x₂ ✓. p≠2q: x₁≠4x₂.
    But also check hS₅ = ExactlyOneCollision x₂ x₂ x₄. With x₃=x₂:
    First disjunct gives x₂=x₂ (true), non-degen x₄≠x₂, x₄≠2x₂. So if 2x₂=x₄, contradiction (x₄≠2x₂).
  - p=q+r: x₁=2x₂+x₄. With hS₅: x₄≠x₂, x₄≠2x₂.
    hS₄ = ExactlyOneCollision (x₁+x₂) x₂ x₄ = ExactlyOneCollision (3x₂+x₄) x₂ x₄.
    All 4 options: 3x₂+x₄=x₂ impossible, x₂=x₄ contradicts hS₅, 3x₂+x₄=x₂+x₄ gives 2x₂=0 impossible, x₄=3x₂+x₄+x₂ gives 4x₂=0 impossible. All False.
  - r=p+q: x₄=x₁+2x₂.
    hS₂ = ExactlyOneCollision x₁ x₂ (x₂+x₁+2x₂) = ExactlyOneCollision x₁ x₂ (x₁+3x₂).
    - x₁=x₂ contradicts x₁≠x₂.
    - x₂=x₁+3x₂ → x₁+2x₂=0 impossible.
    - x₁=x₂+x₁+3x₂ → 4x₂=0 impossible.
    - x₁+3x₂=x₁+x₂ → 2x₂=0 impossible.
    All impossible → False.

Case D (third disjunct: x₁=x₂+x₃, x₂≠x₃):
  hS₃ = ExactlyOneCollision (x₂+x₃) (x₂+x₃) x₄.
  First disjunct: x₂+x₃=x₂+x₃ (true), non-degen: x₄≠x₂+x₃, x₄≠2(x₂+x₃).
  Other options all impossible (similar argument). So x₄≠x₂+x₃ ∧ x₄≠2(x₂+x₃).

  hS₂ = ExactlyOneCollision (x₂+x₃) x₂ (x₃+x₄).
  - x₂+x₃=x₂ → x₃=0 impossible.
  - x₂=x₃+x₄. Non-degen: x₂+x₃≠x₂ ✓, x₂+x₃≠2x₂ → x₃≠x₂ ✓.
  - x₂+x₃=x₂+x₃+x₄ → x₄=0 impossible.
  - x₃+x₄=2x₂+x₃ → x₄=2x₂. Non-degen: x₂+x₃≠x₂ ✓.
  So hS₂ gives: x₂=x₃+x₄ ∨ x₄=2x₂.

  Sub-case x₂=x₃+x₄:
    hS₄ = ExactlyOneCollision (2x₂+x₃-x₄+x₂) ... wait, let me recalculate.
    x₁=x₂+x₃. x₁+x₂=2x₂+x₃. hS₄ = ExactlyOneCollision (2x₂+x₃) x₃ x₄.
    With x₂=x₃+x₄: 2x₂+x₃ = 2x₃+2x₄+x₃ = 3x₃+2x₄.
    - 3x₃+2x₄=x₃ → 2x₃+2x₄=0 impossible.
    - x₃=x₄. Then x₂=2x₃. hS₅=ExactlyOneCollision(2x₃)(x₃)(x₃).
      p=q: 2x₃=x₃ → x₃=0 impossible. q=r: x₃=x₃ true, non-degen: 2x₃≠x₃ ✓ but 2x₃≠2x₃ FALSE. All other options impossible. False.
    - 3x₃+2x₄=x₃+x₄ → 2x₃+x₄=0 impossible.
    - x₄=3x₃+2x₄+x₃ → 4x₃+x₄=0 impossible.
    Only x₃=x₄ works, leading to False.

  Sub-case x₄=2x₂:
    hS₄ = ExactlyOneCollision (2x₂+x₃) x₃ (2x₂).
    - 2x₂+x₃=x₃ → 2x₂=0 impossible.
    - x₃=2x₂. Then check ExactlyOneCollision(4x₂)(2x₂)(2x₂):
      q=r: 2x₂=2x₂, non-degen: 4x₂≠2x₂ ✓ but 4x₂≠4x₂ FALSE. p=q+r: 4x₂=4x₂, non-degen: 2x₂≠2x₂ FALSE. All fail → False.
    - 2x₂+x₃=x₃+2x₂ (always true), non-degen: x₃≠2x₂. Then:
      hS₅ = ExactlyOneCollision x₂ x₃ 2x₂.
      - x₂=x₃ contradicts x₂≠x₃.
      - x₃=2x₂ contradicts x₃≠2x₂.
      - x₂=x₃+2x₂ → x₂+x₃=0 impossible.
      - 2x₂=x₂+x₃ → x₂=x₃ contradicts x₂≠x₃.
      All impossible → False.
    - 2x₂=2x₂+x₃+x₃ → 2x₃=0 impossible.
-/
lemma five_gaps_no_solution (x₁ x₂ x₃ x₄ : ℝ)
    (h₁ : 0 < x₁) (h₂ : 0 < x₂) (h₃ : 0 < x₃) (h₄ : 0 < x₄)
    (hS₁ : ExactlyOneCollision x₁ x₂ x₃)
    (hS₅ : ExactlyOneCollision x₂ x₃ x₄)
    (hS₂ : ExactlyOneCollision x₁ x₂ (x₃ + x₄))
    (hS₃ : ExactlyOneCollision x₁ (x₂ + x₃) x₄)
    (hS₄ : ExactlyOneCollision (x₁ + x₂) x₃ x₄)
    : False := by
      unfold ExactlyOneCollision at *;
      grind +ring

/-
PROBLEM
For 4 ordered elements with gaps p, q, r (all positive), p = r implies the difference set
has at most 9 elements (not 11).

PROVIDED SOLUTION
We need to show that {a,b,c,d} - {a,b,c,d} equals a specific 9-element set when b-a = d-c.

The set {a,b,c,d} - {a,b,c,d} = {x-y | x,y ∈ {a,b,c,d}}. There are 16 pairs, giving differences:
0 (from a-a, b-b, c-c, d-d), b-a, c-a, d-a, a-b=-(b-a), c-b, d-b, a-c=-(c-a), b-c=-(c-b), d-c, a-d=-(d-a), b-d=-(d-b), c-d=-(d-c).

Since b-a = d-c, we have d-c = b-a and c-d = a-b = -(b-a). Also d-b = d-c+c-b = (b-a)+(c-b) = c-a, and b-d = -(c-a).

So the distinct elements are: 0, b-a, c-a, d-a, c-b, -(b-a), -(c-a), -(d-a), -(c-b). That's 9 elements (assuming a<b<c<d and b-a=d-c).

Use Set.ext, then for each element show membership using the definition of pointwise subtraction.
-/
lemma type_B_gives_nine {a b c d : ℝ} (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hpr : b - a = d - c) :
    ({a, b, c, d} : Set ℝ) - {a, b, c, d} =
    {(0 : ℝ), b - a, c - a, d - a, c - b, -(b - a), -(c - a), -(d - a), -(c - b)} := by
      simp +decide [ Set.ext_iff, Set.mem_sub, Set.mem_singleton_iff ];
      grind +ring

/-
PROBLEM
For ordered elements a < b < c < d, if |{a,b,c,d} - {a,b,c,d}| = 11, then
ExactlyOneCollision holds for the gaps.

PROVIDED SOLUTION
Prove by the contrapositive: ¬ExactlyOneCollision (b-a) (c-b) (d-c) → ncard ≠ 11.

Let p = b-a, q = c-b, r = d-c.

Step 1: Show ({a,b,c,d} - {a,b,c,d}) = {0, p, q, r, p+q, q+r, p+q+r, -p, -q, -r, -(p+q), -(q+r), -(p+q+r)} using Set.ext and the definition of pointwise subtraction. Use `simp [Set.ext_iff, Set.mem_sub]; grind +ring`.

Step 2: ¬ExactlyOneCollision(p,q,r) means none of the 4 disjuncts hold. Unfold and push_neg to get:
- ¬(p = q ∧ p ≠ r ∧ r ≠ 2p)
- ¬(q = r ∧ p ≠ q ∧ p ≠ 2q)
- ¬(p = q + r ∧ q ≠ r)
- ¬(r = p + q ∧ p ≠ q)

After push_neg: (p = q → r = p ∨ r = 2p), (q = r → p = q ∨ p = 2q), (p = q + r → q = r), (r = p + q → p = q).

Step 3: Show ncard ≠ 11. By case analysis:
- If p = r: use type_B_gives_nine to show B-B has 9 distinct elements (since b-a = d-c). ncard = 9 ≠ 11.
- If p ≠ r, q ≠ r, p ≠ q, p ≠ q+r, r ≠ p+q: then all 6 positive values are distinct, giving 13 elements. ncard = 13 ≠ 11.
- If p = q and r = 2p (non-degeneracy fails): then the 6 values are p, p, 2p, 2p, 3p, 4p → 4 distinct, giving ncard = 9.
  Actually: the 6 positive differences are p, q=p, r=2p, p+q=2p, q+r=3p, p+q+r=4p. So distinct: {p, 2p, 3p, 4p} = 4 values, giving ncard = 2*4+1 = 9.
- If q = r and p = 2q: similarly gives 9.
- Other mixed cases also give ncard ≤ 9 or ncard = 13.

The key case split is on p = r vs p ≠ r. If p = r, apply type_B_gives_nine. If p ≠ r, show that ¬ExactlyOneCollision with p ≠ r means all 6 positive differences are distinct OR there are ≥2 collisions.

For the case p ≠ r and all conditions negated:
From ¬(p=q ∧ p≠r ∧ r≠2p): since p≠r, this means p≠q ∨ r=2p.
From ¬(q=r ∧ p≠q ∧ p≠2q): since we know nothing more, p=q ∨ p=2q ∨ q≠r.
Etc.

This requires careful case splitting. The by_contra approach with `push_neg` and then `rcases` should work, followed by computing ncard for each sub-case.
-/
set_option maxHeartbeats 800000 in
lemma eleven_diff_implies_collision {a b c d : ℝ} (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hdiff : (({a, b, c, d} : Set ℝ) - {a, b, c, d}).ncard = 11) :
    ExactlyOneCollision (b - a) (c - b) (d - c) := by
      -- By contradiction, assume that ¬ExactlyOneCollision (b - a) (c - b) (d - c).
      by_contra h_contra;
      -- By definition of $p$, $q$, and $r$, we know that $p \neq r$, $q \neq r$, $p \neq q$, $p \neq q + r$, and $r \neq p + q$.
      have h_neq : b - a ≠ d - c ∧ c - b ≠ d - c ∧ b - a ≠ c - b ∧ b - a ≠ (c - b) + (d - c) ∧ d - c ≠ (b - a) + (c - b) := by
        unfold ExactlyOneCollision at h_contra;
        by_cases h1 : b - a = d - c <;> by_cases h2 : c - b = d - c <;> simp_all +decide;
        · rw [ show ( { a, b, c, d } - { a, b, c, d } : Set ℝ ) = { 0, b - a, c - a, d - a, c - b, - ( b - a ), - ( c - a ), - ( d - a ), - ( c - b ) } from ?_ ] at hdiff;
          · simp_all +decide [ Set.ncard_eq_toFinset_card' ];
            exact hdiff.not_lt ( lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by linarith [ Finset.card_insert_le 0 { c - a, d - a, d - c, a - c, a - d, c - d }, Finset.card_insert_le ( c - a ) { d - a, d - c, a - c, a - d, c - d }, Finset.card_insert_le ( d - a ) { d - c, a - c, a - d, c - d }, Finset.card_insert_le ( d - c ) { a - c, a - d, c - d }, Finset.card_insert_le ( a - c ) { a - d, c - d }, Finset.card_insert_le ( a - d ) { c - d }, Finset.card_singleton ( c - d ) ] ) );
          · convert type_B_gives_nine hab hbc hcd h1 using 1;
        · -- If $b - a = d - c$, then the difference set has exactly 9 elements.
          have h_diff_set : ({a, b, c, d} : Set ℝ) - {a, b, c, d} = {0, b - a, c - a, d - a, c - b, -(b - a), -(c - a), -(d - a), -(c - b)} := by
            exact type_B_gives_nine hab hbc hcd h1;
          simp_all +decide [ Set.ncard_eq_toFinset_card' ];
          exact hdiff.not_lt ( lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by linarith [ Finset.card_insert_le 0 { d - c, c - a, d - a, c - b, c - d, a - c, a - d, b - c }, Finset.card_insert_le ( d - c ) { c - a, d - a, c - b, c - d, a - c, a - d, b - c }, Finset.card_insert_le ( c - a ) { d - a, c - b, c - d, a - c, a - d, b - c }, Finset.card_insert_le ( d - a ) { c - b, c - d, a - c, a - d, b - c }, Finset.card_insert_le ( c - b ) { c - d, a - c, a - d, b - c }, Finset.card_insert_le ( c - d ) { a - c, a - d, b - c }, Finset.card_insert_le ( a - c ) { a - d, b - c }, Finset.card_insert_le ( a - d ) { b - c }, Finset.card_singleton ( b - c ) ] ) );
        · have h_card : ({a, b, c, d} - {a, b, c, d} : Set ℝ) = {0, b - a, c - a, d - a, c - b, -(b - a), -(c - a), -(d - a), -(c - b)} := by
            ext x;
            simp +decide [ Set.mem_sub, Set.mem_insert_iff, Set.mem_singleton_iff ];
            grind +ring;
          simp_all +decide [ Set.ncard_eq_toFinset_card' ];
          exact hdiff.not_lt ( lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by linarith [ Finset.card_insert_le 0 { 2 * ( d - c ), c - a, d - a, d - c, - ( 2 * ( d - c ) ), a - c, a - d, c - d }, Finset.card_insert_le ( 2 * ( d - c ) ) { c - a, d - a, d - c, - ( 2 * ( d - c ) ), a - c, a - d, c - d }, Finset.card_insert_le ( c - a ) { d - a, d - c, - ( 2 * ( d - c ) ), a - c, a - d, c - d }, Finset.card_insert_le ( d - a ) { d - c, - ( 2 * ( d - c ) ), a - c, a - d, c - d }, Finset.card_insert_le ( d - c ) { - ( 2 * ( d - c ) ), a - c, a - d, c - d }, Finset.card_insert_le ( - ( 2 * ( d - c ) ) ) { a - c, a - d, c - d }, Finset.card_insert_le ( a - c ) { a - d, c - d }, Finset.card_insert_le ( a - d ) { c - d }, Finset.card_singleton ( c - d ) ] ) );
        · constructor <;> intro h <;> simp_all +decide [ Set.Subset.antisymm_iff, Set.subset_def ];
          · rw [ show ( { a, b, c, d } - { a, b, c, d } : Set ℝ ) = { 0, b - a, c - a, d - a, c - b, d - b, d - c, -(b - a), -(c - a), -(d - a), -(c - b), -(d - b), -(d - c) } from ?_ ] at hdiff;
            · rw [ show ( { 0, b - a, c - a, d - a, c - b, d - b, d - c, - ( b - a ), - ( c - a ), - ( d - a ), - ( c - b ), - ( d - b ), - ( d - c ) } : Set ℝ ) = { 0, b - a, c - a, d - a, c - b, d - b, - ( b - a ), - ( c - a ), - ( d - a ), - ( c - b ), - ( d - b ) } from ?_ ] at hdiff;
              · simp_all +decide [ Set.ncard_eq_toFinset_card' ];
                exact hdiff.not_lt ( lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by linarith [ Finset.card_insert_le 0 { c - a, d - a, c - b, d - b, a - c, a - d, b - c, b - d }, Finset.card_insert_le ( c - a ) { d - a, c - b, d - b, a - c, a - d, b - c, b - d }, Finset.card_insert_le ( d - a ) { c - b, d - b, a - c, a - d, b - c, b - d }, Finset.card_insert_le ( c - b ) { d - b, a - c, a - d, b - c, b - d }, Finset.card_insert_le ( d - b ) { a - c, a - d, b - c, b - d }, Finset.card_insert_le ( a - c ) { a - d, b - c, b - d }, Finset.card_insert_le ( a - d ) { b - c, b - d }, Finset.card_insert_le ( b - c ) { b - d }, Finset.card_singleton ( b - d ) ] ) );
              · ext x
                simp [h_contra];
                grind +ring;
            · ext x
              simp [Set.mem_sub, Set.mem_insert_iff, Set.mem_singleton_iff];
              grind +ring;
          · rw [ show ( { a, b, c, d } - { a, b, c, d } : Set ℝ ) = { 0, b - a, c - a, d - a, c - b, d - b, d - c, - ( b - a ), - ( c - a ), - ( d - a ), - ( c - b ), - ( d - b ), - ( d - c ) } from ?_ ] at hdiff;
            · simp_all +decide [ Set.ncard_eq_toFinset_card' ];
              exact hdiff.not_lt ( lt_of_le_of_lt ( Finset.card_insert_le _ _ ) ( by linarith [ Finset.card_insert_le 0 { d - a, c - b, d - b, 2 * ( c - b ), a - d, b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( d - a ) { c - b, d - b, 2 * ( c - b ), a - d, b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( c - b ) { d - b, 2 * ( c - b ), a - d, b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( d - b ) { 2 * ( c - b ), a - d, b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( 2 * ( c - b ) ) { a - d, b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( a - d ) { b - c, b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( b - c ) { b - d, - ( 2 * ( c - b ) ) }, Finset.card_insert_le ( b - d ) { - ( 2 * ( c - b ) ) }, Finset.card_singleton ( - ( 2 * ( c - b ) ) ) ] ) );
            · simp +decide [ Set.ext_iff, Set.mem_sub ];
              grind +ring;
      -- Let's calculate the set of differences and show it has 13 elements.
      have h_diff_set : ({a, b, c, d} : Set ℝ) - {a, b, c, d} = {0, b - a, c - a, d - a, c - b, d - b, d - c, -(b - a), -(c - a), -(d - a), -(c - b), -(d - b), -(d - c)} := by
        ext x; simp [Set.mem_sub, Set.mem_insert_iff, Set.mem_singleton_iff] ; ring_nf ; aesop;
      -- Since these are all distinct elements, the cardinality of the set is 13.
      have h_card : ({0, b - a, c - a, d - a, c - b, d - b, d - c, -(b - a), -(c - a), -(d - a), -(c - b), -(d - b), -(d - c)} : Set ℝ).ncard = 13 := by
        simp +decide [ Set.ncard_eq_toFinset_card' ];
        rw [ Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem, Finset.card_insert_of_notMem ] <;> simp +decide [ *, ne_of_lt ];
        grind;
        grind +ring;
        grind +ring;
        grind +ring;
        grind;
        grind +ring;
        · exact ⟨ by linarith, by linarith, by linarith, by linarith, by linarith, by linarith ⟩;
        · grind +ring;
        · grind +ring;
        · grind +ring;
        · exact ⟨ by linarith, by linarith, by linarith, by linarith, by linarith, by linarith, by linarith, by linarith, by linarith ⟩;
      grind +ring

/-
PROBLEM
No finite set of reals with 5 or more elements can have the property that every 4-element
subset has exactly 11 differences.

PROVIDED SOLUTION
Extract 5 ordered elements a₁ < a₂ < a₃ < a₄ < a₅ from A (using the finite ordering). Define gaps x₁=a₂-a₁, ..., x₄=a₅-a₄.

For each of the 5 four-element subsets, apply eleven_diff_implies_collision to get ExactlyOneCollision on the corresponding gaps.

Then apply five_gaps_no_solution to get False.

The 5 four-element subsets and their gaps:
- {a₁,a₂,a₃,a₄}: gaps (x₁, x₂, x₃)
- {a₂,a₃,a₄,a₅}: gaps (x₂, x₃, x₄)
- {a₁,a₂,a₃,a₅}: gaps (x₁, x₂, x₃+x₄) [since a₅-a₃ = x₃+x₄]
- {a₁,a₂,a₄,a₅}: gaps (x₁, x₂+x₃, x₄) [since a₄-a₂ = x₂+x₃]
- {a₁,a₃,a₄,a₅}: gaps (x₁+x₂, x₃, x₄) [since a₃-a₁ = x₁+x₂]

Key steps:
1. Reduce to |A| = 5 (take 5-element subset if larger)
2. Extract ordered elements using Finset.orderEmbOfFin
3. Show each 4-element subset ⊆ A and has ncard = 4
4. Apply hdiff to get |B-B| = 11
5. Apply eleven_diff_implies_collision
6. Apply five_gaps_no_solution
-/
lemma no_five_element_set {A : Set ℝ} (hA : A.Finite) (hcard : 5 ≤ A.ncard)
    (hdiff : ∀ B ⊆ A, B.ncard = 4 → (B - B).ncard = 11) : False := by
      -- Extract 5 ordered elements a₁ < a₂ < a₃ < a₄ < a₅ from A (using the finite ordering).
      obtain ⟨a, ha⟩ : ∃ a : Fin 5 → ℝ, StrictMono a ∧ ∀ i : Fin 5, a i ∈ A := by
        obtain ⟨ s, hs ⟩ := Set.Finite.exists_finset_coe hA;
        obtain ⟨t, ht⟩ : ∃ t : Finset ℝ, t ⊆ s ∧ t.card = 5 := by
          exact Finset.exists_subset_card_eq ( by simpa [ ← hs ] using hcard );
        exact ⟨ fun i => t.orderEmbOfFin ( by aesop ) i, by aesop_cat, fun i => hs.subset <| ht.1 <| by aesop ⟩;
      -- Apply the lemma `eleven_diff_implies_collision` to each of the 5 four-element subsets.
      have h_collisions : ExactlyOneCollision (a 1 - a 0) (a 2 - a 1) (a 3 - a 2) ∧
                         ExactlyOneCollision (a 2 - a 1) (a 3 - a 2) (a 4 - a 3) ∧
                         ExactlyOneCollision (a 1 - a 0) (a 2 - a 1) ((a 3 - a 2) + (a 4 - a 3)) ∧
                         ExactlyOneCollision (a 1 - a 0) ((a 2 - a 1) + (a 3 - a 2)) (a 4 - a 3) ∧
                         ExactlyOneCollision ((a 1 - a 0) + (a 2 - a 1)) (a 3 - a 2) (a 4 - a 3) := by
                           have h_collisions : ∀ (i j k l : Fin 5), i < j ∧ j < k ∧ k < l →
                               ExactlyOneCollision (a j - a i) (a k - a j) (a l - a k) := by
                                 intros i j k l hijkl
                                 have h_subset : ({a i, a j, a k, a l} : Set ℝ) ⊆ A := by
                                   aesop_cat
                                 have h_card : ({a i, a j, a k, a l} : Set ℝ).ncard = 4 := by
                                   rw [ Set.ncard_insert_of_notMem, Set.ncard_insert_of_notMem, Set.ncard_insert_of_notMem, Set.ncard_singleton ] <;> simp +decide [ ha.1.injective.eq_iff, hijkl ];
                                   · exact ne_of_lt hijkl.2.2;
                                   · exact ⟨ ne_of_lt hijkl.2.1, ne_of_lt ( lt_trans hijkl.2.1 hijkl.2.2 ) ⟩;
                                   · exact ⟨ ne_of_lt hijkl.1, ne_of_lt ( hijkl.1.trans hijkl.2.1 ), ne_of_lt ( hijkl.1.trans ( hijkl.2.1.trans hijkl.2.2 ) ) ⟩
                                 have h_diff : (({a i, a j, a k, a l} : Set ℝ) - {a i, a j, a k, a l}).ncard = 11 := by
                                   exact hdiff _ h_subset h_card
                                 have h_collision : ExactlyOneCollision (a j - a i) (a k - a j) (a l - a k) := by
                                   apply eleven_diff_implies_collision (by
                                   exact ha.1 hijkl.1) (by
                                   exact ha.1 hijkl.2.1) (by
                                   exact ha.1 hijkl.2.2) h_diff
                                 exact h_collision;
                           simp_all +decide [ Fin.forall_fin_succ ];
      exact absurd ( five_gaps_no_solution ( a 1 - a 0 ) ( a 2 - a 1 ) ( a 3 - a 2 ) ( a 4 - a 3 ) ( by linarith [ ha.1 ( show 0 < 1 from by decide ), ha.1 ( show 1 < 2 from by decide ), ha.1 ( show 2 < 3 from by decide ), ha.1 ( show 3 < 4 from by decide ) ] ) ( by linarith [ ha.1 ( show 0 < 1 from by decide ), ha.1 ( show 1 < 2 from by decide ), ha.1 ( show 2 < 3 from by decide ), ha.1 ( show 3 < 4 from by decide ) ] ) ( by linarith [ ha.1 ( show 0 < 1 from by decide ), ha.1 ( show 1 < 2 from by decide ), ha.1 ( show 2 < 3 from by decide ), ha.1 ( show 3 < 4 from by decide ) ] ) ( by linarith [ ha.1 ( show 0 < 1 from by decide ), ha.1 ( show 1 < 2 from by decide ), ha.1 ( show 2 < 3 from by decide ), ha.1 ( show 3 < 4 from by decide ) ] ) h_collisions.1 h_collisions.2.1 h_collisions.2.2.1 h_collisions.2.2.2.1 h_collisions.2.2.2.2 ) ( by norm_num ) ;

/-- IsAdmissible (2/3) -/
lemma isAdmissible_two_thirds : IsAdmissible (2/3 : ℝ) := by
  intro A hA hdiff
  by_cases hcard : A.ncard ≤ 4
  · interval_cases _ : A.ncard <;> simp_all +decide [ Set.ncard_eq_toFinset_card' ]
    · exact?
    · obtain ⟨ a, rfl ⟩ := ‹∃ a, A = { a } ›; use { a } ; norm_num [ isSidon_singleton ]
    · -- Since A has exactly 2 elements, we can take S = A.
      use A; simp [*]
      obtain ⟨ x, hx, y, hy, hxy ⟩ := Set.ncard_eq_two.mp ‹_›; simp_all +decide [ IsSidon ] ; norm_num
      exact ⟨ fun h => y <| by linarith, fun h => by linarith ⟩
    · obtain ⟨ x, y, z, h ⟩ := Set.ncard_eq_three.mp ‹_›
      use {x, y}
      simp_all +decide [ Set.subset_def, IsSidon ]
      exact ⟨ fun h' => h.1 <| by linarith, fun h' => by linarith ⟩
    · obtain ⟨ S, hS₁, hS₂, hS₃ ⟩ := exists_sidon_three_of_four hA ‹_› ( hdiff A ( Set.Subset.refl _ ) ‹_› ) ; exact ⟨ S, hS₁, hS₂, by norm_num [ hS₃ ] ⟩
  · exact False.elim <| no_five_element_set hA ( by linarith ) hdiff

/-- What is the supremum of the set of admissible numbers? -/
@[category research open, AMS 5]
theorem erdos_757 {A : Set ℝ} :
    answer(sorry) = sSup {c | IsAdmissible c} := by
  sorry

/-- The supremum is strictly larger than `1 / 2`, which is proved in [GyLe95]. -/
