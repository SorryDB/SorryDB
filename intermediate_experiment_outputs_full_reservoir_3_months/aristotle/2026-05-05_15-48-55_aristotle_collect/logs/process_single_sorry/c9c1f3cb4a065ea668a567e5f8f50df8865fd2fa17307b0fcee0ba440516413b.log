/-- The quantum capacity is the limit of the coherent information of n-copy uses of the channel. -/
theorem quantumCapacity_eq_piProd_coherentInfo (őõ : CPTPMap d‚āĀ d‚āā) : őõ.quantumCapacity =
    sSup { r : ‚ĄĚ | ‚ąÉ n ŌĀ, r = coherentInfo ŌĀ (CPTPMap.piProd (fun (_ : Fin n) ‚Ü¶ őõ))} := by
