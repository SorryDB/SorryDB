  refine isBernoulliOn_congr ?_
  filter_upwards [hX.ae_subset, hY.ae_subset] with ω hXω hYω
  rw [Set.diff_inter, Set.diff_diff_cancel_left hXω, Set.diff_diff_cancel_left hYω]

end ProbabilityTheory
