lemma MeasureTheory.addHaarScalarFactor_prodLocalComponents_eq_one (φ : V ≃ₗ[ℚ] V) :
    addEquivAddHaarChar (Aux.prodLocalComponents V φ) = 1 := by
  -- product formula
  unfold Aux.prodLocalComponents
  rw [MeasureTheory.addEquivAddHaarChar_prodCongr]
  -- let J : Set (IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) :=
  --   {v | v.valuation ℚ (φ.det) = 1}
  -- have : Fact (Filter.cofinite ≤ Filter.principal J) := sorry
  have hφ : ∀ᶠ v in Filter.cofinite, Set.BijOn
    ⇑((fun v ↦ ((Aux.continuousBaseChange
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v) φ).toContinuousAddEquiv)) v)
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :=
    sorry
  rw [MeasureTheory.addEquivAddHaarChar_restrictedProductCongrRight _ hφ]
  -- this is now close to the product formula
  -- Rewrite addEquivAddHaarChar in terms of ringHaarChar of determinant
  simp_rw [addEquivAddHaarChar_eq_ringHaarChar_det]
  -- Simplify the determinant of the base change to algebraMap of the original determinant
  have hdet : ∀ (R : Type) [CommRing R] [Field R] [Algebra ℚ R] [TopologicalSpace R]
      [IsTopologicalRing R],
      (Aux.continuousBaseChange R φ).toLinearEquiv.det =
      Units.map (algebraMap ℚ R).toMonoidHom φ.det := by
    intro R _ _ _ _ _
    show LinearEquiv.det (TensorProduct.RightActions.LinearEquiv.baseChange ℚ V V R φ) = _
    have h : (TensorProduct.RightActions.LinearEquiv.baseChange ℚ V V R φ).toLinearMap =
        ↑(TensorProduct.RightActions.Module.TensorProduct.comm ℚ R V) ∘ₗ
        (LinearEquiv.baseChange ℚ R V V φ).toLinearMap ∘ₗ
        ↑(TensorProduct.RightActions.Module.TensorProduct.comm ℚ R V).symm := by
      ext; simp [TensorProduct.RightActions.LinearEquiv.baseChange,
                 TensorProduct.RightActions.LinearMap.baseChange]
    ext; simp [LinearEquiv.det_apply, h, LinearMap.det_conj, LinearEquiv.det_baseChange]
  simp_rw [hdet]
  -- Apply the product formula: ∏_v |det(φ)|_v = 1 for φ.det ∈ ℚˣ
  rw [← ringHaarChar_adeles_rat]
  exact ringHaarChar_adeles_units_rat_eq_one φ.det

