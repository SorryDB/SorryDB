lemma agents_le_two_mul_initPart (S : List (Call m)) (hm : 1 < m)
    (hexp : allExpert (after S)) :
    m ≤ 2 * (S.filter (fun c => isInitialCall S c)).length := by
      -- For each agent k, the initial call for k is the first call in S where k is involved. Since every agent must be involved in at least one call to become an expert, each agent's initial call is included in the filtered list.
      have h_initial_calls : ∀ k : Fin m, ∃ c ∈ S.filter (isInitialCall S), c.fst = k ∨ c.snd = k := by
        intro k
        obtain ⟨c, hcS, hc⟩ : ∃ c ∈ S, c.fst = k ∨ c.snd = k := by
          exact agent_has_call S hm hexp k;
        -- By definition of `initial`, we know that `initial S k = some (f k)`.
        obtain ⟨f_k, hf_k⟩ : ∃ f_k, initial S k = some f_k := by
          exact Option.isSome_iff_exists.mp ( List.find?_isSome.mpr ⟨ c, hcS, by aesop ⟩ );
        refine ⟨f_k, List.mem_filter.mpr ⟨List.mem_of_find?_eq_some hf_k, ?_⟩, ?_⟩
        · -- isInitialCall S f_k = true
          unfold isInitialCall isAgentInitialCall
          simp only [Bool.decide_or, Bool.or_eq_true, decide_eq_true_eq]
          have := List.find?_some hf_k
          simp only [decide_eq_true_eq] at this
          rcases this with h1 | h2
          · left; rw [h1]; exact hf_k
          · right; rw [h2]; exact hf_k
        · -- f_k.fst = k ∨ f_k.snd = k
          have := List.find?_some hf_k
          simp only [decide_eq_true_eq] at this
          exact this
      -- By counting the number of initial calls, we can show that each agent is involved in at least one initial call.
      have h_count_initial_calls : Finset.card (Finset.image (fun c => c.fst) (Finset.filter (fun c => isInitialCall S c) S.toFinset)) + Finset.card (Finset.image (fun c => c.snd) (Finset.filter (fun c => isInitialCall S c) S.toFinset)) ≥ m := by
        have h_count_initial_calls : Finset.image (fun c => c.fst) (Finset.filter (fun c => isInitialCall S c) S.toFinset) ∪ Finset.image (fun c => c.snd) (Finset.filter (fun c => isInitialCall S c) S.toFinset) = Finset.univ := by
          ext k; specialize h_initial_calls k; aesop;
        have := Finset.card_union_le ( Finset.image ( fun c => c.1 ) ( Finset.filter ( fun c => isInitialCall S c = true ) S.toFinset ) ) ( Finset.image ( fun c => c.2 ) ( Finset.filter ( fun c => isInitialCall S c = true ) S.toFinset ) ) ; aesop;
      refine le_trans h_count_initial_calls ?_;
      refine' le_trans ( add_le_add ( Finset.card_image_le ) ( Finset.card_image_le ) ) _;
      rw [ two_mul ];
      exact add_le_add ( le_trans ( Finset.card_le_card <| show { c ∈ S.toFinset | isInitialCall S c = true } ⊆ ( List.filter ( fun c => isInitialCall S c ) S ).toFinset from fun x hx => by aesop ) <| List.toFinset_card_le _ ) ( le_trans ( Finset.card_le_card <| show { c ∈ S.toFinset | isInitialCall S c = true } ⊆ ( List.filter ( fun c => isInitialCall S c ) S ).toFinset from fun x hx => by aesop ) <| List.toFinset_card_le _ )

