import VCVio.EvalDist.Monad.Basic
import ToMathlib.Control.OptionT

/-!
# Probability Distributions on `Option` return types

File for lemmas about `evalDist` on optional values.
-/

universe u v w

variable {m : Type u → Type v} [Monad m] [LawfulMonad m] [HasEvalSPMF m] {α β γ : Type u}

private lemma spmf_map_some_run (p : SPMF α) (x : α) :
    (some <$> p).run (some (some x)) = p.run (some x) := by
  rw [map_eq_pure_bind]
  simp only [OptionT.monad_bind_eq_bind, OptionT.bind, OptionT.monad_pure_eq_pure, OptionT.pure]
  show (PMF.bind p.run fun o => match o with
    | some a => PMF.pure (some (some a))
    | none => PMF.pure none) (some (some x)) = p.run (some x)
  simp only [PMF.bind_apply]
  refine (tsum_eq_single (some x) ?_).trans ?_
  · intro o ho
    cases o with
    | none => simp [PMF.pure_apply]
    | some a =>
      have : a ≠ x := fun h => ho (congrArg some h)
      simp [PMF.pure_apply, Option.some.injEq, Ne.symm this]
  · simp [PMF.pure_apply]

@[simp] lemma probOutput_some_map_some (mx : m α) (x : α) :
    Pr[= some x | some <$> mx] = Pr[= x | mx] := by
  simp only [probOutput_def, evalDist, MonadHom.mmap_map, SPMF.apply_eq_run_some]
  exact spmf_map_some_run _ _

@[simp] lemma probOutput_some_map_none (mx : m α) :
    Pr[= none | some <$> mx] = 0 := sorry

