import Mathlib


open scoped Affine Finset
open Module

namespace IMO2025P1

/-- The `x`-axis, as an affine subspace. -/
noncomputable def xAxis : AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2)) where
  carrier := {p | p 1 = 0}
  smul_vsub_vadd_mem c p₁ p₂ p₃ hp₁ hp₂ hp₃ := by simp_all

/-- The `y`-axis, as an affine subspace. -/
noncomputable def yAxis : AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2)) where
  carrier := {p | p 0 = 0}
  smul_vsub_vadd_mem c p₁ p₂ p₃ hp₁ hp₂ hp₃ := by simp_all

/- The line `x+y=0`, as an affine subspace. -/
noncomputable def linexy0 : AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2)) where
  carrier := {p | p 0 + p 1 = 0}
  smul_vsub_vadd_mem c p₁ p₂ p₃ hp₁ hp₂ hp₃ := by
    simp only [Fin.isValue, vsub_eq_sub, vadd_eq_add, Set.mem_setOf_eq, PiLp.add_apply,
      PiLp.smul_apply, PiLp.sub_apply, smul_eq_mul]
    suffices c * (p₁ 0 + p₁ 1 - (p₂ 0 + p₂ 1)) + (p₃ 0 + p₃ 1) = 0 by
      rw [← this]
      ring
    simp_all

/-- The condition on lines in the problem. -/
def Sunny (s : AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))) : Prop :=
   ¬ s ∥ xAxis ∧ ¬ s ∥ yAxis ∧ ¬ s ∥ linexy0

/-- The answer to be determined: the set of achievable numbers of sunny lines is {0, 1, 3}
for all n ≥ 3. -/
def answer : (Set.Ici 3) → Set ℕ := fun _ => {0, 1, 3}

/-- Helper: finrank of the direction of affineSpan of two distinct points is 1. -/
lemma finrank_direction_affineSpan_pair {p q : EuclideanSpace ℝ (Fin 2)} (hpq : p ≠ q) :
    finrank ℝ (affineSpan ℝ ({p, q} : Set (EuclideanSpace ℝ (Fin 2)))).direction = 1 := by
  have hp : p ∈ affineSpan ℝ ({p} : Set (EuclideanSpace ℝ (Fin 2))) :=
    subset_affineSpan ℝ _ rfl
  rw [show ({p, q} : Set _) = insert q ({p} : Set _) from by ext; simp [or_comm],
    ← AffineSubspace.coe_affineSpan_singleton ℝ (EuclideanSpace ℝ (Fin 2)) p,
    AffineSubspace.direction_affineSpan_insert hp,
    show (affineSpan ℝ ({p} : Set (EuclideanSpace ℝ (Fin 2)))).direction = ⊥ from by
      rw [AffineSubspace.direction_eq_vectorSpan, AffineSubspace.coe_affineSpan_singleton]
      simp [vectorSpan],
    sup_bot_eq]
  exact finrank_span_singleton (vsub_ne_zero.mpr (Ne.symm hpq))

lemma zero_achievable (n : Set.Ici 3) :
    0 ∈ {k | ∃ lines : Finset (AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))),
      have : DecidablePred Sunny := Classical.decPred _;
      #lines = n ∧ (∀ l ∈ lines, finrank ℝ l.direction = 1) ∧
      (∀ a b : ℕ, 0 < a → 0 < b → a + b ≤ (n : ℕ) + 1 → ∃ l ∈ lines, !₂[(a : ℝ), b] ∈ l) ∧
      #{l ∈ lines | Sunny l} = k} := by
  sorry

lemma one_achievable (n : Set.Ici 3) :
    1 ∈ {k | ∃ lines : Finset (AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))),
      have : DecidablePred Sunny := Classical.decPred _;
      #lines = n ∧ (∀ l ∈ lines, finrank ℝ l.direction = 1) ∧
      (∀ a b : ℕ, 0 < a → 0 < b → a + b ≤ (n : ℕ) + 1 → ∃ l ∈ lines, !₂[(a : ℝ), b] ∈ l) ∧
      #{l ∈ lines | Sunny l} = k} := by
  sorry

lemma three_achievable (n : Set.Ici 3) :
    3 ∈ {k | ∃ lines : Finset (AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))),
      have : DecidablePred Sunny := Classical.decPred _;
      #lines = n ∧ (∀ l ∈ lines, finrank ℝ l.direction = 1) ∧
      (∀ a b : ℕ, 0 < a → 0 < b → a + b ≤ (n : ℕ) + 1 → ∃ l ∈ lines, !₂[(a : ℝ), b] ∈ l) ∧
      #{l ∈ lines | Sunny l} = k} := by
  sorry

lemma achievable_subset (n : Set.Ici 3) (k : ℕ)
    (hk : k ∈ {k | ∃ lines : Finset (AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))),
      have : DecidablePred Sunny := Classical.decPred _;
      #lines = n ∧ (∀ l ∈ lines, finrank ℝ l.direction = 1) ∧
      (∀ a b : ℕ, 0 < a → 0 < b → a + b ≤ (n : ℕ) + 1 → ∃ l ∈ lines, !₂[(a : ℝ), b] ∈ l) ∧
      #{l ∈ lines | Sunny l} = k}) :
    k ∈ ({0, 1, 3} : Set ℕ) := by
  sorry

theorem result (n : Set.Ici 3) :
    {k | ∃ lines : Finset (AffineSubspace ℝ (EuclideanSpace ℝ (Fin 2))),
      have : DecidablePred Sunny := Classical.decPred _;
      #lines = n ∧ (∀ l ∈ lines, finrank ℝ l.direction = 1) ∧
      (∀ a b : ℕ, 0 < a → 0 < b → a + b ≤ (n : ℕ) + 1 → ∃ l ∈ lines, !₂[(a : ℝ), b] ∈ l) ∧
      #{l ∈ lines | Sunny l} = k} = answer n := by
  ext k
  simp only [Set.mem_setOf_eq, answer, Set.mem_insert_iff, Set.mem_singleton_iff]
  constructor
  · exact achievable_subset n k
  · rintro (rfl | rfl | rfl)
