            -- use h_index_valid

            apply Nat.zero_lt_of_ne_zero
            rw [ne_eq (List.length a) 0]
            rw [List.length_eq_zero_iff]
            have proof_condition : List.foldl afunc [] allChildren = [] ↔ ¬ ∃ location ∈ allChildren, location.2 = index₁ := by
