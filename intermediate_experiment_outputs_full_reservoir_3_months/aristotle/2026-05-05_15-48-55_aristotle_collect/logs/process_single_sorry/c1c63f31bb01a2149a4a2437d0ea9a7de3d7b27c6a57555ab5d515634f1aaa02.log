import Mathlib.MeasureTheory.Integral.IntervalAverage
import MiscYD.PhD.VCDim.UnifAP.Defs

/-!
# Fourier analysis of uniformly almost periodic functions
-/

open Filter
open scoped Topology

variable {Λ : ℝ} {f : ℝ → ℂ}

variable (f) in
/-- The **mean** of an uniformly almost periodic function `f` is the limit of its average on
`[0, X]` as `X → +∞`. -/
noncomputable def mean : ℂ := limUnder atTop fun X ↦ ⨍ x in (0)..X, f x

lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := sorry

variable (Λ f) in
/-- The **Fourier coefficient** at `Λ` of an uniformly almost periodic function `f` is the mean of
`x ↦ f x * exp (-iΛx)`. -/
noncomputable def fourierCoeff : ℂ := mean fun x ↦ f x * .exp (-.I * Λ * x)

/-- **Bessel's inequality** for uniformly almost periodic functions: the set of frequencies where
the Fourier coefficient norm is at least `ε` is finite. -/
lemma IsUnifAlmostPeriodic.finite_of_fourierCoeff_norm_le (hf : IsUnifAlmostPeriodic f)
    {ε : ℝ} (hε : 0 < ε) : Set.Finite {Λ | ε ≤ ‖fourierCoeff Λ f‖} := sorry

-- The original statement was missing the `IsUnifAlmostPeriodic f` hypothesis, which is needed
-- since `fourierCoeff` uses `limUnder` (which can return arbitrary junk values for non-convergent
-- averages of non-UAP functions). The hypothesis has been added.
/-- The **Fourier exponents** of an uniformly almost periodic function `f` are at most countable. -/
lemma IsUnifAlmostPeriodic.countable_fourierCoeff_ne_zero (hf : IsUnifAlmostPeriodic f) :
    {Λ | fourierCoeff Λ f ≠ 0}.Countable := by
  have h_countable : ∀ n : ℕ, Set.Countable {Λ | 1 / ((n : ℝ) + 1) ≤ ‖fourierCoeff Λ f‖} :=
    fun n => (hf.finite_of_fourierCoeff_norm_le (by positivity)).countable
  refine Set.Countable.mono ?_ (Set.countable_iUnion h_countable)
  intro Λ hΛ
  simp only [Set.mem_iUnion, Set.mem_setOf_eq]
  have hpos : 0 < ‖fourierCoeff Λ f‖ := norm_pos_iff.mpr hΛ
  obtain ⟨n, hn⟩ := exists_nat_gt (‖fourierCoeff Λ f‖⁻¹)
  exact ⟨n, by rw [div_le_iff₀ (by positivity : (0:ℝ) < (n:ℝ) + 1)]
               nlinarith [mul_inv_cancel₀ (ne_of_gt hpos)]⟩

