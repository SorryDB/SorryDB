import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  refine' ⟨ fun h => _, _ ⟩;
  · -- From Lemma 2, we know that either $f(1) = 1$ or $f(1) = 1$.
    have h_f1 : f 1 = 1 := by
      have := h 1 1 1 1 ; norm_num at this;
      rw [ div_eq_iff ] at this <;> nlinarith [ h₁ 1 zero_lt_one ];
    -- From Lemma 3, we know that $f(t) \in \{t, 1/t\}$ for each $t > 0$.
    have h_ft : ∀ t > 0, f t = t ∨ f t = 1 / t := by
      -- Set $w = t$, $x = 1$, $y = z = \sqrt{t}$ for $t > 0$ (wx = t, yz = \sqrt{t} \cdot \sqrt{t} = t).
      intros t ht
      have := h t 1 (Real.sqrt t) (Real.sqrt t) ht zero_lt_one (Real.sqrt_pos.mpr ht) (Real.sqrt_pos.mpr ht) (by
      rw [ Real.mul_self_sqrt ht.le, mul_one ]);
      simp_all +decide [ le_of_lt ht ];
      field_simp at this ⊢;
      exact Classical.or_iff_not_imp_left.2 fun h => mul_left_cancel₀ ( sub_ne_zero_of_ne h ) <| by rw [ div_eq_iff ( ne_of_gt ( h₁ t ht ) ) ] at this; nlinarith;
    -- Suppose there exist $a, b > 0$ such that $f(a) = a$ and $f(b) = 1/b$.
    by_contra h_contra
    obtain ⟨a, ha⟩ : ∃ a > 0, f a = a ∧ a ≠ 1 := by
      simp +zetaDelta at *;
      obtain ⟨ ⟨ x, hx₁, hx₂ ⟩, y, hy₁, hy₂ ⟩ := h_contra; cases h_ft x hx₁ <;> cases h_ft y hy₁ <;> use y <;> aesop;
    obtain ⟨b, hb⟩ : ∃ b > 0, f b = 1 / b ∧ b ≠ 1 := by
      grind +ring;
    -- Consider $f(ab)$. Using $w=a$, $x=b$, $y=z=\sqrt{ab}$, we get $\frac{f(a)^2 + f(b)^2}{f(ab) + f(ab)} = \frac{a^2 + b^2}{2ab}$.
    have h_ab : (f a ^ 2 + f b ^ 2) / (2 * f (a * b)) = (a ^ 2 + b ^ 2) / (2 * a * b) := by
      convert h a b ( Real.sqrt ( a * b ) ) ( Real.sqrt ( a * b ) ) ha.1 hb.1 ( Real.sqrt_pos.mpr ( mul_pos ha.1 hb.1 ) ) ( Real.sqrt_pos.mpr ( mul_pos ha.1 hb.1 ) ) ( by rw [ Real.mul_self_sqrt ( mul_nonneg ha.1.le hb.1.le ) ] ) using 1 <;> ring;
      · rw [ Real.sq_sqrt ( mul_nonneg ha.1.le hb.1.le ) ];
      · rw [ inv_pow, Real.sq_sqrt ( mul_nonneg ha.1.le hb.1.le ) ] ; ring;
    cases h_ft ( a * b ) ( mul_pos ha.1 hb.1 ) <;> simp_all +decide [ ne_of_gt, division_def ];
    · -- Simplify the equation obtained from the functional equation.
      field_simp at h_ab;
      simp_all +decide [ ne_of_gt, division_def ];
      rw [ inv_eq_one_div, div_eq_iff ] at h_ab <;> nlinarith [ mul_self_pos.2 ( sub_ne_zero.2 hb.2.2 ), pow_pos hb.1 3 ];
    · -- Simplify the equation obtained from the functional equation.
      field_simp at h_ab;
      rw [ eq_div_iff ] at h_ab <;> ring_nf at * <;> simp_all +decide [ ne_of_gt, division_def ];
      exact ha.2.2 ( by nlinarith [ pow_pos ha.1 2, pow_pos ha.1 3 ] );
  · rintro ( h | h ) w x y z hw hx hy hz <;> simp_all +decide [ ne_of_gt, sq ];
    field_simp;
    grind +ring

