import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real
open EuclideanGeometry

/-- All six sub-angles are positive for P in the interior. -/
private lemma sub_angles_pos
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    0 < ∠ P A B ∧ 0 < ∠ P A C ∧
    0 < ∠ P B A ∧ 0 < ∠ P B C ∧
    0 < ∠ P C A ∧ 0 < ∠ P C B := by
  sorry

/-- The six sub-angles sum to π. -/
private lemma six_angles_sum
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B + ∠ P A C + ∠ P B A + ∠ P B C + ∠ P C A + ∠ P C B = π := by
  sorry

/-- Trigonometric Ceva from the area formula. -/
private lemma trig_ceva
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    Real.sin (∠ P A B) * Real.sin (∠ P B C) * Real.sin (∠ P C A) =
    Real.sin (∠ P A C) * Real.sin (∠ P B A) * Real.sin (∠ P C B) := by
  sorry

/-- sin x > 1/2 on (π/6, 5π/6). -/
private lemma sin_gt_half (x : ℝ) (h1 : π / 6 < x) (h2 : x < 5 * π / 6) :
    Real.sin x > 1 / 2 := by
  by_cases h : x ≤ π / 2
  · rw [← Real.cos_pi_div_two_sub, ← Real.cos_pi_div_three]
    exact Real.cos_lt_cos_of_nonneg_of_le_pi (by linarith) (by linarith) (by linarith)
  · rw [← Real.cos_sub_pi_div_two, ← Real.cos_pi_div_three]
    exact Real.cos_lt_cos_of_nonneg_of_le_pi (by linarith) (by linarith) (by linarith)

/-- Product of sines < 1/8 for positive angles summing to < π/2. -/
private lemma sin_prod_lt (x y z : ℝ) (hx : 0 < x) (hy : 0 < y) (hz : 0 < z)
    (hsum : x + y + z < π / 2) :
    Real.sin x * Real.sin y * Real.sin z < 1 / 8 := by
  have h1 : Real.sin x * Real.sin y ≤ (1 - Real.cos (x + y)) / 2 := by
    have : Real.sin x * Real.sin y ≤ 1 / 2 * (Real.cos (x - y) - Real.cos (x + y)) := by
      rw [Real.cos_sub, Real.cos_add]; linarith
    linarith [Real.cos_le_one (x - y)]
  have h2 : Real.sin z ≤ Real.cos (x + y) := by
    rw [← Real.cos_pi_div_two_sub]
    exact Real.cos_le_cos_of_nonneg_of_le_pi (by linarith) (by linarith) (by linarith)
  refine lt_of_le_of_lt (mul_le_mul_of_nonneg_right h1 <|
    Real.sin_nonneg_of_nonneg_of_le_pi hz.le (by linarith)) ?_
  have h3 : Real.cos (x + y) > Real.sin z := by
    rw [← Real.cos_pi_div_two_sub]
    exact Real.cos_lt_cos_of_nonneg_of_le_pi (by linarith) (by linarith) (by linarith)
