import Mathlib

namespace IMO2020P4

/-- A cable car's starting and finishing points. -/
structure Car (n : ℕ) : Type where
  /-- The starting point. -/
  start : Fin (n ^ 2)
  /-- The finishing point. -/
  finish : Fin (n ^ 2)
  start_lt_finish : start < finish

/-- The cable cars of a company. -/
structure Company (n k : ℕ) : Type where
  /-- The individual cars. -/
  cars : Fin k → Car n
  injective_start : Function.Injective fun i ↦ (cars i).start
  injective_finish : Function.Injective fun i ↦ (cars i).finish
  monovary_start_finish : Monovary (fun i ↦ (cars i).start) (fun i ↦ (cars i).finish)

/-- A linkage between two stations. -/
structure Company.linkage {n k : ℕ} (c : Company n k) : Type where
  /-- The sequence of cars used. -/
  cars : List (Fin k)
  nonempty : cars ≠ []
  valid : cars.IsChain fun i j ↦ (c.cars i).finish = (c.cars j).start

/-- The first station in a linkage. -/
def Company.linkage.start {n k : ℕ} {c : Company n k} (x : c.linkage) : Fin (n ^ 2) :=
  (c.cars (x.cars.head x.nonempty)).start

/-- The last station in a linkage. -/
def Company.linkage.finish {n k : ℕ} {c : Company n k} (x : c.linkage) : Fin (n ^ 2) :=
  (c.cars (x.cars.getLast x.nonempty)).finish

/-- The property of two stations being linked (in the given order). -/
def Company.linked {n k : ℕ} (c : Company n k) (l h : Fin (n ^ 2)) : Prop :=
  ∃ x : c.linkage, x.start = l ∧ x.finish = h

/-- The answer to be determined. -/
def answer : (Set.Ioi 1) → ℕ := fun n => (↑n : ℕ) * ((↑n : ℕ) - 1) + 1

/-! ## Key lemmas -/

/-- The set of finish stations. -/
noncomputable def Company.finishSet {n k : ℕ} (c : Company n k) : Finset (Fin (n ^ 2)) :=
  Finset.image (fun i ↦ (c.cars i).finish) Finset.univ

/-- Given a station that is a finish, find the unique car whose finish is that station. -/
noncomputable def Company.predCar {n k : ℕ} (c : Company n k) (v : Fin (n ^ 2))
    (hv : v ∈ c.finishSet) : Fin k :=
  (Finset.mem_image.mp hv).choose

/-- The predecessor car's finish is v. -/
lemma Company.predCar_finish {n k : ℕ} (c : Company n k) (v : Fin (n ^ 2))
    (hv : v ∈ c.finishSet) : (c.cars (c.predCar v hv)).finish = v :=
  (Finset.mem_image.mp hv).choose_spec.2

open Classical in
/-- The root function: follows predecessors to find the start of the chain. -/
noncomputable def Company.root {n k : ℕ} (C : Company n k) : Fin (n ^ 2) → Fin (n ^ 2) :=
  fun v => if h : v ∈ C.finishSet then
    have : (C.cars (C.predCar v h)).start < v := by
      have := (C.cars (C.predCar v h)).start_lt_finish
      rwa [Company.predCar_finish] at this
    C.root (C.cars (C.predCar v h)).start
  else v
termination_by v => v

/-
PROVIDED SOLUTION
The root function maps each station to a station that is a start but not a finish (a "root" of its chain). So the image of root on all stations is a subset of startSet \ finishSet. The cardinality of startSet \ finishSet equals activeSet.card - k where activeSet = startSet ∪ finishSet. Since activeSet.card ≤ n², this gives at most n²-k.

More precisely:
1. Show root(v) ∈ startSet \ finishSet for all v, by induction on the well-founded recursion. If v ∉ finishSet, then root(v) = v. In this case, if v ∈ startSet, we're done. If v ∉ startSet either, then v is not active, so root(v) = v. But we need root(v) ∈ startSet... hmm.

Actually, the root function maps v to itself if v ∉ finishSet. If v is also not in startSet, then root(v) = v which is NOT in startSet \ finishSet. So the image of root is not a subset of startSet \ finishSet.

Let me reconsider: the image of root on ALL of Fin(n²) includes non-active stations mapped to themselves. So the image has at most |startSet \ finishSet| + |non-active stations| = (activeSet.card - k) + (n² - activeSet.card) = n² - k values. This uses that startSet \ finishSet has card activeSet.card - k and non-active stations have card n² - activeSet.card.

So (Finset.image C.root Finset.univ).card ≤ (activeSet.card - k) + (n² - activeSet.card) = n² - k.

For the proof: root(v) is either in startSet \ finishSet (when v is active and follows the chain to a root) or equals v (when v is not a finish). In the latter case, v is not in finishSet, so either v ∈ startSet (contributing to startSet \ finishSet) or v ∉ startSet ∪ finishSet (contributing to non-active singletons).

The image of root is contained in (startSet \ finishSet) ∪ (Finset.univ \ (startSet ∪ finishSet)), which has cardinality |startSet \ finishSet| + |Finset.univ \ activeSet| = (activeSet.card - k) + (n² - activeSet.card) = n² - k.
-/
open Classical in
/-- The root's image has at most n²-k values (the roots = starts \ finishes). -/
lemma Company.root_image_card {n k : ℕ} (C : Company n k) :
    (Finset.image C.root Finset.univ).card ≤ n ^ 2 - k := by
  -- Let's first show that the image of root is contained in a subset of size at most $n^2 - k$.
  have h_subset : (Finset.image C.root Finset.univ) ⊆ Finset.univ \ Finset.image (fun i => (C.cars i).finish) Finset.univ := by
    intro v
    simp;
    intro x hx y hy; rw [ ← hx ] at hy;
    -- By definition of $root$, we know that $root(x)$ is not in the range of $finish$.
    have h_root_not_finish : ∀ x : Fin (n ^ 2), C.root x ∉ Finset.image (fun i => (C.cars i).finish) Finset.univ := by
      intro x; exact (by
      induction' x with x ih;
      induction' x using Nat.strong_induction_on with x ih;
      unfold Company.root;
      split_ifs <;> simp_all +decide [ Finset.mem_image ];
      · intro z hz; specialize ih ( C.cars ( C.predCar ⟨ x, by assumption ⟩ ‹_› ) |> Car.start |> Fin.val ) ( by
          convert ( C.cars ( C.predCar ⟨ x, by assumption ⟩ ‹_› ) |> Car.start_lt_finish ) using 1;
          rw [ Company.predCar_finish ] ; aesop ) ( by
          exact Fin.is_lt _ ) z; aesop;
      · exact fun i hi => ‹¬⟨ x, by assumption ⟩ ∈ C.finishSet› <| Finset.mem_image.mpr ⟨ i, Finset.mem_univ _, hi ⟩);
    exact h_root_not_finish x ( Finset.mem_image.mpr ⟨ y, Finset.mem_univ _, hy ⟩ );
  refine le_trans ( Finset.card_le_card h_subset ) ?_;
  rw [ Finset.card_sdiff ] ; norm_num [ Finset.card_image_of_injective _ C.injective_finish ]

open Classical in
/-- Same root and s < t implies linked. -/
lemma Company.linked_of_same_root {n k : ℕ} (C : Company n k)
    {s t : Fin (n ^ 2)} (hs : C.root s = C.root t) (hlt : s < t) :
    C.linked s t := by
  sorry

/-
PROVIDED SOLUTION
We need to find distinct s, t with A.root s = A.root t and B.root s = B.root t.

Consider the function f : Fin(n²) → Fin(n²) × Fin(n²) given by f(v) = (A.root v, B.root v).

The image of f has cardinality at most |image(A.root)| × |image(B.root)| ≤ (n²-k) × (n²-k) where k = n*(n-1)+1.

Since n²-k = n-1, the image has at most (n-1)² elements.

Since |Fin(n²)| = n² > (n-1)² (because n² - (n-1)² = 2n-1 > 0 for n ≥ 1), by the pigeonhole principle, f is not injective: there exist s ≠ t with f(s) = f(t), meaning A.root s = A.root t and B.root s = B.root t.

Use Finset.exists_ne_map_eq_of_card_lt or the contrapositive: if f were injective on Finset.univ, then |Finset.univ| = n² ≤ |image(f)| ≤ (n-1)² < n², contradiction.

Key arithmetic: n²-k = n²-(n*(n-1)+1) = n²-n²+n-1 = n-1 (for n ≥ 1, since n*(n-1) = n²-n). And (n-1)² < n² for n ≥ 2.
-/
open Classical in
/-- Upper bound: any two companies with n*(n-1)+1 cars share a linked pair. -/
lemma upper_bound {n : ℕ} (hn : 1 < n) (A B : Company n (n * (n - 1) + 1)) :
    ∃ i j : Fin (n ^ 2), A.linked i j ∧ B.linked i j := by
  -- The root image for each company has at most n-1 values
  have hA := A.root_image_card  -- image card ≤ n² - k = n - 1
  have hB := B.root_image_card
  -- n² > (n²-k)² = (n-1)², so by pigeonhole two stations share (root_A, root_B)
  -- There exist distinct stations with the same (root_A, root_B)
  have h_pigeonhole : ∃ s t : Fin (n ^ 2), s ≠ t ∧ A.root s = A.root t ∧ B.root s = B.root t := by
    -- By the pigeonhole principle, since there are $n^2$ stations and at most $k$ roots, at least two stations must map to the same root pair.
    have h_pigeonhole : Finset.card (Finset.image (fun v => (A.root v, B.root v)) Finset.univ) ≤ (n - 1) ^ 2 := by
      have h_pigeonhole : (Finset.image (fun v => (A.root v, B.root v)) Finset.univ).card ≤ (Finset.image A.root Finset.univ).card * (Finset.image B.root Finset.univ).card := by
        rw [ ← Finset.card_product ] ; exact Finset.card_le_card fun x hx => by aesop;
      exact h_pigeonhole.trans <| by rw [ show n ^ 2 - ( n * ( n - 1 ) + 1 ) = n - 1 by exact Nat.sub_eq_of_eq_add <| by nlinarith only [ Nat.sub_add_cancel hn.le, Nat.sub_add_cancel <| show 1 ≤ n from hn.le ] ] at *; nlinarith;
    contrapose! h_pigeonhole;
    rw [ Finset.card_image_of_injective _ fun s t h => Classical.not_not.1 fun hst => h_pigeonhole s t hst ( by injection h ) ( by injection h ) ] ; cases n <;> norm_num [ Nat.mul_succ, pow_succ' ] at * ; nlinarith;
  obtain ⟨s, t, hne, hrA, hrB⟩ := h_pigeonhole
  rcases lt_or_gt_of_ne (show s ≠ t from hne) with hlt | hlt
  · exact ⟨s, t, A.linked_of_same_root hrA hlt, B.linked_of_same_root hrB hlt⟩
  · exact ⟨t, s, A.linked_of_same_root hrA.symm hlt, B.linked_of_same_root hrB.symm hlt⟩

/-
PROBLEM
A linkage's start is strictly less than its finish.

PROVIDED SOLUTION
A linkage is a non-empty list of car indices where consecutive cars have matching finish/start. The start of the linkage is the start of the first car, and the finish is the finish of the last car. Since each car has start < finish, and consecutive cars chain (finish of one = start of next), by induction on the list, the start of the first car is less than the finish of the last car.

More precisely: by induction on the list length.
- Base case (1 car): start = (c.cars a).start < (c.cars a).finish = finish. Use Car.start_lt_finish.
- Inductive case: the chain (a :: b :: rest) has (c.cars a).finish = (c.cars b).start by the chain condition. So (c.cars a).start < (c.cars a).finish = (c.cars b).start ≤ finish of (b :: rest) by induction.
-/
lemma Company.linkage_start_lt_finish {n k : ℕ} {c : Company n k} (x : c.linkage) :
    x.start < x.finish := by
  unfold Company.linkage.start Company.linkage.finish;
  rcases x with ⟨ l, hl ⟩;
  -- By induction on the length of the list `l`.
  induction' l with a l ih;
  · contradiction;
  · rcases l with ( _ | ⟨ b, l ⟩ ) <;> simp_all +decide [ List.IsChain ];
    · exact c.cars a |>.start_lt_finish;
    · rename_i h;
      exact lt_trans ( c.cars a |> Car.start_lt_finish ) ( by have := h; rw [ List.isChain_iff_getElem ] at this; aesop )

/-- If c links i to j then i < j. -/
lemma Company.linked_lt {n k : ℕ} {c : Company n k} {i j : Fin (n ^ 2)}
    (h : c.linked i j) : i < j := by
  obtain ⟨x, rfl, rfl⟩ := h
  exact Company.linkage_start_lt_finish x

/-
PROBLEM
Lower bound: there exist two companies with n*(n-1) cars sharing no linked pair.

PROVIDED SOLUTION
We construct two companies A (horizontal) and B (vertical) with n*(n-1) cars.

Company B (vertical, simpler): Car i has start = ⟨i, _⟩ and finish = ⟨i + n, _⟩. The bound proofs: i < n*(n-1) ≤ n^2 (since n-1 ≤ n, we have n*(n-1) ≤ n*n = n^2). For finish: i + n < n*(n-1) + n = n*(n-1+1) = n*n = n^2 (use Nat.succ_pred_eq_of_pos). Injective starts: trivial (start = i). Injective finishes: i+n = j+n implies i = j. Monovary: i ≤ j implies i+n ≤ j+n.

Company A (horizontal): Car i has start = ⟨i/(n-1)*n + i%(n-1), _⟩ and finish = ⟨i/(n-1)*n + i%(n-1) + 1, _⟩. Bounds use that i/(n-1) < n and i%(n-1) < n-1, so the value is < n*n = n^2. Injectivity: if the values are equal, then the quotient and remainder by n must agree (since the remainder part < n and the quotient determines the n-multiple), hence i = j (by Nat.div_add_mod). Monovary: finish = start + 1, so start_i ≤ start_j implies finish_i ≤ finish_j.

Disjointness: For ANY linkage of A, the start and finish stations are in the SAME ROW (same value of station/n). This is because each car of A connects station g*n+r to g*n+r+1, which are in the same row. A chain of such cars stays in the same row.

For ANY linkage of B, the start and finish stations are in the SAME COLUMN (same value of station%n). This is because each car of B connects station i to i+n, and i%n = (i+n)%n.

If (s,t) is linked by both A and B with s < t, then s/n = t/n (same row) and s%n = t%n (same column). But s = n*(s/n) + s%n = n*(t/n) + t%n = t, contradicting s < t.

Use Company.linked_lt to get s < t from the linked relation.
-/
set_option maxHeartbeats 800000 in
lemma lower_bound {n : ℕ} (hn : 1 < n) :
    ∃ A B : Company n (n * (n - 1)),
      ∀ i j : Fin (n ^ 2), ¬(A.linked i j ∧ B.linked i j) := by
  by_contra! h_contra;
  -- Define the companies A and B as described.
  set A : Company n (n * (n - 1)) := ⟨fun i => ⟨⟨i.val / (n - 1) * n + i.val % (n - 1), by
    have := Nat.div_add_mod i ( n - 1 );
    nlinarith [ Nat.zero_le ( i.val / ( n - 1 ) ), Nat.zero_le ( i.val % ( n - 1 ) ), Fin.is_lt i, Nat.sub_add_cancel hn.le ]⟩, ⟨i.val / (n - 1) * n + i.val % (n - 1) + 1, by
    nlinarith [ Nat.div_mul_le_self i.val ( n - 1 ), Nat.mod_add_div i.val ( n - 1 ), Nat.sub_add_cancel hn.le, Fin.is_lt i ]⟩, by
    exact Nat.lt_succ_self _⟩, by
    intro i j h_eq; simp_all +decide [ Fin.ext_iff ] ;
    -- Since $n > 1$, we have $i / (n - 1) = j / (n - 1)$ and $i % (n - 1) = j % (n - 1)$.
    have h_div_mod : i.val / (n - 1) = j.val / (n - 1) ∧ i.val % (n - 1) = j.val % (n - 1) := by
      have h_div_mod : i.val / (n - 1) = j.val / (n - 1) := by
        nlinarith [ Nat.zero_le ( i.val % ( n - 1 ) ), Nat.zero_le ( j.val % ( n - 1 ) ), Nat.mod_lt i.val ( Nat.sub_pos_of_lt hn ), Nat.mod_lt j.val ( Nat.sub_pos_of_lt hn ), Nat.sub_add_cancel hn.le ]
      generalize_proofs at *;
      aesop;
    rw [ ← Nat.div_add_mod i ( n - 1 ), ← Nat.div_add_mod j ( n - 1 ), h_div_mod.1, h_div_mod.2 ], by
    intro i j h_eq; simp_all +decide [ Fin.ext_iff ] ;
    -- Since $n > 1$, we have $i / (n - 1) = j / (n - 1)$ and $i % (n - 1) = j % (n - 1)$.
    have h_div_mod : i.val / (n - 1) = j.val / (n - 1) ∧ i.val % (n - 1) = j.val % (n - 1) := by
      have h_div_mod : i.val / (n - 1) = j.val / (n - 1) := by
        nlinarith [ Nat.zero_le ( i.val % ( n - 1 ) ), Nat.zero_le ( j.val % ( n - 1 ) ), Nat.mod_lt i.val ( Nat.sub_pos_of_lt hn ), Nat.mod_lt j.val ( Nat.sub_pos_of_lt hn ), Nat.sub_add_cancel hn.le ]
      generalize_proofs at *;
      aesop;
    rw [ ← Nat.div_add_mod i ( n - 1 ), ← Nat.div_add_mod j ( n - 1 ), h_div_mod.1, h_div_mod.2 ], by
    intro i j hij
    generalize_proofs at *;
    grind⟩
  generalize_proofs at *;
  set B : Company n (n * (n - 1)) := ⟨fun i => ⟨⟨i.val, by
    nlinarith [ Fin.is_lt i, Nat.sub_add_cancel hn.le ]⟩, ⟨i.val + n, by
    nlinarith [ Fin.is_lt i, Nat.sub_add_cancel hn.le ]⟩, by
    exact Nat.lt_add_of_pos_right ( pos_of_gt hn )⟩, by
    exact fun i j h => Fin.ext <| by simpa using congr_arg Fin.val h;, by
    intro i j; aesop;, by
    simp +decide [ Monovary ];
    exact fun i j hij => le_of_lt hij⟩
  generalize_proofs at *;
  -- By definition of A and B, any linkage in A stays within the same row, and any linkage in B stays within the same column.
  have hA_row : ∀ (x : A.linkage), x.start.val / n = x.finish.val / n := by
    intro x
    generalize_proofs at *;
    -- By definition of A, each car in the linkage has the same quotient when divided by n.
    have h_quot : ∀ i : Fin (n * (n - 1)), (A.cars i).start.val / n = (A.cars i).finish.val / n := by
      simp +zetaDelta at *;
      intro i; rw [ Nat.add_div ] <;> norm_num [ Nat.div_eq_of_lt, Nat.mod_lt, hn ] ;
      · rcases n with ( _ | _ | n ) <;> simp_all +decide [ Nat.div_eq_of_lt, Nat.mod_eq_of_lt ];
        norm_num [ Nat.add_div, Nat.mod_eq_of_lt ];
        norm_num [ Nat.div_eq_of_lt, Nat.mod_eq_of_lt ];
        exact Nat.le_of_lt_succ ( by rw [ Nat.mod_eq_of_lt ] <;> linarith [ Nat.mod_lt ( i : ℕ ) ( Nat.succ_pos n ) ] );
      · linarith;
    -- By induction on the length of the linkage, we can show that the quotient of the start and finish stations is the same.
    have h_ind : ∀ (l : List (Fin (n * (n - 1)))), l.IsChain (fun i j => (A.cars i).finish = (A.cars j).start) → ∀ i j : Fin (n * (n - 1)), i ∈ l → j ∈ l → (A.cars i).start.val / n = (A.cars j).start.val / n := by
      intros l hl i j hi hj;
      induction' hl with i j hij ih generalizing i j;
      · contradiction;
      · aesop;
      · grind +ring;
    convert h_ind x.cars x.valid ( x.cars.head x.nonempty ) ( x.cars.getLast x.nonempty ) ( List.head_mem x.nonempty ) ( List.getLast_mem x.nonempty ) using 1;
    exact h_quot _ ▸ rfl
  have hB_col : ∀ (x : B.linkage), x.start.val % n = x.finish.val % n := by
    intro x
    generalize_proofs at *;
    -- By definition of B, each car in the linkage has a start and finish that are congruent modulo n.
    have hB_cong : ∀ i : Fin (n * (n - 1)), (B.cars i).start.val % n = (B.cars i).finish.val % n := by
      intro i; simp +zetaDelta
    generalize_proofs at *; (
    -- By definition of linkage, the start and finish of each car in the linkage are congruent modulo n.
    have hB_cong_linkage : ∀ (cars : List (Fin (n * (n - 1)))), cars.IsChain (fun i j => (B.cars i).finish = (B.cars j).start) → ∀ (i j : Fin (n * (n - 1))), i ∈ cars → j ∈ cars → (B.cars i).start.val % n = (B.cars j).start.val % n := by
      intros cars hcars i j hi hj
      generalize_proofs at *; (
      induction' cars with cars ih generalizing i j <;> simp_all +decide [ List.IsChain ];
      cases hcars ; aesop
      (generalize_proofs at *; (
      grind +ring)))
    generalize_proofs at *; (
    convert hB_cong_linkage x.cars x.valid ( x.cars.head x.nonempty ) ( x.cars.getLast x.nonempty ) ( List.head_mem x.nonempty ) ( List.getLast_mem x.nonempty ) using 1
    (generalize_proofs at *; (
    exact hB_cong _ ▸ rfl;))));
  obtain ⟨ i, j, hi, hj ⟩ := h_contra A B;
  obtain ⟨ x, hx ⟩ := hi
  obtain ⟨ y, hy ⟩ := hj
  have h_eq : i.val / n = j.val / n ∧ i.val % n = j.val % n := by
    exact ⟨ by simpa [ hx ] using hA_row x, by simpa [ hy ] using hB_col y ⟩
  have h_eq' : i.val = j.val := by
    rw [ ← Nat.div_add_mod i n, ← Nat.div_add_mod j n, h_eq.1, h_eq.2 ]
  have h_lt : i < j := by
    exact hx.1 ▸ hx.2 ▸ Company.linkage_start_lt_finish x
  exact h_lt.ne (Fin.ext h_eq')

/-
PROBLEM
S is upward closed.

PROVIDED SOLUTION
Given companies A, B : Company n l, restrict to the first k cars. Define A' : Company n k by A'.cars i = A.cars (Fin.castLE hle i). The restriction preserves injective_start, injective_finish, monovary_start_finish since A satisfies them. By hk, A' and B' share a linked pair (i, j). A'.linked i j implies A.linked i j because a linkage in A' (using car indices from Fin k) can be mapped to a linkage in A by Fin.castLE. The mapped list is nonempty, the chain property is preserved because A'.cars = A.cars ∘ Fin.castLE, and the start/finish are the same.
-/
lemma S_upward_closed' {n : ℕ} {k l : ℕ} (hle : k ≤ l)
    (hk : ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j) :
    ∀ A B : Company n l, ∃ i j, A.linked i j ∧ B.linked i j := by
  intro A B;
  -- Define A' : Company n k by A'.cars i = A.cars (Fin.castLE hle i).
  set A' : Company n k := ⟨fun i => A.cars (Fin.castLE hle i), by
    exact A.injective_start.comp ( Fin.castLE_injective _ ), by
    exact A.injective_finish.comp ( Fin.castLE_injective _ ), by
    intro i j hij; have := A.monovary_start_finish; aesop;⟩
  generalize_proofs at *;
  -- Define B' : Company n k by B'.cars i = B.cars (Fin.castLE hle i).
  set B' : Company n k := ⟨fun i => B.cars (Fin.castLE hle i), by
    exact B.injective_start.comp ( Fin.castLE_injective _ ), by
    exact B.injective_finish.comp ( Fin.castLE_injective _ ), by
    intro i j hij; have := B.monovary_start_finish; aesop;⟩
  generalize_proofs at *;
  obtain ⟨ i, j, hi, hj ⟩ := hk A' B';
  refine' ⟨ i, j, _, _ ⟩;
  · obtain ⟨ x, hx ⟩ := hi;
    use ⟨ x.cars.map ( Fin.castLE hle ), by
      exact List.ne_nil_of_mem ( List.mem_map.mpr ⟨ x.cars.head x.nonempty, x.cars.head_mem x.nonempty, rfl ⟩ ), by
      rw [ List.isChain_iff_get ] at *;
      intro i; have := x.valid; simp_all +decide [ List.isChain_iff_get ] ;
      convert this ⟨ i, _ ⟩ using 1;
      exact Nat.lt_of_lt_of_le i.2 ( by simp ) ⟩
    generalize_proofs at *;
    unfold Company.linkage.start Company.linkage.finish at * ; aesop;
  · obtain ⟨ x, hx ⟩ := hj;
    use ⟨ x.cars.map ( fun i => Fin.castLE hle i ), by
      exact List.ne_nil_of_mem ( List.mem_map.mpr ⟨ x.cars.head x.nonempty, List.head_mem x.nonempty, rfl ⟩ ), by
      rw [ List.isChain_iff_get ] at *;
      intro i; have := x.valid; simp_all +decide [ List.isChain_iff_get ] ;
      convert this ⟨ i, _ ⟩ using 1;
      exact Nat.lt_of_lt_of_le i.2 ( by simp ) ⟩
    generalize_proofs at *;
    unfold Company.linkage.start Company.linkage.finish at * ; aesop

theorem result (n : Set.Ioi 1) :
    IsLeast {k : ℕ | ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j} (answer n) := by
  have hn : 1 < (↑n : ℕ) := n.prop
  constructor
  · -- Upper bound: answer n ∈ S
    intro A B; exact upper_bound hn A B
  · -- Lower bound: ∀ k ∈ S, answer n ≤ k
    intro k hk
    simp only [Set.mem_setOf_eq] at hk
    by_contra h; push_neg at h; simp only [answer] at h
    have hk_le : k ≤ (↑n : ℕ) * ((↑n : ℕ) - 1) := by omega
    obtain ⟨A, B, hAB⟩ := lower_bound hn
    have hS := S_upward_closed' hk_le hk
    obtain ⟨i, j, hA, hB⟩ := hS A B
    exact hAB i j ⟨hA, hB⟩

end IMO2020P4
