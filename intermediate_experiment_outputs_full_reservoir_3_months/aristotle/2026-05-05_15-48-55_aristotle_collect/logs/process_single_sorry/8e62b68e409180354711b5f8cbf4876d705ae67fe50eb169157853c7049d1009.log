Released under Apache 2.0 license as described in the file LICENSE.
Authors: Rémy Degenne
-/
import Mathlib

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-! The original statement below used `[PartialOrder ι]` (from the section variable) and
`[FirstCountableTopology ι]`, but the theorem is **false** at that generality.

**Counterexample**: Take `ι = ℝ` with the *discrete* partial order (`x ≤ y ↔ x = y`) and
the standard Euclidean topology. Then `Set.Ioi x = ∅` and `Set.Iio x = ∅` for every `x`,
so `IsCadlag` is vacuously satisfied by *any* function. Yet the function
`f(x) = 1/x` (for `x > 0`, `f(0) = 0`) maps the compact set `[0, 1]` to the unbounded
set `{0} ∪ [1, ∞)`.

The proof requires `[LinearOrder ι]` so that `Set.Iio x ∪ Set.Ici x = Set.univ`
(`Set.Iio_union_Ici`), which lets us combine the left-limit and right-continuity
neighborhoods into a full neighborhood of each point. The corrected statement appears
below. -/

-- The original statement is false and has been commented out:
-- lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
--     [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
--     (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
--     IsBounded (f '' s) := by
--   sorry

section BoundedImage

variable {ι' : Type*} [LinearOrder ι'] [TopologicalSpace ι']
  {E' : Type*} [PseudoMetricSpace E']

private lemma isBounded_image_of_continuousWithinAt_Ioi
    {f : ι' → E'} {x : ι'}
    (hf : ContinuousWithinAt f (Set.Ioi x) x) :
    ∃ U ∈ 𝓝[≥] x, IsBounded (f '' U) := by
  obtain ⟨U, hU⟩ : ∃ U ∈ nhdsWithin x (Set.Ioi x), IsBounded (f '' U) :=
    ⟨_, hf (Metric.ball_mem_nhds _ one_pos),
      Metric.isBounded_ball.subset (Set.image_subset_iff.2 fun _ h => h)⟩
  refine ⟨U ∪ {x}, ?_, ?_⟩ <;>
    simp_all +decide [nhdsWithin, Filter.mem_sup]
  · simp_all +decide [Filter.mem_inf_principal, Set.subset_def]
    filter_upwards [hU.1] with y hy using fun hxy =>
      Classical.or_iff_not_imp_left.2 fun h =>
        hy <| lt_of_le_of_ne hxy <| Ne.symm h
  · simp_all +decide [Set.image_insert_eq, isBounded_iff_forall_norm_le]

private lemma isBounded_image_of_tendsto_nhdsWithin_Iio
    {f : ι' → E'} {x : ι'} {l : E'}
    (hf : Tendsto f (𝓝[<] x) (𝓝 l)) :
    ∃ U ∈ 𝓝[<] x, IsBounded (f '' U) :=
  ⟨{y | dist (f y) l < 1},
    hf (Metric.ball_mem_nhds l one_pos),
    Metric.isBounded_ball.subset
      (Set.image_subset_iff.2 fun _ hy => hy)⟩

private lemma isCadlag_locally_bounded
    {f : ι' → E'} (hf : IsCadlag f) (x : ι') :
    ∃ U ∈ 𝓝 x, IsBounded (f '' U) := by
  obtain ⟨l, hl⟩ := hf.left_limit x
  obtain ⟨U₁, hU₁_mem, hU₁_bdd⟩ :=
    isBounded_image_of_continuousWithinAt_Ioi (hf.right_continuous x)
  obtain ⟨U₂, hU₂_mem, hU₂_bdd⟩ :=
    isBounded_image_of_tendsto_nhdsWithin_Iio hl
  refine ⟨U₂ ∪ U₁, ?_, ?_⟩
  · have : 𝓝[Set.Iio x] x ⊔ 𝓝[Set.Ici x] x = 𝓝 x := by
      rw [← nhdsWithin_union]
      rw [show Set.Iio x ∪ Set.Ici x = Set.univ from Set.Iio_union_Ici]
      exact nhdsWithin_univ x
    rw [← this]
    exact Filter.union_mem_sup hU₂_mem hU₁_mem
  · rw [Set.image_union]
    exact hU₂_bdd.union hU₁_bdd

/-- A càdlàg function on a linear order maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact
    [FirstCountableTopology ι'] {f : ι' → E'}
    (hf : IsCadlag f) {s : Set ι'} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U ∈ nhds x, IsBounded (f '' U) :=
    fun x _ => isCadlag_locally_bounded hf x
  choose! U hU using h_loc
  obtain ⟨t, ht₁, ht₂⟩ :
      ∃ t : Finset ι', (∀ x ∈ t, x ∈ s) ∧ s ⊆ ⋃ x ∈ t, U x := by
    have := hs.elim_nhds_subcover U fun x hx => (hU x hx).1
    aesop
  have h_bdd : Bornology.IsBounded (⋃ x ∈ t, f '' U x) := by
    exact (isBounded_biUnion_finset t).mpr fun x hx => (hU x (ht₁ x hx)).2
  exact h_bdd.subset (Set.image_subset_iff.2 fun x hx =>
    Set.mem_iUnion₂.2 <| by
      rcases Set.mem_iUnion₂.1 (ht₂ hx) with ⟨y, hy, hy'⟩
      exact ⟨y, hy, Set.mem_image_of_mem _ hy'⟩)

end BoundedImage

