import SpherePacking.MagicFunction.a.IntegralEstimates.I1
import SpherePacking.MagicFunction.a.IntegralEstimates.I2
import SpherePacking.MagicFunction.a.IntegralEstimates.I3
import SpherePacking.MagicFunction.a.IntegralEstimates.I4
import SpherePacking.MagicFunction.a.IntegralEstimates.I5
import SpherePacking.MagicFunction.a.IntegralEstimates.I6
import SpherePacking.MagicFunction.a.Integrability.RealIntegrands

/-! # Integrability

In this file, we prove that the integrands `Φⱼ` are integrable.
-/

open MagicFunction.Parametrisations MagicFunction.a.RealIntegrals MagicFunction.a.RadialFunctions
  MagicFunction.PolyFourierCoeffBound MagicFunction.a.RealIntegrands
open Complex Real Set MeasureTheory MeasureTheory.Measure Filter intervalIntegral
open scoped Function UpperHalfPlane

namespace MagicFunction.a.Integrability

/-
PROVIDED SOLUTION
For t ∈ Ioc 0 1, Φ₃ r t = I * Φ₃' r (z₃' t) where z₃'(t) = 1 + I*t (since t ∈ [0,1]). So Φ₃' r (1 + I*t) = φ₀''(-1/(I*t)) * (I*t)^2 * cexp(π * I * r * (1 + I*t)). We have ‖Φ₃ r t‖ = ‖φ₀''(-1/(I*t))‖ * t² * |cexp(π * I * r * (1 + I*t))|. Now -1/(I*t) = I/t, and im(I/t) = 1/t ≥ 1 > 1/2 for t ∈ (0,1]. By norm_φ₀_le, ‖φ₀''(I/t)‖ = ‖φ₀(⟨I/t, ...⟩)‖ ≤ C₀ * exp(-2π/t). Also |cexp(π*I*r*(1+I*t))| = exp(-π*r*t) ≤ 1 (since r ≥ 0, t ≥ 0). So ‖Φ₃ r t‖ ≤ C₀ * t² * exp(-2π/t). Since h(t) = t² * exp(-2π/t) is increasing on (0,∞) (derivative is (2t + 2π)*exp(-2π/t) > 0), h(t) ≤ h(1) = exp(-2π) for t ∈ (0,1]. So ‖Φ₃ r t‖ ≤ C₀ * exp(-2π). Take C = C₀ * exp(-2π).
-/
private lemma Φ₃_norm_bound (r : ℝ) (hr : r ≥ 0) :
    ∃ C : ℝ, ∀ t ∈ Ioc (0 : ℝ) 1, ‖Φ₃ r t‖ ≤ C := by
  by_contra h_contra;
  have h_bound : ∃ C, ∀ t ∈ Ioo (0 : ℝ) 1, ‖Φ₃ r t‖ ≤ C := by
    have h_bound : ∃ C, ∀ t ∈ Ioo (0 : ℝ) 1, ‖φ₀'' (-1 / (I * t))‖ ≤ C * Real.exp (-2 * Real.pi / t) := by
      have h_bound : ∃ C, ∀ z : ℂ, z.im ≥ 1 → ‖φ₀'' z‖ ≤ C * Real.exp (-2 * Real.pi * z.im) := by
        have := norm_φ₀_le;
        obtain ⟨ C₀, hC₀_pos, hC₀ ⟩ := this;
        use C₀;
        intro z hz
        have hz_upper : z.im > 1 / 2 := by
          linarith;
        convert hC₀ ⟨ z, by
          linarith ⟩ hz_upper using 1
        generalize_proofs at *;
