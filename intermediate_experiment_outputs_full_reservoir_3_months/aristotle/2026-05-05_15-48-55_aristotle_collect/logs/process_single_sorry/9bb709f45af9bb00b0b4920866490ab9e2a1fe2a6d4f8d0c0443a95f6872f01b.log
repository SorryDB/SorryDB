Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib

open scoped Finset

namespace IMO2022P1

/-- The two types of coins. -/
inductive Coin : Type where
  | A : Coin
  | B : Coin
  deriving DecidableEq

/-- A row of coins. -/
abbrev Row (n : ℕ) : Type := Fin (2 * n) → Coin

open scoped Classical in
/-- The property of a row having `n` of each kind of coin. -/
def Row.valid {n : ℕ} (c : Row n) : Prop := #{i | c i = Coin.A} = n

open scoped Classical in
/-- The first coin in the chain containing coin `k` (zero-based). -/
noncomputable def Row.chainLeft {n : ℕ} (c : Row n) (k : Fin (2 * n)) : Fin (2 * n) :=
  {j ∈ Finset.Iic k | ∀ i, j ≤ i → i ≤ k → c i = c k}.min' ⟨k, by
    simp only [Finset.mem_filter, Finset.mem_Iic, le_refl, true_and]
    rintro i hki hik
    rw [le_antisymm hki hik]⟩

open scoped Classical in
/-- The last coin in the chain containing coin `k` (zero-based). -/
noncomputable def Row.chainRight {n : ℕ} (c : Row n) (k : Fin (2 * n)) : Fin (2 * n) :=
  {j ∈ Finset.Ici k | ∀ i, k ≤ i → i ≤ j → c i = c k}.max' ⟨k, by
    simp only [Finset.mem_filter, Finset.mem_Ici, le_refl, true_and]
    rintro i hki hik
    rw [le_antisymm hki hik]⟩

/-- Move coins `a` through `b` to the left of the row. -/
def Row.move {n : ℕ} (c : Row n) (a b : Fin (2 * n)) : Row n :=
  fun i ↦ if b < i then c i else c ⟨(((i : ℕ) + (a : ℕ)) % ((b : ℕ) + 1)),
    (Nat.mod_lt _ (by omega)).trans_le (by omega)⟩

/-- The operation moving the chain containing coin `k` (zero-based). -/
noncomputable def Row.operation {n : ℕ} (k : Fin (2 * n)) (c : Row n) : Row n :=
  c.move (c.chainLeft k) (c.chainRight k)

/-- The operation moving the chain containing coin `k` (one-based). -/
noncomputable def Row.operationOneBased {n k : ℕ} (hk1 : 1 ≤ k) (hkn : k ≤ 2 * n) (c : Row n) :
    Row n :=
  c.operation ⟨k - 1, by omega⟩

/-- The answer to be determined. -/
def answer : Set (ℕ × ℕ) := {(n, k) | 1 ≤ n ∧ n ≤ k ∧ 2 * k ≤ 3 * n + 1}

/-- The "good" property for (n, k). -/
def Good (n k : ℕ) : Prop :=
  ∃ hk1 : 1 ≤ k, ∃ hkn : k ≤ 2 * n, ∀ c : Row n, c.valid →
    ∃ i, ∀ j₁ j₂ : Fin (2 * n), (j₁ : ℕ) < n → (j₂ : ℕ) < n →
    (Row.operationOneBased hk1 hkn)^[i] c j₁ = (Row.operationOneBased hk1 hkn)^[i] c j₂

lemma good_imp_n_pos {n k : ℕ} (h : Good n k) : 1 ≤ n := by
  obtain ⟨hk1, hkn, _⟩ := h; linarith

/-
PROVIDED SOLUTION
Proof by contrapositive: assume k < n, show ¬Good n k. From Good we get 1 ≤ k, k ≤ 2n.

Construct counterexample c where:
- c(i) = Coin.A for i.val < k
- c(i) = Coin.B for k ≤ i.val < n
- c(i) = Coin.A for n ≤ i.val < 2n - k
- c(i) = Coin.B for 2n - k ≤ i.val

This has n A's and n B's (valid). The chain at position k-1 (0-based) is positions 0..k-1 (all A, since c(k) = B ≠ A). The chainLeft = 0, chainRight = k-1. The move(0, k-1) rotates 0..k-1 by 0, which is identity. So c is a fixed point. But c(k-1) = A and c(k) = B with both k-1 < n and k < n, so the first n positions are not uniform. Contradiction.
-/
lemma good_imp_n_le_k {n k : ℕ} (h : Good n k) : n ≤ k := by
  obtain ⟨hk1, hkn, h_op⟩ := h;
  by_contra h_contra;
  -- Consider the row $c$ where $c(i) = Coin.A$ for $i < k$, $c(i) = Coin.B$ for $k \leq i < n$, $c(i) = Coin.A$ for $n \leq i < 2n - k$, and $c(i) = Coin.B$ for $2n - k \leq i$.
  set c : Row n := fun i => if i.val < k then Coin.A else if i.val < n then Coin.B else if i.val < 2 * n - k then Coin.A else Coin.B;
  -- We need to show that this row $c$ is valid.
  have hc_valid : c.valid := by
    -- Let's count the number of A's in the row $c$.
    have hc_A_count : Finset.card (Finset.filter (fun i : Fin (2 * n) => c i = Coin.A) Finset.univ) = k + (2 * n - k - n) := by
      rw [ Finset.card_eq_of_bijective ];
      use fun i hi => ⟨ if i < k then i else i + n - k, by split_ifs <;> omega ⟩;
      · simp +zetaDelta at *;
        intro a ha; use if a.val < k then a.val else a.val - n + k; split_ifs <;> simp_all +decide [ Nat.sub_sub ] ;
        · omega;
        · omega;
        · grind +ring;
      · grind;
      · grind +ring;
    exact hc_A_count.trans ( by omega );
  -- We need to show that this row $c$ is a fixed point of the operation.
  have hc_fixed_point : ∀ i : ℕ, (Row.operationOneBased hk1 hkn)^[i] c = c := by
    intro i
    induction' i with i ih;
    · rfl;
    · rw [ Function.iterate_succ_apply', ih ];
      -- By definition of $c$, we know that the chain containing $k$ is positions $0$ to $k-1$.
      have h_chain : c.chainLeft ⟨k - 1, by omega⟩ = ⟨0, by omega⟩ ∧ c.chainRight ⟨k - 1, by omega⟩ = ⟨k - 1, by omega⟩ := by
        constructor <;> refine' le_antisymm _ _ <;> simp +decide [ *, Row.chainLeft, Row.chainRight ];
        · simp +decide [ Finset.min' ];
          use ⟨0, by omega⟩; simp [c];
          intro i hi₁ hi₂; split_ifs <;> norm_num ; linarith [ Fin.is_lt i, Nat.sub_add_cancel hk1 ] ;
          grind;
          any_goals omega;
          · exact ‹¬ ( i : ℕ ) < k› ( lt_of_le_of_lt hi₂ ( Nat.pred_lt ( ne_bot_of_gt hk1 ) ) );
          · exact ‹¬ ( i : ℕ ) < k› ( lt_of_le_of_lt hi₂ ( Nat.pred_lt ( ne_bot_of_gt hk1 ) ) );
        · exact fun _ _ _ => Nat.zero_le _;
        · simp +zetaDelta at *;
          intro y hy₁ hy₂; specialize hy₂ ⟨ k, by linarith ⟩ ; rcases k with ( _ | k ) <;> simp_all +decide ;
          · contradiction;
          · exact Nat.le_of_lt_succ hy₂;
        · simp +decide [ Finset.max' ];
          use ⟨k - 1, by omega⟩;
          grind;
      unfold Row.operationOneBased Row.operation;
      ext i; simp [h_chain, Row.move];
      intro hi; simp +decide [ Nat.mod_eq_of_lt ( show ( i : ℕ ) < k - 1 + 1 from Nat.lt_succ_of_le ( Nat.le_trans hi ( Nat.le_refl _ ) ) ) ] ;
  obtain ⟨ i, hi ⟩ := h_op c hc_valid ; specialize hi ⟨ k - 1, by omega ⟩ ⟨ k, by omega ⟩ ; rcases k with ( _ | k ) <;> simp_all +decide ;
  · contradiction;
  · grind +ring

/-- The alternating configuration: A at even positions, B at odd positions. -/
def altRow (n : ℕ) : Row n := fun i => if i.val % 2 = 0 then Coin.A else Coin.B

/-- The reversed alternating configuration: B at even positions, A at odd positions. -/
def altRowRev (n : ℕ) : Row n := fun i => if i.val % 2 = 0 then Coin.B else Coin.A

/-
PROVIDED SOLUTION
The alternating configuration c(i) = A if i even, B if i odd has exactly n A's among the 2n positions. The even positions in Fin(2n) are {0, 2, 4, ..., 2n-2}, which has exactly n elements. So the cardinality of {i | c i = Coin.A} = cardinality of {i | i.val % 2 = 0} = n.
-/
lemma altRow_valid {n : ℕ} (hn : 1 ≤ n) : (altRow n).valid := by
  unfold Row.valid;
  convert Finset.card_filter ( fun i : Fin ( 2 * n ) => i.val % 2 = 0 ) Finset.univ using 1;
  · congr with i ; unfold altRow ; aesop;
  · induction hn <;> simp_all +arith +decide [ Nat.mul_succ, Fin.sum_univ_castSucc ];
    rw [ Finset.card_filter, Finset.card_filter ];
    rw [ Fin.sum_univ_castSucc, Fin.sum_univ_castSucc ] ; aesop

/-
PROBLEM
The alternating config is not a 2n fixed point: it 2-cycles between altRow and altRowRev.

PROVIDED SOLUTION
We show ¬Good n (2n) for n ≥ 2 by exhibiting a counterexample: the alternating config altRow n.

The alternating config c has c(i) = A if i even, B if i odd. It is valid (by altRow_valid, since n ≥ 2 ≥ 1).

For k = 2n, the 0-based position is 2n-1 (the last position). In the alternating config:
- c(2n-1) = B (since 2n-1 is odd)
- c(2n-2) = A (since 2n-2 is even), which is ≠ B

So the chain at 2n-1 is just the singleton {2n-1}. Thus chainLeft = chainRight = 2n-1.

The move(2n-1, 2n-1) rotates positions 0..2n-1 by 2n-1. For position i:
c'(i) = c((i + 2n - 1) mod 2n)

Since 2n-1 ≡ -1 (mod 2n), this gives c'(i) = c((i - 1) mod 2n).

So c'(0) = c(2n-1) = B, c'(1) = c(0) = A, c'(2) = c(1) = B, c'(3) = c(2) = A, ...

In general: c'(i) = B if i is even, A if i is odd. This is exactly altRowRev n.

Applying the operation again to altRowRev:
- altRowRev(2n-1) = A (since 2n-1 is odd → altRowRev gives A at odd positions)
- altRowRev(2n-2) = B ≠ A. Singleton chain.
- c''(i) = altRowRev((i - 1) mod 2n)
- c''(0) = altRowRev(2n-1) = A, c''(1) = altRowRev(0) = B, ...
- c''(i) = A if i even, B if i odd = altRow n

So the orbit is altRow → altRowRev → altRow → ... (period 2).

For n ≥ 2, the first n positions of altRow are A,B,A,B,... which has both A and B (not uniform).
Similarly, the first n positions of altRowRev are B,A,B,A,... which also has both A and B.

So no element of the orbit has uniform first n positions. Therefore ¬Good n (2n).

The formal proof: introduce the alternating config, show it's valid, obtain i from Good, then show that the i-th iterate has non-uniform first n positions by showing it equals altRow or altRowRev depending on parity of i, and both have different coins at positions 0 and 1 (both < n since n ≥ 2).
-/
set_option maxHeartbeats 400000 in
lemma not_good_2n {n : ℕ} (hn : 2 ≤ n) : ¬Good n (2 * n) := by
  intro h
  obtain ⟨hk1, hkn, h_iter⟩ := h;
  -- Applying the operation to the alternating configuration `altRow n`, we see that it cycles between `altRow n` and `altRowRev n`.
  have h_cycle : ∀ i : ℕ, (Row.operationOneBased hk1 hkn)^[i] (altRow n) = if i % 2 = 0 then altRow n else altRowRev n := by
    -- Applying the operation to `altRow n` results in `altRowRev n`.
    have h_op_altRow : Row.operation ⟨2 * n - 1, by omega⟩ (altRow n) = altRowRev n := by
      -- By definition of `Row.operation`, we have:
      unfold Row.operation;
      -- By definition of `chainLeft` and `chainRight`, we have:
      have h_chainLeft : (altRow n).chainLeft ⟨2 * n - 1, by omega⟩ = ⟨2 * n - 1, by omega⟩ := by
        refine' le_antisymm _ _ <;> simp +decide [ Row.chainLeft ];
        · exact Finset.min'_mem _ _ |> fun x => Finset.mem_filter.mp x |>.1 |> Finset.mem_Iic.mp;
        · intro y hy h; specialize h ⟨ 2 * n - 2, by omega ⟩ ; rcases n with ( _ | _ | n ) <;> simp_all +decide ;
          simp_all +decide [ Nat.mul_succ, altRow ];
          exact Nat.succ_le_of_lt h
      have h_chainRight : (altRow n).chainRight ⟨2 * n - 1, by omega⟩ = ⟨2 * n - 1, by omega⟩ := by
        refine' le_antisymm _ _ <;> simp +decide [ Row.chainRight ];
        · exact fun y hy₁ hy₂ => Nat.le_sub_one_of_lt <| Fin.is_lt y;
        · simp +decide [ Finset.max' ];
          refine' ⟨ ⟨ 2 * n - 1, Nat.sub_lt ( by linarith ) ( by linarith ) ⟩, _, _ ⟩ <;> norm_num;
          exact fun i hi₁ hi₂ => by rw [ le_antisymm hi₂ hi₁ ] ;
      ext i; simp +decide [ *, Row.move ] ;
      split_ifs <;> simp_all +decide [ Fin.lt_def ];
      · exact absurd ‹_› ( not_lt_of_ge ( Nat.le_sub_one_of_lt i.2 ) );
      · unfold altRow altRowRev; simp +decide [ Nat.add_mod, Nat.mod_eq_of_lt ] ;
        grind;
    -- Applying the operation to `altRowRev n` results in `altRow n`.
    have h_op_altRowRev : Row.operation ⟨2 * n - 1, by omega⟩ (altRowRev n) = altRow n := by
      -- Applying the operation to `altRowRev n` results in `altRow n` because the chain at position `2 * n - 1` is just the singleton `{2 * n - 1}`.
      have h_chain_rev : ∀ i : Fin (2 * n), i.val = 2 * n - 1 → (altRowRev n).chainLeft i = i ∧ (altRowRev n).chainRight i = i := by
        intro i hi
        simp [Row.chainLeft, Row.chainRight, hi];
        constructor <;> refine' le_antisymm _ _ <;> simp +decide [ Finset.min', Finset.max' ];
        · exact ⟨ i, ⟨ le_rfl, fun j hj₁ hj₂ => by rw [ le_antisymm hj₂ hj₁ ] ⟩, le_rfl ⟩;
        · intro j hj₁ hj₂; specialize hj₂ ⟨ 2 * n - 2, by omega ⟩ ; rcases n with ( _ | _ | n ) <;> simp_all +decide [ Nat.mul_succ ] ;
          simp_all +decide [ Fin.le_iff_val_le_val, altRowRev ];
          linarith;
        · grind;
        · use i; simp [hi];
          exact fun j hj₁ hj₂ => by rw [ le_antisymm hj₂ hj₁ ] ;
      -- Applying the operation to `altRowRev n` results in `altRow n` because the chain at position `2 * n - 1` is just the singleton `{2 * n - 1}`, and moving this chain to the left of the row results in `altRow n`.
      have h_op_altRowRev : Row.move (altRowRev n) ⟨2 * n - 1, by omega⟩ ⟨2 * n - 1, by omega⟩ = altRow n := by
        ext i; simp [Row.move];
        split_ifs <;> simp_all +decide [ Fin.lt_def ];
        · exact absurd ‹_› ( not_lt_of_ge ( Nat.le_sub_one_of_lt i.2 ) );
        · rcases n with ( _ | _ | n ) <;> simp_all +decide [ Nat.mod_eq_of_lt ];
          · contradiction;
          · unfold altRow altRowRev; simp +decide [ Nat.mod_eq_of_lt ] ;
            cases Nat.mod_two_eq_zero_or_one i.val <;> simp +decide [ *, Nat.add_mod, Nat.mul_succ ];
      convert h_op_altRowRev using 1;
      exact congr_arg₂ _ ( h_chain_rev _ rfl |>.1 ) ( h_chain_rev _ rfl |>.2 );
    intro i; induction i <;> simp_all +decide [ Function.iterate_succ_apply', Nat.even_iff ] ;
    split_ifs <;> simp_all +decide [ Nat.add_mod ];
    · convert h_op_altRow using 1;
    · convert h_op_altRowRev using 1;
  obtain ⟨ i, hi ⟩ := h_iter ( altRow n ) ( altRow_valid ( by linarith ) ) ; specialize hi ⟨ 0, by linarith ⟩ ⟨ 1, by linarith ⟩ ; simp_all +decide ;
  split_ifs at hi <;> simp_all +decide [ altRow, altRowRev ];
  · linarith [ hi ( by linarith ) ];
  · linarith [ hi ( by linarith ) ]

lemma good_imp_2k_le {n k : ℕ} (h : Good n k) : 2 * k ≤ 3 * n + 1 := by sorry

/-
PROBLEM
If the chain at position k-1 starts at 0 and k ≥ n, the first n positions are uniform.

PROVIDED SOLUTION
If c.chainLeft k = 0, this means there is a contiguous block of the same color from position 0 all the way to position k (inclusive). In particular, all positions j with 0 ≤ j ≤ k have c j = c k. Since k.val ≥ n - 1 (from hk: n ≤ k.val + 1), positions 0 through n-1 are all ≤ k, so they're all in this chain and all have the color c k. Therefore c j₁ = c k = c j₂ for any j₁, j₂ with j₁.val < n and j₂.val < n.

More formally: from the definition of chainLeft, c.chainLeft k = ⟨0, _⟩ means that 0 is in the filtered set {j ∈ Finset.Iic k | ∀ i, j ≤ i → i ≤ k → c i = c k}, and it is the minimum. The membership condition means ∀ i, 0 ≤ i → i ≤ k → c i = c k, which means all positions 0..k have color c k.

For j₁ with j₁.val < n ≤ k.val + 1, we have j₁.val ≤ k.val, so j₁ ≤ k, and thus c j₁ = c k. Similarly for j₂. So c j₁ = c k = c j₂.
-/
lemma chainLeft_zero_uniform {n : ℕ} (hn : 1 ≤ n) (k : Fin (2 * n)) (hk : n ≤ k.val + 1)
    (c : Row n) (h0 : c.chainLeft k = ⟨0, by omega⟩) :
    ∀ j₁ j₂ : Fin (2 * n), j₁.val < n → j₂.val < n → c j₁ = c j₂ := by
      -- From Lemma~\ref{lem:chainLeft_def}, c.chainLeft k = 0 implies that for all i in Finset.Iic k, c i = c k.
      have h_chain : ∀ i ∈ Finset.Iic k, c i = c k := by
        contrapose! h0; simp_all +decide [ Finset.min' ] ;
        unfold Row.chainLeft; simp_all +decide [ Finset.min' ] ;
        refine' ne_of_gt ( lt_of_lt_of_le _ ( Finset.le_inf' _ _ _ ) ) <;> norm_num;
        rotate_left;
        exact ⟨ 1, by linarith ⟩;
        · intro b hb h; rcases b with ⟨ _ | b, hb ⟩ <;> norm_num at *;
          exact h0.elim fun i hi => hi.2 <| h i ( Nat.zero_le _ ) hi.1;
        · exact Nat.zero_lt_one;
      grind

lemma good_of_bounds {n k : ℕ} (hn : 1 ≤ n) (hnk : n ≤ k) (h2k : 2 * k ≤ 3 * n + 1) :
    Good n k := by sorry

theorem result : {(n, k) | ∃ hk1 : 1 ≤ k, ∃ hkn : k ≤ 2 * n, ∀ c : Row n, c.valid →
    ∃ i, ∀ j₁ j₂ : Fin (2 * n), (j₁ : ℕ) < n → (j₂ : ℕ) < n →
    (Row.operationOneBased hk1 hkn)^[i] c j₁ = (Row.operationOneBased hk1 hkn)^[i] c j₂} =
    answer := by
  ext ⟨n, k⟩
  simp only [Set.mem_setOf_eq, answer]
  constructor
  · intro h
    have hg : Good n k := h
    exact ⟨good_imp_n_pos hg, good_imp_n_le_k hg, good_imp_2k_le hg⟩
  · intro ⟨hn, hnk, h2k⟩
    exact good_of_bounds hn hnk h2k

end IMO2022P1
