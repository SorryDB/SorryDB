For sorry at line 567 (the main Measure.map = compProd equality):
Step 1: Rewrite using reward_eq to simplify the function:
  `have h_rw : ... = fun x ↦ ((hist alg x n, action alg (n + 1) x), reward alg (n + 1) x) := by funext ω; simp only [reward_eq]`
  `rw [h_rw]`
Step 2: Use compProd_map_condDistrib to decompose:
  `rw [← compProd_map_condDistrib (measurable_reward alg (n + 1)).aemeasurable]`
Step 3: Use Measure.compProd_congr to reduce to condDistrib equality:
  `exact Measure.compProd_congr sorry`  -- condDistrib = Kernel.prodMkLeft _ ν
-/
lemma hasCondDistrib_reward' (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν]
    (n : ℕ) :
    HasCondDistrib (reward alg (n + 1)) (fun ω ↦ (hist alg ω n, action alg (n + 1) ω))
      (ν.prodMkLeft _) (arrayMeasure ν) := by
  rw [reward_eq]
  refine ⟨?_, by fun_prop, ?_⟩
  ·
    convert ( measurable_reward alg ( n + 1 ) ).aemeasurable using 1 ; exact ( reward_eq alg ( n + 1 ) ).symm ▸ rfl;
  refine condDistrib_ae_eq_of_measure_eq_compProd _ ?_ ?_
  ·
    -- The function ω ↦ ω.2 (pullCount (action alg) (action alg (n + 1) ω) (n + 1) ω) (action alg (n + 1) ω) is measurable because it is a composition of measurable functions.
    have h_measurable : Measurable (fun ω : probSpace α R => ω.2 (pullCount (action alg) (action alg (n + 1) ω) (n + 1) ω) (action alg (n + 1) ω)) := by
      have h_reward_measurable : Measurable (fun ω : (ℕ → I) × (ℕ → α → R) => reward alg (n + 1) ω) := by
        apply measurable_reward;
      convert h_reward_measurable using 1 ; exact?;
    exact h_measurable.aemeasurable
  sorry

lemma hasCondDistrib_action (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    HasCondDistrib (action alg (n + 1))
      (fun ω (i : Iic n) ↦ (action alg i ω, reward alg i ω))
      (alg.policy n) (arrayMeasure ν) := by
  convert hasCondDistrib_action' alg ν n with ω i
  · simp only [action]
    rw [hist_eq _ _ n]
  · simp only [reward]
    rw [hist_eq _ _ n]

lemma hasCondDistrib_reward (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν]
    (n : ℕ) :
    HasCondDistrib (reward alg (n + 1))
      (fun ω ↦ (fun (i : Iic n) ↦ (action alg i ω, reward alg i ω), action alg (n + 1) ω))
      ((stationaryEnv ν).feedback n) (arrayMeasure ν) := by
  convert hasCondDistrib_reward' alg ν n with ω i
  · simp only [action]
    rw [hist_eq _ _ n]
  · simp only [reward]
    rw [hist_eq _ _ n]

lemma isAlgEnvSeq_arrayMeasure (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] :
    IsAlgEnvSeq (action alg) (reward alg) alg (stationaryEnv ν) (arrayMeasure ν) where
  hasLaw_action_zero := hasLaw_action_zero alg ν
  hasCondDistrib_reward_zero := hasCondDistrib_reward_zero alg ν
  hasCondDistrib_action := hasCondDistrib_action alg ν
  hasCondDistrib_reward := hasCondDistrib_reward alg ν

end ArrayModel

end MeasureSpace

end Bandits
