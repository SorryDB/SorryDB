-- exercise 1.2.vi
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  have hfg : f ≫ g = Category.id X := hg
  have h_inv : g ≫ f = Category.id Y := by
    have hgfg : (g ≫ f) ≫ g = g := by
      rw [Category.assoc, hfg, Category.comp_id]
    have := @Category.mono_op_epi α C Y X g
    contrapose! this
    refine Or.inr ⟨?_, ?_⟩
    · intro h_mono_g
      have := h_mono_g (g ≫ f) (id Y)
        (hgfg.trans (by rw [Category.id_comp]))
      aesop
    · intro Z h k h_eq
      have := @Category.mono_op_epi α C Y X g
      exact this.mp
        (@section_mono α C X Y g f
          (hm (f ≫ g) (id X) (congrFun (congrArg comp hg) f))) _ _ h_eq
  exact ⟨g, hfg, h_inv⟩

-- prove by duality
theorem Category.iso_of_epi_and_split_mono {X Y : α} (f : Hom X Y)
    (he : Epi f) (hm : split_mono f) : IsIso f := by sorry

