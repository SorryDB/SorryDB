lemma eqvgen_connected_length_bound {k : Fin n}
    (R : List (Fin n × Fin n))
    (hconn : ∀ j : Fin n, Relation.EqvGen (fun i j => ∃ p ∈ R, (p.1 = i ∧ p.2 = j) ∨ (p.1 = j ∧ p.2 = i)) k j) :
    n - 1 ≤ R.length := by
  -- Let $G$ be the graph with vertices $0, 1, \ldots, n-1$ and edges corresponding to the pairs in $R$.
  set G : SimpleGraph (Fin n) := SimpleGraph.fromRel (fun i j => ∃ p ∈ R, (p.1 = i ∧ p.2 = j) ∨ (p.1 = j ∧ p.2 = i)) with hG_def
  have hG_connected : G.Connected := by
    -- By definition of $G$, we know that for any $j$, there exists a path from $k$ to $j$ in $G$.
    have h_path : ∀ j, G.Reachable k j := by
      intro j
      specialize hconn j
      induction' hconn with j hj ih;
      · by_cases h : j = hj <;> simp_all +decide [ SimpleGraph.Reachable ];
        · exact ⟨ SimpleGraph.Walk.nil ⟩;
        · exact ⟨ SimpleGraph.Walk.cons ( by aesop ) SimpleGraph.Walk.nil ⟩;
      · exact SimpleGraph.Reachable.refl _;
      · exact SimpleGraph.Reachable.symm ‹_›;
      · exact SimpleGraph.Reachable.trans ‹_› ‹_›
    generalize_proofs at *; (
    rw [ SimpleGraph.connected_iff_exists_forall_reachable ] ; aesop;)
  have hG_spanning_tree : ∃ T : SimpleGraph (Fin n), T.IsTree ∧ T ≤ G := by
    have := hG_connected.exists_isTree_le; aesop;
  obtain ⟨ T, hT_tree, hT_le ⟩ := hG_spanning_tree;
  have hT_edge_card : T.edgeFinset.card = n - 1 := by
    have := hT_tree.card_edgeFinset;
    exact eq_tsub_of_add_eq ( by simpa using this );
  have hG_edge_card : G.edgeFinset.card ≤ R.length := by
    refine' le_trans ( Finset.card_le_card _ ) _;
    exact Finset.image ( fun p : Fin n × Fin n => Sym2.mk ( p.1, p.2 ) ) ( R.toFinset.filter fun p => p.1 ≠ p.2 );
    · intro e he; simp_all +decide [ Sym2.eq_swap ] ;
      rcases e with ⟨ a, b ⟩ ; simp_all +decide [ SimpleGraph.fromRel ] ;
      grind +ring;
    · exact Finset.card_image_le.trans ( le_trans ( Finset.card_filter_le _ _ ) ( List.toFinset_card_le _ ) );
  have hT_edge_card_le_G_edge_card : T.edgeFinset.card ≤ G.edgeFinset.card := by
    apply_rules [ Finset.card_le_card, SimpleGraph.edgeFinset_mono ];
  linarith;

