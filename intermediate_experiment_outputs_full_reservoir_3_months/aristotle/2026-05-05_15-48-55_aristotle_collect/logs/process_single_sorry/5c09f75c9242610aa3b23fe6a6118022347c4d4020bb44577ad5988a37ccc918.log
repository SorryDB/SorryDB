/-- Key geometric lemma (sorry'd): triangle parity. -/
lemma imo_2016_p6_triangle_parity (n : ℕ) (hn : 2 ≤ n)
    (points : Fin n → ℝ² × ℝ²)
    (hpoints : ∀ i, (points i).1 ≠ (points i).2)
    (interAlong : Fin n → Fin (n - 1 : ℕ) ↪o Set.Ioo (0 : ℝ) 1)
    (interBtw : (i : Fin n) → {j // i ≠ j} ≃ Fin (n - 1 : ℕ))
    (lineMap_eq_iff : ∀ i j (hij : i ≠ j),
      ∀ ri rj : Set.Ioo 0 (1 : ℝ),
        lineMap (points i).1 (points i).2 ri.1 =
        lineMap (points j).1 (points j).2 rj.1 ↔
          ri = interAlong i (interBtw i ⟨j, hij⟩) ∧
          rj = interAlong j (interBtw j ⟨i, hij.symm⟩))
    (i j k : Fin n) (hij : i ≠ j) (hik : i ≠ k) (hjk : j ≠ k) :
    Odd ((interBtw i ⟨j, hij⟩).val + (interBtw j ⟨i, hij.symm⟩).val +
         ((interBtw i ⟨k, hik⟩).val + (interBtw k ⟨i, hik.symm⟩).val) +
         ((interBtw j ⟨k, hjk⟩).val + (interBtw k ⟨j, hjk.symm⟩).val)) := by
  sorry

/-
PROBLEM
Parity assignment helper.

PROVIDED SOLUTION
Parity argument using tri_par and omega.

Define ref = ⟨0, by omega⟩, S_rf = interBtw ref ⟨f, h⟩.val + interBtw f ⟨ref, _⟩.val, etc.

Part 1 (bf = bg → .val ≠):
Case ref = f: bf = false (by dif_pos). Since bf = bg, bg = false.
  If ref = g too: impossible since f ≠ g and ref = f, ref = g.
  If ref ≠ g: bg = decide(Even S_rg) = false, so ¬Even S_rg, so Odd S_rg.
  S_fg = S(f,g) = S(ref,g) = S_rg since f = ref.  S_rg is odd → .val's differ (a + b odd → a ≠ b).

Case ref = g: symmetric (swap f and g roles).

Case ref ≠ f, ref ≠ g:
  bf = decide(Even S_rf), bg = decide(Even S_rg).
  bf = bg means Even S_rf ↔ Even S_rg (same parity).
  By tri_par ref f g: S_rf + S_rg + S_fg is odd.
  Same parity → S_rf + S_rg even → S_fg odd → .val's differ.

Part 2 (bf ≠ bg → sum ≠ n-2):
Similar cases. In the ref ≠ f, ref ≠ g case:
  bf ≠ bg → different parity of S_rf and S_rg → sum odd.
  By tri_par: S_rf + S_rg + S_fg odd. Odd + S_fg = odd → S_fg even.
  n odd → n - 2 odd. S_fg even ≠ n - 2 odd.

For ref = f: bf = false ≠ bg. If ref ≠ g: bg = decide(Even S_rg) = true (≠ false),
  so Even S_rg. S_fg = S_rg. S_rg even, n-2 odd → ≠.

Use Nat.odd_iff, Nat.even_iff, omega throughout.
IMPORTANT: avoid `grind` tactic (too slow). Use omega and simp instead.
-/
set_option maxHeartbeats 800000 in
lemma imo_2016_p6_parity_assignment (n : ℕ) (hn : 2 ≤ n)
    (interBtw : (i : Fin n) → {j // i ≠ j} ≃ Fin (n - 1 : ℕ))
    (hodd : Odd n)
    (tri_par : ∀ (i j k : Fin n) (hij : i ≠ j) (hik : i ≠ k) (hjk : j ≠ k),
      Odd ((interBtw i ⟨j, hij⟩).val + (interBtw j ⟨i, hij.symm⟩).val +
           ((interBtw i ⟨k, hik⟩).val + (interBtw k ⟨i, hik.symm⟩).val) +
           ((interBtw j ⟨k, hjk⟩).val + (interBtw k ⟨j, hjk.symm⟩).val)))
    (f g : Fin n) (hfg : f ≠ g) :
    let ref : Fin n := ⟨0, by omega⟩
    let bf := if h : ref = f then false
              else decide (Even ((interBtw ref ⟨f, h⟩).val + (interBtw f ⟨ref, Ne.symm h⟩).val))
    let bg := if h : ref = g then false
              else decide (Even ((interBtw ref ⟨g, h⟩).val + (interBtw g ⟨ref, Ne.symm h⟩).val))
    (bf = bg → (interBtw f ⟨g, hfg⟩).val ≠ (interBtw g ⟨f, hfg.symm⟩).val) ∧
    (bf ≠ bg → (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val ≠ n - 2) := by
  constructor <;> intros h₁ h₂ <;> split_ifs at h₁ h₂ <;> simp_all +decide [ Nat.even_iff, Nat.add_mod ];
  all_goals subst_vars; simp_all +decide [ Nat.even_iff ] ;
  any_goals omega;
  · have := tri_par ⟨ 0, by linarith ⟩ f g; simp_all +decide [ Nat.even_iff, Nat.add_mod ] ;
    grind +ring;
  · cases hodd ; omega;
  · grind;
  · specialize tri_par ⟨ 0, by linarith ⟩ f g ; simp_all +decide [ Nat.even_iff, Nat.odd_iff ] ; omega;

/-
PROBLEM
IMO 2016 P6 part (a).

PROVIDED SOLUTION
Use imo_2016_p6_parity_assignment and imo_2016_p6_triangle_parity.

STEP 1: Define F.
  let ref : Fin n := ⟨0, by omega⟩
  use fun i => (i, if h : ref = i then false else decide (Even ((interBtw ref ⟨i, h⟩).val + (interBtw i ⟨ref, Ne.symm h⟩).val)))

STEP 2: intro f g hfg; refine ⟨hfg, fun t hcoll => ?_⟩

STEP 3: From hcoll, use lineMap_eq_iff to get parameter equalities.
  The key: (lineMap_eq_iff f g hfg ...).mp hcoll gives:
    interAlong f (clap (bf) t) = interAlong f (interBtw f ⟨g, hfg⟩)  AND
    interAlong g (clap (bg) t) = interAlong g (interBtw g ⟨f, hfg.symm⟩)
  By (interAlong f).injective and (interAlong g).injective:
    clap (bf) t = interBtw f ⟨g, hfg⟩
    clap (bg) t = interBtw g ⟨f, hfg.symm⟩

STEP 4: Get parity constraints from imo_2016_p6_parity_assignment.

STEP 5: by_cases hb : bf = bg
  Case bf = bg:
    Since clap bf = clap bg (same function), we get:
      interBtw f ⟨g⟩ = interBtw g ⟨f⟩
    (because clap bf t = interBtw f ⟨g⟩ and clap bg t = interBtw g ⟨f⟩ and clap bf = clap bg)
    So their .val are equal. But parity says .val ≠ .val. Contradiction.

  Case bf ≠ bg:
    WLOG bf = false, bg = true (handle both subcases).
    clap false t = id t = t, so interBtw f ⟨g⟩ = t.
    clap true t = Fin.rev t, so interBtw g ⟨f⟩ = Fin.rev t.
    .val sum = t.val + (n-1-1 - t.val) = n - 2.
    But parity says sum ≠ n - 2. Contradiction.

KEY LEAN DETAILS:
- To apply lineMap_eq_iff, the parameters are Subtype values in Set.Ioo 0 1.
  Use (interAlong f (clap (bf) t)) which has type ↑(Set.Ioo 0 1).
- Injectivity: OrderEmbedding.injective gives Subtype-level injection.
  Need to go from Subtype equality to Fin equality.
- For Fin.rev: Fin.val_rev gives (Fin.rev t).val = n - 1 - 1 - t.val.
- AVOID grind tactic (it times out). Use omega, simp, and exact.
- For the ≠ case: use cases on Bool to split bf and bg values.
-/
set_option maxHeartbeats 800000 in
theorem imo_2016_p6.parts.a (n : ℕ) (hn : 2 ≤ n)
    (points : Fin n → ℝ² × ℝ²)
    (hpoints : ∀ i, (points i).1 ≠ (points i).2)
    (interAlong : Fin n → Fin (n - 1 : ℕ) ↪o Set.Ioo (0 : ℝ) 1)
    (interBtw : (i : Fin n) → {j // i ≠ j} ≃ Fin (n - 1 : ℕ))
    (lineMap_eq_iff : ∀ i j (hij : i ≠ j),
      ∀ ri rj : Set.Ioo 0 (1 : ℝ),
        lineMap (points i).1 (points i).2 ri.1 =
        lineMap (points j).1 (points j).2 rj.1 ↔
          ri = interAlong i (interBtw i ⟨j, hij⟩) ∧
          rj = interAlong j (interBtw j ⟨i, hij.symm⟩))
    (clap : Bool → Fin (n - 1 : ℕ) → Fin (n - 1 : ℕ))
    (clap_def : ∀ b, clap b = if b then Fin.rev else id)
    (hn : Odd n) :
    ∃ F : Fin n → Fin n × Bool,
      ∀ f g (hfg : f ≠ g),
        (F f).1 ≠ (F g).1 ∧
        ∀ t : Fin (n - 1 : ℕ),
        lineMap (points (F f).1).1 (points (F f).1).2 (interAlong (F f).1 (clap (F f).2 t)).1 ≠
        lineMap (points (F g).1).1 (points (F g).1).2 (interAlong (F g).1 (clap (F g).2 t)).1 := by
  use fun i => (i, if h : ⟨0, by omega⟩ = i then false else decide (Even ((interBtw ⟨0, by omega⟩ ⟨i, h⟩).val + (interBtw i ⟨⟨0, by omega⟩, Ne.symm h⟩).val)));
  intro f g hfg;
  simp [hfg];
  intro t ht
  have h_eq : clap (if h : ⟨0, by omega⟩ = f then false else decide (Even ((interBtw ⟨0, by omega⟩ ⟨f, h⟩).val + (interBtw f ⟨⟨0, by omega⟩, Ne.symm h⟩).val))) t = interBtw f ⟨g, hfg⟩ ∧ clap (if h : ⟨0, by omega⟩ = g then false else decide (Even ((interBtw ⟨0, by omega⟩ ⟨g, h⟩).val + (interBtw g ⟨⟨0, by omega⟩, Ne.symm h⟩).val))) t = interBtw g ⟨f, hfg.symm⟩ := by
    have := lineMap_eq_iff f g hfg ( interAlong f ( clap ( if h : ⟨ 0, by omega ⟩ = f then false else decide ( Even ( ( interBtw ⟨ 0, by omega ⟩ ⟨ f, h ⟩ : ℕ ) + ( interBtw f ⟨ ⟨ 0, by omega ⟩, Ne.symm h ⟩ : ℕ ) ) ) ) t ) ) ( interAlong g ( clap ( if h : ⟨ 0, by omega ⟩ = g then false else decide ( Even ( ( interBtw ⟨ 0, by omega ⟩ ⟨ g, h ⟩ : ℕ ) + ( interBtw g ⟨ ⟨ 0, by omega ⟩, Ne.symm h ⟩ : ℕ ) ) ) ) t ) ) ; aesop;
  have := imo_2016_p6_parity_assignment n ‹_› interBtw hn (fun i j k hij hik hjk => ?_) f g hfg;
  · split_ifs at * <;> simp_all +decide only [Fin.rev];
    · tauto;
    · grind;
    · grind +ring;
    · grind;
  · convert imo_2016_p6_triangle_parity n ‹_› points hpoints interAlong interBtw lineMap_eq_iff i j k hij hik hjk using 1

/--
IMO 2016 P6 part (b).
-/
theorem imo_2016_p6.parts.b (n : ℕ) (hn : 2 ≤ n)
    (points : Fin n → ℝ² × ℝ²)
    (hpoints : ∀ i, (points i).1 ≠ (points i).2)
    (interAlong : Fin n → Fin (n - 1 : ℕ) ↪o Set.Ioo (0 : ℝ) 1)
    (interBtw : (i : Fin n) → {j // i ≠ j} ≃ Fin (n - 1 : ℕ))
    (lineMap_eq_iff : ∀ i j (hij : i ≠ j),
      ∀ ri rj : Set.Ioo 0 (1 : ℝ),
        lineMap (points i).1 (points i).2 ri.1 =
        lineMap (points j).1 (points j).2 rj.1 ↔
          ri = interAlong i (interBtw i ⟨j, hij⟩) ∧
          rj = interAlong j (interBtw j ⟨i, hij.symm⟩))
    (clap : Bool → Fin (n - 1 : ℕ) → Fin (n - 1 : ℕ))
    (clap_def : ∀ b, clap b = if b then Fin.rev else id)
    (hn : Even n) :
    ¬ ∃ F : Fin n → Fin n × Bool,
      Pairwise fun f g ↦
        (F f).1 ≠ (F g).1 ∧
        ∀ t : Fin (n - 1 : ℕ),
          lineMap (points (F f).1).1 (points (F f).1).2 (interAlong (F f).1 (clap (F f).2 t)).1 ≠
          lineMap (points (F g).1).1 (points (F g).1).2 (interAlong (F g).1 (clap (F g).2 t)).1 := by
  sorry

@[imo_problem_subject combinatorics]
