-- logCounting decomposition
private lemma logCounting_eq_decomposition {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f)
    (hr : r ≠ 0) (a₀ : ℂ) :
    logCounting f (↑a₀) r = circleAverage (fun z => log ‖f z - a₀‖) 0 r
      - log ‖meromorphicTrailingCoeffAt (fun z => f z - a₀) 0‖ + logCounting f ⊤ r := by
  have h₁ : logCounting f (↑a₀) r = logCounting (fun z => f z - a₀) 0 r := by
    rw [logCounting_coe_eq_logCounting_sub_const_zero]; rfl
  rw [h₁]
  have h₂ : Meromorphic (fun z => f z - a₀) := h.sub (Meromorphic.const a₀)
  have h₃ := logCounting_zero_sub_logCounting_top_eq_circleAverage_sub_const h₂ hr
  have h₄ : logCounting (fun z => f z - a₀) ⊤ = logCounting f ⊤ := by
    have : (fun z => f z - a₀) = f - fun _ => a₀ := rfl
    rw [this, logCounting_sub_const h]
  simp [Pi.sub_apply] at h₃
  have h₅ : logCounting (fun z ↦ f z - a₀) ⊤ r = logCounting f ⊤ r := by rw [h₄]
  linarith

/--
Helper Lemma: The logarithmic counting function is circle integrable. The right
side of the equality in Cartan's theorem is therefore meaningful.
-/
-- Helper: the circleAverage of log norm is continuous (hence circle integrable)
-- Proof: By MeasureTheory.continuousWithinAt_of_dominated at each point x₀ on the sphere.
-- The dominator bound(θ) = posLog ‖f(circleMap 0 r θ)‖ + posLog ‖(f(circleMap 0 r θ) - x₀)⁻¹‖ + C
-- is integrable by circleIntegrable_posLog_norm_meromorphicOn and circleIntegrable_log_norm_meromorphicOn.
private lemma continuous_circleAverage_log_norm {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f)
    (hr : r ≠ 0) :
    Continuous (fun a₀ => circleAverage (fun z => log ‖f z - a₀‖) 0 r) := by
  sorry

set_option maxHeartbeats 400000 in
lemma logCounting_circleIntegrable {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (logCounting f · r) 0 1 := by
  by_cases hr : r = 0
  · -- For r = 0, logCounting f a 0 = 0
    subst hr
    show CircleIntegrable (fun x : ℂ => logCounting f (↑x) 0) 0 1
    convert circleIntegrable_const (0 : ℝ) (0 : ℂ) (1 : ℝ) using 1
    ext; exact logCounting_eval_zero
  · -- For r ≠ 0, decompose via Jensen formula
    show CircleIntegrable (fun x : ℂ => logCounting f (↑x) r) 0 1
    have hdecomp : ∀ a₀ : ℂ, logCounting f (↑a₀) r =
        circleAverage (fun z => log ‖f z - a₀‖) 0 r
        - log ‖meromorphicTrailingCoeffAt (fun z => f z - a₀) 0‖
        + logCounting f ⊤ r :=
      logCounting_eq_decomposition h hr
    -- Each piece is circle integrable
    have h1 : CircleIntegrable (fun a₀ => circleAverage (fun z => log ‖f z - a₀‖) 0 r) 0 1 :=
      (continuous_circleAverage_log_norm h hr).continuousOn.circleIntegrable'
    have h2 : CircleIntegrable
        (fun a₀ => log ‖meromorphicTrailingCoeffAt (fun z => f z - a₀) 0‖) 0 1 :=
      circleIntegrable_log_trailingCoeff h
    have h3 : CircleIntegrable (fun _ : ℂ => logCounting f ⊤ r) 0 1 :=
      circleIntegrable_const _ 0 1
    -- Combine: logCounting = h1 - h2 + h3
    have heq : (fun x : ℂ => logCounting f (↑x) r) =
        (fun a₀ => circleAverage (fun z => log ‖f z - a₀‖) 0 r
        - log ‖meromorphicTrailingCoeffAt (fun z => f z - a₀) 0‖
        + logCounting f ⊤ r) := by
      ext a₀; exact hdecomp a₀
    rw [heq]
    exact (h1.sub h2).add h3

/--
Cartan's theorem, qualitative version: Up to a constant, the characteristic
function for the poles of `f` equals a circle integral over the logarithmic
counting functions for the `z`-values of `f`, where `z` is the integration
variable.
-/
theorem characteristic_top_eq_circleAverage_logCounting_add_const {f : ℂ → ℂ} (h : Meromorphic f) :
    ∃ const, ∀ r ≠ 0, characteristic f ⊤ r = circleAverage (logCounting f · r) 0 1 + const := by
  sorry


end ValueDistribution

