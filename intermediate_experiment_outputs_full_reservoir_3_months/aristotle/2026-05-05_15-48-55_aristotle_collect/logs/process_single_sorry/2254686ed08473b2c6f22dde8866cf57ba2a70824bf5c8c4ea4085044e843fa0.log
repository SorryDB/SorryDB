import Mathlib

open Filter Function MeromorphicOn Metric Real Set Classical Topology ValueDistribution

namespace ValueDistribution

-- Helper: trailing coefficient for pole case
private lemma trailingCoeff_pole {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : meromorphicOrderAt f 0 < 0) (a₀ : ℂ) :
    meromorphicTrailingCoeffAt (fun z => f z - a₀) 0 = meromorphicTrailingCoeffAt f 0 := by
  convert MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_left_of_lt _ _ using 1;
  convert rfl using 2;
  ext z;
  rw [ Pi.add_apply, sub_eq_add_neg ];
  · exact?;
  · exact hord.trans_le ( by erw [ meromorphicOrderAt_const ] ; aesop )

-- Helper: trailing coefficient for order 0 case
private lemma trailingCoeff_order_zero {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : meromorphicOrderAt f 0 = 0) (a₀ : ℂ)
    (ha₀ : a₀ ≠ meromorphicTrailingCoeffAt f 0) :
    meromorphicTrailingCoeffAt (fun z => f z - a₀) 0 =
      meromorphicTrailingCoeffAt f 0 - a₀ := by
  by_cases ha : a₀ = 0 <;> simp_all +decide [ sub_eq_add_neg ];
  convert MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_add _ _ _ _ using 1 <;> norm_num [ hord, ha ];
  · exact?;
  · rw [ eq_comm, meromorphicOrderAt_const ] ; aesop;
  · exact fun h => ha₀ <| by linear_combination' -h;

-- Helper: trailing coefficient for positive order case
private lemma trailingCoeff_pos_order {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : 0 < meromorphicOrderAt f 0)  (a₀ : ℂ) (ha₀ : a₀ ≠ 0) :
    meromorphicTrailingCoeffAt (fun z => f z - a₀) 0 = -a₀ := by
  by_contra h_contra;
  have := @MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_left_of_lt; simp_all +decide [ add_comm ] ;
  convert @this ℂ _ ℂ _ _ 0 ( fun _ => -a₀ ) f _ _ using 1 <;> norm_num [ ha₀, hord ];
  · convert h_contra using 1 ; rw [ add_comm ] ; aesop;
  · exact h 0;
  · rw [ meromorphicOrderAt_const ] ; aesop;

-- Helper: the log trailing coefficient function is circle integrable
private lemma circleIntegrable_log_trailingCoeff {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (fun a₀ => log ‖meromorphicTrailingCoeffAt (fun z => f z - a₀) 0‖) 0 1 := by
  by_cases h_order : meromorphicOrderAt f 0 < 0;
  · rw [ show ( fun a₀ => log ‖meromorphicTrailingCoeffAt ( fun z => f z - a₀ ) 0‖ ) = fun _ => log ‖meromorphicTrailingCoeffAt f 0‖ from funext fun _ => ?_ ] ; exact circleIntegrable_const _ _ _;
    rw [ trailingCoeff_pole h h_order ];
  · cases' lt_or_eq_of_le ( le_of_not_gt h_order ) with h_order h_order <;> simp_all +decide [ CircleIntegrable ];
    · have h_trailing : ∀ θ : ℝ, meromorphicTrailingCoeffAt (fun z => f z - circleMap 0 1 θ) 0 = -circleMap 0 1 θ := by
        intro θ; exact trailingCoeff_pos_order h h_order ( circleMap 0 1 θ ) ( by norm_num [ circleMap ] ) ;
      simp_all +decide [ circleMap ];
    · have h_trailing_coeff : ∀ θ ∈ Set.Icc 0 (2 * Real.pi), circleMap 0 1 θ ≠ meromorphicTrailingCoeffAt f 0 → meromorphicTrailingCoeffAt (fun z => f z - circleMap 0 1 θ) 0 = meromorphicTrailingCoeffAt f 0 - circleMap 0 1 θ := by
        intro θ hθ hne; exact trailingCoeff_order_zero h ( h_order.symm ) _ hne;
      rw [ intervalIntegrable_iff_integrableOn_Ioo_of_le Real.two_pi_pos.le ];
      have h_measure_zero : MeasureTheory.volume {θ ∈ Set.Ioo 0 (2 * Real.pi) | circleMap 0 1 θ = meromorphicTrailingCoeffAt f 0} = 0 := by
        have h_singleton : {θ ∈ Set.Ioo 0 (2 * Real.pi) | circleMap 0 1 θ = meromorphicTrailingCoeffAt f 0} ⊆ {θ ∈ Set.Ioo 0 (2 * Real.pi) | Complex.exp (θ * Complex.I) = meromorphicTrailingCoeffAt f 0} := by
          simp +decide [ circleMap ];
        have h_singleton_exp : {θ ∈ Set.Ioo 0 (2 * Real.pi) | Complex.exp (θ * Complex.I) = meromorphicTrailingCoeffAt f 0}.Finite := by
          refine' Set.Subsingleton.finite _;
          intros θ₁ hθ₁ θ₂ hθ₂; have := Complex.exp_eq_exp_iff_exists_int.mp ( hθ₁.2.trans hθ₂.2.symm ) ; obtain ⟨ k, hk ⟩ := this; rcases k with ⟨ _ | k ⟩ <;> norm_num [ Complex.ext_iff ] at hk <;> nlinarith [ Real.pi_pos, hθ₁.1.1, hθ₁.1.2, hθ₂.1.1, hθ₂.1.2 ] ;
        exact MeasureTheory.measure_mono_null h_singleton ( h_singleton_exp.countable.measure_zero MeasureTheory.MeasureSpace.volume );
      have h_integrable : MeasureTheory.IntegrableOn (fun θ => log ‖meromorphicTrailingCoeffAt f 0 - circleMap 0 1 θ‖) (Set.Ioo 0 (2 * Real.pi)) MeasureTheory.volume := by
        have h_integrable : MeasureTheory.IntegrableOn (fun θ => log ‖circleMap 0 1 θ - meromorphicTrailingCoeffAt f 0‖) (Set.Ioo 0 (2 * Real.pi)) MeasureTheory.volume := by
          have h_circle_integrable : CircleIntegrable (fun z => log ‖z - meromorphicTrailingCoeffAt f 0‖) 0 1 := by
