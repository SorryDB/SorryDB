          apply hk1
          have hbv : k.bv.toNat = (1#u32).bv.toNat := by
            change k.val = 1 at heq; simp only [UScalar.val] at heq; exact heq
          exact U32.bv_eq_imp_eq_iff.mpr (BitVec.toNat_injective hbv)
        omega
      obtain ⟨km1, hkm1_eq, _, _⟩ := u32_sub_one_ok k hk_gt1
      obtain ⟨e_k, e_km1, e_km1_double, eq_choice, h_mul, h_mul_km1, h_double, h_ct_eq, h_choice⟩ :=
        mul_by_pow_2_step e k km1 hk_gt1 hkm1_eq
      exact ⟨e_k, h_mul,
