  rw [reduce₁ h₁, reduce₂ h₂]

lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩

  sorry

lemma fail₂ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
    e.eval ≠ (bits2num args) -> (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
  intros w args e cs h
  unfold Cs.eval Exp.eval
  sorry

lemma fail : ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
 (¬ (assert_bits args /\ e.eval = bits2num args)) ->
 (assert_bits_e args (.eq0 (bits2num_e args - e) cs)).eval = denotation.n := by
  intros w args e cs h
  by_cases h' : assert_bits args
  · rw [reduce₁ h', fail₂ (by tauto)]
  · rw [fail₁ h']

lemma bits_good : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  e.eval.val < 2 ^ w -> assert_bits args /\ e = bits2num args := sorry

/-
PROVIDED SOLUTION
By induction on w.
Base case (w=0): args is empty, bits2num #v[] = 0, and (0 : ZMod p).val = 0 < 1 = 2^0.
Inductive case (w+1): We have args with head b and tail.
assert_bits args means b ∈ {0,1} and assert_bits tail.
bits2num args unfolds the foldl: the result is b + 2 * (bits2num tail_part).
But careful: Vector.foldl processes left to right.

Actually, let me reconsider. bits2num uses Vector.foldl with (fun acc b => b + 2 * acc) starting from 0.
For a vector [b0, b1, ..., b_{w-1}], this computes:
  step 0: 0
  step 1: b0 + 2*0 = b0
  step 2: b1 + 2*b0
  step 3: b2 + 2*(b1 + 2*b0)
  ...
So the result is b_{w-1} + 2*b_{w-2} + ... + 2^{w-1}*b0.

Each b_i.val ∈ {0, 1}. The maximum is sum of 2^i for i=0..w-1 = 2^w - 1.

We need: val of this ZMod p element < 2^w.
Since p is prime (≥ 2), and the "natural" value is ≤ 2^w - 1 < p when p > 2^w - 1.
But if p ≤ 2^w - 1, the val could be different...
Actually val is always < p, and if p ≤ 2^w, then val < p ≤ 2^w. So it works!

Case 1: p ≤ 2^w. Then val < p ≤ 2^w. Done.
Case 2: p > 2^w. Then the natural value ≤ 2^w - 1 < p, so val = natural value < 2^w.

For case 2, we need to show the "natural" value of (b + 2*acc) in ZMod p when 0 ≤ natural_val < p.
Use ZMod.val_add and ZMod.val_mul when the sum/product < p.

This is complex. Try induction on w with the Vector structure.
-/
lemma assert_bits_val_lt (w : ℕ) (args : Vector (ZMod p) w) :
    assert_bits args = true → (bits2num args).val < 2 ^ w := by
      revert args;
      induction w <;> simp_all +decide [ bits2num ];
      · simp +decide [ Vector.foldl ];
        aesop;
      · rename_i n ih;
        intro args h
        obtain ⟨b, args', h_split⟩ : ∃ b : ZMod p, ∃ args' : Vector (ZMod p) n, args = args'.push b := by
          use args.get ⟨n, by linarith⟩, Vector.ofFn (fun i => args.get ⟨i, by
            exact Nat.lt_succ_of_lt i.2⟩)
          generalize_proofs at *;
          refine' Vector.ext _;
          intro i hi; by_cases hi' : i < n <;> simp_all +decide [ Vector.get ] ;
          cases hi'.eq_or_lt <;> first | linarith | aesop;
        simp_all +decide [ Vector.foldl_push, pow_succ' ];
        -- Since $b$ is a bit, we have $b.val \in \{0, 1\}$.
        have hb : b.val = 0 ∨ b.val = 1 := by
          have := h;
          unfold assert_bits at this; simp_all +decide [ Vector.all ] ;
          cases this.2 <;> simp +decide [ * ];
          rcases p with ( _ | _ | p ) <;> norm_cast;
        cases hb <;> simp_all +decide [ ZMod.val_add, ZMod.val_mul ];
        · refine' lt_of_le_of_lt ( Nat.mod_le _ _ ) _;
          refine' lt_of_le_of_lt ( Nat.mul_le_mul ( show ZMod.val 2 ≤ 2 from _ ) le_rfl ) _;
          · rcases p with ( _ | _ | _ | p ) <;> norm_num [ ZMod.val ] at *;
            rw [ Nat.mod_eq_of_lt ] ; linarith;
          · unfold assert_bits at *; aesop;
        · refine' lt_of_le_of_lt ( Nat.mod_le _ _ ) _;
          erw [ ZMod.val_natCast ];
          rcases p with ( _ | _ | _ | p ) <;> simp_all +arith +decide [ Nat.mod_eq_of_lt ];
          · exact absurd Fact.out ( Nat.not_prime_zero );
          · exact absurd ( Fact.out ( p := Nat.Prime 1 ) ) ( by decide );
          · have : 0 < 2^n := Nat.pos_of_ne_zero (by positivity); linarith;
          · linarith [ ih args' ( by
              unfold assert_bits at *; aesop; ) ]

lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
    intros w args e h_enoughbits h_contra
    obtain ⟨h_bits, h_eq⟩ := h_contra;
    exact h_enoughbits <| by rw [ h_eq ] ; exact ( by simpa [ Exp.eval ] using ( @assert_bits_val_lt p ‹_› ) w args h_bits ) ;

theorem soundness : ∀ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs]
    constructor
  | lam k h =>
    simp [Circuit.eval,to_cs]
    constructor
    exact h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    split
    apply h
    constructor
  | share e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    apply rw_bisim.right
    intro x
    simp [Exp.eval]
    split
    have hmy : x = Exp.eval e := by grind
    rw [<-hmy]
    apply h
    constructor
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    split
    case is_zero.h.h.isTrue he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          have hmy : o=1 := by grind
          rw [hmy]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
    case is_zero.h.h.isFalse he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          rw [hmul]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
  | assert_range w e c h =>
    simp [Circuit.eval,to_cs]
    apply rw_bisim_uncurry
    intros args
    split
    case _ ew =>
      rw [reduce]
      apply h
      sorry
      -- apply bits_good
      -- assumption
    case _ lt w =>
      rw [fail]
      constructor
      sorry
      -- apply bits_bad
      -- assumption

theorem soundness' : ∀ (c:Circuit' p),
  rw_bisim (Circuit.eval' c) (Cs.eval' (to_cs' c)) := by
  intro c
  apply soundness

def completeness : ∀ (c:Circuit p (ZMod p)),
  Circuit.eval c = Cs.eval (wrap (to_wg c) (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs,to_wg,wrap]
    constructor
  | lam k h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    funext
    apply h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    exact h
    constructor
  | share e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    apply h
  | is_zero e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    case is_zero.isTrue he0 =>
      simp
      split <;> apply h
    case is_zero.isFalse he0 =>
      split
      case isTrue he0' =>
        apply h
      case isFalse he0' =>
        simp [*] at *
  | assert_range e c h =>
    sorry
