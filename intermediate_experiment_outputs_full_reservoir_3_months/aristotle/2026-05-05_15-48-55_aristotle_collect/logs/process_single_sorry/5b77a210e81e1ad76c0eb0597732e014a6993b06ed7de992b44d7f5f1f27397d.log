import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  by_contra! h_contra;
  obtain ⟨s, hs⟩ : ∃ s : Set ℕ+, Set.Infinite s ∧ ∀ m ∈ s, ∀ n ∈ s, m < n → Nat.Coprime (2 ^ (n : ℕ) - 3) (2 ^ (m : ℕ) - 3) := by
    -- We'll use induction to construct the set $s$.
    have h_inductive_construction : ∃ f : ℕ → ℕ+, StrictMono f ∧ ∀ i j, i < j → Nat.Coprime (2 ^ (f j : ℕ) - 3) (2 ^ (f i : ℕ) - 3) := by
      -- We'll use induction to construct the sequence.
      have h_inductive_step : ∀ n : ℕ, ∃ m > n, Nat.Coprime (2 ^ (m : ℕ) - 3) (∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3)) := by
        intro n
        obtain ⟨m, hm⟩ : ∃ m > n, 2 ^ m ≡ 1 [MOD ∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3)] := by
          use (Nat.totient (∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3))) * (n + 1) + Nat.totient (∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3));
          refine' ⟨ _, _ ⟩
          all_goals generalize_proofs at *;
          · nlinarith [ show 0 < Nat.totient ( ∏ i ∈ Finset.range n, ( 2 ^ ( i + 2 ) - 3 ) ) from Nat.pos_of_ne_zero ( by exact Nat.ne_of_gt <| Nat.totient_pos.mpr <| Finset.prod_pos fun i hi => Nat.sub_pos_of_lt <| by linarith [ Nat.pow_le_pow_right two_pos <| show i + 2 ≥ 2 by linarith ] ) ];
          · -- By Euler's theorem, since $2$ and $\prod_{i=0}^{n-1} (2^{i+2} - 3)$ are coprime, we have $2^{\phi(\prod_{i=0}^{n-1} (2^{i+2} - 3))} \equiv 1 \pmod{\prod_{i=0}^{n-1} (2^{i+2} - 3)}$.
            have h_euler : 2 ^ Nat.totient (∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3)) ≡ 1 [MOD ∏ i ∈ Finset.range n, (2 ^ (i + 2 : ℕ) - 3)] := by
              refine' Nat.ModEq.pow_totient _;
              refine' Nat.Coprime.prod_right fun i hi => _;
              exact Nat.prime_two.coprime_iff_not_dvd.mpr ( by rw [ ← even_iff_two_dvd ] ; rw [ Nat.even_sub ( by linarith [ Nat.pow_le_pow_right two_pos ( by linarith : i + 2 ≥ 2 ) ] ) ] ; norm_num [ Nat.one_le_iff_ne_zero, parity_simps ] ) ;
            generalize_proofs at *; (
            simp_all +decide [ ← ZMod.natCast_eq_natCast_iff, pow_add, pow_mul ])
        use m + 2
        generalize_proofs at *; (
        simp_all +decide [ ← ZMod.natCast_eq_natCast_iff, pow_add ];
        -- Since $2^m \equiv 1 \pmod{P}$, we have $2^m * 4 - 3 \equiv 4 - 3 \equiv 1 \pmod{P}$.
        have h_cong : (2 ^ m * 4 - 3 : ℕ) ≡ 1 [MOD ∏ x ∈ Finset.range n, (2 ^ x * 4 - 3)] := by
          simp_all +decide [ ← ZMod.natCast_eq_natCast_iff ];
          rw [ Nat.cast_sub ] <;> norm_num [ hm.2 ] ; linarith [ Nat.pow_le_pow_right two_pos ( show m ≥ 1 by linarith ) ] ;
        generalize_proofs at *; (
        exact ⟨ by linarith, by simpa using h_cong.gcd_eq ⟩));
      choose f hf using h_inductive_step;
      refine' ⟨ fun n => ⟨ f ( Nat.recOn n 2 fun n ih => f ih ), _ ⟩, _, _ ⟩ <;> norm_num;
      grind;
      · exact strictMono_nat_of_lt_succ fun n => hf _ |>.1;
      · intro i j hij; have := hf ( Nat.rec 2 ( fun n ih => f ih ) j ) ; have := hf ( Nat.rec 2 ( fun n ih => f ih ) i ) ; simp_all +decide [ Nat.coprime_prod_right_iff, Nat.coprime_prod_left_iff ] ;
        convert ‹∀ i < Nat.rec 2 ( fun n ih => f ih ) j, Nat.Coprime ( 2 ^ f ( Nat.rec 2 ( fun n ih => f ih ) j ) - 3 ) ( 2 ^ ( i + 2 ) - 3 ) › ( f ( Nat.rec 2 ( fun n ih => f ih ) i ) - 2 ) _ using 1;
        · rw [ Nat.sub_add_cancel ( show 2 ≤ f ( Nat.rec 2 ( fun n ih => f ih ) i ) from by linarith [ hf ( Nat.rec 2 ( fun n ih => f ih ) i ), show Nat.rec 2 ( fun n ih => f ih ) i ≥ 2 from Nat.recOn i ( by norm_num ) fun n ihn => by linarith [ hf ( Nat.rec 2 ( fun n ih => f ih ) n ) ] ] ) ];
        · refine' lt_of_lt_of_le ( Nat.sub_lt ( by linarith [ hf ( Nat.rec 2 ( fun n ih => f ih ) i ) ] ) zero_lt_two ) _;
          exact Nat.le_induction ( by linarith [ hf ( Nat.rec 2 ( fun n ih => f ih ) i ) ] ) ( fun k hk ih => by linarith [ hf ( Nat.rec 2 ( fun n ih => f ih ) k ) ] ) j hij;
    obtain ⟨ f, hf_mono, hf_coprime ⟩ := h_inductive_construction;
    exact ⟨ Set.range f, Set.infinite_range_of_injective hf_mono.injective, by rintro _ ⟨ i, rfl ⟩ _ ⟨ j, rfl ⟩ hij; exact hf_coprime _ _ ( hf_mono.lt_iff_lt.mp hij ) ⟩;
