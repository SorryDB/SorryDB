      sorry
    _ = вИС w вИИ (piAntidiag A m).map
          вЯ®(2 вАҐ ¬Ј), fun _ _ h вЖ¶ funext fun i вЖ¶ mul_right_injectiveвВА two_ne_zero (congr_fun h i)вЯ©,
        multinomial A w * вИЂ ѕЙ, вИП i вИИ A, вАЦX i ѕЙвАЦ ^ w i вИВќЉ := by
      rw [map_nsmul_piAntidiag _ _ two_ne_zero]
    _ = вИС w вИИ piAntidiag A m, multinomial A (2 вАҐ w) * вИЂ ѕЙ, вИП i вИИ A, вАЦX i ѕЙвАЦ ^ (2 * w i) вИВќЉ := by
      simp
    -- Use the fact that `(2m choose 2wвВБ, ..., 2wвВР) вЙ§ m ^ m * (m choose wвВБ, ..., wвВР)`.
    _ вЙ§ вИС w вИИ piAntidiag A m, marcinkiewiczZygmundSymmConst (2 * m) * multinomial A w *
          вИЂ ѕЙ, вИП i вИИ A, вАЦX i ѕЙвАЦ ^ (2 * w i) вИВќЉ := by
      gcongr with w hw
      calc
        (multinomial A (2 вАҐ w) : вДЭ)
        _ вЙ§ ((вИС i вИИ A, w i) ^ вИС i вИИ A, w i) * multinomial A w :=
