    -- Rewrite the sum of `рЭФЉ вИП k, вАЦX iвВЦ ѕЙвАЦ * вАЦX jвВЦ ѕЙвАЦ` over even families of indices
    -- `iвВБ, ..., iвВЩ, jвВБ, ..., jвВЩ` into the sum over `wвВБ + ... + wвВР = m` of
    -- `(2m choose 2wвВБ, ..., 2wвВР) * рЭФЉ вИП i, вАЦX iвАЦ ^ wбµҐ`.
    _ = вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I,
          вИЂ ѕЙ, вИП i вИИ A, вАЦX i ѕЙвАЦ ^ (#{k | (I k).1 = i} + #{k | (I k).2 = i}) вИВќЉ := by
      congr! with I hI ѕЙ
      simp only [mem_filter, mem_piFinset, mem_product, forall_and] at hI
      simp_rw [pow_add, prod_mul_distrib, вЖР prod_const]
      rw [prod_fiberwise_of_maps_to', prod_fiberwise_of_maps_to']
      ¬Ј simpa using hI.1.2
