/-- The constant appearing in the Marcinkiewicz-Zygmund inequality for random variables with zero
mean. -/
noncomputable def marcinkiewiczZygmundConst (p : вДЭвЙ•0) : вДЭ :=
  2 ^ (p / 2 : вДЭ) * marcinkiewiczZygmundSymmConst p

/-- The **Marcinkiewicz-Zygmund inequality** for random variables with zero mean.

For symmetric random variables, `marcinkiewicz_zygmund` provides a slightly better constant. -/
theorem marcinkiewicz_zygmund (iIndepFun_X : iIndepFun X ќЉ)
    (integral_X : вИА i, вИЂ ѕЙ, X i ѕЙ вИВќЉ = 0)
    (memLp_X : вИА i вИИ A, MemLp (X i) (2 * m) ќЉ) :
    вИЂ ѕЙ, вАЦвИС i вИИ A, X i ѕЙвАЦ ^ (2 * m) вИВќЉ вЙ§
      marcinkiewiczZygmundConst (2 * m) * вИЂ ѕЙ, (вИС i вИИ A, вАЦX i ѕЙвАЦ ^ 2) ^ m вИВќЉ := by
  let XвВБ i : ќ© √Ч ќ© вЖТ E := X i вИШ Prod.fst
  let XвВВ i : ќ© √Ч ќ© вЖТ E := X i вИШ Prod.snd
  let X' i : ќ© √Ч ќ© вЖТ E := XвВБ i - XвВВ i
  have : DecidableEq ќє := Classical.decEq _
  calc
    вИЂ ѕЙ, вАЦвИС i вИИ A, X i ѕЙвАЦ ^ (2 * m) вИВќЉ
    _ вЙ§ вИЂ ѕЙ, вАЦвИС i вИИ A, X' i ѕЙвАЦ ^ (2 * m) вИВќЉ.prod ќЉ := by
      sorry
    _ вЙ§ marcinkiewiczZygmundSymmConst (2 * m) * вИЂ ѕЙ, (вИС i вИИ A, вАЦX' i ѕЙвАЦ ^ 2) ^ m вИВќЉ.prod ќЉ :=
      marcinkiewicz_zygmund_symmetric sorry (fun i вЖ¶ sorry) sorry
    _ вЙ§ marcinkiewiczZygmundConst (2 * m) * вИЂ ѕЙ, (вИС i вИИ A, вАЦX i ѕЙвАЦ ^ 2) ^ m вИВќЉ := sorry

