import Mathlib.Data.Nat.Choose.Multinomial
import Mathlib.Probability.IdentDistrib

/-!
# The Marcinkiewicz-Zygmund inequality

This file proves the Marcinkiewicz-Zygmund inequality.

The Marcinkiewicz-Zygmund inequality states that, if `XвВБ, ... XвВР вИИ L^p` are independent random
variables of mean zero valued in some inner product space, then the `L^p`-norm of `XвВБ + ... + XвВР` is
at most `CвВЪ` times the `L^(p/2)`-norm of `|XвВБ|¬≤ + ... + |XвВР|¬≤`, where `CвВЪ` is a constant depending
on `p` alone.

## Notation

Throughout this file, `A ^^ n` denotes `A √Ч ... √Ч A` (with `n` factors). Formally, this is
`Fintype.piFinset fun _ : Fin n вЖ¶ A`.

## TODO

We currently only prove the inequality for `p = 2 * m` an even natural number. The general `p` case
can be obtained from this specific one by nesting of Lp norms.
-/

open Finset Fintype Function Nat MeasureTheory ProbabilityTheory Real
open scoped NNReal ENNReal

variable {ќє ќ© E : Type*} {A : Finset ќє} {m n : вДХ} [MeasurableSpace ќ©] {ќЉ : Measure ќ©}
  [IsFiniteMeasure ќЉ] [mE : MeasurableSpace E] [NormedAddCommGroup E] [InnerProductSpace вДЭ E]
  {X : ќє вЖТ ќ© вЖТ E}

local notation:70 A:70 " ^^ " n:71 => Fintype.piFinset fun _ : Fin n вЖ¶ A

/-- The constant appearing in the Marcinkiewicz-Zygmund inequality for symmetric random variables.
-/
noncomputable def marcinkiewiczZygmundSymmConst (p : вДЭвЙ•0) : вДЭ := (p / 2) ^ (p / 2 : вДЭ)

/-- The **Marcinkiewicz-Zygmund inequality** for symmetric random variables, with a slightly better
constant than `marcinkiewicz_zygmund`. -/
theorem marcinkiewicz_zygmund_symmetric (iIndepFun_X : iIndepFun X ќЉ)
    (identDistrib_neg_X : вИА i, IdentDistrib (X i) (-X i) ќЉ ќЉ)
    (memLp_X : вИА i вИИ A, MemLp (X i) (2 * m) ќЉ) :
    вИЂ ѕЙ, вАЦвИС i вИИ A, X i ѕЙвАЦ ^ (2 * m) вИВќЉ вЙ§
      marcinkiewiczZygmundSymmConst (2 * m) * вИЂ ѕЙ, (вИС i вИИ A, вАЦX i ѕЙвАЦ ^ 2) ^ m вИВќЉ := by
  have : DecidableEq ќє := Classical.decEq _
  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I вИИ A √ЧЋҐ A ^^ m) :
    Integrable (fun ѕЙ вЖ¶ вИП k, вАЦX (I k).1 ѕЙвАЦ * вАЦX (I k).2 ѕЙвАЦ) ќЉ := by
    sorry
  have integrable_prod_inner_X I (hI : I вИИ A √ЧЋҐ A ^^ m) :
    Integrable (fun ѕЙ вЖ¶ вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ)) ќЉ := sorry
  -- Call a family of indices `iвВБ, ..., iвВЩ, jвВБ, ..., jвВЩ` *even* if each `i вИИ A` appears an even
  -- number of times among the `2n` indices.
  let EvenIndex (I : Fin m вЖТ ќє √Ч ќє) : Prop :=
    вИА i вИИ A, Even (#{k | (I k).1 = i} + #{k | (I k).2 = i})
  -- Now, let the calculation begin...
  calc
    вИЂ ѕЙ, вАЦвИС i вИИ A, X i ѕЙвАЦ ^ (2 * m) вИВќЉ
    -- Expand out the power of the sum into a sum over families of indices
    -- `iвВБ, ..., iвВЩ, jвВБ, ..., jвВЩ` of `вИП k, вЯ®X iвВЦ, X jвВЦвЯ©`. Push the integral inside the sum.
    _ = вИС I вИИ A √ЧЋҐ A ^^ m, вИЂ ѕЙ, вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ := by
      simp_rw [pow_mul, вЖР real_inner_self_eq_norm_sq, sum_inner, inner_sum, вЖР sum_product',
        Finset.sum_pow', integral_finset_sum _ integrable_prod_inner_X]
    -- Show that the terms coming from odd families of indices `iвВБ, ..., iвВЩ, jвВБ, ..., jвВЩ` integrate
    -- to zero.
    _ = вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, вИЂ ѕЙ, вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ := by
      rw [Finset.sum_filter_of_ne]
      -- Assume that `I = (iвВБ, ..., iвВЩ, jвВБ, ..., jвВЩ)` is an odd family.
      -- Say `i` appears an odd number of times in it.
      rintro I hI hI' i hi
      contrapose! hI'
      replace hI' : Odd (#{k | (I k).1 = i} + #{k | (I k).2 = i}) := by simpa using hI'
      -- Let `Y` be the family of random variables `X` where `X i` has been replaced by `-X i`.
      let Y : ќє вЖТ ќ© вЖТ E := update X i (-X i)
      -- By the assumption that `X i` is symmetric, we get that `X j` and `Y j` are identically
      -- distributed for all `j`.
      have identDistrib_X_Y j : IdentDistrib (X j) (Y j) ќЉ ќЉ := by
        obtain rfl | hji := eq_or_ne j i
        ¬Ј simpa [Y] using identDistrib_neg_X _
        ¬Ј simpa [Y, hji] using .refl (identDistrib_neg_X _).aemeasurable_fst
      -- To show that `рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ© = 0`, we will show
      -- `рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ© = рЭФЉ вИП k, вЯ®Y iвВЦ, Y jвВЦвЯ© = -рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ©`.
      rw [вЖР neg_eq_self, вЖР integral_neg, eq_comm]
      calc
        -- `рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ© = рЭФЉ вИП k, вЯ®Y iвВЦ, Y jвВЦвЯ©` because `рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ©` and
        -- `вИП k, вЯ®Y iвВЦ, Y jвВЦвЯ©` are identically distributed.
        вИЂ ѕЙ, вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ
        _ = вИЂ ѕЙ, вИП k, inner вДЭ (Y (I k).1 ѕЙ) (Y (I k).2 ѕЙ) вИВќЉ := by
          refine IdentDistrib.integral_eq ?_
          sorry -- TODO: Upstream result from PFR
        -- `рЭФЉ вИП k, вЯ®Y iвВЦ, Y jвВЦвЯ© = -рЭФЉ вИП k, вЯ®X iвВЦ, X jвВЦвЯ©` by the assumption that `i` appears an odd
        -- number of times in `I`.
        _ = вИЂ ѕЙ, -вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ := by
          congr with ѕЙ
          calc
            вИП k, inner вДЭ (Y (I k).1 ѕЙ) (Y (I k).2 ѕЙ)
            _ = вИП k, (if (I k).1 = i then -1 else 1) * (if (I k).2 = i then -1 else 1) *
                inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) := by
              congr! with k; split_ifs with hkвВБ hkвВВ hkвВВ <;> simp [hkвВБ, hkвВВ, Y]
            _ = -вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) := by
              rw [prod_mul_distrib, prod_mul_distrib]
              simp [prod_ite, вЖР pow_add, hI']
    -- Upper bound the sum by its absolute value and push the absolute value inside.
    _ вЙ§ |вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, вИЂ ѕЙ, вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ| :=
      le_abs_self _
    _ вЙ§ вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, |вИЂ ѕЙ, вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ) вИВќЉ| :=
      abs_sum_le_sum_abs ..
    _ вЙ§ вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, вИЂ ѕЙ, |вИП k, inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ)| вИВќЉ := by
      gcongr with I; exact abs_integral_le_integral_abs
    _ = вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, вИЂ ѕЙ, вИП k, |inner вДЭ (X (I k).1 ѕЙ) (X (I k).2 ѕЙ)| вИВќЉ := by
      simp_rw [abs_prod]
    -- Finish pushing the absolute value inside using Cauchy-Schwarz.
    _ вЙ§ вИС I вИИ A √ЧЋҐ A ^^ m with EvenIndex I, вИЂ ѕЙ, вИП k, вАЦX (I k).1 ѕЙвАЦ * вАЦX (I k).2 ѕЙвАЦ вИВќЉ := by
      gcongr with I hI
      ¬Ј simpa [abs_prod] using (integrable_prod_inner_X I <| filter_subset _ _ hI).abs
      ¬Ј exact integrable_prod_norm_X I <| filter_subset _ _ hI
      rintro ѕЙ
      dsimp
      gcongr with k
