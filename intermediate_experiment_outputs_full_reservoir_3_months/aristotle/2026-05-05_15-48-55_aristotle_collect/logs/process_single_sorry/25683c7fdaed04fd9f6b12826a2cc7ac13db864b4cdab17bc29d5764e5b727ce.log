    _ = marcinkiewiczZygmundSymmConst (2 * m) * вИЂ ѕЙ, (вИС i вИИ A, вАЦX i ѕЙвАЦ ^ 2) ^ m вИВќЉ := by
      simp_rw [sum_pow_eq_sum_piAntidiag, вЖР pow_mul, вЖР integral_const_mul, mul_sum, вЖР mul_assoc]
      rw [integral_finset_sum]
