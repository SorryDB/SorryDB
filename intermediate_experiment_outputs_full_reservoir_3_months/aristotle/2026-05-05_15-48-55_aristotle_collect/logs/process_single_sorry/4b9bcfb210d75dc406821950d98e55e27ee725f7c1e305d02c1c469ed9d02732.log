    -- The iso `G ≅ Diag (Spec R) A` composed with `diagSpecIso` yields
    -- `G ≅ Spec(R[Multiplicative A])` as a group-scheme iso over `Spec R`.
    -- By `hopfSpec.fullyFaithful` this lifts to a `BialgEquiv Γ(G, ⊤) ≃ₐc[R] R[Multiplicative A]`.
    -- Then `IsDiagonalisable.ofBialgEquiv` and `span_isGroupLikeElem_eq_top_of_isDiagonalisable`
    -- finish.
    intro ⟨A, _, e, he, hm⟩
    have hDiag : (hopfSpec R).essImage
        (⟨(Diag (Spec R) A).asOver (Spec R)⟩ : Grp (Over (Spec R))) :=
      ⟨_, ⟨((diagFunctorIso R).app (.op (.of A))).symm⟩⟩
    have hG : (hopfSpec R).essImage (⟨G.asOver (Spec R)⟩ : Grp (Over (Spec R))) :=
      essImage_hopfSpec.mpr (by assumption)
    have eGrp : (⟨G.asOver (Spec R)⟩ : Grp (Over (Spec R))) ≅
        ⟨(Diag (Spec R) A).asOver (Spec R)⟩ :=
      { hom := Grp.homMk (e.hom.asOver (Spec R))
        inv := Grp.homMk (e.inv.asOver (Spec R))
        hom_inv_id := by ext; simp
        inv_hom_id := by ext; simp }
    -- Lift the group-scheme iso to a `CommHopfAlgCat` iso via `hopfSpec.fullyFaithful`
    let eHopf := hopfSpec.fullyFaithful.preimageIso
      (hG.getIso ≪≫ eGrp ≪≫ hDiag.getIso.symm)
    sorry
  · -- Reverse: `span = ⊤ → IsDiag`.
    -- Establish `NoZeroSMulDivisors R Γ(G, ⊤)` (needed for the bialgebra-level result).
    -- Then `IsDiagonalisable.of_span_isGroupLikeElem_eq_top` gives
    -- `Bialgebra.IsDiagonalisable R Γ(G, ⊤)`, whence `Γ(G, ⊤) ≃ₐc[R] R[G₀]` for some
    -- group `G₀`.  Taking `Spec` and composing with `G.isoSpec` and `diagSpecIso` gives
    -- `G ≅ Diag (Spec R) (Additive G₀)` as a group scheme over `Spec R`.
    sorry

