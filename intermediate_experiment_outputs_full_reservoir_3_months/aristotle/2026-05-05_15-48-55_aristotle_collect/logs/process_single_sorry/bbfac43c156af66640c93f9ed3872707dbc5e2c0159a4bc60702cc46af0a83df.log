private lemma integrable_uniformIntegrable_condExp_real' {g : Ω → ℝ}
    (hint : Integrable g μ) {ℱ : ι → MeasurableSpace Ω} (hℱ : ∀ i, ℱ i ≤ mΩ) :
    UniformIntegrable (fun i => μ[g|ℱ i]) 1 μ := by
  have hmeas : ∀ i, AEStronglyMeasurable (μ[g|ℱ i]) μ :=
    fun i => (stronglyMeasurable_condExp.mono (hℱ i)).aestronglyMeasurable
  refine ⟨hmeas, ?_, ⟨(eLpNorm g 1 μ).toNNReal, fun i => ?_⟩⟩
  · -- UnifIntegrable: use unifIntegrable_of
    have hg : MemLp g 1 μ := memLp_one_iff_integrable.2 hint
    apply unifIntegrable_of le_rfl ENNReal.one_ne_top hmeas
    intro ε hε
    by_cases hne : eLpNorm g 1 μ = 0
    · refine ⟨0, fun i => ?_⟩
      calc eLpNorm ({x | (0 : ℝ≥0) ≤ ‖μ[g|ℱ i] x‖₊}.indicator (μ[g|ℱ i])) 1 μ
          ≤ eLpNorm (μ[g|ℱ i]) 1 μ := eLpNorm_indicator_le _
        _ ≤ eLpNorm g 1 μ := eLpNorm_one_condExp_le_eLpNorm g
        _ = 0 := hne
        _ ≤ ENNReal.ofReal ε := by positivity
    · obtain ⟨δ, hδ, h⟩ := hg.eLpNorm_indicator_le le_rfl ENNReal.one_ne_top hε
      set C : ℝ≥0 := ⟨δ, hδ.le⟩⁻¹ * (eLpNorm g 1 μ).toNNReal
      have hCpos : 0 < C := mul_pos (inv_pos.2 hδ)
        (ENNReal.toNNReal_pos hne hg.eLpNorm_lt_top.ne)
      refine ⟨C, fun i => ?_⟩
      have hmeasC : MeasurableSet {ω | C ≤ ‖μ[g|ℱ i] ω‖₊} :=
        measurableSet_le measurable_const
          (stronglyMeasurable_condExp.mono (hℱ i) |>.measurable.nnnorm)
      have hmu : μ {ω | C ≤ ‖μ[g|ℱ i] ω‖₊} ≤ ENNReal.ofReal δ := by
        have hmarkov : μ {ω : Ω | ‖(MeasureTheory.condExp (ℱ i) μ g) ω‖₊ ≥ C} ≤ (ENNReal.ofReal δ) := by
          have hmarkov_aux : ∀ t > 0, μ {ω : Ω | ‖(MeasureTheory.condExp (ℱ i) μ g) ω‖₊ ≥ t} ≤ (eLpNorm g 1 μ).toNNReal / t := by
            intro t ht_pos
            have hmarkov_aux : μ {ω : Ω | ‖(MeasureTheory.condExp (ℱ i) μ g) ω‖₊ ≥ t} * ENNReal.ofReal t ≤ eLpNorm g 1 μ := by
              have hmarkov_aux : μ {ω : Ω | ‖(MeasureTheory.condExp (ℱ i) μ g) ω‖₊ ≥ t} * ENNReal.ofReal t ≤ eLpNorm (MeasureTheory.condExp (ℱ i) μ g) 1 μ := by
                have := @mul_meas_ge_le_pow_eLpNorm;
                specialize this μ ( show ( 1 : ℝ≥0∞ ) ≠ 0 by norm_num ) ( show ( 1 : ℝ≥0∞ ) ≠ ∞ by norm_num ) ( hmeas i ) ( ENNReal.ofReal t ) ; simp_all +decide [ mul_comm ] ;
              refine' le_trans hmarkov_aux _;
              exact?;
            rw [ ENNReal.le_div_iff_mul_le ] <;> norm_cast;
            · convert hmarkov_aux using 1;
              · simp +decide [ ENNReal.ofReal ];
              · exact ENNReal.coe_toNNReal ( by aesop );
            · exact Or.inl ht_pos.ne';
            · exact Or.inl ENNReal.coe_ne_top
          refine' le_trans ( hmarkov_aux C hCpos ) _ ; norm_num [ div_eq_mul_inv, ENNReal.ofReal_mul hδ.le, hCpos.ne' ];
          rw [ ← ENNReal.toReal_le_toReal ] <;> norm_num [ hCpos.ne', hδ.le ];
          · simp +zetaDelta at *;
            rw [ ← mul_assoc, mul_inv_cancel₀ ( ne_of_gt ( mod_cast hCpos.2 ) ), one_mul ];
          · exact ENNReal.mul_ne_top ( ENNReal.coe_ne_top ) ( ENNReal.inv_ne_top.mpr ( by aesop ) );
        exact hmarkov
      refine le_trans ?_ (h _ hmeasC hmu)
      have hmeasF : MeasurableSet[ℱ i] {ω | C ≤ ‖μ[g|ℱ i] ω‖₊} := by
        exact stronglyMeasurable_const.measurableSet_le stronglyMeasurable_condExp.nnnorm
      calc eLpNorm ({ω | C ≤ ‖μ[g|ℱ i] ω‖₊}.indicator (μ[g|ℱ i])) 1 μ
          = eLpNorm (μ[{ω | C ≤ ‖μ[g|ℱ i] ω‖₊}.indicator g | ℱ i]) 1 μ := by
            exact eLpNorm_congr_ae (condExp_indicator hint hmeasF).symm
        _ ≤ eLpNorm ({ω | C ≤ ‖μ[g|ℱ i] ω‖₊}.indicator g) 1 μ :=
            eLpNorm_one_condExp_le_eLpNorm _
  · -- Bounded eLpNorm
    have hlt : eLpNorm g 1 μ < ⊤ := (memLp_one_iff_integrable.2 hint).eLpNorm_lt_top
    calc eLpNorm (μ[g|ℱ i]) 1 μ ≤ eLpNorm g 1 μ := eLpNorm_one_condExp_le_eLpNorm g
      _ = ↑(eLpNorm g 1 μ).toNNReal := (ENNReal.coe_toNNReal hlt.ne).symm

