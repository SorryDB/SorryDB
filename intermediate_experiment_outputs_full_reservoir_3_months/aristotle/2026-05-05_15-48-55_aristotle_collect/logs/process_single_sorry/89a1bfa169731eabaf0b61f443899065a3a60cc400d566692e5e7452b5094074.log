example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  have ⟨lhs, rhs, ok⟩ := sl
  simp [Function.comp]
  sorry


end SymList

/- examples of use -/

open List (map reverse tails) in

def inits₁ {a : Type} : List a → List (List a) :=
 map reverse ∘ reverse ∘ tails ∘ reverse

def inits₂ {a : Type} : List a → List (List a) :=
 List.map SymList.fromSL ∘ List.scanl (flip SymList.snocSL) SymList.nil


/- trying to prove inits₁ = inits₂ -/

theorem tails_append_singleton (xs : List α) (x : α) :
    (xs ++ [x]).tails = xs.tails.map (fun ys => ys ++ [x]) ++ [[]] := by
  induction xs with
  | nil      => simp
  | cons y ys ih =>
      simp [List.tails, ih]

theorem map_reverse_tails_snoc (x : α) (xs : List α) :
    List.map reverse (snoc x xs).tails =
      List.map (fun ys : List α => x :: reverse ys) xs.tails ++ [[]] := by
  simp [snoc, tails_append_singleton, List.map_append, List.map_map, Function.comp]

theorem map_reverse (f : α → β) (xs : List α) :
    List.map f xs.reverse = (List.map f xs).reverse := by
  induction xs
  all_goals
  simp

theorem scanl_cons {α β}
        (f : β → α → β) (b : β) (a : α) (as : List α) :
    List.scanl f b (a :: as) = b :: List.scanl f (f b a) as :=
  List.scanl_cons

theorem fromSL_snoc {α} (z : α) (sl : SymList α) :
    SymList.fromSL (SymList.snocSL z sl) = SymList.fromSL sl ++ [z] := by
  cases sl with
  | mk lhs rhs ok =>
      cases lhs with
      | nil =>
          cases rhs with
          | nil =>
              unfold SymList.fromSL
              unfold SymList.snocSL
              simp
          | cons y ys =>
              cases ys with
              | nil =>
                  unfold SymList.fromSL
                  unfold SymList.snocSL
                  simp
              | cons z zs =>
                  have hFalse : False := by
                    have h := (ok.left) (by simp)
                    cases h with
                    | inl h0 =>
                        simp at h0
                    | inr hlen1 =>
                        have : (List.length (y :: z :: zs)) = 1 := by
                          simp at hlen1
                        simp at this
                  cases hFalse
      | cons a as =>
          simp [SymList.snocSL, SymList.fromSL, List.reverse_cons, List.append_assoc]

theorem scanl_snocSL_cons {a : Type} (x : a) (s0 s1 : SymList a) (ys : List a)
    (h : SymList.fromSL s1 = x :: SymList.fromSL s0) :
    List.map SymList.fromSL (List.scanl (flip SymList.snocSL) s1 ys) =
    List.map (x :: ·) (List.map SymList.fromSL (List.scanl (flip SymList.snocSL) s0 ys)) := by
  induction ys generalizing s0 s1 with
  | nil => simp [List.scanl_nil, h]
  | cons y ys' ih =>
    simp only [List.scanl_cons, List.map, flip]
    rw [h]
    congr 1
    exact ih _ _ (by rw [fromSL_snoc, fromSL_snoc, h, List.cons_append])

theorem inits_eq {a : Type} : ∀ xs : List a, inits₁ xs = inits₂ xs
  | [] => by
    unfold inits₁ inits₂ SymList.fromSL SymList.nil
    simp
  | x :: xs => by
    have ih := inits_eq xs
    simp [inits₁, inits₂,
          List.reverse_cons,
          Function.comp, flip] at *
    -- Step 1: Simplify fromSL nil
    have h_nil : SymList.fromSL (a := a) SymList.nil = [] := by simp [SymList.fromSL, SymList.nil]
    rw [h_nil]
    -- Step 2: Use tails_append_singleton
    rw [tails_append_singleton]
    simp [List.map_append, List.map_map]
    -- Goal: map (reverse ∘ fun ys => ys ++ [x]) xs.reverse.tails =
    --       (map fromSL (scanl (flip snocSL) (snocSL x nil) xs)).reverse
    -- Step 3: (reverse ∘ fun ys => ys ++ [x]) = (fun ys => x :: reverse ys)
    have h_comp : (List.reverse ∘ fun ys : List a => ys ++ [x]) = (fun ys => x :: List.reverse ys) := by
      funext ys; simp [Function.comp, List.reverse_append]
    rw [h_comp]
    -- Goal: map (fun ys => x :: reverse ys) xs.reverse.tails = ...
    -- Step 4: rewrite as map (x :: ·) (map reverse xs.reverse.tails)
    rw [show List.map (fun ys : List a => x :: ys.reverse) xs.reverse.tails
        = List.map (x :: ·) (List.map List.reverse xs.reverse.tails) from by
      rw [List.map_map]; rfl]
    -- Step 5: Use ih
    have h_rev : List.map List.reverse xs.reverse.tails =
      (List.map SymList.fromSL (List.scanl (flip SymList.snocSL) SymList.nil xs)).reverse := by
      rw [← ih, List.reverse_reverse]
    rw [h_rev]
    -- Step 6: Use List.map_reverse
    rw [List.map_reverse]
    congr 1
    -- Step 7: Use scanl_snocSL_cons
    rw [← scanl_snocSL_cons x SymList.nil (SymList.snocSL x SymList.nil) xs]
    simp [SymList.fromSL, SymList.nil, SymList.snocSL]

-- # Section 3.2 Random-access lists

def fetch {a : Type} : Nat → List a → Option a
 | _, []      => none
 | k, x :: xs => if k = 0 then x else fetch (k - 1) xs

