import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

The answer is **yes**. We construct n = 3^2001 · p₂ · p₃ · ... · p₂₀₀₀ where
each pⱼ is a prime > 3 dividing Fⱼ = 2^(2·3^(j-1)) - 2^(3^(j-1)) + 1.
These primes are pairwise distinct, each > 3, and each divides 2^n + 1.
-/

namespace Imo2000P5

determine solution : Bool := true

/-- Fⱼ = 2^(2·3^(j-1)) - 2^(3^(j-1)) + 1. This satisfies
    2^(3^j) + 1 = (2^(3^(j-1)) + 1) · Fⱼ for j ≥ 1. -/
noncomputable def F (j : ℕ) : ℕ := 2 ^ (2 * 3 ^ j) - 2 ^ (3 ^ j) + 1

/-
The factorization: 2^(3^(j+1)) + 1 = (2^(3^j) + 1) · F(j)
-/
lemma factorization (j : ℕ) :
    2 ^ (3 ^ (j + 1)) + 1 = (2 ^ (3 ^ j) + 1) * F j := by
  zify [ F ];
  rw [ Nat.cast_sub ] <;> push_cast <;> ring ; gcongr <;> norm_num

/-
F(j) is divisible by 3 for j ≥ 0
-/
lemma three_dvd_F (j : ℕ) : 3 ∣ F j := by
  unfold F;
  rw [ ← ZMod.natCast_eq_zero_iff ];
  rw [ Nat.cast_add, Nat.cast_sub ] <;> norm_num [ pow_mul ];
  · grind;
  · gcongr ; norm_num

/-
F(j) / 3 > 1 for j ≥ 1
-/
lemma F_div_three_gt_one (j : ℕ) (hj : 1 ≤ j) : F j / 3 > 1 := by
  refine' Nat.le_div_iff_mul_le three_pos |>.2 _;
  induction hj <;> simp +arith +decide [ Nat.pow_succ', Nat.pow_mul ] at *;
  unfold F at *;
  zify at *;
  rw [ Nat.cast_sub ];
  · norm_num [ pow_succ, pow_mul' ] at *;
    nlinarith [ pow_le_pow_right₀ ( show 1 ≤ 8 by norm_num ) ( show 3 ^ ‹_› ≥ 1 by exact Nat.one_le_pow _ _ ( by norm_num ) ) ];
  · gcongr <;> norm_num

/-
F(j) has a prime factor > 3 for j ≥ 1
-/
lemma F_has_prime_gt_three (j : ℕ) (hj : 1 ≤ j) :
    ∃ p, Nat.Prime p ∧ p ∣ F j ∧ p > 3 := by
  -- Since $F(j) / 3 > 1$ and $F(j) \equiv 3 \pmod{9}$, it follows that $F(j) / 3$ is not divisible by 3.
  have h_not_div_three : ¬(3 ∣ F j / 3) := by
    rw [ Nat.dvd_div_iff_mul_dvd ];
    · unfold F;
      rw [ ← Nat.mod_add_div ( 2 ^ ( 2 * 3 ^ j ) ) 9, ← Nat.mod_add_div ( 2 ^ 3 ^ j ) 9 ];
      rcases j with ( _ | _ | j ) <;> norm_num [ Nat.pow_succ', Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] at *;
      rw [ ← Nat.mod_add_div ( 3 ^ j ) 2 ] ; norm_num [ Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod ] ; omega;
    · exact?;
  -- Since $F(j) / 3 > 1$ and $F(j) / 3$ is not divisible by 3, it must have a prime factor greater than 3.
  have h_prime_factor : ∃ p, Nat.Prime p ∧ p ∣ F j / 3 ∧ p ≠ 3 := by
    obtain ⟨p, hp_prime, hp_div⟩ : ∃ p, Nat.Prime p ∧ p ∣ F j / 3 := by
      exact Nat.exists_prime_and_dvd ( Nat.ne_of_gt ( F_div_three_gt_one j hj ) );
    exact ⟨ p, hp_prime, hp_div, by rintro rfl; exact h_not_div_three hp_div ⟩;
  obtain ⟨ p, hp₁, hp₂, hp₃ ⟩ := h_prime_factor;
  refine' ⟨ p, hp₁, hp₂.trans ( Nat.div_dvd_of_dvd ( three_dvd_F j ) ), _ ⟩;
  contrapose! hp₃; interval_cases p <;> simp_all +decide ;
  rw [ Nat.dvd_div_iff_mul_dvd ] at hp₂;
  · obtain ⟨ k, hk ⟩ := hp₂; replace hk := congr_arg Even hk; simp_all +decide [ parity_simps ] ;
    unfold F at hk; simp_all +decide [ Nat.one_le_iff_ne_zero, parity_simps ] ;
    exact absurd hk ( by rw [ Nat.odd_iff ] ; exact ne_of_eq_of_ne ( Nat.mod_eq_zero_of_dvd ( Nat.dvd_sub ( dvd_pow_self _ ( by positivity ) ) ( dvd_pow_self _ ( by positivity ) ) ) ) ( by norm_num ) );
  · exact?

/-
If p > 3 is prime and p | F(j), then p | 2^(3^(j+1)) + 1
-/
lemma prime_dvd_pow_add_one (j : ℕ) (p : ℕ) (hp : Nat.Prime p) (hp3 : p > 3)
    (hpF : p ∣ F j) : p ∣ 2 ^ (3 ^ (j + 1)) + 1 := by
  exact dvd_trans hpF ( mod_cast factorization j ▸ dvd_mul_left _ _ )

/-
If p > 3 is prime and p | F(j), then p ∤ 2^(3^j) + 1
-/
lemma prime_not_dvd_smaller (j : ℕ) (p : ℕ) (hp : Nat.Prime p) (hp3 : p > 3)
    (hpF : p ∣ F j) : ¬(p ∣ 2 ^ (3 ^ j) + 1) := by
  contrapose! hpF; haveI := Fact.mk hp; simp_all +decide [ ← ZMod.natCast_eq_zero_iff, pow_succ ] ;
  rw [ add_eq_zero_iff_eq_neg ] at *;
  simp_all +decide [ F ];
  rw [ Nat.cast_sub ( by gcongr <;> norm_num ) ] ; norm_num [ pow_mul', hpF ];
  erw [ ZMod.natCast_eq_zero_iff ] ; exact Nat.not_dvd_of_pos_of_lt ( by norm_num ) ( by linarith )

/-
If p > 3 is prime and p | 2^(3^k) + 1, and 3^k | n with n/3^k odd,
    then p | 2^n + 1.
-/
lemma prime_dvd_pow_general (k n : ℕ) (p : ℕ) (hp : Nat.Prime p) (hp3 : p > 3)
    (hpk : p ∣ 2 ^ (3 ^ k) + 1) (hkn : 3 ^ k ∣ n) (hodd : ¬Even (n / 3 ^ k)) :
    p ∣ 2 ^ n + 1 := by
  obtain ⟨ m, rfl ⟩ := hkn;
  haveI := Fact.mk hp; simp_all +decide [ ← ZMod.natCast_eq_zero_iff, pow_mul ] ;
  rw [ add_eq_zero_iff_eq_neg ] at * ; aesop

/-
Key disjointness: if p > 3 divides both F(i) and F(j) with i < j, contradiction
-/
lemma F_coprime (i j : ℕ) (hij : i < j) (p : ℕ) (hp : Nat.Prime p) (hp3 : p > 3)
    (hpi : p ∣ F i) (hpj : p ∣ F j) : False := by
  -- From p | F(i): p | 2^(3^(i+1))+1 (by prime_dvd_pow_add_one). So 2^(3^(i+1)) ≡ -1 (mod p).
  have hpi_mod : 2 ^ (3 ^ (i + 1)) ≡ -1 [ZMOD p] := by
    rw [ Int.modEq_comm, Int.modEq_iff_dvd ];
    simpa [ ← Int.natCast_dvd_natCast, pow_add ] using Int.natCast_dvd_natCast.mpr ( prime_dvd_pow_add_one i p hp hp3 hpi );
  -- By induction: 2^(3^m) ≡ -1 (mod p) for all m ≥ i+1.
  have h_induction : ∀ m ≥ i + 1, 2 ^ (3 ^ m) ≡ -1 [ZMOD p] := by
    intro m hm; induction hm <;> simp_all +decide [ ← ZMod.intCast_eq_intCast_iff, pow_succ, pow_mul ] ;
  -- So p | 2^(3^j)+1. But from p | F(j): p ∤ 2^(3^j)+1 (by prime_not_dvd_smaller). Contradiction!
  have h_contradiction : p ∣ 2 ^ (3 ^ j) + 1 ∧ ¬(p ∣ 2 ^ (3 ^ j) + 1) := by
    exact ⟨ by simpa [ ← Int.natCast_dvd_natCast ] using h_induction j ( by linarith ) |> Int.ModEq.symm |> Int.ModEq.dvd, prime_not_dvd_smaller j p hp hp3 hpj ⟩;
  exact h_contradiction.2 h_contradiction.1

/-
LTE for p=3: v₃(2^n + 1) = 1 + v₃(n) for odd n > 0
-/
lemma v3_pow_add_one (n : ℕ) (hn : 0 < n) (hodd : ¬Even n) :
    (Nat.factorization (2 ^ n + 1)) 3 = 1 + (Nat.factorization n) 3 := by
  -- We can use the fact that $v_3(2^n + 1) = 1 + v_3(n)$ for odd $n$.
  have h_lte : ∀ {n : ℕ}, Odd n → padicValNat 3 (2 ^ n + 1) = 1 + padicValNat 3 n := by
    intro n hn_odd
    have h_lte : padicValNat 3 (2 ^ n + 1) = padicValNat 3 (2 + 1) + padicValNat 3 n := by
      convert padicValNat.pow_add_pow _ _ _ _ using 1;
      grind;
      · exact ⟨ by norm_num ⟩;
      · decide;
      · norm_num;
      · norm_num;
      · exact hn_odd;
    exact h_lte.trans ( congr_arg₂ _ ( by native_decide ) rfl );
  simp_all +decide [ Nat.factorization ]

/-- n.primeFactors.card for n = 3^a · p₁ · ... · pₖ -/
lemma primeFactors_mul_prime (n p : ℕ) (hn : 0 < n) (hp : Nat.Prime p) (hpn : ¬(p ∣ n)) :
    (n * p).primeFactors.card = n.primeFactors.card + 1 := by
  rw [ Nat.primeFactors_mul, Finset.card_union ] <;> aesop

/-
The main existence result
-/
theorem exists_with_prime_factors :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 := by
  by_contra! h_contra;
  obtain ⟨q, hq⟩ : ∃ q : ℕ → ℕ, (∀ j : ℕ, 1 ≤ j → Nat.Prime (q j) ∧ q j ∣ F j ∧ q j > 3) ∧ (∀ i j : ℕ, 1 ≤ i → 1 ≤ j → i ≠ j → q i ≠ q j) := by
    have hq_exists : ∀ j : ℕ, 1 ≤ j → ∃ q : ℕ, Nat.Prime q ∧ q ∣ F j ∧ q > 3 := by
      exact?;
    choose! q hq using hq_exists;
    use q;
    refine ⟨ hq, fun i j hi hj hij h => ?_ ⟩;
    cases lt_or_gt_of_ne hij <;> [ exact F_coprime _ _ ‹_› _ ( hq _ hi |>.1 ) ( hq _ hi |>.2.2 ) ( hq _ hi |>.2.1 ) ( h.symm ▸ hq _ hj |>.2.1 ) ; exact F_coprime _ _ ‹_› _ ( hq _ hj |>.1 ) ( hq _ hj |>.2.2 ) ( hq _ hj |>.2.1 ) ( h ▸ hq _ hi |>.2.1 ) ];
  -- Define n as 3^2001 multiplied by the product of the primes q_j for j from 1 to 1999.
  set n := 3 ^ 2001 * Finset.prod (Finset.Icc 1 1999) (fun j => q j);
  -- Show that n has exactly 2000 distinct prime factors.
  have h_prime_factors : n.primeFactors.card = 2000 := by
    rw [ Nat.primeFactors_mul ] <;> norm_num;
    · -- The prime factors of $3^{2001}$ are $\{3\}$, and the prime factors of $\prod_{j=1}^{1999} q_j$ are $\{q_1, q_2, \ldots, q_{1999}\}$.
      have h_prime_factors_prod : (∏ j ∈ Finset.Icc 1 1999, q j).primeFactors = Finset.image q (Finset.Icc 1 1999) := by
        have h_prime_factors_prod : ∀ {S : Finset ℕ}, (∀ j ∈ S, Nat.Prime (q j)) → (∀ i j : ℕ, i ∈ S → j ∈ S → i ≠ j → q i ≠ q j) → (∏ j ∈ S, q j).primeFactors = Finset.image q S := by
          intros S hS_prime hS_distinct; induction S using Finset.induction <;> simp_all +decide [ Nat.primeFactors_mul ] ;
          rw [ Nat.primeFactors_mul, ‹ ( ∏ j ∈ _, q j |> Nat.primeFactors ) = _ › ] <;> simp +decide [ *, Nat.Prime.ne_zero, Finset.prod_eq_zero_iff ];
          exact fun x hx => Nat.Prime.ne_zero ( hS_prime.2 x hx );
        exact h_prime_factors_prod ( fun j hj => hq.1 j ( Finset.mem_Icc.mp hj |>.1 ) |>.1 ) ( fun i j hi hj hij => hq.2 i j ( Finset.mem_Icc.mp hi |>.1 ) ( Finset.mem_Icc.mp hj |>.1 ) hij );
      rw [ h_prime_factors_prod, Finset.card_union_of_disjoint ];
      · rw [ Finset.card_image_of_injOn fun i hi j hj hij => by contrapose hij; exact hq.2 i j ( Finset.mem_Icc.mp hi |>.1 ) ( Finset.mem_Icc.mp hj |>.1 ) hij ] ; native_decide;
      · norm_num [ Nat.primeFactors_pow ];
        exact fun x hx₁ hx₂ => ne_of_gt ( hq.1 x hx₁ |>.2.2 );
    · exact Finset.prod_ne_zero_iff.mpr fun x hx => Nat.Prime.ne_zero ( hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.1 );
  -- Show that 3^2001 divides 2^n + 1.
  have h3_div : 3 ^ 2001 ∣ 2 ^ n + 1 := by
    -- By the properties of the 3-adic valuation, we know that $v_3(2^n + 1) = 1 + v_3(n)$.
    have h_val : Nat.factorization (2 ^ n + 1) 3 = 1 + Nat.factorization n 3 := by
      apply v3_pow_add_one;
      · exact mul_pos ( by norm_num ) ( Finset.prod_pos fun x hx => Nat.Prime.pos ( hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.1 ) );
      · rw [ Nat.even_mul, Nat.even_pow' ] <;> norm_num;
        exact Nat.odd_iff.mpr ( by rw [ Finset.prod_nat_mod ] ; exact by rw [ Finset.prod_eq_one fun x hx => Nat.Prime.eq_two_or_odd ( hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.1 ) |> Or.resolve_left <| by linarith [ hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.2.2 ] ] ; norm_num );
    -- Since $n$ is divisible by $3^{2001}$, we have $v_3(n) \geq 2001$.
    have h_v3_n : Nat.factorization n 3 ≥ 2001 := by
      rw [ Nat.factorization_mul ] <;> norm_num;
      exact Finset.prod_ne_zero_iff.mpr fun x hx => Nat.Prime.ne_zero ( hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.1 );
    exact dvd_trans ( pow_dvd_pow _ ( by linarith ) ) ( h_val ▸ Nat.ordProj_dvd _ _ );
  -- Show that each q_j divides 2^n + 1.
  have hq_div : ∀ j : ℕ, 1 ≤ j → j ≤ 1999 → q j ∣ 2 ^ n + 1 := by
    intros j hj1 hj2
    have hq_div_step : q j ∣ 2 ^ (3 ^ (j + 1)) + 1 := by
      exact prime_dvd_pow_add_one j ( q j ) ( hq.1 j hj1 |>.1 ) ( hq.1 j hj1 |>.2.2 ) ( hq.1 j hj1 |>.2.1 );
    -- Since $3^{j+1} \mid n$, we can write $n = 3^{j+1} \cdot k$ for some integer $k$.
    obtain ⟨k, hk⟩ : ∃ k, n = 3 ^ (j + 1) * k := by
      exact dvd_mul_of_dvd_left ( pow_dvd_pow _ ( by linarith ) ) _;
    -- Since $k$ is odd, we have $2^{3^{j+1} \cdot k} + 1 = (2^{3^{j+1}})^k + 1$.
    have h_odd_k : Odd k := by
      replace hk := congr_arg Even hk; simp_all +contextual [ parity_simps ] ;
      simp +zetaDelta at *;
      simp_all +contextual [ Finset.prod_nat_mod, Nat.even_iff, Nat.add_mod, Nat.mul_mod, Nat.pow_mod ];
      exact Nat.odd_iff.mpr ( by rw [ Finset.prod_congr rfl fun x hx => by rw [ Nat.Prime.eq_two_or_odd ( hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.1 ) |> Or.resolve_left <| by linarith [ hq.1 x ( Finset.mem_Icc.mp hx |>.1 ) |>.2.2 ] ] ] at hk; norm_num at hk; omega );
    rw [ hk, pow_mul ];
    exact dvd_trans hq_div_step ( by simpa using h_odd_k.nat_add_dvd_pow_add_pow _ 1 );
  -- Since $3^{2001}$ and each $q_j$ divide $2^n + 1$, and they are pairwise coprime, their product also divides $2^n + 1$.
  have h_prod_div : (∏ j ∈ Finset.Icc 1 1999, q j) ∣ 2 ^ n + 1 := by
    refine' Nat.dvd_trans _ ( Nat.prod_primeFactors_dvd _ );
    have h_prod_div : Finset.image q (Finset.Icc 1 1999) ⊆ (2 ^ n + 1).primeFactors := by
      exact Finset.image_subset_iff.mpr fun j hj => Nat.mem_primeFactors.mpr ⟨ hq.1 j ( Finset.mem_Icc.mp hj |>.1 ) |>.1, hq_div j ( Finset.mem_Icc.mp hj |>.1 ) ( Finset.mem_Icc.mp hj |>.2 ), by positivity ⟩;
    rw [ ← Finset.prod_sdiff h_prod_div ];
    rw [ Finset.prod_image <| by intros i hi j hj hij; exact Classical.not_not.1 fun hi' => hq.2 i j ( Finset.mem_Icc.mp hi |>.1 ) ( Finset.mem_Icc.mp hj |>.1 ) hi' hij ] ; exact dvd_mul_left _ _;
  refine h_contra n ?_ h_prime_factors ?_;
  · exact mul_pos ( pow_pos ( by decide ) _ ) ( Finset.prod_pos fun j hj => Nat.Prime.pos ( hq.1 j ( Finset.mem_Icc.mp hj |>.1 ) |>.1 ) );
  · refine Nat.Coprime.mul_dvd_of_dvd_of_dvd ?_ h3_div h_prod_div;
    exact Nat.Coprime.prod_right fun i hi => Nat.Coprime.pow_left _ <| Nat.prime_three.coprime_iff_not_dvd.mpr <| fun h => by have := hq.1 i ( Finset.mem_Icc.mp hi |>.1 ) ; have := Nat.prime_dvd_prime_iff_eq Nat.prime_three this.1; aesop;

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp only [solution]
  constructor
  · rintro ⟨n, hn_pos, hn_card, hn_dvd⟩; trivial
  · intro _; exact exists_with_prime_factors

end Imo2000P5
