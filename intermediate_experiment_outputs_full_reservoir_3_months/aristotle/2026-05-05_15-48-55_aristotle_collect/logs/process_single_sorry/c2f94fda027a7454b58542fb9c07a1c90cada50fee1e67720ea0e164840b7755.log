module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  haveI : Fintype K := Fintype.ofFinite K
  -- Helper: algebraic elements over finite fields are roots of unity or zero
  have element_rou : ∀ (x : L), IsAlgebraic K x →
      x = 0 ∨ ∃ n : ℕ, 0 < n ∧ (n : K) ≠ 0 ∧ x ^ n = 1 := by
    intro x ⟨p, hp, hp'⟩
    obtain ⟨F, hF⟩ : ∃ F : IntermediateField K L, FiniteDimensional K F ∧ x ∈ F :=
      ⟨IntermediateField.adjoin K {x},
        IntermediateField.adjoin.finiteDimensional (isAlgebraic_iff_isIntegral.mp ⟨p, hp, hp'⟩),
        IntermediateField.mem_adjoin_simple_self K x⟩
    haveI : FiniteDimensional K F := hF.1
    haveI : Finite F := Module.finite_of_finite K
    haveI : Fintype F := Fintype.ofFinite _
    by_cases hx : x = 0
    · exact Or.inl hx
    · right
      refine ⟨Fintype.card F - 1, Nat.sub_pos_of_lt Fintype.one_lt_card, ?_, ?_⟩
      · rw [Module.card_eq_pow_finrank (K := K) (V := F)]
        rw [Nat.cast_sub (Nat.one_le_pow _ _ Fintype.card_pos)]
        simp [zero_pow (Nat.ne_of_gt Module.finrank_pos)]
      · have hxF : (⟨x, hF.2⟩ : F) ≠ 0 := by simpa [Subtype.ext_iff]
        have h1 := FiniteField.pow_card_sub_one_eq_one (⟨x, hF.2⟩ : F) hxF
        have : ((⟨x, hF.2⟩ : F) : L) ^ (Fintype.card F - 1) = (1 : L) := by
          have := congr_arg (Subtype.val) h1; simpa using this
        simpa using this
  -- Helper: roots of unity in extension are in base when base has primitive root
  have rou_in_base : ∀ (n : ℕ) (hn : n ≠ 0) (ζ : L) (hζ : IsPrimitiveRoot ζ n)
      (x : AlgebraicClosure L),
      x ^ n = 1 → x ∈ Set.range (algebraMap L (AlgebraicClosure L)) := by
    intro n hn ζ hζ x hx
    have h_prod : Polynomial.X ^ n - 1 =
        (∏ μ ∈ (Polynomial.nthRootsFinset n (1 : L)),
          (Polynomial.X - Polynomial.C μ)) :=
      Polynomial.X_pow_sub_one_eq_prod (Nat.pos_of_ne_zero hn) hζ
    have h_eval : ∏ μ ∈ (Polynomial.nthRootsFinset n (1 : L)),
        (x - (algebraMap L (AlgebraicClosure L) μ)) = 0 := by
      have h1 := congr_arg (Polynomial.map (algebraMap L (AlgebraicClosure L))) h_prod
      have h2 := congr_arg (Polynomial.eval x) h1
      simp only [Polynomial.map_sub, Polynomial.map_pow,
        Polynomial.map_X, Polynomial.map_one, Polynomial.eval_sub, Polynomial.eval_pow,
        Polynomial.eval_X, Polynomial.eval_one, hx, sub_self,
        Polynomial.map_prod, Polynomial.eval_prod, Polynomial.map_C,
        Polynomial.eval_C] at h2
      exact h2.symm
    rw [Finset.prod_eq_zero_iff] at h_eval
    obtain ⟨μ, hμ_mem, hμ_eq⟩ := h_eval
    exact ⟨μ, (sub_eq_zero.mp hμ_eq).symm⟩
  -- Also need element_rou for AlgebraicClosure L
  have element_rou_ac : ∀ (x : AlgebraicClosure L), IsAlgebraic K x →
      x = 0 ∨ ∃ n : ℕ, 0 < n ∧ (n : K) ≠ 0 ∧ x ^ n = 1 := by
    intro x ⟨p, hp, hp'⟩
    obtain ⟨F, hF⟩ : ∃ F : IntermediateField K (AlgebraicClosure L),
        FiniteDimensional K F ∧ x ∈ F :=
      ⟨IntermediateField.adjoin K {x},
        IntermediateField.adjoin.finiteDimensional (isAlgebraic_iff_isIntegral.mp ⟨p, hp, hp'⟩),
        IntermediateField.mem_adjoin_simple_self K x⟩
    haveI : FiniteDimensional K F := hF.1
    haveI : Finite F := Module.finite_of_finite K
    haveI : Fintype F := Fintype.ofFinite _
    by_cases hx : x = 0
    · exact Or.inl hx
    · right
      refine ⟨Fintype.card F - 1, Nat.sub_pos_of_lt Fintype.one_lt_card, ?_, ?_⟩
      · rw [Module.card_eq_pow_finrank (K := K) (V := F)]
        rw [Nat.cast_sub (Nat.one_le_pow _ _ Fintype.card_pos)]
        simp [zero_pow (Nat.ne_of_gt Module.finrank_pos)]
      · have hxF : (⟨x, hF.2⟩ : F) ≠ 0 := by simpa [Subtype.ext_iff]
        have h1 := FiniteField.pow_card_sub_one_eq_one (⟨x, hF.2⟩ : F) hxF
        have : ((⟨x, hF.2⟩ : F) : AlgebraicClosure L) ^ (Fintype.card F - 1) = 1 := by
          have := congr_arg (Subtype.val) h1; simpa using this
        simpa using this
  constructor
  · intro h
    have h_alg : Algebra.IsAlgebraic K L := by
      constructor; intro x
      refine Algebra.adjoin_induction ?_ ?_ ?_ ?_ (h.adjoin_roots x)
      · rintro x ⟨n, hn, hn', hx⟩
        exact ⟨Polynomial.X ^ n - 1,
          Polynomial.X_pow_sub_C_ne_zero (Nat.pos_of_ne_zero hn') 1, by aesop⟩
      · exact fun r => isAlgebraic_algebraMap r
      · exact fun x y _ _ hx' hy' => hx'.add hy'
      · exact fun x y _ _ hx' hy' => hx'.mul hy'
    have h_alg_closed : IsAlgClosed L := by
      apply IsAlgClosed.of_exists_root
      intro p _ hirr
      have h_deg := Polynomial.degree_pos_of_irreducible hirr
      obtain ⟨x, hx⟩ : ∃ x : AlgebraicClosure L,
          Polynomial.eval x (Polynomial.map (algebraMap L (AlgebraicClosure L)) p) = 0 :=
        IsAlgClosed.exists_root _ (by aesop)
      have hx_alg_L : IsAlgebraic L x :=
        ⟨p, by aesop, by simpa [Polynomial.eval_map] using hx⟩
      have hx_alg : IsAlgebraic K x := hx_alg_L.restrictScalars K
      have hx_in_L : x ∈ Set.range (algebraMap L (AlgebraicClosure L)) := by
        rcases element_rou_ac x hx_alg with rfl | ⟨n, hn_pos, hn_ne_zero, hn_root⟩
        · exact ⟨0, map_zero _⟩
        · obtain ⟨ζ, hζ⟩ := h.exists_isPrimitiveRoot
            (show n ∈ {n : ℕ | ¬(n : K) = 0} from by simpa) hn_pos.ne'
          exact rou_in_base n hn_pos.ne' ζ hζ x hn_root
      obtain ⟨y, rfl⟩ := hx_in_L
      exact ⟨y, by simpa [Polynomial.eval_map] using hx⟩
    exact ⟨h_alg_closed, h_alg⟩
  · intro h
    constructor
    · intro n hn hn'
      haveI : NeZero (n : L) := by
        constructor; intro h_eq; apply hn
        rwa [← map_natCast (algebraMap K L), map_eq_zero] at h_eq
      have hcyc := h.isAlgClosed.exists_root (Polynomial.cyclotomic n L)
        (by rw [Polynomial.degree_cyclotomic]
            exact_mod_cast (Nat.totient_pos.mpr (Nat.pos_of_ne_zero hn')).ne')
      obtain ⟨x, hx⟩ := hcyc
      exact ⟨x, Polynomial.isRoot_cyclotomic_iff.mp hx⟩
    · intro x
      have hx_alg : IsAlgebraic K x := h.isAlgebraic.isAlgebraic x
      rcases element_rou x hx_alg with rfl | ⟨n, hn_pos, hn_ne, hxn⟩
      · exact Subalgebra.zero_mem _
      · exact Algebra.subset_adjoin ⟨n, hn_ne, hn_pos.ne', hxn⟩

