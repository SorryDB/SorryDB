import Mathlib.Analysis.Complex.Basic
import Mathlib.Tactic.Positivity.Basic
import Mathlib.Tactic.FieldSimp
import Mathlib.Tactic.Ring
import Mathlib.Topology.UniformSpace.HeineCantor
import Mathlib.Topology.Order.Basic
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-!
# Uniformly almost periodic functions
-/

variable {E F : Set ℝ} {C D ε δ t l : ℝ} {f g : ℝ → ℂ}

variable (E l) in
/-- A set `E` of reals is **relatively dense with respect to `l`** if every (closed-open) interval
of length `l` contains an element of `E`. -/
def IsRelDenseWith : Prop := ∀ x, ∃ y ∈ Set.Ico 0 l, x + y ∈ E

lemma IsRelDenseWith.subset (hEF : E ⊆ F) : IsRelDenseWith E l → IsRelDenseWith F l :=
  forall_imp fun _x ↦ .imp fun _l ↦ .imp_right <| @hEF _

lemma IsRelDenseWith.pos (hE : IsRelDenseWith E l) : 0 < l := by
  obtain ⟨y, ⟨hy₀, hyl⟩, _⟩ := hE 0; exact hy₀.trans_lt hyl

variable (E) in
/-- A set `E` of reals is **relatively dense** if it is relatively dense with respect to some `l`.
-/
def IsRelDense : Prop := ∃ l, IsRelDenseWith E l

lemma IsRelDense.subset (hEF : E ⊆ F) : IsRelDense E → IsRelDense F := .imp fun _ ↦ .subset hEF

variable (ε t f) in
/-- A real number `t` is an **`ε`, L∞-almost period** of a function `f : ℝ \r ℝ` if
`‖f - τ t f‖_∞ ≤ ε`. -/
def IsLinftyAP : Prop := ∀ x, ‖f (x + t) - f x‖ ≤ ε

lemma IsLinftyAP.mul_fun (hfbdd : ∀ x, ‖f x‖ ≤ C) (hgbdd : ∀ x, ‖g x‖ ≤ D)
    (hf : IsLinftyAP ε t f) (hg : IsLinftyAP δ t g) : IsLinftyAP (D * ε + C * δ) t (f * g) := by
  rintro x
  have := hf x
  have := hg x
  have := hfbdd (x + t)
  have := hgbdd x
  calc
        ‖f (x + t) * g (x + t) - f x * g x‖
    _ = ‖g x * (f (x + t) - f x) + f (x + t) * (g (x + t) - g x)‖ := by ring_nf
    _ ≤ ‖g x * (f (x + t) - f x)‖ + ‖f (x + t) * (g (x + t) - g x)‖ := norm_add_le ..
    _ = ‖g x‖ * ‖f (x + t) - f x‖ + ‖f (x + t)‖ * ‖g (x + t) - g x‖ := by simp
    _ ≤ D * ε + C * δ := by gcongr <;> exact (norm_nonneg _).trans ‹_›

variable (f) in
/-- A function `f : ℝ → ℂ` is **uniformly almost periodic** if its set of `ε`, L∞-almost period is
relatively dense for all `ε > 0`. -/
def IsUnifAlmostPeriodic : Prop := ∀ ⦃ε⦄, 0 < ε → IsRelDense {t | IsLinftyAP ε t f}

-- The following theorem is false as stated: the definition `IsUnifAlmostPeriodic` does not
-- include a continuity hypothesis, but the indicator function of ℚ (as ℝ → ℂ) satisfies
-- `IsUnifAlmostPeriodic` while not being continuous. Every rational is a 0-almost period,
-- and ℚ is relatively dense. The standard Bohr definition of "uniformly almost periodic"
-- includes continuity.
--
-- /-- Any uniformly almost periodic function is uniformly continuous. -/
-- lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
--     UniformContinuous f := sorry

private lemma uap_triangle {f : ℝ → ℂ} {ε : ℝ} {x y τ : ℝ}
    (hτ : IsLinftyAP ε τ f) (hfxy : dist (f (x + τ)) (f (y + τ)) < ε) :
    dist (f x) (f y) < 3 * ε := by
  have h1 := hτ x
  have h2 := hτ y
  rw [dist_eq_norm] at *
  calc ‖f x - f y‖
      = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by
        calc ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖
          _ ≤ ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ))‖ + ‖f (y + τ) - f y‖ :=
              norm_add_le _ _
          _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by
              linarith [norm_add_le (f x - f (x + τ)) (f (x + τ) - f (y + τ))]
    _ < ε + ε + ε := by
        have h1' : ‖f x - f (x + τ)‖ ≤ ε := by rw [norm_sub_rev]; exact h1
        have h2' : ‖f (y + τ) - f y‖ ≤ ε := h2
        linarith
    _ = 3 * ε := by ring

/-
PROBLEM
A continuous, uniformly almost periodic function is uniformly continuous.
This corrects the original statement by adding the missing `Continuous f` hypothesis,
which is part of the standard Bohr definition of uniform almost periodicity.

PROVIDED SOLUTION
Use Metric.uniformContinuous_iff. Given ε > 0, need δ > 0 such that dist a b < δ → dist (f a) (f b) < ε.

Step 1: Get the set E of (ε/3)-almost periods, relatively dense with length l > 0. (Use hf (div_pos hε (by norm_num : (0:ℝ) < 3)))

Step 2: f is continuous, hence uniformly continuous on the compact set Icc (-1) (l+1). Use isCompact_Icc.uniformContinuousOn_of_continuous hcont.continuousOn, then Metric.uniformContinuousOn_iff to get δ₁ > 0 such that for x, y in Icc (-1) (l+1), dist x y < δ₁ → dist (f x) (f y) < ε/3.

Step 3: Set δ = min δ₁ 1 > 0.

Step 4: For any a b with dist a b < δ: let h = b - a, so |h| < δ ≤ 1. Apply relative density to (-a): get z ∈ [0, l) with (-a) + z ∈ E, i.e., τ := z - a is an (ε/3)-almost period. Then a + τ = z ∈ [0, l) ⊂ [-1, l+1] and b + τ = z + h ∈ (-1, l+1) since |h| < 1 and z ∈ [0, l). Both are in Icc (-1) (l+1). Also dist (a + τ) (b + τ) = dist a b < δ ≤ δ₁. So dist (f (a + τ)) (f (b + τ)) < ε/3 by Step 2.

Step 5: Apply uap_triangle with the (ε/3)-almost period τ and the bound dist (f (a+τ)) (f (b+τ)) < ε/3 to get dist (f a) (f b) < 3 * (ε/3) = ε.
-/
lemma IsUnifAlmostPeriodic.uniformContinuous (hcont : Continuous f)
    (hf : IsUnifAlmostPeriodic f) : UniformContinuous f := by
      rw [ Metric.uniformContinuous_iff ];
      intro ε hε_pos
      obtain ⟨l, hl⟩ : ∃ l > 0, ∀ x, ∃ y ∈ Set.Ico 0 l, x + y ∈ {t | ∀ x, ‖f (x + t) - f x‖ ≤ ε / 3} := by
        obtain ⟨l, hl⟩ := hf (by linarith : 0 < ε / 3);
        exact ⟨ l, IsRelDenseWith.pos hl, hl ⟩;
      obtain ⟨ δ₁, hδ₁_pos, hδ₁ ⟩ : ∃ δ₁ > 0, ∀ x ∈ Set.Icc (-1) (l + 1), ∀ y ∈ Set.Icc (-1) (l + 1), |x - y| < δ₁ → ‖f x - f y‖ < ε / 3 := by
        have h_unif_cont : UniformContinuousOn f (Set.Icc (-1 : ℝ) (l + 1)) := by
