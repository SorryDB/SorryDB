namespace DSet
open BST2

def pair {α β : Type} (f : α -> β) (p : α × α) : (β × β) := (f p.1, f p.2)

def split₁ {α : Type} [LT α] [LE α]
  [DecidableRel (α := α) (· < ·)]
  [DecidableRel (α := α) (· ≤ ·)]
  (x : α) : Set α → Set α × Set α :=
  pair mkTree ∘ List.partition (· ≤ x) ∘ Tree.flatten


end DSet

end Chapter4

