import Imo.ProblemImports
import P6Helpers
import P6Helpers2

open scoped Real
open scoped Nat
open Finset

noncomputable section

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  -- Proved using helper infrastructure in P6Work.lean, P6Helpers.lean, P6Helpers2.lean
  obtain ⟨hfin, hcard⟩ := imo6_M_finite_bounded a hi hii
  set p := (imo6_M a).ncard with hp_def
  have hp_le : p ≤ 2014 := hcard
  have hb_pos : 0 < 1 + p := by omega
  obtain ⟨L, N, hN⟩ := imo6_partial_sum_bounded a hi hii hfin hcard
  refine ⟨⟨1 + p, hb_pos⟩, N, fun m n ⟨hmn, hNm⟩ => ?_⟩
  have hNn : N ≤ n := le_trans hNm (le_of_lt hmn)
  have hn_bound := hN n hNn
  have hm_bound := hN m hNm
  rw [imo6_sum_split _ m n hmn]
  show |∑ j ∈ Icc 1 n, (a j - (1 + ↑(imo6_M a).ncard)) -
    ∑ j ∈ Icc 1 m, (a j - (1 + ↑(imo6_M a).ncard))| ≤ 1007 ^ 2
  have hamgm : (↑(p * (2014 - p)) : ℤ) ≤ (1007 : ℤ) ^ 2 := by
    exact_mod_cast imo6_amgm p hp_le
  rw [abs_le]
  constructor <;> linarith [hn_bound.1, hn_bound.2, hm_bound.1, hm_bound.2]

