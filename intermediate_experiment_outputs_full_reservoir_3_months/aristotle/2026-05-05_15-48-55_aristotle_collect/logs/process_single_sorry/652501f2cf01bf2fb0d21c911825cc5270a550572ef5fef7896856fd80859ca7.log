      rw [ Nat.geomSum_eq ] <;> norm_num
    linarith [hA_sum, hB_sum, hB_sum_le]

/-
Key mathematical theorem: bit 127 of the sum of parts indicates whether input > c
-/
lemma partNatVal_sum_testBit127 (c : ℕ) (hc : c < 2^254) (input_bits : Vector ℕ 254)
    (h_bits : ∀ i (_ : i < 254), input_bits[i] = 0 ∨ input_bits[i] = 1) :
    (Fin.foldl 127 (fun acc i => acc + partNatVal c input_bits i) 0).testBit 127 =
      decide (fromBits input_bits > c) := by
  have h_decomp : ∃ (G : ℕ) (A B : ℕ), G = (Finset.filter (fun i : Fin 127 => pairDigit (fromBits input_bits) i.val > pairDigit c i.val) Finset.univ).card ∧ A = Finset.sum (Finset.filter (fun i : Fin 127 => pairDigit (fromBits input_bits) i.val > pairDigit c i.val) Finset.univ) (fun i => 2^i.val) ∧ B = Finset.sum (Finset.filter (fun i : Fin 127 => pairDigit (fromBits input_bits) i.val < pairDigit c i.val) Finset.univ) (fun i => 2^i.val) := by
    exact ⟨ _, _, _, rfl, rfl, rfl ⟩;
  obtain ⟨ G, A, B, hG, hA, hB ⟩ := h_decomp;
  have h_sum : Fin.foldl 127 (fun acc i => acc + partNatVal c input_bits i) 0 = G * 2^128 - A + B := by
    have h_sum : Fin.foldl 127 (fun acc i => acc + partNatVal c input_bits i) 0 = Finset.sum (Finset.univ : Finset (Fin 127)) (fun i => if pairDigit (fromBits input_bits) i.val > pairDigit c i.val then 2^128 - 2^i.val else if pairDigit (fromBits input_bits) i.val < pairDigit c i.val then 2^i.val else 0) := by
      have h_sum : ∀ i : Fin 127, partNatVal c input_bits i = if pairDigit (fromBits input_bits) i.val > pairDigit c i.val then 2^128 - 2^i.val else if pairDigit (fromBits input_bits) i.val < pairDigit c i.val then 2^i.val else 0 := by
        exact?;
      simp +decide only [h_sum];
      rw [ Finset.sum_eq_multiset_sum ];
      erw [ Multiset.map_coe ] ; norm_num;
      rw [ List.sum_eq_foldl ];
      rw [ List.foldl_map ];
      grind;
    simp_all +decide [ Finset.sum_ite ];
    congr! 1;
    · rw [ Nat.sub_eq_of_eq_add ];
      rw [ ← Finset.sum_add_distrib, Finset.sum_congr rfl fun x hx => tsub_add_cancel_of_le <| Nat.le_of_lt <| Nat.lt_of_lt_of_le ( pow_lt_pow_right₀ ( by decide ) <| Fin.is_lt x ) <| by decide ] ; simp +decide [ Finset.sum_const ];
    · congr! 1;
      grind;
  by_cases hG : G ≥ 1 ∨ A = 0 <;> by_cases hS : G * 2 ^ 128 ≥ A <;> simp_all +decide only [decide_eq_true_eq];
  · rw [ testBit127_weighted_sum ];
    · have h_pairDigit_comparison : (Finset.sum (Finset.range 127) (fun i => if pairDigit (fromBits input_bits) i > pairDigit c i then 2^i else 0) > Finset.sum (Finset.range 127) (fun i => if pairDigit (fromBits input_bits) i < pairDigit c i then 2^i else 0)) ↔ (fromBits input_bits > c) := by
        apply pairDigit_weighted_comparison;
        · exact fromBits_lt _ h_bits;
        · exact hc;
      simp_all +decide [ Finset.sum_filter, Finset.sum_range ];
    · refine' lt_of_le_of_lt ( Finset.sum_le_sum_of_subset ( Finset.subset_univ _ ) ) _;
      native_decide +revert;
    · refine' lt_of_le_of_lt ( Finset.sum_le_sum_of_subset ( Finset.filter_subset _ _ ) ) _;
      native_decide +revert;
    · exact hG;
    · exact hS;
  · contrapose! hS;
    exact le_trans ( Finset.sum_le_sum fun _ _ => Nat.pow_le_pow_right ( by decide ) ( Fin.is_lt _ |> Nat.le_of_lt ) ) ( by norm_num; nlinarith );
  · simp_all +decide [ Finset.ext_iff ];
    exact absurd hG.2 ( by rintro ⟨ i, hi ⟩ ; exact not_lt_of_ge ( hG.1 i ) hi );
  · simp_all +decide [ not_or, Finset.ext_iff ];
    exact absurd hG.2 ( by rintro ⟨ i, hi ⟩ ; exact not_lt_of_ge ( hG.1 i ) hi )

/--
The CompConstant circuit, formalized with a correctness proof.

**Note**: The `Assumptions` field includes `c < 2^254` because the circuit only examines
the bottom 254 bits of `c`. This matches the intended usage in circomlib where the constant
is always a field prime (which is < 2^254 for the BN254/BabyJubjub curves).
-/
def circuit (c : ℕ) : FormalCircuit (F p) (fields 254) field where
  main := main c
  localLength _ := 127 + 1 + 135 + 1
  localLength_eq := by simp only [circuit_norm, main, Num2Bits.circuit]
  subcircuitsConsistent input n := by
    simp only [circuit_norm, main, Num2Bits.circuit]
    and_intros <;> ac_rfl

  Assumptions input :=
    (∀ i (_ : i < 254), input[i] = 0 ∨ input[i] = 1) ∧ c < 2^254

  Spec bits output :=
    output = if fromBits (bits.map ZMod.val) > c then 1 else 0

  soundness := by
    simp only [circuit_norm, main]
    intro offset env input_var input h_input ⟨h_bits, hc⟩ ⟨h_parts, h_sout, h_num2bits, h_out⟩
    simp only [Num2Bits.circuit] at h_num2bits h_out
    obtain ⟨h_sout_lt, h_fieldToBits⟩ := h_num2bits
    -- Simplify ElaboratedCircuit.localLength in goal
    simp only [circuit_norm, Num2Bits.circuit] at h_out ⊢
    -- h_out: env.get (offset + 263) = env.get (offset + 255)
    -- h_fieldToBits: bits vector = fieldToBits 135 sout
    -- Goal: env.get (offset + 263) = if fromBits ... > c then 1 else 0

    -- Step 1: output = (fieldToBits 135 sout)[127]
    have h_bit127 : env.get (offset + 127 + 1 + 127) = (fieldToBits 135 (env.get (offset + 127)))[127] := by
      have := congr_arg (fun v => v[127]) h_fieldToBits
      simp only [Vector.getElem_map, Vector.getElem_mapRange, circuit_norm] at this
      exact this
    rw [h_out, h_bit127]

    -- Step 2: (fieldToBits 135 sout)[127] = if sout.val.testBit 127 then 1 else 0
    simp only [fieldToBits, toBits, Vector.getElem_map, Vector.getElem_mapRange]
    simp only [Nat.cast_ite, Nat.cast_one, Nat.cast_zero]

    -- Step 3: Show sout.val.testBit 127 = decide(fromBits > c)
    -- Need: env.get(offset+127).val = partsNatSum
    -- From h_parts and h_sout, env.get(offset+127) = sum of field parts
    -- Each field part = ↑(partNatVal ...) by partFieldVal_eq_natCast
    -- Total sum as nat < 2^135 < p, so val = nat sum
    -- Then apply partNatVal_sum_testBit127
    -- Goal: (sout.val.testBit 127 = true) = (fromBits > c)
    -- We need to show sout.val = Fin.foldl 127 (fun acc i => acc + partNatVal c (input.map ZMod.val) i) 0
    -- Then apply partNatVal_sum_testBit127
    have h_input_bits : ∀ i (_ : i < 254), (input.map ZMod.val)[i] = 0 ∨ (input.map ZMod.val)[i] = 1 := by
      intro i hi; simp only [Vector.getElem_map]
      rcases h_bits i hi with h | h
      · left; exact congrArg ZMod.val h ▸ ZMod.val_zero
      · right; exact congrArg ZMod.val h ▸ ZMod.val_one p
    have h_sum_val : (env.get (offset + 127)).val =
        Fin.foldl 127 (fun acc i => acc + partNatVal c (input.map ZMod.val) i) 0 := by
      sorry
    have key := partNatVal_sum_testBit127 c hc (input.map ZMod.val) h_input_bits
    rw [← h_sum_val] at key
    -- key : testBit 127 = decide(fromBits > c)
    -- Goal: (if testBit 127 = true then 1 else 0) = (if fromBits > c then 1 else 0)
    by_cases h_gt : fromBits (Vector.map ZMod.val input) > c
    · have : (ZMod.val (env.get (offset + 127))).testBit 127 = true := by
        rw [key]; simp [h_gt]
      simp [this, h_gt]
    · have : (ZMod.val (env.get (offset + 127))).testBit 127 ≠ true := by
        rw [key]; simp [h_gt]
      simp [this, h_gt]

  completeness := by
    simp only [circuit_norm, main, Num2Bits.circuit]
    sorry
end CompConstant

end Circomlib
