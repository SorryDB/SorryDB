https://github.com/iden3/circomlib/blob/35e54ea21da3e8762557234298dbb553c175ea8d/circuits/compconstant.circom
-/

namespace Circomlib
open Utils.Bits
variable {p : ℕ} [Fact p.Prime] [Fact (p < 2^254)] [Fact (p > 2^253)]

namespace CompConstant
/-
template CompConstant(ct) {
    signal input in[254];
    signal output out;

    signal parts[127];
    signal sout;

    var clsb;
    var cmsb;
    var slsb;
    var smsb;

    var sum=0;

    var b = (1 << 128) -1;
    var a = 1;
    var e = 1;
    var i;

    for (i=0;i<127; i++) {
        clsb = (ct >> (i*2)) & 1;
        cmsb = (ct >> (i*2+1)) & 1;
        slsb = in[i*2];
        smsb = in[i*2+1];

        if ((cmsb==0)&&(clsb==0)) {
            parts[i] <== -b*smsb*slsb + b*smsb + b*slsb;
        } else if ((cmsb==0)&&(clsb==1)) {
            parts[i] <== a*smsb*slsb - a*slsb + b*smsb - a*smsb + a;
        } else if ((cmsb==1)&&(clsb==0)) {
            parts[i] <== b*smsb*slsb - a*smsb + a;
        } else {
            parts[i] <== -a*smsb*slsb + a;
        }

        sum = sum + parts[i];

        b = b -e;
        a = a +e;
        e = e*2;
    }

    sout <== sum;

    component num2bits = Num2Bits(135);

    num2bits.in <== sout;

    out <== num2bits.out[127];
}
-/
def main (ct : ℕ) (input : Vector (Expression (F p)) 254) := do
  let parts : fields 127 (Expression (F p)) <== Vector.ofFn fun i =>
    let clsb := (ct >>> (i.val * 2)) &&& 1
    let cmsb := (ct >>> (i.val * 2 + 1)) &&& 1
    let slsb := input[i.val * 2]
    let smsb := input[i.val * 2 + 1]

    -- Compute b, a values for this iteration
    let b_val : ℤ := 2^128 - 2^i.val
    let a_val : ℤ := 2^i.val

    if cmsb == 0 && clsb == 0 then
      -(b_val : F p) * smsb * slsb + (b_val : F p) * smsb + (b_val : F p) * slsb
    else if cmsb == 0 && clsb == 1 then
      (a_val : F p) * smsb * slsb - (a_val : F p) * slsb + (b_val : F p) * smsb - (a_val : F p) * smsb + (a_val : F p)
    else if cmsb == 1 && clsb == 0 then
      (b_val : F p) * smsb * slsb - (a_val : F p) * smsb + (a_val : F p)
    else
      -(a_val : F p) * smsb * slsb + (a_val : F p)

  -- Compute sum
  let sout <== parts.sum

  -- Convert sum to bits
  have hp : p > 2^135 := by linarith [‹Fact (p > 2^253)›.elim]
  let bits ← Num2Bits.circuit 135 hp sout

  let out <== bits[127]
  return out

/-! ### Helper definitions and lemmas for the soundness proof -/

/-- Compute the field value of parts[i] for binary inputs. -/
noncomputable def partFieldVal (c : ℕ) (input : Vector (F p) 254) (i : Fin 127) : F p :=
  let clsb := (c >>> (i.val * 2)) &&& 1
  let cmsb := (c >>> (i.val * 2 + 1)) &&& 1
  let slsb := input[i.val * 2]
  let smsb := input[i.val * 2 + 1]
  let b_val : ℤ := 2^128 - 2^i.val
  let a_val : ℤ := 2^i.val
  if cmsb == 0 && clsb == 0 then
    -(b_val : F p) * smsb * slsb + (b_val : F p) * smsb + (b_val : F p) * slsb
  else if cmsb == 0 && clsb == 1 then
    (a_val : F p) * smsb * slsb - (a_val : F p) * slsb + (b_val : F p) * smsb - (a_val : F p) * smsb + (a_val : F p)
  else if cmsb == 1 && clsb == 0 then
    (b_val : F p) * smsb * slsb - (a_val : F p) * smsb + (a_val : F p)
  else
    -(a_val : F p) * smsb * slsb + (a_val : F p)

/-- The natural number value corresponding to each part, for binary inputs. -/
def partNatVal (c : ℕ) (input_bits : Vector ℕ 254) (i : Fin 127) : ℕ :=
  let clsb := (c >>> (i.val * 2)) &&& 1
  let cmsb := (c >>> (i.val * 2 + 1)) &&& 1
  let slsb := input_bits[i.val * 2]
  let smsb := input_bits[i.val * 2 + 1]
  let d := slsb + 2 * smsb
  let cd := clsb + 2 * cmsb
  if d > cd then 2^128 - 2^i.val
  else if d < cd then 2^i.val
  else 0

/-
When inputs are binary, the field value of each part equals the cast of the natural number value
-/
set_option maxHeartbeats 800000 in
lemma partFieldVal_eq_natCast (c : ℕ) (input : Vector (F p) 254) (i : Fin 127)
    (h_bits : ∀ j (_ : j < 254), input[j] = 0 ∨ input[j] = 1) :
    partFieldVal c input i = (partNatVal c (input.map ZMod.val) i : F p) := by
  unfold partFieldVal partNatVal;
  rcases h_bits ( i * 2 ) ( by linarith [ Fin.is_lt i ] ) with ha | ha <;> rcases h_bits ( i * 2 + 1 ) ( by linarith [ Fin.is_lt i ] ) with hb | hb <;> norm_num [ ha, hb ];
  · split_ifs <;> simp_all +decide [ Nat.shiftRight_eq_div_pow ];
    · grind;
    · grind +suggestions;
    · cases Nat.mod_two_eq_zero_or_one ( c / 2 ^ ( i.val * 2 ) ) <;> cases Nat.mod_two_eq_zero_or_one ( c / 2 ^ ( i.val * 2 + 1 ) ) <;> simp_all +decide only;
      · grind +suggestions;
      · grind;
      · grind +suggestions;
  · cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 + 1 ) ) <;> cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 ) ) <;> simp +decide [ *, Nat.add_comm ];
    · simp_all +decide [ add_comm ];
      rw [ Nat.cast_sub ] <;> norm_num [ ha, hb ];
      · grind +revert;
      · exact le_trans ( pow_le_pow_right₀ ( by decide ) ( Fin.is_le i ) ) ( by decide );
    · rw [ Nat.cast_sub ] <;> norm_num [ ha, hb ];
      · grind +suggestions;
      · exact le_trans ( pow_le_pow_right₀ ( by decide ) ( Fin.is_le i ) ) ( by decide );
    · grind +suggestions;
    · grind +suggestions;
  · cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 ) ) <;> cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 + 1 ) ) <;> simp +decide [ *, Nat.sub_sub ];
    · rw [ Nat.cast_sub ( by exact le_trans ( pow_le_pow_right₀ ( by decide ) ( Fin.is_le _ ) ) ( by decide ) ) ] ; norm_num [ ha, hb ];
      grobner;
    · grind +suggestions;
    · grind +suggestions;
    · grind +suggestions;
  · cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 ) ) <;> cases Nat.mod_two_eq_zero_or_one ( c >>> ( i.val * 2 + 1 ) ) <;> simp +decide [ *, Nat.add_mod, Nat.mul_mod ];
    · rw [ Nat.cast_sub ] <;> norm_num [ ha, hb ];
      · grind;
      · exact le_trans ( pow_le_pow_right₀ ( by decide ) ( Fin.is_le i ) ) ( by decide );
    · simp_all +decide [ ZMod.val ];
      rcases p with ( _ | _ | p ) <;> norm_num [ ZMod ] at *;
      · exact False.elim <| Fact.out;
      · exact False.elim <| Fact.out;
      · erw [ ha, hb ] ; norm_num;
        rw [ Nat.cast_sub ] <;> norm_num ; linarith [ Nat.pow_le_pow_right ( by decide : 1 ≤ 2 ) ( show ( i : ℕ ) ≤ 126 by linarith [ Fin.is_lt i ] ) ];
    · simp_all +decide [ ZMod.val ];
      rcases p with ( _ | _ | p ) <;> simp_all +decide [ ZMod ];
      erw [ ha, hb ] ; norm_num;
      rw [ Nat.cast_sub ] <;> norm_num ; linarith [ Nat.pow_le_pow_right ( by decide : 1 ≤ 2 ) ( show ( i : ℕ ) ≤ 126 by linarith [ Fin.is_lt i ] ) ];
    · erw [ ha, hb ];
      rcases p with ( _ | _ | _ | _ | p ) <;> norm_cast

/-
The sum of part natural values is less than 2^135
-/
lemma partNatVal_sum_lt (c : ℕ) (input_bits : Vector ℕ 254)
    (h_bits : ∀ i (_ : i < 254), input_bits[i] = 0 ∨ input_bits[i] = 1) :
    Fin.foldl 127 (fun acc i => acc + partNatVal c input_bits i) 0 < 2^135 := by
  -- Each partNatVal is at most 2^128 - 1.
  have h_partNatVal_bound : ∀ i : Fin 127, partNatVal c input_bits i ≤ 2 ^ 128 - 1 := by
    intro i
    unfold partNatVal
    simp [h_bits];
    split_ifs <;> norm_num;
    · fin_cases i <;> trivial;
    · exact le_trans ( pow_le_pow_right₀ ( by decide ) ( Fin.is_le i ) ) ( by decide );
  -- The sum of 127 such terms is ≤ 127*(2^128-1).
  have h_sum_bound : Fin.foldl 127 (fun acc i => acc + partNatVal c input_bits i) 0 ≤ 127 * (2 ^ 128 - 1) := by
    have h_sum_bound : ∀ (n : ℕ) (f : Fin n → ℕ), (∀ i, f i ≤ 2 ^ 128 - 1) → (Fin.foldl n (fun acc i => acc + f i) 0) ≤ n * (2 ^ 128 - 1) := by
      intros n f hf_bound
      have h_sum_bound : ∑ i : Fin n, f i ≤ n * (2 ^ 128 - 1) := by
        exact le_trans ( Finset.sum_le_sum fun _ _ => hf_bound _ ) ( by norm_num );
      convert h_sum_bound using 1;
      rw [ Finset.sum_eq_multiset_sum ];
      erw [ Multiset.map_coe ] ; norm_num [ Finset.univ ];
      rw [ List.sum_eq_foldl ];
      rw [ List.foldl_map ];
      exact?;
    exact h_sum_bound _ _ h_partNatVal_bound;
  exact lt_of_le_of_lt h_sum_bound ( by decide )

/-! ### Sub-lemmas for the key mathematical theorem -/

/-- The "digit" of a number at pair position i: bits 2i and 2i+1 combined -/
def pairDigit (x : ℕ) (i : ℕ) : ℕ := (x >>> (i * 2)) &&& 3

/-
For a number < 2^254, it equals the sum of its pair digits times 4^i
-/
lemma sum_pairDigits (x : ℕ) (hx : x < 2^254) :
    x = Finset.sum (Finset.range 127) (fun i => pairDigit x i * 4^i) := by
  -- By definition of `pairDigit`, we can write `x` as a sum of its base-4 digits.
  have h_digits : x = Finset.sum (Finset.range 127) (fun i => (x / 4^i) % 4 * 4^i) := by
    -- Applying the definition of `Finset.sum_range_succ` repeatedly, we can expand the right-hand side of the equation.
    have h_expand : ∀ n, ∑ i ∈ Finset.range n, (x / 4^i) % 4 * 4^i = x - x / 4^n * 4^n := by
      intro n; induction n <;> simp +decide [ Finset.sum_range_succ, pow_succ, * ] ; ring;
      rw [ tsub_add_eq_add_tsub ];
      · rw [ ← Nat.mod_add_div ( x / 4 ^ _ ) 4 ] ; ring;
        norm_num [ Nat.div_div_eq_div_mul ] ; ring;
        rw [ Nat.add_comm, Nat.add_sub_add_left ];
      · exact Nat.div_mul_le_self _ _;
    rw [ h_expand, Nat.div_eq_of_lt ] <;> norm_num ; linarith;
  convert h_digits using 2;
  unfold pairDigit; norm_num [ Nat.shiftRight_eq_div_pow ] ;
  norm_num [ Nat.pow_mul' ];
  have h_mod : ∀ n : ℕ, n % 4 = n &&& 3 := by
    intro n; exact (by
    have h_mod : ∀ n : ℕ, n % 4 = n &&& 3 := by
      intro n
      have h_mod : n % 4 = n % 2^2 := by
        rfl
      have h_mod : n % 2^2 = n &&& (2^2 - 1) := by
        exact?
      exact Eq.trans ‹_› h_mod;
    exact h_mod n);
  rw [ h_mod ]

/-
Comparison of two numbers < 2^254 is determined by the highest differing pair digit
-/
lemma pairDigit_comparison (a b : ℕ) (ha : a < 2^254) (hb : b < 2^254) :
    a > b ↔ ∃ k < 127, pairDigit a k > pairDigit b k ∧
      ∀ j, k < j → j < 127 → pairDigit a j = pairDigit b j := by
  constructor;
  · intro h_gt
    obtain ⟨k, hk⟩ : ∃ k < 127, pairDigit a k > pairDigit b k ∧ ∀ j, k < j → j < 127 → pairDigit a j = pairDigit b j := by
      have h_sum : a = Finset.sum (Finset.range 127) (fun i => pairDigit a i * 4^i) ∧ b = Finset.sum (Finset.range 127) (fun i => pairDigit b i * 4^i) := by
        exact ⟨ sum_pairDigits a ha, sum_pairDigits b hb ⟩
      -- Let $k$ be the largest index such that $pairDigit a k \neq pairDigit b k$.
      obtain ⟨k, hk⟩ : ∃ k < 127, pairDigit a k ≠ pairDigit b k ∧ ∀ j, k < j → j < 127 → pairDigit a j = pairDigit b j := by
        obtain ⟨k, hk⟩ : ∃ k < 127, pairDigit a k ≠ pairDigit b k := by
          contrapose! h_gt;
          rw [ h_sum.1, h_sum.2 ] ; exact Finset.sum_le_sum fun i hi => by rw [ h_gt i ( Finset.mem_range.mp hi ) ] ;
        exact ⟨ Finset.max' ( Finset.filter ( fun i => pairDigit a i ≠ pairDigit b i ) ( Finset.range 127 ) ) ⟨ k, by simpa using hk ⟩, Finset.mem_range.mp ( Finset.mem_filter.mp ( Finset.max'_mem ( Finset.filter ( fun i => pairDigit a i ≠ pairDigit b i ) ( Finset.range 127 ) ) ⟨ k, by simpa using hk ⟩ ) |>.1 ), Finset.mem_filter.mp ( Finset.max'_mem ( Finset.filter ( fun i => pairDigit a i ≠ pairDigit b i ) ( Finset.range 127 ) ) ⟨ k, by simpa using hk ⟩ ) |>.2, fun j hj₁ hj₂ => Classical.not_not.1 fun hj₃ => not_lt_of_ge ( Finset.le_max' _ _ <| by simpa using ⟨ hj₂, hj₃ ⟩ ) hj₁ ⟩;
      refine' ⟨ k, hk.1, lt_of_le_of_ne _ _, hk.2.2 ⟩;
      · -- Since $pairDigit a k < pairDigit b k$, we have $a - b = \sum_{i=0}^{126} (pairDigit a i - pairDigit b i) * 4^i \leq (pairDigit a k - pairDigit b k) * 4^k + \sum_{i=0}^{k-1} (pairDigit a i - pairDigit b i) * 4^i$.
        have h_diff : a - b ≤ (pairDigit a k - pairDigit b k) * 4^k + ∑ i ∈ Finset.range k, (pairDigit a i - pairDigit b i : ℤ) * 4^i := by
          have h_diff : a - b = ∑ i ∈ Finset.range 127, (pairDigit a i - pairDigit b i : ℤ) * 4^i := by
            simp +decide [ sub_mul, Finset.sum_sub_distrib, ← h_sum.1, ← h_sum.2 ];
            exact congrArg₂ _ ( mod_cast h_sum.1 ) ( mod_cast h_sum.2 );
          rw [ h_diff, ← Finset.sum_range_add_sum_Ico _ ( show k ≤ 127 from hk.1.le ) ];
          rw [ add_comm, Finset.sum_Ico_eq_sum_range ];
          rw [ Finset.sum_eq_single 0 ] <;> norm_num;
          · exact fun i hi hi' => by rw [ hk.2.2 ( k + i ) ( by linarith [ Nat.pos_of_ne_zero hi' ] ) ( by omega ) ] ; ring;
          · grind;
        -- Since $pairDigit a k < pairDigit b k$, we have $\sum_{i=0}^{k-1} (pairDigit a i - pairDigit b i) * 4^i \leq \sum_{i=0}^{k-1} 3 * 4^i$.
        have h_sum_bound : ∑ i ∈ Finset.range k, (pairDigit a i - pairDigit b i : ℤ) * 4^i ≤ ∑ i ∈ Finset.range k, 3 * 4^i := by
          have h_sum_bound : ∀ i < k, (pairDigit a i - pairDigit b i : ℤ) ≤ 3 := by
            intros i hi
            have h_pairDigit_bound : pairDigit a i ≤ 3 ∧ pairDigit b i ≤ 3 := by
              exact ⟨ Nat.le_of_lt_succ ( Nat.lt_of_le_of_lt ( Nat.and_le_right ) ( by decide ) ), Nat.le_of_lt_succ ( Nat.lt_of_le_of_lt ( Nat.and_le_right ) ( by decide ) ) ⟩;
            grind;
          exact Finset.sum_le_sum fun i hi => mul_le_mul_of_nonneg_right ( h_sum_bound i ( Finset.mem_range.mp hi ) ) ( by positivity );
        -- Since $\sum_{i=0}^{k-1} 3 * 4^i = 4^k - 1$, we have $\sum_{i=0}^{k-1} (pairDigit a i - pairDigit b i) * 4^i \leq 4^k - 1$.
        have h_sum_bound_final : ∑ i ∈ Finset.range k, (pairDigit a i - pairDigit b i : ℤ) * 4^i ≤ 4^k - 1 := by
          exact h_sum_bound.trans ( Nat.recOn k ( by norm_num ) fun n ihn => by norm_num [ Finset.sum_range_succ, pow_succ' ] at ihn ⊢ ; linarith );
        nlinarith [ pow_pos ( by decide : 0 < 4 ) k ];
      · exact Ne.symm hk.2.1
    exact ⟨k, hk⟩;
  · intro h
    obtain ⟨k, hk_lt, hk_gt, hk_eq⟩ := h
    have h_sum : a - b = Finset.sum (Finset.range 127) (fun j => (pairDigit a j - pairDigit b j : ℤ) * 4^j) := by
      have h_sum : a = Finset.sum (Finset.range 127) (fun j => pairDigit a j * 4^j) ∧ b = Finset.sum (Finset.range 127) (fun j => pairDigit b j * 4^j) := by
        exact ⟨ sum_pairDigits a ha, sum_pairDigits b hb ⟩;
      norm_num [ sub_mul, Finset.sum_sub_distrib ] at * ; linarith;
    -- Since $pairDigit a j = pairDigit b j$ for all $j > k$, the sum simplifies to $(pairDigit a k - pairDigit b k) * 4^k$.
    have h_sum_simplified : a - b = (pairDigit a k - pairDigit b k : ℤ) * 4^k + Finset.sum (Finset.range k) (fun j => (pairDigit a j - pairDigit b j : ℤ) * 4^j) := by
      have h_sum_simplified : a - b = Finset.sum (Finset.range (k + 1)) (fun j => (pairDigit a j - pairDigit b j : ℤ) * 4^j) := by
        rw [ h_sum, ← Finset.sum_subset ( Finset.range_mono ( Nat.succ_le_of_lt hk_lt ) ) ] ; aesop;
      rw [ h_sum_simplified, Finset.sum_range_succ, add_comm ];
    -- Since $pairDigit a j \leq 3$ and $pairDigit b j \geq 0$ for all $j$, the sum $\sum_{j=0}^{k-1} (pairDigit a j - pairDigit b j) * 4^j$ is bounded above by $3 * \sum_{j=0}^{k-1} 4^j$.
    have h_sum_bound : Finset.sum (Finset.range k) (fun j => (pairDigit a j - pairDigit b j : ℤ) * 4^j) ≥ -3 * Finset.sum (Finset.range k) (fun j => 4^j) := by
      rw [ Finset.mul_sum _ _ _ ];
      gcongr ; norm_num [ pairDigit ];
      exact_mod_cast Nat.le_trans ( Nat.and_le_right ) ( by norm_num );
    -- Since $pairDigit a k > pairDigit b k$, we have $(pairDigit a k - pairDigit b k) * 4^k \geq 4^k$.
    have h_diff_ge : (pairDigit a k - pairDigit b k : ℤ) * 4^k ≥ 4^k := by
      exact le_mul_of_one_le_left ( by positivity ) ( by linarith );
    exact_mod_cast ( by linarith [ show ( ∑ j ∈ Finset.range k, ( 4 : ℤ ) ^ j ) = ( 4 ^ k - 1 ) / 3 by rw [ Int.ediv_eq_of_eq_mul_left ] <;> linarith [ geom_sum_mul_neg ( 4 : ℤ ) k ], Int.mul_ediv_add_emod ( 4 ^ k - 1 ) 3, Int.emod_nonneg ( 4 ^ k - 1 ) three_ne_zero, Int.emod_lt_of_pos ( 4 ^ k - 1 ) three_pos ] : ( a : ℤ ) > b )

/-
The pair digit of fromBits input_bits equals slsb + 2*smsb
-/
lemma fromBits_pairDigit (input_bits : Vector ℕ 254)
    (h_bits : ∀ i (_ : i < 254), input_bits[i] = 0 ∨ input_bits[i] = 1)
    (i : ℕ) (hi : i < 127) :
    pairDigit (fromBits input_bits) i = input_bits[i * 2] + 2 * input_bits[i * 2 + 1] := by
  unfold pairDigit;
  have h_pair_digit : ∀ (x : ℕ), x < 2^254 → (x >>> (i * 2) &&& 3) = (x.testBit (i * 2) |>.toNat) + 2 * (x.testBit (i * 2 + 1) |>.toNat) := by
    intro x hx
    have h_pair_digit : (x >>> (i * 2) &&& 3) = (x.testBit (i * 2) |>.toNat) + 2 * (x.testBit (i * 2 + 1) |>.toNat) := by
      have h_bit : ∀ (n : ℕ), n < 4 → n = (n.testBit 0 |>.toNat) + 2 * (n.testBit 1 |>.toNat) := by
        native_decide
      convert h_bit ( x >>> ( i * 2 ) &&& 3 ) _ using 1;
      · norm_num [ Nat.testBit_and, Nat.testBit_shiftRight ];
        grind +revert;
      · exact Nat.lt_succ_of_le ( Nat.le_of_lt_succ ( Nat.lt_of_le_of_lt ( Nat.and_le_right ) ( by decide ) ) );
    exact h_pair_digit;
  rw [ h_pair_digit _ ( fromBits_lt _ h_bits ) ];
  have h_testBit : ∀ (j : ℕ) (hj : j < 254), (fromBits input_bits).testBit j = (input_bits[j] == 1) := by
    have h_testBit : toBits 254 (fromBits input_bits) = input_bits := by
      exact toBits_fromBits _ h_bits;
    intro j hj; replace h_testBit := congr_arg ( fun x => x[j] ) h_testBit; simp_all +decide [ toBits ] ;
    cases h_bits j hj <;> simp_all +decide [ Vector.getElem_mapRange ];
  grind +locals

/-
partNatVal in terms of pairDigit comparison
-/
lemma partNatVal_eq_pairDigit (c : ℕ) (input_bits : Vector ℕ 254)
    (h_bits : ∀ i (_ : i < 254), input_bits[i] = 0 ∨ input_bits[i] = 1)
    (i : Fin 127) :
    partNatVal c input_bits i =
      if pairDigit (fromBits input_bits) i.val > pairDigit c i.val then 2^128 - 2^i.val
      else if pairDigit (fromBits input_bits) i.val < pairDigit c i.val then 2^i.val
      else 0 := by
  -- Apply the definition of `partNatVal` and `pairDigit`.
  simp [partNatVal, pairDigit];
  -- By definition of `fromBits`, we know that `fromBits input_bits >>> (i.val * 2) &&& 3` is equal to `input_bits[i.val * 2] + 2 * input_bits[i.val * 2 + 1]`.
  have h_fromBits : fromBits input_bits >>> (i.val * 2) &&& 3 = input_bits[i.val * 2] + 2 * input_bits[i.val * 2 + 1] := by
    convert fromBits_pairDigit input_bits h_bits i.val ( Fin.is_lt i ) using 1;
  simp_all +decide [ Nat.shiftRight_eq_div_pow ];
  -- By definition of modulo and bitwise AND, we know that $x \mod 4 = x \&\&\& 3$ for any integer $x$.
  have h_mod_and : ∀ x : ℕ, x % 4 = x &&& 3 := by
    intro x; exact (by
    have h_mod_and : ∀ x : ℕ, x % 4 = x &&& 3 := by
      intro x
      have h_mod : x % 4 = x % 2^2 := by
        rfl
      have h_and : x &&& 3 = x &&& (2^2 - 1) := by
        rfl
      rw [ h_mod, h_and ];
      exact?;
    exact h_mod_and x);
  rw [ ← h_mod_and ] ; ring;
  rw [ show c / 2 ^ ( i.val * 2 ) % 4 = c / 2 ^ ( i.val * 2 ) % 2 + c / ( 2 ^ ( i.val * 2 ) * 2 ) % 2 * 2 from ?_ ];
  rw [ show c / ( 2 ^ ( i.val * 2 ) * 2 ) = c / 2 ^ ( i.val * 2 ) / 2 by rw [ Nat.div_div_eq_div_mul ] ];
  grind +ring

/-
testBit 127 of a sum G*2^128 - A + B where A,B < 2^127
-/
lemma testBit127_weighted_sum (G A B : ℕ) (hA : A < 2^127) (hB : B < 2^127)
    (hG : G ≥ 1 ∨ A = 0) (hS : G * 2^128 ≥ A) :
    (G * 2^128 - A + B).testBit 127 = decide (A > B) := by
  grind

/-
For two numbers < 2^254, the pairDigit-based comparison is equivalent to
    comparison of weighted sums of powers of 2
-/
lemma pairDigit_weighted_comparison (a b : ℕ) (ha : a < 2^254) (hb : b < 2^254) :
    ((∑ i ∈ Finset.range 127, if pairDigit a i > pairDigit b i then (2:ℕ)^i else 0) >
     (∑ i ∈ Finset.range 127, if pairDigit a i < pairDigit b i then (2:ℕ)^i else 0)) ↔
    a > b := by
  constructor <;> intro h <;> contrapose! h <;> simp_all +decide [ Finset.sum_ite ];
  · by_cases h_eq : a = b;
    · aesop;
    · -- By pairDigit_comparison, there exists k < 127 such that pairDigit b k > pairDigit a k and all higher pairs agree.
      obtain ⟨k, hk₁, hk₂⟩ : ∃ k < 127, pairDigit b k > pairDigit a k ∧ ∀ j, k < j → j < 127 → pairDigit b j = pairDigit a j := by
        have := pairDigit_comparison b a hb ha;
        exact this.mp ( lt_of_le_of_ne h h_eq );
      have h_sum_gt : ∑ x ∈ Finset.range 127 with pairDigit b x < pairDigit a x, 2 ^ x ≤ ∑ x ∈ Finset.range k, 2 ^ x := by
        refine Finset.sum_le_sum_of_subset ?_;
        grind;
      refine le_trans h_sum_gt ?_;
      refine' le_trans _ ( Finset.single_le_sum ( fun x _ => Nat.zero_le ( 2 ^ x ) ) ( Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr hk₁, hk₂.1 ⟩ ) ) ; norm_num [ Nat.geomSum_eq ];
  · by_contra h_contra;
    obtain ⟨ k, hk₁, hk₂, hk₃ ⟩ := pairDigit_comparison a b ( by linarith ) ( by linarith ) |>.1 ( lt_of_not_ge h_contra );
    -- Since $k$ is the largest index where $pairDigit a k > pairDigit b k$, we have $A_sum \geq 2^k$ and $B_sum \leq \sum_{j=0}^{k-1} 2^j = 2^k - 1$.
    have hA_sum : ∑ x ∈ Finset.range 127 with pairDigit b x < pairDigit a x, 2 ^ x ≥ 2 ^ k := by
      exact Finset.single_le_sum ( fun x _ => Nat.zero_le ( 2 ^ x ) ) ( Finset.mem_filter.mpr ⟨ Finset.mem_range.mpr hk₁, hk₂ ⟩ ) |> le_trans ( by norm_num ) |> le_trans <| le_rfl;
    have hB_sum : ∑ x ∈ Finset.range 127 with pairDigit a x < pairDigit b x, 2 ^ x ≤ ∑ x ∈ Finset.range k, 2 ^ x := by
