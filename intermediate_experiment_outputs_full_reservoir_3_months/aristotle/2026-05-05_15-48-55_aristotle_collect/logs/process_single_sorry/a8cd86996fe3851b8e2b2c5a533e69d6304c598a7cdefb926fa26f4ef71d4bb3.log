/-- KomlГіs's lemma for Hilbert spaces: every bounded sequence has a sequence of convex
combinations of tails that converges in norm.

**Correction**: Added `[CompleteSpace E]` to the original statement, which is needed
to ensure the Cauchy sequence produced by `komlos_convex` (via the parallelogram law identity)
converges within `E`. -/
lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace в„қ E] [CompleteSpace E]
    {f : в„• вҶ’ E} (h_bdd : вҲғ M : в„қ, вҲҖ n, вҖ–f nвҖ– вүӨ M) :
    вҲғ (g : в„• вҶ’ E) (x : E), (вҲҖ n, g n вҲҲ convexHull в„қ (Set.range fun m вҶҰ f (n + m))) вҲ§
    Tendsto g atTop (рқ“қ x) := by
  obtain вҹЁM, hMвҹ© := h_bdd
  have hM0 : 0 вүӨ M := le_trans (norm_nonneg (f 0)) (hM 0)
  have hM' : вҲғ M' : в„қ, вҲҖ n, (fun x : E => вҖ–xвҖ– ^ 2) (f n) вүӨ M' :=
    вҹЁM ^ 2, fun n => by
      simp only
      exact pow_le_pow_leftвӮҖ (norm_nonneg _) (hM n) 2вҹ©
  obtain вҹЁg, hg_mem, hg_komlosвҹ© := komlos_convex (fun x => sq_nonneg вҖ–xвҖ–) hM'
  have hg_bdd : вҲҖ n, вҖ–g nвҖ– вүӨ M :=
    fun n => norm_convexHull_le (fun x hx => by
      obtain вҹЁm, rflвҹ© := hx; exact hM (n + m)) hM0 (hg_mem n)
  have hg_cauchy : CauchySeq g := komlos_cauchy hg_komlos
  obtain вҹЁx, hxвҹ© := cauchySeq_tendsto_of_complete hg_cauchy
  exact вҹЁg, x, fun n => convexHull_nnreal_subset_real _ (hg_mem n), hxвҹ©
