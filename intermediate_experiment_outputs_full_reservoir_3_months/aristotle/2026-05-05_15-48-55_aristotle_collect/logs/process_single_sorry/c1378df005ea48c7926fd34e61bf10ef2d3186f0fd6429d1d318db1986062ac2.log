variable
  {X} [NormedAddCommGroup X] [AdjointSpace 𝕜 X]
  {Y} [NormedAddCommGroup Y] [AdjointSpace 𝕜 Y]
  {ι : Type*} [Fintype ι]
  {E : ι → Type*} [∀ i, NormedAddCommGroup (E i)] [∀ i, AdjointSpace 𝕜 (E i)]

instance : AdjointSpace 𝕜 𝕜 where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp [norm_sq_eq_def]
  conj_symm := by simp[mul_comm]
  add_left := by simp[add_mul]
  smul_left := by simp[mul_assoc]

instance : Inner 𝕜 Unit where
  inner _ _ := 0

instance : AdjointSpace 𝕜 Unit where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp[Inner.inner]
  conj_symm := by simp[Inner.inner]
  add_left := by simp[Inner.inner]
  smul_left := by simp[Inner.inner]

instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    apply Exists.intro (cx*cx + cy*cy) -- todo: fix this constant
    apply Exists.intro (dx*dx + dy*dy) -- todo: fix this constant
    constructor
    · positivity
    constructor
    · positivity
    · intro (x,y)
      sorry
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
  smul_left := by simp[inner_smul_left,mul_add]

open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    have hbounds : ∀ i, ∃ c d : ℝ, c > 0 ∧ d > 0 ∧
        ∀ x : E i, (c • ‖x‖^2 ≤ re (@inner 𝕜 (E i) _ x x)) ∧
          (re (@inner 𝕜 (E i) _ x x) ≤ d • ‖x‖^2) :=
      fun i => inner_top_equiv_norm (𝕜 := 𝕜) (E := E i)
    choose c d hcd using hbounds
    by_cases h : Nonempty ι
    · refine' ⟨Finset.univ.inf' Finset.univ_nonempty c,
        Finset.sum Finset.univ d, _, _, _⟩ <;>
        simp_all +decide [Finset.inf'_le]
      · exact Finset.sum_pos (fun i _ => hcd i |>.2.1) Finset.univ_nonempty
      · refine' fun x => ⟨_, _⟩
        · obtain ⟨j, hj⟩ : ∃ j, ‖x j‖ = ‖x‖ := by
            have h_sup : ∃ j, ∀ i, ‖x i‖ ≤ ‖x j‖ := by
              simpa using Finset.exists_max_image Finset.univ
                (fun i => ‖x i‖) ⟨h.some, Finset.mem_univ _⟩
            obtain ⟨j, hj⟩ := h_sup
            use j
            refine' le_antisymm _ _
            · exact norm_le_pi_norm x j
            · exact (pi_norm_le_iff_of_nonempty x).mpr hj
          refine' le_trans _ (Finset.single_le_sum (fun i _ => _) (Finset.mem_univ j))
          · exact le_trans (mul_le_mul_of_nonneg_right (Finset.inf'_le _ (Finset.mem_univ j))
              (sq_nonneg _)) (by simpa [hj] using hcd j |>.2.2 (x j) |>.1)
          · exact le_trans (mul_nonneg (le_of_lt (hcd i |>.1)) (sq_nonneg _))
              (hcd i |>.2.2 _ |>.1)
        · rw [Finset.sum_mul _ _ _]
          exact Finset.sum_le_sum fun i _ =>
            le_trans (hcd i |>.2.2 _ |>.2)
              (mul_le_mul_of_nonneg_left
                (pow_le_pow_left₀ (norm_nonneg _) (norm_le_pi_norm x i) 2)
                (le_of_lt (hcd i |>.2.1)))
    · refine' ⟨1, 1, zero_lt_one, zero_lt_one, _⟩
      simp_all +decide [Finset.sum_empty]
      exact fun x => Subsingleton.elim _ _
  conj_symm := by simp
  add_left := by simp[inner_add_left,Finset.sum_add_distrib]
  smul_left := by simp[inner_smul_left,Finset.mul_sum]


theorem inner_prod_split (x y : X×Y) : ⟪x,y⟫_𝕜 = ⟪x.1,y.1⟫_𝕜 + ⟪x.2,y.2⟫_𝕜 := by rfl

theorem inner_forall_split (f g : (i : ι) → E i) :
    ⟪f,g⟫_𝕜 = ∑ i, ⟪f i, g i⟫_𝕜 := by rfl

