import Mathlib


open scoped EuclideanGeometry
open Affine Module

namespace IMO2021P3

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

private lemma eq_left_of_wbtw_wbtw_eq {A B C E F : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hE : Wbtw ℝ A E C) (hF : Wbtw ℝ A F B) (hEF : E = F) :
    E = A := by
  contrapose! hABC with hABC
  simp_all +decide [affineIndependent_iff_not_collinear, collinear_pair]
  rw [collinear_iff_exists_forall_eq_smul_vadd]
  use A, F -ᵥ A
  rintro p (rfl | rfl | rfl) <;> simp_all +decide [Wbtw]
  · obtain ⟨r, hr⟩ := hE
    by_cases hr' : r = 0 <;> simp_all +decide [AffineMap.lineMap_apply]
    refine' ⟨1 / r, _⟩; simp +decide [← hr.2, hr', smul_smul]
  · obtain ⟨r, hr⟩ := hF
    use 1 / r
    by_cases hr' : r = 0 <;> simp_all +decide [AffineMap.lineMap_apply]
    simp +decide [← hr.2, hr']
  · exact ⟨0, by simp +decide⟩

private lemma ne_of_mem_interior_left {A B C D : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hD : D ∈ (⟨_, hABC⟩ : Triangle ℝ P).interior) :
    D ≠ A := by
  intro hD'
  obtain ⟨weights, hweights⟩ := hD
  rw [Finset.affineCombination_eq_weightedVSubOfPoint_vadd_of_sum_eq_one] at hweights <;>
    simp_all +decide [Fin.sum_univ_three]
  swap; exact A
  have h_lin_ind : LinearIndependent ℝ ![B -ᵥ A, C -ᵥ A] := by
    rw [affineIndependent_iff_linearIndependent_vsub] at hABC; swap; exact 0
    convert hABC.comp _ _; rotate_left
    use fun i => ⟨if i = 0 then 1 else 2, by fin_cases i <;> simp +decide⟩
    · simp +decide [Function.Injective]
    · ext i; fin_cases i <;> rfl
  have := Fintype.linearIndependent_iff.mp h_lin_ind
  specialize this (fun i => if i = 0 then weights 1 else weights 2)
  simp_all +decide [Fin.sum_univ_succ]
  exact absurd (this (by simpa [add_eq_zero_iff_eq_neg] using congr_arg (fun x => x -ᵥ A) hweights.2.2)) (by intro h; linarith [hweights.2.1 1, hweights.2.1 2])

private lemma angle_ne_zero_of_interior {A B C D : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hD : D ∈ (⟨_, hABC⟩ : Triangle ℝ P).interior) :
    ∠ B C D ≠ 0 := by
  simp +decide [EuclideanGeometry.angle]
  rw [InnerProductGeometry.angle_eq_zero_iff]
  obtain ⟨w, hw⟩ : ∃ w : Fin 3 → ℝ, (∀ i, 0 < w i) ∧ (∑ i, w i = 1) ∧
      (D -ᵥ C) = w 0 • (A -ᵥ C) + w 1 • (B -ᵥ C) := by
    rcases hD with ⟨w, hw₁, hw₂⟩
    refine' ⟨w, fun i => hw₂.1 i |>.1, by simpa [Fin.sum_univ_three] using hw₁, _⟩
    simp +decide [← hw₂.2, Fin.sum_univ_three]
    rw [Finset.affineCombination_eq_weightedVSubOfPoint_vadd_of_sum_eq_one] <;>
      simp_all +decide [Fin.sum_univ_three]
    swap; exacts [C, by simp +decide [add_assoc, hw₁]]
  rintro ⟨hBC, r, hr, hr'⟩
  have h_lin_indep : LinearIndependent ℝ ![A -ᵥ C, B -ᵥ C] := by
    rw [affineIndependent_iff_linearIndependent_vsub] at hABC; swap; exact 2
    convert hABC.comp _ _; rotate_left
    use fun i => if i = 0 then ⟨0, by decide⟩ else ⟨1, by decide⟩
    · simp +decide [Function.Injective]
    · ext i; fin_cases i <;> rfl
  rw [Fintype.linearIndependent_iff] at h_lin_indep
  specialize h_lin_indep (fun i => if i = 0 then w 0 else w 1 - r)
  simp_all +decide [Fin.sum_univ_succ]
  exact absurd (h_lin_indep (by rw [sub_smul, add_sub, hw.2.2.symm, sub_self]))
    (by intro h; linarith [hw.1 0, hw.1 1])

private lemma E_ne_F {A B C D E F : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hD : D ∈ (⟨_, hABC⟩ : Triangle ℝ P).interior)
    (hE : Wbtw ℝ A E C) (hADE_BCD : ∠ A D E = ∠ B C D)
    (hF : Wbtw ℝ A F B) (hFDA_DBC : ∠ F D A = ∠ D B C) :
    E ≠ F := by
  intro hEF
  have hEA : E = A := eq_left_of_wbtw_wbtw_eq hABC hE hF hEF
  have hDA : D ≠ A := ne_of_mem_interior_left hABC hD
  rw [hEA] at hADE_BCD
  have : ∠ A D A = 0 := EuclideanGeometry.angle_self_of_ne hDA.symm
  rw [this] at hADE_BCD
  exact angle_ne_zero_of_interior hABC hD hADE_BCD.symm

private lemma eq_of_collinear_equidist {O A C X : P}
    (hAC : A ≠ C) (hX : X ∈ line[ℝ, A, C])
    (hOA_OC : dist O A = dist O C)
    (hOX_OA : dist O X = dist O A) :
    X = A ∨ X = C := by
  obtain ⟨t, ht⟩ : ∃ t : ℝ, X = t • (C -ᵥ A) +ᵥ A := by
    rw [affineSpan] at hX
    simp_all +decide [spanPoints]
    rcases hX with (⟨v, hv, rfl⟩ | ⟨v, hv, rfl⟩) <;>
      rw [vectorSpan_pair] at hv <;> simp_all +decide [Submodule.mem_span_singleton]
    · rcases hv with ⟨t, rfl⟩; exact ⟨-t, by simp +decide [neg_smul, ← smul_neg]⟩
    · rcases hv with ⟨t, rfl⟩; use 1 - t; simp +decide [sub_smul, smul_sub]; abel_nf
      simp +decide [← add_vadd, ← sub_eq_add_neg, ← smul_neg, neg_sub]
      simp +decide [add_comm, add_left_comm, add_assoc, vadd_vadd]
      simp +decide [add_vadd, vadd_vsub]
  simp_all +decide [dist_eq_norm_vsub, vsub_vadd_eq_vsub_sub, sub_eq_zero]
  have h_eq : t * (t - 1) * ‖(C -ᵥ A)‖ ^ 2 = 0 := by
    have h_eq : ‖O -ᵥ A - t • (C -ᵥ A)‖ ^ 2 = ‖O -ᵥ A‖ ^ 2 := by rw [hOX_OA, hOA_OC]
    have h_eq : ‖(O -ᵥ A) - t • (C -ᵥ A)‖ ^ 2 =
        ‖O -ᵥ A‖ ^ 2 + t ^ 2 * ‖C -ᵥ A‖ ^ 2 - 2 * t * inner ℝ (O -ᵥ A) (C -ᵥ A) := by
      rw [@norm_sub_sq ℝ]; ring; simp +decide [norm_smul, inner_smul_right]; ring
      norm_num [mul_comm]
    have h_eq : ‖O -ᵥ C‖ ^ 2 =
        ‖O -ᵥ A‖ ^ 2 + ‖C -ᵥ A‖ ^ 2 - 2 * inner ℝ (O -ᵥ A) (C -ᵥ A) := by
      rw [show O -ᵥ C = (O -ᵥ A) - (C -ᵥ A) by rw [vsub_sub_vsub_cancel_right],
        norm_sub_sq_real]; ring
    grind +ring
  simp_all +decide [sub_eq_iff_eq_add]
  aesop

private lemma O1_ne_O2 {A B C D E F X O₁ O₂ : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hAcute : (⟨_, hABC⟩ : Triangle ℝ P).AcuteAngled)
    (hACltAB : dist A C < dist A B)
    (hD : D ∈ (⟨_, hABC⟩ : Triangle ℝ P).interior)
    (hDAB_CAD : ∠ D A B = ∠ C A D) (hE : Wbtw ℝ A E C) (hADE_BCD : ∠ A D E = ∠ B C D)
    (hF : Wbtw ℝ A F B) (hFDA_DBC : ∠ F D A = ∠ D B C)
    (hX : X ∈ line[ℝ, A, C]) (hCX_BX : dist C X = dist B X)
    (hADC : AffineIndependent ℝ ![A, D, C])
    (hO₁ : O₁ = (⟨_, hADC⟩ : Triangle ℝ P).circumcenter)
    (hEXD : AffineIndependent ℝ ![E, X, D])
    (hO₂ : O₂ = (⟨_, hEXD⟩ : Triangle ℝ P).circumcenter) :
    O₁ ≠ O₂ := by
  intro h_eq
  have h_eq_dist : dist O₁ A = dist O₁ C ∧ dist O₁ X = dist O₁ A ∧
      dist O₁ C = dist O₁ X := by
    have h_eq_dist : dist O₁ A = dist O₁ D ∧ dist O₁ D = dist O₁ C := by
      have := Simplex.dist_circumcenter_eq_circumradius
        (⟨_, hADC⟩ : Simplex ℝ P 2) 0
      have := Simplex.dist_circumcenter_eq_circumradius
        (⟨_, hADC⟩ : Simplex ℝ P 2) 1
      have := Simplex.dist_circumcenter_eq_circumradius
        (⟨_, hADC⟩ : Simplex ℝ P 2) 2
      simp_all +decide [dist_comm]
    have h_eq_dist_X : dist O₂ E = dist O₂ X ∧ dist O₂ X = dist O₂ D := by
      rw [hO₂]
      have := Simplex.dist_circumcenter_eq_circumradius ⟨_, hEXD⟩ 0
      have := Simplex.dist_circumcenter_eq_circumradius ⟨_, hEXD⟩ 1
      have := Simplex.dist_circumcenter_eq_circumradius ⟨_, hEXD⟩ 2
      simp_all +decide [dist_comm]
    simp_all +decide [dist_comm]
  have h_X_eq_A_or_C : X = A ∨ X = C := by
    apply eq_of_collinear_equidist
    any_goals tauto
    rintro rfl; simp_all +decide [dist_comm]
  rcases h_X_eq_A_or_C with (rfl | rfl) <;> simp_all +decide [dist_comm]

private lemma concurrent' {A B C D E F X O₁ O₂ : P}
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hAcute : (⟨_, hABC⟩ : Triangle ℝ P).AcuteAngled)
    (hACltAB : dist A C < dist A B)
    (hD : D ∈ (⟨_, hABC⟩ : Triangle ℝ P).interior)
    (hDAB_CAD : ∠ D A B = ∠ C A D) (hE : Wbtw ℝ A E C) (hADE_BCD : ∠ A D E = ∠ B C D)
    (hF : Wbtw ℝ A F B) (hFDA_DBC : ∠ F D A = ∠ D B C)
    (hX : X ∈ line[ℝ, A, C]) (hCX_BX : dist C X = dist B X)
    (hADC : AffineIndependent ℝ ![A, D, C])
    (hO₁ : O₁ = (⟨_, hADC⟩ : Triangle ℝ P).circumcenter)
    (hEXD : AffineIndependent ℝ ![E, X, D])
    (hO₂ : O₂ = (⟨_, hEXD⟩ : Triangle ℝ P).circumcenter) :
    (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  sorry

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  exact ⟨
    E_ne_F affineIndependent_ABC D_mem_interior_ABC wbtw_A_E_C angle_ADE_eq_angle_BCD
      wbtw_A_F_B angle_FDA_eq_angle_DBC,
    O1_ne_O2 affineIndependent_ABC acuteAngled_ABC AC_lt_AB D_mem_interior_ABC
      angle_DAB_eq_angle_CAD wbtw_A_E_C angle_ADE_eq_angle_BCD wbtw_A_F_B angle_FDA_eq_angle_DBC
      X_mem_AC CX_eq_BX affineIndependent_ADC O₁_eq_circumcenter_ADC affineIndependent_EXD
      O₂_eq_circumcenter_EXD,
    concurrent' affineIndependent_ABC acuteAngled_ABC AC_lt_AB D_mem_interior_ABC
      angle_DAB_eq_angle_CAD wbtw_A_E_C angle_ADE_eq_angle_BCD wbtw_A_F_B angle_FDA_eq_angle_DBC
      X_mem_AC CX_eq_BX affineIndependent_ADC O₁_eq_circumcenter_ADC affineIndependent_EXD
      O₂_eq_circumcenter_EXD⟩

end IMO2021P3

