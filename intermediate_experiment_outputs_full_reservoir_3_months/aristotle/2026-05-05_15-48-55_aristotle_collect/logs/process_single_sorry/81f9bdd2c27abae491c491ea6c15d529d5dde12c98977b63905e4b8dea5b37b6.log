        · refine' MeasureTheory.Integrable.mono' _ _ _;
          refine' fun ω => 1;
          · norm_num;
          · exact Measurable.aestronglyMeasurable ( by measurability );
          · filter_upwards [ ] using fun ω => by rw [ Real.norm_of_nonneg ( by positivity ) ] ; exact hu_bdd _ _;
      · refine' MeasureTheory.Integrable.mono' _ _ _;
        refine' fun ω => 1;
        · norm_num;
        · exact Measurable.aestronglyMeasurable ( by measurability );
        · simp +zetaDelta at *;
          filter_upwards [ ] with ω using abs_le.mpr ⟨ by linarith [ hu_bdd ( ns k ) ω, hu_bdd ( ns ( k + 1 ) ) ω, inv_nonneg.mpr ( show 0 ≤ ( 1 + g ( ns k ) ω |> ENNReal.toReal ) by positivity ), inv_nonneg.mpr ( show 0 ≤ ( 1 + g ( ns ( k + 1 ) ) ω |> ENNReal.toReal ) by positivity ) ], by linarith [ hu_bdd ( ns k ) ω, hu_bdd ( ns ( k + 1 ) ) ω, inv_nonneg.mpr ( show 0 ≤ ( 1 + g ( ns k ) ω |> ENNReal.toReal ) by positivity ), inv_nonneg.mpr ( show 0 ≤ ( 1 + g ( ns ( k + 1 ) ) ω |> ENNReal.toReal ) by positivity ) ] ⟩;
