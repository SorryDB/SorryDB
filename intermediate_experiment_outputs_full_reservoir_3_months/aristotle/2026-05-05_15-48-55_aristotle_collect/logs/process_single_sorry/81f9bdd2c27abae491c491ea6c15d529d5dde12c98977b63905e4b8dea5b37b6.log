lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  -- Step 1: Define φ and apply komlos_convex
  set φ : (Ω → ℝ≥0∞) → ℝ := fun f => (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nn : (0 : (Ω → ℝ≥0∞) → ℝ) ≤ φ := fun _ => ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := by
    refine ⟨1, fun n => ?_⟩
    simp only [φ]
    have h1 : ∫⁻ ω, (1 + X n ω)⁻¹ ∂P ≤ 1 := by
      calc ∫⁻ ω, (1 + X n ω)⁻¹ ∂P ≤ ∫⁻ _, 1 ∂P :=
            lintegral_mono fun ω => ENNReal.inv_le_one.mpr (le_add_right le_rfl)
        _ = 1 := by simp [measure_univ]
    exact_mod_cast ENNReal.toReal_mono (by norm_num) h1
  obtain ⟨g, hg_mem, hg_def⟩ := komlos_convex hφ_nn hφ_bdd
  -- Step 2: g n are measurable
  have hg_meas : ∀ n, Measurable (g n) := by
    intro n
    exact Measurable.convexHull_nnreal
      (fun f hf => by obtain ⟨m, rfl⟩ := hf; exact hX (n + m)) (hg_mem n)
  -- Step 3: From the defect, extract a fast Cauchy subsequence ns
  -- such that ∫ (u(ns k) - u(ns(k+1)))² < 1/(k+1)⁴
  -- and then ∫ |u(ns k) - u(ns(k+1))| ≤ 1/(k+1)² (Cauchy-Schwarz)
  -- and ∑ ∫ |u(ns k) - u(ns(k+1))| < ∞
  -- leading to a.e. convergence.
  -- Set $u n ω = (1+g n ω)⁻¹.toReal$.
  set u : ℕ → Ω → ℝ := fun n ω => (1 + g n ω)⁻¹.toReal;
  have hu_meas : ∀ n, Measurable (u n) := by
    exact fun n => Measurable.ennreal_toReal ( Measurable.inv ( measurable_const.add ( hg_meas n ) ) );
  have hu_bdd : ∀ n ω, 0 ≤ u n ω ∧ u n ω ≤ 1 := by
    exact fun n ω => ⟨ ENNReal.toReal_nonneg, ENNReal.toReal_le_of_le_ofReal zero_le_one <| by simp ⟩;
  -- For each ε > 0, there exists N such that for all n, m ≥ N, ∫ (u n - u m)² dP < ε.
  have h_integral_bound : ∀ ε > 0, ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m → ∫ ω, ((u n ω) - (u m ω)) ^ 2 ∂P < ε := by
    intro ε hε_pos
    obtain ⟨δ, hδ_pos, hδ⟩ : ∃ δ > 0, ∀ n m : ℕ, 2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m)) < δ → ∫ ω, ((u n ω) - (u m ω)) ^ 2 ∂P < ε := by
      refine' ⟨ ε / 4, div_pos hε_pos zero_lt_four, fun n m hnm => _ ⟩;
      refine' lt_of_le_of_lt ( komlos_integral_sq_le_defect ( hg_meas n ) ( hg_meas m ) ) _;
      linarith!;
    exact Exists.elim ( hg_def δ hδ_pos ) fun N hN => ⟨ N, fun n m hn hm => hδ n m ( hN n m hn hm ) ⟩;
  -- Extract a subsequence $(ns k)$ such that $\int (u(ns k) - u(ns(k+1)))^2 dP < 1/(k+1)^4$.
  obtain ⟨ns, hns⟩ : ∃ ns : ℕ → ℕ, StrictMono ns ∧ ∀ k : ℕ, ∫ ω, ((u (ns k) ω) - (u (ns (k + 1)) ω)) ^ 2 ∂P < 1 / (k + 1) ^ 4 := by
    have h_subseq : ∀ k : ℕ, ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m → ∫ ω, ((u n ω) - (u m ω)) ^ 2 ∂P < 1 / (k + 1) ^ 4 := by
      exact fun k => h_integral_bound _ <| by positivity;
    choose N hN using h_subseq;
    refine' ⟨ fun k => Nat.recOn k ( N 0 ) fun k ih => Max.max ( N ( k + 1 ) ) ( ih + 1 ), strictMono_nat_of_lt_succ fun k => _, fun k => hN k _ _ _ _ ⟩ <;> simp +decide [ Nat.lt_succ_iff ];
    · induction k <;> aesop;
    · exact Or.inr ( Nat.recOn k ( by norm_num ) fun k ih => by norm_num; linarith [ Nat.le_max_left ( N ( k + 1 ) ) ( Nat.rec ( N 0 ) ( fun k ih => max ( N ( k + 1 ) ) ( ih + 1 ) ) k + 1 ), Nat.le_max_right ( N ( k + 1 ) ) ( Nat.rec ( N 0 ) ( fun k ih => max ( N ( k + 1 ) ) ( ih + 1 ) ) k + 1 ) ] );
  -- By the properties of the integral, we have $\int |u(ns k) - u(ns(k+1))| dP \leq \sqrt{\int (u(ns k) - u(ns(k+1)))^2 dP}$.
  have h_integral_abs : ∀ k : ℕ, ∫ ω, |u (ns k) ω - u (ns (k + 1)) ω| ∂P ≤ Real.sqrt (∫ ω, ((u (ns k) ω) - (u (ns (k + 1)) ω)) ^ 2 ∂P) := by
    intro k
    have h_integral_abs : (∫ ω, |u (ns k) ω - u (ns (k + 1)) ω| ∂P) ^ 2 ≤ ∫ ω, ((u (ns k) ω) - (u (ns (k + 1)) ω)) ^ 2 ∂P := by
      have h_cauchy_schwarz : ∀ {f g : Ω → ℝ}, MeasureTheory.Integrable (fun ω => f ω * g ω) P → MeasureTheory.Integrable (fun ω => f ω ^ 2) P → MeasureTheory.Integrable (fun ω => g ω ^ 2) P → (∫ ω, f ω * g ω ∂P) ^ 2 ≤ (∫ ω, f ω ^ 2 ∂P) * (∫ ω, g ω ^ 2 ∂P) := by
