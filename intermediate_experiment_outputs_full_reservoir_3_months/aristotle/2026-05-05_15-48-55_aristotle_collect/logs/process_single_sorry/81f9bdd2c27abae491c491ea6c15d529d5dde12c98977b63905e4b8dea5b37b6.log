          · simp_all +decide [ ← mul_assoc, MeasureTheory.integral_mul_const, MeasureTheory.integral_const_mul ];
            nlinarith [ mul_div_cancel₀ ( ∫ ω, f ω * g ω ∂P ) h, show 0 ≤ ∫ ω, f ω ^ 2 ∂P from MeasureTheory.integral_nonneg fun _ => sq_nonneg _, show 0 ≤ ∫ ω, g ω ^ 2 ∂P from MeasureTheory.integral_nonneg fun _ => sq_nonneg _ ];
