import Mathlib

/-!
# Komlos lemmas

-/

variable {E Ω : Type*} {mΩ : MeasurableSpace Ω}

open Filter MeasureTheory
open scoped Topology NNReal ENNReal

lemma komlos_convex [AddCommMonoid E] [Module ℝ≥0 E]
  {f : ℕ → E} {φ : E → ℝ} (hφ_nonneg : 0 ≤ φ)
  (hφ_bdd : ∃ M : ℝ, ∀ n, φ (f n) ≤ M) :
  ∃ g : ℕ → E, (∀ n, g n ∈ convexHull ℝ≥0 (Set.range fun m ↦ f (n + m))) ∧
    ∀ δ > 0, ∃ N, ∀ n m, N ≤ n → N ≤ m →
      2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m)) < δ := by
  obtain ⟨M, hM⟩ := hφ_bdd
  let r : ℕ → ℝ := fun n ↦ sInf (Set.image φ (convexHull ℝ≥0 (Set.range (fun m ↦ f (n + m)))))
  have hr_nondec n : r n ≤ r (n + 1) := by
    apply_rules [csInf_le_csInf]
    · exact ⟨0, Set.forall_mem_image.2 fun x hx ↦ hφ_nonneg x⟩
    · exact ⟨_, ⟨ _, subset_convexHull ℝ≥0 _ ⟨0, rfl⟩, rfl⟩⟩
    · refine Set.image_mono <| convexHull_min ?_ (convex_convexHull ℝ≥0 _)
      rintro _ ⟨m, rfl⟩; exact subset_convexHull ℝ≥0 _ ⟨m + 1, by simp [add_comm, add_left_comm]⟩
  obtain ⟨A, hA⟩ : ∃ A, Filter.Tendsto r Filter.atTop (nhds A) := by
    refine ⟨_, tendsto_atTop_ciSup (monotone_nat_of_le_succ hr_nondec) ?_⟩
    exact ⟨M, Set.forall_mem_range.mpr fun n ↦ csInf_le
      ⟨0, Set.forall_mem_image.mpr fun x hx ↦ hφ_nonneg x⟩
        (Set.mem_image_of_mem _ <| subset_convexHull ℝ≥0 _
          <| Set.mem_range_self 0) |> le_trans <| by simpa using hM n⟩
  obtain ⟨g, hg⟩ :
      ∃ g : ℕ → E, (∀ n, g n ∈ convexHull ℝ≥0 (Set.range (fun m ↦ f (n + m))))
          ∧ (∀ n, φ (g n) ≤ A + 1 / (n + 1)) := by
    have h_exists_g :
        ∀ n, ∃ g ∈ convexHull ℝ≥0 (Set.range (fun m ↦ f (n + m))), φ g ≤ A + 1 / (n + 1) := by
      intro n
      have h_exists_g :
          ∃ g ∈ convexHull ℝ≥0 (Set.range (fun m ↦ f (n + m))), φ g < A + 1 / (n + 1) := by
        have h_exists_g : r n < A + 1 / (n + 1) := by
          exact lt_add_of_le_of_pos (le_of_tendsto_of_tendsto tendsto_const_nhds hA
            (Filter.eventually_atTop.2 ⟨n, fun m hm ↦ by
              induction hm <;> [tauto; linarith [hr_nondec ‹_›]]⟩)) (by positivity)
        contrapose! h_exists_g
        exact le_csInf ⟨ _, Set.mem_image_of_mem _ <| subset_convexHull ℝ≥0 _
          <| Set.mem_range_self 0 ⟩ fun x hx ↦ by
            rcases hx with ⟨ g, hg, rfl ⟩; exact h_exists_g g hg
      exact ⟨h_exists_g.choose, h_exists_g.choose_spec.1, le_of_lt h_exists_g.choose_spec.2⟩
    exact ⟨fun n ↦ Classical.choose (h_exists_g n),
      fun n ↦ Classical.choose_spec (h_exists_g n) |>.1,
        fun n ↦ Classical.choose_spec (h_exists_g n) |>.2⟩
  refine ⟨g, hg.1, fun δ δpos ↦ ?_⟩
  obtain ⟨ε, εpos, hε⟩ := exists_between (div_pos δpos zero_lt_four)
  obtain ⟨N, hN⟩ : ∃ N, r N ≥ A - ε ∧ 1 / (N + 1) ≤ ε := by
    rcases Metric.tendsto_atTop.mp hA ε εpos with ⟨N, hN⟩
    exact ⟨N + ⌈ε⁻¹⌉₊, by linarith [abs_lt.mp (hN (N + ⌈ε⁻¹⌉₊) (by grind))], by
      simpa using inv_le_of_inv_le₀ εpos (by linarith [Nat.le_ceil (ε⁻¹)])⟩
  refine ⟨N, fun n m hn hm ↦ ?_⟩
  have h_convex : φ ((1 / 2 : ℝ≥0) • (g n + g m)) ≥ A - ε := by
    have h_convex :
        (1 / 2 : ℝ≥0) • (g n + g m) ∈ convexHull ℝ≥0 (Set.range (fun m ↦ f (N + m))) := by
      simp only [one_div, gt_iff_lt, ge_iff_le, tsub_le_iff_right, smul_add] at *
      refine convex_convexHull ℝ≥0 _ ?_ ?_ ?_ ?_ ?_ <;> norm_num
      · refine convexHull_mono (Set.range_subset_iff.2 fun m ↦ ?_) (hg.1 n)
        exact ⟨m + (n - N), by grind⟩
      · refine convexHull_mono ?_ (hg.1 m)
        exact Set.range_subset_iff.2 fun k ↦ ⟨k + (m - N), by
          simp [show N + (k + (m - N)) = m + k by grind]⟩
    refine le_trans hN.1 ?_
    exact csInf_le ⟨0, Set.forall_mem_image.2 fun x hx ↦ hφ_nonneg _⟩ ⟨_, h_convex, rfl⟩
  norm_num at *
  linarith [hg.2 n, hg.2 m, inv_anti₀
    (by positivity) (by norm_cast; grind : (n : ℝ) + 1 ≥ N + 1), inv_anti₀
      (by positivity) (by norm_cast; grind : (m : ℝ) + 1 ≥ N + 1)]

lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  sorry

/-! ### Helper lemmas for komlos_ennreal -/

section KomlosHelpers

variable {α : Type*} [MeasurableSpace α]

omit [MeasurableSpace α] in
lemma convexHull_nnreal_sub_ennreal
    {S : Set (α → ℝ≥0∞)} {f : α → ℝ≥0∞}
    (hf : f ∈ convexHull NNReal S) : f ∈ convexHull ENNReal S := by
  apply convexHull_min (subset_convexHull ENNReal S) _ hf
  intro x hx y hy a b ha hb hab
  have h1 : (a : ENNReal) + (b : ENNReal) = 1 := by exact_mod_cast hab
  have := (convex_convexHull ENNReal S) hx hy
    (by exact_mod_cast ha : (0 : ENNReal) ≤ a) (by exact_mod_cast hb : (0 : ENNReal) ≤ b) h1
  convert this using 1

lemma convex_measurable_ennreal :
    Convex NNReal {f : α → ℝ≥0∞ | Measurable f} := by
  intro f hf g hg a b _ _ _
  exact Measurable.add (Measurable.const_mul hf _) (Measurable.const_mul hg _)

lemma Measurable.convexHull_nnreal {S : Set (α → ℝ≥0∞)}
    (hS : ∀ f ∈ S, Measurable f) {f : α → ℝ≥0∞}
    (hf : f ∈ convexHull NNReal S) : Measurable f :=
  convexHull_min hS convex_measurable_ennreal hf

/-
PROVIDED SOLUTION
Case split on a = ⊤ and b = ⊤ using rcases eq_or_ne a ⊤. Four cases. For both-top: simp. For one-top: use ENNReal.smul_def, norm_num, and the fact that x² ≤ 2x for x ∈ [0,1]. For both-finite: set a' = a.toReal, b' = b.toReal, convert using ENNReal.toReal_add/toReal_smul, then field_simp and nlinarith [sq_nonneg (a' - b'), mul_nonneg ha' hb'].
-/
lemma ennreal_inv_sq_le_defect (a b : ℝ≥0∞) :
    ((1 + a)⁻¹.toReal - (1 + b)⁻¹.toReal) ^ 2 ≤
      4 * ((2 : ℝ)⁻¹ * (1 + a)⁻¹.toReal + (2 : ℝ)⁻¹ * (1 + b)⁻¹.toReal -
        (1 + (2 : ℝ≥0)⁻¹ • (a + b))⁻¹.toReal) := by
  rcases eq_or_ne a ⊤ with ha | ha <;> rcases eq_or_ne b ⊤ with hb | hb <;> simp_all +decide [ ENNReal.toReal ];
  · norm_num [ ENNReal.smul_def ];
  · norm_num [ ENNReal.toNNReal, ENNReal.smul_def ];
    rcases b with ( _ | _ | b ) <;> norm_num [ ENNReal.toReal ] at *;
    erw [ WithTop.untopD_coe, WithTop.untopD_top ] ; norm_num ; ring;
    rw [ inv_le_comm₀ ] <;> norm_num <;> nlinarith [ show ( 0 : ℝ ) ≤ { cauchy := Quot.mk ( ⇑CauSeq.equiv ) ‹_› } by positivity ];
  · erw [ ENNReal.toNNReal_add ] <;> norm_num [ ha ];
    erw [ ENNReal.smul_def ] ; norm_num ; ring_nf;
    rw [ inv_le_comm₀ ] <;> norm_num <;> nlinarith [ show ( 0 : ℝ ) ≤ a.toNNReal by positivity ];
  · -- Let's simplify the expression by setting $a' = a.toReal$ and $b' = b.toReal$.
    set a' := a.toReal
    set b' := b.toReal
    have ha' : 0 ≤ a' := by
      exact ENNReal.toReal_nonneg
    have hb' : 0 ≤ b' := by
      exact ENNReal.toReal_nonneg;
    -- Substitute $a'$ and $b'$ into the inequality.
    have h_sub : ((1 + a')⁻¹ - (1 + b')⁻¹) ^ 2 ≤ 4 * ((1 + a')⁻¹ / 2 + (1 + b')⁻¹ / 2 - (1 + (a' + b') / 2)⁻¹) := by
      field_simp;
      nlinarith [ sq_nonneg ( a' - b' ), mul_nonneg ha' hb' ];
    convert h_sub using 1 <;> norm_num [ ENNReal.toNNReal_add, ha, hb ] ; ring;
    · norm_cast;
    · ring;
      rw [ ENNReal.toNNReal_add, ENNReal.toNNReal_add ] <;> norm_num [ ha, hb ] ; ring;
      · aesop;
      · exact ENNReal.mul_ne_top ( by norm_num ) ha;
      · exact ENNReal.mul_ne_top ( by norm_num ) ha;
      · exact ENNReal.mul_ne_top ( by norm_num ) hb

/-
PROVIDED SOLUTION
Convert (1+x n)⁻¹.toReal → l to (1+x n)⁻¹ → ENNReal.ofReal l using ENNReal.tendsto_ofReal and ENNReal.ofReal_toReal (since (1+x n)⁻¹ ≠ ⊤). Then invert using tendsto_inv_iff to get (1+x n) → (ENNReal.ofReal l)⁻¹. Then subtract 1 using ENNReal.Tendsto.sub.
-/
lemma ENNReal.tendsto_of_inv_one_add_tendsto {x : ℕ → ℝ≥0∞} {l : ℝ}
    (hl : 0 ≤ l) (hl1 : l ≤ 1)
    (h : Tendsto (fun n => (1 + x n)⁻¹.toReal) atTop (nhds l)) :
    Tendsto x atTop (nhds ((ENNReal.ofReal l)⁻¹ - 1)) := by
  by_cases hl' : l = 0 <;> simp_all +decide [ ENNReal.tendsto_ofReal ];
  · rw [ ENNReal.tendsto_nhds_top_iff_nnreal ];
    intro a;
    filter_upwards [ h.eventually ( gt_mem_nhds <| show 0 < ( 1 + a : ℝ ) ⁻¹ by positivity ) ] with n hn;
    contrapose! hn;
    gcongr;
    · exact ENNReal.toReal_pos ( by norm_num ) ( by aesop );
    · rw [ ENNReal.toReal_add ] <;> norm_num;
      · exact le_trans ( ENNReal.toReal_mono ( by aesop ) hn ) ( by aesop );
      · exact ne_of_lt ( lt_of_le_of_lt hn ( ENNReal.coe_lt_top ) );
  · convert ENNReal.Tendsto.sub ( ENNReal.tendsto_inv_iff.mpr ?_ ) tendsto_const_nhds using 1;
    any_goals exact ENNReal.tendsto_ofReal h;
    swap;
    exact 1;
    by_cases h : ENNReal.ofReal l = 0 <;> simp_all +decide [ ENNReal.inv_eq_zero ];
    · exact False.elim <| hl' <| le_antisymm h hl;
    · congr! 2;
      cases h : x ‹_› <;> simp_all +decide [ ENNReal.toReal_add ];
      rw [ ENNReal.ofReal_inv_of_pos ( by positivity ), ENNReal.ofReal_add ] <;> norm_num

/-
PROBLEM
The integral of the squared difference of (1+·)⁻¹.toReal is controlled by the defect.

PROVIDED SOLUTION
The proof uses ennreal_inv_sq_le_defect pointwise and then integrates.

Key steps:
1. The integrand (u₁ - u₂)² is nonneg and bounded by 1 (since u₁, u₂ ∈ [0,1]).
2. The pointwise bound: (u₁ ω - u₂ ω)² ≤ 4 * (½u₁ω + ½u₂ω - vω) where v ω = (1+(2:NNReal)⁻¹•(g₁ω + g₂ω))⁻¹.toReal.
3. Integrate both sides using MeasureTheory.integral_mono (all functions are integrable since bounded by constants on probability space).
4. The integral of the RHS equals 4 * (½∫u₁ + ½∫u₂ - ∫v) by linearity.
5. Show ∫ uᵢ = (∫⁻ (1+gᵢ)⁻¹ dP).toReal using integral_eq_lintegral_of_nonneg_ae and the fact that ENNReal.toReal ∘ (1+·)⁻¹ is non-negative and measurable.

The relationship between Bochner integral and lintegral: for non-negative measurable f, ∫ f dP = (∫⁻ f.toNNReal dP).toReal. Since (1+g ω)⁻¹.toReal ≥ 0, its toNNReal equals its ENNReal value after round-tripping.
-/
lemma komlos_integral_sq_le_defect {P : Measure α} [IsProbabilityMeasure P]
    {g₁ g₂ : α → ℝ≥0∞} (hg₁ : Measurable g₁) (hg₂ : Measurable g₂) :
    ∫ ω, ((1 + g₁ ω)⁻¹.toReal - (1 + g₂ ω)⁻¹.toReal) ^ 2 ∂P ≤
      4 * ((2 : ℝ)⁻¹ * (∫⁻ ω, (1 + g₁ ω)⁻¹ ∂P).toReal +
           (2 : ℝ)⁻¹ * (∫⁻ ω, (1 + g₂ ω)⁻¹ ∂P).toReal -
