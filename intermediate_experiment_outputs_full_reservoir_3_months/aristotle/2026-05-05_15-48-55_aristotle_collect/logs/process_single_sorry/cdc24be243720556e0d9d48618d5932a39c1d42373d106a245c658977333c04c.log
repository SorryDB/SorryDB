variable
  {X} [NormedAddCommGroup X] [AdjointSpace 𝕜 X]
  {Y} [NormedAddCommGroup Y] [AdjointSpace 𝕜 Y]
  {ι : Type*} [Fintype ι]
  {E : ι → Type*} [∀ i, NormedAddCommGroup (E i)] [∀ i, AdjointSpace 𝕜 (E i)]

instance : AdjointSpace 𝕜 𝕜 where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp [norm_sq_eq_def]
  conj_symm := by simp[mul_comm]
  add_left := by simp[add_mul]
  smul_left := by simp[mul_assoc]

instance : Inner 𝕜 Unit where
  inner _ _ := 0

instance : AdjointSpace 𝕜 Unit where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp[Inner.inner]
  conj_symm := by simp[Inner.inner]
  add_left := by simp[Inner.inner]
  smul_left := by simp[Inner.inner]

instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (min cx cy)
    apply Exists.intro (dx + dy)
    constructor
    · positivity
    constructor
    · positivity
    · intro (x,y)
      have hx1 := (_hx x).1
      have hx2 := (_hx x).2
      have hy1 := (_hy y).1
      have hy2 := (_hy y).2
      have h_norm_sq : ‖(x, y)‖ ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by
        simp only [Prod.norm_def]
        rcases le_total ‖x‖ ‖y‖ with h | h
        · simp [max_eq_right h, sq_nonneg]
        · simp [max_eq_left h, sq_nonneg]
      have h_fst : ‖x‖ ^ 2 ≤ ‖(x, y)‖ ^ 2 := by
        nlinarith [norm_fst_le (x, y), norm_nonneg x,
                   norm_nonneg (show X × Y from (x, y))]
      have h_snd : ‖y‖ ^ 2 ≤ ‖(x, y)‖ ^ 2 := by
        nlinarith [norm_snd_le (x, y), norm_nonneg y,
                   norm_nonneg (show X × Y from (x, y))]
      simp only [Inner.inner, map_add] at *
      have hmin_le_cx : min cx cy ≤ cx := min_le_left cx cy
      have hmin_le_cy : min cx cy ≤ cy := min_le_right cx cy
      have hmin_pos : 0 ≤ min cx cy := le_min hcx.le hcy.le
      have hmin_norm : min cx cy * ‖(x, y)‖ ^ 2 ≤ min cx cy * (‖x‖ ^ 2 + ‖y‖ ^ 2) :=
        mul_le_mul_of_nonneg_left h_norm_sq hmin_pos
      have hdx_fst : dx * ‖x‖ ^ 2 ≤ dx * ‖(x, y)‖ ^ 2 :=
        mul_le_mul_of_nonneg_left h_fst hdx.le
      have hdy_snd : dy * ‖y‖ ^ 2 ≤ dy * ‖(x, y)‖ ^ 2 :=
        mul_le_mul_of_nonneg_left h_snd hdy.le
      simp only [smul_eq_mul] at *
      constructor <;> nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
  smul_left := by simp[inner_smul_left,mul_add]

