import Mathlib

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

/- The original `solution` definition below is mathematically correct in ℝ, but incorrect
   in ENNReal due to truncating subtraction. For example at n=1:
     1 - (8/9)^1 - (5/9)^1 + (4/9)^1
   evaluates as ((1 - 8/9) - 5/9) + 4/9 = (1/9 - 5/9) + 4/9 = 0 + 4/9 = 4/9 in ENNReal,
   but the true probability is 0 (no single digit 1–9 has product divisible by 10).

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n
-/

/-- Corrected solution: rearranged to `1 + (4/9)^n - (8/9)^n - (5/9)^n` so that
    each intermediate subtraction in ENNReal is non-negative. -/
noncomputable def solution (n : ℕ) : ENNReal :=
  1 + (4 / 9) ^ n - (8 / 9) ^ n - (5 / 9) ^ n

set_option maxHeartbeats 800000 in
problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
    -- The set of good sequences is exactly those sequences that contain at least one digit 5 and at least one even digit.
    have h_good_seqs : good_seqs = {s : DigitSeq n | (∃ a, s a = 4) ∧ (∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7)} := by
      ext s;
      constructor <;> intro h <;> simp_all +decide [ good_seqs, is_good_seq ];
      · -- Since 10 divides the product, there must be at least one even digit and at least one digit equal to 5.
        have h_even : ∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7 := by
          contrapose! h; simp_all +decide ;
          -- If there are no even digits, then all digits are odd, and their product is also odd.
          have h_odd_prod : ∀ a, to_nat_digit (s a) % 2 = 1 := by
            intro a; specialize h a; unfold to_nat_digit; rcases h : s a with ( _ | _ | _ | _ | _ | _ | _ | _ | _ | _ | k ) <;> simp_all +arith +decide;
            · contradiction;
            · grind +splitImp;
          exact fun h => absurd ( Nat.dvd_trans ( by decide : 2 ∣ 10 ) h ) ( by rw [ Nat.dvd_iff_mod_eq_zero ] ; rw [ Finset.prod_nat_mod ] ; aesop )
        have h_five : ∃ a, s a = 4 := by
          have h_five : 5 ∣ ∏ a, to_nat_digit (s a) := by
            exact dvd_trans ( by decide ) h;
          contrapose! h_five; simp_all +decide [ Nat.Prime.dvd_iff_not_coprime ] ;
          refine' Nat.Coprime.prod_right fun a _ => _ ; simp_all +decide [ to_nat_digit ] ; have := Fin.is_lt ( s a ) ; interval_cases _ : ( s a : ℕ ) <;> simp_all +decide ;
          exact h_five a ( Fin.ext ‹_› )
        exact ⟨h_five, h_even⟩;
      · obtain ⟨ ⟨ a, ha ⟩, ⟨ b, hb ⟩ ⟩ := h;
        rw [ Finset.prod_eq_mul_prod_diff_singleton ( Finset.mem_univ a ) ];
        exact dvd_trans ( by decide ) ( mul_dvd_mul ( show 5 ∣ to_nat_digit ( s a ) from by simp +decide [ ha, to_nat_digit ] ) ( show 2 ∣ ∏ x ∈ Finset.univ \ { a }, to_nat_digit ( s x ) from dvd_trans ( by decide ) ( Finset.dvd_prod_of_mem _ ( Finset.mem_sdiff.mpr ⟨ Finset.mem_univ b, by aesop ⟩ ) |> dvd_trans ( show 2 ∣ to_nat_digit ( s b ) from by rcases hb with ( hb | hb | hb | hb ) <;> simp +decide [ hb, to_nat_digit ] ) ) ) );
    -- Let's simplify the expression using the fact that multiplication by a constant out of the sum can be taken outside.
    suffices h_simp : (∑ s : DigitSeq n, (if (∃ a, s a = 4) ∧ (∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7) then (1 : ℝ) else 0)) / 9^n = 1 + (4 / 9 : ℝ) ^ n - (8 / 9 : ℝ) ^ n - (5 / 9 : ℝ) ^ n by
      convert congr_arg ENNReal.ofReal h_simp using 1;
      · simp +decide [ h_good_seqs ];
        rw [ ENNReal.ofReal_div_of_pos ] <;> norm_num [ unifDistN ];
        simp +decide [ Set.indicator ];
        rw [ Finset.sum_ite ] ; norm_num [ div_eq_mul_inv ];
      · unfold solution;
        rw [ ENNReal.ofReal_sub, ENNReal.ofReal_sub ] <;> norm_num;
        rw [ ENNReal.ofReal_add ] <;> norm_num;
        rw [ ENNReal.ofReal_div_of_pos, ENNReal.ofReal_div_of_pos, ENNReal.ofReal_div_of_pos ] <;> norm_num;
    -- Let's count the number of sequences that do not contain the digit 4 and the number of sequences that do not contain any of the digits 1, 3, 5, or 7.
    have h_count : (∑ s : DigitSeq n, (if ¬(∃ a, s a = 4) ∨ ¬(∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7) then (1 : ℝ) else 0)) = 8^n + 5^n - 4^n := by
      have h_count : (∑ s : DigitSeq n, (if ¬(∃ a, s a = 4) then (1 : ℝ) else 0)) = 8^n ∧ (∑ s : DigitSeq n, (if ¬(∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7) then (1 : ℝ) else 0)) = 5^n ∧ (∑ s : DigitSeq n, (if ¬(∃ a, s a = 4) ∧ ¬(∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7) then (1 : ℝ) else 0)) = 4^n := by
        have h_count : ∀ (S : Finset Digit), (∑ s : DigitSeq n, (if ∀ a, s a ∉ S then (1 : ℝ) else 0)) = (9 - S.card : ℝ) ^ n := by
          intro S
          have h_count : (∑ s : DigitSeq n, (if ∀ a, s a ∉ S then (1 : ℝ) else 0)) = (∏ a : Fin n, (∑ d : Digit, (if d ∉ S then (1 : ℝ) else 0))) := by
            rw [ Finset.prod_sum ];
            refine' Finset.sum_bij ( fun s _ => fun a _ => s a ) _ _ _ _ <;> simp +decide;
            · simp +decide [ funext_iff ];
            · exact fun b => ⟨ fun a => b a ( Finset.mem_univ a ), rfl ⟩;
            · intro a; split_ifs <;> simp_all +decide ;
              rw [ Finset.prod_eq_zero ( Finset.mem_univ ( Classical.choose ‹∃ x, a x ∈ S› ) ) ] ; simp +decide [ Classical.choose_spec ‹∃ x, a x ∈ S› ];
          simp_all +decide [ Finset.sum_ite ];
          rw [ show ( Finset.univ.filter fun x => x∉S ) = Finset.univ \ S by ext; simp +decide, Finset.card_sdiff ] ; norm_num;
          rw [ Nat.cast_sub ] <;> norm_num ; exact le_trans ( Finset.card_le_univ _ ) ( by decide );
        convert And.intro ( h_count { 4 } ) ( And.intro ( h_count { 1, 3, 5, 7 } ) ( h_count { 4, 1, 3, 5, 7 } ) ) using 2 <;> simp +decide;
        · norm_num;
        · norm_cast;
          rw [ Int.subNatNat_of_le ] <;> norm_cast;
        · norm_num [ forall_and ];
      rw [ ← h_count.1, ← h_count.2.1, ← h_count.2.2 ];
      rw [ ← Finset.sum_add_distrib, ← Finset.sum_sub_distrib ] ; congr ; ext ; aesop;
    -- Subtract the count of sequences that do not satisfy the condition from the total number of sequences.
    have h_sub : (∑ s : DigitSeq n, (if (∃ a, s a = 4) ∧ (∃ a, s a = 1 ∨ s a = 3 ∨ s a = 5 ∨ s a = 7) then (1 : ℝ) else 0)) = 9^n - (8^n + 5^n - 4^n) := by
      rw [ ← h_count ];
      rw [ eq_sub_iff_add_eq', ← Finset.sum_add_distrib ];
      rw [ Finset.sum_congr rfl fun x hx => by aesop ] ; norm_num [ Finset.card_univ ];
    rw [ h_sub, div_eq_iff ] <;> first | positivity | norm_num [ ← div_pow ] ; ring;
    norm_num [ ← mul_pow ]

end Usa1972P3
