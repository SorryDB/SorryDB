        apply Circuit.is_zero_congr; (
        apply to_var_sem_pre k hk₃ G hk₅ hG);
        intro x; exact hk₂ x ( hk₄ ( n, x ) ) ( { l := x, r := ( n, x ) } :: G ) ( n + 1 ) set ( hk₆ x n x ) ( by
