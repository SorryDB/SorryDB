        rw [ h_dedup_share ] ; exact Circuit.share_congr ( to_var_sem_pre _ _ _ he hG ) ( fun x => by
          apply_assumption;
          exact hk x n x;
          · simp +decide [ List.forall_cons, hG ]
            simp [Exp.eval]
