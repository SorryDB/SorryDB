private theorem dedup_gen :
    ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G n set,
    wf G cl cr →
    List.Forall (fun entry => entry.l = (Exp.eval (↑entry.r.2))) G →
    (∀ e_nat ∈ set, ∀ (el : Exp (ZMod p) (ZMod p)) (er : Exp (ZMod p) (ℕ × ZMod p)),
      wf_e G el er → to_nat er = e_nat → el.eval = 0) →
    (∀ entry ∈ G, entry.r.1 < n) →
    (∀ e_nat ∈ set, vars_lt n e_nat) →
    (∀ e1 ∈ G, ∀ e2 ∈ G, e1.r.1 = e2.r.1 → e1.r.2 = e2.r.2) →
    cl ≈ dedup_ cr n set := by
      intros cl cr G n set hcl hG hset hset_vars hset_unique hG_unique
      induction' cl with cl ih generalizing cr G n set; (
      cases hcl ; aesop;);
      · cases hcl;
        rename_i e₁ e₂ he₁ he₂
        generalize_proofs at *;
        apply Eq.symm; exact (by
        unfold dedup_ ; simp +decide [ * ] ; (
        split_ifs;
        · exact Eq.symm ( by apply_assumption; assumption; assumption; assumption; assumption; assumption; assumption ) ;
        · exact False.elim <| ‹¬cl.eval = 0› <| hset _ ‹_› _ _ he₁ rfl;
        · rename_i h₁ h₂;
          have h_eval_eq : (to_var e₁).eval = cl.eval := by
            have h_eval_eq : cl ≈ to_var e₁ := by
              apply to_var_sem_pre; assumption; assumption;
            generalize_proofs at *; (
            exact h_eval_eq.symm ▸ rfl)
          generalize_proofs at *; (
          simp +decide [ h₂, h_eval_eq, Circuit.eval_eq0 ];
          convert Eq.symm ( ‹∀ ( cr : Circuit p ( ℕ × ZMod p ) ) ( G : List ( Entry ( ZMod p ) ( ℕ × ZMod p ) ) ) ( n : ℕ ) ( set : List ( Exp ( ZMod p ) ℕ ) ), wf G ih cr → List.Forall ( fun entry => entry.l = ( Exp.c entry.r.2 ).eval ) G → ( ∀ e_nat ∈ set, ∀ ( el : Exp ( ZMod p ) ( ZMod p ) ) ( er : Exp ( ZMod p ) ( ℕ × ZMod p ) ), wf_e G el er → to_nat er = e_nat → el.eval = 0 ) → ( ∀ entry ∈ G, entry.r.1 < n ) → ( ∀ e_nat ∈ set, vars_lt n e_nat ) → ( ∀ e1 ∈ G, ∀ e2 ∈ G, e1.r.1 = e2.r.1 → e1.r.2 = e2.r.2 ) → ih ≈ dedup_ cr n set› e₂ G n ( to_nat e₁ :: set ) he₂ hG ( by
            simp +zetaDelta at *;
            exact ⟨ fun el er he he' => by
              have h_eval_eq : el.eval = (to_var er).eval := by
                apply to_var_sem_pre; assumption; assumption;
              generalize_proofs at *; (
              have h_eval_eq : (to_var er).eval = (to_var e₁).eval := by
                apply to_var_determined_by_to_nat he₁ he (by
                exact he'.symm ▸ rfl) (by
                exact hG_unique) |> fun h => h ▸ rfl
              generalize_proofs at *; (
              grind +ring)), fun a ha el er he he' => by
              exact hset a ha el er he he' ▸ rfl ⟩ ) ( by
            assumption ) ( by
            simp +zetaDelta at *;
            exact ⟨ by simpa using wf_e_to_nat_vars_lt he₁ ( by aesop ), hset_unique ⟩ ) ( by
            exact hG_unique ) ) using 1);
        · -- Since `cl.eval ≠ 0` and `to_var e₁ ≈ cl`, we have `(to_var e₁).eval ≠ 0`.
          have h_eval_ne_zero : (to_var e₁).eval ≠ 0 := by
            have h_eval_ne_zero : cl ≈ to_var e₁ := by
              apply to_var_sem_pre cl e₁ G he₁ hG
            generalize_proofs at *; (
            exact h_eval_ne_zero.symm ▸ by assumption;)
          generalize_proofs at *; (
          exact if_neg h_eval_ne_zero))); -- Apply the equality we've already established.;
      · rcases hcl with ⟨f, hf⟩;
        apply Circuit.lam_congr;
        rename_i k hk; intro x; apply_assumption;
        exact hk x ( n, x );
        · simp +zetaDelta at *;
          exact ⟨ rfl, hG ⟩;
        · intro e_nat he_nat el er h_wf h_to_nat
          apply hset e_nat he_nat el er (by
          apply_rules [ wf_e_of_cons ];
          · exact h_to_nat ▸ he_nat;
          · exact le_rfl) h_to_nat;
        · grind +ring;
        · exact fun e he => vars_lt_mono ( hset_unique e he ) ( Nat.le_succ _ );
        · grind +ring;
      · rcases hcl with ⟨ er, kr, he, hk ⟩ ; simp +decide [ *, Circuit.share ] at *;
        rename_i er kr he hk;
        -- By definition of `dedup_`, we know that `dedup_ (Circuit.share er kr) n set` is equivalent to `Circuit.share (to_var er) (fun x => dedup_ (kr (n, x)) (n+1) set)`.
        have h_dedup_share : dedup_ (Circuit.share er kr) n set = Circuit.share (to_var er) (fun x => dedup_ (kr (n, x)) (n+1) set) := by
          rfl
