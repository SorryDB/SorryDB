            generalize_proofs at *; (
            apply_rules [ wf_e_of_cons ] ; aesop ( simp_config := { singlePass := true } ) ;
            exact le_rfl);
          · grind +ring;
          · exact fun e_nat he_nat => vars_lt_mono ( hset_unique e_nat he_nat ) ( Nat.le_succ _ );
