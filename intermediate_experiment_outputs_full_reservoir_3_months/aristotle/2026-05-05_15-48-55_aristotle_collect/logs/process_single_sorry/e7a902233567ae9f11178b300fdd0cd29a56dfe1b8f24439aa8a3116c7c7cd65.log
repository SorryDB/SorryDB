            · cases h3;
            · cases h3;
            · cases h3;
            · cases h3;
          · cases er' <;> cases h3 ; trivial;
          · rcases er' with ( _ | _ | er' | er' | er' ) <;> norm_num at *;
            · cases h3;
            · cases h3;
            · rename_i k l hk hl ih₁ ih₂;
              rcases h2 with ( _ | _ | _ | _ | _ | h2 );
              exact congr_arg₂ ( · + · ) ( hl ‹_› ( by
