                                                    intros e_nat he_nat el er h_wf h_to_nat
                                                    apply hset e_nat he_nat el er (by
                                                    apply_rules [ wf_e_of_cons ] ; aesop ( simp_config := { singlePass := true } ) ;
                                                    exact le_rfl) h_to_nat ) ( by
                                                    grind ) ( by
                                                    exact fun e he => vars_lt_mono ( hset_unique e he ) ( Nat.le_succ _ ) ) ( by
                                                    grind +ring ) ;)));
      · rcases hcl with ⟨⟩

-- The original theorem with arbitrary G is false because dedup_'s internal
-- counter (starting at 0) can collide with variable IDs already present in G.
-- Counterexample: with p = 7, G = [{l := 0, r := (0, 0)}],
--   cr = .lam (fun y => .eq0 (.v (0, 0)) (.eq0 (.v y) .nil))
--   cl = .lam (fun x => .eq0 (.v 0) (.eq0 (.v x) .nil))
-- satisfies wf G cl cr and the Forall condition, but dedup incorrectly
-- removes the second eq0 check (on x) because it has the same to_nat as
-- the first check (on the free variable with ID 0), even though they
-- evaluate to different values.
--
-- theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
--   wf G cl cr ->
--     List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
--       cl ≈ (dedup cr) := sorry

/-- Corrected version of dedup_sem_pre. The original statement with arbitrary G
is false because dedup_'s internal counter (starting at 0) can collide with
variable IDs already present in G. This version restricts to G = [], which is
the standard use case (matching wf' which uses wf []). -/
theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)),
  wf [] cl cr →
    cl ≈ (dedup cr) := by
  intro cl cr hwf
  apply dedup_gen cl cr [] 0 []
  · exact hwf
  · simp [List.Forall]
  · simp
  · simp
  · simp
  · simp

