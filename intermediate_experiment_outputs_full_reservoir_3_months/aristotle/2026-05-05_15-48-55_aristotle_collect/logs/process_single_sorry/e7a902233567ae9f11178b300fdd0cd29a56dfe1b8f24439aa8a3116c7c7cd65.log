import Mathlib
import Clap.Circuit
import Clap.Simulation
import Clap.Id

namespace Clap

/-
  This file introduces an optimization to remove duplicate checks.
  The current version eliminates any `eq0` with an expression that has
  already been met before. The same optimization should be applicable
  to boolean checks, limb checks and other lookup arguments with minor
  modifications.

  Dedup is extremely valuable as it allows to write composable
  circuits with many redundant checks without having to pay the price
  in term of constraints.
-/

namespace Dedup

variable {p : ℕ} [Fact (Nat.Prime p)]

def to_nat {F var : Type} (e : Exp F (ℕ × var)) : Exp F ℕ :=
  match e with
  | .v (v, _) => .v v
  | .c f => .c f
  | .add l r => to_nat l + to_nat r
  | .mul l r => to_nat l * to_nat r
  | .sub l r => to_nat l - to_nat r

def to_var {F var : Type} (e : Exp F (ℕ × var)) : Exp F var :=
  match e with
  | .v (_, v) => .v v
  | .c f => .c f
  | .add l r => to_var l + to_var r
  | .mul l r => to_var l * to_var r
  | .sub l r => to_var l - to_var r

def beq : (e1 e2 : Exp (ZMod p) Nat) -> Bool
  | .v n1, .v n2
  | .c n1, .c n2 => n1 = n2
  | .add ll lr, .add rl rr => beq ll rl && beq lr rr
  | .mul ll lr, .mul rl rr => beq ll rl && beq lr rr
  | .sub ll lr, .sub rl rr => beq ll rl && beq lr rr
  | _,_ => false

-- TODO we are mixing expressions from eq0 and assert_range, they should be in different sets
def dedup_ {var} (c : Circuit p (ℕ × var)) (n : ℕ) (set : List (Exp (ZMod p) ℕ)) : Circuit p var :=
  match c with
  | .nil => .nil
  | .eq0 e c =>
    if (to_nat e) ∈ set
    then dedup_ c n set
    else .eq0 (to_var e) (dedup_ c n ((to_nat e)::set))
  | .lam k => .lam (fun x => dedup_ (k (n,x)) (n+1) set)
  | .share e k => .share (to_var e) (fun x => dedup_ (k (n,x)) (n+1) set)
  | .is_zero e k => .is_zero (to_var e) (fun x => dedup_ (k (n,x)) (n+1) set)
  | .assert_range w e c => .assert_range w (to_var e) (dedup_ c n ((to_nat e)::set))

def dedup {var} (c : Circuit p (Nat × var)) : Circuit p var := dedup_ c 0 []

def dedup' (c : Circuit' p) : Circuit' p := fun var => dedup (c (Nat × var))

namespace Test

abbrev F7 := Clap.F7.F

def a        : Circuit' 7 := fun _ => .lam (fun x => .eq0 (.v x + .c 1) (.eq0 (.v x + .c 2) (.eq0 (.v x + .c 1) .nil )))
def expected : Circuit' 7 := fun _ => .lam (fun x => .eq0 (.v x + .c 1) (.eq0 (.v x + .c 2) .nil ))

#guard s!"{dedup' a Nat}" = s!"{expected Nat}"

end Test

open Id

/-
PROBLEM
variable [Coe F Nat]

Helper: to_var preserves expression semantics (analogous to unwrap_e_sem_pre in Id.lean)

PROVIDED SOLUTION
By induction on el, mirroring the proof of unwrap_e_sem_pre in Clap/Id.lean. For variables, use wf_e.v and the Forall condition to get el ≈ er. For constants, trivial. For compound expressions, use the appropriate congr lemma (add_congr, mul_congr, sub_congr) with IH.
-/
lemma to_var_sem_pre : ∀ (el: Exp (ZMod p) (ZMod p)) (er: Exp (ZMod p) (ℕ × ZMod p)) G,
  wf_e G el er ->
   List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
   el ≈ (to_var er) := by
     intro el er G h1 h2;
     induction h1;
     · rw [ List.forall_iff_forall_mem ] at h2;
       rename_i x y hxy; specialize h2 _ hxy; aesop;
     · rfl;
     · exact Exp.add_congr ‹_› ‹_›;
     · apply_rules [ Exp.mul_congr ];
     · exact Exp.sub_congr ‹_› ‹_›

-- Predicate: all variable IDs in an Exp (ZMod p) ℕ expression are < n
def vars_lt (n : ℕ) : Exp (ZMod p) ℕ → Prop
  | .v m => m < n
  | .c _ => True
  | .add l r => vars_lt n l ∧ vars_lt n r
  | .mul l r => vars_lt n l ∧ vars_lt n r
  | .sub l r => vars_lt n l ∧ vars_lt n r

/-
PROBLEM
Monotonicity of vars_lt

PROVIDED SOLUTION
By induction on e. For .v m, use Nat.lt_of_lt_of_le. For .c, trivial. For compound expressions, use the IH on both sides.
-/
lemma vars_lt_mono {n m : ℕ} {e : Exp (ZMod p) ℕ} (h : vars_lt n e) (hle : n ≤ m) :
    vars_lt m e := by
      induction e <;> simp_all +decide [ vars_lt ]
      omega

/-
PROBLEM
wf_e implies vars_lt for to_nat

PROVIDED SOLUTION
By induction on the wf_e derivation. For wf_e.v: we have {l:=x, r:=x'} ∈ G, so x'.1 < n by the hypothesis. to_nat (.v x') = .v x'.1, and vars_lt n (.v x'.1) = x'.1 < n. For wf_e.c: to_nat (.c c) = .c c, vars_lt n (.c c) = True. For compound cases: use IH on sub-expressions and combine.
-/
lemma wf_e_to_nat_vars_lt {G : List (Entry (ZMod p) (ℕ × ZMod p))}
    {el : Exp (ZMod p) (ZMod p)} {er : Exp (ZMod p) (ℕ × ZMod p)} {n : ℕ} :
    wf_e G el er →
    (∀ entry ∈ G, entry.r.1 < n) →
    vars_lt n (to_nat er) := by
      intro he he';
      have h_vars_lt : ∀ e : Exp (ZMod p) (ℕ × ZMod p), (∀ entry ∈ G, entry.r.1 < n) → (∃ e' : Exp (ZMod p) (ZMod p), wf_e G e' e) → vars_lt n (to_nat e) := by
        intros e he he';
        obtain ⟨ e', he' ⟩ := he';
        induction e' generalizing e;
        · cases he';
          exact he _ ‹_›;
        · cases he' ; tauto;
        · cases he';
          exact ⟨ by solve_by_elim, by solve_by_elim ⟩;
        · cases he';
          exact ⟨ by solve_by_elim, by solve_by_elim ⟩;
        · cases he';
          exact ⟨ by solve_by_elim, by solve_by_elim ⟩;
      exact h_vars_lt er he' ⟨ el, he ⟩

/-
PROBLEM
Removing head entry from context when expression doesn't use it

PROVIDED SOLUTION
By induction on the wf_e (entry :: G) el er derivation.

Case wf_e.v: We have {l:=x, r:=x'} ∈ (entry :: G). vars_lt n (to_nat (.v x')) means x'.1 < n. Since n ≤ entry.r.1, we get x'.1 < entry.r.1. This means the entry {l:=x, r:=x'} is NOT the head (which has r = entry.r with first component ≥ n), so it must be in the tail G. That is, from List.mem_cons, either {l:=x, r:=x'} = {l:=entry.l, r:=entry.r} or {l:=x, r:=x'} ∈ G. The first case leads to x' = entry.r, so x'.1 = entry.r.1 ≥ n, contradicting x'.1 < n. So the second case holds, and we use wf_e.v with the membership in G.

Case wf_e.c: trivial, wf_e.c G n works for any G.

Case wf_e.add/mul/sub: vars_lt n decomposes into conjunction for sub-expressions. Apply IH on each and use the appropriate wf_e constructor.
-/
lemma wf_e_of_cons {G : List (Entry (ZMod p) (ℕ × ZMod p))}
    {el : Exp (ZMod p) (ZMod p)} {er : Exp (ZMod p) (ℕ × ZMod p)}
    {entry : Entry (ZMod p) (ℕ × ZMod p)} {n : ℕ} :
    wf_e (entry :: G) el er →
    vars_lt n (to_nat er) →
    n ≤ entry.r.1 →
    wf_e G el er := by
  intro hwfe hvlt hle
  induction hwfe with
  | v x x' hmem =>
    simp [to_nat, vars_lt] at hvlt
    cases hmem with
    | head => simp_all; omega
    | tail _ h => exact wf_e.v _ _ _ h
  | c => exact wf_e.c _ _
  | add e1 e2 e1' e2' h1 h2 ih1 ih2 =>
    simp [to_nat, Exp.add_def, vars_lt] at hvlt
    exact wf_e.add _ _ _ _ _ (ih1 hvlt.1) (ih2 hvlt.2)
  | mul e1 e2 e1' e2' h1 h2 ih1 ih2 =>
    simp [to_nat, Exp.mul_def, vars_lt] at hvlt
    exact wf_e.mul _ _ _ _ _ (ih1 hvlt.1) (ih2 hvlt.2)
  | sub e1 e2 e1' e2' h1 h2 ih1 ih2 =>
    simp [to_nat, Exp.sub_def, vars_lt] at hvlt
    exact wf_e.sub _ _ _ _ _ (ih1 hvlt.1) (ih2 hvlt.2)

/-
PROBLEM
Same to_nat with unique-ID context implies same to_var

PROVIDED SOLUTION
Prove by induction on er, generalizing el, el', er'.

For each case, do cases on er' and use the hypothesis to_nat er = to_nat er' to eliminate impossible cases (e.g., .v vs .c gives .v _ = .c _ which is impossible by injection/Exp constructor injectivity).

Case .v x: er' must be .v y with x.1 = y.1 (from Exp.v injection on to_nat). From wf_e.v, we get {l:=_, r:=x} ∈ G and {l:=_, r:=y} ∈ G. The uniqueness hypothesis gives x.2 = y.2 (since x.1 = y.1). So to_var (.v x) = .v x.2 = .v y.2 = to_var (.v y). Use Prod.ext or ext to close.

Case .c f: er' must be .c f (same constant from injection). Trivial.

Case .add l r: er' must be .add l' r'. From Exp.add injection on to_nat, get to_nat l = to_nat l' and to_nat r = to_nat r'. Invert wf_e on both sides to get sub-wf_e. Apply IH. Then to_var (.add l r) = to_var l + to_var r = to_var l' + to_var r' = to_var (.add l' r'). Use congr_arg2 or congrArg.

Similarly for mul and sub.
-/
lemma to_var_determined_by_to_nat {G : List (Entry (ZMod p) (ℕ × ZMod p))}
    {el el' : Exp (ZMod p) (ZMod p)}
    {er er' : Exp (ZMod p) (ℕ × ZMod p)} :
    wf_e G el er → wf_e G el' er' →
    to_nat er = to_nat er' →
    (∀ e1 ∈ G, ∀ e2 ∈ G, e1.r.1 = e2.r.1 → e1.r.2 = e2.r.2) →
    to_var er = to_var er' := by
      -- Prove by induction on er, generalizing el, el', er'.
      have h_ind : ∀ {el el' : Exp (ZMod p) (ZMod p)} {er er' : Exp (ZMod p) (ℕ × ZMod p)},
        wf_e G el er →
        wf_e G el' er' →
        to_nat er = to_nat er' →
        (∀ e1 ∈ G, ∀ e2 ∈ G, e1.r.1 = e2.r.1 → e1.r.2 = e2.r.2) →
        to_var er = to_var er' := by
