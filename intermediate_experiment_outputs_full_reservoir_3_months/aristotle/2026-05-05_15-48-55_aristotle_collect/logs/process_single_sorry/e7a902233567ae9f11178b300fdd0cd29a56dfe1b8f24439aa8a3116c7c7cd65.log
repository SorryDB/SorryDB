          · induction h2;
            · cases h3;
            · cases h3;
            · cases h3;
            · cases h3;
            · rename_i h₁ h₂ h₃ h₄ h₅ h₆;
              rename_i h₇ h₈ h₉ h₁₀ h₁₁ h₁₂;
              exact congr_arg₂ _ ( h₉ h₃ ( by injection h3 ) ) ( h₁₀ h₄ ( by injection h3 ) );
