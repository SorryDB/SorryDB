module

public import Mathlib.Data.Nat.Choose.Multinomial
public import Mathlib.Probability.IdentDistrib

/-!
# The Marcinkiewicz-Zygmund inequality

This file proves the Marcinkiewicz-Zygmund inequality.

The Marcinkiewicz-Zygmund inequality states that, if `X₁, ... Xₐ ∈ L^p` are independent random
variables of mean zero valued in some inner product space, then the `L^p`-norm of `X₁ + ... + Xₐ` is
at most `Cₚ` times the `L^(p/2)`-norm of `|X₁|² + ... + |Xₐ|²`, where `Cₚ` is a constant depending
on `p` alone.

## Notation

Throughout this file, `A ^^ n` denotes `A × ... × A` (with `n` factors). Formally, this is
`Fintype.piFinset fun _ : Fin n ↦ A`.

## TODO

We currently only prove the inequality for `p = 2 * m` an even natural number. The general `p` case
can be obtained from this specific one by nesting of Lp norms.
-/

open Finset Fintype Function Nat MeasureTheory ProbabilityTheory Real
open scoped NNReal ENNReal

variable {ι Ω E : Type*} {A : Finset ι} {m n : ℕ} [MeasurableSpace Ω] {μ : Measure Ω}
  [IsFiniteMeasure μ] [mE : MeasurableSpace E] [NormedAddCommGroup E] [InnerProductSpace ℝ E]
  {X : ι → Ω → E}

local notation:70 A:70 " ^^ " n:71 => Fintype.piFinset fun _ : Fin n ↦ A

/-- The constant appearing in the Marcinkiewicz-Zygmund inequality for symmetric random variables.
-/
noncomputable def marcinkiewiczZygmundSymmConst (p : ℝ≥0) : ℝ := (p / 2) ^ (p / 2 : ℝ)

/-- The **Marcinkiewicz-Zygmund inequality** for symmetric random variables, with a slightly better
constant than `marcinkiewicz_zygmund`. -/
theorem marcinkiewicz_zygmund_symmetric (iIndepFun_X : iIndepFun X μ)
    (identDistrib_neg_X : ∀ i, IdentDistrib (X i) (-X i) μ μ)
    (memLp_X : ∀ i ∈ A, MemLp (X i) (2 * m) μ) :
    ∫ ω, ‖∑ i ∈ A, X i ω‖ ^ (2 * m) ∂μ ≤
      marcinkiewiczZygmundSymmConst (2 * m) * ∫ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ∂μ := by
  have : DecidableEq ι := Classical.decEq _
  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I ∈ A ×ˢ A ^^ m) :
    Integrable (fun ω ↦ ∏ k, ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
    have h_prod_integrable : ∀ k : Fin m, MeasureTheory.Integrable (fun ω => ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
      intro k
      have h_norms : MemLp (fun ω => ‖X (I k).1 ω‖) 2 μ ∧ MemLp (fun ω => ‖X (I k).2 ω‖) 2 μ := by
        have h_integrable_k : ∀ i ∈ A, MeasureTheory.MemLp (fun ω => ‖X i ω‖) 2 μ := by
          intro i hi
          have h_integrable_k : MeasureTheory.MemLp (fun ω => ‖X i ω‖) (2 * m) μ := by
            exact memLp_X i hi |> fun h => h.norm
          have h_integrable_k : MeasureTheory.MemLp (fun ω => ‖X i ω‖) 2 μ := by
            rcases m with ( _ | m ) <;> simp_all +decide [ Nat.mul_succ ];
            · exact False.elim ( Fin.elim0 k );
            · exact h_integrable_k.mono_exponent ( by norm_cast; linarith )
          exact h_integrable_k;
        aesop;
      exact MeasureTheory.Integrable.mono_measure ( h_norms.1.integrable_mul h_norms.2 ) le_rfl;
    induction' m with m ih <;> simp_all +decide [ Fin.prod_univ_succ ];
    refine' MeasureTheory.Integrable.mono' _ _ _;
    refine' fun ω => ∑ k : Fin ( m + 1 ), ( ‖X ( I k |>.1 ) ω‖ * ‖X ( I k |>.2 ) ω‖ ) ^ ( m + 1 );
    · refine' MeasureTheory.integrable_finset_sum _ fun k _ => _;
      refine' MeasureTheory.Integrable.mono' _ _ _;
      refine' fun ω => ( ‖X ( I k |>.1 ) ω‖ ^ ( 2 * ( m + 1 ) ) + ‖X ( I k |>.2 ) ω‖ ^ ( 2 * ( m + 1 ) ) ) / 2;
      · have := memLp_X ( I k |>.1 ) ( hI k |>.1 );
        have := memLp_X ( I k |>.2 ) ( hI k |>.2 );
        norm_cast at *;
        exact MeasureTheory.Integrable.div_const ( MeasureTheory.Integrable.add ( MeasureTheory.MemLp.integrable_norm_pow ( by assumption ) ( by norm_num ) ) ( MeasureTheory.MemLp.integrable_norm_pow ( by assumption ) ( by norm_num ) ) ) _;
      · exact MeasureTheory.AEStronglyMeasurable.pow ( h_prod_integrable k |> MeasureTheory.Integrable.aestronglyMeasurable ) _;
      · filter_upwards [ ] with ω ; rw [ Real.norm_of_nonneg ( by positivity ) ] ; rw [ pow_mul', pow_mul' ] ; ring_nf ;
        norm_num [ pow_mul ];
        nlinarith only [ sq_nonneg ( ‖X ( I k |>.1 ) ω‖ * ‖X ( I k |>.1 ) ω‖ ^ m - ‖X ( I k |>.2 ) ω‖ * ‖X ( I k |>.2 ) ω‖ ^ m ) ];
    · refine' MeasureTheory.AEStronglyMeasurable.mul _ _;
      · exact h_prod_integrable 0 |> MeasureTheory.Integrable.aestronglyMeasurable;
      · refine' MeasureTheory.Integrable.aestronglyMeasurable _;
        exact ih ( fun i hi => by simpa using memLp_X i hi |> fun h => h.mono_exponent <| by norm_cast; linarith ) ( fun k => I k.succ ) ( fun k => hI _ ) ( fun k => h_prod_integrable _ );
    · refine' Filter.Eventually.of_forall fun ω => _;
      have h_am_gm : ∀ (a : Fin (m + 1) → ℝ), (∀ k, 0 ≤ a k) → (∏ k, a k) ≤ (∑ k, a k ^ (m + 1)) / (m + 1) := by
