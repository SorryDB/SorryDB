-- !benchmark @start import type=solution
import Mathlib

-- !benchmark @end import

-- !benchmark @start solution_aux

-- !benchmark @end solution_aux

-- !benchmark @start precond_aux

-- !benchmark @end precond_aux
@[reducible, simp]
def longestIncreasingSubsequence_precond (nums : List Int) : Prop :=
  -- !benchmark @start precond
  True
  -- !benchmark @end precond


-- !benchmark @start code_aux

-- !benchmark @end code_aux


def longestIncreasingSubsequence (nums : List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) : Nat :=
  -- !benchmark @start code
  let max2 (a : Nat) (b : Nat) : Nat :=
    if a > b then a else b

  let rec listLength (l : List Int) : Nat :=
    match l with
    | []      => 0
    | _ :: xs => 1 + listLength xs

  let rec helper (lst : List Int) (prev : Option Int) : Nat :=
    match lst with
    | [] => 0
    | h :: t =>
        let canTake : Bool :=
          if prev = none then true
          else if prev.get! < h then true else false
        let withTake : Nat :=
          if canTake then 1 + helper t (some h) else 0
        let withoutTake : Nat := helper t prev
        max2 withTake withoutTake

  let result := helper nums none
  result
  -- !benchmark @end code


-- !benchmark @start postcond_aux

-- !benchmark @end postcond_aux


@[reducible, simp]
def longestIncreasingSubsequence_postcond (nums : List Int) (result: Nat) (h_precond : longestIncreasingSubsequence_precond (nums)) : Prop :=
  -- !benchmark @start postcond
  let allSubseq := (nums.foldl fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse
  let increasingSubseqLens := allSubseq.filter (fun l => List.Pairwise (· < ·) l) |>.map (·.length)
  increasingSubseqLens.contains result ∧ increasingSubseqLens.all (· ≤ result)
  -- !benchmark @end postcond


-- !benchmark @start proof_aux

-- Abbreviation for the helper function
abbrev lisMax2 : ℕ → ℕ → ℕ := fun a b => if a > b then a else b
abbrev lisHelper := longestIncreasingSubsequence.helper lisMax2

-- All subsequences generated by the foldl construction (reversed)
def genSubseqs (nums : List ℤ) : List (List ℤ) :=
  (nums.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse

-- Membership in genSubseqs ↔ Sublist
lemma mem_genSubseqs_iff (nums : List ℤ) (s : List ℤ) :
    s ∈ genSubseqs nums ↔ s.Sublist nums := by
  constructor
  · unfold genSubseqs
    induction' nums using List.reverseRecOn with nums x ih generalizing s <;> aesop
  · revert s
    refine' List.reverseRecOn nums _ _
    · simp +decide [genSubseqs]
    · intro l a ih s hs
      by_cases h : s.Sublist l <;> simp_all +decide [List.sublist_append_iff]
      · simp_all +decide [genSubseqs]
      · rcases hs with ⟨l₁, l₂, rfl, hl₁, rfl | rfl⟩ <;> simp_all +decide [genSubseqs]

-- Helper: all elements of a pairwise-increasing list with head > a are all > a
private lemma pairwise_lt_all_gt_head {a : ℤ} {s : List ℤ}
    (h_head : ∀ x ∈ s.head?, a < x)
    (h_pw : s.Pairwise (· < ·)) :
    ∀ y ∈ s, a < y := by
  intro y hy
  cases s with
  | nil => simp at hy
  | cons hd tl =>
    simp at h_head
    rw [List.pairwise_cons] at h_pw
    cases hy with
    | head _ => exact h_head
    | tail _ hmem => exact lt_trans h_head (h_pw.1 y hmem)

-- lisMax2 is just max
private lemma lisMax2_eq (a b : ℕ) : lisMax2 a b = max a b := by
  simp [lisMax2]; split_ifs with h <;> omega

/-
The generalized achievable lemma
-/
lemma lisHelper_achievable_gen (lst : List ℤ) (prev : Option ℤ) :
    ∃ s : List ℤ, s.Sublist lst ∧ s.Pairwise (· < ·) ∧
    (∀ a, prev = some a → ∀ x ∈ s.head?, a < x) ∧
    s.length = lisHelper lst prev := by
  induction' lst with x xs ih generalizing prev;
  · use []
    simp [longestIncreasingSubsequence.helper];
  · obtain ⟨ s, hs₁, hs₂, hs₃, hs₄ ⟩ := ih ( Option.some x ) ; ( obtain ⟨ t, ht₁, ht₂, ht₃, ht₄ ⟩ := ih prev; ( unfold longestIncreasingSubsequence.helper; simp +decide [ hs₄, ht₄ ] ; ) );
    split_ifs <;> simp_all +decide [ lisMax2_eq ];
    · cases max_cases ( 1 + longestIncreasingSubsequence.helper lisMax2 xs ( some x ) ) ( longestIncreasingSubsequence.helper lisMax2 xs prev ) <;> [ refine' ⟨ x :: s, _, _, _, _ ⟩ ; refine' ⟨ t, _, _, _, _ ⟩ ] <;> simp_all +decide [ List.sublist_cons_iff ];
      · exact pairwise_lt_all_gt_head hs₃ hs₂;
      · intro a hpa; subst hpa; simp_all
      · unfold lisHelper; omega;
    · exact ⟨ t, ht₁.trans ( List.sublist_cons_self _ _ ), ht₂, ht₃, ht₄ ⟩

/-
The generalized optimal lemma
-/
lemma lisHelper_optimal_gen (lst : List ℤ) (prev : Option ℤ)
    (s : List ℤ) (hs : s.Sublist lst) (hinc : s.Pairwise (· < ·))
    (hprev : ∀ a, prev = some a → ∀ x ∈ s.head?, a < x) :
    s.length ≤ lisHelper lst prev := by
  revert hs hinc hprev;
  induction' lst with x t ih generalizing s prev <;> simp_all +decide [ List.sublist_cons_iff ];
  rintro ( hs | ⟨ r, rfl, hr ⟩ ) hinc hprev;
  · refine' le_trans ( ih prev s hs hinc hprev ) _;
    simp +decide [ lisHelper ];
    simp +decide [ lisMax2, longestIncreasingSubsequence.helper ];
    split_ifs <;> omega;
  · -- By the induction hypothesis, we have `r.length ≤ lisHelper t (some x)`.
    have h_ind : r.length ≤ lisHelper t (some x) := by
      apply ih (some x) r hr;
      · exact hinc.tail;
      · cases r <;> aesop;
    cases prev <;> simp_all +decide [ longestIncreasingSubsequence.helper ];
    all_goals {
      have h1 : r.length + 1 ≤ 1 + lisHelper t (some x) := by omega
      have h2 : ∀ a b : ℕ, a ≤ lisMax2 a b := by intro a b; simp [lisMax2]; split_ifs <;> omega
      exact le_trans h1 (h2 _ _) }

