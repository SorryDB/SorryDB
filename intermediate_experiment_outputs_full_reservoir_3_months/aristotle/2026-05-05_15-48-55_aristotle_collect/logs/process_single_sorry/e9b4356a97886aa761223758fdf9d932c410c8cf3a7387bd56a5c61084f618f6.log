    unfold genSubseqs; aesop
  · intro x hx
    by_cases h_inc : List.Pairwise (· < ·) x.reverse
    · convert lisHelper_optimal_gen nums none x.reverse _ _ using 1
      · aesop
      · convert mem_genSubseqs_iff nums x.reverse |>.1 _ using 1
        unfold genSubseqs; aesop
      · assumption
    · exact Or.inl h_inc
  -- !benchmark @end proof
