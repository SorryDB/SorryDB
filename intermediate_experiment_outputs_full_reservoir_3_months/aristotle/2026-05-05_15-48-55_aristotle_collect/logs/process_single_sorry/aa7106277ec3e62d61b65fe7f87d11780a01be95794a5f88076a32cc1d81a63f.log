import Mathlib

/-! # Spec Theorem for `FieldElement51::invert`

Specification and proof for `FieldElement51::invert`.

This function computes the multiplicative inverse of a field element r in 𝔽_p where p = 2^255 - 19.
The inverse is computed as r^(p-2), since r^(p-2) * r = r^(p-1) = 1 (mod p) by Fermat's Little Theorem.

This function returns zero on input zero.

**Source**: curve25519-dalek/src/field.rs

## TODO
- Complete proof
-/

open Aeneas.Std Result
namespace curve25519_dalek.field.FieldElement51

set_option maxHeartbeats 4000000 in
private lemma p_prime : Nat.Prime p := by unfold p; native_decide

private lemma r'_congruence (r_nat t19_nat t3_nat t20_nat r'_nat : Nat)
    (h_t19 : t19_nat % p = (r_nat ^ (2 ^ 250 - 1)) % p)
    (h_t3 : t3_nat % p = (r_nat ^ 11) % p)
    (h_t20 : t20_nat ≡ t19_nat ^ (2 ^ 5) [MOD p])
    (h_r' : r'_nat ≡ t20_nat * t3_nat [MOD p]) :
    r'_nat % p = (r_nat ^ (p - 2)) % p := by
  have : (2 ^ 250 - 1) * 2 ^ 5 + 11 = p - 2 := by unfold p; omega
  rw [Nat.ModEq] at h_t20 h_r'
  rw [h_r']
  conv_rhs => rw [← this, pow_add, pow_mul]
  rw [Nat.mul_mod, Nat.mul_mod (r_nat ^ ((2 ^ 250 - 1) * 2 ^ 5))]
  rw [h_t20, Nat.pow_mod, h_t19, ← Nat.pow_mod, h_t3]

private lemma fermat_inverse (a : Nat) (ha : a % p ≠ 0) :
    a ^ (p - 2) % p * (a % p) % p = 1 := by
  have hp := p_prime
  have hfact : Fact (Nat.Prime p) := ⟨hp⟩
  have ha' : (a : ZMod p) ≠ 0 := by
    rwa [Ne, ZMod.natCast_eq_zero_iff a p, Nat.dvd_iff_mod_eq_zero]
  have key : (a : ZMod p) ^ (p - 1) = 1 := ZMod.pow_card_sub_one_eq_one ha'
  have hsub : p - 2 + 1 = p - 1 := by unfold p; omega
  have hzmod : ((a ^ (p - 2) * a : ℕ) : ZMod p) = 1 := by
    push_cast; rw [← pow_succ, hsub, key]
  rw [← Nat.mul_mod, ← Nat.pow_mod]
  rw [← ZMod.val_natCast p (a ^ (p - 2) * a), hzmod]
  exact ZMod.val_one p

private lemma zero_pow_mod (a : Nat) (ha : a % p = 0) (n : Nat) (hn : 0 < n) :
    a ^ n % p = 0 := by
  rw [Nat.pow_mod, ha, zero_pow (by omega), Nat.zero_mod]

/-
Natural language description:

    • Computes the multiplicative inverse r^(-1) of a field element r in 𝔽_p where p = 2^255 - 19
    • The inverse is computed as r^(p-2) = r^(2^255-21) using the identity r^(p-2) * r = r^(p-1) = 1 (mod p)
    • The field element is represented in radix 2^51 form with five u64 limbs
    • Returns zero when the input is zero

Natural language specs:

    • The function succeeds (no panic)
    • For any nonzero field element r, the result r' satisfies:
      - Field51_as_Nat(r') * Field51_as_Nat(r) ≡ 1 (mod p)
    • For zero input, the result is zero:
      - Field51_as_Nat(r) ≡ 0 (mod p) → Field51_as_Nat(r') ≡ 0 (mod p)
-/

/-- **Spec and proof concerning `field.FieldElement51.invert`**:
- No panic for field element inputs r (always returns r' successfully)
- If r ≢ 0 (mod p), then Field51_as_Nat(r') * Field51_as_Nat(r) ≡ 1 (mod p)
- If r ≡ 0 (mod p), then Field51_as_Nat(r') ≡ 0 (mod p)
-/
theorem invert_spec (r : backend.serial.u64.field.FieldElement51) (h_bounds : ∀ i, i < 5 → (r[i]!).val < 2 ^ 54) :
    ∃ r', invert r = ok r' ∧
    let r_nat := Field51_as_Nat r % p
    let r'_nat := Field51_as_Nat r' % p
    (r_nat ≠ 0 → (r'_nat * r_nat) % p = 1) ∧
    (r_nat = 0 → r'_nat = 0) ∧
    (∀ i, i < 5 → (r'[i]!).val < 2 ^ 52)
    := by
    -- Step 1: Apply pow22501 spec
    obtain ⟨t19, t3, h_pow22501, h_t19_mod, h_t3_mod, h_t19_bounds, h_t3_bounds⟩ :=
      pow22501_spec r h_bounds
    -- Step 2: Apply pow2k spec (t19 has limbs < 2^52 < 2^54)
    have h_t19_bounds' : ∀ i < 5, (t19[i]!).val < 2 ^ 54 := by
      intro i hi; exact Nat.lt_trans (h_t19_bounds i hi) (by norm_num)
    obtain ⟨t20, h_pow2k, h_t20_mod, h_t20_bounds⟩ :=
      backend.serial.u64.field.FieldElement51.pow2k_spec t19 5#u32 (by omega) h_t19_bounds'
    -- Step 3: Apply mul spec (t20, t3 have limbs < 2^52 < 2^54)
    have h_t20_bounds' : ∀ i < 5, (t20[i]!).val < 2 ^ 54 := by
      intro i hi; exact Nat.lt_trans (h_t20_bounds i hi) (by norm_num)
    have h_t3_bounds' : ∀ i < 5, (t3[i]!).val < 2 ^ 54 := by
      intro i hi; exact Nat.lt_trans (h_t3_bounds i hi) (by norm_num)
    obtain ⟨r', h_mul, h_r'_mod, h_r'_bounds⟩ :=
      backend.serial.u64.field.FieldElement51.Mul.mul_spec t20 t3 h_t20_bounds' h_t3_bounds'
    -- Establish r' ≡ r^(p-2) (mod p)
    have h_r'_pow : Field51_as_Nat r' % p = (Field51_as_Nat r ^ (p - 2)) % p :=
      r'_congruence (Field51_as_Nat r) (Field51_as_Nat t19) (Field51_as_Nat t3)
        (Field51_as_Nat t20) (Field51_as_Nat r')
        h_t19_mod h_t3_mod h_t20_mod h_r'_mod
    -- Construct the result
    refine ⟨r', ?_, ?_, ?_, ?_⟩
    -- invert r = ok r'
    · simp [invert, h_pow22501, h_pow2k, h_mul]
    -- Inverse property: r' * r ≡ 1 (mod p) when r ≠ 0
    · intro hr_ne
      rw [h_r'_pow]
      exact fermat_inverse (Field51_as_Nat r) hr_ne
    -- Zero property: r ≡ 0 → r' ≡ 0
    · intro hr_zero
      rw [h_r'_pow]
      exact zero_pow_mod (Field51_as_Nat r) hr_zero (p - 2) (by unfold p; omega)
    -- Bounds
    · exact h_r'_bounds

end curve25519_dalek.field.FieldElement51

