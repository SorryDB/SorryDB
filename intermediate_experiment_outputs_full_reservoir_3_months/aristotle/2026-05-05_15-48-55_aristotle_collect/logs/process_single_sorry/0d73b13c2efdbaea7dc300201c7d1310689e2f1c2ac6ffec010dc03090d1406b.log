import ClassFieldTheory.Cohomology.IsFilterComplete
import ClassFieldTheory.Cohomology.Subrep.ShortExact
import Mathlib.RepresentationTheory.Homological.GroupCohomology.LongExactSequence

/-! # An approximation lemma

Let `M` be a filtered `G`-module, i.e. given `G`-submodules `M_i ≤ M` indexed by `i : ℕ`, such that
`M = lim[<-] M/M_i`. Now fix `q : ℕ` and suppose that `∀ i : ℕ, H^(q+1)(G, M_i/M_{i+1}) = 0`. Then
`H^(q+1)(G, M) = 0`.

-/

universe u

namespace Rep
variable {k G : Type u} [CommRing k] [Monoid G] (A : Rep k G)

end Rep

namespace IsFilterComplete

instance subrepToSubmodule {k G : Type u} [CommRing k] [Monoid G] (M : Rep k G)
    {ι : Type*} [LE ι] (M_ : ι → Subrep M) [IsFilterComplete M_] :
    IsFilterComplete fun i ↦ (M_ i).toSubmodule :=
  sorry

instance piLeft {k M ι : Type*} [Ring k] [AddCommGroup M] [Module k M]
    [LE ι] (M_ : ι → Submodule k M) [IsFilterComplete M_] (α : Type*) :
    IsFilterComplete fun i ↦ Submodule.pi .univ fun _ : α ↦ M_ i :=
  sorry

-- theorem ker {R M N ι : Type*} [Ring R] [AddCommGroup M] [Module R M]
--     [AddCommGroup N] [Module R N] [LE ι] (F : ι → Submodule R M) (G : ι → Submodule R N)
--     [IsFilterComplete F] [IsFilterComplete G]
--     (φ : M →ₗ[R] N) (hφ : ∀ i x, x ∈ F i → φ x ∈ G i) :
--     IsFilterComplete fun i ↦ (F i).submoduleOf (LinearMap.ker φ) :=
--   sorry

end IsFilterComplete

namespace groupCohomology
variable {k G : Type u} [CommRing k] [Group G] {M : Rep k G}

section
variable (M_ : ℕ → Subrep M) [IsFilterComplete M_]

open CategoryTheory ShortComplex HomologicalComplex Limits

/-- Given a subrep `w : M`, this is `C^q(w)` as a submodule of `C^q(M)`. -/
noncomputable def _root_.Subrep.toCochains (w : Subrep M) (q : ℕ) :
    Submodule k ((inhomogeneousCochains M).X q) :=
  Submodule.pi .univ fun _ ↦ w.toSubmodule

noncomputable def _root_.Subrep.toCochainsOrderHom (q : ℕ) :
    Subrep M →o Submodule k ((inhomogeneousCochains M).X q) :=
  ⟨(·.toCochains q), fun _ _ h₁ _ h₂ _ _ ↦ h₁ <| h₂ _ trivial⟩

/-- Given a subrep `w : M`, this is `Z^q(w)` as a submodule of `Z^q(M)`. -/
noncomputable def _root_.Subrep.toCocycles (w : Subrep M) (q : ℕ) :
    Submodule k (cocycles M q) :=
  (w.toCochains q).comap (iCocycles M q).hom

noncomputable def _root_.Subrep.toCocyclesOrderHom (q : ℕ) :
    Subrep M →o Submodule k (cocycles M q) :=
  ⟨(·.toCocycles q), fun _ _ h₁ _ h₂ _ _ ↦ h₁ <| h₂ _ trivial⟩

instance (q : ℕ) : IsFilterComplete fun i ↦ (M_ i).toCochains q :=
  inferInstanceAs <| IsFilterComplete fun _ ↦ Submodule.pi _ _

private lemma iCocycles_hom_injective (q : ℕ) :
    Function.Injective (iCocycles M q).hom := by
      exact (ModuleCat.mono_iff_injective (iCocycles M q)).mp inferInstance

private lemma toCocycles_hausdorff (q : ℕ) :
    IsFilterHausdorff fun i ↦ (M_ i).toCocycles q := by
      have h_cocycles_hausdorff : ∀ x : cocycles M q, (∀ i, (iCocycles M q).hom x ∈ (M_ i).toCochains q) → x = 0 := by
        intro x hx
        have h_inter : (iCocycles M q).hom x = 0 := by
          have := ‹IsFilterComplete M_›.haus';
          ext i; specialize this ( ( ModuleCat.Hom.hom ( iCocycles M q ) ) x i ) ; aesop;
        have h_inj : Function.Injective (iCocycles M q).hom := iCocycles_hom_injective q
        exact h_inj <| by simpa using h_inter;
      constructor ; aesop

/-
PROBLEM
The differential maps `C^q(M_i)` into `C^{q+1}(M_i)`.

PROVIDED SOLUTION
We need to show that d maps C^q(M_i) into C^{q+1}(M_i). Since toCochains q is `Submodule.pi .univ (fun _ => w.toSubmodule)`, a cochain x ∈ w.toCochains q means x f ∈ w for all f : Fin q → G. Similarly, d(x) ∈ w.toCochains (q+1) means (d x) g ∈ w for all g : Fin (q+1) → G. The differential d is given by inhomogeneousCochains.d which is a sum involving the G-action (ρ) and evaluations of x. Since w is a Subrep (invariant under ρ), and w.toSubmodule is closed under addition, subtraction, and scalar multiplication, all terms in d(x)(g) will be in w when x f ∈ w for all f. Specifically, d has terms like ρ(g_0)(x(g_1,...,g_q)), (-1)^i x(g_0,...,g_i·g_{i+1},...,g_q), and (-1)^{q+1} x(g_0,...,g_{q-1}), all of which are in w by the Subrep property and the hypothesis.
-/
private lemma d_mem_toCochains (w : Subrep M) (q : ℕ) (x : (inhomogeneousCochains M).X q)
    (hx : x ∈ w.toCochains q) :
    (inhomogeneousCochains M).d q (q + 1) x ∈ w.toCochains (q + 1) := by
      -- Let's choose any $f : Fin (q + 1) → G$.
      intro f
      simp [inhomogeneousCochains.d];
      refine' Submodule.add_mem _ _ _;
      · exact w.le_comap _ ( hx _ trivial );
      · refine' Submodule.sum_mem _ _;
        intro c _; specialize hx ( c.contractNth ( fun x1 x2 => x1 * x2 ) f ) ; aesop;

/-
PROBLEM
If a cochain limit L satisfies L - z_i ∈ C^q(M_i) for cocycles z_i, then d(L) = 0.

PROVIDED SOLUTION
For each i, we have iCocycles(z_i) - L ∈ (M_ i).toCochains q, so by d_mem_toCochains, d(iCocycles(z_i) - L) ∈ (M_ i).toCochains (q+1). Since d(iCocycles(z_i)) = 0 (by iCocycles_d), we get d(-L) = -d(L) ∈ (M_ i).toCochains (q+1), hence d(L) ∈ (M_ i).toCochains (q+1) for all i. By Hausdorff of the cochains filtration at degree q+1 (which we have from the IsFilterComplete instance), d(L) = 0.

Key steps:
1. Use `map_sub` and `iCocycles_d_apply` to show d(iCocycles(z_i)) = 0
2. Use `d_mem_toCochains` on the difference
3. Combine to show d(L) ∈ (M_ i).toCochains (q+1) for all i
4. Use IsFilterHausdorff to conclude d(L) = 0
-/
private lemma limit_is_cocycle (q : ℕ) (L : (inhomogeneousCochains M).X q)
    (z : ℕ → cocycles M q)
    (hL : ∀ i, (iCocycles M q).hom (z i) - L ∈ (M_ i).toCochains q) :
    (inhomogeneousCochains M).d q (q + 1) L = 0 := by
      -- By definition of `iCocycles`, we know that `d(iCocycles(z_i)) = 0`.
      have h_diff_zero : ∀ i, (inhomogeneousCochains M).d q (q + 1) ((iCocycles M q).hom (z i)) = 0 := by
        have h_diff_zero : (iCocycles M q) ≫ (inhomogeneousCochains M).d q (q + 1) = 0 := by
          exact?;
        exact fun i => by simpa using congr_arg ( fun f => f.hom ( z i ) ) h_diff_zero;
      -- By definition of `toCochains`, we know that `d(L) ∈ (M_ i).toCochains (q + 1)` for all `i`.
      have h_diff_mem : ∀ i, (inhomogeneousCochains M).d q (q + 1) L ∈ (M_ i).toCochains (q + 1) := by
        intro i
        specialize hL i
        have h_diff_mem_i : (inhomogeneousCochains M).d q (q + 1) ((iCocycles M q).hom (z i) - L) ∈ (M_ i).toCochains (q + 1) := by
          exact?
        simp_all +decide [ sub_eq_iff_eq_add ];
      -- By definition of `toCochains`, we know that `(M_ i).toCochains (q + 1)` is Hausdorff.
      have h_hausdorff : IsFilterHausdorff (fun i => (M_ i).toCochains (q + 1)) := by
        exact?;
      exact h_hausdorff.haus' _ h_diff_mem

/-
PROVIDED SOLUTION
We need: ∀ x : ℕ → cocycles M q, Cauchy → ∃ L, ∀ i, x i - L ∈ toCocycles q.

Use IsFilterPrecomplete.prec'. The Cauchy condition and membership in toCocycles unfolds via comap.

Step 1: Define y i = (iCocycles M q).hom (x i). Show y is Cauchy in the cochains filtration.
Step 2: By IsFilterPrecomplete of cochains, ∃ L_c, ∀ i, y i - L_c ∈ (M_ i).toCochains q.
Step 3: By limit_is_cocycle, d L_c = 0, so L_c is a cocycle.
Step 4: Lift L_c to L : cocycles M q using that L_c is in the kernel of d (which is the image of iCocycles).
Step 5: For each i, (iCocycles M q).hom (x i - L) = y i - L_c ∈ (M_ i).toCochains q, so x i - L ∈ (M_ i).toCocycles q.

For Step 4, use that cocycles M q = ker(d) and iCocycles is the inclusion of the kernel. To get L from L_c, use HomologicalComplex.liftCycles or something similar.
-/
private lemma toCocycles_precomplete (q : ℕ) :
    IsFilterPrecomplete fun i ↦ (M_ i).toCocycles q := by
      constructor;
      intro x hx
      set y : ℕ → (inhomogeneousCochains M).X q := fun i => (iCocycles M q).hom (x i)
      have hy_cauchy : ∀ i j, i ≤ j → y i - y j ∈ AddSubgroup.ofClass ((M_ i).toCochains q) ⊔ AddSubgroup.ofClass ((M_ j).toCochains q) := by
        intro i j hij; specialize hx i j hij; simp_all +decide [ AddSubgroup.mem_sup ] ;
        obtain ⟨ y, hy, z, hz, h ⟩ := hx; use ( iCocycles M q ).hom y, ?_, ( iCocycles M q ).hom z, ?_, ?_ <;> simp_all +decide [ AddSubgroup.ofClass ] ;
        · exact?;
        · exact?;
        · convert congr_arg ( ModuleCat.Hom.hom ( iCocycles M q ) ) h using 1 ; simp +decide [ add_sub_add_comm ];
          exact?
      obtain ⟨L_c, hL_c⟩ : ∃ L_c : (inhomogeneousCochains M).X q, ∀ i, y i - L_c ∈ (M_ i).toCochains q := by
        exact?
      have hL_c_cocycle : (inhomogeneousCochains M).d q (q + 1) L_c = 0 := by
        convert limit_is_cocycle M_ q L_c x hL_c using 1
      obtain ⟨L, hL⟩ : ∃ L : cocycles M q, (iCocycles M q).hom L = L_c := by
        refine' ⟨ _, _ ⟩;
        norm_num +zetaDelta at *;
        exact?;
        exact?
      use L
      intro i
      simp [hL] at *;
      unfold _root_.Subrep.toCocycles; aesop;

instance [IsFilterComplete M_] (q : ℕ) : IsFilterComplete fun i ↦ (M_ i).toCocycles q :=
  { toIsFilterHausdorff := toCocycles_hausdorff M_ q
    toIsFilterPrecomplete := toCocycles_precomplete M_ q }

/-- `C(w)` is isomorphic to the submodule of `C(M)` called `w.toCochains q`. -/
@[simps!] noncomputable def _root_.Subrep.toCochainsIso (w : Subrep M) (q : ℕ) :
    w.toCochains q ≃ₗ[k] (inhomogeneousCochains w.toRep).X q where
  toFun x := fun f ↦ ⟨_, x.2 f trivial⟩
  invFun x := ⟨(cochainsMap (.id G) w.subtype).f q x, fun f _ ↦ by
    simp [Subrep.subtype, Submodule.subtype]⟩
  map_add' _ _ := rfl
  map_smul' _ _ := rfl

/-- `d : C(M_i) ⟶ C(M_i)` commutes with `d : C(M) ⟶ C(M)`. -/
theorem d_toCochainsIso_symm {w : Subrep M} {q : ℕ} {x : (inhomogeneousCochains w.toRep).X q} :
    (inhomogeneousCochains M).d q (q + 1) ((w.toCochainsIso q).symm x) =
    (w.toCochainsIso (q + 1)).symm ((inhomogeneousCochains w.toRep).d q (q + 1) x) := by
  ext; simp [inhomogeneousCochains.d_hom_apply, Subrep.toCochainsIso, Subrep.toRep]

