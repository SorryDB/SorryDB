import Mathlib


namespace IMO2021P1

private lemma sqrt_ge_10 {n : ℕ} (hn : 100 ≤ n) : 10 ≤ n.sqrt := by
  exact Nat.le_sqrt.2 ( by linarith )

private lemma sum_ab_sq {k : ℕ} (hk : 10 ≤ k) :
    (2 * k ^ 2 + 3 - 4 * k) + (2 * k ^ 2 + 6 - 8 * k) = (2 * k - 3) ^ 2 := by
  zify [ hk ] ; ring;
  repeat rw [ Nat.cast_sub ] <;> push_cast <;> repeat nlinarith;

private lemma sum_bc_sq {k : ℕ} (hk : 10 ≤ k) :
    (2 * k ^ 2 + 6 - 8 * k) + (2 * k ^ 2 - 2) = (2 * k - 2) ^ 2 := by
  zify;
  repeat rw [ Nat.cast_sub ] <;> push_cast <;> repeat nlinarith;

private lemma sum_ac_sq {k : ℕ} (hk : 10 ≤ k) :
    (2 * k ^ 2 + 3 - 4 * k) + (2 * k ^ 2 - 2) = (2 * k - 1) ^ 2 := by
  zify at *;
  repeat rw [ Nat.cast_sub ] <;> push_cast <;> repeat nlinarith;

private lemma triangle_mem_a {n : ℕ} (hn : 100 ≤ n) :
    let k := n.sqrt
    n ≤ 2 * k ^ 2 + 3 - 4 * k ∧ 2 * k ^ 2 + 3 - 4 * k ≤ 2 * n := by
  constructor
  · exact le_tsub_of_add_le_left
      (by nlinarith only [hn, Nat.lt_succ_sqrt n, Nat.sqrt_le (n - 1)])
  · rw [tsub_le_iff_left]; nlinarith only [hn, Nat.sqrt_le n]

private lemma triangle_mem_b {n : ℕ} (hn : 100 ≤ n) :
    let k := n.sqrt
    n ≤ 2 * k ^ 2 + 6 - 8 * k ∧ 2 * k ^ 2 + 6 - 8 * k ≤ 2 * n := by
  constructor
  · by_contra h_contra
    exact h_contra <| Nat.le_sub_of_add_le <|
      by nlinarith only [hn, Nat.lt_succ_sqrt n,
        show n.sqrt ≥ 10 by exact le_trans (by norm_num) (Nat.sqrt_le_sqrt hn)]
  · exact Nat.sub_le_of_le_add <|
      by nlinarith only [Nat.sqrt_le n, hn]

private lemma triangle_mem_c {n : ℕ} (hn : 100 ≤ n) :
    let k := n.sqrt
    n ≤ 2 * k ^ 2 - 2 ∧ 2 * k ^ 2 - 2 ≤ 2 * n := by
  have h1 : n ≤ 2 * (Nat.sqrt n) ^ 2 - 2 := by
    by_contra h_contra
    exact h_contra <| Nat.le_sub_of_add_le <|
      by nlinarith only [hn,
        show n.sqrt ≥ 10 by exact Nat.le_sqrt.2 <| by linarith,
        Nat.lt_succ_sqrt n]
  exact ⟨h1, Nat.sub_le_of_le_add <| by nlinarith only [Nat.sqrt_le n]⟩

private lemma triangle_ne_ab {k : ℕ} (hk : 10 ≤ k) :
    2 * k ^ 2 + 3 - 4 * k ≠ 2 * k ^ 2 + 6 - 8 * k := by
  zify at *;
  rw [Nat.cast_sub, Nat.cast_sub] <;> push_cast <;> nlinarith

private lemma triangle_ne_ac {k : ℕ} (hk : 10 ≤ k) :
    2 * k ^ 2 + 3 - 4 * k ≠ 2 * k ^ 2 - 2 := by
  zify at *;
  rw [Nat.cast_sub, Nat.cast_sub] <;> push_cast <;> nlinarith

private lemma triangle_ne_bc {k : ℕ} (hk : 10 ≤ k) :
    2 * k ^ 2 + 6 - 8 * k ≠ 2 * k ^ 2 - 2 := by
  zify;
  rw [Nat.cast_sub, Nat.cast_sub] <;> push_cast <;> nlinarith

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  set k := Nat.sqrt n with hk_def
