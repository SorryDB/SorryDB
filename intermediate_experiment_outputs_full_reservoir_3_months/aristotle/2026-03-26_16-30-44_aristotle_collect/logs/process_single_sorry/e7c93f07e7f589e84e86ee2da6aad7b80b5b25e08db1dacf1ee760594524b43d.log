lemma U8x32_as_Nat_injective : Function.Injective U8x32_as_Nat := by
  -- To prove injectivity, we show that if two U8x32 arrays are different, then their corresponding natural numbers are different.
  have h_inj : ‚ąÄ a b : Array U8 32#usize, a ‚Č† b ‚Üí U8x32_as_Nat a ‚Č† U8x32_as_Nat b := by
    intro a b hab;
    -- By definition of $U8x32_as_Nat$, if $a \neq b$, then there exists some $i$ such that $a[i] \neq b[i]$.
    obtain ‚ü®i, hi‚ü© : ‚ąÉ i : Fin 32, a[i]! ‚Č† b[i]! := by
      contrapose! hab with h_eq
      generalize_proofs at *; (
      -- Since the lists are equal at every index, they are equal as lists.
      have h_list_eq : a.val = b.val := by
        refine' List.ext_get _ _ <;> simp_all +decide [ Fin.forall_fin_succ ];
        exact fun n hn => by interval_cases n <;> simp +decide [ * ] ;
      generalize_proofs at *; (
      exact Subtype.ext h_list_eq));
    -- By definition of $U8x32_as_Nat$, if $a[i] \neq b[i]$, then $2^{8i} * a[i] \neq 2^{8i} * b[i]$.
    have h_term_diff : 2^(8 * i.val) * (a[i]!).val ‚Č† 2^(8 * i.val) * (b[i]!).val := by
      cases a ; cases b ; aesop;
    grind +suggestions;
  exact fun a b h => Classical.not_not.1 fun hab => h_inj a b hab h

/-- If a 32-byte array represents a value less than `2 ^ 252`, then the high bit (bit 7) of byte 31
must be 0. -/
theorem high_bit_zero_of_lt_255 (bytes : Array U8 32#usize) (h : U8x32_as_Nat bytes < 2 ^ 255) :
    bytes.val[31]!.val >>> 7 = 0 := by
  by_contra!
  have : 2 ^ 7 ‚Č§ bytes.val[31]!.val := by omega
  have : 2 ^ 255 ‚Č§ U8x32_as_Nat bytes := by
    unfold U8x32_as_Nat
    have : ‚ąĎ i ‚ąą Finset.range 32, 2^(8*i) * bytes.val[i]!.val =
        ‚ąĎ i ‚ąą Finset.range 31, 2^(8*i) * bytes.val[i]!.val + 2^(8*31) * bytes.val[31]!.val := by
      rw [Finset.sum_range_succ]
    simp_all; grind
  grind

/-- If a 32-byte array represents a value less than `L`, then the high bit (bit 7) of byte 31
