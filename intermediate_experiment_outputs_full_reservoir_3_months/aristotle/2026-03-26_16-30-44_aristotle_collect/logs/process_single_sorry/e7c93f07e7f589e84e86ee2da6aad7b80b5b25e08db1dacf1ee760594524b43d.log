  have h_split_sum : (‚ąĎ j ‚ąą Finset.range 32, 2 ^ (8 * j) * (bytes[j]!).val) = (‚ąĎ j ‚ąą Finset.range i.val, 2 ^ (8 * j) * (bytes[j]!).val) + 2 ^ (8 * i.val) * (bytes[i]!).val + (‚ąĎ j ‚ąą Finset.Ico (i.val + 1) 32, 2 ^ (8 * j) * (bytes[j]!).val) := by
    rw [ ‚Üź Finset.sum_range_add_sum_Ico _ ( show ( i : ‚Ąē ) + 1 ‚Č§ 32 from Nat.succ_le_of_lt i.2 ) ];
    simp +arith +decide [ Finset.sum_range_succ ];
  -- The sum of terms with j < i is less than 2^(8i), so dividing by 2^(8i) gives 0.
  have h_sum_lt : (‚ąĎ j ‚ąą Finset.range i.val, 2 ^ (8 * j) * (bytes[j]!).val) < 2 ^ (8 * i.val) := by
    -- Each term in the sum is less than or equal to $2^{8j} \cdot 255$, and there are $i$ terms.
    have h_term_le : ‚ąÄ j < i.val, (bytes[j]!).val ‚Č§ 255 := by
