    refine' lt_of_le_of_lt ( Finset.sum_le_sum fun j hj => Nat.mul_le_mul_left _ ( h_term_le j ( Finset.mem_range.mp hj ) ) ) _;
    fin_cases i <;> native_decide;
  -- The sum of terms with j > i is divisible by 256, so dividing by 2^(8i) gives 0 modulo 256.
  have h_sum_div : (‚ąĎ j ‚ąą Finset.Ico (i.val + 1) 32, 2 ^ (8 * j) * (bytes[j]!).val) % (2 ^ (8 * i.val) * 256) = 0 := by
    rw [ Nat.mod_eq_zero_of_dvd ];
    refine' Finset.dvd_sum fun j hj => _;
    exact dvd_mul_of_dvd_left ( by exact dvd_trans ( by ring_nf; norm_num ) ( pow_dvd_pow _ ( show 8 * j ‚Č• 8 * ( i : ‚Ąē ) + 8 by linarith [ Finset.mem_Ico.mp hj ] ) ) ) _;
  rw [ ‚Üź Nat.dvd_iff_mod_eq_zero ] at h_sum_div; obtain ‚ü® k, hk ‚ü© := h_sum_div; simp_all +decide [ Nat.add_div, Nat.mul_div_assoc ] ;
  norm_num [ Nat.mul_assoc, Nat.mul_div_assoc, Nat.mod_eq_of_lt h_sum_lt ];
