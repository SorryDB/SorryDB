        (∑ k : Fin 3, (x k) ^ 2 - x i * x i) ∂volume =
        (8 / 15) * Real.pi * (R : ℝ) ^ 5 := by
      rw [integral_sub
        ((ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
          (by fun_prop)).integrable)
        ((ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
          (by fun_prop)).integrable),
        integral_closedBall_norm_sq]
      have : (fun x : Space 3 => x i * x i) = (fun x => (x i) ^ 2) := by ext x; ring
      rw [this, h_each]; ring
    rw [h_int, volume_closedBall_three, div_mul_eq_mul_div,
        div_eq_iff (by positivity : (4 / 3 * Real.pi * (↑R : ℝ) ^ 3) ≠ 0)]
    show (↑m : ℝ) * (8 / 15 * Real.pi * (↑R : ℝ) ^ 5) =
         2 / 5 * (↑m : ℝ) * (↑R : ℝ) ^ 2 * (4 / 3 * Real.pi * (↑R : ℝ) ^ 3)
    ring
  · simp only [hij, ite_false, zero_mul, zero_sub, mul_zero]
    rw [integral_neg, integral_closedBall_coord_mul_ne i j hij]; simp
