      ← mul_rpow]
    any_goals positivity
    rw [nnratCast_dens, le_div_iff₀, mul_comm] at hγC
    any_goals positivity
    refine rpow_le_rpow_of_nonpos ?_ hγC (neg_nonpos.2 ?_) <;> positivity
  · rw [mul_comm, mu_univ_eq_const, wLpNorm_const_right, mul_right_comm, rpow_neg, ← inv_rpow]
    any_goals positivity
    · congr
    · exact ENNReal.natCast_ne_top _
  · have : 1 ≤ γ⁻¹ := (one_le_inv₀ hγ).2 hγ₁
    have : 0 ≤ log γ⁻¹ := by bound
    calc
      γ ^ (-(↑p)⁻¹ : ℝ) = √(γ⁻¹ ^ ((↑⌈1 + log γ⁻¹⌉₊)⁻¹ : ℝ)) := by
        rw [rpow_neg hγ.le, inv_rpow hγ.le]
        unfold p
        push_cast
        rw [mul_inv_rev, rpow_mul, sqrt_eq_rpow, one_div, inv_rpow] <;> positivity
      _ ≤ √(γ⁻¹ ^ ((1 + log γ⁻¹)⁻¹ : ℝ)) := by
        gcongr
        · assumption
        · exact Nat.le_ceil _
      _ ≤ √ (exp 1) := by gcongr; exact rpow_inv_neg_curlog_le hγ.le hγ₁
      _ ≤ √ 2.7182818286 := by gcongr; exact exp_one_lt_d9.le
      _ ≤ 2 := by rw [sqrt_le_iff]; norm_num

private lemma sub_finrank_inf_le {R M : Type*} [CommRing R] [AddCommGroup M] [Module R M]
    [Module.Finite R M] [StrongRankCondition R] (s t : Submodule R M) :
    finrank R M - finrank R ↑(s ⊓ t) ≤
    (finrank R M - finrank R ↑s) + (finrank R M - finrank R ↑t) := by
  have h := Submodule.finrank_sup_add_finrank_inf_eq s t
  have hsup := Submodule.finrank_le (s ⊔ t)
  have hs := Submodule.finrank_le s
  have ht := Submodule.finrank_le t
  omega

/-
PROVIDED SOLUTION
Set S := AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker.
Use `haveI : Field (ZMod q) := ZMod.instField q hq` to make ZMod q a field.
By rank-nullity (`S.finrank_quotient_add_finrank`), `finrank G - finrank S = finrank (G ⧸ S)`.
`suffices finrank (ZMod q) (G ⧸ S) ≤ 1 by omega`.
By contradiction, assume `2 ≤ finrank (ZMod q) (G ⧸ S)`.
Then `q ^ 2 ≤ card (G ⧸ S)` via `Module.card_eq_pow_finrank` and `ZMod.card`.

Now show `card (G ⧸ S) ≤ q`:
1. `card (G ⧸ S) = card (G ⧸ γ.toAddMonoidHom.ker)` via `Submodule.Quotient.equivQuotientAddSubgroup`.
2. By first isomorphism theorem (`QuotientAddGroup.quotientKerEquivRange`), `card (G ⧸ ker) = card (γ.toAddMonoidHom.range)`.
3. Since `Additive.ofMul` is bijective and `γ.toAddMonoidHom = Additive.ofMul ∘ γ`, the range has the same cardinality as `Set.range γ` (the image of γ in ℂ). Use `Fintype.card_range`.
4. `Set.range γ ⊆ {z : ℂ | z ^ q = 1}` because for all g, `(γ g)^q = γ(q•g) = γ(0) = 1` (using `map_nsmul_eq_pow`, and `q • g = 0` since `CharP.cast_eq_zero` gives `(q : ZMod q) = 0` and `Nat.cast_smul_eq_nsmul`).
5. `card (Set.range γ) ≤ card {z : ℂ | z ^ q = 1}` by `Set.card_le_card`.
6. `card {z : ℂ | z ^ q = 1} ≤ q` - this follows from `Complex.card_rootsOfUnity` which says `card (rootsOfUnity q ℂ) = q`, and `rootsOfUnity q ℂ` is the group of q-th roots of unity as units. Since the set `{z : ℂ | z^q = 1}` injects into `rootsOfUnity q ℂ` (via `Units.mk0`), we get the bound.

This gives `card(G ⧸ S) ≤ q`, contradicting `q^2 ≤ card(G ⧸ S)` since `q ≥ 2`.
-/
private lemma sub_finrank_addChar_ker_le_one [DecidableEq G] {q : ℕ}
    [Module (ZMod q) G] [Fact (1 < q)] (hq : Nat.Prime q) (γ : AddChar G ℂ) :
    finrank (ZMod q) G - finrank (ZMod q)
      (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker) ≤ 1 := by
  haveI := Fact.mk hq; haveI := Fact.mk hq.ne_one; haveI := Fact.mk hq.ne_zero; haveI := Fact.mk hq.pos; haveI := Fact.mk hq.two_le; simp_all +decide [ AddChar ] ;
  generalize_proofs at *;
  have h_finrank_quotient : ∀ (H : Submodule (ZMod q) G), Module.finrank (ZMod q) G = Module.finrank (ZMod q) H + Module.finrank (ZMod q) (G ⧸ H) := by
    haveI := Fact.mk hq; intro H; exact (by
    rw [ ← Submodule.finrank_quotient_add_finrank H, add_comm ]);
  generalize_proofs at *; (
  have h_card_quotient : (Fintype.card (G ⧸ (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker))) ≤ q := by
    have h_card : Fintype.card (G ⧸ (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker)) ≤ Fintype.card (Additive.ofMul '' Set.range γ) := by
      have h_card : Fintype.card (G ⧸ (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker)) = Fintype.card (Additive.ofMul '' Set.range γ) := by
        refine' Fintype.card_congr _;
        refine' Equiv.ofBijective ( fun x => Quotient.liftOn' x ( fun x => ⟨ _, Set.mem_image_of_mem _ ( Set.mem_range_self x ) ⟩ ) _ ) ⟨ _, _ ⟩
        generalize_proofs at *; (
        intro a b hab; rcases hab with ⟨ k, hk ⟩ ; simp_all +decide [ AddChar.toAddMonoidHom ] ;
        simp +decide [ ← hk, AddChar.map_add_eq_mul ];
        exact γ.map_add_eq_mul _ _ ▸ by aesop;);
        · intro x y hxy
          generalize_proofs at *; (
          obtain ⟨ a, rfl ⟩ := QuotientAddGroup.mk_surjective x; obtain ⟨ b, rfl ⟩ := QuotientAddGroup.mk_surjective y; simp_all +decide [ QuotientAddGroup.eq ] ;
          rw [ QuotientAddGroup.eq ] ; simp_all +decide [ AddSubgroup.mem_toAddSubmonoid, AddSubgroup.mem_bot ] ;
          simp +decide [ hxy, AddChar.map_add_eq_mul ];
          rw [ ← hxy, ← AddChar.map_add_eq_mul ] ; simp +decide [ AddChar.map_zero_eq_one ] ;);
        · intro x
          generalize_proofs at *; (
          rcases x with ⟨ x, hx ⟩
          generalize_proofs at *; (
          rcases hx with ⟨ y, ⟨ z, rfl ⟩, rfl ⟩ ; exact ⟨ Quotient.mk'' z, rfl ⟩ ;))
      generalize_proofs at *; (exact h_card.le)
    generalize_proofs at *; (
    have h_card_range : Set.range γ ⊆ {z : ℂ | z ^ q = 1} := by
      rintro _ ⟨ x, rfl ⟩
      generalize_proofs at *; (
      have h_card_range : γ (q • x) = 1 := by
        have h_card_range : q • x = 0 := by
          rw [← Nat.cast_smul_eq_nsmul (ZMod q), CharP.cast_eq_zero, zero_smul]
        generalize_proofs at *; (
        rw [ h_card_range, AddChar.map_zero_eq_one ])
      generalize_proofs at *; (
      have h_card_range : γ (q • x) = (γ x) ^ q := by
        exact γ.map_nsmul_eq_pow q x
      generalize_proofs at *; (
      aesop)))
    generalize_proofs at *; (
    have h_card_roots : (Set.range γ).toFinset.card ≤ q := by
      have h_card_roots : (Set.range γ).toFinset ⊆ Multiset.toFinset (Polynomial.roots (Polynomial.X ^ q - 1 : Polynomial ℂ)) := by
        simp_all +decide [ Finset.subset_iff, Set.subset_def ];
        exact Polynomial.X_pow_sub_C_ne_zero ( by linarith [ Fact.out ( p := 1 < q ) ] ) _
      generalize_proofs at *; (
      exact le_trans ( Finset.card_le_card h_card_roots ) ( le_trans ( Multiset.toFinset_card_le _ ) ( by exact le_trans ( Polynomial.card_roots' _ ) ( by erw [ Polynomial.natDegree_X_pow_sub_C ] ) ) ))
    generalize_proofs at *; (
    simp_all +decide [ Set.toFinset_card ];
    grind)))
  generalize_proofs at *; (
  have h_card_quotient_eq : (Fintype.card (G ⧸ (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker))) = q ^ (Module.finrank (ZMod q) (G ⧸ (AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker))) := by
    have h_card_quotient_eq : ∀ (H : Submodule (ZMod q) G), (Fintype.card (G ⧸ H)) = q ^ (Module.finrank (ZMod q) (G ⧸ H)) := by
      intro H
      have h_iso : (G ⧸ H) ≃ₗ[ZMod q] (Fin (Module.finrank (ZMod q) (G ⧸ H)) → ZMod q) := by
        haveI := Fact.mk hq; exact (LinearEquiv.ofFinrankEq _ _ <| by simp +decide [ h_finrank_quotient H ] ;) ;
      have := Fintype.card_congr h_iso.toEquiv; simp_all +decide [ Fintype.card_pi ] ;
    generalize_proofs at *; (
    exact h_card_quotient_eq _ ▸ rfl)
  generalize_proofs at *; (
  contrapose! h_card_quotient; simp_all +decide [ pow_succ' ] ;
  exact lt_self_pow₀ hq.one_lt ( by linarith [ h_finrank_quotient ( AddSubgroup.toZModSubmodule q γ.toAddMonoidHom.ker ) ] ) ;)))

/-
PROVIDED SOLUTION
By Finset.induction on Δ'.

Base case (Δ' = ∅): The iInf over the empty set is ⊤. So toZModSubmodule q ⊤ = ⊤ (since toZModSubmodule is an order iso mapping ⊤ to ⊤). finrank ⊤ = finrank G, so codim = 0 ≤ 0.

Step: Suppose the result holds for s, prove for insert a s (with a ∉ s).
We have ⨅ γ ∈ insert a s, γ.toAddMonoidHom.ker = a.toAddMonoidHom.ker ⊓ ⨅ γ ∈ s, γ.toAddMonoidHom.ker.
Apply toZModSubmodule (order iso) to get toZModSubmodule(ker a ⊓ ⨅ s) = toZModSubmodule(ker a) ⊓ toZModSubmodule(⨅ s) (using map_inf).

Then: codim(toZModSubmodule(ker a) ⊓ toZModSubmodule(⨅ s)) ≤ codim(toZModSubmodule(ker a)) + codim(toZModSubmodule(⨅ s))
    by sub_finrank_inf_le.
codim(toZModSubmodule(ker a)) ≤ 1 by sub_finrank_addChar_ker_le_one.
codim(toZModSubmodule(⨅ s)) ≤ s.card by the IH.
So ≤ 1 + s.card = (insert a s).card.
-/
private lemma sub_finrank_biInf_addChar_ker_le [DecidableEq G] {q : ℕ}
    [Module (ZMod q) G] [Fact (1 < q)] (hq : Nat.Prime q) (Δ' : Finset (AddChar G ℂ)) :
    finrank (ZMod q) G - finrank (ZMod q)
      (AddSubgroup.toZModSubmodule q (⨅ γ ∈ Δ', γ.toAddMonoidHom.ker)) ≤ Δ'.card := by
  revert Δ';
  intro s; induction s using Finset.induction <;> simp_all +decide [ Finset.card_insert_of_notMem, Finset.card_singleton ] ;
  · convert Nat.sub_self _;
    fapply LinearEquiv.finrank_eq;
    refine' { Equiv.ofBijective ( fun x => x.1 ) ⟨ fun x y hxy => _, fun x => _ ⟩ with .. } <;> aesop;
  · rename_i a s ha ih;
    -- Apply the sub_finrank_inf_le lemma to the submodules corresponding to a and s.
    have h_sub_finrank_inf_le : finrank (ZMod q) G - finrank (ZMod q) ↥((AddSubgroup.toZModSubmodule q) (a.toAddMonoidHom.ker ⊓ ⨅ γ ∈ s, γ.toAddMonoidHom.ker)) ≤ (finrank (ZMod q) G - finrank (ZMod q) ↥((AddSubgroup.toZModSubmodule q) (a.toAddMonoidHom.ker))) + (finrank (ZMod q) G - finrank (ZMod q) ↥((AddSubgroup.toZModSubmodule q) (⨅ γ ∈ s, γ.toAddMonoidHom.ker))) := by
      convert sub_finrank_inf_le ( AddSubgroup.toZModSubmodule q a.toAddMonoidHom.ker ) ( AddSubgroup.toZModSubmodule q ( ⨅ γ ∈ s, γ.toAddMonoidHom.ker ) ) using 1;
    -- Apply the sub_finrank_addChar_ker_le_one lemma to the submodule corresponding to a.
    have h_sub_finrank_addChar_ker_le_one : finrank (ZMod q) G - finrank (ZMod q) ↥((AddSubgroup.toZModSubmodule q) (a.toAddMonoidHom.ker)) ≤ 1 := by
      exact sub_finrank_addChar_ker_le_one hq a
    rw [ show ( ⨅ γ ∈ insert a s, γ.toAddMonoidHom.ker ) = a.toAddMonoidHom.ker ⊓ ⨅ γ ∈ s, γ.toAddMonoidHom.ker from ?_ ];
    · omega;
    · ext; simp [Finset.mem_insert, Finset.mem_singleton]

variable {q n : ℕ} [Module (ZMod q) G] {A₁ A₂ : Finset G} (S : Finset G) {α : ℝ}

set_option linter.flexible false in
lemma ap_in_ff [DecidableEq G] (hq₃ : 3 ≤ q) (hq : q.Prime) (hα₀ : 0 < α) (hα₂ : α ≤ 2⁻¹)
    (hε₀ : 0 < ε) (hε₁ : ε ≤ 1) (hαA₁ : α ≤ A₁.dens) (hαA₂ : α ≤ A₂.dens) :
    ∃ (V : Submodule (ZMod q) G) (_ : DecidablePred (· ∈ V)),
        ↑(finrank (ZMod q) G - finrank (ZMod q) V) ≤ 2 ^ 32 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2 ∧
          |∑ x ∈ S, (μ (Set.toFinset V) ∗ μ A₁ ∗ μ A₂) x - ∑ x ∈ S, (μ A₁ ∗ μ A₂) x| ≤ ε := by
  classical
  let _ : MeasurableSpace G := ⊤
  have : Fact (1 < q) := sorry
  have : DiscreteMeasurableSpace G := ⟨fun _ ↦ trivial⟩
  have hA₁ : A₁.Nonempty := by simpa using hα₀.trans_le hαA₁
  have hA₂ : A₂.Nonempty := by simpa using hα₀.trans_le hαA₂
  have hα₁ : α ≤ 1 := hαA₁.trans <| mod_cast A₁.dens_le_one
  have : 0 ≤ log α⁻¹ := by bound
  have : 0 ≤ log (ε * α)⁻¹ := by bound
  obtain rfl | hS := S.eq_empty_or_nonempty
  · exact ⟨⊤, inferInstance, by simp [hε₀.le]; positivity⟩
  have hA₁ : σ[A₁, univ] ≤ α⁻¹ :=
    calc
      _ ≤ (A₁.dens⁻¹ : ℝ) := by norm_cast; exact addConst_le_inv_dens
      _ ≤ α⁻¹ := by gcongr
  let k : ℕ := ⌈𝓛 (ε * α / 4)⌉₊
  have hk₀ : 0 < k := Nat.ceil_pos.2 <| curlog_pos (by positivity) <|
    calc
      ε * α / 4 ≤ ε * 1 / 4 := by gcongr
      _ ≤ 1 := by linarith
  obtain ⟨T, hTcard, hTε⟩ := AlmostPeriodicity.linfty_almost_periodicity_boosted ε hε₀ hε₁ k
    (by positivity) (le_inv_of_le_inv₀ (by positivity) hα₂) hA₁ univ_nonempty S A₂ hS hA₂
  have hT : 0 < (#T : ℝ) := hTcard.trans_lt' (by positivity)
  replace hT : T.Nonempty := by simpa using hT
  let Δ := largeSpec (μ T) 2⁻¹
  let V : Submodule (ZMod q) G := AddSubgroup.toZModSubmodule _ <| ⨅ γ ∈ Δ, γ.toAddMonoidHom.ker
  let V' : Finset G := Set.toFinset V
  refine ⟨V, inferInstance, ?_, ?_⟩
  · obtain ⟨Δ', hΔ'Δ, hΔ'card, hfΔ'⟩ : ∃ Δ' ⊆ Δ, _ := chang (mu_ne_zero.2 hT) (by norm_num)
    let W : Submodule (ZMod q) G := AddSubgroup.toZModSubmodule _ <| ⨅ γ ∈ Δ', γ.toAddMonoidHom.ker
    have mem_W {x} : x ∈ W ↔ ∀ γ ∈ Δ', γ x = 1 := by simp [W]
    have hWV : W ≤ V := by sorry
    have :=
      calc
        log T.dens⁻¹ ≤ log (α⁻¹ ^ (-4096 * ⌈𝓛 (min 1 (#A₂ / #S))⌉ * k ^ 2 / ε ^ 2))⁻¹ := by
          gcongr; rwa [nnratCast_dens, le_div_iff₀]; positivity
        _ = 2 ^ 12 * log α⁻¹ * ⌈𝓛 (min 1 (#A₂ / #S))⌉ * k ^ 2 / ε ^ 2 := by
          rw [log_inv, log_rpow (by positivity)]; ring_nf
        _ ≤ 2 ^ 12 * log α⁻¹ * ⌈𝓛 (min 1 A₂.dens)⌉ * k ^ 2 / ε ^ 2 := by
          rw [nnratCast_dens, ← card_univ]; gcongr; exact S.subset_univ
        _ ≤ 2 ^ 12 * log α⁻¹ * ⌈𝓛 (min 1 α)⌉ * (k) ^ 2 / ε ^ 2 := by gcongr
        _ = 2 ^ 12 * log α⁻¹ * ⌈𝓛 α⌉ * k ^ 2 / ε ^ 2 := by rw [min_eq_right hα₁]
        _ ≤ 2 ^ 12 * 𝓛 α * (2 * 𝓛 α) * (2 ^ 3 * 𝓛 (ε * α)) ^ 2 / ε ^ 2 := by
          gcongr
          · exact le_add_of_nonneg_left zero_le_one
          · exact Int.ceil_le_two_mul <| two_inv_lt_one.le.trans <| one_le_curlog hα₀.le hα₁
          · calc
              k ≤ 2 * 𝓛 (ε * α / 4) :=
                Nat.ceil_le_two_mul <| two_inv_lt_one.le.trans <| one_le_curlog (by positivity)
                  sorry
              _ ≤ 2 * (4 * 𝓛 (ε * α)) := by
                gcongr
                exact curlog_div_le (by positivity) (mul_le_one₀ hε₁ hα₀.le hα₁) (by norm_num)
              _ = 2 ^ 3 * 𝓛 (ε * α) := by ring
        _ = 2 ^ 19 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2 := by ring_nf
    calc
      (↑(finrank (ZMod q) G - finrank (ZMod q) V) : ℝ)
        ≤ ↑(finrank (ZMod q) G - finrank (ZMod q) W) := by
        gcongr; exact Submodule.finrank_mono hWV
      _ ≤ #Δ' := Nat.cast_le.mpr (sub_finrank_biInf_addChar_ker_le hq Δ')
      _ ≤ ⌈changConst * exp 1 * ⌈𝓛 ↑(‖μ T‖_[1] ^ 2 / ‖μ T‖_[2] ^ 2 / card G)⌉₊ / 2⁻¹ ^ 2⌉₊ := by
        gcongr
      _ = ⌈2 ^ 7 * exp 1 ^ 2 * ⌈𝓛 T.dens⌉₊⌉₊ := by
        simp [hT, ← rpow_mul_natCast, dens, changConst, -exp_one_pow, rpow_neg_one]; ring_nf
      _ ≤ ⌈2 ^ 7 * 2 ^ 3 * (2 * 𝓛 T.dens)⌉₊ := by
        gcongr
        · calc
            exp 1 ^ 2 ≤ 2.7182818286 ^ 2 := by gcongr; exact exp_one_lt_d9.le
            _ ≤ 2 ^ 3 := by norm_num
        · exact Nat.ceil_le_two_mul <| two_inv_lt_one.le.trans <|
            one_le_curlog (by positivity) <| mod_cast T.dens_le_one
      _ = ⌈2 ^ 11 * 𝓛 T.dens⌉₊ := by ring_nf
      _ ≤ 2 * (2 ^ 11 * 𝓛 T.dens) := Nat.ceil_le_two_mul <|
          calc
            (2⁻¹ : ℝ) ≤ 2 ^ 11 * 1 := by norm_num
            _ ≤ 2 ^ 11 * 𝓛 T.dens := by
              gcongr; exact one_le_curlog (by positivity) <| mod_cast T.dens_le_one
      _ = 2 ^ 12 * 𝓛 T.dens := by ring
      _ ≤ 2 ^ 12 * (1 + 2 ^ 19 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2) := by gcongr
      _ ≤ 2 ^ 12 * (2 ^ 19 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2 +
            2 ^ 19 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2) := by
        gcongr
        sorry
      _ = 2 ^ 32 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2 := by ring
  · have : ∑ x ∈ S, (μ_[ℝ] V' ∗ μ A₁ ∗ μ A₂) x = 𝔼 x ∈ V', (μ A₁ ∗ μ A₂ ○ 𝟭 S) x := by
      have : -V' = V' := by ext; simp [V']
      rw [← mu_wInner_one, ← indicate_wInner_one, conv_rotate,
        ← dconv_wInner_one_eq_wInner_one_conv, wInner_one_dconv_eq_conv_wInner_one, ← conv_conjneg,
        conjneg_mu, this, conv_comm]
    have : ∑ x ∈ S, (μ_[ℝ] A₁ ∗ μ A₂) x = (μ_[ℝ] A₁ ∗ μ A₂ ○ 𝟭 S) 0 := by simp [dconv_indicate]
    sorry

lemma ap_in_ff' [DecidableEq G] (hq₃ : 3 ≤ q) (hq : q.Prime) (hα₀ : 0 < α) (hα₂ : α ≤ 2⁻¹)
    (hε₀ : 0 < ε) (hε₁ : ε ≤ 1) (hαA₁ : α ≤ A₁.dens) (hαA₂ : α ≤ A₂.dens) :
    ∃ (V : Submodule (ZMod q) G) (_ : DecidablePred (· ∈ V)),
        ↑(finrank (ZMod q) G - finrank (ZMod q) V) ≤ 2 ^ 32 * 𝓛 α ^ 2 * 𝓛 (ε * α) ^ 2 * ε⁻¹ ^ 2 ∧
          |∑ x ∈ S, (μ (Set.toFinset V) ∗ μ A₁ ○ μ A₂) x - ∑ x ∈ S, (μ A₁ ○ μ A₂) x| ≤ ε := by
  simpa [← conjneg_mu] using ap_in_ff S hq₃ hq (A₂ := -A₂) hα₀ hα₂ hε₀ hε₁ hαA₁ (by simpa)

set_option linter.flexible false in
set_option maxHeartbeats 400000 in
-- FIXME: Get rid of raised heartbeats
lemma di_in_ff [DecidableEq G] [MeasurableSpace G] [DiscreteMeasurableSpace G] (hq₃ : 3 ≤ q)
    (hq : q.Prime) (hε₀ : 0 < ε) (hε₁ : ε < 1) (hγC : γ ≤ C.dens) (hγ : 0 < γ)
    (hAC : ε ≤ |card G * ⟪μ_[ℝ] A ∗ μ A, μ C⟫_[ℝ] - 1|) :
    ∃ (V : Submodule (ZMod q) G) (_ : DecidablePred (· ∈ V)),
        ↑(finrank (ZMod q) G - finrank (ZMod q) V) ≤
            2 ^ 132 * 𝓛 A.dens ^ 4 * 𝓛 γ ^ 4 / ε ^ 16 ∧
          (1 + ε / 32) * A.dens ≤ ‖𝟭_[ℝ] A ∗ μ (Set.toFinset V)‖_[∞] := by
  have hγ₁ : γ ≤ 1 := hγC.trans (by norm_cast; exact dens_le_one)
  let α : ℝ := A.dens
  let p : ℕ := 2 * ⌈𝓛 γ⌉₊
  let f : G → ℝ := balance (μ A)
  obtain rfl | hA₀ := A.eq_empty_or_nonempty
  · exact ⟨⊤, Classical.decPred _, by simp; positivity⟩
  obtain ⟨p', hp', unbalancing⟩ :
    ∃ p' : ℕ, p' ≤ 2 ^ 10 * (ε / 2)⁻¹ ^ 2 * p ∧
      1 + ε / 2 / 2 ≤ ‖card G • (f ○ f) + 1‖_[p', μ univ] := by
    refine unbalancing _ (mul_ne_zero two_ne_zero (Nat.ceil_pos.2 <| curlog_pos hγ.le hγ₁).ne')
      (ε / 2) (by positivity) (div_le_one_of_le₀ (hε₁.le.trans <| by norm_num) <| by norm_num)
