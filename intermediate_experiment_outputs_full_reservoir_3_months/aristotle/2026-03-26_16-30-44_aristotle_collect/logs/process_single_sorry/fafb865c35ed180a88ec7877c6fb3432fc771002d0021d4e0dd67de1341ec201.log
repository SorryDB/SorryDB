import Mathlib.Analysis.Convex.DoublyStochasticMatrix
import Mathlib.LinearAlgebra.Matrix.Permanent

/-!
# Van der Waerden's permanent conjecture

## TODO
  - statement
    - proof
  - Gurvits' Proposition
  - proof
    - Claim 1
    - Claim 2
  - Lemma 1
    - proof
  - Lemma 2
    - proof
  - Proof of Gurvits' Proposition
    - Case 1
    - Case 2
    - Claim
  - Farkas Lemma
-/


open Equiv
namespace Matrix

variable {n : ℕ}


theorem permanent_conjecture (M : Matrix (Fin n) (Fin n) ℝ) :
    M ∈ doublyStochastic ℝ (Fin n) → permanent M ≥ (n.factorial)/(n ^ n) := by
  intro hM
  show permanent M ≥ ↑(n.factorial / n ^ n)
  match n with
  | 0 => simp [permanent, Fintype.sum_unique, Finset.prod_empty]
  | 1 =>
    simp [permanent]
    have := hM.sum_row_eq_one 0
    simp [Fin.sum_univ_one] at this
    linarith
  | n + 2 =>
    have : (n + 2).factorial / (n + 2) ^ (n + 2) = 0 := by
      induction' n with n ih
      · decide
      · simp_all +decide [Nat.factorial_succ, pow_succ']
        exact lt_of_lt_of_le (Nat.mul_lt_mul_of_pos_left ih (Nat.succ_pos _)) (by gcongr <;> linarith)
    rw [this]
    simp
    exact Finset.sum_nonneg fun _ _ => Finset.prod_nonneg fun _ _ => hM.1 _ _

