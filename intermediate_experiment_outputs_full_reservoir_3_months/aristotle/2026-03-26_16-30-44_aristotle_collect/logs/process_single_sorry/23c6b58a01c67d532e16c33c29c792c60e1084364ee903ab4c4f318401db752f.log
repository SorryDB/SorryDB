          grind +ring;
        simp_all +decide [ sub_eq_iff_eq_add ];
        exact ht_values.resolve_right fun h => hABC.2.1 <| by ext i; fin_cases i <;> nlinarith! only [ h ] ;
      cases ht_values <;> simp_all +decide [ sub_eq_iff_eq_add ];
      · exact hABC.1 ( by ext i; fin_cases i <;> aesop );
      · exact hABC.2.2 ( by ext i; fin_cases i <;> aesop );
    rw [ Real.sqrt_inj ( by positivity ) ( by positivity ) ] at *;
    rw [ Real.sqrt_inj ( by positivity ) ( by positivity ) ] at hP;
    grind +ring
  aesop

