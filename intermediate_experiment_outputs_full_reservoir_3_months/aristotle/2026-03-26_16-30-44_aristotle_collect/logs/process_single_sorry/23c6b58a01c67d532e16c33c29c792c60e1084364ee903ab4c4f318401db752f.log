/-- For every n ≥ 3, there exists a balanced set of n points in the plane. -/
lemma balanced_exists_all (n : ℕ) (hn : 3 ≤ n)
    (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C) :
    ∃ s, Balanced s ∧ s.card = n := by
