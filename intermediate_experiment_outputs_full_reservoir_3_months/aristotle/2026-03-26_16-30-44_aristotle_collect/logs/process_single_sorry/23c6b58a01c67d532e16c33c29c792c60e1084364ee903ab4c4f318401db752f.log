import Imo.ProblemImports

open scoped Real
open scoped Nat

/-!
## IMO 2015 Problem 1

We prove two results about balanced and center-free point sets in the plane:
(a) For all n ≥ 3, there exists a balanced set of n points.
(b) The set of n ≥ 3 for which balanced center-free sets of size n exist
    is exactly {n ≥ 3 | n is odd}.
-/

section helpers

set_option maxHeartbeats 800000

/-! ### Counting argument: balanced center-free sets have odd cardinality

Key idea: For each point P in a balanced center-free set S of size n,
P can witness equidistance for at most ⌊(n-1)/2⌋ pairs (since center-free
means each distance class from P has ≤ 2 elements). Balanced means the
total witness count ≥ C(n,2). For even n, this leads to contradiction.
-/

/-
PROBLEM
If a finite set of points is balanced and center-free, its cardinality is odd.

PROVIDED SOLUTION
Proof by contradiction: assume Even s.card.

The key double-counting argument:

For each P ∈ s, consider the partition of (s.erase P) by distance from P. Center-free ensures no distance class has 3+ elements. So each class has size ≤ 2.

The number of UNORDERED pairs {A,B} ⊂ s \ {P} with dist(P,A) = dist(P,B) equals the number of distance classes of size exactly 2. Call this f(P). Since 2·f(P) + (number of singletons) = s.card - 1, and s.card - 1 is odd (as s.card is even), 2·f(P) = s.card - 1 - (singletons) is odd minus an odd number... Actually 2·f(P) ≤ s.card - 1. Since 2·f(P) is even and s.card-1 is odd, 2·f(P) ≤ s.card - 2, so f(P) ≤ (s.card-2)/2.

By balanced: each unordered pair {A,B} ⊂ s has at least one witness P ∈ s with dist(P,A)=dist(P,B) and P ∉ {A,B}. So ∑_{P ∈ s} f(P) ≥ C(s.card, 2) = s.card*(s.card-1)/2.

But ∑ f(P) ≤ s.card * (s.card-2)/2 (since f(P) ≤ (s.card-2)/2 for each P).

So s.card*(s.card-1)/2 ≤ s.card*(s.card-2)/2. Since s.card ≥ 3: (s.card-1) ≤ (s.card-2), contradiction.

For the Lean proof: use by_contra to assume ¬Odd s.card, deduce Even s.card. Then work with natural number arithmetic. The key is to avoid defining f(P) explicitly - instead, directly bound the sum and use omega/linarith for the final contradiction.

A cleaner approach: just prove that s.card * (s.card - 1) ≤ s.card * (s.card - 2) leads to contradiction when s.card ≥ 3. The bound comes from:
- Lower bound: balanced gives at least s.card * (s.card-1) ordered pairs (A,B) witnessed
- Upper bound: center-free + s.card even gives at most s.card * (s.card - 2) ordered witness pairs
Then omega gives the contradiction.
-/
lemma balanced_center_free_odd
    (s : Finset (EuclideanSpace ℝ (Fin 2)))
    (hs : 3 ≤ s.card)
    (hbal : ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (hcf : ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C →
      ¬∃ P ∈ s, dist P A = dist P B ∧ dist P B = dist P C) :
    Odd s.card := by
  by_contra h_even_card;
  -- For each point P in S, consider the partition of (S \ {P}) by distance from P. Center-free ensures no distance class has 3+ elements. So each class has size ≤ 2.
  have h_partition : ∀ P ∈ s, ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card = (s.card - 1) := by
    intro P hP; rw [ ← Finset.card_eq_sum_card_fiberwise ] ; aesop;
    exact fun x hx => Finset.mem_image_of_mem _ hx;
  -- Since S is center-free, each distance class has size at most 2.
  have h_distance_class_size : ∀ P ∈ s, ∀ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card ≤ 2 := by
    intros P hP r hr
    have h_dist_class_size : ∀ Q ∈ Finset.filter (fun Q => dist P Q = r) (s.erase P), ∀ R ∈ Finset.filter (fun Q => dist P Q = r) (s.erase P), Q ≠ R → ¬∃ S ∈ s, dist P S = r ∧ S ≠ Q ∧ S ≠ R := by
      grind;
    by_cases h : ∃ Q ∈ Finset.filter (fun Q => dist P Q = r) (s.erase P), ∃ R ∈ Finset.filter (fun Q => dist P Q = r) (s.erase P), Q ≠ R;
    · obtain ⟨ Q, hQ, R, hR, hQR ⟩ := h;
      exact le_trans ( Finset.card_le_card ( show { Q ∈ s.erase P | dist P Q = r } ⊆ { Q, R } from fun x hx => by_contradiction fun hx' => h_dist_class_size Q hQ R hR hQR ⟨ x, by aesop ⟩ ) ) ( Finset.card_insert_le _ _ ) |> le_trans <| by norm_num;
    · exact le_trans ( Finset.card_le_one.mpr fun x hx y hy => Classical.not_not.1 fun hxy => h ⟨ x, hx, y, hy, hxy ⟩ ) ( by norm_num );
  -- Since S is balanced, each unordered pair {A,B} ⊂ S has at least one witness P ∈ S with dist(P,A)=dist(P,B) and P∉{A,B}.
  have h_witness_count : ∑ P ∈ s, ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card.choose 2 ≥ s.card * (s.card - 1) / 2 := by
    -- Each unordered pair {A,B} ⊂ S has at least one witness P ∈ S with dist(P,A)=dist(P,B) and P∉{A,B}.
    have h_witness_count : ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ P ∈ s, P ≠ A ∧ P ≠ B ∧ dist P A = dist P B := by
      intro A hA B hB hAB
      obtain ⟨C, hC⟩ := hbal A hA B hB hAB
      by_cases hCA : C = A ∨ C = B;
      · rcases hCA with ( rfl | rfl ) <;> simp_all +decide [ dist_comm ];
      · exact ⟨ C, hC.1, by tauto, by tauto, by simpa only [ dist_comm ] using hC.2 ⟩;
    -- Each unordered pair {A,B} ⊂ S is counted at least once in the sum.
    have h_pair_count : ∑ P ∈ s, ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card.choose 2 ≥ Finset.card (Finset.powersetCard 2 s) := by
      have h_pair_count : Finset.powersetCard 2 s ⊆ Finset.biUnion s (fun P => Finset.biUnion (Finset.image (fun Q => dist P Q) (s.erase P)) (fun r => Finset.powersetCard 2 (Finset.filter (fun Q => dist P Q = r) (s.erase P)))) := by
        intro x hx; simp_all +decide [ Finset.mem_powersetCard ] ;
        obtain ⟨ A, B, hAB ⟩ := Finset.card_eq_two.mp hx.2; simp_all +decide [ Finset.subset_iff ] ;
        grind;
      refine le_trans ( Finset.card_le_card h_pair_count ) ?_;
      refine' le_trans ( Finset.card_biUnion_le ) _;
      exact Finset.sum_le_sum fun P hP => Finset.card_biUnion_le.trans <| Finset.sum_le_sum fun r hr => by simp +decide [ Finset.card_powersetCard ] ;
    simp_all +decide [ Nat.choose_two_right ];
  -- Since each distance class has size at most 2, the number of pairs in each distance class is at most 1.
  have h_pair_count : ∀ P ∈ s, ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card.choose 2 ≤ (s.card - 1) / 2 := by
    intros P hP
    have h_pair_count : ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card.choose 2 ≤ ∑ r ∈ (s.erase P).image (fun Q => dist P Q), (Finset.filter (fun Q => dist P Q = r) (s.erase P)).card / 2 := by
      exact Finset.sum_le_sum fun x hx => by have := h_distance_class_size P hP x hx; interval_cases _ : Finset.card ( Finset.filter ( fun Q => dist P Q = x ) ( s.erase P ) ) <;> trivial;
    refine le_trans h_pair_count ?_;
    rw [ ← h_partition P hP ];
    rw [ Nat.le_div_iff_mul_le zero_lt_two ] ; rw [ Finset.sum_mul _ _ _ ] ; exact Finset.sum_le_sum fun x hx => by linarith [ Nat.div_mul_le_self ( Finset.card ( Finset.filter ( fun Q => dist P Q = x ) ( s.erase P ) ) ) 2 ] ;
  have := Finset.sum_le_sum h_pair_count; simp_all +decide ;
  rcases h_even_card with ⟨ k, hk ⟩ ; simp_all +decide [ Nat.mul_div_assoc ];
  rw [ Nat.div_le_iff_le_mul_add_pred ] at h_witness_count <;> norm_num at *;
  rcases k with ( _ | _ | k ) <;> simp_all +arith +decide [ Nat.mul_succ ];
  norm_num [ Nat.add_div ] at * ; nlinarith only [ this, h_witness_count ]

/-! ### Regular n-gon construction for odd n

For odd n ≥ 3, the vertices of a regular n-gon on the unit circle form
a balanced, center-free set.
-/

/-- Point on the unit circle at angle 2πk/n -/
noncomputable def regPoint (n : ℕ) (k : ℕ) : EuclideanSpace ℝ (Fin 2) :=
  EuclideanSpace.equiv (Fin 2) ℝ |>.symm
    ![Real.cos (2 * Real.pi * k / n), Real.sin (2 * Real.pi * k / n)]

/-- The finset of vertices of a regular n-gon -/
noncomputable def regNgon (n : ℕ) : Finset (EuclideanSpace ℝ (Fin 2)) :=
  (Finset.range n).image (regPoint n)

/-
PROBLEM
The regular n-gon has exactly n vertices for n ≥ 1.

PROVIDED SOLUTION
Need to show (Finset.range n).image (regPoint n) has cardinality n. This requires showing regPoint n is injective on Finset.range n.

regPoint n is injective: if regPoint n a = regPoint n b with a, b ∈ Finset.range n (i.e., a, b < n), then cos(2πa/n) = cos(2πb/n) and sin(2πa/n) = sin(2πb/n). This means 2πa/n = 2πb/n + 2kπ for some integer k, so a/n = b/n + k, so a - b = kn. Since |a - b| < n (both in {0,...,n-1}), we need k = 0, hence a = b.

Use Finset.card_image_of_injOn and prove the injectivity using Real.cos_eq_cos_iff or similar.
-/
lemma regNgon_card (n : ℕ) (hn : 1 ≤ n) : (regNgon n).card = n := by
  -- To prove the cardinality is n, we show that the function regPoint n is injective on Finset.range n.
  have h_inj : ∀ k m : ℕ, k < n → m < n → regPoint n k = regPoint n m → k = m := by
    intros k m hk hm h_eq
    have h_cos : Real.cos (2 * Real.pi * k / n) = Real.cos (2 * Real.pi * m / n) := by
      convert congr_arg ( fun x : EuclideanSpace ℝ ( Fin 2 ) => x 0 ) h_eq using 1
    have h_sin : Real.sin (2 * Real.pi * k / n) = Real.sin (2 * Real.pi * m / n) := by
      convert congr_arg ( fun x : EuclideanSpace ℝ ( Fin 2 ) => x 1 ) h_eq using 1;
    have h_eq : Real.cos (2 * Real.pi * (k - m) / n) = 1 := by
      simp_all +decide [ mul_sub, sub_div, Real.cos_sub ];
      rw [ ← sq, ← sq, Real.cos_sq_add_sin_sq ];
    rw [ Real.cos_eq_one_iff ] at h_eq;
    obtain ⟨ l, hl ⟩ := h_eq; rw [ eq_div_iff ( by positivity ) ] at hl; rcases l with ⟨ _ | l ⟩ <;> norm_num at hl;
    · exact_mod_cast sub_eq_zero.mp hl;
    · exact_mod_cast ( by nlinarith [ Real.pi_pos, ( by norm_cast : ( k : ℝ ) < n ), ( by norm_cast : ( m : ℝ ) < n ), mul_pos Real.pi_pos ( by positivity : 0 < ( n : ℝ ) ) ] : ( k : ℝ ) = m );
    · nlinarith [ Real.pi_pos, mul_pos Real.pi_pos ( show 0 < ( n : ℝ ) by positivity ), show ( k : ℝ ) < n by norm_cast, show ( m : ℝ ) < n by norm_cast, mul_le_mul_of_nonneg_left ( show ( k : ℝ ) + 1 ≤ n by norm_cast ) Real.pi_pos.le, mul_le_mul_of_nonneg_left ( show ( m : ℝ ) + 1 ≤ n by norm_cast ) Real.pi_pos.le ];
  rw [ regNgon, Finset.card_image_of_injOn fun k hk l hl hkl => h_inj k l ( Finset.mem_range.mp hk ) ( Finset.mem_range.mp hl ) hkl, Finset.card_range ]

/-
PROBLEM
The regular n-gon is balanced for odd n ≥ 3.

PROVIDED SOLUTION
For odd n ≥ 3, the regular n-gon is balanced.

Key insight: For two vertices at positions a and b (0 ≤ a, b < n, a ≠ b), the vertex at position c is equidistant from them iff the angular distance from c to a equals the angular distance from c to b on the circle. This happens when c is at the "midpoint angle" of a and b.

For positions a and b: if a+b is even, then c = (a+b)/2 mod n is a valid vertex position, and it's equidistant from a and b. If a+b is odd, then c = (a+b+n)/2 mod n is a valid vertex position (since n is odd, a+b+n is even), and it's equidistant.

The distance from vertex c to vertex a on a circle of radius 1 is 2|sin(π(c-a)/n)|. For the midpoint c, the angular distances to a and b are equal, so the chord distances are equal.

Formalization approach: Given A, B ∈ regNgon n, extract their indices a, b < n. Define c based on the parity of a+b. Show regPoint n c ∈ regNgon n and dist(regPoint n a)(regPoint n c) = dist(regPoint n b)(regPoint n c).

The distance equality follows from: if c = (a+b)/2, then |c-a| = |b-a|/2 = |c-b|, so sin(π|c-a|/n) = sin(π|c-b|/n). If c = (a+b+n)/2, then the angular distances from c to a and from c to b satisfy a symmetry that makes the sines equal.
-/
lemma regNgon_balanced (n : ℕ) (hn : 3 ≤ n) (hodd : Odd n) :
    ∀ A ∈ regNgon n, ∀ B ∈ regNgon n, A ≠ B →
    ∃ C ∈ regNgon n, dist A C = dist B C := by
  unfold regNgon;
  -- Let's choose any two distinct points A and B in the image of regPoint n over the range n.
  intro A hA B hB hAB
  obtain ⟨a, ha, rfl⟩ := Finset.mem_image.mp hA
  obtain ⟨b, hb, rfl⟩ := Finset.mem_image.mp hB
  have h_ne : a ≠ b := by
    aesop;
  -- Define $c$ as $(a + b) / 2 \mod n$ if $a + b$ is even, or $(a + b + n) / 2 \mod n$ if $a + b$ is odd.
  obtain ⟨c, hc⟩ : ∃ c : ℕ, c ∈ Finset.range n ∧ (2 * c ≡ a + b [MOD n]) := by
    -- Since $n$ is odd, $2$ has a multiplicative inverse modulo $n$, denoted as $2^{-1}$.
    obtain ⟨inv2, hinv2⟩ : ∃ inv2 : ℕ, 2 * inv2 ≡ 1 [MOD n] := by
      exact ⟨ ( n + 1 ) / 2, by rw [ mul_comm, Nat.div_mul_cancel ( even_iff_two_dvd.mp ( by simpa [ parity_simps ] using hodd ) ) ] ; norm_num [ Nat.ModEq ] ⟩;
    use (a + b) * inv2 % n;
    simp_all +decide [ ← ZMod.natCast_eq_natCast_iff, mul_assoc ];
    exact ⟨ Nat.mod_lt _ ( by positivity ), by linear_combination' hinv2 * ( a + b ) ⟩;
  refine' ⟨ regPoint n c, Finset.mem_image_of_mem _ hc.1, _ ⟩ ; simp_all +decide [ dist_eq_norm, EuclideanSpace.norm_eq ];
  -- By definition of $regPoint$, we know that $regPoint n a = (\cos(2\pi a / n), \sin(2\pi a / n))$, $regPoint n b = (\cos(2\pi b / n), \sin(2\pi b / n))$, and $regPoint n c = (\cos(2\pi c / n), \sin(2\pi c / n))$.
  have h_coords : ∀ k : ℕ, regPoint n k = ![Real.cos (2 * Real.pi * k / n), Real.sin (2 * Real.pi * k / n)] := by
    unfold regPoint; aesop;
  -- Using the fact that $2c \equiv a + b \pmod{n}$, we can simplify the expressions for the distances.
  have h_simplify : Real.cos (2 * Real.pi * (a - c) / n) = Real.cos (2 * Real.pi * (c - b) / n) := by
    rw [ Real.cos_eq_cos_iff ];
    obtain ⟨ k, hk ⟩ := hc.2.symm.dvd;
    field_simp;
    exact ⟨ k, Or.inl <| by push_cast [ ← @Int.cast_inj ℝ ] at *; linarith ⟩;
  simp_all +decide [ Real.cos_sub, Real.sin_sub, mul_sub, sub_div ];
  exact congrArg Real.sqrt ( by linarith [ Real.sin_sq_add_cos_sq ( 2 * Real.pi * a / n ), Real.sin_sq_add_cos_sq ( 2 * Real.pi * b / n ), Real.sin_sq_add_cos_sq ( 2 * Real.pi * c / n ) ] )

/-
PROBLEM
The regular n-gon is center-free for n ≥ 3.

PROVIDED SOLUTION
For n ≥ 3, the regular n-gon on the unit circle is center-free.

Suppose for contradiction there exist distinct A, B, C ∈ regNgon n and P ∈ regNgon n with dist(P,A) = dist(P,B) = dist(P,C). Then A, B, C are all on a circle of radius r centered at P, where r = dist(P,A). But A, B, C are also on the unit circle centered at the origin. Two distinct circles intersect in at most 2 points. Since A, B, C are 3 distinct points on both circles, the circles must be identical. This means the unit circle centered at origin equals the circle of radius r centered at P. So P = origin and r = 1. But the origin is NOT a vertex of the regular n-gon for n ≥ 3 (vertices are on the unit circle, not at the center). Contradiction.

Actually P is a vertex, so P is on the unit circle. If dist(P,A) = dist(P,B) = dist(P,C) = r, then A, B, C lie on the circle of radius r centered at P. They also lie on the unit circle centered at origin. These two circles intersect in at most 2 points (unless they're the same circle). Since A, B, C are 3 distinct points on both, the circles must coincide: same center (P = origin) and same radius (r = 1). But |P| = 1 ≠ 0, so P ≠ origin. Contradiction.
-/
lemma regNgon_center_free (n : ℕ) (hn : 3 ≤ n) :
    ∀ A ∈ regNgon n, ∀ B ∈ regNgon n, ∀ C ∈ regNgon n,
    A ≠ B ∧ B ≠ C ∧ A ≠ C →
    ¬∃ P ∈ regNgon n, dist P A = dist P B ∧ dist P B = dist P C := by
  intro A hA B hB C hC hABC
  intro ⟨P, hP⟩
  have hP_on_unit_circle : dist P 0 = 1 := by
    obtain ⟨ k, hk, rfl ⟩ := Finset.mem_image.mp hP.1; simp +decide [ EuclideanSpace.norm_eq ] ; ring;
    erw [ show ( regPoint n k ).ofLp 0 = Real.cos ( 2 * Real.pi * k / n ) by rfl, show ( regPoint n k ).ofLp 1 = Real.sin ( 2 * Real.pi * k / n ) by rfl ] ; simp +decide [ Real.cos_sq' ] ;
  have hA_on_unit_circle : dist A 0 = 1 := by
    obtain ⟨ k, hk, rfl ⟩ := Finset.mem_image.mp hA; simp +decide [ EuclideanSpace.norm_eq, Fin.sum_univ_two ] ; ring ;
    unfold regPoint; norm_num [ Real.cos_sq' ] ;
  have hB_on_unit_circle : dist B 0 = 1 := by
    obtain ⟨ k, hk, rfl ⟩ := Finset.mem_image.mp hB; simp +decide [ EuclideanSpace.norm_eq, Fin.sum_univ_two ] ; ring ;
    erw [ show ( regPoint n k ).ofLp 0 = Real.cos ( 2 * Real.pi * k / n ) by rfl, show ( regPoint n k ).ofLp 1 = Real.sin ( 2 * Real.pi * k / n ) by rfl ] ; simp +decide [ Real.cos_sq' ] ;
  have hC_on_unit_circle : dist C 0 = 1 := by
    obtain ⟨ k, hk, rfl ⟩ := Finset.mem_image.mp hC; simp +decide [ EuclideanSpace.norm_eq, Fin.sum_univ_two ] ; ring ;
    erw [ show ( regPoint n k ).ofLp 0 = Real.cos ( 2 * Real.pi * k / n ) by rfl, show ( regPoint n k ).ofLp 1 = Real.sin ( 2 * Real.pi * k / n ) by rfl ] ; simp +decide [ Real.cos_sq' ] ;
  have hP.intersect : dist P A = dist P B ∧ dist P B = dist P C → P = 0 := by
    simp_all +decide [ dist_eq_norm, EuclideanSpace.norm_eq ];
    -- Since $A$, $B$, and $C$ are distinct points on the unit circle, we have $A \neq B$, $B \neq C$, and $A \neq C$.
    have h_distinct : (A.ofLp 0 - B.ofLp 0) * (B.ofLp 1 - C.ofLp 1) - (A.ofLp 1 - B.ofLp 1) * (B.ofLp 0 - C.ofLp 0) ≠ 0 := by
      intro h_det_zero;
      -- Since $A$, $B$, and $C$ are distinct points on the unit circle, we have $A \neq B$, $B \neq C$, and $A \neq C$, which implies that $A$, $B$, and $C$ are collinear.
      have h_collinear : ∃ t : ℝ, A.ofLp 0 = B.ofLp 0 + t * (C.ofLp 0 - B.ofLp 0) ∧ A.ofLp 1 = B.ofLp 1 + t * (C.ofLp 1 - B.ofLp 1) := by
        by_cases h_cases : C.ofLp 0 = B.ofLp 0;
        · by_cases h_cases : C.ofLp 1 = B.ofLp 1 <;> simp_all +decide [ sub_eq_iff_eq_add ];
          · exact False.elim <| hABC.2.1 <| by ext i; fin_cases i <;> aesop;
          · exact ⟨ h_det_zero.resolve_right ( by aesop ), ( A.ofLp 1 - B.ofLp 1 ) / ( C.ofLp 1 - B.ofLp 1 ), by rw [ div_mul_cancel₀ _ ( sub_ne_zero_of_ne h_cases ) ] ; ring ⟩;
        · use (A.ofLp 0 - B.ofLp 0) / (C.ofLp 0 - B.ofLp 0);
          grind;
      obtain ⟨ t, ht₀, ht₁ ⟩ := h_collinear;
      -- Since $A$, $B$, and $C$ are distinct points on the unit circle, we have $t = 0$ or $t = 1$.
      have ht_values : t = 0 ∨ t = 1 := by
