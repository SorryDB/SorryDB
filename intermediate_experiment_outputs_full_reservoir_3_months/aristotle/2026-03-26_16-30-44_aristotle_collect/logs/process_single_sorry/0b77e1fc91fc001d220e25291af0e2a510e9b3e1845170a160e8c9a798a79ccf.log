lemma integrable_one_sub_cos_div_rpow (t : ℝ) :
    MeasureTheory.IntegrableOn
      (fun s => (1 - Real.cos (s * t)) / s ^ (3/2 : ℝ)) (Set.Ioi 0) := by
  -- We split the integral into two parts: over $(0, 1]$ and over $(1, \infty)$.
  have h_split : MeasureTheory.IntegrableOn (fun s : ℝ => (1 - Real.cos (s * t)) / s ^ (3 / 2 : ℝ)) (Set.Ioc 0 1) ∧ MeasureTheory.IntegrableOn (fun s : ℝ => (1 - Real.cos (s * t)) / s ^ (3 / 2 : ℝ)) (Set.Ioi 1) := by
    constructor;
    · -- For $s \in (0, 1]$, we have $|1 - \cos(st)| \leq (st)^2 / 2$, thus $|(1 - \cos(st)) / s^{3/2}| \leq t^2 s^{1/2} / 2$.
      have h_bound : ∀ s ∈ Set.Ioc 0 1, abs ((1 - Real.cos (s * t)) / s ^ (3 / 2 : ℝ)) ≤ t^2 * s ^ (1 / 2 : ℝ) / 2 := by
        -- Using the fact that $|1 - \cos(st)| \leq (st)^2 / 2$, we get:
        have h_bound : ∀ s ∈ Set.Ioc 0 1, abs (1 - Real.cos (s * t)) ≤ (s * t)^2 / 2 := by
          -- Using the trigonometric identity $1 - \cos(x) = 2 \sin^2(x/2)$ and the fact that $|\sin(x)| \leq |x|$ for all $x$, we get:
          have h_sin_bound : ∀ x : ℝ, |1 - Real.cos x| ≤ 2 * (x / 2) ^ 2 := by
            -- Using the trigonometric identity $1 - \cos(x) = 2 \sin^2(x/2)$ and the fact that $|\sin(x)| \leq |x|$ for all $x$, we get $|1 - \cos(x)| \leq 2 \left(\frac{x}{2}\right)^2$.
            intros x
            have h_sin_bound : |Real.sin (x / 2)| ≤ |x / 2| := by
              exact Real.abs_sin_le_abs (x / 2);
            rw [ show 1 - Real.cos x = 2 * Real.sin ( x / 2 ) ^ 2 by rw [ Real.sin_sq, Real.cos_sq ] ; ring ] ; rw [ abs_le ] ; constructor <;> cases abs_cases ( x / 2 ) <;> nlinarith [ abs_le.mp h_sin_bound ] ;
          exact fun s hs => le_trans ( h_sin_bound _ ) ( by ring_nf; norm_num );
        intro s hs; rw [ abs_div, abs_of_nonneg ( Real.rpow_nonneg hs.1.le _ ) ] ; convert div_le_div_of_nonneg_right ( h_bound s hs ) ( Real.rpow_nonneg hs.1.le _ ) using 1 ; ring; norm_num [ ← Real.rpow_neg hs.1.le, ← Real.rpow_add hs.1 ] ; ring;
        norm_num [ mul_assoc, ← Real.rpow_add hs.1 ];
        exact Or.inl ( by rw [ ← Real.rpow_natCast, ← Real.rpow_add hs.1 ] ; norm_num );
      refine' MeasureTheory.Integrable.mono' _ _ _;
      refine' fun s => t ^ 2 * s ^ ( 1 / 2 : ℝ ) / 2;
      · exact Continuous.integrableOn_Ioc ( by exact Continuous.div_const ( continuous_const.mul ( continuous_id.rpow_const <| by norm_num ) ) _ );
      · exact Measurable.aestronglyMeasurable ( by exact Measurable.mul ( measurable_const.sub ( Real.continuous_cos.measurable.comp ( measurable_id'.mul_const _ ) ) ) ( measurable_id'.pow_const _ |> Measurable.inv ) );
      · filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioc ] with s hs using h_bound s hs;
    · have h_integrable : MeasureTheory.IntegrableOn (fun s : ℝ => 2 / s ^ (3 / 2 : ℝ)) (Set.Ioi 1) := by
        have h_integrable : MeasureTheory.IntegrableOn (fun s : ℝ => s ^ (-3 / 2 : ℝ)) (Set.Ioi 1) := by
          rw [ integrableOn_Ioi_rpow_iff ] <;> norm_num;
        refine' h_integrable.const_mul 2 |> fun h => h.congr _;
        filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioi ] with x hx using by norm_num [ div_eq_mul_inv, Real.rpow_neg ( le_of_lt ( zero_lt_one.trans hx ) ) ] ;
      refine' h_integrable.mono' _ _;
      · exact Measurable.aestronglyMeasurable ( by exact Measurable.mul ( measurable_const.sub ( Real.continuous_cos.measurable.comp ( measurable_id'.mul_const _ ) ) ) ( measurable_id'.pow_const _ |> Measurable.inv ) );
      · filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioi ] with x hx using by rw [ Real.norm_of_nonneg ( div_nonneg ( sub_nonneg.2 ( Real.cos_le_one _ ) ) ( Real.rpow_nonneg ( by linarith [ hx.out ] ) _ ) ) ] ; exact div_le_div_of_nonneg_right ( by nlinarith [ Real.cos_sq' ( x * t ) ] ) ( Real.rpow_nonneg ( by linarith [ hx.out ] ) _ ) ;
  convert h_split.1.union h_split.2 using 1 ; norm_num

/-
PROBLEM
The integral representation: √|t| = C * ∫_0^∞ (1 - cos(st)) / s^{3/2} ds

PROVIDED SOLUTION
The proof proceeds by cases on whether t = 0 or not.

Case t = 0: Both sides are 0. √|0| = 0 and the integral is ∫ (1 - cos(s*0))/s^{3/2} ds = ∫ 0 ds = 0.

Case t ≠ 0: Use substitution u = |t| * s. Then:
- cos(s * t) = cos(u * (t/|t|)) = cos(±u) = cos(u) (since cos is even: Real.cos_neg)
- s = u/|t|, ds = du/|t|
- s^{3/2} = (u/|t|)^{3/2} = u^{3/2} / |t|^{3/2}

So ∫₀^∞ (1-cos(st))/s^{3/2} ds = ∫₀^∞ (1-cos u) * |t|^{3/2} / (u^{3/2} * |t|) du
= |t|^{1/2} * ∫₀^∞ (1-cos u)/u^{3/2} du = √|t| * (1/C_sqrt)

Therefore C_sqrt * ∫ = C_sqrt * √|t| / C_sqrt = √|t|.

For the substitution, use MeasureTheory.integral_comp_mul_right or MeasureTheory.integral_comp_mul_left. The key identity is:
∫₀^∞ f(cs) ds = (1/c) ∫₀^∞ f(u) du for c > 0

C_sqrt = (∫₀^∞ (1-cos s)/s^{3/2} ds)⁻¹ by definition.

Use Real.sqrt_eq_rpow to write √|t| = |t|^{1/2} = |t|^(1/2 : ℝ).
-/
lemma sqrt_abs_eq_integral (t : ℝ) :
    √|t| = C_sqrt * ∫ s in Set.Ioi (0 : ℝ), (1 - Real.cos (s * t)) / s ^ (3/2 : ℝ) := by
  by_cases ht : t = 0;
  · aesop;
  · -- Use the substitution $u = |t|s$. Then $du = |t|ds$ or $ds = du/|t|$.
    have h_subst : (∫ s in Set.Ioi 0, (1 - Real.cos (s * t)) / s ^ (3 / 2 : ℝ)) = (∫ u in Set.Ioi 0, (1 - Real.cos (u)) / (u / |t|) ^ (3 / 2 : ℝ)) / |t| := by
      have h_subst : ∀ {f : ℝ → ℝ}, ∫ s in Set.Ioi 0, f (s * |t|) = (∫ u in Set.Ioi 0, f u) / |t| := by
        intro f; rw [ div_eq_inv_mul ] ; rw [ MeasureTheory.integral_comp_mul_right_Ioi ] ; norm_num [ ht ] ; ring;
        positivity;
      convert h_subst using 1;
      cases abs_cases t <;> simp +decide [ * ];
    -- Simplify the expression inside the integral.
    have h_simplify : (∫ u in Set.Ioi 0, (1 - Real.cos u) / (u / |t|) ^ (3 / 2 : ℝ)) = |t| ^ (3 / 2 : ℝ) * (∫ u in Set.Ioi 0, (1 - Real.cos u) / u ^ (3 / 2 : ℝ)) := by
      rw [ ← MeasureTheory.integral_const_mul ] ; refine' MeasureTheory.setIntegral_congr_fun measurableSet_Ioi fun u hu => _ ; rw [ Real.div_rpow ( le_of_lt hu ) ( by positivity ) ] ; ring;
      norm_num ; ring;
    rw [ h_subst, h_simplify, Real.sqrt_eq_rpow ];
    rw [ show ( 3 / 2 : ℝ ) = 1 / 2 + 1 by norm_num, Real.rpow_add ] <;> norm_num [ ht ];
    field_simp;
    exact Eq.symm ( inv_mul_cancel₀ <| ne_of_gt <| integral_one_sub_cos_pos )

/-
PROVIDED SOLUTION
Use sqrt_abs_eq_integral to rewrite each √|x_i ± x_j| as C_sqrt * ∫ (1 - cos(s*(x_i ± x_j))) / s^{3/2} ds. Then interchange the finite sums with the integral (using Fubini/sum of integrals). The resulting integrand is C_sqrt * [∑_{i,j} (cos(s*(x_i - x_j)) - cos(s*(x_i + x_j)))] / s^{3/2}, which is nonneg by sum_cos_diff_nonneg and s^{3/2} > 0 for s > 0, and C_sqrt > 0.

Key steps:
1. simp_rw [sqrt_abs_eq_integral] to rewrite √|·|
2. Use Finset.sum properties and MeasureTheory.integral tools to interchange sum and integral
3. Show the integrand is nonneg using sum_cos_diff_nonneg and div_nonneg
4. Use MeasureTheory.setIntegral_nonneg or MeasureTheory.integral_nonneg

Use C_sqrt_pos, integrable_one_sub_cos_div_rpow, sum_cos_diff_nonneg from this file.
-/
theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  -- Apply the integral representation to rewrite the sums.
  have h_subst_sum : (∑ i, (∑ j, (Real.sqrt (abs ((x i) - (x j)))))) =
    C_sqrt * ∫ s in (Set.Ioi 0), (∑ i, (∑ j, ((1 - (Real.cos (s * ((x i) - (x j))))) / s ^ (3 / 2 : ℝ)))) ∧
    (∑ i, (∑ j, (Real.sqrt (abs ((x i) + (x j)))))) =
    C_sqrt * ∫ s in (Set.Ioi 0), (∑ i, (∑ j, ((1 - (Real.cos (s * ((x i) + (x j))))) / s ^ (3 / 2 : ℝ)))) := by
      constructor <;> rw [ MeasureTheory.integral_finset_sum ];
      · rw [ Finset.mul_sum _ _ _ ];
        exact Finset.sum_congr rfl fun i _ => by rw [ MeasureTheory.integral_finset_sum _ fun j _ => integrable_one_sub_cos_div_rpow _ ] ; exact by rw [ Finset.mul_sum ] ; exact Finset.sum_congr rfl fun j _ => by rw [ sqrt_abs_eq_integral ] ;
      · intro i hi; refine' MeasureTheory.integrable_finset_sum _ _; intros j hj; exact ( by simpa using ( integrable_one_sub_cos_div_rpow ( x i - x j ) ) ) ;
      · rw [ Finset.mul_sum _ _ _ ];
        refine' Finset.sum_congr rfl fun i _ => _;
        rw [ MeasureTheory.integral_finset_sum ];
        · rw [ Finset.mul_sum _ _ _ ] ; congr ; ext j ; rw [ sqrt_abs_eq_integral ];
        · exact fun j _ => integrable_one_sub_cos_div_rpow _ |> fun h => h.congr ( by filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioi ] with a ha using by ring );
      · intro i hi; refine' MeasureTheory.integrable_finset_sum _ _; intros j hj; exact ( by simpa using ( integrable_one_sub_cos_div_rpow ( x i + x j ) ) ) ;
  -- Use the fact that the integrand is nonnegative to conclude the proof.
  have h_integrand_nonneg : ∀ s ∈ Set.Ioi (0 : ℝ), (∑ i, (∑ j, ((1 - (Real.cos (s * ((x i) - (x j))))) / s ^ (3 / 2 : ℝ)))) ≤
                               (∑ i, (∑ j, ((1 - (Real.cos (s * ((x i) + (x j))))) / s ^ (3 / 2 : ℝ)))) := by
                                 intro s hs; have := sum_cos_diff_nonneg x s; simp_all +decide [ Finset.sum_div _ _ _ ] ;
                                 norm_num [ ← Finset.sum_div _ _ _ ] at * ; gcongr;
  refine' h_subst_sum.1.symm ▸ h_subst_sum.2.symm ▸ mul_le_mul_of_nonneg_left ( MeasureTheory.integral_mono_of_nonneg _ _ _ ) ( le_of_lt ( C_sqrt_pos ) );
  · filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioi ] with s hs using Finset.sum_nonneg fun i _ => Finset.sum_nonneg fun j _ => div_nonneg ( sub_nonneg.2 ( Real.cos_le_one _ ) ) ( Real.rpow_nonneg hs.out.le _ );
  · have h_integrable : ∀ i j : Fin n, MeasureTheory.IntegrableOn (fun s => (1 - Real.cos (s * (x i + x j))) / s ^ (3 / 2 : ℝ)) (Set.Ioi (0 : ℝ)) := by
      intro i j; exact integrable_one_sub_cos_div_rpow (x i + x j);
    exact MeasureTheory.integrable_finset_sum _ fun i _ => MeasureTheory.integrable_finset_sum _ fun j _ => h_integrable i j;
  · filter_upwards [ MeasureTheory.ae_restrict_mem measurableSet_Ioi ] with s hs using h_integrand_nonneg s hs

end IMO2021P2

