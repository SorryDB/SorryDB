import Mathlib

namespace IMO2021P2

-- Helper: for any s, the cos difference decomposes as 2 * sin * sin
lemma cos_diff_identity (s a b : ℝ) :
    Real.cos (s * (a - b)) - Real.cos (s * (a + b)) = 2 * Real.sin (s * a) * Real.sin (s * b) := by
  have h := Real.two_mul_sin_mul_sin (s * a) (s * b)
  ring_nf at h ⊢
  linarith

-- Helper: the double sum of cos differences equals 2 * (sum of sines)^2
lemma sum_cos_eq_two_mul_sq {n : ℕ} (x : Fin n → ℝ) (s : ℝ) :
    ∑ i, ∑ j, (Real.cos (s * (x i - x j)) - Real.cos (s * (x i + x j))) =
    2 * (∑ i, Real.sin (s * x i)) ^ 2 := by
  simp_rw [cos_diff_identity]
  rw [Finset.sum_comm (f := fun i j => 2 * Real.sin (s * x i) * Real.sin (s * x j))]
  simp_rw [← Finset.mul_sum, ← Finset.sum_mul]
  ring

-- Helper: the double sum of cos differences is nonneg
lemma sum_cos_diff_nonneg {n : ℕ} (x : Fin n → ℝ) (s : ℝ) :
    0 ≤ ∑ i, ∑ j, (Real.cos (s * (x i - x j)) - Real.cos (s * (x i + x j))) := by
  rw [sum_cos_eq_two_mul_sq]
  positivity

-- The integral representation constant
noncomputable def C_sqrt : ℝ := (∫ s in Set.Ioi (0 : ℝ), (1 - Real.cos s) / s ^ (3/2 : ℝ))⁻¹

/-
PROBLEM
The integral is positive

PROVIDED SOLUTION
Show the integral ∫₀^∞ (1 - cos s) / s^{3/2} ds is positive. The integrand is nonneg (since 1 - cos s ≥ 0 and s^{3/2} > 0 for s > 0) and strictly positive on a set of positive measure (e.g., on (0, π), 1 - cos s > 0). Use MeasureTheory.setIntegral_pos_iff_support_of_nonneg_ae or MeasureTheory.integral_pos_of_pos_of_support to show the integral is positive. The integrand is measurable and integrable (shown separately), and is strictly positive on (0, π) which has positive Lebesgue measure.
-/
lemma integral_one_sub_cos_pos :
    0 < ∫ s in Set.Ioi (0 : ℝ), (1 - Real.cos s) / s ^ (3/2 : ℝ) := by
  rw [ MeasureTheory.integral_pos_iff_support_of_nonneg_ae ] <;> norm_num;
  · refine' ( lt_of_lt_of_le _ ( MeasureTheory.measure_mono _ ) );
    swap;
    exact Set.Ioo 0 ( Real.pi / 2 );
    · simpa using by positivity;
    · exact fun x hx => ⟨ ⟨ ne_of_gt <| sub_pos.mpr <| by nlinarith [ Real.sin_sq_add_cos_sq x, Real.sin_pos_of_pos_of_lt_pi hx.1 <| by linarith [ Real.pi_pos, hx.2 ] ], ne_of_gt <| Real.rpow_pos_of_pos hx.1 _ ⟩, hx.1 ⟩;
  · exact Filter.eventually_inf_principal.mpr ( Filter.Eventually.of_forall fun x hx => div_nonneg ( sub_nonneg.mpr ( Real.cos_le_one x ) ) ( Real.rpow_nonneg hx.out.le _ ) );
  · -- We'll use the fact that if the denominator grows faster than the numerator, the integral converges.
    have h_integrable : MeasureTheory.IntegrableOn (fun s : ℝ => (1 - Real.cos s) / s ^ (3 / 2 : ℝ)) (Set.Ioi 0) := by
      -- We can split the integral into two parts: one over $(0, \pi)$ and one over $(\pi, \infty)$.
      have h_split : MeasureTheory.IntegrableOn (fun s : ℝ => (1 - Real.cos s) / s ^ (3 / 2 : ℝ)) (Set.Ioc 0 Real.pi) ∧ MeasureTheory.IntegrableOn (fun s : ℝ => (1 - Real.cos s) / s ^ (3 / 2 : ℝ)) (Set.Ioi Real.pi) := by
        constructor;
        · -- We'll use the fact that $1 - \cos s$ is bounded above by $s^2 / 2$ for all $s$.
