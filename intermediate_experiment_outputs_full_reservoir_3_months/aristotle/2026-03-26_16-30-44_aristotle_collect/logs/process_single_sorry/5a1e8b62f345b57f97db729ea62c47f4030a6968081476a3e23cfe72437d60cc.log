import Imo.ProblemImports

open scoped Real
open scoped Nat

private def imo1988_g (m : ℕ) : ℕ :=
  match m with
  | 0 => 0
  | 1 => 1
  | 2 => 1
  | 3 => 3
  | n + 4 =>
    if (n + 4) % 2 = 0 then imo1988_g ((n + 4) / 2)
    else if (n + 4) % 4 = 1 then
      2 * imo1988_g ((n + 4 + 1) / 2) - imo1988_g ((n + 4 - 1) / 4)
    else
      3 * imo1988_g ((n + 4 - 1) / 2) - 2 * imo1988_g ((n + 4 - 3) / 4)
  termination_by m
  decreasing_by all_goals omega

private lemma f_eq_imo1988_g (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1)
    (h₂ : f 3 = 3) (h₃ : ∀ n > 0, f (2 * n) = f n)
    (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    ∀ n, 0 < n → f n = imo1988_g n := by
  intro n hn; induction' n using Nat.strongRecOn with n ih; rcases Nat.even_or_odd' n with ⟨ k, rfl | rfl ⟩ <;> norm_num at *;
  · rw [ h₃ k hn, ih k ( by linarith ) hn ];
    -- By definition of $g$, we know that if $n$ is even, then $g(n) = g(n/2)$.
    have h_even : ∀ n, n > 0 → n % 2 = 0 → imo1988_g n = imo1988_g (n / 2) := by
      intro n hn h_even; rcases n with ( _ | _ | _ | _ | n ) <;> simp_all +arith +decide;
      · native_decide +revert;
      · rw [ imo1988_g ] ; aesop;
    rw [ h_even ( 2 * k ) ( by positivity ) ( by norm_num ), Nat.mul_div_cancel_left _ ( by positivity ) ];
  · rcases Nat.even_or_odd' k with ⟨ k, rfl | rfl ⟩;
    · rcases k with ( _ | k ) <;> simp_all +arith +decide [ Nat.mul_succ ];
      · native_decide +revert;
      · convert h₄ ( k + 1 ) ( by linarith ) using 1;
        rw [ ih ( 2 * ( k + 1 ) + 1 ) ( by linarith ) ( by linarith ), ih ( k + 1 ) ( by linarith ) ( by linarith ) ];
        rw [ imo1988_g ] ; norm_num [ Nat.add_mod, Nat.mul_mod ] ; ring;
        norm_num [ show 6 + k * 4 = 2 * ( 3 + k * 2 ) by ring, Nat.add_div ];
    · rcases k with ( _ | k ) <;> simp +arith +decide [ * ] at *;
      · native_decide +revert;
      · convert h₅ ( k + 1 ) ( by linarith ) using 1;
        rw [ ih, ih ] <;> norm_num [ Nat.mul_succ ];
        · rw [ imo1988_g ] ; norm_num [ Nat.add_mod, Nat.mul_mod ] ; ring;
          norm_num [ show 6 + k * 4 = 2 * ( 3 + k * 2 ) by ring, show 7 + k * 4 - 3 = 4 * ( 1 + k ) by rw [ Nat.sub_eq_of_eq_add ] ; ring ];
        · grind;
        · linarith

private lemma imo1988_count :
    (Finset.filter (fun n => imo1988_g n = n) (Finset.Icc 1 1988)).card = 92 := by
  native_decide

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = answer(92) := by
  have heq := f_eq_imo1988_g f h₀ h₁ h₂ h₃ h₄ h₅
  have : Finset.filter (fun n => f n = n) (Finset.Icc 1 1988) =
         Finset.filter (fun n => imo1988_g n = n) (Finset.Icc 1 1988) := by
    apply Finset.filter_congr
    intro x hx
    rw [Finset.mem_Icc] at hx
    rw [heq x (by omega)]
  rw [this]
  exact imo1988_count
