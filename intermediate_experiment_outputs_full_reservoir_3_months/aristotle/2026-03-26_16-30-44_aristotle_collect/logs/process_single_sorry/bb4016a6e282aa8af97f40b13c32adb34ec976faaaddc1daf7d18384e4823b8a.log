/-! ### Helper lemmas for IMO 1984 P5 -/

-- Perimeter is positive
private lemma perimeter_pos' {n : ℕ} [NeZero n] (hn : n > 3)
    (P : Fin n → EuclideanSpace ℝ (Fin 2))
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    : (0 : ℝ) < ∑ i, dist (P i) (P (i+1)) := by
  by_contra h_dist_zero
  have h_eq : ∃ i, P i = P (i + 1) := by
    exact not_forall_not.mp fun contra => h_dist_zero <| Finset.sum_pos ( fun x hx => dist_pos.mpr <| contra x ) ⟨ 0, Finset.mem_univ _ ⟩;
  obtain ⟨ i, hi ⟩ := h_eq; specialize hP ( i + 1 ) ( i - 1 ) ; simp_all +decide [ sub_eq_iff_eq_add, add_assoc ] ;
  rcases n with ( _ | _ | _ | n ) <;> norm_num at *;
  rcases n with ( _ | _ | n ) <;> cases hP

-- Crossing segments inequality
private lemma crossing_segments_ineq'
    {V : Type*} [NormedAddCommGroup V] [NormedSpace ℝ V] [StrictConvexSpace ℝ V]
    {A B C D Q : V}
    (hQ_AC : ∃ t : ℝ, 0 < t ∧ t < 1 ∧ Q = A + t • (C - A))
    (hQ_BD : ∃ s : ℝ, 0 < s ∧ s < 1 ∧ Q = B + s • (D - B))
    (hABnc : ¬Collinear ℝ ({(A : V), B, Q} : Set V))
    : dist A C + dist B D > dist A B + dist C D := by
  obtain ⟨t, ht_pos, ht_lt_1, hQ⟩ := hQ_AC
  obtain ⟨s, hs_pos, hs_lt_1, hQ'⟩ := hQ_BD
  have h_dist_AC : dist A C = dist A Q + dist Q C := by
    simp +decide [ hQ, dist_eq_norm, norm_smul, abs_of_pos ht_pos ];
    rw [ show A + t • ( C - A ) - C = ( t - 1 ) • ( C - A ) by simp +decide [ sub_smul, smul_sub ] ; abel1 ] ; rw [ norm_smul, Real.norm_eq_abs, abs_of_nonpos ( by linarith : t - 1 ≤ 0 ) ] ; ring;
    rw [ norm_sub_rev ]
  have h_dist_BD : dist B D = dist B Q + dist Q D := by
    rw [ hQ', dist_eq_norm', dist_eq_norm', dist_eq_norm' ];
    rw [ show D - ( B + s • ( D - B ) ) = ( 1 - s ) • ( D - B ) by rw [ sub_smul, one_smul ] ; abel1, norm_smul, Real.norm_of_nonneg ( by linarith ) ] ; ring;
    simp +decide [ norm_smul, abs_of_pos hs_pos ];
  have h_dist_Q : dist A Q + dist Q B > dist A B := by
    have h_norm : ‖A - B‖ < ‖A - Q‖ + ‖Q - B‖ := by
      have h_norm : ∀ {u v : V}, u ≠ 0 → v ≠ 0 → ¬(∃ r : ℝ, 0 < r ∧ u = r • v) → ‖u + v‖ < ‖u‖ + ‖v‖ := by
        intro u v hu hv huv
        have h_norm : ‖u + v‖ < ‖u‖ + ‖v‖ := by
          have := norm_add_lt_of_not_sameRay ( show ¬ SameRay ℝ u v from fun h => huv <| by
                                                rcases h with ( rfl | rfl | ⟨ r, hr, hr' ⟩ ) <;> simp_all +decide [ norm_smul, abs_of_pos ];
                                                exact ⟨ hr / r, div_pos hr'.2.1 hr'.1, by rw [ div_eq_inv_mul, ← smul_smul, ← hr'.2.2, inv_smul_smul₀ hr'.1.ne' ] ⟩ );
          exact this
        exact h_norm;
      convert h_norm _ _ _ using 1 <;> simp +decide [ sub_eq_iff_eq_add ];
      · contrapose! hABnc; simp_all +decide [ collinear_pair ] ;
      · contrapose! hABnc; simp_all +decide [ collinear_pair ] ;
      · intro x hx h;
        refine' hABnc _;
        rw [ collinear_iff_exists_forall_eq_smul_vadd ] ; use B ; simp +decide [ h ];
        refine' ⟨ Q - B, ⟨ x + 1, _ ⟩, 1, _ ⟩ <;> simp +decide [ add_smul, add_assoc ];
    simpa only [ dist_eq_norm ] using h_norm;
  linarith [ dist_triangle_left C D Q, dist_comm Q B ]

-- Lower bound: (n-3) * p < D
private lemma lower_bound' {n : ℕ} [NeZero n] (hn : n > 3)
    (P : Fin n → EuclideanSpace ℝ (Fin 2))
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    : (↑n - 3 : ℝ) * ∑ i, dist (P i) (P (i+1)) <
      ∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j) := by
  sorry

-- Upper bound
private lemma upper_bound' {n : ℕ} [NeZero n] (hn : n > 3)
    (P : Fin n → EuclideanSpace ℝ (Fin 2))
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    : ∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j) <
      (↑⌊(↑n / 2 : ℝ)⌋ * ↑⌊((↑n + 1) / 2 : ℝ)⌋ - 2) * ∑ i, dist (P i) (P (i+1)) := by
  sorry

/-
PROBLEM
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$.

PROVIDED SOLUTION
Use the helper lemmas `lower_bound'`, `upper_bound'`, and `perimeter_pos'`.

Steps:
1. Get pp := perimeter_pos' hn P hP (perimeter is positive)
2. Get lb := lower_bound' hn P hP (lower bound on diagonal sum)
3. Get ub := upper_bound' hn P hP (upper bound on diagonal sum)
4. From hd: ↑d = 1/2 * D_sum, so 2 * ↑d = D_sum (where D_sum is the diagonal double sum)
5. From hp: ↑p = per_sum (where per_sum is the perimeter sum)
6. Lower bound: lb gives (n-3) * per_sum < D_sum = 2*d, so (n-3) < 2*d / per_sum = 2*d/p
7. Upper bound: ub gives D_sum = 2*d < (floor*floor - 2) * per_sum, so 2*d/p < floor*floor - 2

Use lt_div_iff and div_lt_iff to convert between multiplication and division forms.
The ↑p > 0 needed for these follows from pp and hp.

Be careful with the Nat cast: hp says (p : ℕ) = ∑..., and this should give (↑p : ℝ) = ∑... via Nat.cast.
-/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  apply And.intro;
  · rw [ lt_div_iff₀ ];
    · have := lower_bound' hn P hP; aesop;
    · convert perimeter_pos' hn P hP using 1;
  · rw [ div_lt_iff₀ ];
    · -- Apply the upper bound lemma to get the inequality.
      have h_upper : (∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j)) <
          (↑⌊(↑n / 2 : ℝ)⌋ * ↑⌊((↑n + 1) / 2 : ℝ)⌋ - 2) * (∑ i, dist (P i) (P (i+1))) := by
            convert upper_bound' hn P hP using 1;
      convert h_upper using 1 <;> push_cast [ hp, hd ] <;> ring;
    · convert perimeter_pos' hn P hP using 1
