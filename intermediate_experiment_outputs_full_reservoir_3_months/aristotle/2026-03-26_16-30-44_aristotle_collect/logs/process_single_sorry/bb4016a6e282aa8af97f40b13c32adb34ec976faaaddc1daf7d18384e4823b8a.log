open scoped Real
open scoped Nat
open scoped EuclideanGeometry

scoped[EuclideanGeometry] notation "ℝ²" => EuclideanSpace ℝ (Fin 2)

noncomputable instance Module.orientedEuclideanSpaceFinTwo' : Module.Oriented ℝ (EuclideanSpace ℝ (Fin 2)) (Fin 2) :=
