f is strictly anti on (k, k+1) (each term k'/(x-k') is strictly decreasing since k' > 0 and x-k' doesn't change sign in this interval). Since f(r) = 5/4 and f is strictly decreasing:
- For x ∈ (k, r]: x ≤ r so f(x) ≥ f(r) = 5/4 (strict anti: x < r implies f(x) > f(r), x = r implies f(x) = f(r))
- For x ∈ (r, k+1): x > r so f(x) < f(r) = 5/4

So {x ∈ (k,k+1) | f(x) ≥ 5/4} = (k, r].
Use ext, iff.intro. In each direction, use the strict anti property to compare f(x) with f(r).
-/
lemma solution_Ioo_eq (k : ℕ) (hk1 : 1 ≤ k) (hk2 : k ≤ 69) (r : ℝ)
    (hr : r ∈ Set.Ioo (k : ℝ) (↑k + 1)) (hfr : f r = 5 / 4)
    (huniq : ∀ x ∈ Set.Ioo (k : ℝ) (↑k + 1), f x = 5 / 4 → x = r) :
    {x : ℝ | x ∈ Set.Ioo (k : ℝ) (↑k + 1) ∧ 5 / 4 ≤ f x} = Set.Ioc (k : ℝ) r := by
      -- By definition of $f$, we know that for $x \in (k, k+1)$, $f$ is strictly decreasing.
      have h_decreasing : StrictAntiOn f (Set.Ioo (k : ℝ) (k + 1)) := by
        refine' fun x hx y hy hxy => _;
        refine' Finset.sum_lt_sum _ _ <;> norm_num at *;
        · intro i hi1 hi2; rcases lt_trichotomy i k with ( H | rfl | H );
          · gcongr ; linarith [ show ( i : ℝ ) + 1 ≤ k by norm_cast ];
          · bound;
          · rw [ div_le_iff_of_neg ] <;> nlinarith [ show ( i : ℝ ) ≥ k + 1 by norm_cast, div_mul_cancel₀ ( i : ℝ ) ( by linarith [ show ( i : ℝ ) ≥ k + 1 by norm_cast ] : ( x - i ) ≠ 0 ) ];
        · exact ⟨ k, ⟨ hk1, by linarith ⟩, by rw [ div_lt_div_iff_of_pos_left ] <;> norm_num <;> linarith ⟩;
      ext x;
      simp +zetaDelta at *;
      exact ⟨ fun hx => ⟨ hx.1.1, le_of_not_gt fun hx' => by linarith [ h_decreasing ⟨ by linarith, by linarith ⟩ ⟨ by linarith, by linarith ⟩ hx' ] ⟩, fun hx => ⟨ ⟨ hx.1, by linarith ⟩, by linarith [ h_decreasing.le_iff_ge ( by constructor <;> linarith ) ( by constructor <;> linarith ) |>.2 hx.2 ] ⟩ ⟩

/-
PROVIDED SOLUTION
Same as solution_Ioo_eq but for (70, ∞). f is strictly decreasing on (70, ∞). f(r) = 5/4. For x ≤ r: f(x) ≥ 5/4. For x > r: f(x) < 5/4. So {x > 70 | f(x) ≥ 5/4} = (70, r].
-/
lemma solution_Ioi_eq (r : ℝ) (hr : r > 70) (hfr : f r = 5 / 4)
    (huniq : ∀ x, x > (70 : ℝ) → f x = 5 / 4 → x = r) :
    {x : ℝ | x > 70 ∧ 5 / 4 ≤ f x} = Set.Ioc (70 : ℝ) r := by
      -- To prove equality of sets, we show each set is a subset of the other.
      apply Set.eq_of_subset_of_subset;
      · intro x hx
        obtain ⟨hx_gt, hx_ge⟩ := hx
        have hx_lt : x ≤ r := by
          contrapose! hx_ge;
          -- By definition of $f$, we know that $f(x)$ is strictly decreasing on $(70, \infty)$.
          have h_decreasing : StrictAntiOn f (Set.Ioi 70) := by
            intros x hx y hy hxy;
            exact Finset.sum_lt_sum_of_nonempty ( by norm_num ) fun k hk => div_lt_div_of_pos_left ( Nat.cast_pos.mpr <| Finset.mem_Icc.mp hk |>.1 ) ( by linarith [ Set.mem_Ioi.mp hx, Set.mem_Ioi.mp hy, show ( k : ℝ ) ≤ 70 by exact_mod_cast Finset.mem_Icc.mp hk |>.2 ] ) ( by linarith [ Set.mem_Ioi.mp hx, Set.mem_Ioi.mp hy, show ( k : ℝ ) ≤ 70 by exact_mod_cast Finset.mem_Icc.mp hk |>.2 ] );
          linarith [ h_decreasing ( show 70 < r by linarith ) ( show 70 < x by linarith ) hx_ge ]
        exact ⟨hx_gt, hx_lt⟩;
      · intro x hx;
        -- Since $f$ is strictly decreasing on $(70, \infty)$, we have $f(x) \geq f(r)$ for $x \leq r$.
        have h_decreasing : ∀ x y : ℝ, 70 < x → x ≤ y → f x ≥ f y := by
          intros x y hx hy; exact (by
          apply_rules [ Finset.sum_le_sum ];
          intro i hi; gcongr ; linarith [ show ( i : ℝ ) ≤ 70 by norm_cast; linarith [ Finset.mem_Icc.mp hi ] ] ;);
        exact ⟨ hx.1, hfr ▸ h_decreasing _ _ hx.1 hx.2 ⟩

