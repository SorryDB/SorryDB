/-- The function f(x) = ∑_{k=1}^{70} k/(x-k) -/
def f (x : ℝ) : ℝ := ∑ k ∈ Icc (1 : ℕ) 70, (k : ℝ) / (x - k)

/-- The monic polynomial whose roots are where f = 5/4.
    R(x) = ∏_{k=1}^{70}(x-k) - (4/5)·∑_{k=1}^{70} k·∏_{j≠k}(x-j) -/
def R : Polynomial ℝ :=
  ∏ k ∈ Icc (1 : ℕ) 70, (Polynomial.X - Polynomial.C (k : ℝ)) -
  Polynomial.C (4/5 : ℝ) * ∑ k ∈ Icc (1 : ℕ) 70,
    Polynomial.C (k : ℝ) * ∏ j ∈ (Icc (1 : ℕ) 70).erase k, (Polynomial.X - Polynomial.C (j : ℝ))

/-
PROVIDED SOLUTION
Each term C(k)*∏_{j≠k}(X-Cj) has natDegree ≤ 69: the product ∏_{j≠k}(X-Cj) has 69 factors, each monic of degree 1, so the product has natDegree 69 (by natDegree_prod). C(k)*product has natDegree ≤ 69 (by natDegree_C_mul_le).

The sum of polynomials of natDegree ≤ 69 has natDegree ≤ 69 (by natDegree_sum_le and Finset.sup_le).

C(4/5)*sum has natDegree ≤ 69 (by natDegree_C_mul_le).

Key: For the product part, use natDegree_prod with the fact that each X-Cj ≠ 0 (X_sub_C_ne_zero). For the erase part, the product has 69 factors (card of erase is 69 since k ∈ Icc 1 70).
-/
private lemma correction_natDegree_le :
    (Polynomial.C (4/5 : ℝ) * ∑ k ∈ Icc (1 : ℕ) 70,
      Polynomial.C (k : ℝ) * ∏ j ∈ (Icc (1 : ℕ) 70).erase k,
        (Polynomial.X - Polynomial.C (j : ℝ))).natDegree ≤ 69 := by
          refine' le_trans ( Polynomial.natDegree_C_mul_le _ _ ) _;
          -- The degree of the sum of products is the maximum degree of the individual products, which is 69.
          have h_deg_sum : ∀ k ∈ Finset.Icc (1 : ℕ) 70, Polynomial.natDegree (Polynomial.C (k : ℝ) * ∏ j ∈ Finset.erase (Finset.Icc (1 : ℕ) 70) k, (Polynomial.X - Polynomial.C (j : ℝ))) ≤ 69 := by
            intro k hk; erw [ Polynomial.natDegree_C_mul, Polynomial.natDegree_prod _ _ fun x hx => Polynomial.X_sub_C_ne_zero _ ] ; simp +decide [ Polynomial.natDegree_sub_eq_left_of_natDegree_lt, * ] ;
            aesop;
          exact le_trans ( Polynomial.natDegree_sum_le _ _ ) ( Finset.sup_le h_deg_sum )

/-- R is monic of degree 70 -/
lemma R_monic : R.Monic := by
  apply Polynomial.Monic.sub_of_left
  · exact Polynomial.monic_prod_of_monic _ _ fun x _ => Polynomial.monic_X_sub_C _
  · apply lt_of_le_of_lt (Polynomial.degree_le_of_natDegree_le correction_natDegree_le)
    rw [Polynomial.degree_eq_natDegree (Polynomial.monic_prod_of_monic _ _ (fun x _ =>
      Polynomial.monic_X_sub_C _)).ne_zero]
    rw [Polynomial.natDegree_prod _ _ fun x _ => Polynomial.X_sub_C_ne_zero _]
    simp only [Polynomial.natDegree_X_sub_C]
    simp
    norm_num

