lemma R_nextCoeff : R.nextCoeff = -4473 := by sorry

/-- R has exactly 70 roots (counting multiplicity) -/
lemma R_card_roots : R.roots.card = 70 := by sorry

/-- R splits -/
lemma R_splits : R.Splits := by
  rw [Polynomial.splits_iff_card_roots, R_natDegree]
  exact R_card_roots

/-- Sum of roots of R equals 4473 (by Vieta's formula) -/
lemma R_roots_sum : R.roots.sum = 4473 := by
  have h := R_splits.nextCoeff_eq_neg_sum_roots_of_monic R_monic
  rw [R_nextCoeff] at h; linarith

/-- The S set equals a union of 70 half-open intervals -/
lemma S_eq_union (S : Set ℝ)
    (hS : S = {x : ℝ | (¬∃ n : ℕ, n ∈ Icc (1 : ℕ) 70 ∧ x = n) ∧
      5 / 4 ≤ ∑ k ∈ Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    ∃ rr : Fin 70 → ℝ,
      (∀ i : Fin 70, (↑i + 1 : ℝ) < rr i) ∧
      (∀ i : Fin 70, (i : ℕ) < 69 → rr i < (↑i + 2 : ℝ)) ∧
      (∀ i : Fin 70, f (rr i) = 5 / 4) ∧
      S = ⋃ i : Fin 70, Set.Ioc ((↑i + 1 : ℝ)) (rr i) := by sorry

/-- The total length of the intervals is 1988 -/
lemma total_length_eq_1988 (rr : Fin 70 → ℝ)
    (hr_root : ∀ i, Polynomial.eval (rr i) R = 0)
    (hr_distinct : Function.Injective rr) :
    ∑ i : Fin 70, (rr i - (↑i + 1 : ℝ)) = 1988 := by sorry

end IMO1988P4

/--
