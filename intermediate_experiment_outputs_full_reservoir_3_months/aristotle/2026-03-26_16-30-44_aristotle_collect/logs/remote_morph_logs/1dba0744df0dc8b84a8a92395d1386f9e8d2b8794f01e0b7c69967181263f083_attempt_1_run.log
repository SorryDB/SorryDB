Specifically: unfold R, then apply natDegree_sub_eq_left_of_natDegree_lt. For the first goal (natDegree of product = 70), use natDegree_prod with X_sub_C_ne_zero. For the second goal (natDegree of correction < natDegree of product), use correction_natDegree_le to bound by 69, and then show 69 < 70 = natDegree of product.
-/
lemma R_natDegree : R.natDegree = 70 := by
  -- Apply the lemma that states the natural degree of R is 70.
  apply Classical.byContradiction
  intro h_contra;
  unfold R at h_contra;
  contrapose! h_contra; erw [ Polynomial.natDegree_sub_eq_left_of_natDegree_lt ] at * <;> norm_num at *;
  · erw [ Polynomial.natDegree_prod _ _ fun x hx => Polynomial.X_sub_C_ne_zero _ ] ; erw [ Finset.sum_congr rfl fun x hx => Polynomial.natDegree_X_sub_C _ ] ; norm_cast;
  · refine' lt_of_le_of_lt ( correction_natDegree_le ) _;
    erw [ Polynomial.natDegree_prod _ _ fun x hx => Polynomial.X_sub_C_ne_zero _ ] ; erw [ Finset.sum_congr rfl fun x hx => Polynomial.natDegree_X_sub_C _ ] ; norm_cast

/-
PROBLEM
Key identity: ∑ k·∏_{j≠k}(x-j) = ∏(x-k) · f(x)

PROVIDED SOLUTION
Need: ∑_k k * ∏_{j≠k}(x-j) = ∏(x-k) * f(x) where f(x) = ∑_k k/(x-k).

RHS = ∏(x-k) * ∑_k k/(x-k) = ∑_k k * ∏(x-k)/(x-k) = ∑_k k * ∏_{j≠k}(x-j).

For each k: ∏(x-j) / (x-k) = ∏_{j≠k}(x-j) because ∏(x-j) = (x-k) * ∏_{j≠k}(x-j), so dividing by (x-k) gives ∏_{j≠k}(x-j).

Use Finset.mul_sum, then for each term: k * ∏_{j≠k}(x-j) = k * ∏(x-j)/(x-k), and then use Finset.prod_erase_mul or mul_prod_erase.
-/
lemma eval_sum_eq {x : ℝ} (hx : ∀ k ∈ Icc (1 : ℕ) 70, (x : ℝ) ≠ k) :
    (∑ k ∈ Icc (1 : ℕ) 70,
      (k : ℝ) * ∏ j ∈ (Icc (1 : ℕ) 70).erase k, (x - (j : ℝ))) =
    (∏ k ∈ Icc (1 : ℕ) 70, (x - (k : ℝ))) * f x := by
      rw [ show f x = ( ∑ k ∈ Finset.Icc ( 1 : ℕ ) 70, ( k : ℝ ) / ( x - k ) ) from rfl, mul_comm ] ; simp +decide only [mul_comm, mul_sum] ; ring!;
      refine' Finset.sum_congr rfl fun i hi => _ ; rw [ mul_assoc, inv_mul_eq_div, ← Finset.prod_erase_mul _ _ hi ] ; rw [ mul_div_cancel_right₀ _ ( sub_ne_zero_of_ne <| hx i hi ) ] ;

/-- For x not equal to any integer in [1,70], R(x) = 0 iff f(x) = 5/4 -/
lemma R_eval_zero_iff {x : ℝ} (hx : ∀ k ∈ Icc (1 : ℕ) 70, (x : ℝ) ≠ k) :
    Polynomial.eval x R = 0 ↔ f x = 5 / 4 := by
  have hP : ∏ k ∈ Icc (1 : ℕ) 70, (x - (k : ℝ)) ≠ 0 :=
    Finset.prod_ne_zero_iff.mpr fun k hk => sub_ne_zero_of_ne (hx k hk)
  have heval : Polynomial.eval x R =
      (∏ k ∈ Icc (1 : ℕ) 70, (x - (k : ℝ))) -
      (4/5 : ℝ) * ∑ k ∈ Icc (1 : ℕ) 70,
        (k : ℝ) * ∏ j ∈ (Icc (1 : ℕ) 70).erase k, (x - (j : ℝ)) := by
    unfold R
    simp only [Polynomial.eval_sub, Polynomial.eval_mul, Polynomial.eval_C,
      Polynomial.eval_prod, Polynomial.eval_finset_sum, Polynomial.eval_X]
  rw [heval, eval_sum_eq hx]
  constructor
  · intro h
    have h1 : (∏ k ∈ Icc (1 : ℕ) 70, (x - (k : ℝ))) * (1 - 4 / 5 * f x) = 0 := by linarith
    rcases mul_eq_zero.mp h1 with h2 | h2
    · exact absurd h2 hP
    · linarith
  · intro h
    have : 1 - 4 / 5 * f x = 0 := by rw [h]; ring
    nlinarith [mul_eq_zero_of_right (∏ k ∈ Icc (1 : ℕ) 70, (x - (k : ℝ))) this]

lemma f_continuousOn {a b : ℝ} (h : ∀ k ∈ Icc (1 : ℕ) 70, (k : ℝ) ∉ Set.Icc a b) :
    ContinuousOn f (Set.Ioo a b) := by
  refine continuousOn_finset_sum _ fun k hk => ContinuousOn.div ?_ ?_ ?_ <;> norm_num
  · exact continuousOn_const
  · exact continuousOn_id.sub continuousOn_const
  · exact fun x hx₁ hx₂ hx₃ => h k hk ⟨by linarith, by linarith⟩

