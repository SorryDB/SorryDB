import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

/- The original statement is false for S = ∅: the conclusion requires ∃ i : Fin 0, ...
   which is False, while all hypotheses are vacuously satisfied.
   Counterexample: S = ∅, k = 1, with the trivial empty equivalences. -/
-- theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
--     {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
--     (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
--   sorry

-- ============================================================================
-- Helper lemmas
-- ============================================================================

/-- Any two bijections from Fin n to a type with n ≤ 2 elements differ by a rotation. -/
lemma rotation_of_small_card {n : ℕ} {α : Type*} (hn : n ≤ 2) [NeZero n]
    (p₁ p₂ : Fin n ≃ α) :
    ∃ i : Fin n, ∀ j : Fin n, p₂ j = p₁ (j + i) := by
  interval_cases n
  · exact False.elim <| NeZero.ne 0 rfl
  · exact p₂.surjective (p₁ 0) |> fun ⟨x, hx⟩ => by fin_cases x; aesop
  · cases' p₁.surjective (p₂ 0) with x hx
    cases' p₁.surjective (p₂ 1) with y hy
    fin_cases x <;> fin_cases y <;> simp_all +decide

/-- The witness x in pq = x² + x + k is unique for positive x. -/
lemma witness_unique {p q k x y : ℕ} (hx : 0 < x) (hy : 0 < y)
    (hxeq : p * q = x ^ 2 + x + k) (hyeq : p * q = y ^ 2 + y + k) : x = y := by
  nlinarith only [hxeq, hyeq, hx, hy]

/-- For compatible primes pq = x²+x+k with k ≥ 1, 4pq = (2x+1)² + (4k-1). -/
lemma four_mul_eq {p q k x : ℕ} (hk : 0 < k) (hx : 0 < x)
    (hpq : p * q = x ^ 2 + x + k) :
    4 * (p * q) = (2 * x + 1) ^ 2 + (4 * k - 1) := by
  linarith [Nat.sub_add_cancel (by linarith : 1 ≤ 4 * k)]

/-- At each vertex, the two adjacent witnesses satisfy
    (x-y)(x+y+1) ≡ 0 (mod p) or x = y. -/
lemma vertex_congruence {p k x y : ℕ} (hp : Nat.Prime p) (hx : 0 < x) (hy : 0 < y)
    (hxmod : p ∣ x ^ 2 + x + k) (hymod : p ∣ y ^ 2 + y + k) :
    p ∣ (x - y) * (x + y + 1) ∨ x = y := by
  cases le_total x y <;> simp_all +decide [← ZMod.natCast_eq_zero_iff]
  exact Or.inl (by linear_combination' hxmod - hymod)

/-- An automorphism of the cycle graph Cₙ (n ≥ 3) that maps every edge to an
    adjacent pair is either a rotation or a reflection. -/
lemma cycle_automorphism {n : ℕ} (hn : 3 ≤ n) [NeZero n]
    (σ : Fin n ≃ Fin n)
    (hedge : ∀ i : Fin n, σ (i + 1) = σ i + 1 ∨ σ (i + 1) = σ i - 1) :
    (∃ c : Fin n, ∀ j, σ j = j + c) ∨
    (∃ c : Fin n, ∀ j, σ j = Fin.rev j + c) := by
  by_contra! h_contra
  obtain ⟨h_case1, h_case2⟩ : (∃ i : Fin n, σ (i + 1) = σ i + 1) ∧
      (∃ i : Fin n, σ (i + 1) = σ i - 1) := by
    constructor <;> by_cases h : ∀ i, σ (i + 1) = σ i + 1 <;>
        simp_all +decide [Finset.card_univ]
    · by_cases h : ∀ i, σ (i + 1) = σ i - 1 <;> simp_all +decide [Finset.card_univ]
      · have h_ind : ∀ i : Fin n, σ i = σ 0 - i := by
          intro i; induction' i with i ih
          induction' i with i ih
          · norm_num [Fin.ext_iff, Fin.val_sub]
          · convert h ⟨i, by linarith⟩ using 1
            · norm_num [Fin.add_def, Nat.mod_eq_of_lt ih]
            · rw [‹∀ (ih : i < n), σ ⟨i, ih⟩ = σ 0 - ⟨i, ih⟩› (Nat.lt_of_succ_lt ih)]
              norm_num [sub_sub]
              norm_num [Fin.add_def, Nat.mod_eq_of_lt ih]
        obtain ⟨c, hc⟩ : ∃ c : Fin n, ∀ j : Fin n, σ j = j.rev + c := by
          use σ 0 + 1
          intro j; rw [h_ind j]; norm_num [Fin.ext_iff, Fin.val_add, Fin.val_one]; ring
          grind
        exact False.elim <| h_contra.2 c |> fun ⟨j, hj⟩ => hj <| hc j
      · grind +ring
    · have h_ind : ∀ i : Fin n, σ i = σ 0 + i := by
        intro i; induction' i with i ih
        induction' i with i ih
        · norm_num [Fin.ext_iff]
        · convert h ⟨i, by linarith⟩ using 1 <;>
            simp +decide [*, Fin.add_def, Nat.mod_eq_of_lt]; ring!
      exact False.elim <| h_contra.1 (σ 0) |> fun ⟨j, hj⟩ =>
        hj <| by rw [h_ind j, add_comm]
    · exact h.imp fun i hi => Or.resolve_left (hedge i) hi
  obtain ⟨i, hi⟩ : ∃ i : Fin n, σ (i + 1) = σ i + 1 ∧ σ (i + 2) = σ (i + 1) - 1 := by
    by_cases h_case1 : ∀ i : Fin n, σ (i + 1) = σ i + 1 → σ (i + 2) = σ (i + 1) + 1
    · obtain ⟨i, hi⟩ := ‹∃ i : Fin n, σ (i + 1) = σ i + 1›
      have h_case1_all : ∀ j : Fin n, σ (i + j + 1) = σ (i + j) + 1 := by
        intro j
        induction' j with j ih
        induction' j with j ih
        · simpa using hi
        · convert h_case1 (i + ⟨j, by linarith⟩)
            (by solve_by_elim [Nat.lt_of_succ_lt]) using 1 <;>
            norm_num [add_assoc, Fin.add_def]
      obtain ⟨j, hj⟩ := h_case2
      specialize h_case1_all (j - i)
      simp_all +decide [add_assoc]
      grind
    · grind +ring
  have := σ.injective (show σ (i + 2) = σ i by aesop)
  simp_all +decide [add_assoc]
  rcases n with (_ | _ | _ | n) <;> cases this <;> contradiction

-- ============================================================================
-- Main theorem
-- ============================================================================

/-- The core number-theoretic claim: the permutation σ = p₂ ∘ p₁⁻¹ relating two
    valid arrangements maps edges to edges in the cycle graph.
    This is the heart of IMO 2022 Problem 3. The proof uses the fact that the
    quadratic t² + t + k has at most 2 roots modulo each odd prime, combined with
    growth bounds on compatible prime values to show that non-adjacent compatible
    pairs cannot appear in a valid circular arrangement. -/
lemma edge_preservation {k : ℕ} (hk : 0 < k) (S : Finset ℕ)
    (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p) (hn : 3 ≤ #S)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    ∀ i : Fin #S, have : NeZero #S := ⟨Fin.pos i |>.ne'⟩
    (p₂.trans p₁.symm) (i + 1) = (p₂.trans p₁.symm) i + 1 ∨
    (p₂.trans p₁.symm) (i + 1) = (p₂.trans p₁.symm) i - 1 := by
  sorry

/-- Corrected version of the result, adding the hypothesis that S is nonempty.
    This corresponds to the original IMO 2022 Problem 3: placing elements of a
    nonempty finite set of odd primes around a circle, there is at most one way
    (up to rotation and reflection) such that the product of any two neighbouring
    elements has the form x² + x + k. -/
theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    (hSne : S.Nonempty)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  haveI : NeZero #S := ⟨(Finset.card_pos.mpr hSne).ne'⟩
  by_cases hcard : #S ≤ 2
  · -- Easy case: |S| ≤ 2. Any two bijections differ by rotation.
    exact Or.inl (rotation_of_small_card hcard p₁ p₂)
  · -- Hard case: |S| ≥ 3. Use edge_preservation + cycle_automorphism.
    push_neg at hcard
    set σ := p₂.trans p₁.symm with hσ
    have hedge : ∀ i : Fin #S, σ (i + 1) = σ i + 1 ∨ σ (i + 1) = σ i - 1 :=
      edge_preservation hk S hS (by omega) hp₁ hp₂
    rcases cycle_automorphism (by omega : 3 ≤ #S) σ hedge with ⟨c, hc⟩ | ⟨c, hc⟩
    · left
      exact ⟨c, fun j => by
        have : p₂ j = p₁ (σ j) := by simp [hσ]
        rw [this, hc j]⟩
    · right
      exact ⟨c, fun j => by
        have : p₂ j = p₁ (σ j) := by simp [hσ]
        rw [this, hc j]⟩

end IMO2022P3

