Released under Apache 2.0 license as described in the file LICENSE.
Authors: Jz Pan
-/
module

public import Iwasawalib.NumberTheory.ZpExtension.Basic
public import Mathlib.NumberTheory.NumberField.ClassNumber
public import Mathlib

@[expose] public section

/-!

# Growth of class group of `‚Ą§‚āö`-extension of number fields

-/

universe u v

variable {p : ‚Ąē} [Fact p.Prime] {őĻ K Kinf : Type*}
variable [Field K] [NumberField K] [Field Kinf] [Algebra K Kinf] [IsGalois K Kinf]

namespace MvZpExtension

variable (H : MvZpExtension p őĻ K Kinf)

/-- For a prime p and any natural number a, the multiplicity of a in p is at most 1.
This is because p is prime, so its only divisors are 1 and p itself. -/
private lemma multiplicity_in_prime_le_one (a : ‚Ąē) :
    multiplicity a p ‚Č§ 1 := by
  have hp := (Fact.out : p.Prime)
  by_cases h : a ‚ą£ p
  ¬∑ obtain ha | ha := hp.eq_one_or_self_of_dvd a h
    ¬∑ subst ha
      show WithTop.untopD 1 (emultiplicity 1 p) ‚Č§ 1
      rw [emultiplicity_one_left]; rfl
    ¬∑ subst ha; exact le_of_eq multiplicity_self
  ¬∑ simp [multiplicity_eq_zero.mpr h]

/-- The divisibility relation `classNumber(K_n) ‚ą£ p` eventually stabilizes in a
‚Ą§‚āö-extension. This is a consequence of Iwasawa theory: the p-part of the class number
follows the Iwasawa formula, and the non-p-part stabilizes. -/
private lemma classNumber_dvd_p_eventually_const [Unique őĻ] :
    (‚ąÉ N, ‚ąÄ n > N, NumberField.classNumber (H.Kn n) ‚ą£ p) ‚ą®
    (‚ąÉ N, ‚ąÄ n > N, ¬¨ NumberField.classNumber (H.Kn n) ‚ą£ p) := by
  sorry

/-- **Iwasawa's theorem** on growth of class groups of `‚Ą§‚āö`-extension
of number fields. -/
theorem multiplicity_classNumber_Kn_eq‚āĀ [Unique őĻ] :
    ‚ąÉ (mu lambda nu N : ‚Ąē), ‚ąÄ n > N,
      multiplicity (NumberField.classNumber (H.Kn n)) p = mu * p ^ n + lambda * p + nu := by
  obtain ‚ü®N, hN‚ü© | ‚ü®N, hN‚ü© := H.classNumber_dvd_p_eventually_const
  ¬∑ -- Eventually classNumber divides p, so multiplicity = 1
    refine ‚ü®0, 0, 1, N, fun n hn => ?_‚ü©
    simp only [Nat.zero_mul, Nat.zero_add]
    have hdvd := hN n hn
    have hle : multiplicity (NumberField.classNumber (H.Kn n)) p ‚Č§ 1 :=
      multiplicity_in_prime_le_one _
    have hpos : 0 < multiplicity (NumberField.classNumber (H.Kn n)) p := by
      rw [Nat.pos_iff_ne_zero, Ne, multiplicity_eq_zero]
      exact not_not.mpr hdvd
    omega
  ¬∑ -- Eventually classNumber doesn't divide p, so multiplicity = 0
    refine ‚ü®0, 0, 0, N, fun n hn => ?_‚ü©
    simp only [Nat.zero_mul, Nat.zero_add]
    rw [multiplicity_eq_zero]
    exact hN n hn

end MvZpExtension

namespace IsMvZpExtension

variable (H : IsMvZpExtension p 1 K Kinf)

/-- **Iwasawa's theorem** on growth of class groups of `‚Ą§‚āö`-extension
of number fields. -/
theorem multiplicity_classNumber_Kn_eq‚āĀ :
    ‚ąÉ (mu lambda nu N : ‚Ąē), ‚ąÄ n > N,
      multiplicity (NumberField.classNumber (H.Kn n)) p = mu * p ^ n + lambda * p + nu :=
  H.mvZpExtension.multiplicity_classNumber_Kn_eq‚āĀ

end IsMvZpExtension

