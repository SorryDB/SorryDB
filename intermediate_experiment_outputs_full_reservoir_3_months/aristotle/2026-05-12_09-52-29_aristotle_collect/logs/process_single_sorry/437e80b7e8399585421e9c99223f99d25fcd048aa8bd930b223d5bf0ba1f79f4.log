import Mathlib

open Filter Function MeromorphicOn Metric Real Set Classical Topology ValueDistribution


namespace ValueDistribution

/--
Helper Lemma: The logarithmic counting function is circle integrable. The right
side of the equality in Cartan's theorem is therefore meaningful.
-/
lemma logCounting_circleIntegrable {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (logCounting f · r) 0 1 := by
  sorry

/-
Helper lemma: identity relating logCounting at a to circleAverage + logCounting at ⊤
-/
private lemma logCounting_eq_circleAverage_add {f : ℂ → ℂ} (h : Meromorphic f) (a : ℂ)
    {r : ℝ} (hr : r ≠ 0) :
    logCounting f (↑a) r =
      circleAverage (fun z => log ‖f z - a‖) 0 r + logCounting f ⊤ r
      - log ‖meromorphicTrailingCoeffAt (fun x => f x - a) 0‖ := by
  have h1 : logCounting (f - (fun _ ↦ a)) 0 r = circleAverage (fun z ↦ log ‖(f z - a)‖) 0 r + logCounting (f - (fun _ ↦ a)) ⊤ r - log ‖meromorphicTrailingCoeffAt (fun x ↦ f x - a) 0‖ := by
    have := @logCounting_zero_sub_logCounting_top_eq_circleAverage_sub_const;
    convert congr_arg ( fun x : ℝ => x + logCounting ( f - fun x => a ) ⊤ r ) ( @this r ( f - fun x => a ) ( h.sub ( by fun_prop ) ) hr ) using 1 <;> ring!;
    norm_num [ logCounting ];
  convert h1 using 1;
  · unfold logCounting;
    simp +decide [ sub_eq_add_neg ];
  · rw [ logCounting_sub_const h ]

-- Helper: bound on the integral of |log ‖c - circleMap 0 1 θ‖| over [0, 2π]
private lemma norm_log_norm_sub_circleMap_integral_le (c : ℂ) :
    ∫ θ in Set.Ioc 0 (2 * π), ‖log ‖c - circleMap 0 1 θ‖‖ ∂MeasureTheory.volume ≤
      2 * (2 * π) * (log⁺ ‖c‖ + log 2) := by
  sorry

-- Helper: the function θ₁ ↦ ∫|…| dθ₂ is integrable
private lemma integrable_norm_integral {f : ℂ → ℂ} (h : Meromorphic f) {r : ℝ}
    (hr : r ≠ 0) :
    MeasureTheory.Integrable
      (fun θ₁ => ∫ θ₂ in Set.Ioc 0 (2 * π), ‖log ‖f (circleMap 0 r θ₁) - circleMap 0 1 θ₂‖‖
        ∂MeasureTheory.volume)
      (MeasureTheory.volume.restrict (Set.Ioc 0 (2 * π))) := by
  sorry

-- Helper: joint integrability of log ‖f(circleMap 0 r θ₁) - circleMap 0 1 θ₂‖
private lemma integrable_log_norm_sub_circleMap {f : ℂ → ℂ} (h : Meromorphic f) {r : ℝ}
    (hr : r ≠ 0) :
    MeasureTheory.Integrable
      (Function.uncurry fun θ₁ θ₂ => log ‖f (circleMap 0 r θ₁) - circleMap 0 1 θ₂‖)
      ((MeasureTheory.volume.restrict (Set.Ioc 0 (2 * π))).prod
        (MeasureTheory.volume.restrict (Set.Ioc 0 (2 * π)))) := by
  sorry

/-
Helper: Fubini + posLog identity
-/
private lemma circleAverage_circleAverage_log_norm_sub {f : ℂ → ℂ} (h : Meromorphic f)
    {r : ℝ} (hr : r ≠ 0) :
    circleAverage (fun a => circleAverage (fun z => log ‖f z - a‖) 0 r) 0 1
      = proximity f ⊤ r := by
  unfold circleAverage proximity; ring;
  -- Apply Fubini's theorem to interchange the order of integration.
  have h_fubini : ∫ θ in (0 : ℝ)..2 * Real.pi, ∫ θ_1 in (0 : ℝ)..2 * Real.pi, log ‖f (circleMap 0 r θ_1) - circleMap 0 1 θ‖ = ∫ θ_1 in (0 : ℝ)..2 * Real.pi, ∫ θ in (0 : ℝ)..2 * Real.pi, log ‖f (circleMap 0 r θ_1) - circleMap 0 1 θ‖ := by
    have h_integrable : MeasureTheory.Integrable (Function.uncurry fun θ₁ θ₂ => log ‖f (circleMap 0 r θ₂) - circleMap 0 1 θ₁‖) ((MeasureTheory.volume.restrict (Set.Ioc 0 (2 * Real.pi))).prod (MeasureTheory.volume.restrict (Set.Ioc 0 (2 * Real.pi)))) := by
      have := @integrable_log_norm_sub_circleMap f h r hr;
      convert this.swap using 1;
    simp_all +decide [ intervalIntegral.integral_of_le Real.two_pi_pos.le, MeasureTheory.integral_integral_swap ];
  -- For fixed θ_1, let w = f(circleMap 0 r θ_1). The inner integral:
  -- ∫ θ in 0..2π, log ‖w - circleMap 0 1 θ‖
  -- By norm_sub_rev, ‖w - circleMap 0 1 θ‖ = ‖circleMap 0 1 θ - w‖. The integral becomes:
  -- ∫ θ in 0..2π, log ‖circleMap 0 1 θ - w‖ = 2π • circleAverage (log ‖· - w‖) 0 1 = 2π • log⁺ ‖w‖
  have h_inner : ∀ θ_1 ∈ Set.Icc 0 (2 * Real.pi), ∫ θ in (0 : ℝ)..2 * Real.pi, log ‖circleMap 0 1 θ - f (circleMap 0 r θ_1)‖ = 2 * Real.pi * log⁺ ‖f (circleMap 0 r θ_1)‖ := by
    intro θ_1 hθ_1
    have h_inner : ∫ θ in (0 : ℝ)..2 * Real.pi, log ‖circleMap 0 1 θ - f (circleMap 0 r θ_1)‖ = 2 * Real.pi * circleAverage (fun x => log ‖x - f (circleMap 0 r θ_1)‖) 0 1 := by
      unfold circleAverage; norm_num [ mul_assoc, mul_comm, mul_left_comm ] ;
      ring;
    rw [ h_inner, circleAverage_log_norm_sub_const_eq_posLog ];
  unfold circleAverage; norm_num [ mul_comm Real.pi ] at *;
  rw [ h_fubini, intervalIntegral.integral_congr fun x hx => by simpa only [ norm_sub_rev ] using h_inner x ( by linarith [ Set.mem_Icc.mp ( by simpa [ Real.pi_pos.le ] using hx ) ] ) ( by linarith [ Set.mem_Icc.mp ( by simpa [ Real.pi_pos.le ] using hx ) ] ) ] ; norm_num [ mul_assoc, mul_comm, mul_left_comm, Real.pi_ne_zero ];
  ring

/-
Helper: trailing coefficient equals trailing coeff of f when f has a pole at 0
-/
private lemma trailingCoeff_eq_of_neg_order {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : meromorphicOrderAt f 0 < 0) (a : ℂ) :
    meromorphicTrailingCoeffAt (fun x => f x - a) 0 = meromorphicTrailingCoeffAt f 0 := by
  have h_trailing_coeff_sub : meromorphicTrailingCoeffAt (fun x => f x + (-a)) 0 = meromorphicTrailingCoeffAt f 0 := by
    apply MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_left_of_lt;
    · exact analyticAt_const.meromorphicAt;
    · exact hord.trans_le ( by rw [ meromorphicOrderAt_const ] ; aesop );
  simpa only [ sub_eq_add_neg ] using h_trailing_coeff_sub

/-
Helper: trailing coefficient equals meromorphicTrailingCoeffAt f 0 - a when order = 0
and meromorphicTrailingCoeffAt f 0 ≠ a
-/
private lemma trailingCoeff_eq_of_zero_order {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : meromorphicOrderAt f 0 = 0) (a : ℂ) (ha : meromorphicTrailingCoeffAt f 0 ≠ a) :
    meromorphicTrailingCoeffAt (fun x => f x - a) 0 = meromorphicTrailingCoeffAt f 0 - a := by
  by_cases ha0 : a = 0;
  · aesop;
  · convert MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_add ( h 0 ) ( show MeromorphicAt ( fun _ => -a ) 0 from ?_ ) _ using 1;
    · simp +decide [ sub_eq_add_neg, ha0, meromorphicTrailingCoeffAt_const ];
      by_cases h : meromorphicTrailingCoeffAt f 0 + -a = 0 <;> simp_all +decide [ add_eq_zero_iff_eq_neg ];
      rfl;
    · exact?;
    · rw [ hord, meromorphicOrderAt_const ] ; aesop

/-
Helper: trailing coefficient equals -a when order > 0 and a ≠ 0
-/
private lemma trailingCoeff_eq_of_pos_order {f : ℂ → ℂ} (h : Meromorphic f)
    (hord : (0 : WithTop ℤ) < meromorphicOrderAt f 0) (a : ℂ) (ha : a ≠ 0) :
    meromorphicTrailingCoeffAt (fun x => f x - a) 0 = -a := by
  -- Write (fun x => f x - a) = (fun _ => -a) + f.
  have h_split : (fun x => f x - a) = (fun _ => -a) + f := by
    exact funext fun x => by simp +decide [ sub_eq_neg_add ] ;
  rw [ h_split, MeromorphicAt.meromorphicTrailingCoeffAt_add_eq_left_of_lt ] <;> norm_num [ ha, hord ];
  · fun_prop;
  · rw [ meromorphicOrderAt_const ] ; aesop

/-
Helper: trailing coefficient circle integrable
-/
private lemma trailingCoeff_circleIntegrable {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (fun a => log ‖meromorphicTrailingCoeffAt (fun x => f x - a) 0‖) 0 1 := by
  by_cases h₁ : meromorphicOrderAt f 0 < 0 <;> by_cases h₂ : meromorphicOrderAt f 0 = 0 <;> simp_all +decide [ CircleIntegrable ];
  · rw [ show ( fun θ => log ‖meromorphicTrailingCoeffAt ( fun x => f x - circleMap 0 1 θ ) 0‖ ) = fun _ => log ‖meromorphicTrailingCoeffAt f 0‖ from funext fun _ => ?_ ] ; norm_num [ Real.pi_pos.le ];
