    exact fun θ => log ‖c₀ - circleMap 0 1 θ‖;
    · convert h_circle_integrable using 1;
      unfold CircleIntegrable; norm_num [ circleMap ] ;
      rw [ intervalIntegrable_iff_integrableOn_Icc_of_le Real.two_pi_pos.le ];
      rfl;
    · exact h_eq_almost_everywhere.mono fun x hx => hx.symm;
  · -- Since $meromorphicOrderAt f 0 > 0$, we have $meromorphicTrailingCoeffAt (fun x => f x - circleMap 0 1 θ) 0 = -circleMap 0 1 θ$.
    have h_trailing_coeff : ∀ θ ∈ Set.Icc 0 (2 * Real.pi), meromorphicTrailingCoeffAt (fun x => f x - circleMap 0 1 θ) 0 = -circleMap 0 1 θ := by
      intro θ hθ; exact trailingCoeff_eq_of_pos_order h ( lt_of_le_of_ne h₁ ( Ne.symm h₂ ) ) _ ( by simp +decide [ circleMap ] ) ;
    rw [ intervalIntegrable_iff_integrableOn_Ioc_of_le Real.two_pi_pos.le ];
    rw [ MeasureTheory.integrableOn_congr_fun ( fun x hx => by rw [ h_trailing_coeff x <| Set.Ioc_subset_Icc_self hx ] ) measurableSet_Ioc ] ; norm_num [ circleMap ]

/-
Helper: circleAverage of log norm sub is circle integrable
-/
private lemma circleAverage_log_norm_sub_circleIntegrable {f : ℂ → ℂ} (h : Meromorphic f)
    {r : ℝ} (hr : r ≠ 0) :
    CircleIntegrable (fun a => circleAverage (fun z => log ‖f z - a‖) 0 r) 0 1 := by
  by_contra! h_contra;
  -- By definition of $circleAverage$, we know that
  have h_circleAverage : ∀ a : ℂ, circleAverage (fun z => log ‖f z - a‖) 0 r = logCounting f (↑a) r - logCounting f ⊤ r + log ‖meromorphicTrailingCoeffAt (fun x => f x - a) 0‖ := by
    intro a; rw [ logCounting_eq_circleAverage_add h a hr ] ; ring;
  have h_circleIntegrable : CircleIntegrable (fun a => logCounting f (↑a) r - logCounting f ⊤ r + log ‖meromorphicTrailingCoeffAt (fun x => f x - a) 0‖) 0 1 := by
    have h_circleIntegrable : CircleIntegrable (fun a : ℂ => logCounting f (↑a) r) 0 1 ∧ CircleIntegrable (fun a : ℂ => log ‖meromorphicTrailingCoeffAt (fun x => f x - a) 0‖) 0 1 := by
      exact ⟨ logCounting_circleIntegrable h, trailingCoeff_circleIntegrable h ⟩;
    exact IntervalIntegrable.add ( h_circleIntegrable.1.sub ( intervalIntegral.intervalIntegrable_const ) ) h_circleIntegrable.2;
  exact h_contra <| by simpa only [ ← h_circleAverage ] using h_circleIntegrable;

/-
Cartan's theorem, qualitative version: Up to a constant, the characteristic
function for the poles of `f` equals a circle integral over the logarithmic
counting functions for the `z`-values of `f`, where `z` is the integration
variable.
-/
theorem characteristic_top_eq_circleAverage_logCounting_add_const {f : ℂ → ℂ} (h : Meromorphic f) :
    ∃ const, ∀ r ≠ 0, characteristic f ⊤ r = circleAverage (logCounting f · r) 0 1 + const := by
  use circleAverage ( fun a => log ‖meromorphicTrailingCoeffAt ( fun x => f x - a ) 0‖ ) 0 1;
  intro r hr; simp +decide [ characteristic, circleAverage ] ;
  -- By Fubini's theorem, we can interchange the order of integration.
  have h_fubini : ∫ θ in (0 : ℝ)..2 * Real.pi, logCounting f (circleMap 0 1 θ) r = ∫ θ in (0 : ℝ)..2 * Real.pi, circleAverage (fun z => log ‖f z - circleMap 0 1 θ‖) 0 r + logCounting f ⊤ r - log ‖meromorphicTrailingCoeffAt (fun x => f x - circleMap 0 1 θ) 0‖ := by
    exact intervalIntegral.integral_congr fun x hx => logCounting_eq_circleAverage_add h _ hr;
  rw [ h_fubini, intervalIntegral.integral_sub, intervalIntegral.integral_add ] <;> norm_num;
  · rw [ ← circleAverage_circleAverage_log_norm_sub h hr ] ; norm_num [ circleAverage ] ; ring;
    norm_num [ Real.pi_ne_zero ] ; ring;
  · have := circleAverage_log_norm_sub_circleIntegrable h hr;
    finiteness;
  · apply_rules [ IntervalIntegrable.add, intervalIntegral.intervalIntegrable_const ];
    have := circleAverage_log_norm_sub_circleIntegrable h hr;
    finiteness;
  · have := trailingCoeff_circleIntegrable h;
    convert this.1 using 1;
    rw [ intervalIntegrable_iff_integrableOn_Ioc_of_le Real.two_pi_pos.le ]

end ValueDistribution
