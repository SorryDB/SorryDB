namespace Formula

variable {m m‚āĀ m‚āā : Modality} {ŌÜ Ōą : Formula ‚Ąē}

@[simp]
def attachmodality (m : Modality) (ŌÜ : Formula ‚Ąē) : Formula ‚Ąē :=
  match m with
  | -   => ŌÜ
  | ‚Ė°m' => ‚Ė° (ŌÜ.attachmodality m')
  | ‚óám' => ‚óá (ŌÜ.attachmodality m')
  | ‚ąľm' => ‚ąľ (ŌÜ.attachmodality m')

instance : CoeFun (Modality) (őĽ _ => Formula ‚Ąē ‚Üí Formula ‚Ąē) := ‚ü®Formula.attachmodality‚ü©

#eval (‚Ė°-) (.atom 1)

@[simp]
lemma eq_attachModality_add : m‚āĀ (m‚āā ŌÜ) = (m‚āĀ + m‚āā) ŌÜ := by
  induction m‚āĀ with
  | empty      => rfl
  | box m‚āĀ' ih
  | dia m‚āĀ' ih
  | neg m‚āĀ' ih => simp [ih]

end Formula


namespace Logic

variable {m : Modality} {L : Logic _} [L.IsNormal] {ŌÜ Ōą : Formula ‚Ąē} {s : Substitution ‚Ąē}

lemma modality_congruence (h : L ‚äĘ ŌÜ ‚≠§ Ōą) : L ‚äĘ (m ŌÜ) ‚≠§ (m Ōą) := by
  induction m with
  | empty => simpa [-iff_provable];
  | box m' ih => apply box_congruence! ih;
  | dia m' ih => apply dia_congruence! ih;
  | neg m' ih => apply neg_congruence! ih;

lemma E_subst_attachmodality : L ‚äĘ ((m ŌÜ)‚ü¶s‚üß) ‚≠§ (m (ŌÜ‚ü¶s‚üß)) := by
  induction m with
  | empty => simp;
  | box m' ih => apply box_congruence! ih;
  | dia m' ih => apply dia_congruence! ih;
  | neg m' ih => apply neg_congruence! ih;

lemma C_subst_attachmodality_mp : L ‚äĘ ((m ŌÜ)‚ü¶s‚üß) ‚ěĚ (m (ŌÜ‚ü¶s‚üß)) := by
  apply C_of_E_mp! E_subst_attachmodality;

lemma C_subst_attachmodality_mpr : L ‚äĘ (m (ŌÜ‚ü¶s‚üß)) ‚ěĚ ((m ŌÜ)‚ü¶s‚üß) := by
  apply C_of_E_mpr! E_subst_attachmodality;

lemma attachmodality_subst_of_subst_attachmodality : L ‚äĘ (m ŌÜ)‚ü¶s‚üß ‚Üí L ‚äĘ m (ŌÜ‚ü¶s‚üß) := mdp! $ C_subst_attachmodality_mp

lemma subst_attachmodality_of_attachmodality_subst : L ‚äĘ m (ŌÜ‚ü¶s‚üß) ‚Üí L ‚äĘ (m ŌÜ)‚ü¶s‚üß := mdp! $ C_subst_attachmodality_mpr

end Logic


namespace Modality

open Formula

variable {L : Logic ‚Ąē} [L.IsNormal] {m‚āĀ m‚āā : Modality}

class Translation (L : Logic _) (m‚āĀ m‚āā : Modality) where
  translate : ‚ąÄ a,  L ‚äĘ (m‚āĀ (.atom a)) ‚ěĚ (m‚āā (.atom a))

notation:90 M‚āĀ " ‚§≥[" L "] " M‚āā => Translation L M‚āĀ M‚āā

instance : IsRefl _ (¬∑ ‚§≥[L] ¬∑) := ‚ü®by
  intro M;
  constructor;
  simp;
‚ü©

instance : IsTrans _ (¬∑ ‚§≥[L] ¬∑) where
  trans M‚āĀ M‚āā M‚āÉ := by
    intro T‚āĀ‚āā T‚āā‚āÉ;
    constructor;
    intro a;
    exact C!_trans (T‚āĀ‚āā.translate a) (T‚āā‚āÉ.translate a);

class Equivalence (L : Logic ‚Ąē) (M‚āĀ M‚āā : Modality) where
  equivalent : ‚ąÄ a, L ‚äĘ (M‚āĀ (.atom a)) ‚≠§ (M‚āā (.atom a))

notation M‚āĀ " ‚ČÖ[" L "] " M‚āā => Equivalence L M‚āĀ M‚āā

instance [m‚āĀ ‚ČÖ[L] m‚āā] : m‚āĀ ‚§≥[L] m‚āā := ‚ü®fun a ‚Ü¶ C_of_E_mp! $ Equivalence.equivalent a‚ü©
instance [m‚āĀ ‚ČÖ[L] m‚āā] : m‚āā ‚§≥[L] m‚āĀ := ‚ü®fun a ‚Ü¶ C_of_E_mpr! $ Equivalence.equivalent a‚ü©

lemma iff_equivalence_bi_translate : (m‚āĀ ‚ČÖ[L] m‚āā) ‚ÜĒ (m‚āĀ ‚§≥[L] m‚āā) ‚ąß (m‚āā ‚§≥[L] m‚āĀ) := by
  constructor;
  . intro eq;
    constructor <;> infer_instance;
  . intro ‚ü®T‚āĀ‚āā, T‚āā‚āĀ‚ü©;
    constructor;
    intro a;
    apply E!_intro;
    . exact T‚āĀ‚āā.translate a;
    . exact T‚āā‚āĀ.translate a;

instance [m‚āĀ ‚§≥[L] m‚āā] [m‚āā ‚§≥[L] m‚āĀ] : m‚āĀ ‚ČÖ[L] m‚āā := by
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> infer_instance;

instance : Std.Symm (¬∑ ‚ČÖ[L] ¬∑) := ‚ü®by
  intro _ _ eq;
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> infer_instance;
‚ü©

instance : IsRefl _ (¬∑ ‚ČÖ[L] ¬∑) := ‚ü®by
  intro _;
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> apply _root_.refl;
‚ü©

instance : IsTrans _ (¬∑ ‚ČÖ[L] ¬∑) := ‚ü®by
  intro a b c;
  intro E‚āĀ‚āā E‚āā‚āÉ;
  have ‚ü®T‚āĀ‚āā, T‚āā‚āĀ‚ü© := iff_equivalence_bi_translate.mp E‚āĀ‚āā;
  have ‚ü®T‚āā‚āÉ, T‚āÉ‚āā‚ü© := iff_equivalence_bi_translate.mp E‚āā‚āÉ;
  apply iff_equivalence_bi_translate.mpr;
  constructor;
  . exact _root_.trans T‚āĀ‚āā T‚āā‚āÉ;
  . exact _root_.trans T‚āÉ‚āā T‚āā‚āĀ;
‚ü©

instance : IsEquiv _ (¬∑ ‚ČÖ[L] ¬∑) where


lemma Translation.translate_fml [m‚āĀ ‚§≥[L] m‚āā] (ŌÜ : Formula _) : L ‚äĘ m‚āĀ ŌÜ ‚ěĚ m‚āā ŌÜ := by
  let s : Substitution ‚Ąē := őĽ a => if a = 0 then ŌÜ else (.atom a);
  apply C!_replace ?_ ?_ $ L.subst (Translation.translate (L := L) (m‚āĀ := m‚āĀ) (m‚āā := m‚āā) 0) (s := s);
  . simpa [s] using L.C_subst_attachmodality_mpr (s := s) (ŌÜ := (.atom 0));
  . simpa [s] using L.C_subst_attachmodality_mp (s := s) (ŌÜ := (.atom 0));

def translation_of_axiomInstance {a : ‚Ąē} (h : L ‚äĘ (m‚āĀ a) ‚ěĚ (m‚āā a)) : m‚āĀ ‚§≥[L] m‚āā := ‚ü®by
  intro b;
  let s : Substitution ‚Ąē := őĽ c => if c = a then b else c;
  apply C!_replace ?_ ?_ $ L.subst (s := s) h;
  . simpa [s] using L.C_subst_attachmodality_mpr (s := s) (ŌÜ := (.atom a));
  . simpa [s] using L.C_subst_attachmodality_mp (s := s) (ŌÜ := (.atom a));
‚ü©

lemma translation_expand_right {L : Logic _} [L.IsNormal] (m‚āĀ m‚āā m) [m‚āĀ ‚§≥[L] m‚āā] : (m‚āĀ + m) ‚§≥[L] (m‚āā + m) := by
  constructor;
  intro a;
  simpa using Translation.translate_fml (L := L) (m‚āĀ := m‚āĀ) (m‚āā := m‚āā) $ m (.atom a);

lemma translation_expand_left {L : Logic _} [L.IsNormal] (m‚āĀ m‚āā m) [m‚āĀ ‚§≥[L] m‚āā] [m ‚§≥[L] (-)] : (m + m‚āĀ) ‚§≥[L] (m‚āā) := by
  constructor;
  intro a;
  have H‚āĀ : L ‚äĘ (m + m‚āĀ) (atom a) ‚ěĚ m‚āĀ (atom a) := by simpa using Translation.translate_fml (m‚āĀ := m) (m‚āā := (-)) (m‚āĀ (.atom a));
  have H‚āā : L ‚äĘ m‚āĀ (atom a) ‚ěĚ m‚āā (atom a) := Translation.translate_fml (.atom a);
  exact C!_trans H‚āĀ H‚āā;

lemma Equivalence.equivalent_fml [m‚āĀ ‚ČÖ[L] m‚āā] (ŌÜ : Formula _) : L ‚äĘ m‚āĀ ŌÜ ‚≠§ m‚āā ŌÜ := by
  apply E!_intro <;> apply Translation.translate_fml;

def equivalence_of_axiomInstance {a : ‚Ąē} (h : L ‚äĘ (m‚āĀ a) ‚≠§ (m‚āā a)) : m‚āĀ ‚ČÖ[L] m‚āā := by
  apply iff_equivalence_bi_translate.mpr;
  constructor;
  . apply translation_of_axiomInstance (a := a);
    apply C_of_E_mp! h;
  . apply translation_of_axiomInstance (a := a);
    apply C_of_E_mpr! h;

lemma equivalence_expand_right {L : Logic _} [L.IsNormal] (m‚āĀ m‚āā m) [m‚āĀ ‚ČÖ[L] m‚āā] : (m‚āĀ + m) ‚ČÖ[L] (m‚āā + m) := by
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> apply translation_expand_right;

lemma equivalence_expand_left {L : Logic _} [L.IsNormal] (m‚āĀ m‚āā m) [m‚āĀ ‚ČÖ[L] m‚āā] : (m + m‚āĀ) ‚ČÖ[L] (m + m‚āā) := by
  constructor;
  intro a;
  induction m with
  | empty    => apply Equivalence.equivalent_fml (m‚āĀ := m‚āĀ) (m‚āā := m‚āā);
  | box m ih => apply box_congruence! ih;
  | dia m ih => apply dia_congruence! ih;
  | neg m ih => apply neg_congruence! ih;

end Modality


namespace Logic

open Modality
open Formula


section

open LO.Entailment

variable {L : Logic _} [L.IsNormal] {m : Modality}

instance : m ‚§≥[L] m := refl m

instance : (‚Ė°) ‚ČÖ[L] (‚ąľ‚óá‚ąľ) := ‚ü®by simp‚ü©

instance : (‚óá) ‚ČÖ[L] (‚ąľ‚Ė°‚ąľ) := ‚ü®by simp‚ü©

instance : (‚ąľ‚ąľ) ‚ČÖ[L] (-) := by
  apply equivalence_of_axiomInstance (a := 0);
  simp only [attachmodality];
  cl_prover;

instance : (‚Ė°‚ąľ) ‚ČÖ[L] (‚ąľ‚óá) := by
  apply equivalence_of_axiomInstance (a := 0);
  simp only [attachmodality];
  -- TODO: extract ` ‚Ė°‚ąľp ‚≠§ ‚ąľ‚óáp`
  apply E!_intro;
  . simp;
  . apply C!_trans (Ōą := ‚ąľ‚ąľ‚Ė°(‚ąľ(.atom 0)));
    . apply contra!; simp;
    . simp;

instance : (‚óá‚ąľ) ‚ČÖ[L] (‚ąľ‚Ė°) := by
  apply equivalence_of_axiomInstance (a := 0);
  simp only [attachmodality];
  -- TODO: extract `‚óá‚ąľp ‚≠§ ‚ąľ‚Ė°p`
  apply E!_intro;
  . apply C!_trans (Ōą := ‚ąľ‚Ė°(‚ąľ‚ąľ(.atom 0)));
    . simp;
    . simp;
  . apply C!_trans (Ōą := ‚ąľ‚ąľ‚óá(‚ąľ(.atom 0)));
    . apply contra!; simp;
    . simp;

end

section

open Hilbert.Normal

variable {H : Axiom ‚Ąē} [H.HasK] {m : outParam (Modality)}
variable {L : Logic _} [L.IsNormal]

instance [Entailment.HasAxiomT L] : (‚Ė°m) ‚§≥[L] (m) := translation_of_axiomInstance (a := 0) $ by simp;
instance [Entailment.HasAxiomFour L] : (‚Ė°m) ‚§≥[L] (‚Ė°‚Ė°m) := translation_of_axiomInstance (a := 0) $ by simp;
instance [Entailment.HasAxiomTc L] : (m) ‚§≥[L] (‚Ė°m) := translation_of_axiomInstance (a := 0) $ by simp;
