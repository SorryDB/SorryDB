/-- pure box -/
abbrev pbox : Modality := ‚Ė°-
notation:81 "‚Ė°" => pbox

/-- pure diamond -/
abbrev pdia : Modality := ‚óá-
notation:81 "‚óá" => pdia

/-- pure negation -/
abbrev pneg : Modality := ‚ąľ-
notation:81 "‚ąľ" => pneg

