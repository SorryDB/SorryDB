  | - ,  m‚āā => m‚āā
  | ‚Ė°m‚āĀ, m‚āā => ‚Ė°(m‚āĀ.add m‚āā)
  | ‚óám‚āĀ, m‚āā => ‚óá(m‚āĀ.add m‚āā)
  | ‚ąľm‚āĀ, m‚āā => ‚ąľ(m‚āĀ.add m‚āā)
instance : Add Modality := ‚ü®Modality.add‚ü©

@[simp] lemma add_empty_left : - + m = m := by rfl
@[simp] lemma add_box_left : ‚Ė°m‚āĀ + m‚āā = ‚Ė°(m‚āĀ + m‚āā) := rfl
@[simp] lemma add_dia_left : ‚óám‚āĀ + m‚āā = ‚óá(m‚āĀ + m‚āā) := rfl
@[simp] lemma add_neg_left : ‚ąľm‚āĀ + m‚āā = ‚ąľ(m‚āĀ + m‚āā) := rfl

@[simp]
lemma add_empty_right : m + - = m := by
  induction m with
