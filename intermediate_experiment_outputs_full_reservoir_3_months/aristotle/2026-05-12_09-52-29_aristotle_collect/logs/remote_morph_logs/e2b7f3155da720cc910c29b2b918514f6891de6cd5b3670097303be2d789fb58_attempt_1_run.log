abbrev Modalities := Finset Modality

namespace Modalities

open Modality

variable {n : ‚Ąē} {m : Modality} {M : Modalities}

def max_size (M : Modalities) (M_nonempty : M.Nonempty := by decide) := M.image (őĽ m => m.size) |>.max' $ Finset.image_nonempty.mpr M_nonempty

-- #eval max_size ({-, ‚ąľ, ‚Ė°, ‚Ė°, ‚Ė°, ‚Ė°‚Ė°‚Ė°‚Ė°‚Ė°‚Ė°‚Ė°, ‚Ė°, ‚óá})

lemma lt_max_size_of_mem {M_nonempty : M.Nonempty} (hM : m ‚ąą M) : m.size ‚Č§ (M.max_size M_nonempty) := by
  apply Finset.le_max';
  simp only [Finset.mem_image];
  use m;

def allOfSize : ‚Ąē ‚Üí Modalities
  | 0 => {-}
  | n + 1 =>
    (allOfSize n).image (őĽ m => ‚ąľm) ‚ą™
    (allOfSize n).image (őĽ m => ‚Ė°m) ‚ą™
    (allOfSize n).image (őĽ m => ‚óám)

@[simp] lemma allOfSize.eq_zero : allOfSize 0 = {-} := rfl

lemma allOfSize.iff_mem_eq_size : m ‚ąą allOfSize n ‚ÜĒ m.size = n := by
  induction n generalizing m with
  | zero => simp [allOfSize];
  | succ n ih =>
    simp only [allOfSize, Finset.union_assoc, Finset.mem_union, Finset.mem_image];
    constructor;
    . rintro (‚ü®m, ‚ü®hm, rfl‚ü©‚ü© | ‚ü®M, ‚ü®hm, rfl‚ü©‚ü© | ‚ü®M, ‚ü®hm, rfl‚ü©‚ü©) <;> simp [ih.mp hm];
    . intro;
      match m with
      | -  => contradiction;
      | ‚ąľm => simp_all [allOfSize];
      | ‚Ė°m => simp_all [allOfSize];
      | ‚óám => simp_all [allOfSize];

@[simp]
lemma allOfSize.mem_of_size : m ‚ąą allOfSize m.size := by simp only [allOfSize.iff_mem_eq_size];

@[simp]
lemma allOfSize.iff_mem_zero : m ‚ąą allOfSize 0 ‚ÜĒ m = - := by
  simp [allOfSize.iff_mem_eq_size]

instance : DecidablePred (¬∑ ‚ąą allOfSize n) := by
  simp only [allOfSize.iff_mem_eq_size];
  infer_instance;

-- #eval allOfSize 2
-- #eval ‚Ė° ‚ąą allOfSize 1

lemma allOfSize.eq_succ_left‚āĀ : m ‚ąą allOfSize (n + 1) ‚Üí ‚ąÉ m‚āĀ m‚āā, m‚āĀ ‚ąą allOfSize 1 ‚ąß m‚āā ‚ąą allOfSize n ‚ąß m = m‚āĀ + m‚āā := by
  simp only [allOfSize.iff_mem_eq_size];
  apply split_left‚āĀ;

lemma allOfSize.eq_succ_right‚āĀ : m ‚ąą allOfSize (n + 1) ‚Üí ‚ąÉ m‚āĀ m‚āā, m‚āĀ ‚ąą allOfSize n ‚ąß m‚āā ‚ąą allOfSize 1 ‚ąß m = m‚āĀ + m‚āā := by
  simp only [allOfSize.iff_mem_eq_size];
  apply split_right‚āĀ;


def allOfSizeLe : Nat ‚Üí Modalities
  | 0 => allOfSize 0
  | n + 1 => allOfSizeLe n ‚ą™ allOfSize (n + 1)

-- #eval allOfSizeLe 3

lemma allOfSizeLe.iff_mem_le_size : m ‚ąą allOfSizeLe n ‚ÜĒ m.size ‚Č§ n := by
  induction n with
  | zero => simp [allOfSizeLe];
  | succ n ih =>
    simp only [allOfSizeLe, Finset.mem_union];
    constructor;
    . rintro (h | h);
      . have := ih.mp h; omega;
      . have := allOfSize.iff_mem_eq_size.mp h; omega;
    . intro h;
      replace h := lt_or_eq_of_le h;
      rcases h with (h | h);
      . left;
        apply ih.mpr;
        omega;
      . right;
        exact allOfSize.iff_mem_eq_size.mpr h;

instance : DecidablePred (¬∑ ‚ąą allOfSizeLe n) := by
  simp only [allOfSizeLe.iff_mem_le_size];
  infer_instance;

#eval ‚Ė°‚óá ‚ąą allOfSizeLe 2

@[simp]
lemma allOfSizeLe.iff_mem_zero : m ‚ąą allOfSizeLe 0 ‚ÜĒ m = - := by
  simp [allOfSizeLe.iff_mem_le_size, allOfSize.iff_mem_eq_size]

@[simp]
lemma allOfSizeLe.mem_empty : - ‚ąą allOfSizeLe n := by induction n <;> simp_all [allOfSizeLe];

lemma allOfSizeLe.subset_of_le (h : n‚āĀ ‚Č§ n‚āā) : allOfSizeLe n‚āĀ ‚äÜ allOfSizeLe n‚āā := by
  intro m;
  simp_all [allOfSizeLe.iff_mem_le_size]
  omega;

lemma allOfSizeLe.eq_succ_left‚āĀ : m ‚ąą allOfSizeLe (n‚āā + 1) ‚Üí ‚ąÉ m‚āĀ m‚āā, m‚āĀ ‚ąą allOfSizeLe 1 ‚ąß m‚āā ‚ąą allOfSizeLe n‚āā ‚ąß m = (m‚āĀ + m‚āā) := by
  simp only [allOfSizeLe.iff_mem_le_size];
  apply split_left_le‚āĀ;

lemma allOfSizeLe.eq_succ_right‚āĀ : m ‚ąą allOfSizeLe (n‚āĀ + 1) ‚Üí ‚ąÉ m‚āĀ m‚āā, m‚āĀ ‚ąą allOfSizeLe n‚āĀ ‚ąß m‚āā ‚ąą allOfSizeLe 1 ‚ąß m = (m‚āĀ + m‚āā) := by
  simp only [allOfSizeLe.iff_mem_le_size];
  apply split_right_le‚āĀ;


def posOfSize : ‚Ąē ‚Üí Modalities
  | 0 => {-}
  | n + 1 => (posOfSize n).image (őĽ m => ‚Ė°m) ‚ą™ (posOfSize n).image (őĽ m => ‚óám)

#eval posOfSize 3

end Modalities



section

open Modality Modalities

variable {L : Logic _} {M : Modalities} {n : ‚Ąē} {n : ‚Ąē}

/-- In `L`, every `n`-size modality is reduced to some modality in `M` -/
abbrev ModalReduction (L : Logic _) (n : ‚Ąē) (M : Modalities) := ‚ąÄ m, m.size = n ‚Üí ‚ąÉ m' ‚ąą M, m ‚§≥[L] m'

lemma ModalReduction.of_allOfSize (h : ‚ąÄ m, m ‚ąą allOfSize n ‚Üí ‚ąÉ m' ‚ąą M, m ‚§≥[L] m') : ModalReduction L n M := by
  intro m hm;
  apply h;
  exact allOfSize.iff_mem_eq_size.mpr hm;


/-- In `L`, every modality of size less than `n` is reduced to some modality in `M` -/
abbrev ModalReductionLe (L : Logic _) (n : ‚Ąē) (M : Modalities) := ‚ąÄ m, m.size ‚Č§ n ‚Üí ‚ąÉ m' ‚ąą M, m ‚§≥[L] m'

lemma ModalReductionLe.of_allOfSizeLe (h : ‚ąÄ m, m ‚ąą allOfSizeLe n ‚Üí ‚ąÉ m' ‚ąą M, m ‚§≥[L] m') : ModalReductionLe L n M := by
  intro m hm;
  apply h;
  exact allOfSizeLe.iff_mem_le_size.mpr hm;

lemma ModalReductionLe.of_cumulative (h : ‚ąÄ n' ‚Č§ n, ModalReduction L n' M) : ModalReductionLe L n M := by
  intro m hm;
  apply h m.size ?_ m ?_ <;> tauto;

lemma ModalReductionLe.gt (h : ModalReductionLe L n M) (hn : n ‚Č• n'): ModalReductionLe L n' M := by
  intro m hm;
  apply h m (by omega);

lemma ModalReduction.of_le (h : ModalReductionLe L n M) : ModalReduction L n M := by
  intro m hm;
  apply h m (by omega);


macro "reduce_to " t:term : tactic => `(tactic| focus
  try simp only [add_empty_left, add_box_left, add_dia_left, add_neg_left];
  existsi $t;
  constructor;
  . set_option linter.unnecessarySimpa false in
    first | decide | simpa;
  . infer_instance;
)

section

variable [L.IsNormal]

lemma ModalReduction.reducible_0_of_mem (hM : (-) ‚ąą M) : ModalReduction L 0 M := by
  apply of_allOfSize;
  intro m hm;
  simp only [allOfSize.eq_zero, Finset.mem_singleton] at hm;
  subst hm;
  reduce_to (-);

lemma ModalReduction.reducible_1_of_mem (hNeg : (‚ąľ) ‚ąą M) (hBox : (‚Ė°) ‚ąą M) (hDia : (‚óá) ‚ąą M) : ModalReduction L 1 M := by
  apply of_allOfSize;
  intro m hm;
  simp only [
    allOfSize, Finset.image_singleton, Finset.union_assoc, Finset.mem_union,
    Finset.mem_singleton
  ] at hm;
  rcases hm with (rfl | rfl | rfl);
  . reduce_to (‚ąľ);
  . reduce_to (‚Ė°);
  . reduce_to (‚óá);

lemma ModalReduction.succ_max_of {M : Modalities} (M_ne : M.Nonempty)
  (hMR: ModalReductionLe L ((M.max_size M_ne) + 1) M)
  : ‚ąÄ n, ModalReductionLe L (n + (M.max_size M_ne) + 2) M := by
  generalize hk : (M.max_size M_ne) = k at hMR ‚äĘ;
  intro n m hm;
  obtain ‚ü®m‚āĀ, m‚āā, hm‚āĀ, hm‚āā, rfl‚ü© : ‚ąÉ m‚āĀ m‚āā, m‚āĀ.size ‚Č§ k + 1 ‚ąß m‚āā.size ‚Č§ n + 1 ‚ąß m = m‚āĀ + m‚āā := split_le $ by omega;
  induction n generalizing m‚āā with
  | zero =>
    obtain ‚ü®m‚āÉ, hm‚āÉ, _‚ü© := hMR m‚āĀ hm‚āĀ;
    obtain ‚ü®m‚āĄ, hm‚āĄ, _‚ü© := hMR (m‚āÉ + m‚āā) $ by
      have : m‚āÉ.size ‚Č§ k := by simpa [hk] using @Modalities.lt_max_size_of_mem _ M M_ne hm‚āÉ;
      simp only [add_size];
      omega;
    use m‚āĄ;
    constructor;
    . assumption;
    . trans (m‚āÉ + m‚āā);
      . apply translation_expand_right;
      . assumption;
  | succ n ih =>
    obtain ‚ü®m‚āÉ, m‚āĄ, hm‚āÉ, hm‚āĄ, rfl‚ü© := split_right_le‚āĀ hm‚āā;
    obtain ‚ü®m‚āÖ, hm‚āÖ, _‚ü© := @ih m‚āÉ hm‚āÉ (by simp; omega);
    obtain ‚ü®m‚āÜ, hm‚āÜ, _‚ü© := hMR (m‚āÖ + m‚āĄ) $ by
      have : m‚āÖ.size ‚Č§ k := by simpa [hk] using @Modalities.lt_max_size_of_mem _ M M_ne hm‚āÖ;
      simp only [add_size];
      omega;
    use m‚āÜ;
    constructor;
    . assumption;
    . trans (m‚āÖ + m‚āĄ);
      . rw [show (m‚āĀ + (m‚āÉ + m‚āĄ)) = ((m‚āĀ + m‚āÉ) + m‚āĄ) by simp];
        apply translation_expand_right;
      . assumption;

lemma ModalReductionLe.forall_of_reducibleLe_to_max (M_ne : M.Nonempty) (hMR: ModalReductionLe L ((M.max_size M_ne) + 1) M)
  : ‚ąÄ n, ModalReductionLe L n M := by
  intro n;
  by_cases hn : n ‚Č§ (M.max_size M_ne) + 1;
  . apply ModalReductionLe.gt hMR;
    omega;
  . have : M.max_size M_ne + 2 ‚Č§ n := by omega;
    apply ModalReductionLe.gt (n := n + M.max_size M_ne + 2) $ ModalReduction.succ_max_of M_ne hMR n;
    omega;

lemma ModalReduction.forall_of_reducibleLe_to_max (M_ne : M.Nonempty) (hMR: ModalReductionLe L ((M.max_size M_ne) + 1) M)
  : ‚ąÄ n, ModalReduction L n M := by
  intro n;
  apply ModalReduction.of_le;
  apply ModalReductionLe.forall_of_reducibleLe_to_max _ hMR;

theorem ModalReduction.forall_of_reducible_to_max (M_ne : M.Nonempty) (hMR: ‚ąÄ n' ‚Č§ ((M.max_size M_ne) + 1), ModalReduction L n' M)
  : ‚ąÄ n, ModalReduction L n M := by
  intro n;
  apply forall_of_reducibleLe_to_max M_ne;
  apply ModalReductionLe.of_cumulative;
  exact hMR;

end


end

