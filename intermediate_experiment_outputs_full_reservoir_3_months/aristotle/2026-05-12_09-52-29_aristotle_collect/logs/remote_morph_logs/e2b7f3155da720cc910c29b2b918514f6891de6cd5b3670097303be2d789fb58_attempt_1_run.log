@[simp]
lemma add_assoc : (m‚āĀ + m‚āā) + m‚āÉ = m‚āĀ + (m‚āā + m‚āÉ) := by
  induction m‚āĀ with
  | empty => rfl
  | box m‚āĀ ih | dia m‚āĀ ih | neg m‚āĀ ih => simp [ih]

instance : Std.Associative (őĪ := Modality) (¬∑ + ¬∑) := ‚ü®@add_assoc‚ü©

inductive Polarity
| pos
| neg

variable {P : Polarity}

def Polarity.inv : Polarity ‚Üí Polarity
  | pos => neg
  | neg => pos

@[simp]
lemma Polarity.eq_invinv : P.inv.inv = P := by
  induction P with
  | pos => rfl
  | neg => rfl

def polarity : Modality ‚Üí Polarity
  | -  => .pos
  | ‚Ė°m => m.polarity
  | ‚óám => m.polarity
  | ‚ąľm => m.polarity.inv

@[simp] lemma pempty_pos : (-).polarity = .pos := rfl
@[simp] lemma pbox_pos   : (‚Ė°).polarity = .pos := rfl
@[simp] lemma pdia_pos   : (‚óá).polarity = .pos := rfl
@[simp] lemma pneg_pos   : (‚ąľ).polarity = .neg := rfl
@[simp] lemma box_pos    : (‚Ė°m).polarity = m.polarity := by simp [polarity]
@[simp] lemma dia_pos    : (‚óám).polarity = m.polarity := by simp [polarity]
@[simp] lemma neg_pos    : (‚ąľm).polarity = m.polarity.inv := by simp [polarity]

def size : Modality ‚Üí Nat
  | -  => 0
  | ‚Ė°m => m.size + 1
  | ‚óám => m.size + 1
  | ‚ąľm => m.size + 1

@[simp] lemma empty_size_zero : (-).size = 0 := rfl
@[simp] lemma pbox_size_one   : (‚Ė°).size = 1 := rfl
@[simp] lemma pdia_size_one   : (‚óá).size = 1 := rfl
@[simp] lemma pneg_size_one   : (‚ąľ).size = 1 := rfl
@[simp] lemma box_size_succ   : (‚Ė°m).size = m.size + 1 := rfl
@[simp] lemma dia_size_succ   : (‚óám).size = m.size + 1 := rfl
@[simp] lemma neg_size_succ   : (‚ąľm).size = m.size + 1 := rfl

@[simp]
lemma sneg_size_le_succ : (‚©™m).size ‚Č§ (m.size + 1) := by
  match m with
  | - | ‚Ė°m | ‚óám => simp [sneg];
  | ‚ąľm => simp [sneg]; omega;

@[simp]
lemma sneg_size_le_neg_size : (‚©™m).size ‚Č§ (‚ąľm).size := by trans (m.size + 1) <;> simp [sneg_size_le_succ];

@[simp]
lemma sneg_sneg_size_le_succ : (‚©™‚©™m).size ‚Č§ m.size + 1 := by
  match m with
  | - | ‚Ė°m | ‚óám | ‚ąľ- | ‚ąľ‚Ė°m | ‚ąľ‚óám => simp [sneg];
  | ‚ąľ‚ąľm => simp [sneg]; omega;

