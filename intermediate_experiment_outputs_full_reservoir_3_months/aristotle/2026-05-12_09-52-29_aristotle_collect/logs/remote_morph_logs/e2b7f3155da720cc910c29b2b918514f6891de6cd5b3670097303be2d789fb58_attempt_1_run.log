  constructor;
  . match m with | - | ‚Ė°_ | ‚óá_ | ‚ąľ_ => simp;
  . rintro (rfl | rfl | rfl) <;> simp;

lemma iff_size_2 : m.size = 2 ‚ÜĒ
                   m = ‚Ė°‚Ė° ‚ą® m = ‚Ė°‚óá ‚ą® m = ‚Ė°‚ąľ ‚ą®
                   m = ‚óá‚Ė° ‚ą® m = ‚óá‚óá ‚ą® m = ‚óá‚ąľ ‚ą®
                   m = ‚ąľ‚Ė° ‚ą® m = ‚ąľ‚óá ‚ą® m = ‚ąľ‚ąľ := by
