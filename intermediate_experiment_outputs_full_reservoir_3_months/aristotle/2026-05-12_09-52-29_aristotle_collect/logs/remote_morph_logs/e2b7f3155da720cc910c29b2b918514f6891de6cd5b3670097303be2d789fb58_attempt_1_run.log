    | ‚Ė°m | ‚óám | ‚ąľm  =>
      suffices m.size = 1 ‚Üí (m = ‚Ė°) ‚ą® (m = ‚óá) ‚ą® (m = ‚ąľ) by simpa
      exact iff_size_1.mp;
  . rintro (rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl) <;> simp;

@[simp]
lemma add_size : (m‚āĀ + m‚āā).size = m‚āĀ.size + m‚āā.size := by
  induction m‚āĀ with
  | empty => simp [add];
  | box m‚āĀ ih | dia m‚āĀ ih | neg m‚āĀ ih => simp [add, ih]; omega;

lemma split_left‚āĀ (hm : m.size = n‚āā + 1) : ‚ąÉ m‚āĀ m‚āā, m‚āĀ.size = 1 ‚ąß m‚āā.size = n‚āā ‚ąß m = m‚āĀ + m‚āā := by
  match m with
  | -  => tauto;
  | ‚Ė°m =>
    use ‚Ė°, m;
    refine ‚ü®by tauto, ?_, ?_‚ü©;
    . simpa using hm;
    . rfl;
  | ‚óám =>
    use ‚óá, m;
    refine ‚ü®by tauto, ?_, ?_‚ü©;
    . simpa using hm;
    . rfl;
  | ‚ąľm =>
    use ‚ąľ, m;
    refine ‚ü®by tauto, ?_, ?_‚ü©;
    . simpa using hm;
    . rfl;

lemma split_left‚āĀ' (hm : m.size = n + 1) : ‚ąÉ m', m'.size = n ‚ąß (m = ‚Ė°m' ‚ą® m = ‚óám' ‚ą® m = ‚ąľm') := by
  obtain ‚ü®m‚āĀ, m‚āā, hm‚āĀ, hm‚āā, rfl‚ü© := split_left‚āĀ hm;
  use m‚āā;
  constructor;
  . assumption;
  . rcases iff_size_1.mp hm‚āĀ with (rfl | rfl | rfl) <;> tauto;

lemma split_right‚āĀ (hm : m.size = n + 1) : ‚ąÉ m‚āĀ m‚āā, m‚āĀ.size = n ‚ąß m‚āā.size = 1 ‚ąß m = m‚āĀ + m‚āā := by
  induction n generalizing m with
