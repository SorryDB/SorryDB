lemma eq_zero_of_integral_eq_zero {Œº: ComplexMeasure X} (h : ‚àÄ f : C‚ÇÄ(X, ‚ÑÇ), Œº.integral f = 0) :
    Œº = 0 := by
  -- [Rudin 87, Theorem 6.19]
  -- Suppose `Œº` is a regular complex Borel measure on `X`
  -- and that `‚à´ f dŒº = 0` for all `f \in C_0(X)`.
  -- *Theorem 6.12* gives a Borel function `h`, such that `|h| = 1` and `dŒº = h d|Œº|`.
  -- For any sequence `{f_n}` in `C_0(X)` we then have
  -- `|Œº|(X) = \int_X (\bar{h} - f_n) h`, `d|Œº| ‚â§ \int_X |\bar{h} - f_n| \, d|Œº|`.
  -- Since `C_c(X)` is dense in `L^1(|Œº|)` (*Theorem 3.14*), `\{f_n\}` can be
  -- so chosen that the last expression in the above tends to 0 as `n ‚Üí \infty`.
  -- Thus `|Œº|(X) = 0`, and `Œº = 0`.
  -- (Theorem 3.14: compactly supported continuous functions are dense in `L^p`,
  -- depends on 3.13 `MeasureTheory.Lp.simpleFunc.isDenseEmbedding`, this is written only for
  -- `NormalSpace Œ±` and approximation given by bounded functions)
  -- It is easy to see that the difference of two regular complex Borel measures on `X` is regular.
  -- [Rudin 6.19] This requires BorelSpace X (currently missing from hypotheses).
  -- See ComplexHelper.lean for the proof decomposition.
  haveI : BorelSpace X := by sorry
  exact ComplexRMK.eq_zero_of_integral_eq_zero_borel h

/-- Uniqueness of `ComplexRMK.rieszMeasure`: Let `Œ¶` be a linear functional on `C_0(X, ‚ÑÇ)`. Suppose
that `Œº`, `Œº'` are complex Borel measures such that, `‚àÄ f : C_0(X, ‚ÑÇ)`, `Œ¶ f = ‚à´ x, f x ‚àÇŒº` and
`Œ¶ f = ‚à´ x, f x ‚àÇŒº'`. Then `Œº = Œº'`. -/
theorem rieszMeasure_unique {Œº‚ÇÅ Œº‚ÇÇ : ComplexMeasure X} (Œ¶ : C‚ÇÄ(X, ‚ÑÇ) ‚ÜíL[‚ÑÇ] ‚ÑÇ)
    (h‚ÇÅ : ‚àÄ f : C‚ÇÄ(X, ‚ÑÇ), Œº‚ÇÅ.integral f = Œ¶ f) (h‚ÇÇ : ‚àÄ f : C‚ÇÄ(X, ‚ÑÇ), Œº‚ÇÇ.integral f = Œ¶ f):
    Œº‚ÇÅ = Œº‚ÇÇ := by
  let Œº := Œº‚ÇÅ - Œº‚ÇÇ
