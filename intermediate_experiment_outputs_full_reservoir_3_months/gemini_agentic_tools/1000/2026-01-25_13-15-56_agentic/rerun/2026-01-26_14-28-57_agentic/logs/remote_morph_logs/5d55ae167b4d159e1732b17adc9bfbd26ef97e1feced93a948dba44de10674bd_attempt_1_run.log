instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f [hf : Mono f] := by
    let D := S.diagram ⋙ FintypeCat.toProfinite
    let hL := Limits.isLimitOfPreserves lightToProfinite S.asLimit
    let proj (n : ℕ) : lightToProfinite.obj S ⟶ D.obj (Opposite.op n) := hL.π.app (Opposite.op n)
    let tr (n : ℕ) : D.obj (Opposite.op (n + 1)) ⟶ D.obj (Opposite.op n) := D.map (homOfLe n.le_succ).op
    haveI (n : ℕ) : Finite (D.obj (Opposite.op n)) := inferInstanceAs (Finite (S.component n))
    haveI : Nonempty (D.obj (Opposite.op 0)) := Nonempty.map (S.proj 0) (inferInstance : Nonempty S)
    haveI (n : ℕ) : Epi (tr n) := (Profinite.epi_iff_surjective (tr n)).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ proj 0) f
    let h_step (n : ℕ) (k : Y ⟶ D.obj (Opposite.op n)) (hd : f ≫ k = g ≫ proj n) :
      ∃ k' : Y ⟶ D.obj (Opposite.op (n + 1)), k' ≫ tr n = k ∧ f ≫ k' = g ≫ proj (n + 1) := by
      have h_comm : f ≫ k = g ≫ proj (n + 1) ≫ tr n := by
        rw [hd, ← Category.assoc, ← hL.w (homOfLe n.le_succ).op]; rfl
      exact profinite_key_extension_lemma _ _ _ _ f (tr n) (g ≫ proj (n + 1)) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ D.obj (Opposite.op n) // f ≫ k = g ≫ proj n }
    let next (n : ℕ) (k : lifts n) : lifts (n + 1) :=
      ⟨Classical.choose (h_step n k.val k.property), (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h0⟩ next n
    let k_cone : Cone D := { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1.symm) }
    use hL.lift k_cone
    apply hL.hom_ext; intro n; induction n using Opposite.rec' with | op n =>
    simp [NatTrans.ofOpSequence_app, (k_seq n).property]
