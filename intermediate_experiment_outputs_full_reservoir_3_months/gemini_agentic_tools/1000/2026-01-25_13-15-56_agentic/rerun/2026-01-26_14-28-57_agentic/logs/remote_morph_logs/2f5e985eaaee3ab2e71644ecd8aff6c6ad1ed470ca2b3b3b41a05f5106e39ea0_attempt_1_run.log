  rcases (equinum_iff_inverse_pair _ _).mp (Set_equinum_powerset B) with ⟨f3, g3, f3g3, g3f3⟩
  use f3 ∘ f2 ∘ g1, f1 ∘ g2 ∘ g3
  constructor
  · simp [g1f1, f2g2, f3g3]
  · simp [g3f3, g2f2, f1g1]

