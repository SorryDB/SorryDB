lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  apply le_tsub_of_add_le_left
  rw [MatchingNumber, mul_comm, sSup_le_iff]
  rintro n ⟨M, hM, rfl⟩
  let MR := M ∩ E(G - Y); let MY := M \ MR
  have hM_enc : M.encard = MR.encard + MY.encard := by
    rw [← encard_union_eq (Set.disjoint_sdiff_right.mono_left (inter_subset_left _ _)),
      inter_union_diff]
  have h1 : 2 * MR.encard + (G - Y).OddComponents.encard ≤ (V(G) \ Y).encard := sorry
  have h2 : 2 * MY.encard ≤ (Y ∩ V(G)).encard + Y.encard := sorry
  rw [hM_enc, mul_add, add_right_comm]
  exact (add_le_add_right h1 _).trans (by
    rw [add_assoc, ← encard_diff_add_encard_inter V(G) Y, add_assoc]
    exact add_le_add_left h2 _)
