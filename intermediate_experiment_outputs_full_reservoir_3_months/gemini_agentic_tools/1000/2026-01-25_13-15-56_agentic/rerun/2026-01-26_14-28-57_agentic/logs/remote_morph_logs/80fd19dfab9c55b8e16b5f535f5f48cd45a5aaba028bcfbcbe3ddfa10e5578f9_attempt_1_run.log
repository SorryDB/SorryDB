        refine mem_convexHull_singleton.1 (convexHull_mono ?_ (hy i hi))
        rintro _ ⟨j, hj, rfl⟩
        exact hx _ (mem_of_mem_sdiff hj)
      rw [hzi, sum_congr rfl (fun j hj ↦ hx j (mem_of_mem_sdiff hj)), sum_const, nsmul_eq_smul_cast 𝕜,
        inv_smul_smul₀ (by exact_mod_cast (hs.nonempty_sdiff hi).card_ne_zero)]
