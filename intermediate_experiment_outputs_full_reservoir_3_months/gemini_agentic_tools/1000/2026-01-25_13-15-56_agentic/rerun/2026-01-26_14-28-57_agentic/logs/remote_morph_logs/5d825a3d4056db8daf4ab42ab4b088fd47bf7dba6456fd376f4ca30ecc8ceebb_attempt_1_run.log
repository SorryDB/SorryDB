/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · rintro ⟨f, hf⟩ p hp
    let σ := (Module.support A M ∪ Module.support A N) ∩ {p | p.1.primeHeight = 1}
    set S := ⨅ q ∈ σ, q.1.primeCompl
    have hfS := (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f).mp hf
    by_cases hps : p ∈ σ
    · exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f)
        (LocalizedModule.map_bijective_of_isLocalization_iInf σ p hps f hfS)⟩
    · have hM : Subsingleton (LocalizedModule p.1.primeCompl M) := by
        rw [LocalizedModule.subsingleton_iff, ← Module.notMem_support_iff]
        intro hmem; exact hps ⟨Or.inl hmem, hp⟩
      have hN : Subsingleton (LocalizedModule p.1.primeCompl N) := by
        rw [LocalizedModule.subsingleton_iff, ← Module.notMem_support_iff]
        intro hmem; exact hps ⟨Or.inr hmem, hp⟩
      exact ⟨LocalizedModule.subsingletonEquiv hM hN⟩
  · intro h
    obtain ⟨ιM, _, pM, hM, eM, _, hMp⟩ := hMT.isPseudoIsomorphic_pi
    obtain ⟨ιN, _, pN, hN, eN, _, hNp⟩ := hNT.isPseudoIsomorphic_pi
    refine hMp.trans (hNp.symm.trans (IsPseudoIsomorphic.of_linearEquiv ?_))
    apply linearEquiv_of_localizedModule_iso_ht_one pM eM pN eN hM hN
    intro p hp
    let hMp_iso := (isPseudoIsomorphic_iff_bijective_map (Module.IsTorsion.pi (fun i => (pM i).1.primeCompl_le_nonZeroDivisors.isTorsion_quotient_power (eM i))) hMT (IsPseudoIsomorphic.some_map hMp)).mp (IsPseudoIsomorphic.some_prop hMp) p hp
    let hNp_iso := (isPseudoIsomorphism_iff_bijective_map (Module.IsTorsion.pi (fun i => (pN i).1.primeCompl_le_nonZeroDivisors.isTorsion_quotient_power (eN i))) hNT (IsPseudoIsomorphic.some_map hNp)).mp (IsPseudoIsomorphic.some_prop hNp) p hp
    exact ⟨(LinearEquiv.ofBijective _ hMp_iso).symm.trans ((h p hp).some.trans (LinearEquiv.ofBijective _ hNp_iso))⟩
```
