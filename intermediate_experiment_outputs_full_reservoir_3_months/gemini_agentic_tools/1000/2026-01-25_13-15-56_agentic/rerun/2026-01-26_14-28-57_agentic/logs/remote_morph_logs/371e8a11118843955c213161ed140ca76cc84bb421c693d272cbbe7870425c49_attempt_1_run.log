  | cons b bs ih =>
    simp [foldr1]
    have h₁ := h.right
    match ys with
    | [] => simp_all
    | z :: zs =>
      simp_all
      induction bs generalizing b with
      | nil => sorry
      | cons c cs ih' =>
        simp [foldr1]
        rw [ih]
        sorry
