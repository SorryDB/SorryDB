theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  apply Iff.intro
  · intro h
    cases h with
    | inl hf =>
      obtain ⟨n, hn⟩ := hf
      obtain ⟨f, g, hfg, hgf⟩ := (equinum_iff_inverse_pair (I n) U).mp hn
      exists (λ u => (g u).val)
      intros u1 u2 heq
      have h1 : g u1 = g u2 := Subtype.ext heq
      rw [←(congr_fun hfg u1), ←(congr_fun hfg u2), h1]
    | inr hd =>
      obtain ⟨f, g, hfg, hgf⟩ := (equinum_iff_inverse_pair Nat U).mp hd
      exists g
      intros u1 u2 heq
      rw [←(congr_fun hfg u1), ←(congr_fun hfg u2), heq]
  · intro ⟨f, hf⟩
    let A := range f
    have h1 : U ∼ A := by
      exists (λ u => ⟨f u, u, rfl⟩)
      apply And.intro
      · intros u1 u2 heq
        exact hf (congrArg Subtype.val heq)
      · intro ⟨n, hn⟩
        obtain ⟨u, hu⟩ := hn
        exists u
        apply Subtype.ext
        exact hu
    have h2 : ctble Nat := Or.inr (equinum_refl Nat)
    have h3 : ctble A := theorem_8_1_3 A h2
    exact ctble_of_ctble_equinum (equinum_symm h1) h3
