theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  apply Iff.intro
  · intro h
    cases h with
    | inl hf =>
      obtain ⟨n, g, hg1, hg2⟩ := hf
      exists (λ u => (g u).val)
      intros u1 u2 heq; exact hg1 (Subtype.ext heq)
    | inr hd =>
      obtain ⟨g, hg1, hg2⟩ := hd
      exists g; exact hg1
  · intro ⟨f, hf⟩
    let A := range f
    have h1 : U ∼ A := by
      exists (λ u => ⟨f u, ⟨u, rfl⟩⟩)
      apply And.intro
      · intros u1 u2 heq; exact hf (congrArg Subtype.val heq)
      · intro ⟨y, hy⟩; obtain ⟨u, hu⟩ := hy; exists u; exact Subtype.ext hu
    have h2 : ctble A := Theorem_8_1_3
    apply ctble_of_ctble_equinum _ h2
    obtain ⟨f', g', hf'g', hg'f'⟩ := (equinum_iff_inverse_pair U A).mp h1
    exact (equinum_iff_inverse_pair A U).mpr ⟨g', f', hg'f', hf'g'⟩
