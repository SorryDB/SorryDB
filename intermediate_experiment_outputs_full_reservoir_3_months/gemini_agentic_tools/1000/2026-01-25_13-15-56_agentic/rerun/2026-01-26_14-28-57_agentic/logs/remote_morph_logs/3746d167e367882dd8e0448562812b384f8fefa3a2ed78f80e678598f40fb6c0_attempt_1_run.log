/-- Every convex set in ℝ³ has VC₂ dimension at most 1.

In fact, this set n-shatters an infinite set. -/
lemma vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  let P (i j : Fin 2) : Fin 3 → ℝ := x i + y j
  have h_par : P 0 0 + P 1 1 = P 0 1 + P 1 0 := by ext k; simp [P]; abel
  let M (s : Set (Fin 2 × Fin 2)) : Fin 3 → ℝ := (1 / 2 : ℝ) • (P 0 0 + z s) + (1 / 2 : ℝ) • (P 1 1 + z s)
  have hM (s : Set (Fin 2 × Fin 2)) (h00 : (0, 0) ∈ s) (h11 : (1, 1) ∈ s) : M s ∈ C :=
    hC.segment_subset ((hxy 0 0 s).mpr h00) ((hxy 1 1 s).mpr h11)
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  have hM' (s : Set (Fin 2 × Fin 2)) : M s = (1 / 2 : ℝ) • (P 0 1 + z s) + (1 / 2 : ℝ) • (P 1 0 + z s) := by
    simp [M, smul_add]; abel_nf; rw [h_par]; abel
  have hM_alt (s : Set (Fin 2 × Fin 2)) (h01 : (0, 1) ∈ s) (h10 : (1, 0) ∈ s) : M s ∈ C := by
    rw [hM' s]
    exact hC.segment_subset ((hxy 0 1 s).mpr h01) ((hxy 1 0 s).mpr h10)
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  let s1 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1)}
  let s2 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0)}
  let s3 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (0, 1)}
  let s4 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0), (0, 0)}
  have h1 : M s1 ∈ C := hM s1 (by simp [s1]) (by simp [s1])
  have h2 : M s2 ∈ C := hM_alt s2 (by simp [s2]) (by simp [s2])
  have h3 : M s3 ∈ C := hM s3 (by simp [s3]) (by simp [s3])
  have h4 : M s4 ∈ C := hM_alt s4 (by simp [s4]) (by simp [s4])
  let S := {P 0 0, P 1 1, P 0 1, P 1 0}
  let x_2d : Fin 4 → Fin 2 → ℝ := fun i => if i = 0 then ![0, 0] else if i = 1 then ![1, 1] else if i = 2 then ![0, 1] else ![1, 0]
  exact vc_lt_four_of_convex_r2 sorry sorry
