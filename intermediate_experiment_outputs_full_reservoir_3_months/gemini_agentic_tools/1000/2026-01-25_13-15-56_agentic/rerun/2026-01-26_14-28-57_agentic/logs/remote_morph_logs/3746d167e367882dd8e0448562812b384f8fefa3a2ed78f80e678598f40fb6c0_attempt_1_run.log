and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := sorry

/-- There exists a set of infinite VC dimension in ℝ³. -/
lemma exists_convex_r3_vc_eq_infty :
    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := sorry

/-! ### What's new -/

/-- There exists a set of infinite VCₙ dimension in ℝⁿ⁺². -/
lemma exists_convex_rn_add_two_vc_n_eq_infty (n : ℕ) :
    ∃ (C : Set (Fin (n + 2) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 2) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 2) → ℝ),
        ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s := sorry

/-! ### Conjectures -/

/-- Every convex set in ℝ³ has VC₂ dimension at most 1.

In fact, this set n-shatters an infinite set. -/
lemma vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  let P (i j : Fin 2) : Fin 3 → ℝ := x i + y j
  have h_par : P 0 0 + P 1 1 = P 0 1 + P 1 0 := by ext k; simp [P]; abel
  let M : Fin 3 → ℝ := (1 / 2 : ℝ) • (P 0 0 + P 1 1)
  let s1 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1)}
  let s2 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0)}
  let s3 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (0, 1)}
  have hM1 : M + z s1 ∈ C := by
    have h00 : P 0 0 + z s1 ∈ C := (hxy 0 0 s1).mpr (by simp [s1])
    have h11 : P 1 1 + z s1 ∈ C := (hxy 1 1 s1).mpr (by simp [s1])
    have hmid : M + z s1 = (1 / 2 : ℝ) • (P 0 0 + z s1) + (1 / 2 : ℝ) • (P 1 1 + z s1) := by
      simp [M, smul_add]; abel
    rw [hmid]
    exact hC.segment_subset h00 h11 (Set.midpoint_mem_segment _ _)
  have hM3 : M + z s3 ∈ C := by
    have h00 : P 0 0 + z s3 ∈ C := (hxy 0 0 s3).mpr (by simp [s3])
    have h11 : P 1 1 + z s3 ∈ C := (hxy 1 1 s3).mpr (by simp [s3])
    have hmid : M + z s3 = (1 / 2 : ℝ) • (P 0 0 + z s3) + (1 / 2 : ℝ) • (P 1 1 + z s3) := by
      simp [M, smul_add]; abel
    rw [hmid]
    exact hC.segment_subset h00 h11 (Set.midpoint_mem_segment _ _)
  have h01_3 : P 0 1 + z s3 ∈ C := (hxy 0 1 s3).mpr (by simp [s3])
  have h10_3 : P 1 0 + z s3 ∉ C := (hxy 1 0 s3).not.mpr (by simp [s3])
  have h_mid_3 : M + z s3 = (1 / 2 : ℝ) • (P 0 1 + z s3) + (1 / 2 : ℝ) • (P 1 0 + z s3) := by
    have : M = (1 / 2 : ℝ) • (P 0 1 + P 1 0) := by rw [← h_par]; simp [M]
    simp [this, smul_add]; abel
  let s4 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0), (1, 1)}
  have hM4 : M + z s4 ∈ C := by
    have h01 : P 0 1 + z s4 ∈ C := (hxy 0 1 s4).mpr (by simp [s4])
    have h10 : P 1 0 + z s4 ∈ C := (hxy 1 0 s4).mpr (by simp [s4])
    have h_M : M = (1 / 2 : ℝ) • (P 0 1 + P 1 0) := by rw [← h_par]; simp [M]
    have hmid : M + z s4 = (1 / 2 : ℝ) • (P 0 1 + z s4) + (1 / 2 : ℝ) • (P 1 0 + z s4) := by
      simp [h_M, smul_add]; abel
    rw [hmid]
    exact hC.segment_subset h01 h10 (Set.midpoint_mem_segment _ _)
  sorry
