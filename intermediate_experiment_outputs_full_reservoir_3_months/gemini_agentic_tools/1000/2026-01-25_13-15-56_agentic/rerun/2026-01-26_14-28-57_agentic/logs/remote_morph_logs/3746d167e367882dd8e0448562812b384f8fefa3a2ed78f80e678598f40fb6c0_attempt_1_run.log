    have h00 : P 0 0 + z s1 ∈ C := (hxy 0 0 s1).mpr (by simp [s1])
    have h11 : P 1 1 + z s1 ∈ C := (hxy 1 1 s1).mpr (by simp [s1])
    convert hC.segment_subset h00 h11 (Set.midpoint_mem_segment (P 0 0 + z s1) (P 1 1 + z s1))
