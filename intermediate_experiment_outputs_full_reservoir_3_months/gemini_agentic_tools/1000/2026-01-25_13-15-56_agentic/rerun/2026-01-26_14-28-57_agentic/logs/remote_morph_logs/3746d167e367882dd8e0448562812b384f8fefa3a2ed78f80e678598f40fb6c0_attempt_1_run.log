/-- Every convex set in ℝ³ has VC₂ dimension at most 1.

In fact, this set n-shatters an infinite set. -/
lemma vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  let P (i j : Fin 2) : Fin 3 → ℝ := x i + y j
  have h_par : P 0 0 + P 1 1 = P 0 1 + P 1 0 := by ext k; simp [P]; abel
  let s1 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1)}
  let s2 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0)}
  let s3 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (0, 1)}
  let s4 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0), (0, 0)}
  let M (s : Set (Fin 2 × Fin 2)) : Fin 3 → ℝ := (1 / 2 : ℝ) • (P 0 0 + z s) + (1 / 2 : ℝ) • (P 1 1 + z s)
  have hM1 : M s1 ∈ C :=
    hC.segment_subset ((hxy 0 0 s1).mpr (by simp [s1])) ((hxy 1 1 s1).mpr (by simp [s1]))
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  have hM2 : (1 / 2 : ℝ) • (P 0 1 + z s2) + (1 / 2 : ℝ) • (P 1 0 + z s2) ∈ C :=
    hC.segment_subset ((hxy 0 1 s2).mpr (by simp [s2])) ((hxy 1 0 s2).mpr (by simp [s2]))
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  have h_M2_alt : (1 / 2 : ℝ) • (P 0 1 + z s2) + (1 / 2 : ℝ) • (P 1 0 + z s2) = M s2 := by
    simp [M]; abel_nf; rw [h_par]; abel_nf
  rw [h_M2_alt] at hM2
  have hM3 : M s3 ∈ C :=
    hC.segment_subset ((hxy 0 0 s3).mpr (by simp [s3])) ((hxy 1 1 s3).mpr (by simp [s3]))
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  have hM3_alt : M s3 = (1 / 2 : ℝ) • (P 0 1 + z s3) + (1 / 2 : ℝ) • (P 1 0 + z s3) := by
    simp [M]; abel_nf; rw [h_par]; abel_nf
  have hM4 : (1 / 2 : ℝ) • (P 0 1 + z s4) + (1 / 2 : ℝ) • (P 1 0 + z s4) ∈ C :=
    hC.segment_subset ((hxy 0 1 s4).mpr (by simp [s4])) ((hxy 1 0 s4).mpr (by simp [s4]))
      ⟨1 / 2, 1 / 2, by norm_num, by norm_num, by norm_num, rfl⟩
  have hM4_alt : (1 / 2 : ℝ) • (P 0 1 + z s4) + (1 / 2 : ℝ) • (P 1 0 + z s4) = M s4 := by
    simp [M]; abel_nf; rw [h_par]; abel_nf
  rw [hM4_alt] at hM4
  sorry
