                 exact mem_biUnion.2 ⟨f, hf, mem_inter.2 ⟨hx, mem_smul_finset.2 ⟨s, hs, rfl⟩⟩⟩)
             _ ≤ ∑ f in F, #(A ∩ MulOpposite.op f • S) := mod_cast card_biUnion_le
      have h3 : (F.card : ℝ) * (#A / (2 * K)) ≤ #A := by
