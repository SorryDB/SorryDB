        _ ≤ ∑ f ∈ F, (#(A ∩ MulOpposite.op f • S ^ 2) : ℝ) := by
          gcongr
          exact card_le_card (inter_subset_inter_right A (smul_finset_subset_smul_finset (subset_mul_right S hS₁)))
        _ < ∑ f ∈ F, (#A / (2 * K)) := Finset.sum_lt_sum (fun f hf ↦ h (hFA hf)) hF₀
        _ = #F * (#A / (2 * K)) := by simp
    have h2 : (#A : ℝ) ≤ ∑ f ∈ F, (#(A ∩ MulOpposite.op f • S) : ℝ) := by
      rw [← Nat.cast_sum]
      norm_cast
      calc
