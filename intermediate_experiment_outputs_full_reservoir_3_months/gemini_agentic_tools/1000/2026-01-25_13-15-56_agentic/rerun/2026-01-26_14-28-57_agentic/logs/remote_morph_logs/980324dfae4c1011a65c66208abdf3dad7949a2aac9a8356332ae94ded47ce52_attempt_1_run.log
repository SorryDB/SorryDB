def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnm hB
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hB.prop
    by_contra! h_aug
    have h_max : G.IsMaxMatching MI := by
      refine ⟨hMI, fun M' hM' ↦ by_contra fun h_lt ↦ ?_⟩
      obtain ⟨P, hP⟩ := hMI.exists_isAugPath_not_max (by
        rw [isMaxMatching_iff, not_and_or]
        exact Or.inr (not_forall.mpr ⟨M', not_le.mpr h_lt⟩))
      obtain ⟨x, hx⟩ := (hP.augment_vertex_subset.trans_subset (V_subset_V_symmDiff _ _)).exists_not_mem_subset hIMI
      exact h_aug x (by sorry) ⟨_, hP.augment, insert_subset hx hP.augment_vertex_subset⟩
    have h_MI_encard : MI.encard = MB.encard := h_max.encard.trans hB.prop.1.encard.symm
    have h_V_MI : V(G, MI).encard = V(G, MB).encard := by
      rw [encard_V_matching hMI, encard_V_matching hMB, h_MI_encard]
    exact hnm (hB.prop.2 hI (by
      rw [hBMB]
      intro x hxI
      obtain hx | hx := em (x ∈ V(G, MI))
      · sorry
      · sorry))
```
