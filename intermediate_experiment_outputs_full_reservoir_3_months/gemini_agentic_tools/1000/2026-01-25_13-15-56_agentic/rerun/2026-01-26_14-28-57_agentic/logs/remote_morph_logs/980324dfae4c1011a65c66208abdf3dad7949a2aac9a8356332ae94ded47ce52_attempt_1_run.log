def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnm hB
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hB.1
    have hB_eq : V(G, MB) = B := by
      refine (hB.2 (V(G, MB)) ⟨MB, hMB, subset_refl _⟩ hBMB).symm
    have hI_not_B : ¬(B ⊆ I) := by
      intro hsub
      apply hnm
      exact ⟨⟨MB, hMB, hBMB⟩, fun J hJ hIJ ↦ (hB.2 J hJ (hsub.trans hIJ)).symm.subset⟩
    obtain ⟨x, hxB, hxI⟩ := nonempty_diff.mpr hI_not_B
    have hMI_not_max : ¬ G.IsMaxMatching MI := by
      intro hmax
      apply hnm
      refine ⟨⟨MI, hMI, hIMI⟩, fun J hJ hIJ ↦ ?_⟩
      obtain ⟨MJ, hMJ, hJMJ⟩ := hJ
      have hJ_encard := (IsMatching.encard_le hMJ).trans_eq hmax.encard.symm
      have hMB_encard := (IsMatching.encard_le hMB).trans_eq hmax.encard.symm
      have hB_encard := (encard_V_le_two_encard MB).trans_eq (congr_arg (· * 2) hMB_encard)
      have hJ_encard_v := (encard_le_encard hJMJ).trans (encard_V_le_two_encard MJ)
      have hI_encard := (encard_le_encard hIMI).trans (encard_V_le_two_encard MI)
      sorry
    obtain ⟨P, hP⟩ := hMI.exists_isAugPath_not_max hMI_not_max
    use x, ⟨hxB, hxI⟩, (MI ∆ E(P)), hP.augment
    exact insert_subset_iff.mpr ⟨sorry, hIMI.trans hP.augment_vertex_subset⟩
