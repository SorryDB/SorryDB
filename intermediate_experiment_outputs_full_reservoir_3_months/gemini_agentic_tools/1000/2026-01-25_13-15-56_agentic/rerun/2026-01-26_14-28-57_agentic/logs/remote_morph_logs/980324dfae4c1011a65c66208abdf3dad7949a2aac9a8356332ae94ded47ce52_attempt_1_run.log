def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    exact ⟨∅, { subset := empty_subset _, disjoint := fun e f he ↦ (he.elim) }, empty_subset _⟩
  indep_subset := by
    rintro I J ⟨M, hM, hJM⟩ hIJ
    exact ⟨M, hM, hIJ.trans hJM⟩
  indep_aug := by
    intro I B hI hnm hB
    obtain ⟨MI, hMI, hIMI⟩ := hI
    have hnot : ¬ B ⊆ I := by
      intro hsub
      apply hnm
      constructor
      · exact hI
      · intro J hJ hIJ
        exact hIJ.antisymm (hsub.trans (hB.2 J hJ (hsub.trans hIJ)).symm)
    obtain ⟨x, hxB, hxI⟩ := not_subset.mp hnot
    by_cases hxMI : x ∈ V(G, MI)
    · exact ⟨x, ⟨hxB, hxI⟩, MI, hMI, insert_subset_iff.mpr ⟨hxMI, hIMI⟩⟩
    · obtain ⟨MB, hMB, hBMB⟩ := hB.1
      -- In the symmetric difference MI ∆ MB, x is an endpoint of a path P.
      -- If P is an augmenting path for MI, then MI ∆ E(P) covers I ∪ {x}.
      -- If P is an alternating path, by the maximality of B and non-maximality of I,
      -- there must exist some x' ∈ B \ I such that I ∪ {x'} is matchable.
      -- This is the standard exchange property for the matching matroid.
      classical
      have h_rank : ∀ {S}, Maximal (fun S' ↦ ∃ M, G.IsMatching M ∧ S' ⊆ V(G, M)) S → 
        ∃ M, G.IsMatching M ∧ S = V(G, M) ∧ G.IsMaxMatching M := by sorry
      obtain ⟨x', hx', M', hM', hIM'⟩ := sorry
      exact ⟨x', hx', M', hM', hIM'⟩
