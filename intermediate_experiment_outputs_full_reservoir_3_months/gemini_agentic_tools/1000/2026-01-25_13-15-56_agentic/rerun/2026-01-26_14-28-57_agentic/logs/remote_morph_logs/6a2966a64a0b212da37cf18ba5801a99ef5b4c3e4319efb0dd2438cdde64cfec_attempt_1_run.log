import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, Chapter1.concatMap, extendl, Chapter1.concat₁, List.map]
   | cons y ys =>
     simp only [parts₁, Chapter1.concatMap]
     have hL (L : List (List (List Nat))) (h : ∀ p ∈ L, p ≠ []) : (Chapter1.concat₁ (L.map (extendl x))).length = L.length * 2 := by
       induction L with
       | nil => rfl
       | cons p ps ihs =>
         simp [Chapter1.concat₁, List.length_append, ihs (fun p' hp' => h p' (List.mem_cons_of_mem _ hp'))]
         cases p; exact (h [] (.head ..) rfl).elim; rfl
     rw [hL (parts₁ (y :: ys)), ih]
     · simp [Nat.pow_succ]
     · intro p hp
       simp [parts₁, Chapter1.concatMap, Chapter1.concat₁] at hp
       induction (parts₁ ys) generalizing p with
       | nil => simp [Chapter1.concat₁] at hp
       | cons q qs ihs =>
         rw [List.map_cons, Chapter1.concat₁] at hp
         cases List.mem_append.1 hp with
         | inl h => cases q <;> simp [extendl] at h <;> cases h <;> (intro he; rw [he]; simp)
         | inr h => exact ihs h
