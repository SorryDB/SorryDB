import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, Chapter1.concat₁, extendl, List.map, List.foldr]
   | cons y ys =>
     have h_nz : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       rw [parts₁, List.foldr_cons] at hp
       induction (parts₁ ys) generalizing p with
       | nil => simp [concatMap, Chapter1.concat₁, List.foldr, List.map] at hp
       | cons q qs ih_qs =>
         simp [concatMap, Chapter1.concat₁, List.foldr, List.map, List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q with
           | nil =>
             simp [extendl, List.mem_cons, List.mem_nil] at h
             cases h with | inl h1 => subst h1; simp | inr h2 => contradiction
           | cons s ss =>
             simp [extendl, List.mem_cons, List.mem_nil] at h
             cases h with
             | inl h1 => subst h1; simp
             | inr h2 => cases h2 with | inl h2' => subst h2'; simp [glue] | inr h2'' => contradiction
         | inr h => exact ih_qs _ h
     have h_len : ∀ L, (∀ p ∈ L, p ≠ []) → (concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL
       induction L with
       | nil => rfl
       | cons p ps ih_ps =>
         have h_ps_nz : ∀ p' ∈ ps, p' ≠ [] := λ p' hp' => hL p' (List.mem_cons_of_mem _ hp')
         have hp_nz : p ≠ [] := hL p (List.mem_cons_self _ _)
         simp [concatMap, Chapter1.concat₁, List.map_cons, List.foldr_cons, List.length_append]
         rw [ih_ps h_ps_nz]
         cases p with
         | nil => contradiction
         | cons s ss => simp [extendl, Nat.mul_succ, Nat.add_comm]
     rw [parts₁, List.foldr_cons, h_len _ h_nz, ih]
     simp [List.length, Nat.succ_sub_succ, Nat.pow_succ, Nat.mul_comm]

