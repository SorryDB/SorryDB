import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, extendl, Chapter1.concat₁, List.map, List.foldr]
   | cons y ys =>
     have h_ne (p) (hp : p ∈ parts₁ (y :: ys)) : p ≠ [] := by
       rw [parts₁, List.foldr_cons] at hp
       simp [concatMap, Chapter1.concat₁] at hp
       induction (parts₁ ys) generalizing p with
       | nil => simp [concatMap, Chapter1.concat₁, List.map] at hp; contradiction
       | cons q qs ihs =>
         simp [concatMap, Chapter1.concat₁, List.map, List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q <;> simp [extendl] at h
           · subst h; simp
           · cases h with
             | inl h1 => subst h1; simp
             | inr h1 => cases h1 with | inl h2 => subst h2; simp | inr h2 => contradiction
         | inr h => exact ihs _ h
     have h_len (L : List (Partition Nat)) (hL : ∀ p ∈ L, p ≠ []) : (concatMap (extendl x) L).length = 2 * L.length := by
       induction L with
       | nil => simp [concatMap, Chapter1.concat₁]
       | cons p ps ihL =>
         simp [concatMap, Chapter1.concat₁, List.map, List.length_append]
         rw [ihL (λ p' hp' => hL p' (List.mem_cons_of_mem _ hp'))]
         cases p
         · have := hL [] (List.mem_cons_self _ _); contradiction
         · simp [extendl, Nat.mul_succ, Nat.add_comm]
     rw [parts₁, List.foldr_cons, ←parts₁, h_len (parts₁ (y :: ys)) h_ne, ih]
     simp [Nat.pow_succ, Nat.mul_comm, List.length]
