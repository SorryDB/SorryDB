import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, Chapter1.concat₁, extendl, List.foldr, List.map]
   | cons y ys =>
     have h_nz : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       rw [parts₁, List.foldr_cons] at hp
       induction (parts₁ ys) generalizing p with
       | nil =>
         simp [concatMap, Chapter1.concat₁, List.foldr, List.map] at hp
         cases hp
       | cons q qs ihq =>
         rw [concatMap, Chapter1.concat₁, List.foldr_cons, List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q <;> simp [extendl] at h
           · cases h with | head => subst p; simp | tail h => contradiction
           · cases h with | head => subst p; simp | tail h => (cases h with | head => subst p; simp | tail h => contradiction)
         | inr h => exact ihq _ h
     have h_len : ∀ L, (∀ p ∈ L, p ≠ []) → (concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL
       induction L with
       | nil => rfl
       | cons p ps ihl =>
         simp [concatMap, Chapter1.concat₁, List.foldr_cons, List.length_append]
         rw [ihl (fun p' hp' => hL p' (List.mem_cons_of_mem p hp'))]
         cases p with
         | nil => exact (hL [] (List.mem_cons_self [] ps)) rfl
         | cons s ss => simp [extendl, Nat.mul_succ, Nat.add_comm]
     rw [parts₁, List.foldr_cons, h_len (parts₁ (y :: ys)) h_nz, ih]
     simp [List.length, Nat.succ_sub_succ, Nat.pow_succ, Nat.mul_comm]

