import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, Chapter1.concatMap, extendl, Chapter1.concat₁]
   | cons y ys =>
     have h_p_ne (p) (hp : p ∈ parts₁ (y :: ys)) : p ≠ [] := by
       simp [parts₁, Chapter1.concatMap, Chapter1.concat₁] at hp
       induction (parts₁ ys) generalizing p with
       | nil => simp [Chapter1.concat₁] at hp; subst hp; simp [extendl]
       | cons q qs ihs =>
         simp [Chapter1.concat₁] at hp
         cases hp with
         | inl h =>
           cases q
           · simp [extendl] at h; subst h; simp
           · simp [extendl] at h; cases h <;> (rename_i h; subst h; simp)
         | inr h => exact ihs h
     have h_len : (parts₁ (x :: y :: ys)).length = (parts₁ (y :: ys)).length * 2 := by
       simp [parts₁, Chapter1.concatMap, Chapter1.concat₁]
       let L := parts₁ (y :: ys)
       induction L with
       | nil => rfl
       | cons p ps ihs =>
         simp [Chapter1.concat₁, List.length_append, ihs (fun p' hp' => h_p_ne p' (List.mem_cons_of_mem p hp'))]
         have p_ne : p ≠ [] := h_p_ne p (List.mem_cons_self p ps)
         cases p; contradiction
         simp [extendl, Nat.mul_succ, Nat.add_comm, Nat.mul_comm]
     simp [h_len, ih, Nat.pow_succ, Nat.mul_comm]

