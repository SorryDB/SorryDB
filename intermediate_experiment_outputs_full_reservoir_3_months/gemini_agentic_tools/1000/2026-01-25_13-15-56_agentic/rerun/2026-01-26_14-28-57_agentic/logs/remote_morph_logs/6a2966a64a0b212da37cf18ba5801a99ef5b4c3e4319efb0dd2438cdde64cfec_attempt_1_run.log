import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, Chapter1.concatMap, Chapter1.concat₁, extendl, List.foldr, List.map]
   | cons y ys =>
     have h_nz : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       rw [parts₁, List.foldr_cons] at hp
       let L' := parts₁ ys
       have h_ext_nz : ∀ q, ∀ p' ∈ extendl y q, p' ≠ [] := by
         intro q p' hp'
         cases q with
         | nil => simp [extendl] at hp'; subst hp'; simp
         | cons s ss =>
           simp [extendl] at hp'
           cases hp' with
           | inl h => subst h; simp [cons]
           | inr h => cases h with | inl h => subst h; simp [glue] | inr h => contradiction
       induction L' generalizing p with
       | nil => simp [Chapter1.concatMap, Chapter1.concat₁, List.foldr, List.map] at hp
       | cons q qs ih_qs =>
         rw [Chapter1.concatMap, Chapter1.concat₁, List.map_cons, List.foldr_cons, List.mem_append] at hp
         cases hp with
         | inl h => exact h_ext_nz q p h
         | inr h => exact ih_qs h
     have h_len : ∀ L : List (Partition Nat), (∀ p ∈ L, p ≠ []) → (Chapter1.concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL
       induction L with
       | nil => simp [Chapter1.concatMap, Chapter1.concat₁, List.foldr, List.map]
       | cons q qs ihL =>
         have h_q_nz : q ≠ [] := hL q (List.mem_cons_self _ _)
         have h_qs_nz : ∀ p' ∈ qs, p' ≠ [] := λ p' hp' => hL p' (List.mem_cons_of_mem _ hp')
         rw [Chapter1.concatMap, Chapter1.concat₁, List.map_cons, List.foldr_cons, List.length_append, ihL h_qs_nz]
         cases q with
         | nil => contradiction
         | cons s ss => simp [extendl, Nat.mul_succ, Nat.add_comm]
     rw [parts₁, List.foldr_cons, h_len (parts₁ (y :: ys)) h_nz, ih]
     simp [List.length, Nat.pow_succ, Nat.mul_comm, Nat.succ_sub_succ]
