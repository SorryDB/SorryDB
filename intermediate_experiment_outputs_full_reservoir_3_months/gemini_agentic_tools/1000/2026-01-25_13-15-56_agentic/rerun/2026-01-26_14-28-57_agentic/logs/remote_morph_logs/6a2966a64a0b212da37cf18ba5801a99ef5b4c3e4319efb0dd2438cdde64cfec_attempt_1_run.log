import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, Chapter1.concatMap, Chapter1.concat₁, extendl, List.map, List.foldr]
   | cons y ys =>
     have h_nz : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp
       rw [parts₁, List.foldr_cons] at hp
       simp [Chapter1.concatMap, Chapter1.concat₁, List.map, List.foldr] at hp
       induction (parts₁ ys) generalizing p with
       | nil => contradiction
       | cons q qs ih_qs =>
         rw [List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q with
           | nil =>
             simp [extendl, List.mem_cons, List.mem_nil] at h
             subst h; simp
           | cons s ss =>
             simp [extendl, List.mem_cons, List.mem_nil] at h
             cases h with | inl h => subst h; simp | inr h => subst h; simp
         | inr h => exact ih_qs h
     have h_len : ∀ L, (∀ p ∈ L, p ≠ []) → (Chapter1.concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL
       induction L with
       | nil => rfl
       | cons p ps ih_ps =>
         simp [Chapter1.concatMap, Chapter1.concat₁, List.map, List.foldr, List.length_append]
         rw [ih_ps (λ p' hp' => hL p' (List.mem_cons_of_mem p hp'))]
         have hp_nz : p ≠ [] := hL p (List.mem_cons_self p ps)
         cases p
         · contradiction
         · simp [extendl, Nat.mul_succ, Nat.add_comm]
     rw [parts₁, List.foldr_cons, h_len _ h_nz, ih]
     simp [List.length, Nat.pow_succ, Nat.mul_comm, Nat.succ_sub_succ]
