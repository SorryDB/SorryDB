import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, extendl, Chapter1.concat₁, List.map, List.foldr]
   | cons y ys =>
     have h_len : ∀ L, (∀ p ∈ L, p ≠ []) → (Chapter1.concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL; induction L with
       | nil => rfl
       | cons p ps ihL =>
         unfold Chapter1.concatMap at *
         simp [Chapter1.concat₁, List.map, List.length_append]
         rw [ihL (λ p' hp' => hL p' (List.mem_cons_of_mem _ hp'))]
         cases p
         · have := hL [] (List.mem_cons_self _ _); contradiction
         · simp [extendl, Nat.mul_succ, Nat.add_comm]
     have h_parts_ne : ∀ p ∈ parts₁ (y :: ys), p ≠ [] := by
       intro p hp; rw [parts₁, List.foldr_cons] at hp
       unfold Chapter1.concatMap Chapter1.concat₁ at hp
       induction (parts₁ ys) generalizing p with
       | nil => simp [List.map, List.foldr] at hp
       | cons q qs ih_qs =>
         rw [List.map_cons, List.foldr_cons, List.mem_append] at hp
         cases hp with
         | inl h =>
           cases q <;> simp [extendl] at h
           · cases h with | inl h => subst h; simp | inr h => contradiction
           · cases h with | inl h => subst h; simp | inr h => cases h with | inl h => subst h; simp | inr h => contradiction
         | inr h => exact ih_qs _ h
     rw [parts₁, List.foldr_cons]
     change (Chapter1.concatMap (extendl x) (parts₁ (y :: ys))).length = _
     rw [h_len _ h_parts_ne, ih, Nat.pow_succ, Nat.mul_comm]
     simp [List.length, Nat.succ_sub_succ]

