example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, extendl, Chapter1.concat₁, List.map, List.foldr]
   | cons y ys =>
     have h_len : ∀ L : List (Partition Nat), (∀ p ∈ L, p ≠ []) → (Chapter1.concatMap (extendl x) L).length = 2 * L.length := by
       intro L hL; induction L with
