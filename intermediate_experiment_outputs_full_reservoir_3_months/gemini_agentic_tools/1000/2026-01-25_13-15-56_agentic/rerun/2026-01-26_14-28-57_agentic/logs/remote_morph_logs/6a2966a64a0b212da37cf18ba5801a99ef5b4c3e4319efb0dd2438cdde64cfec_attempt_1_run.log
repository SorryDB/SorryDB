import Fad.Chapter1
import Fad.Chapter12

namespace Chapter12
open Chapter1 (concatMap)

/- # Exercicio 12.1
   a definição recursiva de `parts` provavelmente teria uma prova mais simples
   mas não consigo usar na prova por ser `partial`.
-/

example : ∀ xs : List Nat, (parts₁ xs).length = 2^(xs.length - 1) := by
 intro xs
 induction xs with
 | nil => simp [parts₁]
 | cons x xs ih =>
   cases xs with
   | nil => simp [parts₁, concatMap, extendl]
   | cons y ys =>
     rw [parts₁, Nat.pow_succ, ←ih]
     let L := parts₁ (y :: ys)
     have hL : ∀ p ∈ L, (extendl x p).length = 2 := by
       intro p hp
       rw [←L, parts₁, concatMap] at hp
       simp [concatMap, extendl] at hp
       let ⟨p', _, hp''⟩ := hp
       cases hp'' <;> (rename_i h; rw [h]; simp [extendl])
     induction L with
     | nil => cases ih
     | cons p ps ihL =>
       simp [concatMap, List.length_append, hL p (.head ..), ihL (λ p' h' => hL p' (.tail .. h')), Nat.mul_succ, Nat.add_comm]
