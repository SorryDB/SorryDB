import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h_dep : ¬ AffineIndependent ℝ x := not_affineIndependent_of_card_gt_finrank (by simp)
  obtain ⟨w, hw_sum, hw_x, hw_ne⟩ := exists_sum_smul_eq_zero_of_not_affineIndependent h_dep
  let s_pos := {i | 0 < w i}
  let s_neg := {i | w i < 0}
  have h_pos : s_pos.Nonempty := exists_pos_of_sum_zero_of_exists_nonzero hw_sum hw_ne
  have h_neg : s_neg.Nonempty := exists_neg_of_sum_zero_of_exists_nonzero hw_sum hw_ne
  let W := ∑ i in s_pos.toFinset, w i
  let p := W⁻¹ • ∑ i in s_pos.toFinset, w i • x i
  have hW : 0 < W := Finset.sum_pos (λ i hi ↦ (Set.mem_toFinset.1 hi)) h_pos
  have hp_pos : p ∈ convexHull ℝ (x '' s_pos) := by
    rw [convexHull_eq_sum]
    refine ⟨s_pos.toFinset, λ i ↦ if i ∈ s_pos then w i / W else 0, λ i hi ↦ ?_, ?_, ?_⟩
    · split_ifs; exact div_nonneg (le_of_lt (Set.mem_setOf.1 (by rwa [Set.mem_toFinset] at hi))) (le_of_lt hW); exact le_refl _
    · rw [Finset.sum_extend_byself s_pos.toFinset]; simp [div_eq_mul_inv, ← Finset.sum_mul, hw_sum, hW]
      rw [Finset.sum_subset (Finset.subset_univ _), ← Finset.sum_filter, ← Finset.sum_filter] at hw_sum
      simp [s_pos, W, Finset.mul_inv_cancel (ne_of_gt hW)]
    · rw [Finset.sum_extend_byself s_pos.toFinset]; simp [div_eq_mul_inv, ← Finset.sum_mul, p, W]
  have hp_neg : p ∈ convexHull ℝ (x '' s_neg) := by
    rw [convexHull_eq_sum]
    let W' := ∑ i in s_neg.toFinset, -w i
    have hW' : W' = W := by
      rw [Finset.sum_neg_distrib, ← eq_neg_iff_add_eq_zero.2 hw_sum]
      simp [s_pos, s_neg, Finset.sum_filter, Finset.sum_filter]
    refine ⟨s_neg.toFinset, λ i ↦ if i ∈ s_neg then -w i / W else 0, λ i hi ↦ ?_, ?_, ?_⟩
    · split_ifs; exact div_nonneg (neg_nonneg.2 (le_of_lt (Set.mem_setOf.1 (by rwa [Set.mem_toFinset] at hi)))) (le_of_lt hW); exact le_refl _
    · simp [div_eq_mul_inv, ← Finset.sum_mul, hW', W, Finset.mul_inv_cancel (ne_of_gt hW)]
    · simp [div_eq_mul_inv, ← Finset.sum_mul, p, W]
      rw [← hw_x, Finset.sum_subset (Finset.subset_univ _), ← Finset.sum_filter, ← Finset.sum_filter] at hw_x
      simp [s_pos, s_neg, ← Finset.sum_neg_distrib]
  have h_in_pos : p + y s_pos ∈ C := (convexHull_subset_iff.2 (λ _ hi ↦ (hxy _ _).2 (by simpa using hi))) hp_pos
  have h_in_neg : p + y s_neg ∈ C := (convexHull_subset_iff.2 (λ _ hi ↦ (hxy _ _).2 (by simpa using hi))) hp_neg
  let v := y s_neg - y s_pos
  let I (z : Fin 2 → ℝ) := {t : ℝ | z + y s_pos + t • v ∈ C}
  have h_conv (z) : Convex ℝ (I z) := (hC.translate (-(z + y s_pos))).vadd v.symm -- Not needed but true
  have hI (z) : Set.IsInterval (I z) := (hC.isInterval_preimage_linear (λ t ↦ z + y s_pos + t • v) (by intro; simp [add_assoc, smul_add]; sorry)) -- Too complex
  let s_diag := if ∃ i, s_pos = {i} then (if ∃ j, s_neg = {j} then s_pos else s_pos) else s_pos -- Placeholder for the (2,2) case
  have : s_pos ∩ s_neg = ∅ := Set.disjoint_iff_inter_eq_empty.1 (Set.disjoint_left.2 (λ i hi h2 ↦ (lt_asymm hi h2)))
  obtain ⟨i, hi⟩ := h_pos
  have : i ∉ s_neg := λ h ↦ (lt_asymm hi h)
  obtain ⟨j, hj⟩ := h_neg
  have : j ∉ s_pos := λ h ↦ (lt_asymm h hj)
  cases' h_pos with i hi
  have h31 : i ∈ s_pos ∧ i ∉ s_neg := ⟨hi, λ h ↦ (lt_asymm hi h)⟩
  exact (hxy i s_neg).1 (by
    have h_tri : x i ∈ convexHull ℝ (x '' (Finset.univ \ {i}).toSet) := sorry -- Type (3,1) case
    sorry)
