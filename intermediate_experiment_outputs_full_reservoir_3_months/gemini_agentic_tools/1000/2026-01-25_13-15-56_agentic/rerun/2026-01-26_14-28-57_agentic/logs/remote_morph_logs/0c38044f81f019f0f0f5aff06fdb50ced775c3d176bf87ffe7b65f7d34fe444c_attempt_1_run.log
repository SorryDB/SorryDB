import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  set K : Fin 4 → Set (Fin 2 → ℝ) := fun i ↦ {z | x i + z ∈ C}
  have hK i : Convex ℝ (K i) := hC.translate (-x i)
  set y' : Set (Fin 4) → Fin 2 → ℝ := fun s ↦ y s
  have hy' i s : y' s ∈ K i ↔ i ∈ s := (hxy i s).symm
  obtain ⟨I, J, p, hI, hJ, hdisj, hunion, hP⟩ :=
    exists_partition_convexHull_intersect (f := x) (by simp : (Finset.univ : Finset (Fin 4)).card = 2 + 2)
  have hI_nonempty : I.Nonempty := I.nonempty_of_convexHull_nonempty hP.1
  have hJ_nonempty : J.Nonempty := J.nonempty_of_convexHull_nonempty hP.2
  have hPI : p + y I ∈ C := (convexHull_subset_iff.2 fun i hi ↦ (hxy i I).2 (by simpa using hi)).1 hP.1
  have hPJ : p + y J ∈ C := (convexHull_subset_iff.2 fun i hi ↦ (hxy i J).2 (by simpa using hi)).1 hP.2
  obtain ⟨i, hi⟩ := hI_nonempty
  obtain ⟨j, hj⟩ := hJ_nonempty
  obtain hIJ | hIJ := (Finset.card I).exists_or_exists_le 2
  · obtain ⟨k, hIk⟩ := Finset.card_eq_one.1 hIJ
    have : p = x k := by
      have : convexHull ℝ (Finset.image x I) = {x k} := by rw [hIk, Finset.image_singleton, convexHull_singleton]
      rw [this] at hP; exact hP.1
    rw [this] at hPI
    exact (hxy k I).1 hPI (by rw [hIk]; exact Finset.mem_singleton_self k)
  · obtain hJI | hJI := (Finset.card J).exists_or_exists_le 2
    · obtain ⟨k, hJk⟩ := Finset.card_eq_one.1 hJI
      have : p = x k := by
        have : convexHull ℝ (Finset.image x J) = {x k} := by rw [hJk, Finset.image_singleton, convexHull_singleton]
        rw [this] at hP; exact hP.2
      rw [this] at hPJ
      exact (hxy k J).1 hPJ (by rw [hJk]; exact Finset.mem_singleton_self k)
    · have : I.card = 2 ∧ J.card = 2 := by
        have : I.card + J.card = 4 := by
          rw [← Finset.card_disjoint_union hdisj, hunion]
          exact Finset.card_fin 4
        omega
      obtain ⟨i1, i2, hi12, hI2⟩ := Finset.card_eq_two.1 this.1
      obtain ⟨j1, j2, hj12, hJ2⟩ := Finset.card_eq_two.1 this.2
      set s1 := {i1, j1}
      set s2 := {i2, j2}
      set C1 := K i1 ∩ K i2
      set C2 := K j1 ∩ K j2
      have hp1 : y I ∈ C1 := by simp [hy', hI2]
      have hp2 : y J ∈ C2 := by simp [hy', hJ2]
      have hp1' : y s1 ∈ K i1 \ K i2 := by simp [hy', hi12, hj12, s1]; aesop
      have hp2' : y s2 ∈ K i2 \ K i1 := by simp [hy', hi12, hj12, s2]; aesop
      have : p + y s1 ∈ C ↔ i1 ∈ s1 := hxy i1 s1
      have : p + y s2 ∈ C ↔ i2 ∈ s2 := hxy i2 s2
      set v := y J - y I
      set L : (Fin 2 → ℝ) → ℝ := fun z ↦ if ∃ t, z = p + y I + t • v then t else 0
      exact sorry -- The linear separation of translates of convex sets in R^2 prevents this configuration.
