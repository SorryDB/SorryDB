import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have : ¬ AffineIndependent ℝ x :=
    not_affineIndependent_of_card_gt_finrank (by simp : Fintype.card (Fin 4) > 2 + 1)
  obtain ⟨I, p, hI, hIc⟩ := Convex.radon_partition this
  have h (s : Set (Fin 4)) (hs : (I : Set (Fin 4)) ⊆ s) : p + y s ∈ C :=
    convexHull_subset_iff.mpr (fun z hz ↦ by
      obtain ⟨j, hj, rfl⟩ := (Set.mem_image _ _ _).mp hz
      exact (hxy j s).mpr (hs hj)) hI
  have hc (s : Set (Fin 4)) (hs : (Iᶜ : Set (Fin 4)) ⊆ s) : p + y s ∈ C :=
    convexHull_subset_iff.mpr (fun z hz ↦ by
      obtain ⟨j, hj, rfl⟩ := (Set.mem_image _ _ _).mp hz
      exact (hxy j s).mpr (hs hj)) hIc
  cases Finset.card I with
  | zero => exact (I.nonempty_of_convexHull_nonempty ⟨p, hI⟩).ne_empty (Finset.card_eq_zero.mp rfl)
  | succ n =>
    cases n with
    | zero =>
      obtain ⟨i, hi⟩ := Finset.card_eq_one.mp rfl
      have : p = x i := by simpa [hi] using hI
      rw [this] at hc
      exact (hxy i Iᶜ).mp (hc Iᶜ (subset_refl _)) (by simpa [hi] using Finset.not_mem_singleton_self i)
    | succ m =>
      cases m with
      | zero =>
        cases hIc_card : Finset.card Iᶜ with
        | zero => exact (Iᶜ.nonempty_of_convexHull_nonempty ⟨p, hIc⟩).ne_empty (Finset.card_eq_zero.mp hIc_card)
        | succ k =>
          cases k with
          | zero =>
            obtain ⟨i, hi⟩ := Finset.card_eq_one.mp hIc_card
            have : p = x i := by simpa [hi] using hIc
            rw [this] at h
            exact (hxy i I).mp (h I (subset_refl _)) (by simpa [hi] using Finset.not_mem_singleton_self i)
          | succ l =>
            set s := I ∪ {Iᶜ.choose (Iᶜ.nonempty_of_convexHull_nonempty ⟨p, hIc⟩)}
            set j := Iᶜ.choose (Iᶜ.nonempty_of_convexHull_nonempty ⟨p, hIc⟩)
            have hj : j ∈ Iᶜ := Finset.choose_spec _ _
            have : p + y s ∈ C := h s (Finset.subset_union_left _ _)
            have : p + y sᶜ ∈ C := hc sᶜ (fun k hk ↦ by
              simp [s] at hk; exact ⟨hk.1, fun hkj ↦ hk.2 (by rwa [hkj])⟩)
            sorry -- The 2+2 case requires boundary crossing arguments for translates of convex sets in ℝ².
