  -- Since C is convex, Cₛ is also convex.
  -- The shattering condition (hxy) implies x i ∈ Cₛ ↔ i ∈ s.
  have hp_in_Cs {s : Set (Fin 4)} (hs : I ⊆ s) : p + y s ∈ C := by
