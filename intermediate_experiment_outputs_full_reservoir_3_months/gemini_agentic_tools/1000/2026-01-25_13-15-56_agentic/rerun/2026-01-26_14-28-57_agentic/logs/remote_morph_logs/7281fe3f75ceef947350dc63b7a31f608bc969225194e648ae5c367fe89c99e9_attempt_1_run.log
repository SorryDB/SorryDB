      | inr hz' => cases Set.mem_insert_iff.mp hz' with
        | inl hzy => subst hzy; exact Set.mem_union_left _ (Set.mem_insert_of_mem _ (Set.mem_singleton _))
        | inr hzB => exact Set.mem_union_right _ hzB
    have h_ss : B ⊂ insert x (insert y B) := by
      rw [Set.ssubset_iff_subset_ne]; refine ⟨fun z hz ↦ Set.mem_insert_of_mem _ (Set.mem_insert_of_mem _ hz), ?_⟩
      intro h_eq; have hx_in : x ∈ insert x (insert y B) := Set.mem_insert _ _; rw [← h_eq] at hx_in; exact hx hx_in
    exact hB.dep_of_ssubset h_ss (Set.insert_subset hxV (Set.insert_subset hyV hB.subset_ground))
  · intro J hJ
    rw [Matroid.indep_dual_iff_exists_disjoint_isBase]
    obtain ⟨z, hz_mem, hz_not⟩ := Set.exists_of_ssubset hJ
    have : J ⊆ {x, y} \ {z} := Set.subset_diff_singleton hJ.subset hz_not
