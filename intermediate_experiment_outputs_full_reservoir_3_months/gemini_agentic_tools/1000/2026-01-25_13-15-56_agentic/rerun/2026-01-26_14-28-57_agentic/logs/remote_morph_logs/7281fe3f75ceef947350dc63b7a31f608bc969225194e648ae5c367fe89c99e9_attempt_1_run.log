    G.matchingMatroid.Series x y := by
  have hne : x ≠ y := h.ne
  rw [Matroid.series_iff_isCocircuit hne]
  refine' Matroid.isCocircuit_iff_minimal.mpr ⟨fun B hB ↦ _, fun S hS h_all ↦ _⟩
  · obtain ⟨M, hM, rfl⟩ : ∃ M, G.IsMaxMatching M ∧ B = V(G, M) := sorry
