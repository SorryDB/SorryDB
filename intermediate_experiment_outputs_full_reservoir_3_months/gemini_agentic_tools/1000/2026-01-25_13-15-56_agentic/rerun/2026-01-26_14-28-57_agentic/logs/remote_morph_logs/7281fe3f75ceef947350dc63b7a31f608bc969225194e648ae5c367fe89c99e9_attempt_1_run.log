  obtain ⟨e, he⟩ := h
  have hne : x ≠ y := he.ne
  have hxV : x ∈ V(G) := he.subset_ground (he.V_eq.symm ▸ Set.mem_insert _ _)
  have hyV : y ∈ V(G) := he.subset_ground (he.V_eq.symm ▸ Set.mem_insert_of_mem _ (Set.mem_singleton _))
  have hx_nc : ¬M_mat.IsColoop x := matchingMatroid.noColoop hi hxV
  have hy_nc : ¬M_mat.IsColoop y := matchingMatroid.noColoop hi hyV
  rw [Matroid.Series, Matroid.parallel_iff_isCircuit hne]
  constructor
  · rw [Matroid.dependent_iff_not_indep, Matroid.indep_dual_iff_exists_disjoint_isBase]
    push_neg; intro B hB
