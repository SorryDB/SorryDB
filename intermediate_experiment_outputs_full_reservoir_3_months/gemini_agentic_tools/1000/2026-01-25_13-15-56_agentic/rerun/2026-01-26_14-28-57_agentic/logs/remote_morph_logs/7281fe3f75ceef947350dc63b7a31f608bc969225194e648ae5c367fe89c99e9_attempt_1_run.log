lemma matchingMatroid.seriesPair_of_adj (h_iness : ∀ x, G.inessential x) (h_adj : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  let M_mat := G.matchingMatroid
  obtain ⟨e, he⟩ := h_adj
  have hne : x ≠ y := he.ne
  have hx_ground : x ∈ M_mat.E := he.left_mem
  have hy_ground : y ∈ M_mat.E := he.right_mem
  have h_base_iff : ∀ B, M_mat.IsBase B ↔ ∃ M, G.IsMaxMatching M ∧ B = V(G, M) := sorry
  have hx_nc : ¬M_mat.IsColoop x := noColoop h_iness hx_ground
  have hy_nc : ¬M_mat.IsColoop y := noColoop h_iness hy_ground
  rw [Matroid.Series, Matroid.parallel_iff_isCircuit hne hx_nc hy_nc, Matroid.isCircuit_def]
  refine ⟨?_, ?_, ?_⟩
  · rw [Matroid.indep_dual_iff_exists_disjoint_isBase]
    push_neg
    intro B hB
    obtain ⟨M', hM', rfl⟩ := (h_base_iff B).mp hB
    rw [Set.not_disjoint_iff_nonempty_inter]
    by_contra! h_disj
    have hx : x ∉ V(G, M') := Set.disjoint_left.mp h_disj (Set.mem_insert x {y})
    have hy : y ∉ V(G, M') := Set.disjoint_left.mp h_disj (Set.mem_insert_of_mem x (Set.mem_singleton y))
    let hP := isAugPath_of_singleEdge he hx hy hne
    have hM'_fin : M'.encard < ⊤ := sorry
    exact (ENat.add_one_le_iff hM'_fin.ne).mp (hP.augment_encard ▸ hM'.max _ hP.augment) |>.false
  · rw [M_mat.dual_ground]
    exact Set.insert_subset hx_ground (Set.singleton_subset_iff.mpr hy_ground)
  · intro J hJ
    obtain ⟨z, hz_mem, hz_not⟩ := Set.exists_of_ssubset hJ
    have h_indep_single : ∀ v, G.inessential v → M_mat✶.Indep {v} := by
      intro v hv
      rw [Matroid.indep_dual_iff_exists_disjoint_isBase]
      obtain ⟨M', hM', hMv⟩ := hv
      exact ⟨V(G, M'), (h_base_iff _).mpr ⟨hM', rfl⟩, Set.disjoint_singleton_left.mpr hMv⟩
    have : J ⊆ {x, y} \ {z} := Set.subset_diff_singleton hJ.subset hz_not
    cases Set.mem_insert_iff.mp hz_mem with
    | inl hzx =>
      subst hzx
      exact (h_indep_single y (h_iness y)).subset (by simpa using this)
    | inr hzy =>
      have hzy' : z = y := by simpa using hzy
      subst hzy'
      exact (h_indep_single x (h_iness x)).subset (by simpa using this)
