lemma matchingMatroid.seriesPair_of_adj (h : ∀ x, G.inessential x) (h : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  rename_i h_iness
  let M_mat := G.matchingMatroid
  obtain ⟨e, he⟩ := h
  have hne : x ≠ y := sorry
  have h_base_iff : ∀ B, M_mat.IsBase B ↔ ∃ M, G.IsMaxMatching M ∧ B = V(G, M) := sorry
  rw [Matroid.Series, Matroid.parallel_iff_isCircuit hne, ← Matroid.isCocircuit_def, Matroid.isCocircuit_iff_minimal]
  refine ⟨⟨fun B hB ↦ ?_, ?_⟩, ?_⟩
  · obtain ⟨M, hM, rfl⟩ := (h_base_iff B).mp hB
    rw [Set.nonempty_iff_ne_empty, Ne, Set.inter_eq_empty_iff_disjoint]
    intro h_disj
    have hx : x ∉ V(G, M) := Set.disjoint_left.mp h_disj (Set.mem_insert x _)
    have hy : y ∉ V(G, M) := Set.disjoint_left.mp h_disj (Set.mem_insert_of_mem x (Set.mem_singleton y))
    let hM_match := hM.toIsMatching
    have hP := isAugPath_of_singleEdge he hx hy hne
    have hM_fin : M.encard < ⊤ := sorry
    exact (ENat.add_one_le_iff hM_fin.ne).mp (hP.augment_encard ▸ hM.max _ hP.augment) |>.false
  · simp [M_mat, matchingMatroid, matchingIndepMatroid, h.left_mem, h.right_mem]
  · rintro S ⟨hS_inter, -⟩ hS_sub
    by_contra h_strict
    obtain ⟨z, hz_mem, hz_not⟩ := Set.exists_of_ssubset (Set.ssubset_iff_subset_ne.mpr ⟨hS_sub, h_strict⟩)
    have hz_val : z = x ∨ z = y := by simpa using hz_mem
    cases' hz_val with hval hval <;> subst hval
    · have h_sub : S ⊆ {y} := fun u hu ↦ (Set.mem_insert_iff.mp (hS_sub hu)).resolve_left (hz_not hu)
      obtain ⟨M, hM, hMy⟩ := h_iness y
      have hB := (h_base_iff (V(G, M))).mpr ⟨hM, rfl⟩
      specialize hS_inter (V(G, M)) hB
      exact (Set.disjoint_of_subset_left h_sub (Set.disjoint_singleton_left.mpr hMy)).ne_empty (Set.nonempty_iff_ne_empty.mp hS_inter)
    · have h_sub : S ⊆ {x} := fun u hu ↦ (Set.mem_insert_iff.mp (hS_sub hu)).resolve_right (hz_not hu)
      obtain ⟨M, hM, hMx⟩ := h_iness x
      have hB := (h_base_iff (V(G, M))).mpr ⟨hM, rfl⟩
      specialize hS_inter (V(G, M)) hB
      exact (Set.disjoint_of_subset_left h_sub (Set.disjoint_singleton_left.mpr hMx)).ne_empty (Set.nonempty_iff_ne_empty.mp hS_inter)
