    obtain ⟨e, he⟩ := h
    let P := WList.cons x e (.nil y)
    have hP : G.IsAugPath hM.toIsMatching P := isAugPath_of_singleEdge he
      (h_disj.disjoint_left (mem_insert _ _)) (h_disj.disjoint_left (mem_insert_of_mem _ (mem_singleton _))) hne
    exact hM.max _ hP.augment |>.not_lt (by rw [hP.augment_encard]; sorry)
  · obtain ⟨z, hz_mem, hz_not_mem⟩ := Set.exists_of_ssubset hS
    obtain ⟨M, hM, hMz⟩ := h_iness z
    have h_base : G.matchingMatroid.IsBase (V(G, M)) := sorry
    have h_disj : Disjoint S (V(G, M)) := by
      refine' Disjoint.mono_left _ (Set.disjoint_singleton_left.mpr hMz)
      intro w hw; obtain rfl | rfl := Set.mem_insert_iff.mp (hS.subset hw)
      · exact (hz_not_mem (by rwa [← (Set.mem_insert_iff.mp hz_mem).resolve_right hne.symm])).elim
      · exact (hz_not_mem (by rwa [← (Set.mem_insert_iff.mp hz_mem).resolve_left hne])).elim
    exact (h_all (V(G, M)) h_base).ne_empty h_disj.inter_eq
