    have hB_eq : B = V(G, M) := hB.eq_of_subset hB.indep hBM
    have hMe : G.IsMatching (insert e M) := {
      subset := Set.insert_subset he.edge_mem hM.subset
      disjoint := by
        intro f1 f2 hf1 hf2 hf12
        cases Set.mem_insert_iff.mp hf1 with
        | inl hf1e => subst hf1e; have hf2M : f2 ∈ M := Set.mem_of_mem_insert_of_ne hf2 hf12
          rw [he.V_eq, Set.disjoint_iff_forall_ne]
          rintro z1 (rfl | rfl) z2 hz2 rfl
          · exact hx (hB_eq.symm ▸ ⟨f2, hf2M, hz2⟩)
          · exact hy (hB_eq.symm ▸ ⟨f2, hf2M, hz2⟩)
        | inr hf1M => cases Set.mem_insert_iff.mp hf2 with
          | inl hf2e => subst hf2e; rw [he.V_eq, Set.disjoint_iff_forall_ne]
            rintro z1 hz1 z2 (rfl | rfl) rfl
            · exact hx (hB_eq.symm ▸ ⟨f1, hf1M, hz1⟩)
            · exact hy (hB_eq.symm ▸ ⟨f1, hf1M, hz1⟩)
          | inr hf2M => exact hM.disjoint hf1M hf2M hf12
    }
    have h_indep : M_mat.Indep (insert x (insert y B)) := by
      refine ⟨insert e M, hMe, ?_⟩
      rw [V_insert, he.V_eq, hB_eq]
      intro z hz; cases Set.mem_insert_iff.mp hz with
