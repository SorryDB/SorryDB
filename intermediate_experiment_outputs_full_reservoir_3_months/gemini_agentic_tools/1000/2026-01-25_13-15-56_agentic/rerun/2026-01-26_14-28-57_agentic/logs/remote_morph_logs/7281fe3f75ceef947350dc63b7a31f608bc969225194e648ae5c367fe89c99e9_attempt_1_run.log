  have hne : x ≠ y := he.ne
  have h_base_iff : ∀ B, G.matchingMatroid.IsBase B ↔ ∃ M, G.IsMaxMatching M ∧ B = V(G, M) := sorry
  rw [Matroid.Series, Matroid.parallel_iff_isCircuit hne, ← Matroid.isCocircuit_def, Matroid.isCocircuit_iff_minimal]
  refine ⟨?_, ?_⟩
  · intro B hB
    obtain ⟨M, hM, rfl⟩ := (h_base_iff B).mp hB
    by_contra! h_disj
    have hx : x ∉ V(G, M) := h_disj.notMem_of_mem_left (mem_insert x {y})
    have hy : y ∉ V(G, M) := h_disj.notMem_of_mem_left (mem_insert_of_mem x (mem_singleton y))
    have hP : G.IsAugPath hM.toIsMatching (WList.cons x e (.nil y)) := isAugPath_of_singleEdge he hx hy hne
    have hM_fin : M.encard < ⊤ := sorry
    exact (ENat.add_one_le_iff hM_fin.ne).mp (hP.augment_encard ▸ hM.max _ hP.augment) |>.false
  · rintro S hS h_sub
    obtain ⟨z, hz_mem, hz_not⟩ := Set.exists_of_ssubset h_sub
    have hz_val : z = x ∨ z = y := by simpa using hz_mem
    have h_sub_single : S ⊆ {x} ∨ S ⊆ {y} := by
      cases' hz_val with hval hval <;> [right; left] <;> subst hval <;>
      intro u hu <;> simpa [hz_not] using h_sub.subset hu
    cases' h_sub_single with hSx hSy
    · obtain ⟨M, hM, hMx⟩ := h_iness x
      have hB := (h_base_iff _).mpr ⟨M, hM, rfl⟩
      exact (hS _ hB).ne_empty (Set.disjoint_iff_inter_eq_empty.mp (Set.disjoint_of_subset_left hSx (Set.disjoint_singleton_left.mpr hMx)))
    · obtain ⟨M, hM, hMy⟩ := h_iness y
      have hB := (h_base_iff _).mpr ⟨M, hM, rfl⟩
      exact (hS _ hB).ne_empty (Set.disjoint_iff_inter_eq_empty.mp (Set.disjoint_of_subset_left hSy (Set.disjoint_singleton_left.mpr hMy)))
