lemma matchingMatroid.seriesPair_of_adj (h : ∀ x, G.inessential x) (h : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  rename_i h_iness
  obtain ⟨e, he⟩ := h
  have hne : x ≠ y := sorry
  let M_mat := G.matchingMatroid
  have h_base_iff : ∀ B, M_mat.IsBase B ↔ ∃ M, G.IsMaxMatching M ∧ B = V(G, M) := sorry
  rw [Matroid.Series, Matroid.parallel_iff_isCircuit hne, Matroid.isCircuit_iff_minimal]
  constructor
  · constructor
    · rw [Matroid.indep_dual_iff_exists_disjoint_isBase]
      push_neg
      intro B hB h_disj
      obtain ⟨M, hM, rfl⟩ := (h_base_iff B).mp hB
      have hx : x ∉ V(G, M) := Set.disjoint_left.mp h_disj (Set.mem_insert x {y})
      have hy : y ∉ V(G, M) := Set.disjoint_left.mp h_disj (Set.mem_insert_of_mem x (Set.mem_singleton y))
      have hP := isAugPath_of_singleEdge he hx hy hne
      have hM_fin : M.encard < ⊤ := sorry
      exact (ENat.add_one_le_iff hM_fin.ne).mp (hP.augment_encard ▸ hM.max _ hP.augment) |>.false
    · rw [M_mat.dual_ground]
      exact Set.insert_subset (by sorry) (Set.singleton_subset_iff.mpr (by sorry))
  · intro S hS_sub
    have h_indep_single : ∀ z, G.inessential z → M_mat✶.Indep {z} := by
      intro z hz
      rw [Matroid.indep_dual_iff_exists_disjoint_isBase]
      obtain ⟨M, hM, hMz⟩ := hz
      exact ⟨V(G, M), (h_base_iff _).mpr ⟨hM, rfl⟩, Set.disjoint_singleton_left.mpr hMz⟩
    obtain ⟨z, hz_mem, hz_not⟩ := Set.exists_of_ssubset hS_sub
    have : S ⊆ {x, y} \ {z} := Set.subset_diff_singleton hS_sub.subset hz_not
    cases Set.mem_insert_iff.mp hz_mem with
    | inl hzx =>
      subst hzx
      have hSy : S ⊆ {y} := by simpa using this
      exact (h_indep_single y (h_iness y)).subset hSy
    | inr hzy =>
      have hzy : z = y := by simpa using hzy
      subst hzy
      have hSx : S ⊆ {x} := by simpa using this
      exact (h_indep_single x (h_iness x)).subset hSx
