lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, symmDiff M P.edgeSet) := by
  rintro v ⟨e, heM, hv⟩
  by_cases heP : e ∈ P.edgeSet
  · have hfM : v ∉ V(G, symmDiff M P.edgeSet) → False := by
      intro h_not
      have hf : v ≠ P.first := fun h_eq ↦ h.first_not_in (h_eq ▸ ⟨e, heM, hv⟩)
      have hl : v ≠ P.last := fun h_eq ↦ h.last_not_in (h_eq ▸ ⟨e, heM, hv⟩)
      obtain ⟨i, hi⟩ := List.mem_iff_get.1 heP
      let n := P.edge.length
      have hv_in : v ∈ V(G, P.edge.get hi) := hv
      let vertices := P.toWalk.support
      have h_internal : (P.edgeSet ∩ E(G, v)).encard ≥ 2 := by
         sorry -- In any path, an internal vertex has degree 2.
      have h_matching_deg : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v
      have h_not_in_diff : ∀ f, v ∈ V(G, f) → f ∉ symmDiff M P.edgeSet := by
        simpa using h_not
      have h_subset : (P.edgeSet ∩ E(G, v)) ⊆ M := by
        rintro f ⟨hfP, hfv⟩
        specialize h_not_in_diff f hfv
        rw [symmDiff_def, mem_union, mem_diff, mem_diff, not_or, not_and_or, not_and_or, not_not, not_not] at h_not_in_diff
        obtain ⟨h1, h2⟩ := h_not_in_diff
        cases h1 <;> cases h2 <;> tauto
      have h_le : (P.edgeSet ∩ E(G, v)).encard ≤ (M ∩ E(G, v)).encard :=
        encard_le_encard (subset_inter h_subset (inter_subset_right _ _))
      exact (h_le.trans h_matching_deg).not_lt (by norm_num; exact h_internal)
    contrapose! hfM; exact hfM
  · exact ⟨e, Or.inl ⟨heM, heP⟩, hv⟩
```
