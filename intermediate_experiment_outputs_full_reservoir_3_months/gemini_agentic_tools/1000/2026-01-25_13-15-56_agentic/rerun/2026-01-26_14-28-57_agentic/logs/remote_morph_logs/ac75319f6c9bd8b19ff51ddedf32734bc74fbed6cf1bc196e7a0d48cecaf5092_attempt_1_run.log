lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  rintro v ⟨e, heM, hv⟩
  by_cases heP : e ∈ E(P)
  · have hvn : v ≠ P.first ∧ v ≠ P.last := 
      ⟨ne_of_mem_of_not_mem ⟨e, heM, hv⟩ h.first_not_in, 
       ne_of_mem_of_not_mem ⟨e, heM, hv⟩ h.last_not_in⟩
    obtain ⟨f, hfP, hfv, hfe⟩ := h.isPath.exists_next_or_prev_of_mem_edgeSet heP hv hvn
    refine ⟨f, ?_, hfv⟩
    rw [symmDiff_def, mem_union, mem_diff, mem_diff]
    right
    refine ⟨hfP, fun hfM ↦ hfe ?_⟩
    exact hM.subsingleton_inc v ⟨hfM, hfv⟩ ⟨heM, hv⟩
  · exact ⟨e, Or.inl ⟨heM, heP⟩, hv⟩
```
