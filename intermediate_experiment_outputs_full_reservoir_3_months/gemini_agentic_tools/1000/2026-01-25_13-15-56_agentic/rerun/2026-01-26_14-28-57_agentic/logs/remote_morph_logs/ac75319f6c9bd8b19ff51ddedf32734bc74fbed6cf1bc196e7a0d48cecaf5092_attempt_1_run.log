    obtain ⟨f, ⟨hfP, hfv⟩, hfM⟩ := Set.not_subset.1 h_not_sub
    exact ⟨f, Or.inr ⟨hfP, hfM⟩, hfv⟩
  · exact ⟨e, Or.inl ⟨heM, heP⟩, hv⟩
