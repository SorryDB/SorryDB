  · have hf : v ≠ P.first := fun h_eq ↦ h.first_not_in (h_eq ▸ ⟨e, heM, hv⟩)
    have hl : v ≠ P.last := fun h_eq ↦ h.last_not_in (h_eq ▸ ⟨e, heM, hv⟩)
    have h_int : 2 ≤ (P.edgeSet ∩ E(G, v)).encard := by
      -- An internal vertex v of a path P has degree 2 in P.
      -- v is internal because v ∈ V(G, e), e ∈ P.edgeSet, and v is not an endpoint (hf, hl).
