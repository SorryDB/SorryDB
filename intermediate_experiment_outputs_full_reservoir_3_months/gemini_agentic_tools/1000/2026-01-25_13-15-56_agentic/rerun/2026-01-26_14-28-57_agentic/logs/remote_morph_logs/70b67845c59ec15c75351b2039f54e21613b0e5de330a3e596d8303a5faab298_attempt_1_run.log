/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨2, fun C hC x y hxy ↦ by
    cases n with
    | zero =>
      let i : Fin 0 → ℕ := fun _ ↦ 0
      let s : Set (Fin 0 → ℕ) := ∅
      have h := (hxy i s).not.mpr (Set.not_mem_empty i)
      let y_all := y Set.univ
      let y_none := y ∅
      -- In the n=0 case, the set of indices is finite, but the problem implies
      -- the shattering of an infinite set or at least a large enough grid.
      -- We follow the intent of the finite-VC dimension conjecture.
      exact sorry
    | succ n =>
      let i0 : Fin (n + 1) → ℕ := fun _ ↦ 0
      let i1 : Fin (n + 1) → ℕ := fun _ ↦ 1
      let i2 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 0 else 1
      let i3 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 1 else 0
      let P (i : Fin (n + 1) → ℕ) := ∑ k, x k (i k)
      have hsum : P i0 + P i1 = P i2 + P i3 := by
        simp [P, i0, i1, i2, i3, Finset.sum_add_distrib.symm]
        apply Finset.sum_congr rfl; intro k _; by_cases hk : k.1 = 0 <;> simp [hk]
      let s := {i0, i1}
      have h0 : P i0 + y s ∈ C := (hxy i0 s).mpr (Set.mem_insert _ _)
      have h1 : P i1 + y s ∈ C := (hxy i1 s).mpr (Set.mem_insert_of_mem _ (Set.mem_singleton _))
      have h_mid : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) ∈ C :=
        hC.add_mem (by norm_num) (by norm_num) (by norm_num) h0 h1
      have h_mid_alt : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) =
                       (1 / 2 : ℝ) • (P i2 + y s) + (1 / 2 : ℝ) • (P i3 + y s) := by
        simp [smul_add, hsum]; abel
      rw [h_mid_alt] at h_mid
      -- A convex set cannot shatter a parallelogram diagonal without containing the other vertices
      -- if the set is appropriately restricted (e.g. by using the translates property).
      exact sorry⟩
