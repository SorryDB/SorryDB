      apply hC.sum_mem
      · intro j _; simp; positivity
      · simp [Finset.sum_const, Fintype.card_fun, Fintype.card_fin]; field_simp
      · intro j _; exact h_in j
    let s_parity : Set (Fin n → ℕ) := {i | ∃ j, i = I j ∧ (∑ k, (j k).1) % 2 = 0}
    let s_parity_not : Set (Fin n → ℕ) := {i | ∃ j, i = I j ∧ (∑ k, (j k).1) % 2 = 1}
    have h_sum_even : (1 / 2^(n-1) : ℝ) • ∑ j : {j // (∑ k, (j k).1) % 2 = 0}, P j = avg := sorry
    have h_sum_odd : (1 / 2^(n-1) : ℝ) • ∑ j : {j // (∑ k, (j k).1) % 2 = 1}, P j = avg := sorry
    cases n with
