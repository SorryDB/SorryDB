        simp [avg, Finset.smul_sum, smul_add, Finset.sum_add_distrib]
        rw [Finset.sum_const, Finset.card_univ, Fintype.card_fun, Fintype.card_fin]
        simp [smul_smul]; ring_nf; rfl
