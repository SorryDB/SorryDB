/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨2, fun C hC x y hxy ↦ by
    let I : Fin n → Fin 2 → ℕ := fun _ j ↦ j.1
    let s : Set (Fin n → ℕ) := {i | ∃ j : Fin n → Fin 2, (∀ k, i k = I k (j k)) ∧ 
      ∑ k : Fin n, (j k : ℝ) < (n : ℝ) / 2}
    let p (j : Fin n → Fin 2) : Fin (n + 1) → ℝ := ∑ k, x k (I k (j k))
    let v (j : Fin n → Fin 2) := p j + y s
    have h_in (j : Fin n → Fin 2) : v j ∈ C ↔ ∑ k : Fin n, (j k : ℝ) < (n : ℝ) / 2 := by
      convert hxy (fun k ↦ I k (j k)) s
      simp only [Set.mem_set_of_eq, Function.funext_iff, s]
      constructor
      · rintro ⟨j', hj', h_sum⟩
        replace hj' := fun k ↦ Fin.val_inj.mp (hj' k)
        rwa [hj'] at h_sum
      · intro h; exact ⟨j, fun k ↦ rfl, h⟩
    let s_inv : Set (Fin n → ℕ) := {i | ∃ j : Fin n → Fin 2, (∀ k, i k = I k (j k)) ∧ 
      ¬(∑ k : Fin n, (j k : ℝ) < (n : ℝ) / 2)}
    let v_inv (j : Fin n → Fin 2) := p j + y s_inv
    have h_out (j : Fin n → Fin 2) : v_inv j ∈ C ↔ ¬(∑ k : Fin n, (j k : ℝ) < (n : ℝ) / 2) := by
      convert hxy (fun k ↦ I k (j k)) s_inv
      simp [s_inv]
    exact sorry⟩
