      have : i ∉ s_empty := Set.not_mem_empty i
      refine vc_lt_four_of_convex_r2 (C := (fun x ↦ ![x 0, 0])) ?_
      · exact hC.linear_preimage (f := fun v ↦ v 0) (fun _ _ ↦ rfl) (fun _ _ ↦ rfl)
      · sorry
    | succ n =>
      let i0 : Fin (n + 1) → ℕ := fun _ ↦ 0
      let i1 : Fin (n + 1) → ℕ := fun _ ↦ 1
      let i2 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 1 else 0
      let i3 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 0 else 1
      have h_sum : P i0 + P i1 = P i2 + P i3 := by
