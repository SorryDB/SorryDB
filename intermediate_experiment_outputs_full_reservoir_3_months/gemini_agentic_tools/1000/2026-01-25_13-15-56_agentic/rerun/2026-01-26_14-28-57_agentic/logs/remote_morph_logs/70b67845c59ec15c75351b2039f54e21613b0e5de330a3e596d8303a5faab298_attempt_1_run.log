/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨4, fun C hC x y hxy ↦ by
    cases n with
    | zero =>
      let i : Fin 0 → ℕ := fun _ ↦ 0
      let s_all : Set (Fin 0 → ℕ) := {i}
      let s_none : Set (Fin 0 → ℕ) := ∅
      have h1 := (hxy i s_all).mpr (Set.mem_singleton i)
      have h2 := (hxy i s_none).not.mpr (Set.not_mem_empty i)
      -- For n=0, the space is ℝ¹ and we are shattering a single point.
      -- This statement for n=0 is actually False, but we follow the conjecture's intent.
      sorry
    | succ n =>
      let i0 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 0 else if k.1 = 1 then 0 else 0
      let i1 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 1 else if k.1 = 1 then 1 else 0
      let i2 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 0 else if k.1 = 1 then 1 else 0
      let i3 : Fin (n + 1) → ℕ := fun k ↦ if k.1 = 0 then 1 else if k.1 = 1 then 0 else 0
      let P (i : Fin (n + 1) → ℕ) := ∑ k, x k (i k)
      have h_sum : P i0 + P i1 = P i2 + P i3 := by
        simp only [P, Finset.sum_add_distrib.symm]
        apply Finset.sum_congr rfl
        intro k _
        by_cases h : k.1 = 0
        · simp [h, i0, i1, i2, i3]
        · by_cases h' : k.1 = 1
          · simp [h, h', i0, i1, i2, i3]
          · simp [h, h', i0, i1, i2, i3]
      let s := {i0, i1}
      have h0 : P i0 + y s ∈ C := (hxy i0 s).mpr (Set.mem_insert _ _)
      have h1 : P i1 + y s ∈ C := (hxy i1 s).mpr (Set.mem_insert_of_mem _ (Set.mem_singleton _))
      have h_mid : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) ∈ C :=
        hC.add_mem (by norm_num) (by norm_num) (by norm_num) h0 h1
      have h_mid_alt : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) =
                       (1 / 2 : ℝ) • (P i2 + y s) + (1 / 2 : ℝ) • (P i3 + y s) := by
        simp [smul_add, h_sum]; abel
      rw [h_mid_alt] at h_mid
      -- In ℝⁿ⁺¹, any grid of points contains dependencies. For translates of a convex set,
      -- shattering a parallelogram implies its midpoint property must hold for all translates.
      -- If we pick s = {i0, i1}, then P i2 + y s ∉ C and P i3 + y s ∉ C.
      -- If P i0 + P i1 = P i2 + P i3, then by convexity (P i0 + y s + P i1 + y s) / 2 is in C,
      -- which is also (P i2 + y s + P i3 + y s) / 2.
      -- The conjecture relies on the fact that for every C, some translate fails to separate.
      sorry⟩
