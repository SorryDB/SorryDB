      let s := {i0, i1}
      have h_in0 : P' i0 + y s ∈ C := (hxy i0 s).mpr (by simp)
      have h_in1 : P' i1 + y s ∈ C := (hxy i1 s).mpr (by simp)
      have h_mid : (1 / 2 : ℝ) • (P' i0 + y s) + (1 / 2 : ℝ) • (P' i1 + y s) ∈ C :=
        hC.add_mem (by norm_num) (by norm_num) (by norm_num) h_in0 h_in1
