/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨4, fun C hC x y hxy ↦ by
    cases n with
    | zero =>
      let i : Fin 0 → ℕ := fun _ ↦ 0
      -- The n=0 case involves a 1-point grid in ℝ¹, which is always shatterable.
      -- We follow the conjecture's spirit that VC dimension is bounded in n+1 dimensions.
      sorry
    | succ n =>
      cases n with
      | zero =>
        -- n=1 case: space is ℝ². Every convex set has VC dimension ≤ 3.
        -- Shattering an infinite sequence x₀(j) is impossible.
        let P (j : ℕ) : Fin 1 → ℕ := fun _ ↦ j
        have h_shatter : ∀ (s : Set ℕ), ∃ y_s, ∀ j, ∑ k, x k (P j k) + y_s ∈ C ↔ j ∈ s :=
          fun s ↦ ⟨y (P '' s), fun j ↦ by
            rw [hxy (P j) (P '' s), Set.mem_image]
            exact ⟨fun ⟨j', hj', heq⟩ ↦ (fun k ↦ (congr_fun heq k)).mp hj', fun hj ↦ ⟨j, hj, rfl⟩⟩⟩
        sorry
      | succ n =>
        -- n≥2 case: the grid contains parallelograms.
        -- A convex set cannot shatter a parallelogram diagonal from its other diagonal.
        let i0 : Fin (n + 2) → ℕ := fun _ ↦ 0
        let i1 : Fin (n + 2) → ℕ := fun k ↦ if k = 0 ∨ k = 1 then 1 else 0
        let i2 : Fin (n + 2) → ℕ := fun k ↦ if k = 0 then 1 else 0
        let i3 : Fin (n + 2) → ℕ := fun k ↦ if k = 1 then 1 else 0
        let P (idx : Fin (n + 2) → ℕ) := ∑ k, x k (idx k)
        have h_sum : P i0 + P i1 = P i2 + P i3 := by
          simp only [P, Finset.sum_add_distrib.symm]
          apply Finset.sum_congr rfl
          intro k _
          by_cases h0 : k = 0 <;> by_cases h1 : k = 1 <;> simp [h0, h1, i0, i1, i2, i3]
        let s := {i0, i1}
        have h_mid : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) ∈ C :=
          hC.add_mem (by norm_num) (by norm_num) (by norm_num) ((hxy i0 s).mpr (Set.mem_insert _ _))
            ((hxy i1 s).mpr (Set.mem_insert_of_mem _ (Set.mem_singleton _)))
        have h_mid_alt : (1 / 2 : ℝ) • (P i0 + y s) + (1 / 2 : ℝ) • (P i1 + y s) =
                         (1 / 2 : ℝ) • (P i2 + y s) + (1 / 2 : ℝ) • (P i3 + y s) := by
          simp only [smul_add, h_sum]; abel
        rw [h_mid_alt] at h_mid
        -- If (P i2 + y s + P i3 + y s) / 2 ∈ C, then s must contain i2 or i3 for some convex sets.
        -- In general, a grid shattered by translates of C requires disjoint convex hulls of disjoint subsets.
        sorry⟩

