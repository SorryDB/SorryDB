/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨4, fun C hC x y hxy ↦ by
    cases n with
    | zero =>
      let i : Fin 0 → ℕ := fun _ ↦ 0
      let s : Set (Fin 0 → ℕ) := ∅
      have h1 := (hxy i s).not.mpr (Set.not_mem_empty i)
      have h2 := (hxy i {i}).mpr (Set.mem_singleton i)
      -- The n=0 case is actually not False as discussed, but we follow the conjecture.
      sorry
    | succ n =>
      cases n with
      | zero =>
        -- n=1: Convex sets in ℝ² have finite VC dimension, so they cannot shatter an infinite set.
        let i (j : ℕ) : Fin 1 → ℕ := fun _ ↦ j
        let S : Set (Fin 1 → ℕ) := Set.range i
        -- Shattering an infinite set in ℝ² by translates of a convex set is impossible.
        sorry
      | succ n =>
        -- n≥2: Grid contains parallelograms. In ℝⁿ⁺¹, an n-dimensional grid cannot be shattered.
        let i00 : Fin (n + 2) → ℕ := fun _ ↦ 0
        let i11 : Fin (n + 2) → ℕ := fun k ↦ if k < 2 then 1 else 0
        let i01 : Fin (n + 2) → ℕ := fun k ↦ if k = 1 then 1 else 0
        let i10 : Fin (n + 2) → ℕ := fun k ↦ if k = 0 then 1 else 0
        let P (i : Fin (n + 2) → ℕ) := ∑ k, x k (i k)
        have h_sum : P i00 + P i11 = P i01 + P i10 := by
          simp only [P, ← Finset.sum_add_distrib]
          apply Finset.sum_congr rfl
          intro k _
          by_cases h : k < 2
          · revert h; cases k using Fin.cases with | H0 => _ | H1 k => _
            · intro; simp [i00, i11, i01, i10]
            · cases k using Fin.cases with | H0 => _ | H1 k => _
              · intro; simp [i00, i11, i01, i10]
              · intro h; exfalso; exact (Nat.not_lt_of_le (by simp [Fin.val_succ])) (by simpa [Fin.val_succ] using h)
          · simp [i00, i11, i01, i10, h, (by omega : ¬(k = 0)), (by omega : ¬(k = 1))]
        let s := {i00, i11}
        have h_mid : (1 / 2 : ℝ) • (P i00 + y s) + (1 / 2 : ℝ) • (P i11 + y s) ∈ C :=
          hC.add_mem (by norm_num) (by norm_num) (by norm_num)
            ((hxy i00 s).mpr (Set.mem_insert _ _))
            ((hxy i11 s).mpr (Set.mem_insert_of_mem _ (Set.mem_singleton _)))
        rw [smul_add, smul_add, ← add_assoc, add_assoc ((1/2:ℝ)• P i00),
            add_comm ((1/2:ℝ)• P i11), ← add_assoc, ← add_smul, (by norm_num : (1/2:ℝ)+(1/2:ℝ)=1),
            one_smul, h_sum, add_smul, smul_add, smul_add, add_assoc, add_comm ((1/2:ℝ)• P i10),
            ← add_assoc, ← add_assoc] at h_mid
        -- For translates of convex sets, diagonal shattering of parallelograms leads to contradiction.
        sorry⟩
