      have h_in1 : P i1 + y s ∈ C := (hxy i1 s).mpr (by simp)
      have h_out2 : P i2 + y s ∉ C := (hxy i2 s).not.mpr (by 
        simp [s, i0, i1, i2, i3]
        intro h; cases h
        · have : i2 0 = i0 0 := congr_fun ‹i2 = i0› 0; simp [i2, i0] at this
        · have : i2 0 = i1 0 := congr_fun ‹i2 = i1› 0; simp [i2, i1] at this)
      have h_out3 : P i3 + y s ∉ C := (hxy i3 s).not.mpr (by
        simp [s, i0, i1, i2, i3]
        intro h; cases h
        · have : i3 0 = i0 0 := congr_fun ‹i3 = i0› 0; simp [i3, i0] at this
        · have : i3 0 = i1 0 := congr_fun ‹i3 = i1› 0; simp [i3, i1] at this)
