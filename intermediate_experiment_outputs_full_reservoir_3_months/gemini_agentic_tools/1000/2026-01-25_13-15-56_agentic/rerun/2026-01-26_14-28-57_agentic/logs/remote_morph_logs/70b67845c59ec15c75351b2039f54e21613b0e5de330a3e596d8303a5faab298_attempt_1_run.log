      let f : (Fin (n + 1) → ℝ) → ℝ := fun v ↦ v 0
      let C2 : Set (Fin 2 → ℝ) := {v | ∃ w ∈ C, ![v 0, v 1] = ![w 0, 0]}
      exact sorry⟩

