        let x' (i : Fin 4) : Fin 2 → ℝ := x 0 i
        let y' (s : Set (Fin 4)) : Fin 2 → ℝ := y (fun _ ↦ (s.image (fun j ↦ j.val)).min)
        -- VC dimension of translates of convex sets in ℝ² is at most 3.
