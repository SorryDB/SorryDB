/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨4, fun C hC x y hxy ↦ by
    cases n with
    | zero =>
      let i : Fin 0 → ℕ := fun k ↦ k.elim0
      let s : Set (Fin 0 → ℕ) := ∅
      have h1 := (hxy i s).not.mpr (Set.not_mem_empty i)
      have h2 := (hxy i {i}).mpr (Set.mem_singleton i)
      exact vc_lt_four_of_convex_r2 (C := (fun x ↦ ![x 0, 0])) (by
        intro a ha b hb w1 w2 hw1 hw2 hsum
        refine ⟨hC.add_mem (show 0 ≤ w1 from hw1) (show 0 ≤ w2 from hw2) hsum ha.1 hb.1, ?_⟩
        simp) (fun _ ↦ ![(y {i}) 0, 0]) (fun _ ↦ ![((y s) 0) - ((y {i}) 0), 0]) (by
          intro j t
          simp only [Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_val, add_zero, add_sub_cancel, hxy])
    | succ n =>
      let i00 : Fin (n + 1) → ℕ := fun _ ↦ 0
      let i11 : Fin (n + 1) → ℕ := fun k ↦ if k < 2 then 1 else 0
      let i01 : Fin (n + 1) → ℕ := fun k ↦ if k = 1 then 1 else 0
      let i10 : Fin (n + 1) → ℕ := fun k ↦ if k = 0 then 1 else 0
      let P (i : Fin (n + 1) → ℕ) := ∑ k, x k (i k)
      have h_sum : P i00 + P i11 = P i01 + P i10 := by
        simp only [P, ← Finset.sum_add_distrib]
        apply Finset.sum_congr rfl
        intro k _
        by_cases h : k < 2
        · revert h; cases k using Fin.cases with
          | zero => intro; simp [i00, i11, i01, i10]
          | succ k => cases k using Fin.cases with
            | zero => intro; simp [i00, i11, i01, i10]
            | succ k => intro h; exfalso; exact (Nat.not_lt_of_le (by simp [Fin.val_succ])) (by simpa [Fin.val_succ] using h)
        · have h0 : k ≠ 0 := by intro h0; subst h0; exact h (by norm_num)
          have h1 : k ≠ 1 := by intro h1; subst h1; exact h (by norm_num)
          simp [i00, i11, i01, i10, h, h0, h1]
      let s := {i01, i10}
      have h_mid : (1 / 2 : ℝ) • (P i01 + y s) + (1 / 2 : ℝ) • (P i10 + y s) ∈ C :=
        hC.add_mem (by norm_num) (by norm_num) (by norm_num)
          ((hxy i01 s).mpr (Set.mem_insert _ _))
          ((hxy i10 s).mpr (Set.mem_insert_of_mem _ (Set.mem_singleton _)))
      rw [smul_add, smul_add, ← add_assoc, add_assoc ((1/2:ℝ)• P i01),
          add_comm ((1/2:ℝ)• P i10), ← add_assoc, ← add_smul, (by norm_num : (1/2:ℝ)+(1/2:ℝ)=1),
          one_smul, ← h_sum, add_smul, smul_add, smul_add, add_assoc, add_comm ((1/2:ℝ)• P i11),
          ← add_assoc, ← add_assoc] at h_mid
      exact vc2_lt_two_of_convex_r3 hC (fun i ↦ if i = 0 then x 0 0 else x 1 0) (fun i ↦ if i = 0 then x 0 1 else x 1 1)
        (fun s' ↦ y (fun k ↦ if k = 0 then (if (0, 0) ∈ s' then 0 else 1) else (if (0, 0) ∈ s' then 0 else 1)))
        (fun _ _ _ ↦ sorry)⟩
