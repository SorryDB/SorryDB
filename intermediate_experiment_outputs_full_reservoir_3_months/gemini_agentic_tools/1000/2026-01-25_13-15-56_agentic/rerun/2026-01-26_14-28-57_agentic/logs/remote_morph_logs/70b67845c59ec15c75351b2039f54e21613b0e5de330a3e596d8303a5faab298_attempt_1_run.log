lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨2, fun C hC x y hxy ↦ by
    let I : Fin n → Fin 2 → ℕ := fun _ j ↦ j.1
    let V (j : Fin n → Fin 2) : Fin (n + 1) → ℝ := ∑ k, x k (I k (j k))
    let s : Set (Fin n → ℕ) := {i | ∃ j : Fin n → Fin 2, (∀ k, i k = I k (j k)) ∧ 
      ∑ k, (j k : ℝ) < (n : ℝ) / 2}
    let s_inv : Set (Fin n → ℕ) := {i | ∃ j : Fin n → Fin 2, (∀ k, i k = I k (j k)) ∧ 
      ¬(∑ k, (j k : ℝ) < (n : ℝ) / 2)}
    have h_in (j : Fin n → Fin 2) : V j + y s ∈ C ↔ ∑ k, (j k : ℝ) < (n : ℝ) / 2 := by
      convert hxy (fun k ↦ I k (j k)) s
      constructor
      · rintro ⟨j', hj, hs⟩
        have : j' = j := funext fun k ↦ Fin.val_inj.mp (hj k)
        rwa [this] at hs
      · exact fun h ↦ ⟨j, fun _ ↦ rfl, h⟩
    have h_out (j : Fin n → Fin 2) : V j + y s_inv ∈ C ↔ ¬(∑ k, (j k : ℝ) < (n : ℝ) / 2) := by
      convert hxy (fun k ↦ I k (j k)) s_inv
      constructor
      · rintro ⟨j', hj, hs⟩
        have : j' = j := funext fun k ↦ Fin.val_inj.mp (hj k)
        rwa [this] at hs
      · exact fun h ↦ ⟨j, fun _ ↦ rfl, h⟩
    let avg : Fin (n + 1) → ℝ := (1 / 2^n : ℝ) • ∑ j : Fin n → Fin 2, V j
    have h_avg_in : avg + y s ∈ C := hC.sum_mem (fun _ _ ↦ by simp) (by simp) 
      (fun j _ ↦ (h_in j).mpr (sorry))
    have h_avg_out : avg + y s_inv ∈ C := hC.sum_mem (fun _ _ ↦ by simp) (by simp)
      (fun j _ ↦ (h_out j).mpr (sorry))
    exact sorry⟩
