lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ P.edgeSet).encard = M.encard + 1 := by
  let L := P.edge
  have h_nodup : L.Nodup := h.isTrail.edge_nodup
  classical
  let l := L.map (fun e => decide (e ∈ M))
  have hl_ne : l ≠ [] := by
    cases P with
    | nil u => exact (h.nonempty rfl).elim
    | cons u e P' => simp [l, L, WList.edge]
  have hl_head : l.head hl_ne = false := by
    cases P with
    | nil u => exact (h.nonempty rfl).elim
    | cons u e P' =>
      simp only [l, L, WList.edge, List.map_cons, List.head_cons, decide_eq_false_iff_not]
      intro heM
      apply h.first_not_in
      use e, heM
      have hP_path := h.toIsPath
      rw [Graph.cons_isPath_iff] at hP_path
      exact hP_path.2.inc_left
  have hl_last : l.getLast hl_ne = false := by
    obtain ⟨P', e, v, hP⟩ := h.nonempty.exists_concat
    simp only [l, L, hP, WList.edge_concat, List.map_append, List.map_cons, List.map_nil,
      List.getLast_append_singleton, decide_eq_false_iff_not]
    intro heM
    apply h.last_not_in
    use e, heM
    rw [hP, WList.last_concat]
    have hP_path := h.toIsPath
    rw [hP, Graph.concat_isPath_iff] at hP_path
    exact hP_path.2.inc_right
  have hl_alt : l.IsChain (· ≠ ·) := by
    rw [List.isChain_map]
    refine h.mem_matching_iff.imp ?_
    intro e f h_iff
    cases decide (e ∈ M) <;> cases decide (f ∈ M) <;> simp_all
  have h_count : (l.count false : ℕ∞) = l.count true + 1 := by
    have h_formula : (l.count false : ℕ) + (if l.head hl_ne then 1 else 0) =
                     (l.count true : ℕ) + (if l.getLast hl_ne = false then 1 else 0) := by
      revert hl_ne hl_alt
      induction l with
      | nil => intro hne; contradiction
      | cons b t ih =>
        intro hne halt
        cases t with
        | nil => cases b <;> simp
        | cons b_next t' =>
          have hb_next : b_next = (decide (¬ b = true)) := by
            rw [List.isChain_cons] at halt; cases b <;> simpa using halt.1
          specialize ih (by simp) (by rw [List.isChain_cons] at halt; exact halt.2)
          simp [List.count_cons, List.head_cons, List.getLast_cons, hb_next]
          cases b <;> simp_all
    rw [hl_head, hl_last] at h_formula
    simp only [ite_false, add_zero, ite_true] at h_formula
    rw [← Nat.cast_inj (R := ℕ∞), h_formula, Nat.cast_add, Nat.cast_one]
  have h_inter : (P.edgeSet ∩ M).encard = (l.count true : ℕ∞) := by
    rw [l, List.count_map, List.countP_eq_length_filter]
    have h_nodup_filter : (L.filter (· ∈ M)).Nodup := h_nodup.filter _
    rw [← ENat.card_toSet, ← List.toFinset_card, List.toFinset_filter, List.toFinset_nodup h_nodup]
    · simp [Finset.encard_def, P.edgeSet, L]
  have h_diff : (P.edgeSet \ M).encard = (l.count false : ℕ∞) := by
    rw [l, List.count_map, List.countP_eq_length_filter]
    have h_nodup_filter : (L.filter (· ∉ M)).Nodup := h_nodup.filter _
    rw [← ENat.card_toSet, ← List.toFinset_card, List.toFinset_filter, List.toFinset_nodup h_nodup]
    · simp [Finset.encard_def, P.edgeSet, L]
  rw [Set.symmDiff_def, Set.encard_union_eq disjoint_sdiff_sdiff,
    ← Set.encard_diff_add_encard_inter M P.edgeSet, Set.inter_comm, h_inter, h_diff, h_count, add_assoc]
