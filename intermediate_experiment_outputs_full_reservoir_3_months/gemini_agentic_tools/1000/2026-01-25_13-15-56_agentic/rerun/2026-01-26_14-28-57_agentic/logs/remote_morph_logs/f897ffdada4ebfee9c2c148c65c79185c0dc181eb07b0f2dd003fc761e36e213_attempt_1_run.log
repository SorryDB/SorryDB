lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_fin := P.edgeSet_finite
  rw [encard_symmDiff_add_inter M _ (h_fin.inter_left M), add_comm M.encard, add_assoc]
  congr 1
  have h_nodup := h.isTrail.edge_nodup
  have h_ne := h.nonempty_edge
  have h_head : P.edge.head h_ne ∉ M := fun hm ↦ h.first_not_in ⟨_, hm, P.first_mem_head h_ne⟩
  have h_last : P.edge.last h_ne ∉ M := fun hm ↦ h.last_not_in ⟨_, hm, P.last_mem_last h_ne⟩
  simp only [P.edgeSet_eq_toSet_edge, encard_toSet_nodup h_nodup,
    ← P.edgeSet_eq_toSet_edge, encard_diff_finite h_fin M, encard_finite (h_fin.inter_left M)]
  norm_cast
  let l := P.edge.map (· ∈ M)
  have h_alt : l.IsChain (· ≠ ·) := by simpa [l] using h.mem_matching_iff
  have h_ne' : l ≠ [] := by simpa using h_ne
  have h_head' : l.head h_ne' = false := by simpa [l] using h_head
  have h_last' : l.last h_ne' = false := by simpa [l] using h_last
  have h_odd : Odd l.length := by
    by_contra h_even
    have h_ne_last := h_alt.head_ne_last_of_even_length (Nat.even_iff_not_odd.mpr h_even) h_ne'
    exact h_last' (by rwa [h_head', Bool.not_false_iff] at h_ne_last)
  have h_ite := List.IsChain.two_mul_count_bool_eq_ite h_alt false
  simp [h_odd, List.head?_eq_head h_ne', h_head', (· == ·)] at h_ite
  rw [← List.count_filter, ← List.count_filter]
  simp only [Bool.not_eq_true]
  have := l.count_add_count_not true
  linarith
```
