lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_Efin := P.edgeSet_finite
  rw [← Set.encard_diff_add_encard_inter M E(P), symmDiff_def,
    Set.encard_union_eq_encard_add_encard Set.disjoint_sdiff_sdiff]
  have h_nodup := h.isTrail.edge_nodup
  have h_ne : P.edge ≠ [] := h.nonempty.edge_ne_nil
  let l := P.edge.map (decide · ∈ M)
  have h_chain : l.IsChain (· ≠ ·) := by
    rw [List.isChain_map]
    refine h.mem_matching_iff.imp (fun e f hm ↦ ?_)
    simp only [decide_eq_decide]; exact hm.not
  have h_head : l.head h_ne = false := by
    simp only [List.head_map, decide_eq_false_iff_not]
    intro hm; exact h.first_not_in ⟨_, hm, P.first_mem_head h_ne⟩
  have h_last : l.last h_ne = false := by
    simp only [List.last_map, decide_eq_false_iff_not]
    intro hm; exact h.last_not_in ⟨_, hm, P.last_mem_last h_ne⟩
  have h_odd : Odd l.length := by
    by_contra h_even
    have h_ln := h_chain.head_ne_last_of_even_length (Nat.even_iff_not_odd.mpr h_even) h_ne
    exact (h_ln (h_head.trans h_last.symm)).elim
  have h_ite := List.IsChain.two_mul_count_bool_eq_ite h_chain false
  simp [h_odd, h_head, (· == ·)] at h_ite
  have h_count : (l.count false : ℕ∞) = l.count true + 1 := by
    rw [← Nat.cast_add_one, Nat.cast_inj]
    linarith [l.count_add_count_not false]
  have h_EM : (E(P) ∩ M).encard = l.count true := by
    rw [← List.count_filter, ← encard_toSet_nodup (h_nodup.filter (· ∈ M))]
    congr; ext e; simp [l]
  have h_EcM : (E(P) \ M).encard = l.count false := by
    rw [← List.count_filter, ← encard_toSet_nodup (h_nodup.filter (· ∉ M))]
    congr; ext e; simp [l, Bool.not_eq_true]
  rw [h_EM, h_EcM, h_count, add_assoc]
