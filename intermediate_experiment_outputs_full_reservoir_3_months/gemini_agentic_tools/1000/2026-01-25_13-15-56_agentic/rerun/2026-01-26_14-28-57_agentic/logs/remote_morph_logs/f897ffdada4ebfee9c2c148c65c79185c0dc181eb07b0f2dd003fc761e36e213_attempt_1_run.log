    exact h.mem_matching_iff.imp (fun e f h_iff ↦ by
      rw [← Bool.not_eq_iff_not_eq, decide_eq_decide]; exact h_iff)
  have h_head : l.head h_ne = false := by
    simp only [List.head_map, decide_eq_false_iff_not]
    intro hm; exact h.first_not_in ⟨_, hm, P.first_mem_head h_ne⟩
  have h_last : l.last h_ne = false := by
    simp only [List.last_map, decide_eq_false_iff_not]
    intro hm; exact h.last_not_in ⟨_, hm, P.last_mem_last h_ne⟩
  have h_EM : (E(P) ∩ M).encard = l.count true := by
