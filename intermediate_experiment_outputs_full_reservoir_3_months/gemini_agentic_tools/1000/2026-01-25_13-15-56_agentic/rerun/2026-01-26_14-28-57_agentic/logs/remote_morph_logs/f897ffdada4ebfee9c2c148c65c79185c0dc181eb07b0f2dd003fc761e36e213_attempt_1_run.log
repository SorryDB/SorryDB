lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_fin := P.edgeSet_finite
  have h_nodup := h.isTrail.edge_nodup
  have h_ne := h.nonempty.edge_ne_nil
  have h_encard_M : M.encard = (M \ E(P)).encard + (M ∩ E(P)).encard := by
    rw [← encard_union_of_disjoint disjoint_sdiff_inter, diff_union_inter]
  have h_encard_symm : (M ∆ E(P)).encard = (M \ E(P)).encard + (E(P) \ M).encard := by
    rw [symmDiff_def, encard_union_of_disjoint disjoint_sdiff_sdiff]
  rw [h_encard_M, h_encard_symm, add_assoc]
  congr 1
  let l := P.edge.map (· ∈ M)
  have h_encard_EM : (E(P) ∩ M).encard = l.count true := by
    rw [P.edgeSet_eq_toSet_edge, ← List.toSet_filter, encard_toSet_nodup (h_nodup.filter _), List.count_filter]
    simp [l]
  have h_encard_EdM : (E(P) \ M).encard = l.count false := by
    rw [P.edgeSet_eq_toSet_edge, ← List.toSet_filter, encard_toSet_nodup (h_nodup.filter _), List.count_filter]
    simp [l, Bool.not_eq_true]
  rw [h_encard_EM, h_encard_EdM]
  norm_cast
  have h_ne' : l ≠ [] := by simpa using h_ne
  have h_alt : l.IsChain (· ≠ ·) := by
    simpa [l, List.isChain_map, ← Bool.not_eq_iff_not_eq] using h.mem_matching_iff
  have h_head : l.head h_ne' = false := by
    simp [l]; intro hm; exact h.first_not_in ⟨_, hm, P.first_mem_head h_ne⟩
  have h_last : l.last h_ne' = false := by
    simp [l]; intro hm; exact h.last_not_in ⟨_, hm, P.last_mem_last h_ne⟩
  have h_even : Even (l.dropLast.length) := by
    refine Nat.even_iff_not_odd.mpr (fun h_odd ↦ ?_)
    have h_len := h_alt.head_ne_last_of_even_length (Nat.even_add_one.mpr h_odd) h_ne'
    exact (h_len (h_head.trans h_last.symm)).elim
  rw [← List.dropLast_append_last h_ne', List.count_append, List.count_append]
  simp [h_last, h_alt.dropLast.count_not_eq_count h_even]
