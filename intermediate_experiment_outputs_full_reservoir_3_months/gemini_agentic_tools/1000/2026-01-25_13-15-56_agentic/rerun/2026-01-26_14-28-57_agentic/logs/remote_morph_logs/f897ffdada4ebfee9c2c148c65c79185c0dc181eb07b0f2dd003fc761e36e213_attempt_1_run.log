lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ P.edgeSet).encard = M.encard + 1 := by
  let L := P.edge
  have h_nodup : L.Nodup := h.isTrail.edge_nodup
  classical
  let l := L.map (fun e => decide (e ∈ M))
  have hl_ne : l ≠ [] := by
    cases P with
    | nil u => cases h.nonempty
    | cons u e P' => simp [l, L, WList.edge]
  have hl_head : l.head hl_ne = false := by
    cases P with
    | nil u => cases h.nonempty
    | cons u e P' =>
      simp only [l, L, WList.edge, List.map_cons, List.head_cons, decide_eq_false_iff_not]
      intro heM
      apply h.first_not_in
      refine ⟨e, heM, ?_⟩
      have hP := h.toIsPath
      rw [Graph.cons_isPath_iff] at hP
      exact hP.2.1.inc_left
  have hl_last : l.getLast hl_ne = false := by
    obtain ⟨P', e, v, hP_eq⟩ := h.nonempty.exists_concat
    simp only [l, L, hP_eq, WList.concat_edge, List.map_append, List.map_cons, List.map_nil,
      List.getLast_append_singleton, decide_eq_false_iff_not]
    intro heM
    apply h.last_not_in
    refine ⟨e, heM, ?_⟩
    rw [hP_eq, WList.last_concat]
    have hP := h.toIsPath
    rw [hP_eq, Graph.concat_isPath_iff] at hP
    exact hP.2.1.inc_right
  have hl_alt : l.IsChain (· ≠ ·) := by
    rw [List.isChain_map]
    refine h.mem_matching_iff.imp ?_
    intro e f h_iff
    simp only [decide_eq_decide]
    exact h_iff.not
  have h_count : (l.count false : ℕ∞) = l.count true + 1 := by
    rw [← Nat.cast_one, ← Nat.cast_add, Nat.cast_inj]
    revert hl_ne hl_head hl_last hl_alt
    induction l with
    | nil => intro hne; contradiction
    | cons b1 t1 ih =>
      intro hne hhead hlast halt
      cases t1 with
      | nil =>
        simp only [List.head_singleton, List.getLast_singleton] at hhead hlast
        simp [hhead, hlast]
      | cons b2 t2 =>
        have hb1 : b1 = false := hhead
        have hb2 : b2 = true := by
          rw [List.isChain_cons] at halt; simpa [hb1] using halt.1
        cases t2 with
        | nil =>
          rw [List.getLast_cons, List.getLast_singleton] at hlast
          rw [hb2] at hlast; contradiction
        | cons b3 t3 =>
          have hb3 : b3 = false := by
            rw [List.isChain_cons, List.isChain_cons] at halt
            simpa [hb2] using halt.2.1
          simp [List.count_cons, hb1, hb2]
          rw [ih (by simp) hb3 (by rwa [List.getLast_cons, List.getLast_cons] at hlast) (by
            rw [List.isChain_cons, List.isChain_cons] at halt
            exact halt.2.2)]
  have h_inter : (P.edgeSet ∩ M).encard = (l.count true : ℕ∞) := by
    simp [l, L, P.edgeSet, List.count_map, List.countP_eq_length_filter]
    rw [← List.encard_toSet (h_nodup.filter _)]
    congr; ext e; simp
  have h_diff : (P.edgeSet \ M).encard = (l.count false : ℕ∞) := by
    simp [l, L, P.edgeSet, List.count_map, List.countP_eq_length_filter]
    rw [← List.encard_toSet (h_nodup.filter (· ∉ M))]
    congr; ext e; simp
  rw [Set.symmDiff_def, Set.encard_union_eq disjoint_sdiff_sdiff,
    ← Set.encard_diff_add_encard_inter M P.edgeSet, Set.inter_comm, h_inter, h_diff, h_count, add_assoc]
