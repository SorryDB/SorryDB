lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  let L := P.edge
  let E := E(P)
  have hE : E = L.toSet := rfl
  have h_nodup : L.Nodup := h.isTrail.edge_nodup
  classical
  let l := L.map (fun e => decide (e ∈ M))
  have hl_ne : l ≠ [] := by cases P; exact h.nonempty.elim; simp [l, L, WList.edge]
  have hl_head : l.head hl_ne = false := by
    cases P with
    | nil u => exact h.nonempty.elim
    | cons u e P' =>
      simp only [l, L, WList.edge, List.map_cons, List.head_cons, decide_eq_false_iff_not]
      intro heM
      apply h.first_not_in
      refine ⟨e, heM, ?_⟩
      have hP := h.toIsPath
      rw [Graph.cons_isPath_iff] at hP
      exact hP.2.1.left_mem
  have hl_last : l.getLast hl_ne = false := by
    obtain ⟨P', e, v, hP_eq⟩ := h.nonempty.exists_concat
    simp only [l, L, hP_eq, WList.edge_concat, List.map_append, List.map_cons, List.map_nil,
      List.getLast_append_singleton, decide_eq_false_iff_not]
    intro heM
    apply h.last_not_in
    rw [hP_eq, WList.last_concat]
    refine ⟨e, heM, ?_⟩
    have hP := h.toIsPath
    rw [hP_eq, Graph.concat_isPath_iff] at hP
    exact hP.2.1.right_mem
  have hl_alt : l.IsChain (· ≠ ·) := by
    rw [List.isChain_map]
    refine h.mem_matching_iff.imp ?_
    intro e f h_iff
    cases decide (e ∈ M) <;> cases decide (f ∈ M) <;> simp_all
  have h_count : (l.count false : ℕ∞) = l.count true + 1 := by
    revert hl_ne hl_head hl_last hl_alt
    induction l with
    | nil => intro h_ne; contradiction
    | cons b1 t1 ih =>
      intro hne hhead hlast halt
      cases t1 with
      | nil => simp at hhead hlast; simp [hhead, hlast]
      | cons b2 t2 =>
        have hb1 : b1 = false := hhead
        have hb2 : b2 = true := by
          rw [List.isChain_cons] at halt; simpa [hb1] using halt.1
        cases t2 with
        | nil => simp at hlast; rw [hb2] at hlast; contradiction
        | cons b3 t3 =>
          have hb3 : b3 = false := by
            rw [List.isChain_cons] at halt
            have halt' := halt.2
            rw [List.isChain_cons] at halt'
            simpa [hb2] using halt'.1
          simp [hb1, hb2, hb3]
          rw [ih (List.cons_ne_nil _ _) hb3 (by rwa [List.getLast_cons] at hlast) (halt.2.2)]
          rw [Nat.cast_add, Nat.cast_one, add_assoc, add_comm 1, ← add_assoc]
  have h_inter : (E ∩ M).encard = (l.count true : ℕ∞) := by
    rw [l, List.count_map, List.countP_eq_length_filter, E, hE, ← List.encard_toSet]
    · congr; ext e; simp
    · exact h_nodup.filter _
  have h_diff : (E \ M).encard = (l.count false : ℕ∞) := by
    rw [l, List.count_map, List.countP_eq_length_filter, E, hE, ← List.encard_toSet]
    · congr; ext e; simp
    · exact h_nodup.filter _
  rw [symmDiff_eq_union_sdiff_sdiff, Set.encard_union_eq disjoint_sdiff_sdiff,
    Set.encard_diff_add_encard_inter M E, h_inter, h_diff, h_count, add_assoc]
