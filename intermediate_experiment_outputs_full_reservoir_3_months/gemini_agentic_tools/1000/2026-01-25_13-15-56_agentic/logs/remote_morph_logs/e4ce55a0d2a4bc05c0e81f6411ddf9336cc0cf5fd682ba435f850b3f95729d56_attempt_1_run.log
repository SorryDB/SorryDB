    (affineIndependent_ACD : AffineIndependent ℝ ![A, C, D])
    (P_eq_circumcenter : P = (⟨_, affineIndependent_ACD⟩ : Triangle ℝ Pt).circumcenter)
    (E_mem_inter : E ∈ (line[ℝ, A, P] ∩ Ω : Set Pt)) (E_ne_A : E ≠ A)
    (F_mem_inter : F ∈ (line[ℝ, A, P] ∩ Γ : Set Pt)) (F_ne_A : F ≠ A)
    (affineIndependent_PMN : AffineIndependent ℝ ![P, M, N])
    (H_eq_orthocenter : H = Triangle.orthocenter (⟨_, affineIndependent_PMN⟩ : Triangle ℝ Pt)) :
    ∃ affineIndependent_BEF : AffineIndependent ℝ ![B, E, F],
      (⟨_, affineIndependent_BEF⟩ : Triangle ℝ Pt).circumsphere.IsTangent
        (AffineSubspace.mk' H line[ℝ, A, P].direction) := by
  have h_not_coll : ¬ Collinear ℝ ({B, E, F} : Set Pt) := by
    intro h_coll
    have hE : E ∈ line[ℝ, A, P] := E_mem_inter.1
    have hF : F ∈ line[ℝ, A, P] := F_mem_inter.1
    have hA : A ∈ line[ℝ, A, P] := left_mem_line ℝ A P
    have h_line : line[ℝ, E, F] = line[ℝ, A, P] := by
      refine line_eq_of_mem_left E_ne_A hE hF ?_
      rw [← line_eq_line_extension E_ne_A hE]
      exact hF
    have hB : B ∈ line[ℝ, A, P] := by
      rw [← h_line]
      exact (collinear_iff_of_ne E_ne_A).mp h_coll |>.2
    have hP : P ∈ line[ℝ, A, P] := right_mem_line ℝ A P
    have h_ABP : Collinear ℝ ({A, B, P} : Set Pt) := by
      apply collinear_of_mem_line hA hB hP
    have h_AB_perp : line[ℝ, A, B] ⊥ line[ℝ, M, N] := by
      have hAΩ : A ∈ Ω := A_mem_inter.1
      have hBΩ : B ∈ Ω := B_mem_inter.1
      have hAΓ : A ∈ Γ := A_mem_inter.2
      have hBΓ : B ∈ Γ := B_mem_inter.2
      rw [← Ω_center_eq_M, ← Γ_center_eq_N] at *
      exact (Sphere.line_center_orthogonal_line_inter A_ne_B hAΩ hBΩ hAΓ hBΓ).symm
    have h_P_perp : P ∈ (perpBisector A B).carrier := by
      sorry
    sorry
  let affineIndependent_BEF : AffineIndependent ℝ ![B, E, F] := affineIndependent_iff_not_collinear.mpr h_not_coll
  use affineIndependent_BEF
  sorry

