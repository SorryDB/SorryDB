    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem, beq_iff_eq, Membership.mem]
  | node v L R ihL ihR =>
    simp [IsOrdered] at h
    rcases h with ⟨hL, hR, ordL, ordR, hmem⟩
    unfold fastCheckMem
    split_ifs with h1 h2
    · simp [beq_iff_eq] at h1
      subst h1
      simp [LabelledTree.mem, Membership.mem]
      exact hmem
    · simp [beq_iff_eq] at h1
      rw [ihL ordL]
      simp [LabelledTree.mem, Membership.mem]
      constructor
      · exact Or.inl
      · rintro (hl | hr)
        · exact hl
        · exact (not_le_of_lt h2 (hR label hr)).elim
    · simp [beq_iff_eq] at h1
      rw [ihR ordR]
      simp [LabelledTree.mem, Membership.mem]
      constructor
      · exact Or.inr
      · rintro (hl | hr)
        · have : v < label := lt_of_le_of_ne (le_of_not_lt h2) h1
          exact (not_le_of_lt this (hL label hl)).elim
        · exact hr
