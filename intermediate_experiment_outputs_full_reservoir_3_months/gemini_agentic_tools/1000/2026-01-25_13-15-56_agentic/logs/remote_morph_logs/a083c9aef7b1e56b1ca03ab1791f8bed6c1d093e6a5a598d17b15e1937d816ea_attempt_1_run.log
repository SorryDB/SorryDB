theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, beq_iff_eq, LabelledTree.mem, Membership.mem]
  | node v L R ihL ihR =>
    rcases h with ⟨hL, hR, ordL, ordR, hmem⟩
    unfold fastCheckMem
    split_ifs with h1 h2
    · simp [beq_iff_eq] at h1
      subst h1
      simp [LabelledTree.mem, Membership.mem, hmem]
    · simp [beq_iff_eq] at h1
      rw [ihL ordL]
      simp [LabelledTree.mem, Membership.mem]
      exact ⟨Or.inl, fun h => h, fun | .inl h => h | .inr h => (not_le_of_lt h2 (hR label h)).elim⟩
    · simp [beq_iff_eq] at h1
      rw [ihR ordR]
      simp [LabelledTree.mem, Membership.mem]
      have h_gt : v < label := lt_of_le_of_ne (le_of_not_lt h2) (Ne.symm h1)
      exact ⟨Or.inr, fun h => h, fun | .inl h => (not_le_of_lt h_gt (hL label h)).elim | .inr h => h⟩
```
