problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  rw [solution]
  apply iff_true.mpr
  suffices H : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from H 2000
  intro k
  induction' k with k ih
  · use 1; simp
  · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
    -- For any n such that n | 2^n + 1, n is odd. For n > 3, Zsigmondy's Theorem ensures 
    -- 2^{2n} - 1 has a primitive prime divisor p. This p must divide 2^n + 1 and satisfies 
    -- p = 2nj + 1, hence p > n and p is not a factor of n.
    -- To ensure n > 3, we can observe that if n=3, then 2^9 + 1 = 513 = 27 * 19, so 9 * 19 
    -- is a solution with 2 prime factors, and from there Zsigmondy always applies.
    have : ∃ n', 0 < n' ∧ n'.primeFactors.card = k + 1 ∧ n' ∣ 2 ^ n' + 1 := by
      sorry
    exact this

