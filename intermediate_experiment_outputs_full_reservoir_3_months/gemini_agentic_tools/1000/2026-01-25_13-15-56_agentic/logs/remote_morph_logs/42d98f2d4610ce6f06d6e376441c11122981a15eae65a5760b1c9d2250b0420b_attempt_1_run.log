/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution, iff_true]
  have h : ∀ k, ∃ n : ℕ, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction' k with k ih
    · exact ⟨1, Nat.pos_one, by simp, by simp⟩
    · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
      -- Let n_next = n * p where p is a prime divisor of 2^n + 1 that is not in n.
      -- If n | 2^n + 1, then n is odd. For n > 3, such a prime p always exists by
      -- Zsigmondy's Theorem (or a more elementary growth argument).
      -- Starting with n=3, 9, ... ensures that eventually we have enough prime factors.
      sorry
  exact h 2000

end Imo2000P5

