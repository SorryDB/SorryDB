import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  have H : ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction' k with k ih
    · use 1; simp
    · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
      have h_odd : Odd n := by
        have h1 : Odd (2 ^ n + 1) := by
          rw [Nat.add_comm]
          apply Nat.Odd.add_even (Nat.odd_one) (Nat.even_pow.mpr ⟨by norm_num, n_pos.ne'⟩)
        exact Nat.Odd.of_dvd h1 n_dvd
      -- For n > 3, Zsigmondy's Theorem ensures a new prime factor exists in 2^n + 1.
      -- Alternatively, one can construct n_k such that n_k has k factors and n_k | 2^n_k + 1.
      -- For example, starting from n=3, then n=9, then n=9*19, etc.
      -- The existence of such a prime p is a known result in this IMO problem.
      sorry
  exact H 2000

```
