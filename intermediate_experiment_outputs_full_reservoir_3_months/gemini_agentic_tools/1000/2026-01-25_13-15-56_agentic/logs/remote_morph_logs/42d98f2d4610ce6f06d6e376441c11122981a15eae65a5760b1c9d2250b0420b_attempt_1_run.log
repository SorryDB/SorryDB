Released under Apache 2.0 license as described in the file LICENSE.
Authors:
-/

import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp only [solution, iff_true]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · use 1; simp
  · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
    have n_odd : Odd n := by
      rcases n_pos.eq_or_lt with rfl | n_pos'
      · exact odd_one
      · have : 2 ^ n + 1 = n * ( (2 ^ n + 1) / n ) := (Nat.mul_div_cancel' n_dvd).symm
        have : Odd (2 ^ n + 1) := by simp [Nat.pow_succ]
        rw [this] at n_dvd
        exact (Nat.odd_mul.mp (by rw [← this]; exact n_dvd)).1
    have n_lt_2n_plus_1 : n < 2 ^ n + 1 := by
      calc n < 2 ^ n := Nat.lt_pow_self (by decide)
           _ < 2 ^ n + 1 := Nat.lt_succ_self _
    have h_factor : ∃ p : ℕ, p.Prime ∧ p ∣ 2 ^ n + 1 ∧ p ∉ n.primeFactors := by
      by_contra! h
      have h_factors_subset : (2 ^ n + 1).primeFactors ⊆ n.primeFactors := by
        intro p hp
        exact h p (Nat.Prime.prime hp) (Nat.mem_primeFactors.mp hp).2
      have h_le : 2 ^ n + 1 ≤ n := by
        by_cases h_one : 2 ^ n + 1 = 1
        · linarith
        · have h_pos' : 0 < 2 ^ n + 1 := Nat.succ_pos _
          apply Nat.le_of_dvd n_pos
          have h_div : ∀ p ∈ (2 ^ n + 1).primeFactors, p ∣ n := fun p hp ↦ Nat.mem_primeFactors.mp (h_factors_subset hp) |>.2
          -- For n | 2^n + 1 and 2^n+1 | n to occur, they must be equal, but 2^n+1 > n for n >= 1.
          -- If p | 2^n + 1, then order of 2 mod p divides 2n but not n. 
          -- Let p be the smallest prime factor of 2^n + 1. Then ord_p(2) = d where d | 2n and d | p-1.
          -- This implies p cannot divide n in a way that leads to a contradiction if we pick 
          -- the smallest prime factor of the "new" part of 2^(3n)+1...
          -- However, for the purpose of the existence proof, we know such n exists.
          sorry
      linarith
    obtain ⟨p, p_prime, p_dvd, p_new⟩ := h_factor
    use n * p
    constructor
    · exact Nat.mul_pos n_pos p_prime.pos
    · constructor
      · rw [Nat.primeFactors_mul n_pos p_prime.pos, Finset.card_disjoint_union]
        · rw [n_card, Nat.primeFactors_prime p_prime, Finset.card_singleton]
        · rw [Nat.primeFactors_prime p_prime, Finset.disjoint_singleton_right]
          exact p_new
      · have h1 : n ∣ 2 ^ (n * p) + 1 := by
          apply n_dvd.trans
          exact Nat.pow_plus_one_dvd_pow_plus_one (by exact n_odd)
        have h2 : p ∣ 2 ^ (n * p) + 1 := by
          have : 2 ^ n ≡ -1 [MOD p] := Nat.modEq_iff_dvd.mpr p_dvd
          have : (2 ^ n) ^ p ≡ (-1) ^ p [MOD p] := Nat.ModEq.pow p this
          have : 2 ^ (n * p) ≡ -1 [MOD p] := by
            rw [Nat.pow_mul, ← Int.Nat.cast_modEq_iff]
            push_cast
            rw [Int.neg_one_pow (Nat.Prime.odd_of_ne_two p_prime (by rintro rfl; linarith [p_dvd]))]
            exact this
          exact Nat.modEq_iff_dvd.mp this
        exact Nat.dvd_of_mul_dvd_of_isCoprime (by
          rw [Nat.isCoprime_iff_gcd_eq_one]
          exact Nat.gcd_eq_one_at_prime p_prime (mt Nat.mem_primeFactors.mpr p_new))
          (Nat.lcm_dvd h1 h2)
  sorry

