/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
by
  let s : ℂ := 2 * n + 1
  have h_s_ne_one : s ≠ 1 := by
    intro h; have h_re : s.re = 1 := by rw [h]; simp
    simp [s] at h_re; linarith
  have h_s_ne_zero : s ≠ 0 := by
    intro h; have h_re : s.re = 0 := by rw [h]; simp
    simp [s] at h_re; linarith
  let F := fun z : ℂ => (2 : ℂ) * (2 * Real.pi) ^ (-z) * Complex.Gamma z * riemannZeta z
  let G := fun z : ℂ => Complex.cos (Real.pi * z / 2)
  have h_eq : (fun z => riemannZeta (1 - z)) =ᶠ[nhds s] fun z => F z * G z := by
    refine Filter.eventuallyEq_of_mem ((isOpen_ne.inter isOpen_ne).mem_nhds ⟨h_s_ne_one, h_s_ne_zero⟩) ?_
    intro z hz; rw [riemannZeta_one_sub z hz.1 hz.2]; simp [F, G]; ring
  have h_diff_zeta : DifferentiableAt ℂ riemannZeta (1 - s) := by
    apply differentiableAt_riemannZeta
    intro h; have h_re : (1 - s).re = 1 := by rw [h]; simp
    simp [s] at h_re; linarith
  have h_deriv_zeta : HasDerivAt (fun z => riemannZeta (1 - z)) (-deriv riemannZeta (1 - s)) s := by
    have h1 : HasDerivAt (fun z => 1 - z) (-1) s := by
      simpa using (hasDerivAt_const 1 s).sub (hasDerivAt_id s)
    exact h_diff_zeta.hasDerivAt.comp s h1
  have hF : DifferentiableAt ℂ F s := by
    repeat' apply DifferentiableAt.mul
    · exact differentiableAt_const _
    · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg); left; simp; exact Real.pi_pos
    · apply Complex.differentiableAt_Gamma; intro m
      intro h; have h_re : s.re = -m := by rw [h]; simp
      simp [s] at h_re; linarith
    · exact differentiableAt_riemannZeta h_s_ne_one
  have h_Gs : G s = 0 := by
    simp [G, s]; rw [add_div, mul_assoc, mul_div_cancel_left _ (two_ne_zero : (2 : ℂ) ≠ 0)]
    rw [Complex.cos_add_pi_div_two, Complex.sin_nat_mul_pi]; simp
  have h_deriv_G : HasDerivAt G (-(Real.pi / 2) * (-1 : ℂ) ^ n) s := by
    have h1 : HasDerivAt (fun z => Real.pi * z / 2) (Real.pi / 2) s := by
      simpa [mul_comm] using (hasDerivAt_id s).mul_const (Real.pi / 2)
    have h2 := (Complex.hasDerivAt_cos (Real.pi * s / 2)).comp s h1
    convert h2 using 1
    · simp [G, s]
    · simp [s]; rw [add_div, mul_assoc, mul_div_cancel_left _ (two_ne_zero : (2 : ℂ) ≠ 0)]
      rw [Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]; ring
  have h_deriv_FG : HasDerivAt (fun z => F z * G z) (F s * (-(Real.pi / 2) * (-1 : ℂ) ^ n)) s := by
    simpa [h_Gs] using hF.hasDerivAt.mul h_deriv_G
  have h_val := h_deriv_zeta.unique (h_deriv_FG.congr_of_eventuallyEq h_eq.symm)
  have h_1s : 1 - s = -2 * n := by simp [s]; ring
  rw [h_1s, neg_mul, neg_inj] at h_val
  rw [h_val]
  repeat' apply mul_ne_zero
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; left; simp; exact Real.pi_pos
  · apply Complex.Gamma_ne_zero; intro m
    intro h; have h_re : s.re = -m := by rw [h]; simp
    simp [s] at h_re; linarith
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · apply div_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'; exact two_ne_zero
  · exact pow_ne_zero n (neg_ne_zero.mpr one_ne_zero)

end Millennium
