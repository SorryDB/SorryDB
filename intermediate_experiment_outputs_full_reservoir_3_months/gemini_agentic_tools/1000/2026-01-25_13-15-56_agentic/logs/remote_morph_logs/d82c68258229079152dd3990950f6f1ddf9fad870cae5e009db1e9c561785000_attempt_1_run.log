  have h_eq : (fun z => riemannZeta (1 - z)) =ᶠ[nhds s] (fun z => F z * G z) := by
    apply Filter.EventuallyEq.of_mem ((isOpen_ne.inter isOpen_ne).mem_nhds ⟨h_s_ne_one, h_s_ne_zero⟩)
    intro z hz; exact riemannZeta_one_sub z hz.2 hz.1
  have h_deriv_eq : deriv (fun z => riemannZeta (1 - z)) s = deriv (fun z => F z * G z) s :=
    Filter.EventuallyEq.deriv h_eq
  have h_diff_zeta : DifferentiableAt ℂ riemannZeta (1 - s) :=
    differentiableAt_riemannZeta (by simp [s]; linarith)
  have h_LHS : deriv (fun z => riemannZeta (1 - z)) s = - deriv riemannZeta (1 - s) := by
    rw [deriv_comp s h_diff_zeta ((differentiableAt_const 1).sub differentiableAt_id)]
    simp; ring
  have hF : DifferentiableAt ℂ F s := by
    repeat' apply DifferentiableAt.mul
    · exact differentiableAt_const _
    · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg)
      left; simp; linarith [Real.pi_pos]
    · apply Complex.differentiableAt_Gamma; intro m hm; simp [s] at hm; linarith
    · exact differentiableAt_riemannZeta h_s_ne_one
  have hG : DifferentiableAt ℂ G s := Complex.differentiable_cos.differentiableAt.comp s (differentiableAt_id.mul_const _)
  have h_RHS : deriv (fun z => F z * G z) s = F s * deriv G s := by
    rw [deriv_mul hF hG]
    have h_Gs : G s = 0 := by simp [G, s, Complex.cos_eq_zero_iff]; use n; ring
    rw [h_Gs]; simp
  have h_deriv_G : deriv G s = -(Real.pi / 2) * (-1 : ℂ) ^ n := by
    rw [deriv_comp s Complex.differentiable_cos.differentiableAt (differentiableAt_id.mul_const _)]
    simp [s]; ring_nf; rw [Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]
  rw [h_LHS, h_RHS, h_deriv_G] at h_deriv_eq
  have h_val : deriv riemannZeta (-2 * ↑n) = F s * (Real.pi / 2) * (-1 : ℂ) ^ n := by
    have h_1s : 1 - s = -2 * ↑n := by simp [s]; ring
    rw [h_1s, neg_inj] at h_deriv_eq
    rw [h_deriv_eq]; ring
  rw [h_val]
  repeat' apply mul_ne_zero
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero_iff.mpr; left; apply mul_ne_zero; exact two_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'
  · apply Complex.Gamma_ne_zero; intro m hm; simp [s] at hm; linarith
  · exact _root_.riemannZeta_ne_zero_of_one_lt_re (by simp [s]; linarith)
  · apply div_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'; exact two_ne_zero
  · exact pow_ne_zero n (neg_ne_zero.mpr one_ne_zero)

end Millennium
