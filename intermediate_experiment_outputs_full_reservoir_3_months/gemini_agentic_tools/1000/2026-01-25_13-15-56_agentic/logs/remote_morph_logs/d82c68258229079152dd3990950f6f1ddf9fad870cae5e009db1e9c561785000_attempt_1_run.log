    convert (differentiableAt_riemannZeta (by intro h; simp [s] at h; linarith)).hasDerivAt.comp s h_ds; ring
  have h_val := h_deriv_f.unique (h_deriv_FG.congr_of_eventuallyEq h_eq.symm)
  have h_1s : 1 - s = -2 * (n : ℂ) := by simp [s]; ring
  rw [h_1s] at h_val
  have : deriv riemannZeta (-2 * ↑n) = -(F s * (-(↑Real.pi / 2) * (-1 : ℂ) ^ n)) := by linarith [h_val]
  rw [this]
  repeat' apply mul_ne_zero
