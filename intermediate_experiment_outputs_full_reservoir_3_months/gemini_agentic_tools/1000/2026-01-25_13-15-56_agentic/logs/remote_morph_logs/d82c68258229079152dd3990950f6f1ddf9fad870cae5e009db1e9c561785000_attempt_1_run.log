theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
by
  let s : ℂ := 2 * ↑n + 1
  have h1 : s ≠ 1 := by
    intro h; have h' := (Complex.ext_iff.1 h).1; simp [s] at h'; linarith
  have h2 : HasDerivAt (fun z => riemannZeta (1 - z)) (-(deriv riemannZeta (-2 * n))) s := by
    convert (differentiableAt_riemannZeta (1 - s)).hasDerivAt.comp s (hasDerivAt_const_sub 1 s)
    simp [s]
  let f := fun z => 2 * (2 * π : ℂ) ^ (-z) * Gamma z * riemannZeta z
  let g := fun z => cos (π * z / 2)
  have h3 : HasDerivAt (fun z => f z * g z) (f s * (-(π / 2) * (-1) ^ n)) s := by
    have hf : DifferentiableAt ℂ f s := by
      repeat' apply DifferentiableAt.mul
      · exact differentiableAt_const _
      · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_neg differentiableAt_id)
        left; simp; exact Real.pi_pos.ne'
      · apply Complex.differentiableAt_Gamma; intro m h; have h' := (Complex.ext_iff.1 h).1; simp [s] at h'; linarith
      · apply differentiableAt_riemannZeta; exact h1
    have hg : HasDerivAt g (-(π / 2) * (-1) ^ n) s := by
      convert (hasDerivAt_cos (π * s / 2)).comp s (hasDerivAt_mul_const (π / 2)) using 1
      simp [s]; ring_nf; rw [Complex.sin_add_pi_half, Complex.cos_nat_mul_pi]
    have hgs : g s = 0 := by simp [g, s, Complex.cos_eq_zero_iff]; use n; ring
    convert hf.hasDerivAt.mul hg; simp [hgs]
  have h4 : (fun z => riemannZeta (1 - z)) =ᶠ[𝓝 s] (fun z => f z * g z) := by
    refine Filter.EventuallyEq.of_mem (isOpen_ne.mem_nhds h1) (fun z hz => riemannZeta_one_sub ?_ hz)
    intro m h; have h' := (Complex.ext_iff.1 h).1; simp at h'; linarith
  have h5 := h2.unique (h3.congr_of_eventuallyEq h4.symm)
  simp [h5]
  repeat' (apply mul_ne_zero)
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; left; simp; exact Real.pi_pos.ne'
  · apply Complex.Gamma_ne_zero
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · apply neg_ne_zero; apply mul_ne_zero
    · apply div_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'; exact two_ne_zero
    · exact pow_ne_zero n (neg_ne_zero one_ne_zero)
```
