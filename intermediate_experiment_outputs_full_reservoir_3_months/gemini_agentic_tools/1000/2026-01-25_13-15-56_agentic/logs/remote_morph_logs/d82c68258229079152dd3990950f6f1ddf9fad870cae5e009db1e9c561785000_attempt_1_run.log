  have h_deriv_FG : HasDerivAt (fun z => F z * G z) (F s * (-(Real.pi / 2) * (-1 : ℂ) ^ n)) s := by
    have h := h_diff_F.hasDerivAt.mul h_deriv_G
    rw [h_Gs] at h; simp at h; exact h
  have h_1s_ne_one : 1 - s ≠ 1 := by
