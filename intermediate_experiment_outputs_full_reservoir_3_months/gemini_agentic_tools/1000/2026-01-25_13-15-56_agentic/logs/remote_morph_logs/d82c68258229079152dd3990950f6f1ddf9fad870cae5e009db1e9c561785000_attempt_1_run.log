  have h_s_ne_zero : s ≠ 0 := by
    intro h; have h_re := congr_arg Complex.re h; simp [s] at h_re; linarith
  let F := fun z : ℂ => (2 : ℂ) * (2 * (Real.pi : ℂ)) ^ (-z) * Complex.Gamma z * riemannZeta z
  let G := fun z : ℂ => Complex.cos (Real.pi * z / 2)
  have h_eq : (fun z => riemannZeta (1 - z)) =ᶠ[nhds s] fun z => F z * G z := by
    refine Filter.EventuallyEq.of_mem ((isOpen_ne.inter isOpen_ne).mem_nhds ⟨h_s_ne_one, h_s_ne_zero⟩) ?_
    intro z hz; rw [riemannZeta_one_sub z hz.1 hz.2]; simp only [F, G, mul_assoc]
  have h_deriv_eq := h_eq.deriv_eq
  have h_diff_zeta : DifferentiableAt ℂ riemannZeta (1 - s) := by
    apply differentiableAt_riemannZeta; intro h; simp [s] at h; linarith
  have h_LHS : deriv (fun z => riemannZeta (1 - z)) s = - deriv riemannZeta (1 - s) := by
    rw [deriv_comp s h_diff_zeta ((differentiableAt_const 1).sub differentiableAt_id)]; simp
  have hF : DifferentiableAt ℂ F s := by
    repeat' apply DifferentiableAt.mul
    · exact differentiableAt_const _
    · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg); left; simp; exact Real.pi_pos
    · apply Complex.differentiableAt_Gamma; intro m hm; simp [s, Complex.neg_re] at hm; linarith
    · exact differentiableAt_riemannZeta h_s_ne_one
  have hG : DifferentiableAt ℂ G s := by
    apply DifferentiableAt.comp Complex.differentiable_cos.differentiableAt (differentiableAt_id.mul_const _)
  have h_Gs : G s = 0 := by simp [G, s, Complex.cos_eq_zero_iff]; use n; ring
  have h_deriv_G : deriv G s = -(Real.pi / 2) * (-1 : ℂ) ^ n := by
    rw [deriv_comp s Complex.differentiable_cos.differentiableAt (differentiableAt_id.mul_const _)]
    simp [s]; rw [Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]; ring
  have h_RHS : deriv (fun z => F z * G z) s = F s * deriv G s := by
    rw [deriv_mul hF hG, h_Gs]; simp
  rw [h_LHS, h_RHS, h_deriv_G] at h_deriv_eq
  have h_1s : 1 - s = -2 * n := by simp [s]; ring
  rw [h_1s, neg_inj] at h_deriv_eq
  rw [h_deriv_eq]
  repeat' apply mul_ne_zero
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; left; simp; exact Real.pi_pos
  · apply Complex.Gamma_ne_zero; intro m hm; simp [s, Complex.neg_re] at hm; linarith
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · apply div_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'; exact two_ne_zero
  · exact pow_ne_zero n (by norm_num : (-1 : ℂ) ≠ 0)
