  let G := fun z : ℂ => Complex.cos (↑Real.pi * z / 2)
  have h_eq : ∀ᶠ z in nhds s, riemannZeta (1 - z) = F z * G z := by
    filter_upwards [Metric.ball_mem_nhds s (one_pos)] with z hz
    have h_z_re : z.re > 2 := by
      have h_abs := Complex.abs_re_le_abs (z - s)
      have h_ball : Complex.abs (z - s) < 1 := by simpa [dist_eq_norm] using hz
      have h_s_re : s.re = 2 * n + 1 := by simp [s]
      linarith
    have h_z_ne_one : z ≠ 1 := by
      intro h; apply_fun Complex.re at h; simp at h; linarith
    have h_z_not_neg_nat : ∀ m : ℕ, z ≠ -m := by
      intro m h; apply_fun Complex.re at h; simp at h; linarith
    rw [riemannZeta_one_sub h_z_not_neg_nat h_z_ne_one, F, G]
    ring
  have h_diff_F : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.mul
        · exact differentiableAt_const _
        · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg)
          left; simp; exact Real.pi_pos
      · apply Complex.differentiableAt_Gamma; exact hs_not_neg_nat
    · exact differentiableAt_riemannZeta h_s_ne_one
  have h_Gs : G s = 0 := by
    dsimp [G, s]
    have : (↑Real.pi * (2 * ↑n + 1) / 2 : ℂ) = ↑n * ↑Real.pi + ↑Real.pi / 2 := by push_cast; ring
    rw [this, Complex.cos_add_pi_div_two]
    simp [Complex.sin_nat_mul_pi]
  have h_deriv_G : HasDerivAt G (-(↑Real.pi / 2) * (-1 : ℂ) ^ n) s := by
    have h1 : HasDerivAt (fun z => ↑Real.pi * z / 2) (↑Real.pi / 2) s := by
      convert (hasDerivAt_id s).mul_const (↑Real.pi / 2) using 1; ring
    convert (Complex.hasDerivAt_cos (↑Real.pi * s / 2)).comp s h1 using 1
    · dsimp [G, s]; ring
    · simp [s, add_div, mul_assoc]
      rw [mul_div_cancel_left _ (by norm_num : (2 : ℂ) ≠ 0)]
      rw [Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]
      ring
  have h_deriv_FG : HasDerivAt (fun z => F z * G z) (F s * (-(↑Real.pi / 2) * (-1 : ℂ) ^ n)) s := by
    have h := h_diff_F.hasDerivAt.mul h_deriv_G
    rw [h_Gs] at h; simp at h; exact h
  have h_deriv_f : HasDerivAt (fun z => riemannZeta (1 - z)) (-deriv riemannZeta (1 - s)) s := by
