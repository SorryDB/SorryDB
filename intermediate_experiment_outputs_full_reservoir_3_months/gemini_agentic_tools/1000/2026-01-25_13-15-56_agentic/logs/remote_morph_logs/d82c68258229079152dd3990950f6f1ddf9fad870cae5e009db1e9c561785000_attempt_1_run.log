    have hz2 : z ≠ 1 := by
      intro h; apply_fun Complex.re at h; simp at h; linarith
    rw [riemannZeta_one_sub hz1 hz2, F, G]; ring
  have h_diff_F : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
