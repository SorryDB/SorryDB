/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
by
  let s : ℂ := (2 * n + 1 : ℕ)
  have h_s_re : s.re = 2 * n + 1 := by simp only [s, Complex.nat_cast_re]; norm_cast
  have h_s_ne_one : s ≠ 1 := by
    intro h; apply_fun Complex.re at h; simp [h_s_re] at h; linarith
  have hs_not_neg_nat : ∀ m : ℕ, s ≠ -m := by
    intro m h; apply_fun Complex.re at h; simp [h_s_re] at h; linarith
  let F := fun z : ℂ => (2 : ℂ) * (2 * ↑Real.pi) ^ (-z) * Complex.Gamma z * riemannZeta z
  let G := fun z : ℂ => Complex.cos (↑Real.pi * z / 2)
  have h_eq : ∀ᶠ z in nhds s, riemannZeta (1 - z) = F z * G z := by
    apply Filter.eventually_of_mem (Metric.ball_mem_nhds s (one_pos))
    intro z hz
    have h_z_re : z.re > 0 := by
      have h_abs := Complex.abs_re_le_abs (z - s)
      rw [Metric.mem_ball, dist_eq_norm] at hz
      rw [h_s_re] at h_abs; linarith
    have hz1 : ∀ m : ℕ, z ≠ -m := by
      intro m h; apply_fun Complex.re at h; simp at h; linarith
    have hz2 : z ≠ 1 := by
      intro h; apply_fun Complex.re at h; simp at h; linarith
    rw [riemannZeta_one_sub hz1 hz2, F, G]; ring
  have h_diff_F : DifferentiableAt ℂ F s := by
    repeat' apply DifferentiableAt.mul
    · exact differentiableAt_const _
    · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg); left; simp; exact Real.pi_pos
    · apply Complex.differentiableAt_Gamma; exact hs_not_neg_nat
    · exact differentiableAt_riemannZeta h_s_ne_one
  have h_Gs : G s = 0 := by
    simp [G, s]; rw [add_div, mul_assoc]
    have : ((2 * n : ℂ) * (↑Real.pi / 2)) = n * ↑Real.pi := by ring
    rw [this, Complex.cos_add_pi_div_two, Complex.sin_nat_mul_pi]; simp
  have h_deriv_G : HasDerivAt G (-(↑Real.pi / 2) * (-1 : ℂ) ^ n) s := by
    have h1 : HasDerivAt (fun z => (↑Real.pi : ℂ) * z / 2) ((↑Real.pi : ℂ) / 2) s := by
      have : (fun z => (↑Real.pi : ℂ) * z / 2) = (fun z => ((↑Real.pi : ℂ) / 2) * z) := by ext; ring
      rw [this]; exact (hasDerivAt_id s).const_mul ((↑Real.pi : ℂ) / 2)
    convert (Complex.hasDerivAt_cos (↑Real.pi * s / 2)).comp s h1 using 1
    · simp [G, mul_comm]
    · simp [s]; rw [add_div, mul_assoc]
      have : ((2 * n : ℂ) * (↑Real.pi / 2)) = n * ↑Real.pi := by ring
      rw [this, Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]; ring
  have h_deriv_FG : HasDerivAt (fun z => F z * G z) (F s * (-(↑Real.pi / 2) * (-1 : ℂ) ^ n)) s := by
    have h := h_diff_F.hasDerivAt.mul h_deriv_G
    rw [h_Gs] at h; simp at h; exact h
  have h_1s_ne_one : 1 - s ≠ 1 := by
    intro h; apply_fun Complex.re at h; simp [h_s_re] at h; linarith
  have h_deriv_f : HasDerivAt (fun z => riemannZeta (1 - z)) (-deriv riemannZeta (1 - s)) s := by
