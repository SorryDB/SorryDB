      convert (hasDerivAt_id s).neg.add_const 1; ring
    convert (differentiableAt_riemannZeta h_1s_ne_one).hasDerivAt.comp s h_ds; ring
  have h_val := h_deriv_f.unique (h_deriv_FG.congr_of_eventuallyEq h_eq)
  have h_1s : 1 - s = -2 * (n : ℂ) := by simp only [s]; norm_cast; ring
  rw [h_1s] at h_val
  rw [← neg_ne_zero, ← h_val]
  repeat' apply mul_ne_zero
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; left; simp; exact Real.pi_pos
  · apply Complex.Gamma_ne_zero; exact hs_not_neg_nat
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [h_s_re]; linarith
  · apply div_ne_zero; exact Complex.ofReal_ne_zero.mpr Real.pi_pos.ne'; exact two_ne_zero
  · exact pow_ne_zero n (by norm_num)

end Millennium
