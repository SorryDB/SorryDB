/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
by
  let s : ℂ := 2 * (n : ℂ) + 1
  have h_s_ne_one : s ≠ 1 := by
    intro h; have h_re := congr_arg Complex.re h; simp [s] at h_re; linarith
  have h_zeta_s : riemannZeta s ≠ 0 := riemannZeta_ne_zero_of_one_lt_re (by simp [s]; linarith)
  have h_gamma_s : Complex.Gamma s ≠ 0 := by
    apply Complex.Gamma_ne_zero; intro m h; have h_re := congr_arg Complex.re h
    simp [s, Complex.neg_re] at h_re; linarith
  let f := fun z : ℂ => (2 : ℂ) * (2 * (Real.pi : ℂ)) ^ (-z) * Complex.Gamma z * riemannZeta z
  let g := fun z : ℂ => Complex.cos ((Real.pi : ℂ) * z / 2)
  have h_eq : (fun z => riemannZeta (1 - z)) =ᶠ[nhds s] fun z => f z * g z := by
    have h_open : IsOpen ({z : ℂ | 0 < z.re} ∩ {z : ℂ | z ≠ 1}) :=
      (Complex.continuous_re.isOpen_preimage _ isOpen_pos).inter isOpen_ne
    apply Filter.EventuallyEq.of_mem (h_open.mem_nhds (by simp [s]; constructor; linarith; exact h_s_ne_one))
    intro z hz; simp only [f, g]; rw [riemannZeta_one_sub _ hz.2]
    intro m hm; have h_re := congr_arg Complex.re hm; simp [Complex.neg_re] at h_re; linarith [hz.1]
  have hf : DifferentiableAt ℂ f s := by
    repeat' apply DifferentiableAt.mul
    · exact differentiableAt_const _
    · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.neg)
      left; apply mul_ne_zero two_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne')
    · apply Complex.differentiableAt_Gamma; intro m hm; have h_re := congr_arg Complex.re hm
      simp [s, Complex.neg_re] at h_re; linarith
    · apply differentiableAt_riemannZeta h_s_ne_one
  have hg : HasDerivAt g (-( (Real.pi : ℂ) / 2) * (-1 : ℂ) ^ n) s := by
    have h1 : HasDerivAt (fun z => z * ((Real.pi : ℂ) / 2)) ((Real.pi : ℂ) / 2) s :=
      (hasDerivAt_id s).mul_const ((Real.pi : ℂ) / 2)
    convert (Complex.hasDerivAt_cos (s * ((Real.pi : ℂ) / 2))).comp s h1 using 1
    · simp [g]; ring
    · simp [s]; rw [Complex.sin_add_pi_div_two, Complex.cos_nat_mul_pi]; ring
  have h_gs_zero : g s = 0 := by
    simp [g, s, Complex.cos_eq_zero_iff]; use n; ring
  have h_deriv_fg : HasDerivAt (fun z => f z * g z) (f s * (-( (Real.pi : ℂ) / 2) * (-1 : ℂ) ^ n)) s := by
    convert hf.hasDerivAt.mul hg; simp [h_gs_zero]
  have h_deriv_zeta : HasDerivAt (fun z => riemannZeta (1 - z)) (-deriv riemannZeta (1 - s)) s := by
    have h_diff : DifferentiableAt ℂ riemannZeta (1 - s) := by
      apply differentiableAt_riemannZeta; intro h; simp [s] at h; linarith
    convert h_diff.hasDerivAt.comp s ((hasDerivAt_const 1 s).sub (hasDerivAt_id s)) using 1
    simp
  have h_val := h_deriv_zeta.unique (h_deriv_fg.congr_of_eventuallyEq h_eq.symm)
  simp only [neg_mul, neg_inj] at h_val
  have h_s_sub : 1 - s = -2 * ↑n := by simp [s]; ring
  rw [h_s_sub] at h_val; rw [h_val]
  repeat' apply mul_ne_zero
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; left; apply mul_ne_zero two_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne')
  · exact h_gamma_s
  · exact h_zeta_s
  · apply div_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne') two_ne_zero
  · exact Complex.ofReal_ne_zero.mpr (by norm_num : (-1 : ℝ) ^ n ≠ 0)

end Millennium
