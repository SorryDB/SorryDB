import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; constructor
  · rintro ⟨n, n_pos, A, B, hAB, hA, hI, hB, f, hf, hfA, rfl⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ i, (A i).card = ∑ x in B, k x := by simp [k, Finset.sum_card_filter]
    have h2 : ∑ i, ∑ j in Finset.univ.erase i, (A i ∩ A j).card = ∑ x in B, k x * (k x - 1) := by
      simp_rw [k, Finset.card_filter, ← Finset.sum_comm (s := Finset.univ), Finset.filter_filter]
      simp [Finset.univ_filter_mem, Finset.filter_univ, ← Finset.sum_card_filter, Finset.sum_univ_erase, hI]
    have h3 : ∀ x ∈ B, k x = 2 := by
      intro x hx
      have hsum : ∑ x in B, k x * (k x - 2) = 0 := by
        simp [h1, h2, hA, Finset.sum_const, Finset.card_univ, Finset.card_fin, mul_comm, Finset.sum_sub_distrib, Finset.sum_mul]
      have : k x ≥ 2 := by
        rcases hB x hx with ⟨i, j, hij, hi, hj⟩
        have : {i, j} ⊆ Finset.univ.filter (x ∈ A ·) := by simp [hi, hj]
        have c := Finset.card_le_card this
        simp [hij] at c; exact c
      exact (Nat.mul_eq_zero.1 (Finset.sum_eq_zero_iff.1 hsum x hx)).resolve_right (by linarith)
    have h4 : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← Finset.sum_card_filter, Finset.sum_congr rfl]
      intro i; rw [hfA i, ← Finset.sum_card_filter, Finset.sum_comm]
      apply Finset.sum_congr rfl
      intro x hx; by_cases h : f x = 0 <;> simp [h, h3 x (Finset.mem_filter.1 hx).1]
    exact ⟨n_pos, by rw [← Nat.even_iff_two_dvd, ← Nat.even_mul] at h4; simpa using h4⟩
  · rintro ⟨n_pos, k, rfl⟩; set n := 2 * k; let V := Fin (2 * n + 1)
    let e : V × V → ℕ := fun (u, v) => if u < v then u.val * (2 * n + 1) + v.val else v.val * (2 * n + 1) + u.val
    let B := (Finset.univ.offDiag : Finset (V × V)).filter (fun p => p.1 < p.2) |>.map ⟨fun p => e p, by sorry⟩
    let A i := B.filter (fun x => ∃ j, e (i, j) = x ∧ i ≠ j)
    let f x := if ∃ u v, e (u, v) = x ∧ u < v ∧ ((v.val + 2*n+1 - u.val) % (2*n+1) ≤ k) then 0 else 1
    use n, n_pos, A, B; refine ⟨by simp, by sorry, by sorry, by sorry, f, by sorry, by sorry⟩

