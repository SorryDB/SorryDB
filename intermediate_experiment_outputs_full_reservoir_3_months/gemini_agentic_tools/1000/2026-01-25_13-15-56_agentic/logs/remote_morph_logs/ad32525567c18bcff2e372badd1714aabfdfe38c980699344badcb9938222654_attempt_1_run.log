import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; constructor
  · rintro ⟨n, n_pos, A, B, hAB, hA, hI, hB, ⟨f, hf, hfA⟩, rfl⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ x ∈ B, k x = (2 * n + 1) * (2 * n) := by
      simp only [k, Finset.card_filter, ← Finset.sum_comm, Finset.sum_boole, Finset.filter_mem_univ_right, Finset.card_filter_intersect_left hAB, hA, Finset.sum_const, Finset.card_univ, Finset.card_fin]
    have h2 : ∑ x ∈ B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      simp only [k, Finset.card_filter, Finset.filter_filter, ← Finset.sum_comm, Finset.sum_boole, Finset.filter_mem_univ_right, ← Finset.sum_univ_erase]
      simp only [fun i j => Finset.card_filter_intersect_left (Finset.Subset.trans (Finset.inter_subset_left _ _) (hAB i)), hI, Finset.sum_const, Finset.card_erase_univ, Finset.card_fin, Nat.sub_self, Nat.add_zero]
    have h3 : ∀ x ∈ B, k x = 2 := by
      intro x hx
      have : ∑ y ∈ B, k y * (k y - 2) = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, Finset.sum_sub_distrib, ← h2, ← h1]; omega
      have kge2 : 2 ≤ k x := by
        rcases hB x hx with ⟨i, j, hij, hi, hj⟩
        have : {i, j} ⊆ Finset.univ.filter (x ∈ A ·) := by simp [hi, hj, hij]
        have c := Finset.card_le_card this; simp [hij] at c; exact c
      have : k x * (k x - 2) = 0 := Finset.sum_eq_zero_iff.1 this x hx
      omega
    have h4 : 2 * (B.filter (f · = 0)).card = (2 * n + 1) * n := by
      simp only [Finset.card_filter, ← Finset.sum_comm, Finset.sum_boole, Finset.filter_mem_univ_right, Finset.card_filter_intersect_left hAB, hfA, Finset.sum_const, Finset.card_fin]
      rw [← Finset.sum_filter, Finset.sum_congr rfl]; intro x hx; simp [h3 x (Finset.mem_filter.1 hx).1, (Finset.mem_filter.1 hx).2]
    have : Even ((2 * n + 1) * n) := ⟨_, h4.symm⟩
    rw [Nat.even_mul, Nat.even_add_one, Nat.even_two_mul] at this; simp at this
    exact ⟨n_pos, even_iff_two_dvd.1 this⟩
  · rintro ⟨n_pos, h_even⟩; rcases h_even with ⟨k, rfl⟩; set n := 2 * k
    let V := Fin (2 * n + 1)
    let e (i j : V) : ℕ := if i < j then i.val * (2 * n + 1) + j.val else j.val * (2 * n + 1) + i.val
    let B := (Finset.univ.offDiag : Finset (V × V)).filter (fun p => p.1 < p.2) |>.map ⟨fun p => e p.1 p.2, by
      intro p1 p2 h; simp [e] at h; rcases p1 with ⟨a, b⟩; rcases p2 with ⟨c, d⟩; simp at *
      have : a.val = c.val ∧ b.val = d.val := by split_ifs at h <;> omega
