    · intro x hx; simp [B] at hx; rcases hx with ⟨⟨i, j⟩, hij, rfl⟩; use i, j; simp [hij.1, A, e, hij.2]
    · intro x hx; simp [f]
    · intro i; let S := (Finset.univ.erase i).filter (fun j => (j - i).val ≤ k ∨ (i - j).val ≤ k)
      have : (A i).filter (f · = 0) = S.map ⟨fun j => e i j, by intro j1 j2 h; simp [e] at h; split_ifs at h <;> omega⟩ := by
        ext x; simp [A, S, f]; constructor
        · rintro ⟨j, hj, rfl⟩; use j; simp [hj, e]; split_ifs <;> (try omega) <;> (rintro i' j' hij' hx; have : {i', j'} = {i, j} := by simp [e] at hx; split_ifs at hx <;> omega; omega)
        · rintro ⟨j, hj, rfl⟩; use j; simp [hj]; use (if i < j then i else j), (if i < j then j else i); simp [e]; split_ifs <;> omega
      rw [this, Finset.card_map]; have : S.card = n := by
