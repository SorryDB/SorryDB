lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  filter_upwards [hX.IsLocalizingSequence.tendsto_top] with ω hω t
  rw [WithTop.tendsto_atTop_nhds_top_iff] at hω
  obtain ⟨n, hn⟩ := hω t
  let τ := hX.localSeq n
  have h_lt : (t : WithTop ι) < τ ω := hn n le_rfl
  have h_bot : (⊥ : WithTop ι) < τ ω := (WithTop.coe_le_coe.2 bot_le).trans_lt h_lt
  have h_rc : Function.RightContinuous (stoppedProcess (fun i ↦ {ω | ⊥ < τ ω}.indicator (X i)) τ · ω) :=
    hX.stoppedProcess n ω
  refine (h_rc t).congr_of_eventuallyEq ?_ ?_
  · have h_mem : {s : ι | (s : WithTop ι) < τ ω} ∈ 𝓝 t := by
      cases hτ : τ ω with
      | top => simp only [hτ, WithTop.coe_lt_top, Set.setOf_true, Filter.univ_mem]
      | coe c =>
        have h_tc : t < c := WithTop.coe_lt_coe.1 (hτ ▸ h_lt)
        simp only [hτ, WithTop.coe_lt_coe]
        exact Iio_mem_nhds h_tc
    filter_upwards [nhdsWithin_le_nhds h_mem] with s hs
    rw [stoppedProcess_indicator_comm', Set.indicator_apply, if_pos h_bot, stoppedProcess_eq_of_le hs.le]
  · rw [stoppedProcess_indicator_comm', Set.indicator_apply, if_pos h_bot, stoppedProcess_eq_of_le h_lt.le]

end NormedSpace
```
