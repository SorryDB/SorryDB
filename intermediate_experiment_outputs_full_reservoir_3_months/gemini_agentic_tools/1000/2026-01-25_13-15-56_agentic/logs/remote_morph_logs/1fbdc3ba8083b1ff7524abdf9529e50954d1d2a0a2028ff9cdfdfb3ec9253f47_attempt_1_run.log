  filter_upwards [mem_nhdsWithin_of_mem h_mem] with s hs
  rw [MeasureTheory.stoppedProcess_eq_of_le (le_of_lt hs), Set.indicator_of_mem]
  exact (WithTop.coe_le_coe.mpr bot_le).trans_lt hn
