/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ generalizing S
  case nil =>
    unfold eval eval eval at a_kv_b; rw [eval_dis] at a_kv_b
    rcases a_kv_b with h|h <;> have h_val := true_of_knowldege h
    all_goals
      simp at h_val ⊢
      by_cases b = a <;> try simp_all
      exfalso; have := h (S.switch b) ⟨[], by simp [maxOne]⟩ (by simp) (by simp [Dist.switch]; grind)
      simp [eval, Dist.switch] at this; simp_all [Dist.switch]
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Other =>
      unfold resultSet; rw [ra]; apply IH (⁻o); rwa [not_in_call_then_invariant_kv ra] at a_kv_b
    case Caller | Callee =>
      rw [eval_dis] at a_kv_b; rcases a_kv_b with h_k | h_k
      all_goals
        have h_val := true_of_knowldege h_k; have h_true := h_val; rwa [stubbornness] at h_true
        constructor
        · unfold resultSet; simp [ra]
          cases C <;> simp_all [roleOfIn, stubbornness]
          all_goals { try { left; rwa [stubbornness] } }
          all_goals { try { right; rwa [stubbornness] } }
          all_goals { try { left; simp [invert]; use (b, S b); simp [stubbornness]; rwa [stubbornness] at h_val } }
          all_goals { try { right; simp [invert]; use (b, S b); simp [stubbornness]; rwa [stubbornness] at h_val } }
          all_goals { try { sorry } }
        · unfold resultSet; simp [ra]; right; simp [delete]
          intro T τ D len_τ equ role_D same_contrib
          have h_equi : (S, ⟨C :: σ, o⟩) ~_ a (T, ⟨D :: τ, by rw [← τ.2, ← len_τ]; simp⟩) :=
            ⟨by simp [OSequence.length, len_τ]; linarith, equ, ra.trans role_D.symm, same_contrib⟩
          have h_ka_T := (equiv_then_know_same (equiv_of_equi h_equi) _).mp h_k
          have := true_of_knowldege h_ka_T; rwa [stubbornness] at this
```
