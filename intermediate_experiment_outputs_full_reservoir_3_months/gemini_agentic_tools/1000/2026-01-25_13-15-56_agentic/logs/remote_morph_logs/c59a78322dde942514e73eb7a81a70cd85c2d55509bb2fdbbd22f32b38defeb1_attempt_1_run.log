section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have hs : ∀ {x y} (w : G.LoopWalk x y), x ∈ supportSet w := by
    intro x y w; induction w <;> simp [supportSet, support, *]
  have he : ∀ {x y} (w : G.LoopWalk x y) {e}, e ∈ edgeSet w → ∀ vz ∈ e, vz ∈ supportSet w := by
    intro x y w e h_e vz h_vz
    induction w with
    | nil => simp [edgeSet, edges, darts] at h_e
    | cons _ q ih =>
      simp [edgeSet, edges, darts, dartEdge] at h_e
      rcases h_e with rfl | h_e
      · rcases Sym2.mem_iff.1 h_vz with rfl | rfl <;> simp [supportSet, support, hs]
      · simp [supportSet, support]; exact Or.inr (ih h_e)
    | loop q ih =>
      simp [edgeSet, edges, darts, dartEdge] at h_e
      rcases h_e with rfl | h_e
      · rcases Sym2.mem_iff.1 h_vz with rfl | rfl <;> simp [supportSet, support, hs]
      · simp [supportSet, support]; exact Or.inr (ih h_e)
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | cons h q ih =>
    rename_i u v' w
    simp [supportSet, edgeSet, support, edges, darts, dartEdge] at *
    by_cases hu : u ∈ q.support.toFinset
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have h_not : Sym2.mk (u, v') ∉ (q.darts.map dartEdge).toFinset := by
        intro h_mem; exact hu (he q h_mem (Sym2.mem_mk_left u v'))
      rw [Finset.card_insert_of_not_mem h_not]
      exact Nat.add_le_add_right ih 1
  | loop q ih =>
    rename_i u v
    simp [supportSet, edgeSet, support, edges, darts, dartEdge] at *
    rw [Finset.insert_eq_of_mem (hs q)]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)

end LoopWalkCounting
