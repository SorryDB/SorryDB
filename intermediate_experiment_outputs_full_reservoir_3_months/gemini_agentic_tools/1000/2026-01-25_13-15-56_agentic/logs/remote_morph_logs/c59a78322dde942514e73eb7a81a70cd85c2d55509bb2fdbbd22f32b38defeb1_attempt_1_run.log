section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ support w := by
    intro u v w; induction w <;> simp [support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v), ∀ e ∈ edgeSet w, ∀ x ∈ e, x ∈ support w := by
    intro u' v' w' e' he' x' hx'
    induction w' with
    | nil => simp [edgeSet, edges, darts] at he'
    | loop q ih =>
      simp [edgeSet, edges, darts, dartEdge, support] at he' ⊢
      rcases he' with (rfl | he')
      · rw [Sym2.mem_iff] at hx'; rcases hx' with (rfl | rfl) <;> exact Or.inl rfl
      · exact Or.inr (ih he')
    | cons h q ih =>
      simp [edgeSet, edges, darts, dartEdge, support] at he' ⊢
      rcases he' with (rfl | he')
      · rw [Sym2.mem_iff] at hx'; rcases hx' with (rfl | rfl)
        · exact Or.inl rfl
        · exact Or.inr (h_start q)
      · exact Or.inr (ih he')
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    have h_u : u ∈ supportSet q := Finset.mem_toFinset.mpr (h_start q)
    rw [supportSet, support, Finset.toFinset_cons, Finset.insert_eq_of_mem h_u]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
  | cons h q ih =>
    rename_i v_next
    have h_u_s : supportSet (LoopWalk.cons h q) = insert u (supportSet q) := rfl
    have h_e_s : edgeSet (LoopWalk.cons h q) = insert (Sym2.mk (u, v_next)) (edgeSet q) := rfl
    rw [h_u_s, h_e_s]
    by_cases hu : u ∈ support q
    · rw [Finset.insert_eq_of_mem (Finset.mem_toFinset.mpr hu)]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem (Finset.mem_toFinset.not_mpr hu)]
      have he : Sym2.mk (u, v_next) ∉ edgeSet q := by
        intro h_in
        exact hu (h_edges q _ h_in u (Sym2.mem_mk_left u v_next))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
