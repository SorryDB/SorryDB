section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ w.support := by
    intro u' v' w'; induction w' <;> simp [support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v) {e x}, e ∈ w.edgeSet → x ∈ e → x ∈ w.supportSet := by
    intro u' v' w' e x he hx
    induction w' with
    | nil => simp [edgeSet, edges, darts] at he
    | loop q ih =>
      rw [edgeSet, edges, darts, dartEdge, List.toFinset_cons, Finset.mem_insert] at he
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl) <;> simp [supportSet, support, h_start q]
      · simp [supportSet, support]; exact Or.inr (List.mem_toFinset.mp (ih he hx))
    | cons h q ih =>
      rw [edgeSet, edges, darts, dartEdge, List.toFinset_cons, Finset.mem_insert] at he
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · simp [supportSet, support]
        · simp [supportSet, support]; exact Or.inr (h_start q)
      · simp [supportSet, support]; exact Or.inr (List.mem_toFinset.mp (ih he hx))
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    rename_i u' v'
    have h_s : (LoopWalk.loop q).supportSet = q.supportSet := by
      apply Finset.ext; intro x; simp [supportSet, support, h_start q]
    rw [h_s]
    have h_e_le : q.edgeSet.card ≤ (LoopWalk.loop q).edgeSet.card :=
      Finset.card_le_card (by simp [edgeSet, edges, darts, dartEdge]; apply Finset.subset_insert)
    exact ih.trans (Nat.add_le_add_right h_e_le 1)
  | cons h q ih =>
    rename_i u_start v_next v_end
    have h_s : (LoopWalk.cons h q).supportSet = insert u_start q.supportSet := by simp [supportSet, support]
    have h_e : (LoopWalk.cons h q).edgeSet = insert (Sym2.mk (u_start, v_next)) q.edgeSet := by simp [edgeSet, edges, darts, dartEdge]
    rw [h_s, h_e]
    by_cases hu : u_start ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      have h_e_le : q.edgeSet.card ≤ (insert (Sym2.mk (u_start, v_next)) q.edgeSet).card := Finset.card_le_card (Finset.subset_insert _ _)
      exact ih.trans (Nat.add_le_add_right h_e_le 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u_start, v_next) ∉ q.edgeSet := by
        intro h_in; exact hu (h_edges q h_in (Sym2.mem_mk_left u_start v_next))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
