section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ w.support := by
    intro u v w; induction w <;> simp [support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v) {e x}, e ∈ w.edgeSet → x ∈ e → x ∈ w.supportSet := by
    intro u' v' w e x he hx
    induction w with
    | nil => simp [edgeSet, edges, darts] at he
    | loop q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support, List.toFinset_cons] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl) <;> exact Finset.mem_insert_self ..
      · exact Finset.mem_insert_of_mem (ih he hx)
    | cons h q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support, List.toFinset_cons] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · exact Finset.mem_insert_self ..
        · exact Finset.mem_insert_of_mem (List.mem_toFinset.mpr (h_start q))
      · exact Finset.mem_insert_of_mem (ih he hx)
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    rename_i u' v'
    have h_s : (LoopWalk.loop q).supportSet = q.supportSet := by
      simp [supportSet, support, List.toFinset_cons]
      exact Finset.insert_eq_of_mem (List.mem_toFinset.mpr (h_start q))
    rw [h_s]
    have h_e_le : q.edgeSet.card ≤ (LoopWalk.loop q).edgeSet.card := by
      simp [edgeSet, edges, darts, dartEdge, List.toFinset_cons]
      exact Finset.card_le_card (Finset.subset_insert _ _)
    exact ih.trans (Nat.add_le_add_right h_e_le 1)
  | cons h q ih =>
    rename_i u_start v_mid v_end
    have h_s : (LoopWalk.cons h q).supportSet = insert u_start q.supportSet := by
      simp [supportSet, support, List.toFinset_cons]
    have h_e : (LoopWalk.cons h q).edgeSet = insert (Sym2.mk (u_start, v_mid)) q.edgeSet := by
      simp [edgeSet, edges, darts, dartEdge, List.toFinset_cons]
    rw [h_s, h_e]
    by_cases hu : u_start ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      have h_e_le : q.edgeSet.card ≤ (insert (Sym2.mk (u_start, v_mid)) q.edgeSet).card :=
        Finset.card_le_card (Finset.subset_insert _ _)
      exact ih.trans (Nat.add_le_add_right h_e_le 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u_start, v_mid) ∉ q.edgeSet := by
        intro h_in
        exact hu (h_edges q h_in (Sym2.mem_mk_left u_start v_mid))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
