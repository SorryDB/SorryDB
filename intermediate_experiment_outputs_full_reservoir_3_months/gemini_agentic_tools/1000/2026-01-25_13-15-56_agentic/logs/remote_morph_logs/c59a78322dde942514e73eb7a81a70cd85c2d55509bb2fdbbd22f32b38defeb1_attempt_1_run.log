section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u' v' : V} (w : G.LoopWalk u' v'), u' ∈ support w := by
    intro u' v' w; induction w <;> simp [support, *]
  have h_edges : ∀ {u' v' : V} (w : G.LoopWalk u' v'), ∀ e ∈ edgeSet w, ∀ x ∈ e, x ∈ supportSet w := by
    intro u' v' w e' he' x' hx'
    induction w with
    | nil => simp [edgeSet, edges, darts] at he'
    | loop q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support] at he' ⊢
      rw [Finset.mem_insert] at he'
      rcases he' with (rfl | he')
      · rw [Sym2.mem_iff] at hx'; rcases hx' with (rfl | rfl) <;> exact Or.inl rfl
      · exact Or.inr (ih he' x' hx')
    | cons h q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support] at he' ⊢
      rw [Finset.mem_insert] at he'
      rcases he' with (rfl | he')
      · rw [Sym2.mem_iff] at hx'; rcases hx' with (rfl | rfl)
        · exact Or.inl rfl
        · exact Or.inr (List.mem_toFinset.mpr (h_start q))
      · exact Or.inr (ih he' x' hx')
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    have h_s : supportSet (LoopWalk.loop q) = supportSet q := by
      simp [supportSet, support]
      exact Finset.insert_eq_of_mem (List.mem_toFinset.mpr (h_start q))
    rw [h_s]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
  | cons h q ih =>
    rename_i v_next
    have h_s : supportSet (LoopWalk.cons h q) = insert u (supportSet q) := by simp [supportSet, support]
    have h_e : edgeSet (LoopWalk.cons h q) = insert (Sym2.mk (u, v_next)) (edgeSet q) := by simp [edgeSet, edges, darts, dartEdge]
    rw [h_s, h_e]
    by_cases hu : u ∈ supportSet q
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u, v_next) ∉ edgeSet q := by
        intro h_in
        exact hu (h_edges q h_in u (Sym2.mem_iff.mpr (Or.inl rfl)))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
