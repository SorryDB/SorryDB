section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ w.supportSet := by
    intro u v w; induction w <;> simp [LoopWalk.supportSet, LoopWalk.support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v) {e : Sym2 V}, e ∈ w.edgeSet → ∀ x ∈ e, x ∈ w.supportSet := by
    intro u v w e he x hx
    induction w with
    | nil => simp [LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts] at he
    | cons h q ih =>
      simp [LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts, dartEdge, LoopWalk.supportSet, LoopWalk.support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · exact Or.inl rfl
        · exact Or.inr (h_start q)
      · exact Or.inr (ih he x hx)
    | loop q ih =>
      simp [LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts, dartEdge, LoopWalk.supportSet, LoopWalk.support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl) <;> exact Or.inl rfl
      · exact Or.inr (ih he x hx)
  induction p with
  | nil => simp [LoopWalk.supportSet, LoopWalk.support, LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts]
  | loop q ih =>
    have h_s : (LoopWalk.loop q).supportSet = q.supportSet := by
      simp [LoopWalk.supportSet, LoopWalk.support, h_start q]
    have h_e_sub : q.edgeSet ⊆ (LoopWalk.loop q).edgeSet := by
      simp [LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts, dartEdge, Finset.subset_insert]
    rw [h_s]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card h_e_sub) 1)
  | cons h q ih =>
    rename_i u_start v_next v_end
    have h_s : (LoopWalk.cons h q).supportSet = insert u_start q.supportSet := by
      simp [LoopWalk.supportSet, LoopWalk.support]
    have h_e : (LoopWalk.cons h q).edgeSet = insert (Sym2.mk (u_start, v_next)) q.edgeSet := by
      simp [LoopWalk.edgeSet, LoopWalk.edges, LoopWalk.darts, dartEdge]
    rw [h_s, h_e]
    by_cases hu : u_start ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u_start, v_next) ∉ q.edgeSet := by
        intro h_in
        exact hu (h_edges q h_in u_start (Sym2.mem_mk_left u_start v_next))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
