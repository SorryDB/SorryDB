section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_v_in : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ w.support := by
    intro _ _ w; cases w <;> simp [support]
  have h_e_in : ∀ {u v : V} (w : G.LoopWalk u v) {e x}, e ∈ w.edgeSet → x ∈ e → x ∈ w.supportSet := by
    intro u' v' w' e x he hx
    induction w' with
    | nil => cases he
    | loop q ih' =>
      simp [edgeSet, edges, darts, dartEdge] at he
      rcases he with rfl | he
      · simp [Sym2.mem_iff] at hx; rcases hx with rfl | rfl <;> (rw [supportSet, List.mem_toFinset]; first | left; rfl | right; apply h_v_in)
      · rw [supportSet, List.mem_toFinset]; right; exact List.mem_toFinset.mp (ih' he hx)
    | cons h' q ih' =>
      simp [edgeSet, edges, darts, dartEdge] at he
      rcases he with rfl | he
      · simp [Sym2.mem_iff] at hx; rcases hx with rfl | rfl <;> (rw [supportSet, List.mem_toFinset]; first | left; rfl | right; apply h_v_in)
      · rw [supportSet, List.mem_toFinset]; right; exact List.mem_toFinset.mp (ih' he hx)
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    rw [supportSet, support, List.toFinset_cons, Finset.insert_eq_of_mem (List.mem_toFinset.mpr (h_v_in q))]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (by simp [edgeSet, edges, darts, dartEdge]; apply Finset.subset_insert)) 1)
  | cons h q ih =>
    rename_i v_mid
    by_cases hu : u ∈ q.supportSet
    · rw [supportSet, support, List.toFinset_cons, Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (by simp [edgeSet, edges, darts, dartEdge]; apply Finset.subset_insert)) 1)
    · rw [supportSet, support, List.toFinset_cons, Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u, v_mid) ∉ q.edgeSet := fun h_in => hu (h_e_in q h_in (Sym2.mem_mk_left u v_mid))
      have h_e_card : (LoopWalk.cons h q).edgeSet.card = q.edgeSet.card + 1 := by
        simp [edgeSet, edges, darts, dartEdge]
        rw [Finset.card_insert_of_not_mem he]
      rw [h_e_card]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
