section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ (support w).toFinset := by
    intro u v w; induction w <;> simp [support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v) {e : Sym2 V},
    e ∈ (edges w).toFinset → ∀ x ∈ e, x ∈ (support w).toFinset := by
    intro u v w e he x hx
    induction w with
    | nil => simp [edges, darts] at he
    | cons h q ih =>
      simp [edges, darts, dartEdge, support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · exact Or.inl rfl
        · exact Or.inr (h_start q)
      · exact Or.inr (ih he)
    | loop q ih =>
      simp [edges, darts, dartEdge, support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · exact Or.inl rfl
        · exact Or.inl rfl
      · exact Or.inr (ih he)
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | cons h q ih =>
    rename_i u' v' w'
    simp only [supportSet, edgeSet, support, edges, darts, dartEdge, List.toFinset_cons, List.map_cons] at *
    by_cases h_mem : u' ∈ (support q).toFinset
    · rw [Finset.insert_eq_of_mem h_mem]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem h_mem]
      have h_edge_not : Sym2.mk (u', v') ∉ (List.map dartEdge q.darts).toFinset := by
        intro h_in; exact h_mem (h_edges q h_in u' (Sym2.mem_mk_left u' v'))
      rw [Finset.card_insert_of_not_mem h_edge_not]
      exact Nat.add_le_add_right ih 1
  | loop q ih =>
    rename_i u' v'
    simp only [supportSet, edgeSet, support, edges, darts, dartEdge, List.toFinset_cons, List.map_cons] at *
    rw [Finset.insert_eq_of_mem (h_start q)]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)

end LoopWalkCounting
