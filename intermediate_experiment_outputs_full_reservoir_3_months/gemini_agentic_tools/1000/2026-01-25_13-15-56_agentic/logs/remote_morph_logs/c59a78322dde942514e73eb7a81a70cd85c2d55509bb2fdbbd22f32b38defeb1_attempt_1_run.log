lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have hs : ∀ {x y} (w : G.LoopWalk x y), x ∈ (support w).toFinset := by
    intro x y w; induction w <;> simp [support, *]
  have hd : ∀ {x y} (w : G.LoopWalk x y) {a b}, (a, b) ∈ w.darts → a ∈ (support w).toFinset ∧ b ∈ (support w).toFinset := by
    intro x y w a b h
    induction w with
    | nil => contradiction
    | cons _ q ih =>
      simp [darts, support] at h ⊢
      rcases h with rfl | h
      · exact ⟨Or.inl rfl, Or.inr (hs q)⟩
      · rcases ih h with ⟨h1, h2⟩; exact ⟨Or.inr h1, Or.inr h2⟩
    | loop q ih =>
      simp [darts, support] at h ⊢
      rcases h with rfl | h
      · exact ⟨Or.inl rfl, Or.inr (hs q)⟩
      · rcases ih h with ⟨h1, h2⟩; exact ⟨Or.inr h1, Or.inr h2⟩
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | cons _ q ih =>
    rename_i u v w
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons, List.map_cons, dartEdge] at *
    by_cases hu : u ∈ (support q).toFinset
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu, Finset.card_insert_of_not_mem]
      · exact Nat.add_le_add_right ih 1
      · intro he
        rw [List.mem_toFinset, List.mem_map] at he
        rcases he with ⟨⟨a, b⟩, h_dart, h_eq⟩
        rcases hd q h_dart with ⟨ha, hb⟩
        rw [Sym2.eq_iff] at h_eq
        rcases h_eq with ⟨rfl, rfl⟩ | ⟨rfl, rfl⟩ <;> contradiction
  | loop q ih =>
    rename_i u v
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons, List.map_cons, dartEdge] at *
    have hu : u ∈ (support q).toFinset := hs q
    rw [Finset.insert_eq_of_mem hu]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)

end LoopWalk
