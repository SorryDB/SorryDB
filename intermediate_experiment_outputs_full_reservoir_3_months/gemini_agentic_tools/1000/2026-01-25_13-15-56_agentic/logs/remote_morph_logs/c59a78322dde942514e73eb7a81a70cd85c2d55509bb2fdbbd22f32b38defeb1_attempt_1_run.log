section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have hs : ∀ {x y} (p : G.LoopWalk x y), x ∈ p.support := fun p => by cases p <;> simp [support]
  have hd : ∀ {x y} (p : G.LoopWalk x y) {d}, d ∈ p.darts → d.1 ∈ p.support ∧ d.2 ∈ p.support := by
    intro x y p d h
    induction p with
    | nil => contradiction
    | cons _ q ih =>
      simp [darts, support] at h ⊢
      rcases h with rfl | h
      · exact ⟨by simp, Or.inr (hs q)⟩
      · rcases ih h with ⟨h1, h2⟩; exact ⟨Or.inr h1, Or.inr h2⟩
    | loop q ih =>
      simp [darts, support] at h ⊢
      rcases h with rfl | h
      · exact ⟨by simp, Or.inr (hs q)⟩
      · rcases ih h with ⟨h1, h2⟩; exact ⟨Or.inr h1, Or.inr h2⟩
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | cons _ q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons, List.map_cons, dartEdge]
    by_cases hu : u ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu, Finset.card_insert_of_not_mem]
      · exact Nat.add_le_add_right ih 1
      · intro he
        rw [edgeSet, List.mem_toFinset, List.mem_map] at he
        rcases he with ⟨d, h_d, he⟩
        have h' := hd q h_d
        rw [Sym2.eq_iff] at he
        rcases he with ⟨rfl, rfl⟩ | ⟨rfl, rfl⟩
        · exact hu (List.mem_toFinset.mpr h'.1)
        · exact hu (List.mem_toFinset.mpr h'.2)
  | loop q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons, List.map_cons, dartEdge]
    have hu : u ∈ q.supportSet := List.mem_toFinset.mpr (hs q)
    rw [Finset.insert_eq_of_mem hu]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)

end LoopWalkCounting
