section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {u v : V} (w : G.LoopWalk u v), u ∈ w.supportSet := by
    intro u' v' w'; induction w' <;> simp [supportSet, support, *]
  have h_edges : ∀ {u v : V} (w : G.LoopWalk u v) {e x}, e ∈ w.edgeSet → x ∈ e → x ∈ w.supportSet := by
    intro u' v' w' e x he hx
    induction w' with
    | nil => simp [edgeSet, edges, darts] at he
    | loop q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl) <;> apply Finset.mem_insert_self
      · exact Finset.mem_insert_of_mem (ih he hx)
    | cons h q ih =>
      simp [edgeSet, edges, darts, dartEdge, supportSet, support] at he ⊢
      rcases he with (rfl | he)
      · rw [Sym2.mem_iff] at hx; rcases hx with (rfl | rfl)
        · apply Finset.mem_insert_self
        · apply Finset.mem_insert_of_mem; exact h_start q
      · exact Finset.mem_insert_of_mem (ih he hx)
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | loop q ih =>
    have h_s : (LoopWalk.loop q).supportSet = q.supportSet := by
      simp [supportSet, support, h_start q]
    rw [h_s]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
  | cons h q ih =>
    rename_i u_s v_m v_e
    have h_s : (LoopWalk.cons h q).supportSet = insert u_s q.supportSet := rfl
    have h_e : (LoopWalk.cons h q).edgeSet = insert (Sym2.mk (u_s, v_m)) q.edgeSet := rfl
    rw [h_s, h_e]
    by_cases hu : u_s ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu]
      have he : Sym2.mk (u_s, v_m) ∉ q.edgeSet := by
        intro h_in
        exact hu (h_edges q h_in (Sym2.mem_mk_left _ _))
      rw [Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1

end LoopWalkCounting
