theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  unfold longestIncreasingSubseqLength_postcond longestIncreasingSubseqLength
  simp only [longestIncreasingSubseqLength_precond]
  let f_acc := fun (acc : List (List Int)) (x : Int) => acc ++ acc.map (fun sub => x :: sub)
  let L1 := (subsequences xs).filter isStrictlyIncreasing |>.map List.length
  let allSubseq := (xs.foldl f_acc [[]]).map List.reverse
  let L2 := allSubseq.filter (fun l => l.Pairwise (· < ·)) |>.map List.length

  have h_inc {s : List Int} : isStrictlyIncreasing s = true ↔ s.Pairwise (· < ·) := by
    induction s with
    | nil => simp [isStrictlyIncreasing, List.Pairwise]
    | cons x s ih =>
      cases s with
      | nil => simp [isStrictlyIncreasing, List.Pairwise]
      | cons y s' =>
        simp [isStrictlyIncreasing, List.Pairwise, ih]
        constructor
        · intro h; constructor
          · intro z hz; cases hz with
            | head => exact h.1
            | tail _ hz' =>
              have h_p := (ih.mp h.2).1 z hz'
              exact Int.lt_trans h.1 h_p
          · exact ih.mp h.2
        · intro h; exact ⟨h.1 y (List.mem_cons_self _ _), ih.mpr h.2⟩

  have h_mem_sub (s : List Int) : s ∈ subsequences xs ↔ s.Sublist xs := by
    induction xs generalizing s with
    | nil => simp [subsequences]; constructor <;> intro h <;> (try cases h); rfl
    | cons x xs ih =>
      simp [subsequences, List.mem_append, List.mem_map, ih]
      constructor
      · rintro (h | ⟨s', hs', rfl⟩)
        · exact (ih.mp h).cons x
        · exact (ih.mp hs').cons₂ x
      · intro h; cases h with
        | slnil => left; exact ih.mpr List.Sublist.slnil
        | cons _ h' => left; exact ih.mpr h'
        | cons₂ _ h' => right; use s; exact ⟨ih.mpr h', rfl⟩

  have h_mem_all (s : List Int) : s ∈ allSubseq ↔ s.Sublist xs := by
    simp [allSubseq, List.mem_map]; constructor
    · rintro ⟨s', hs', rfl⟩; induction xs using List.reverse_induction generalizing s' with
      | Nil => simp at hs'; subst hs'; constructor
      | concat x xs ih =>
        simp [List.foldl_append, List.mem_append, List.mem_map] at hs'
        rcases hs' with (h | ⟨s'', hs'', rfl⟩)
        · exact (ih h).trans (List.sublist_append_left _ _)
        · rw [List.reverse_cons]; exact (ih hs'').append (List.Sublist.refl _)
    · intro h; induction xs using List.reverse_induction generalizing s with
      | Nil => cases h; use []; simp
      | concat x xs ih =>
        rw [List.sublist_append_iff] at h
        rcases h with ⟨s1, s2, h1, h2, rfl⟩
        cases s2 with
        | nil => rcases ih h1 with ⟨s', hs', rfl⟩; use s'; simp [List.foldl_append, hs']
        | cons y ys => simp at h2; subst h2; rcases ih h1 with ⟨s', hs', rfl⟩; use x :: s'; simp [List.foldl_append, hs']

  have h_L12 : ∀ n, n ∈ L1 ↔ n ∈ L2 := by
    intro n; simp [L1, L2, h_inc, h_mem_sub, h_mem_all]

  have h_fold (l : List Nat) (m : Nat) : (∀ x ∈ l, x ≤ l.foldl max m) ∧ (l.foldl max m ∈ m :: l) := by
    induction l generalizing m with
    | nil => simp
    | cons x l ih =>
      simp [List.foldl]; constructor
      · intro y hy; cases hy with
        | head => exact (le_max_right m x).trans (ih (max m x)).1
        | tail _ hy' => exact (ih (max m x)).1 y hy'
      · rcases (ih (max m x)).2 with h | h
        · rw [h]; simp [max]; split <;> simp [*]
        · right; exact h

  let res := L1.foldl max 0
  have h_res : res ∈ L1 := by
    have := (h_fold L1 0).2
    cases this with
    | head h =>
      have h0 : 0 ∈ L1 := by
        simp [L1]; use []; simp [isStrictlyIncreasing, h_mem_sub, List.Sublist.slnil]
      rw [h]; exact h0
    | tail h => exact h

  constructor
  · rw [List.contains_iff, ← h_L12]; exact h_res
  · rw [List.all_iff_forall_mem]; intro n hn; rw [← h_L12] at hn; exact (h_fold L1 0).1 n hn
