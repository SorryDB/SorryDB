theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  unfold longestIncreasingSubseqLength_postcond longestIncreasingSubseqLength
  simp only [longestIncreasingSubseqLength_precond]
  let L1 := (subsequences xs).filter (fun l => isStrictlyIncreasing l) |>.map List.length
  let f_acc := fun (acc : List (List Int)) (x : Int) => acc ++ acc.map (fun sub => x :: sub)
  let allSubseq := (xs.foldl f_acc [[]]).map List.reverse
  let L2 := allSubseq.filter (fun l => l.Pairwise (· < ·)) |>.map List.length

  have h_inc {s : List Int} : isStrictlyIncreasing s = true ↔ s.Pairwise (· < ·) := by
    induction s with
    | nil => simp [isStrictlyIncreasing, List.Pairwise]
    | cons x s ih =>
      cases s with
      | nil => simp [isStrictlyIncreasing, List.Pairwise]
      | cons y s' =>
        simp [isStrictlyIncreasing, List.Pairwise, ih]
        constructor
        · intro h; constructor
          · intro z hz; simp [List.Pairwise] at h; rcases h with ⟨h1, h2⟩
            cases hz with | head => exact h1 | tail _ hz' =>
              have h_all : ∀ a ∈ s', y < a := by 
                have h_p := ih.1 h2; simp [List.Pairwise] at h_p; exact h_p.1
              exact Int.lt_trans h1 (h_all z hz')
          · exact (ih.1 h.2)
        · intro h; exact ⟨h.1 y (List.mem_cons_self _ _), ih.2 h.2⟩

  have h_mem_sub (s : List Int) : s ∈ subsequences xs ↔ s.Sublist xs := by
    induction xs generalizing s with
    | nil => simp [subsequences]; constructor <;> intro h <;> (try cases h); rfl
    | cons x xs ih =>
      simp [subsequences, List.mem_append, List.mem_map, ih]
      constructor
      · rintro (h | ⟨s', hs', rfl⟩)
        · exact List.Sublist.cons _ _ _ (ih.1 h)
        · exact List.Sublist.cons₂ _ _ _ (ih.1 hs')
      · intro h; cases h with
        | cons _ _ _ h' => left; exact ih.2 h'
        | cons₂ _ _ _ h' => right; use s; exact ⟨ih.2 h', rfl⟩

  have h_sub_append (s L : List Int) (x : Int) : s.Sublist (L ++ [x]) ↔ s.Sublist L ∨ ∃ s', s = s' ++ [x] ∧ s'.Sublist L := by
    constructor
    · intro h; induction h with
      | slnil => left; constructor
      | cons _ _ h' ih' =>
        rcases ih' with hl | ⟨s', rfl, hr⟩
        · left; exact List.Sublist.cons _ _ _ hl
        · right; use s'; exact ⟨rfl, List.Sublist.cons _ _ _ hr⟩
      | cons₂ _ _ h' ih' =>
        rcases ih' with hl | ⟨s', rfl, hr⟩
        · left; exact List.Sublist.cons₂ _ _ _ hl
        · right; use (s' ++ [x]); constructor; · simp; · exact List.Sublist.cons₂ _ _ _ hr
    · rintro (h | ⟨s', rfl, h⟩)
      · exact h.trans (List.sublist_append_left _ _)
      · exact h.append (List.Sublist.refl _)

  have h_f (s : List Int) (L : List Int) : s ∈ (L.foldl f_acc [[]]) ↔ s.reverse.Sublist L := by
    induction L using List.reverseRecOn generalizing s with
    | nil => 
      simp [List.foldl]; constructor <;> intro h
      · subst h; constructor
      · cases h; rfl
    | snoc L x ih =>
      simp [List.foldl_append, List.foldl_cons, List.mem_append, List.mem_map, ih]
      rw [h_sub_append]
      constructor
      · rintro (h | ⟨s', hs', rfl⟩)
        · left; exact ih.1 h
        · right; use s'.reverse; rw [List.reverse_reverse]; exact ⟨by rw [List.reverse_cons], ih.1 hs'⟩
      · rintro (h | ⟨s', h_rev, h_sub⟩)
        · left; exact ih.2 h
        · right; use s'.reverse; constructor
          · apply ih.2; rw [List.reverse_reverse]; exact h_sub
          · rw [h_rev, List.reverse_append]; simp

  have h_mem_all (s : List Int) : s ∈ allSubseq ↔ s.Sublist xs := by
    simp [allSubseq]; constructor
    · rintro ⟨s', hs', rfl⟩; exact (h_f s' xs).1 hs'
    · intro h; use s.reverse; simp [h_f, h]

  have h_L12 : ∀ n, n ∈ L1 ↔ n ∈ L2 := by
    intro n; simp [L1, L2, List.mem_filter, List.mem_map, h_inc, h_mem_sub, h_mem_all]

  have h_fold {α} [LinearOrder α] (l : List α) (m : α) :
      (∀ x ∈ l, x ≤ l.foldl max m) ∧ (l.foldl max m ∈ m :: l) := by
    induction l generalizing m with
    | nil => simp [List.foldl]
    | cons x l ih =>
      simp [List.foldl]; constructor
      · intro y hy; cases hy with
        | head => exact (le_max_right m x).trans (ih (max m x)).1
        | tail _ hy' => exact (ih (max m x)).1 y hy'
      · rcases (ih (max m x)).2 with (h_eq | h_in)
        · rw [h_eq]; simp [max]; split <;> simp [*]
        · exact List.mem_cons_of_mem _ h_in

  let res := List.foldl max 0 L1
  have result_eq : longestIncreasingSubseqLength xs h_precond = res := by
    unfold longestIncreasingSubseqLength; simp [L1, List.foldl_map]

  rw [result_eq]
  constructor
  · apply List.contains_iff.mpr; rw [← h_L12]
    rcases (h_fold L1 0).2 with (h0 | h_in)
    · rw [h0]; apply List.mem_map.mpr; use []; simp [isStrictlyIncreasing, h_mem_sub, List.nil_sublist]
    · exact h_in
  · apply List.all_iff_forall_mem.mpr; intro n hn; rw [← h_L12] at hn; exact (h_fold L1 0).1 n hn
