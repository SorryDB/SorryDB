theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  let result := longestIncreasingSubseqLength xs h_precond
  unfold longestIncreasingSubseqLength_postcond
  simp only [longestIncreasingSubseqLength_precond]
  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  let increasingSubseqLens := allSubseq.filter (fun l => l.Pairwise (· < ·)) |>.map (·.length)
  have h_inc {s : List Int} : isStrictlyIncreasing s = true ↔ s.Pairwise (· < ·) := by
    induction s with
    | nil => simp [isStrictlyIncreasing, List.Pairwise]
    | cons x s ih =>
      cases s with
      | nil => simp [isStrictlyIncreasing, List.Pairwise]
      | cons y s' =>
        simp [isStrictlyIncreasing, List.Pairwise, ih]
        constructor
        · intro h; constructor
          · intro z hz; cases hz with
            | head => exact h.1
            | tail _ hz' => exact Int.lt_trans h.1 ((ih.mp h.2).1 z hz')
          · exact ih.mp h.2
        · intro h; exact ⟨h.1 y (List.mem_cons_self _ _), ih.mpr h.2⟩
  have h_mem_sub (s : List Int) : s ∈ subsequences xs ↔ s.Sublist xs := by
    induction xs generalizing s with
    | nil => simp [subsequences]; constructor <;> (intro h; cases h; rfl)
    | cons x xs ih =>
      simp [subsequences, List.mem_append, List.mem_map]
      constructor
      · rintro (h | ⟨s', hs, rfl⟩)
        · exact List.Sublist.cons x ((ih s).mp h)
        · exact List.Sublist.cons₂ x ((ih s'').mp hs)
      · intro h; cases h with
        | cons h' => left; exact (ih s).mpr h'
        | cons₂ h' => rename_i s'; right; use s'; exact ⟨(ih s').mpr h', rfl⟩
  have h_mem_all (s : List Int) : s ∈ allSubseq ↔ s.Sublist xs := by
    let H := fun l => (l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
    have H_snoc : ∀ l x, H (l ++ [x]) = H l ++ (H l).map (· ++ [x]) := by
      intro l x; simp [H, List.foldl_append, List.map_append, List.map_map, List.reverse_cons]
    change s ∈ H xs ↔ s.Sublist xs
    induction xs using List.reverseRecOn generalizing s with
    | nil => simp [H]; constructor <;> (intro h; cases h; rfl)
    | append_singleton xs x ih =>
      rw [H_snoc, List.mem_append, List.mem_map, ih]
      constructor
      · rintro (h | ⟨s', hs, rfl⟩)
        · exact h.trans (List.sublist_append_left _ _)
        · exact hs.append (List.Sublist.refl _)
      · intro h; rw [List.sublist_append_right_iff] at h
        rcases h with h | ⟨s', hs, rfl⟩
        · left; exact (ih s).mpr h
        · right; use s'; exact ⟨(ih s').mpr hs, rfl⟩
  have h_fold (l : List Nat) (m : Nat) : (∀ x ∈ l, x ≤ l.foldl max m) ∧ (l.foldl max m ∈ m :: l) := by
    induction l generalizing m with
    | nil => simp
    | cons x l ih =>
      simp [List.foldl]; constructor
      · intro y hy; cases hy with
        | head => exact (le_max_right m x).trans (ih (max m x)).1
        | tail _ hy' => exact (ih (max m x)).1 y hy'
      · rcases (ih (max m x)).2 with h | h
        · rw [h]; simp [max]; split <;> simp [*]
        · right; exact h
  let lens1 := (subsequences xs).filter isStrictlyIncreasing |>.map (·.length)
  have res_val : result = lens1.foldl max 0 := by
    unfold result longestIncreasingSubseqLength
    simp [lens1, List.foldl_map]
  have h_lens (n : Nat) : n ∈ lens1 ↔ n ∈ increasingSubseqLens := by
    simp [lens1, increasingSubseqLens, h_inc, h_mem_sub, h_mem_all]
  rw [res_val]
  constructor
  · rw [List.contains_iff, ← h_lens]
    rcases (h_fold lens1 0).2 with h | h
    · rw [h]; simp [lens1, h_inc, h_mem_sub, List.nil_sublist]
    · exact h
  · rw [List.all_iff_forall_mem]; intro n hn; rw [← h_lens] at hn; exact (h_fold lens1 0).1 n hn
