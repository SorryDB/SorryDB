            rw [h_sb] at a_kv_b; simp at a_kv_b
            unfold resultSet; simp [ra]
            apply Set.not_mem_diff_of_mem; simp [eval]
            intro T τ len D equ role_eq sel_eq
            rw [stubbornness _ _ rfl]
            apply true_of_knowldege a_kv_b T τ len.symm equ
