            apply Set.not_mem_diff_of_mem; simp [eval]
            intro T τ len D equ role_eq sel_eq
            rw [stubbornness _ _ rfl]
            rw [eval_dis] at a_kv_b
            cases h_sb : S b <;> rcases a_kv_b with h_kv | h_kv <;> (try have := true_of_knowldege h_kv) <;> simp_all [h_sb, true_of_knowldege h_kv T τ len.symm equ]
      · constructor
        · sorry
        · rw [eval_dis] at a_kv_b
          cases h_sb : S b
