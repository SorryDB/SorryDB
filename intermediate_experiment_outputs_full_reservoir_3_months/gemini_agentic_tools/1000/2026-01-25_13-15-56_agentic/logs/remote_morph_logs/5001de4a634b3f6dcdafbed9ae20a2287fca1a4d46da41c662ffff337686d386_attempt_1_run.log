      constructor
      · apply Real.lt_sqrt_of_sq_lt; norm_num
      · apply Real.sqrt_le_iff.mpr; constructor <;> norm_num
    rw [hc]; norm_num
  have hf4 : f (9 / 2) = 4 := by
    have hn : ¬ Irrational (9 / 2) := by
      exact Rat.not_irrational (9 / 2)
    rw [h₀ (9 / 2) hn]
    norm_num
  rw [hf1, hf2, hf3, hf4]
  norm_num
