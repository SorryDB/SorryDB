import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let p : Polynomial ℝ := Polynomial.C (5 / 4) * (∏ k ∈ Finset.Icc 1 n, (Polynomial.X - Polynomial.C (k : ℝ))) -
    ∑ k ∈ Finset.Icc 1 n, Polynomial.C (k : ℝ) * (∏ j ∈ (Finset.Icc 1 n).erase k, (Polynomial.X - Polynomial.C (j : ℝ)))
  have h_roots_exist : ∃ rs : List ℝ, rs.length = n ∧ (∀ r ∈ rs, Polynomial.IsRoot p r) ∧ rs.Chain' (· < ·) ∧
      (∀ i < n, rs.get ⟨i, by omega⟩ ∈ if i < n - 1 then Set.Ioo (i + 1 : ℝ) (i + 2 : ℝ) else Set.Ioi (n : ℝ)) := sorry
  rcases h_roots_exist with ⟨rs, h_len, h_p_roots, h_sorted, h_bounds⟩
  let l (k : ℕ) : ℝ := k + 1
  let r (k : ℕ) : ℝ := rs.get ⟨k, h_len.symm ▸ k.2⟩
  use l, r, n
  have h_sum_rs : ∑ k ∈ Finset.range n, r k = (9 / 5 : ℝ) * ∑ k ∈ Finset.Icc 1 n, (k : ℝ) := sorry
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro k hk; specialize h_bounds k (h_len ▸ hk); split_ifs at h_bounds <;> simp_all [Set.mem_Ioo, Set.mem_Ioi]; linarith
  · intro k hk; have hk_n : k < n - 1 := hk; specialize h_bounds k (h_len ▸ (by linarith)); specialize h_bounds (k + 1) (h_len ▸ (by linarith))
    split_ifs at h_bounds <;> simp_all [Set.mem_Ioo, Set.mem_Ioi]; linarith
  · rw [Finset.sum_sub_distrib, h_sum_rs]
    have h_sum_l : (∑ k ∈ Finset.range n, l k) = (∑ k ∈ Finset.Icc 1 n, (k : ℝ)) := by
      rw [Finset.sum_range_add_one_eq_sum_Icc]; simp
    rw [h_sum_l]
    have h_sum_id : ∑ k ∈ Finset.Icc 1 70, (k : ℝ) = 2485 := by
      rw [← Finset.sum_nat_cast, Finset.sum_Icc_id]; norm_num
    rw [h_sum_id]; norm_num
  · ext x; rw [h₁]; simp only [Set.mem_setOf_eq, Set.mem_iUnion, Set.mem_Ioc, Finset.mem_range]
    sorry
