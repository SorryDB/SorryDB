import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let f (x : ℝ) := ∑ k in Finset.Icc 1 n, (k : ℝ) / (x - k)
  let P : Polynomial ℝ := Polynomial.C (5 / 4) * (Finset.Icc 1 n).prod (λ k => Polynomial.X - Polynomial.C (k : ℝ)) -
    ∑ k in Finset.Icc 1 n, Polynomial.C (k : ℝ) * (Finset.Icc 1 n).prod (λ j => if j = k then 1 else Polynomial.X - Polynomial.C (j : ℝ))
  have hP_deg : P.degree = n := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_mul, Polynomial.degree_C (by norm_num), zero_add, Polynomial.degree_prod_X_minus_C, Finset.card_Icc, Nat.add_sub_cancel_left]
    · apply (Polynomial.degree_sum_le _ _).trans_lt
      rw [Finset.degree_sum_le_max]
      apply Finset.sup_lt_iff.mpr (by intro k hk; rw [Polynomial.degree_mul, Polynomial.degree_C (by norm_num), zero_add];
        have h_card : (Finset.Icc 1 n).card = n := by rw [Finset.card_Icc]; norm_num
        have : (Finset.Icc 1 n).sum (λ j => if j = k then (0 : WithBot ℕ) else 1) = n - 1 := by
          rw [Finset.sum_ite, Finset.filter_eq', if_pos hk, Finset.card_singleton, Finset.card_Icc]; norm_num
        rw [Polynomial.degree_prod]; simp only [Polynomial.degree_X_minus_C, ite_self, h_card, WithBot.coe_one, Finset.sum_ite];
        rw [Finset.filter_eq', if_pos hk, Finset.card_singleton, Finset.sum_const, Finset.card_erase_of_mem hk, h_card]; simp; norm_num)
  have h_roots_exist : ∃ r : ℕ → ℝ, (∀ k < n, l k < r k) ∧ (∀ k < n - 1, r k < l (k + 1)) ∧
    (∀ x, P.IsRoot x ↔ ∃ k < n, x = r k) := sorry
  rcases h_roots_exist with ⟨r, h_rk1, h_rk2, h_roots⟩
  use (λ k => (k + 1 : ℝ)), r, n
  refine ⟨h_rk1, h_rk2, ?_, ?_⟩
  · have h_vieta : (Finset.range n).sum r = (9 / 5 : ℝ) * (Finset.Icc 1 n).sum (λ k => (k : ℝ)) := sorry
    have h_len_sum : ∑ k in Finset.range n, (r k - (k + 1 : ℝ)) = (4 / 5 : ℝ) * (Finset.Icc 1 n).sum (λ k => (k : ℝ)) := by
      rw [Finset.sum_sub_distrib, h_vieta, ← Finset.sum_range_add_one_eq_sum_Icc, ← Finset.sum_range_add_one_eq_sum_Icc]
      ring
    rw [h_len_sum]
    have : (Finset.Icc 1 70).sum (λ k => (k : ℝ)) = 2485 := by
      simp only [Finset.sum_Icc_id, Nat.cast_id]; norm_num
    rw [this]; norm_num
  · ext x; rw [h₁]; simp only [Set.mem_setOf_eq, Set.mem_iUnion, Set.mem_Ioc, Finset.mem_range]
    refine ⟨?_, ?_⟩
    · intro h; sorry
    · intro h; sorry
