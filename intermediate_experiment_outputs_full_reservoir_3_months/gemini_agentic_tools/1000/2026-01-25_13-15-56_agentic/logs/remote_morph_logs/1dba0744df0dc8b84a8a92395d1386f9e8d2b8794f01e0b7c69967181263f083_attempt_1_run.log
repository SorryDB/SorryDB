import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n : ℕ := 70
  let p : Polynomial ℝ := Polynomial.C (5 / 4) * (∏ k ∈ Finset.Icc 1 n, (Polynomial.X - Polynomial.C (k : ℝ))) -
    ∑ k ∈ Finset.Icc 1 n, Polynomial.C (k : ℝ) * (∏ j ∈ (Finset.Icc 1 n).erase k, (Polynomial.X - Polynomial.C (j : ℝ)))
  have h_rs : ∃ rs : List ℝ, rs.length = n ∧ rs.Chain' (· < ·) ∧ (∀ r_ ∈ rs, p.IsRoot r_) ∧
      (∀ i : Fin n, rs.get ⟨i.1, h_len.symm ▸ i.2⟩ ∈ if i.1 < n - 1 then Set.Ioo (i.1 + 1 : ℝ) (i.1 + 2 : ℝ) else Set.Ioi (n : ℝ)) := sorry
  rcases h_rs with ⟨rs, h_len, h_sorted, h_roots, h_bounds⟩
  let l (k : ℕ) : ℝ := k + 1
  let r (k : ℕ) : ℝ := if h : k < n then rs.get ⟨k, h_len.symm ▸ h⟩ else 0
  use l, r, n
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro k hk
    have h_bound := h_bounds ⟨k, hk⟩
    simp only [l, r, hk, ↓reduceIte] at *
    split_ifs at h_bound <;> simp_all [Set.mem_Ioo, Set.mem_Ioi]
    · linarith
    · linarith
  · intro k hk
    have h_kn : k < n := by linarith
    have h_bound := h_bounds ⟨k, h_kn⟩
    simp only [l, r, h_kn, ↓reduceIte] at *
    simp only [hk, ↓reduceIte] at h_bound
    split_ifs at h_bound <;> simp_all [Set.mem_Ioo, Set.mem_Ioi]
    linarith
  · rw [Finset.sum_sub_distrib]
    have h_sum_l : ∑ k ∈ Finset.range n, l k = 2485 := by
      simp only [l, n, Finset.sum_add_distrib, Finset.sum_const, Finset.card_range, nsmul_eq_mul]
      have : ∑ i ∈ Finset.range 70, (i : ℝ) = 2415 := by
        rw [← Nat.cast_sum, Finset.sum_range_id]
        norm_num
      rw [this]
      norm_num
    have h_sum_r : ∑ k ∈ Finset.range n, r k = 4473 := sorry
    rw [h_sum_r, h_sum_l]
    norm_num
  · ext x; rw [h₁]; simp only [Set.mem_setOf_eq, Set.mem_iUnion, Set.mem_Ioc, Finset.mem_range]
    sorry
