import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n : ℕ := 70
  let l (k : ℕ) : ℝ := k + 1
  have h_roots : ∃ r_root : ℕ → ℝ,
      (∀ k < n - 1, r_root k ∈ Set.Ioo (k + 1 : ℝ) (k + 2 : ℝ)) ∧
      (r_root (n - 1) ∈ Set.Ioi (n : ℝ)) ∧
      (∑ k ∈ Finset.range n, r_root k = 4473) ∧
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r_root k) := sorry
  rcases h_roots with ⟨r_root, h_range, h_last, h_sum_r_root, h_S⟩
  let r (k : ℕ) : ℝ := if k < n then r_root k else 0
  use l, r, n
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro k hk
    simp only [r, hk, ↓reduceIte]
    if h : k < n - 1 then
      specialize h_range k h
      simp only [Set.mem_Ioo] at h_range
      linarith
    else
      have : k = n - 1 := by linarith
      rw [this]
      simp only [Set.mem_Ioi] at h_last
      linarith
  · intro k hk
    have h1 : k < n := by linarith
    have h2 : k < n - 1 := hk
    simp only [r, h1, ↓reduceIte]
    specialize h_range k h2
    simp only [Set.mem_Ioo, l] at h_range
    linarith
  · rw [Finset.sum_sub_distrib]
    have h_sum_l : ∑ k ∈ Finset.range n, l k = 2485 := by
      simp only [l, n, Finset.sum_add_distrib, Finset.sum_range_id, Finset.sum_const, Finset.card_range, nsmul_eq_mul]
      norm_num
    have h_sum_r : ∑ k ∈ Finset.range n, r k = 4473 := by
      rw [← h_sum_r_root]
      apply Finset.sum_congr rfl
      intro k hk; simp only [r, Finset.mem_range] at hk; simp [hk]
    rw [h_sum_r, h_sum_l]
    norm_num
  · ext x; rw [h_S]
    simp only [Set.mem_iUnion, Set.mem_Ioc, Finset.mem_range]
    constructor <;> rintro ⟨k, hk, hx⟩ <;> use k, hk <;> simp only [r, hk, ↓reduceIte] at *; exact hx

