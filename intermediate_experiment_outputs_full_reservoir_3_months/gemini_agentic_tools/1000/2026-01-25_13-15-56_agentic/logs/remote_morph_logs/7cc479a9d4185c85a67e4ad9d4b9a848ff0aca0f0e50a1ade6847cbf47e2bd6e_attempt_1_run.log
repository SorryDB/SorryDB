namespace LessEqThan
/-
template LessEqThan(n) {
    signal input in[2];
    signal output out;

    component lt = LessThan(n);

    lt.in[0] <== in[0];
    lt.in[1] <== in[1]+1;
    lt.out ==> out;
}
-/
def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    have h_p : 2^n < p := by have := hn; linarith [pow_succ' 2 n]
    have heq : ZMod.val ((2 : F p) ^ n) = 2 ^ n := by
      rw [ZMod.val_pow, ZMod.val_ofNat_of_lt (Fact.out : p > 2)]; simp; exact h_p
    simp only [circuit_norm, LessThan.main, Num2Bits.circuit, Prod.mk.injEq] at h_holds ⊢
    rcases assumptions with ⟨hx, hy⟩
    have h3 : ZMod.val (y + 1) = ZMod.val y + 1 := by
      rw [ZMod.val_add_of_lt]; simp [ZMod.val_one]; linarith
    have h_in_lt : ZMod.val (x + (2 : F p) ^ n - (y + 1)) < 2 ^ (n + 1) := by
      rw [ZMod.val_sub, ZMod.val_add_of_lt, heq, h3]; omega
      · rw [heq]; linarith
      · rw [heq, h3]; linarith
      · rw [heq, h3]; linarith
    specialize h_holds h_in_lt
    rcases h_holds with ⟨h_bits, h_out⟩
    rw [h_out, h_bits, fieldToBits, toBits]
    have h_val : ZMod.val (x + (2 : F p) ^ n - (y + 1)) = ZMod.val x + 2 ^ n - (ZMod.val y + 1) := by
      rw [ZMod.val_sub, ZMod.val_add_of_lt, heq, h3]
      · rw [heq]; linarith
      · rw [heq, h3]; linarith
      · rw [heq, h3]; linarith
    rw [h_val]
    split_ifs with hle
    · have : ZMod.val x + 2 ^ n - (ZMod.val y + 1) < 2 ^ n := by omega
      simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one,
        Nat.cast_zero, Nat.testBit_eq_false_of_lt this, ↓reduceIte, neg_zero, add_zero]
    · have hge : 2 ^ n ≤ ZMod.val x + 2 ^ n - (ZMod.val y + 1) := by omega
      have hlt : ZMod.val x + 2 ^ n - (ZMod.val y + 1) < 2 ^ (n + 1) := by omega
      rw [Nat.testBit, Nat.shiftRight_eq_div_pow, Nat.div_eq_of_lt_le hlt hge]
      simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one,
        Nat.cast_zero, ↓reduceIte, neg_one, add_neg_cancel]

  completeness := by
    circuit_proof_start
    simp only [circuit_norm, LessThan.main, Num2Bits.circuit] at *
    refine ⟨?_, rfl⟩
    have h_p : 2^n < p := by have := hn; linarith [pow_succ' 2 n]
    have heq : ZMod.val ((2 : F p) ^ n) = 2 ^ n := by
      rw [ZMod.val_pow, ZMod.val_ofNat_of_lt (Fact.out : p > 2)]; simp; exact h_p
    have h3 : ZMod.val (input.2 + 1) = ZMod.val input.2 + 1 := by
      rw [ZMod.val_add_of_lt]; simp [ZMod.val_one]; rcases h_assumptions; linarith
    rw [ZMod.val_sub, ZMod.val_add_of_lt, heq, h3]
    · rcases h_assumptions; omega
    · rw [heq]; linarith
    · rw [heq, h3]; linarith
    · rw [heq, h3]; linarith

end LessEqThan
