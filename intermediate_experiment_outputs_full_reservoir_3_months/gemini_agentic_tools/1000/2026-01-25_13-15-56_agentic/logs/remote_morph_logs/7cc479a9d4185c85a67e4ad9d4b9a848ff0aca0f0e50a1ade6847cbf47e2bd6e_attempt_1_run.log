def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    circuit_proof_start
    simp only [circuit_norm, LessThan.main, Num2Bits.circuit] at h_holds ⊢
    rcases h_assumptions with ⟨hx, hy⟩
    rcases h_holds with ⟨⟨h_val_lt, h_bits⟩, h_out⟩
    have hp : 2^n < p := lt_of_le_of_lt (by gcongr; decide) hn
    have h2n : ZMod.val ((2 : F p)^n) = 2^n := by
      rw [ZMod.val_pow, ZMod.val_ofNat_of_lt (Fact.out : 2 < p)]; simp; exact hp
    have hy1 : ZMod.val (input.2 + 1) = ZMod.val input.2 + 1 := by
      rw [ZMod.val_add_of_lt]; simp [ZMod.val_one]; linarith
    have h_val : ZMod.val (input.1 + (2 : F p)^n - (input.2 + 1)) = ZMod.val input.1 + 2^n - (ZMod.val input.2 + 1) := by
      rw [ZMod.val_sub] <;> (rw [ZMod.val_add_of_lt, h2n, hy1] <;> [omega; (have := pow_succ 2 n; linarith)])
    rw [h_out, ← congrArg (·[n]) h_bits, h_val]
    simp [fieldToBits, toBits]
    split_ifs with hle <;>
    · have h_lt2 : ZMod.val input.1 + 2^n - (ZMod.val input.2 + 1) < 2^(n + 1) := by (have := pow_succ 2 n; omega)
      if h : ZMod.val input.1 + 2^n - (ZMod.val input.2 + 1) < 2^n then
