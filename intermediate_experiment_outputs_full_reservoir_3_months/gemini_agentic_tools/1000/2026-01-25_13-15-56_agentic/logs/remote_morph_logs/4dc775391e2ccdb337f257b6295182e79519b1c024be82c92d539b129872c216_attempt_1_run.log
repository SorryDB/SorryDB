import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  set n := S.card
  have hn : n = #S := rfl
  if h0 : n = 0 then
    rw [hn] at h0; exact ⟨(j : Fin 0).elim0, λ j => j.elim0⟩
  haveI : NeZero n := ⟨h0⟩
  let R (a b : S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
  have hR_symm : ∀ {a b}, R a b ↔ R b a := fun {a b} => by
    simp [R, mul_comm]
  have h_deg : ∀ a : S, (Finset.univ.filter (R a)).card ≤ 2 := sorry
  let f := p₂.trans p₁.symm
  have hf_R : ∀ j, R (p₂ j) (p₂ (j + 1)) := hp₂
  have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
    intro j
    have : R (p₁ (f j)) (p₁ (f (j + 1))) := by
      rw [p₁.apply_symm_apply, p₁.apply_symm_apply]; exact hf_R j
    if h2 : n ≤ 2 then
      if h1 : n = 1 then
        subst h1; fin_cases j; left; rfl
      else
        have : n = 2 := by linarith
        have : f (j + 1) ≠ f j := f.injective.ne (by simp [this])
        clear h_deg hS hp₁ hp₂ hR_symm hk; revert this j; subst this; intro j; fin_cases j <;> intro h <;> fin_cases (f 0) <;> fin_cases (f 1) <;> (try contradiction) <;> simp <;> rfl
    else
      have hgt2 : n > 2 := by linarith
      have h_neighbors : Finset.univ.filter (R (p₁ (f j))) = {p₁ (f j - 1), p₁ (f j + 1)} := by
        refine Finset.eq_of_subset_of_card_le (fun x hx => ?_) ?_
        · simp at hx; rcases hx with rfl | rfl
          · rw [hR_symm]; exact hp₁ (f j - 1)
          · exact hp₁ (f j)
        · rw [Finset.card_pair]
          · exact h_deg (p₁ (f j))
          · intro h; rw [p₁.injective.eq_iff] at h
            have : (2 : Fin n) = 0 := by rw [← h]; ring
            have : n ∣ 2 := (Fin.val_eq_zero.mp this).trans (by rfl)
            linarith
      have : p₁ (f (j + 1)) ∈ Finset.univ.filter (R (p₁ (f j))) := by simp [this]
      rw [h_neighbors] at this; simp at this
      rcases this with h | h <;> rw [p₁.injective.eq_iff] at h
      · right; exact h
      · left; exact h
  have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
    if h2 : n ≤ 2 then
      if h1 : n = 1 then left; intro j; fin_cases j; rfl
      else
        have : n = 2 := by linarith
        left; intro j; subst this; fin_cases j <;> have := f.injective.ne (by simp : (1 : Fin 2) ≠ 0) <;> fin_cases (f 0) <;> fin_cases (f 1) <;> (try contradiction) <;> rfl
    else
      by_contra h; push_neg at h
      rcases h with ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩
      have : ∃ j, f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1 := by
        let S_rot := {j : Fin n | f (j + 1) = f j + 1}
        have hS_rot : S_rot.Nonempty := ⟨j1, hj1⟩
        have hS_rot_c : S_rotᶜ.Nonempty := ⟨j2, hj2⟩
        rcases Fin.exists_next_mem_compl hS_rot hS_rot_c with ⟨j, hj, hj_next⟩
        use j; simp [S_rot] at hj hj_next
        exact ⟨hj, (hf_step (j + 1)).resolve_left hj_next⟩
      rcases this with ⟨j, h1, h2⟩
      have : f (j + 2) = f j := by rw [h2, h1]; simp
      have : (j + 2 : Fin n) = j := f.injective this
      have : (2 : Fin n) = 0 := by rw [← this]; ring
      have : n ∣ 2 := (Fin.val_eq_zero.mp this).trans (by rfl)
      linarith
  rcases hf_const with h_rot | h_rev
  · left; use f 0; intro j
    have : f j = j + f 0 := by
      induction j using Fin.induction with
      | zero => simp
      | succ j ih => rw [h_rot, ih]; ring
    rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
  · right; use f 0 + 1; intro j
    have : f j = f 0 - j := by
      induction j using Fin.induction with
      | zero => simp
      | succ j ih => rw [h_rev, ih]; simp; ring
    rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
    congr; simp [Fin.rev]; ring
