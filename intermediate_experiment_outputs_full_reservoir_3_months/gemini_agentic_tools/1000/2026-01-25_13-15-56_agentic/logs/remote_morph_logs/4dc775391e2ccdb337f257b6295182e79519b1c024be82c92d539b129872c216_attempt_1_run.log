import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  set n := #S
  if hn : n = 0 then
    sorry
  else
    haveI : NeZero n := ⟨hn⟩
    let R := fun (a b : S) => ∃ x > 0, (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
    let f := p₁.symm.trans p₂
    have h_neighbors1 : ∀ i : Fin n, {b ∈ S | R (p₁ i) b} = {p₁ (i - 1), p₁ (i + 1)} := sorry
    have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
      intro j
      have : p₂ (j + 1) ∈ S.filter (R (p₂ j)) := by simp [R, hp₂ j]
      have hf : f (j + 1) ∈ ({f j - 1, f j + 1} : Finset (Fin n)) := by
        simpa [f, h_neighbors1 (f j)] using this
      simpa using hf
    if h_rot_sign : ∀ j, f (j + 1) = f j + 1 then
      left; use f 0; intro j
      have : f j = j + f 0 := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h_rot_sign, ih]; ring
      simp [f, Equiv.trans_apply, Equiv.symm_apply_eq, this]
    else
      have h_rev_sign : ∀ j, f (j + 1) = f j - 1 := sorry
      right; use f 0 + 1; intro j
      have : f j = f 0 - j := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h_rev_sign, ih]; simp; ring
      simp [f, Equiv.trans_apply, Equiv.symm_apply_eq, Fin.rev]
      rw [this]; ring

