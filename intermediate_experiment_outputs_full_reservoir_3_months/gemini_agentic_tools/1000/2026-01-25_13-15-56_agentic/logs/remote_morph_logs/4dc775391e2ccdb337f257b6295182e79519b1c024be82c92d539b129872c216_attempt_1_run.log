import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  if hn0 : n = 0 then
    subst n; exact False.elim (S.card_pos.mp (by omega) |> S.nonempty_of_ne_empty |> (fun ⟨x, hx⟩ => (p₁.symm ⟨x, hx⟩).elim0))
  else
    haveI : NeZero n := ⟨hn0⟩
    let f := p₂.trans p₁.symm
    have hf_p2 : ∀ j, p₂ j = p₁ (f j) := by simp [f]
    let R (a b : ↥S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
    have hR₁ : ∀ i, R (p₁ i) (p₁ (i + 1)) := fun i => hp₁ i
    have hR₂ : ∀ j, R (p₂ j) (p₂ (j + 1)) := fun j => hp₂ j
    have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
      intro j
      have hRf : R (p₁ (f j)) (p₁ (f (j + 1))) := by simpa [hf_p2] using hR₂ j
      have h_deg : ∀ {a b c d : ↥S}, R a b → R a c → R a d → b = c ∨ b = d ∨ c = d := sorry
      have := h_deg hRf (hR₁ (f j)) (by have := hR₁ (f j - 1); rwa [Fin.sub_add_cancel] at this)
      simpa [EmbeddingLike.apply_eq_iff_eq] using this
    have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
      if h_n : n ≤ 2 then
        cases' n with n <;> try omega
        cases' n with n <;> try omega
        · left; intro j; fin_cases j; rfl
        · left; intro j; fin_cases j <;> (have h_inj := f.injective.ne (by omega); fin_cases (f 0) <;> fin_cases (f 1) <;> try contradiction <;> rfl)
      else
        by_contra! h; obtain ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩ := h
        have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                    (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
        rcases this with ⟨j, ⟨h1, h2⟩ | ⟨h1, h2⟩⟩ <;>
        (have : f (j + 2) = f j := by rw [h2, h1]; simp; have : j + 2 = j := f.injective this;
         have : (2 : Fin n) = 0 := by rw [← this]; ring;
         have : n ∣ 2 := by have := Fin.val_eq_zero.1 this; rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at this; exact this; omega)
    rcases hf_const with h_rot | h_rev
    · left; use f 0; intro j
      have : f j = j + f 0 := by
        cases' n with n'; · omega
        induction j using Fin.induction with | zero => simp | succ j ih => rw [h_rot, ih]; ring
      rw [hf_p2, this]
    · right; use f 0 + 1; intro j
      have : f j = f 0 - j := by
        cases' n with n'; · omega
        induction j using Fin.induction with | zero => simp | succ j ih => rw [h_rev, ih]; simp; ring
      rw [hf_p2, this]; congr; simp [Fin.rev]; ring
