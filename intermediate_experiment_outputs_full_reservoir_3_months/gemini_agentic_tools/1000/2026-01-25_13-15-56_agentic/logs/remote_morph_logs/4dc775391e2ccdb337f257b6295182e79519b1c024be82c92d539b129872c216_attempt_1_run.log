  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  if hn : n = 0 then
    left; use 0; intro j; exact j.elim0
  else
    haveI : NeZero n := ⟨hn⟩
    let R (a b : ℕ) : Prop := ∃ x : ℕ, 0 < x ∧ a * b = x ^ 2 + x + k
    let f := p₂.trans p₁.symm
    have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
      intro j
      have hR : R (p₁ (f j)) (p₁ (f (j + 1))) := by
        have h1 : p₂ j = p₁ (f j) := by simp [f]
        have h2 : p₂ (j + 1) = p₁ (f (j + 1)) := by simp [f]
        rw [← h1, ← h2]
        exact hp₂ j
      have h_p1_neighbors : (S.filter (R (p₁ (f j)))) = {p₁ (f j - 1), p₁ (f j + 1)} := sorry
      have : p₁ (f (j + 1)) ∈ S.filter (R (p₁ (f j))) := by
        simp; exact ⟨(p₁ (f (j + 1))).2, hR⟩
      rw [h_p1_neighbors] at this
      simp at this
      rcases this with h | h <;> [right, left] <;> exact Equiv.injective p₁ h
    have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
      if hn2 : n ≤ 2 then
        if hn1 : n = 1 then left; intro j; fin_cases j; rfl
        else
          have h2 : n = 2 := by omega
          left; intro j; subst h2; fin_cases j <;> (have : f 1 ≠ f 0 := f.injective.ne (by decide); fin_cases (f 0) <;> fin_cases (f 1) <;> (try contradiction) <;> rfl)
      else
        by_contra h; push_neg at h
        rcases h with ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩
        have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                    (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
        rcases this with ⟨j, ⟨h1, h2⟩ | ⟨h1, h2⟩⟩
        all_goals
          have : f (j + 2) = f j := by rw [h2, h1]; simp
          have hf : j + 2 = j := f.injective this
          have : n ∣ 2 := sorry
          omega
    rcases hf_const with h_rot | h_rev
    · left; use f 0; intro j
      have : f j = j + f 0 := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h_rot j, ih]; simp; ring
      rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
    · right; use f 0 + 1; intro j
      have : f j = f 0 - j := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h_rev j, ih]; simp; ring
      rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
      congr; simp [Fin.rev]; ring

