import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  if hn : n = 0 then
    subst hn
    exact (j : Fin 0).elim0
  else
    haveI : NeZero n := ⟨hn⟩
    let R := fun (a b : S) => ∃ x > 0, (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
    have hR₁ : ∀ i, R (p₁ i) (p₁ (i + 1)) := hp₁
    have hR₂ : ∀ i, R (p₂ i) (p₂ (i + 1)) := hp₂
    have h_deg : ∀ a : S, (Finset.univ.filter (R a)).card ≤ 2 := sorry
    have h_neighbors1 : ∀ i, (Finset.univ.filter (R (p₁ i))) = {p₁ (i - 1), p₁ (i + 1)} := by
      intro i
      have h1 : p₁ (i - 1) ∈ Finset.univ.filter (R (p₁ i)) := by
        simp [R]; rw [mul_comm, ← (i - 1).succ_is_correct]; exact hp₁ (i - 1)
      have h2 : p₁ (i + 1) ∈ Finset.univ.filter (R (p₁ i)) := by
        simp [R]; exact hp₁ i
      if hn2 : n ≤ 2 then
        simp [n] at hn2
        interval_cases n <;> aesop
      else
        have h12 : p₁ (i - 1) ≠ p₁ (i + 1) := by
          intro h; exact hn2 (by simpa [sub_eq_add_neg, add_left_inj, (Fin.ext_iff).1 h] using (2 : ℕ))
        refine Finset.eq_of_subset_of_card_le (by simp [h1, h2]) ?_
        rw [Finset.card_pair h12]; exact h_deg (p₁ i)
    let f := p₁.symm.trans p₂
    have h_f_neighbors : ∀ j, f (j + 1) = f j + 1 ∨ f j (j + 1) = f j - 1 := by
      intro j
      have : p₂ (j + 1) ∈ Finset.univ.filter (R (p₂ j)) := by simp [R, hp₂ j]
      have hf : p₁ (f (j + 1)) ∈ Finset.univ.filter (R (p₁ (f j))) := by
        simpa [f, Equiv.trans_apply, Equiv.symm_apply_apply] using this
      rw [h_neighbors1 (f j)] at hf
      simp at hf; cases hf <;> aesop
    if h_rot : ∀ j, f (j + 1) = f j + 1 then
      left; use f 0; intro j
      have : f j = j + f 0 := by
        induction j using Fin.induction with | zero => simp | succ j ih => rw [h_rot j, ih, add_right_comm]; rfl
      simp [f, Equiv.trans_apply] at this; rw [← this, Equiv.apply_symm_apply]
    else
      right; use f 0 + 1; intro j
      have : f j = f 0 - j := sorry
      simp [f, Equiv.trans_apply] at this; rw [← this, Equiv.apply_symm_apply]
      simp [Fin.rev]; congr; rw [sub_eq_add_neg, add_comm]; rfl
