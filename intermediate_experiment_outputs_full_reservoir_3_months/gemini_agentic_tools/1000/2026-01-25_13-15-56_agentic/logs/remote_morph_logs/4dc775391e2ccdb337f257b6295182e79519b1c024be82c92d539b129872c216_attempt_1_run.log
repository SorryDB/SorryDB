Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  rcases n.eq_zero_or_pos with rfl | hn_pos
  · sorry
  · haveI : NeZero n := ⟨hn_pos.ne'⟩
    let f := p₂.trans p₁.symm
    have hf_p2 : ∀ j, p₂ j = p₁ (f j) := by simp [f]
    have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := sorry
    if hn2 : n ≤ 2 then
      left; use f 0; intro j
      cases' n with n <;> try omega
      cases' n with n <;> try omega
      · have : j = 0 := by ext; omega
        subst this; simp
      · have : j = 0 ∨ j = 1 := by ext; omega
        rcases this with rfl | rfl
        · simp
        · have h_inj : f 1 ≠ f 0 := f.injective.ne (by omega)
          fin_cases (f 0) <;> fin_cases (f 1) <;> contradiction <;> (simp; ring)
    else
      have h_sign : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
        by_contra! h; obtain ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩ := h
        have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                    (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
        rcases this with ⟨j, ⟨h1, h2⟩ | ⟨h1, h2⟩⟩ <;>
        (have hf : f (j + 2) = f j := by rw [h2, h1]; simp;
         have hj : j + 2 = j := f.injective hf;
         have h_n2 : (2 : Fin n) = 0 := by rw [← hj]; ring;
         have : n ∣ 2 := by
           have h0 := Fin.val_eq_zero.1 h_n2; rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at h0; exact h0
         omega)
      rcases h_sign with h_rot | h_rev
      · left; use f 0; intro j
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h_rot, ih]; ring
      · right; use f 0 + 1; intro j
        induction j using Fin.induction with
        | zero => simp [Fin.rev]; ring
        | succ j ih => rw [h_rev, ih]; simp [Fin.rev]; ring

