import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  set n := S.card
  let R (a b : S) : Prop := ∃ x, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
  have hR_symm : ∀ {a b}, R a b ↔ R b a := fun {a b} => by
    simp only [R]; constructor <;> rintro ⟨x, hx, h⟩ <;> use x, hx <;> rwa [mul_comm]
  have h_deg : ∀ a : S, (Finset.univ.filter (R a)).card ≤ 2 := sorry
  cases n_eq : n with
  | zero => left; use 0; intro j; rw [n_eq] at j; exact j.elim0
  | succ n1 =>
    haveI : NeZero n := ⟨by rw [n_eq]; exact Nat.succ_ne_zero n1⟩
    let f := p₁.symm.trans p₂
    have hf_R : ∀ j, R (p₂ j) (p₂ (j + 1)) := hp₂
    if hn_le2 : n ≤ 2 then
      left; use f 0; intro j
      if hn_eq1 : n = 1 then fin_cases j; rfl
      else
        have hn_eq2 : n = 2 := by
          have : n ≠ 0 := by rw [n_eq]; exact Nat.succ_ne_zero n1
          linarith [this, hn_le2]
        have hf1 : f 1 = f 0 + 1 := by
          have : f 1 ≠ f 0 := f.injective.ne (by decide)
          fin_cases (f 0) <;> fin_cases (f 1) <;> simp at * <;> try contradiction <;> rfl
        fin_cases j <;> simp [f, hf1]
    else
      have hn_gt2 : n > 2 := by linarith
      have h_p1_neighbors : ∀ i : Fin n, Finset.univ.filter (R (p₁ i)) = {p₁ (i - 1), p₁ (i + 1)} := by
        intro i; apply Finset.eq_of_subset_of_card_le
        · intro x hx; simp at hx; rcases hx with hx | hx <;> rw [hx]
          · rw [hR_symm]; exact hp₁ (i - 1)
          · exact hp₁ i
        · rw [Finset.card_pair]
          · exact h_deg (p₁ i)
          · intro h; rw [p₁.injective.eq_iff] at h
            have : (2 : Fin n) = 0 := by rw [← h]; ring
            have : n ∣ 2 := (Fin.val_eq_zero.mp this).trans (by rfl)
            linarith
      have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
        intro j; have : p₁ (f (j + 1)) ∈ Finset.univ.filter (R (p₁ (f j))) := by
          simp [f, hf_R]
        rw [h_p1_neighbors (f j)] at this; simp at this
        rcases this with h | h <;> rw [p₁.injective.eq_iff] at h <;> [right; left] <;> exact h
      have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
        by_contra' h_not; rcases h_not with ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩
        have h_sw : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                        (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
        rcases h_sw with ⟨j, ⟨h1, h2⟩ | ⟨h1, h2⟩⟩
        all_goals
          have : f (j + 2) = f j := by rw [h2, h1]; simp
          have : (j + 2 : Fin n) = j := f.injective this
          have : (2 : Fin n) = 0 := by rw [← this]; ring
          have : n ∣ 2 := (Fin.val_eq_zero.mp this).trans (by rfl)
          linarith
      rcases hf_const with h_rot | h_rev
      · left; use f 0; intro j
        have : f j = j + f 0 := by
          induction j using Fin.induction with
          | zero => simp
          | succ j ih => rw [h_rot, ih]; ring
        simp [f, Equiv.trans_apply, Equiv.symm_apply_eq, this]
      · right; use f 0 + 1; intro j
        have : f j = f 0 - j := by
          induction j using Fin.induction with
          | zero => simp
          | succ j ih => rw [h_rev, ih]; simp; ring
        simp [f, Equiv.trans_apply, Equiv.symm_apply_eq, Fin.rev, this]; ring
