import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  have hn_pos : n > 0 := by
    by_contra h; have h0 : n = 0 := Nat.eq_zero_of_nonpos (le_of_not_gt h)
    have : S = ∅ := Finset.card_eq_zero.mp h0
    subst this; exact (p₁.symm ⟨p₁ 0, (p₁ 0).2⟩).elim0
  haveI : NeZero n := ⟨hn_pos.ne'⟩
  let f := p₂.trans p₁.symm
  have hf_p2 : ∀ j, p₂ j = p₁ (f j) := by simp [f]
  let R (a b : ↥S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
  have hR₁ : ∀ i, R (p₁ i) (p₁ (i + 1)) := hp₁
  have hR₂ : ∀ j, R (p₂ j) (p₂ (j + 1)) := hp₂
  have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := sorry
  have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
    if h_n : n ≤ 2 then
      if h1 : n = 1 then left; intro j; fin_cases j; rfl
      else
        have h2 : n = 2 := by omega
        left; intro j; revert j; rw [h2]; intro j; fin_cases j <;>
        (have hi := f.injective.ne (by omega : (0 : Fin 2) ≠ 1);
         match f 0, f 1 with | 0, 1 => rfl | 1, 0 => rfl)
    else
      by_contra! h; obtain ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩ := h
      have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                  (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
      rcases this with ⟨j, ⟨ha, hb⟩ | ⟨ha, hb⟩⟩ <;>
      (have : f (j + 2) = f j := by rw [hb, ha]; simp;
       have : j + 2 = j := f.injective this;
       have : (2 : Fin n) = 0 := by rw [← this]; ring;
       have h0 := Fin.val_eq_zero.mp this;
       rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at h0;
       have : n ∣ 2 := h0; omega)
  rcases n.exists_eq_succ with ⟨m, rfl⟩
  rcases hf_const with h_rot | h_rev
  · left; use f 0; intro j
    have : f j = j + f 0 := by
      induction j using Fin.induction with
      | zero => simp
      | succ j ih => rw [h_rot, ih]; ring
    rw [hf_p2, this]
  · right; use f 0 + 1; intro j
    have : f j = f 0 - j := by
      induction j using Fin.induction with
      | zero => simp
      | succ j ih => rw [h_rev, ih]; simp; ring
    rw [hf_p2, this]; congr; simp [Fin.rev]; ring

