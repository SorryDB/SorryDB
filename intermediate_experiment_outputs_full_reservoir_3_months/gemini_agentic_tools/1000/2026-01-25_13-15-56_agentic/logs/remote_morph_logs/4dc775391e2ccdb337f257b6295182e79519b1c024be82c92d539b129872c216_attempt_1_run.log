  set n := #S
  have hn_pos : 0 < n := by
    by_contra hn; simp at hn; subst hn
    have := p₁.surjective (S.min.get (Finset.nonempty_of_ne_empty (by
      intro h; subst h; simp at hk -- Vacuous in context of IMO, primes set is not empty
      sorry)))
    rcases this with ⟨i, hi⟩; exact i.elim0
  haveI : NeZero n := ⟨hn_pos.ne'⟩
  let R (a b : S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x^2 + x + k
  have hR_symm : ∀ {a b}, R a b ↔ R b a := fun {a b} =>
    ⟨fun ⟨x, hx, h⟩ => ⟨x, hx, by rw [mul_comm, h]⟩, fun ⟨x, hx, h⟩ => ⟨x, hx, by rw [mul_comm, h]⟩⟩
  have h_deg : ∀ a, (Finset.univ.filter (R a)).card ≤ 2 := by
    intro a; set c := 1 - 4 * (k : ℤ)
    have h_sq : ∀ {b}, R a b → ∃ y : ℕ, y^2 = 4 * (a * b : ℤ) + c ∧ y > 1 := by
      rintro b ⟨x, hx, hxb⟩
      use 2 * x + 1; constructor
      · zify [hxb]; ring
      · exact (Nat.succ_le_iff.mpr hx).trans_lt (by linarith)
    by_contra h_card; simp at h_card; obtain ⟨b1, hb1, b2, hb2, b3, hb3, h12, h23, h13⟩ := h_card
    obtain ⟨y1, hy1, _⟩ := h_sq (Finset.mem_filter.mp hb1).2
    obtain ⟨y2, hy2, _⟩ := h_sq (Finset.mem_filter.mp hb2).2
    obtain ⟨y3, hy3, _⟩ := h_sq (Finset.mem_filter.mp hb3).2
    have : ∀ {yi yj}, yi^2 ≡ yj^2 [ZMOD a] := fun {yi yj} => by
      have hi : yi^2 = 4*a*(_:ℤ) + c := by assumption'
      have hj : yj^2 = 4*a*(_:ℤ) + c := by assumption'
      rw [hi, hj]; exact Int.ModEq.add_right c (Int.ModEq.mul_left 4 Int.modEq_zero)
    -- By properties of primes and quadratics, this implies y1 ≡ ±y2 ≡ ±y3 mod a, forcing two to be same or large.
    -- Shortlist N3 proof continues here with a descent or bound.
    sorry
  have h_neighbors : ∀ i, (Finset.univ.filter (R (p₁ i))) = {p₁ (i - 1), p₁ (i + 1)} := by
    intro i; refine Finset.eq_of_subset_of_card_le (fun x hx => ?_) (h_deg (p₁ i))
    simp at hx; rcases hx with rfl|rfl
    · simp [R, mul_comm]; rw [← (i-1).succ_is_correct]; exact hp₁ (i - 1)
    · simp [R]; exact hp₁ i
  let f := p₁.symm.trans p₂
  have hf_step : ∀ i, f (i + 1) = f i + 1 ∨ f (i + 1) = f i - 1 := by
    intro i; have h : p₂ (i + 1) ∈ Finset.univ.filter (R (p₂ i)) := by simp [R, hp₂ i]
    have hf : f (i + 1) ∈ {f i - 1, f i + 1} := by
      simpa [f, h_neighbors (f i)] using h
    simpa using hf
  if h_rot : f 1 = f 0 + 1 then
    left; use f 0; intro j; induction j using Fin.induction with
    | zero => simp [f]
    | succ j ih =>
      have : f (j + 1) = f j + 1 := by
        cases hf_step j with | h1 => exact h1 | h2 =>
        by_contra; have : f (j + 1) = f j - 1 := h2
        if hj : j = 0 then rw [hj, h_rot] at this; simp at this; exact (by linarith)
        else sorry -- Standard cycle argument: bijection sign is constant
      rw [this, ih]; ring
  else
    right; use f 0 + 1; intro j
    sorry -- Symmetrical case for reflection
