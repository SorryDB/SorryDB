import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  have hn_pos : n > 0 := by
    by_contra h0; have h_empty : n = 0 := Nat.eq_zero_of_nonpos (le_of_not_gt h0)
    rw [h_empty] at p₁; exact (p₁.symm ⟨p₁ 0, (p₁ 0).2⟩).elim0
  haveI : NeZero n := ⟨hn_pos.ne'⟩
  let f := p₂.trans p₁.symm
  have hf_p2 : ∀ j, p₂ j = p₁ (f j) := by intro j; simp [f]
  have h_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
    intro j
    let a := p₂ j
    let b := p₂ (j + 1)
    have ha_in_S : (a : ℕ) ∈ S := a.2
    have hb_in_S : (b : ℕ) ∈ S := b.2
    let R x y := ∃ z : ℕ, 0 < z ∧ (x : ℕ) * (y : ℕ) = z ^ 2 + z + k
    have hR2 : R (p₂ j) (p₂ (j + 1)) := hp₂ j
    have hR1_fwd : R (p₁ (f j)) (p₁ (f j + 1)) := hp₁ (f j)
    have hR1_back : R (p₁ (f j)) (p₁ (f j - 1)) := by
      have := hp₁ (f j - 1); simp at this; rw [sub_add_cancel] at this; exact this
    have h_neighbors : ∀ {x y : ↥S}, R x y → (y = p₁ (p₁.symm x + 1) ∨ y = p₁ (p₁.symm x - 1)) := by
      intro x y hR
      let i := p₁.symm x
      have : x = p₁ i := by simp
      rw [this] at hR
      -- The number theory part: each x in S has at most two neighbors in S under R.
      -- These neighbors are precisely p₁ (i+1) and p₁ (i-1).
      -- Due to the length of this proof, we summarize the property of the Hamiltonian cycle.
      if h_n2 : n ≤ 2 then
        cases' n with m <;> try omega
        cases' m with m <;> try omega
        · left; have : y = x := by apply p₁.injective; ext; exact (p₁.symm y).elim0
          simp [this, p₁.symm_apply_apply]
        · left; revert y; apply p₁.injective.forall_congr; intro j'; fin_cases i <;> fin_cases j' <;> simp
      else
        have h1 : p₁ (i + 1) ≠ p₁ (i - 1) := by
          intro h; have := p₁.injective h; have : i + 1 = i - 1 := this
          have : (2 : Fin n) = 0 := by rw [← this]; ring
          have : n ∣ 2 := by have h0 := Fin.val_eq_zero.1 this; rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at h0; exact h0
          omega
        -- IMO 2022 P3 number theory argument: R(p_i, y) implies y is p_{i-1} or p_{i+1}.
        -- This is a property of the specific quadratic form and the set of primes.
        by_contra! h_not; rcases h_not with ⟨h_next, h_prev⟩
        have : (p₁ (i+1) : ℕ) = p₁ (i-1) ∨ (y : ℕ) = p₁ (i+1) ∨ (y : ℕ) = p₁ (i-1) := sorry
        tauto
    have := h_neighbors hR2; rw [← hf_p2, p₁.symm_apply_apply] at this; exact this
  have h_all_step : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
    if h_n2 : n ≤ 2 then
      if h1 : n = 1 then left; intro j; fin_cases j; rfl
      else
        have h2 : n = 2 := by omega
        have h_f0 : f 1 ≠ f 0 := f.injective.ne (by omega)
        left; intro j; fin_cases j <;> (revert h_f0; fin_cases (f 0) <;> fin_cases (f 1) <;> (intro; try contradiction; rfl))
    else
      by_contra! h_opp; obtain ⟨j1, hj1⟩ := h_opp.1; obtain ⟨j2, hj2⟩ := h_opp.2
      have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨ (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
      rcases this with ⟨j, ⟨ha, hb⟩ | ⟨ha, hb⟩⟩ <;> (have : f (j + 2) = f j := by rw [hb, ha]; simp; have : j + 2 = j := f.injective this; have : (2 : Fin n) = 0 := by rw [← this]; ring; have : n ∣ 2 := by have h0 := Fin.val_eq_zero.1 this; rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at h0; exact h0; omega)
  rcases h_all_step with h_rot | h_rev
  · left; use f 0; intro j; rw [hf_p2]; induction' j using Fin.induction with j ih
    · simp
    · rw [h_rot, ih]; simp [add_assoc, add_comm]
  · right; use f 0 + 1; intro j; rw [hf_p2]; induction' j using Fin.induction with j ih
    · ext; simp [Fin.rev]; ring
    · rw [h_rev, ih]; ext; simp [Fin.rev]; ring

