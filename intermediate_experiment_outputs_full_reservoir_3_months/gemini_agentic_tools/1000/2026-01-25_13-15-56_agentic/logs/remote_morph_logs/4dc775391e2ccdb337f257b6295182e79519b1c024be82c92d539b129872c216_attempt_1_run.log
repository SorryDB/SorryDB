import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  set n := #S
  if h_n0 : n = 0 then
    -- As S is a finite set of odd prime numbers and adjacent products match x^2+x+k,
    -- #S cannot be zero in any configuration that satisfies the condition.
    sorry
  else
    haveI : NeZero n := ⟨h_n0⟩
    let R (a b : S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
    let f := p₂.trans p₁.symm
    have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
      intro j
      have hR : R (p₂ j) (p₂ (j + 1)) := hp₂ j
      have : R (p₁ (f j)) (p₁ (f (j + 1))) := by
        rw [p₁.apply_symm_apply, p₁.apply_symm_apply]; exact hR
      -- The degree of any vertex in the graph (S, R) is at most 2.
      -- Thus the neighbors of p₁(f j) must be p₁(f j - 1) and p₁(f j + 1).
      have : f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := sorry
      exact this
    have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
      if h_nle2 : n ≤ 2 then
        if h_n1 : n = 1 then
          left; intro j; fin_cases j; rfl
        else
          have h_n2 : n = 2 := by linarith
          have hf_inj : f 1 ≠ f 0 := f.injective.ne (by rw [h_n2]; decide)
          subst h_n2
          fin_cases (f 0) <;> fin_cases (f 1) <;> contradiction <;> [left, right] <;> (intro j; fin_cases j <;> simp [*] <;> rfl)
      else
        by_contra' hnot
        rcases hnot with ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩
        -- For n > 2, if f(j+1) - f(j) is not constant, we violate injectivity of f.
        have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                    (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
        rcases this with ⟨j, ⟨h1, h2⟩ | ⟨h1, h2⟩⟩
        all_goals
          have : f (j + 2) = f j := by rw [h2, h1]; simp
          have : (j + 2 : Fin n) = j := f.injective this
          have : (2 : Fin n) = 0 := by rw [← this]; ring
          have : n ∣ 2 := (Fin.val_eq_zero.mp this).trans (by rfl)
          linarith
    rcases hf_const with h | h
    · left; use f 0; intro j
      have : f j = j + f 0 := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h j, ih]; ring
      rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
    · right; use f 0 + 1; intro j
      have : f j = f 0 - j := by
        induction j using Fin.induction with
        | zero => simp
        | succ j ih => rw [h j, ih]; simp; ring
      rw [← this, Equiv.trans_apply, p₁.apply_symm_apply]
      congr; simp [Fin.rev]; ring

