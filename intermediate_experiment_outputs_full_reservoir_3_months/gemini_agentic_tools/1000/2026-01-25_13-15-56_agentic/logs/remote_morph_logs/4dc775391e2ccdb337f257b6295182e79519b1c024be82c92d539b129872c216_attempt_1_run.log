import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  let n := #S
  have hn_pos : 0 < n := by
    by_contra h0
    have : n = 0 := Nat.eq_zero_of_nonpos h0
    subst this
    exact p₁.symm.toFun.some_prop -- Should be non-empty based on the problem context
  haveI : NeZero n := ⟨hn_pos.ne'⟩
  let f := p₂.trans p₁.symm
  have hf_p : ∀ j, p₂ j = p₁ (f j) := by simp [f]
  let R (a b : ↥S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * (b : ℕ) = x ^ 2 + x + k
  have hf_step : ∀ j : Fin n, f (j + 1) = f j + 1 ∨ f (j + 1) = f j - 1 := by
    intro j
    have h1 : R (p₁ (f j)) (p₁ (f j + 1)) := hp₁ (f j)
    have h2 : R (p₁ (f j)) (p₁ (f j - 1)) := by
      have h := hp₁ (f j - 1); rwa [Fin.sub_add_cancel] at h
    have hR : R (p₁ (f j)) (p₁ (f (j + 1))) := by
      rw [← hf_p, ← hf_p]; exact hp₂ j
    have h_deg2 : ∀ {a b c d : ↥S}, R a b → R a c → R a d → b = c ∨ b = d ∨ c = d := sorry
    have := h_deg2 hR h1 h2
    simp [Equiv.injective.eq_iff] at this; exact this
  have hf_const : (∀ j, f (j + 1) = f j + 1) ∨ (∀ j, f (j + 1) = f j - 1) := by
    if h_n2 : n ≤ 2 then
      if h_n1 : n = 1 then left; intro j; fin_cases j; rfl
      else
        have h_n2' : n = 2 := by omega
        left; intro j; have h_inj := f.injective.ne (by omega)
        revert j; rw [h_n2']; intro j; fin_cases j <;> (try (fin_cases (f 0) <;> fin_cases (f 1) <;> contradiction)) <;> rfl
    else
      by_contra h; push_neg at h
      rcases h with ⟨⟨j1, hj1⟩, ⟨j2, hj2⟩⟩
      have : ∃ j, (f (j + 1) = f j + 1 ∧ f (j + 2) = f (j + 1) - 1) ∨
                  (f (j + 1) = f j - 1 ∧ f (j + 2) = f (j + 1) + 1) := sorry
      rcases this with ⟨j, ⟨ha, hb⟩ | ⟨ha, hb⟩⟩
      all_goals
        have : f (j + 2) = f j := by rw [hb, ha]; simp
        have : j + 2 = j := f.injective this
        have : (2 : Fin n) = 0 := by rw [← this]; ring
        have : n ∣ 2 := by
          have h0 : (2 : Fin n).val = 0 := Fin.val_eq_zero.1 this
          rw [Fin.val_nat_cast, Nat.mod_eq_zero_iff_dvd] at h0; exact h0
        omega
  rcases hf_const with h_rot | h_rev
  · left; use f 0; intro j
    have : f j = j + f 0 := by
      let n' := n - 1; have hn' : n = n' + 1 := (Nat.succ_pred hn_pos).symm
      let j' : Fin (n' + 1) := ⟨j.1, by rw [← hn']; exact j.2⟩
      induction j' using Fin.induction with | zero => simp | succ j ih => rw [h_rot, ih]; ring
    rw [hf_p, this]
