import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let R := fun (a b : S) => ∃ x > 0, (a : ℕ) * (b : ℕ) = x^2 + x + k
  have hR : ∀ {p : Fin #S ≃ S}, Condition k S p → ∀ i, R (p i) (p (i + 1)) := fun hp i => hp i
  have hR_symm : ∀ {a b}, R a b ↔ R b a := by
    intro a b; constructor <;> rintro ⟨x, hx, h⟩ <;> exact ⟨x, hx, by rw [mul_comm, h]⟩
  have h_deg : ∀ a ∈ S, (S.filter (R a)).card ≤ 2 := by
    sorry
  have h_cycle1 : ∀ i, (S.filter (R (p₁ i))).card = 2 ∨ #S ≤ 2 := by
    sorry
  have h_edges : ∀ i, {p₂ i, p₂ (i + 1)} = {p₁ (p₁.symm (p₂ i)), p₁ (p₁.symm (p₂ i) + 1)} ∨
                    {p₂ i, p₂ (i + 1)} = {p₁ (p₁.symm (p₂ i)), p₁ (p₁.symm (p₂ i) - 1)} := by
    sorry
  sorry
