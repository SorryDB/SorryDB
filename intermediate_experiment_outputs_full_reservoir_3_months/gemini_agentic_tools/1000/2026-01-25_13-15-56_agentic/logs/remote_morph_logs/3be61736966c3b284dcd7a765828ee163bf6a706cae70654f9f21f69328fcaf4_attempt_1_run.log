import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx => by
      specialize h (sqrt x) (sqrt x) (sqrt x) (sqrt x) (sqrt_pos.mpr hx) (sqrt_pos.mpr hx) (sqrt_pos.mpr hx) (sqrt_pos.mpr hx) (by ring)
      rw [sq_sqrt (le_of_lt hx)] at h
      field_simp [h₁ (sqrt x) (sqrt_pos.mpr hx)] at h; exact h.symm
    have h_one : f 1 = 1 := by
      have := h_sq 1 zero_lt_one; simp at this; exact (f 1).eq_one_of_pow_eq_self (h₁ 1 zero_lt_one) 2 (by decide) this
    have h_gen : ∀ w x > 0, f w ^ 2 + f x ^ 2 = (1 + f (w * x) ^ 2) / (1 + (w * x) ^ 2) * (w ^ 2 + x ^ 2) := fun w hw x hx => by
      specialize h w x 1 (w * x) hw hx zero_lt_one (by positivity) (by ring)
      rw [h_sq 1 zero_lt_one, h_one, h_sq (w * x) (by positivity)] at h; exact h
    have h_root : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h_gen x x hx hx; rw [h_sq x hx] at h_gen
      have : (f x ^ 2 - x ^ 2) * (1 - x ^ 2 * f x ^ 2) = 0 := by field_simp [hx] at h_gen; nlinarith
      rcases eq_zero_or_eq_zero_of_mul_eq_zero this with h2 | h2
      · left; exact (sq_eq_sq (h₁ x hx).le hx.le).mp h2
      · right; have : f x ^ 2 = (1 / x) ^ 2 := by field_simp [hx] at h2; nlinarith
        exact (sq_eq_sq (h₁ x hx).le (by positivity)).mp this
    by_contra! h_neg
    rcases h_neg with ⟨⟨a, ha, ha_f⟩, ⟨b, hb, hb_f⟩⟩
    have h_an1 : a ≠ 1 ∧ f a = 1 / a := by
      rcases h_root a ha with h2 | h2
      · exact (ha_f h2).elim
      · refine ⟨?_, h2⟩; rintro rfl; simp [h_one] at ha_f
    have h_bn1 : b ≠ 1 ∧ f b = b := by
      rcases h_root b hb with h2 | h2
      · refine ⟨?_, h2⟩; rintro rfl; simp [h_one] at hb_f
      · exact (hb_f h2).elim
    specialize h_gen a b ha hb; rw [h_an1.2, h_bn1.2] at h_gen
    rcases h_root (a * b) (by positivity) with hab | hab
    · rw [hab] at h_gen; field_simp [ha, hb] at h_gen; nlinarith
    · rw [hab] at h_gen; field_simp [ha, hb] at h_gen; nlinarith
  · rintro (rfl | rfl) w x y z hw hx hy hz heq <;> field_simp [h₁, heq] <;> ring

