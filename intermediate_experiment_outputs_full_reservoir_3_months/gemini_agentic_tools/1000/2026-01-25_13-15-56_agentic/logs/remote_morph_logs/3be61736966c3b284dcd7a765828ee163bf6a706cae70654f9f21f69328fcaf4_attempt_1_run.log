import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x x x x hx hx hx hx rfl
      have hfx := h₁ x hx
      have hfx2 := h₁ (x ^ 2) (pow_pos hx 2)
      field_simp [hfx.ne.symm, hfx2.ne.symm] at h
      nlinarith
    have h_one : f 1 = 1 := by
      have h1 := h_sq 1 zero_lt_one
      rw [one_pow] at h1
      nlinarith [h₁ 1 zero_lt_one]
    have h_root : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h x x 1 (x ^ 2) hx hx zero_lt_one (pow_pos hx 2) (by ring)
      have h1sq : f (1 ^ 2) = 1 := by rw [h_sq 1 zero_lt_one, h_one, one_pow]
      have hx2sq : f ((x ^ 2) ^ 2) = f x ^ 4 := by
        rw [h_sq (x ^ 2) (pow_pos hx 2), h_sq x hx]
        ring
      rw [h1sq, hx2sq] at h
      have hfx := h₁ x hx
      field_simp [hx.ne.symm, hfx.ne.symm] at h
      have h_poly : (f x ^ 2 - x ^ 2) * (f x ^ 2 * x ^ 2 - 1) = 0 := by nlinarith
      rcases eq_zero_or_eq_zero_of_mul_eq_zero h_poly with h2 | h2
      · left; exact (sq_eq_sq₀ (h₁ x hx).le hx.le).mp (by nlinarith)
      · right; field_simp [hx.ne.symm]
        have : (f x * x) ^ 2 = 1 ^ 2 := by nlinarith
        exact (sq_eq_sq₀ (mul_pos (h₁ x hx) hx).le zero_le_one).mp this
    by_contra! h_neg
    rcases h_neg with ⟨⟨a, ha, ha_ne⟩, ⟨b, hb, hb_ne⟩⟩
    have ha_f : f a = 1 / a := (h_root a ha).resolve_left ha_ne
    have hb_f : f b = b := (h_root b hb).resolve_right hb_ne
    specialize h a b 1 (a * b) ha hb zero_lt_one (mul_pos ha hb) (by ring)
    have habsq : f ((a * b) ^ 2) = f (a * b) ^ 2 := h_sq (a * b) (mul_pos ha hb)
    rw [h_sq 1 zero_lt_one, h_one, one_pow, habsq, ha_f, hb_f] at h
    rcases h_root (a * b) (mul_pos ha hb) with hab_x | hab_inv
    · rw [hab_x] at h
      field_simp [ha.ne.symm, hb.ne.symm] at h
      have : a ^ 2 = 1 := by nlinarith
      have : a = 1 := (sq_eq_sq₀ ha.le zero_le_one).mp this
      rw [this, h_one] at ha_ne; exact ha_ne rfl
    · rw [hab_inv] at h
      field_simp [ha.ne.symm, hb.ne.symm] at h
      have : b ^ 2 = 1 := by nlinarith
      have : b = 1 := (sq_eq_sq₀ hb.le zero_le_one).mp this
      rw [this, h_one] at hb_ne; exact hb_ne (by simp)
  · rintro (hf | hf) w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      rw [← mul_pow, ← mul_pow, heq]
      ring
