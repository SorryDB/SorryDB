/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h_sq : ∀ x, 0 < x → f (x ^ 2) = f x ^ 2 := fun x hx => by
      specialize h x x x x hx hx hx hx (by ring)
      field_simp [h₁ (x ^ 2) (pow_pos hx 2)] at h
      exact h.symm
    have h_one : f 1 = 1 := by
      specialize h_sq 1 zero_lt_one
      simp at h_sq; nlinarith [h₁ 1 zero_lt_one]
    have h_gen : ∀ w x, 0 < w → 0 < x → f w ^ 2 + f x ^ 2 = (1 + f (w * x) ^ 2) / (1 + (w * x) ^ 2) * (w ^ 2 + x ^ 2) := fun w x hw hx => by
      specialize h w x 1 (w * x) hw hx zero_lt_one (mul_pos hw hx) (by ring)
      rw [h_sq 1 zero_lt_one, h_one, h_sq (w * x) (mul_pos hw hx)] at h
      exact h
    have h_root : ∀ x, 0 < x → f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h_gen x x hx hx; rw [h_sq x hx] at h_gen
      have h_poly : (f x ^ 2 - x ^ 2) * (x ^ 2 * f x ^ 2 - 1) = 0 := by
        field_simp [hx] at h_gen; ring_nf at h_gen ⊢; nlinarith
      rcases eq_zero_or_eq_zero_of_mul_eq_zero h_poly with h2 | h2
      · left; exact (pow_left_inj (h₁ x hx).le hx.le (by decide)).mp h2
      · right; have h_sq_eq : f x ^ 2 = (1 / x) ^ 2 := by field_simp [hx] at h2; nlinarith
        exact (pow_left_inj (h₁ x hx).le (by positivity) (by decide)).mp h_sq_eq
    by_contra! h_neg
    rcases h_neg with ⟨⟨a, ha, ha_f⟩, ⟨b, hb, hb_f⟩⟩
    have h_an1 : a ≠ 1 ∧ f a = 1 / a := by
      rcases h_root a ha with h2 | h2
      · exact (ha_f h2).elim
      · refine ⟨?_, h2⟩; rintro rfl; simp [h_one] at ha_f
    have h_bn1 : b ≠ 1 ∧ f b = b := by
      rcases h_root b hb with h2 | h2
      · refine ⟨?_, h2⟩; rintro rfl; simp [h_one] at hb_f
      · exact (hb_f h2).elim
    specialize h_gen a b ha hb; rw [h_an1.2, h_bn1.2] at h_gen
    rcases h_root (a * b) (mul_pos ha hb) with hab | hab <;>
    (rw [hab] at h_gen; field_simp [ha, hb] at h_gen; nlinarith)
  · rintro (h | h) w x y z hw hx hy hz heq
    · rw [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2)]
    · rw [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2)]
      field_simp [hw, hx, hy, hz]
      rw [← mul_pow, heq, mul_pow]; ring
