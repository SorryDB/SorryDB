      have : b ^ 2 = 1 := by nlinarith [ha, hb]
      have : b = 1 := by rwa [sq_eq_sq₀ hb.le zero_le_one, one_pow] at this
      subst this; rw [h_one] at hb_ne; field_simp at hb_ne
  · rintro (hf | hf) w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
