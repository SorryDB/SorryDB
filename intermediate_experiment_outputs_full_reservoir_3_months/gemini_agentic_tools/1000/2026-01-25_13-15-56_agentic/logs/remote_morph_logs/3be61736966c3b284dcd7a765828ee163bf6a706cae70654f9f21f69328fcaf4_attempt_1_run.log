import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x x x x hx hx hx hx rfl
      have := h₁ x hx
      have := h₁ (x ^ 2) (pow_pos hx 2)
      field_simp at h
      nlinarith
    have h_one : f 1 = 1 := by
      specialize h_sq 1 zero_lt_one
      simp at h_sq
      nlinarith [h₁ 1 zero_lt_one]
    have h_root : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h x x 1 (x ^ 2) hx hx zero_lt_one (pow_pos hx 2) (by ring)
      have h1sq : f (1 ^ 2) = 1 := by rw [h_sq 1 zero_lt_one, h_one, one_pow]
      have hx2sq : f ((x ^ 2) ^ 2) = f x ^ 4 := by rw [h_sq (x ^ 2) (pow_pos hx 2), h_sq x hx, pow_mul]
      rw [h1sq, hx2sq] at h
      have hfx := h₁ x hx
      field_simp [hx.ne', hfx.ne'] at h
      have h_poly : (f x ^ 2 - x ^ 2) * (f x ^ 2 * x ^ 2 - 1) = 0 := by nlinarith
      rcases eq_zero_or_eq_zero_of_mul_eq_zero h_poly with h2 | h2
      · left; apply (sq_eq_sq₀ hfx.le hx.le).mp; nlinarith
      · right; field_simp [hx.ne']; apply (sq_eq_sq₀ (mul_pos hx hfx).le zero_le_one).mp; nlinarith
    by_contra! h_neg
    rcases h_neg with ⟨⟨a, ha, ha_ne⟩, ⟨b, hb, hb_ne⟩⟩
    have ha_inv : f a = 1 / a := (h_root a ha).resolve_left ha_ne
    have hb_val : f b = b := (h_root b hb).resolve_right hb_ne
    have a_ne_1 : a ≠ 1 := by intro h_a1; rw [h_a1, h_one] at ha_ne; exact ha_ne rfl
    have b_ne_1 : b ≠ 1 := by intro h_b1; rw [h_b1, h_one] at hb_ne; exact hb_ne (by simp)
    specialize h a b 1 (a * b) ha hb zero_lt_one (mul_pos ha hb) (by ring)
    have h1sq : f (1 ^ 2) = 1 := by rw [h_sq 1 zero_lt_one, h_one, one_pow]
    have habsq : f ((a * b) ^ 2) = f (a * b) ^ 2 := h_sq (a * b) (mul_pos ha hb)
    rw [h1sq, habsq, ha_inv, hb_val] at h
    rcases h_root (a * b) (mul_pos ha hb) with hab_val | hab_val
    · rw [hab_val] at h
      field_simp [ha.ne', hb.ne', (1 + (a * b) ^ 2).ne'] at h
      have : a ^ 4 = 1 := by nlinarith
      exact a_ne_1 ((sq_eq_sq₀ ha.le zero_le_one).mp (by nlinarith))
    · rw [hab_val] at h
      field_simp [ha.ne', hb.ne', (1 + (a * b) ^ 2).ne'] at h
      have : b ^ 4 = 1 := by nlinarith
      exact b_ne_1 ((sq_eq_sq₀ hb.le zero_le_one).mp (by nlinarith))
  · rintro (hf | hf) w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      have : (w * x) ^ 2 = (y * z) ^ 2 := by rw [heq]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [this]; ring

