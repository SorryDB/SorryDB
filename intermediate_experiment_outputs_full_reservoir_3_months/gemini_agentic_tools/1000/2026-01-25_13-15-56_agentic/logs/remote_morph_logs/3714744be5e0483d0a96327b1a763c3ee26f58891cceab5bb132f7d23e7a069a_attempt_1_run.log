    have hj : j < L.length := getElem_flatten_aux₁ L i h
    let k := i - (L.take j).flatten.length
    k < L[j].length := by
  let P := (L.map length).partialSums
  have hP {n} (hn : n ≤ L.length) : P[n] = (L.take n).flatten.length := by
    simp [P, getElem_partialSums, length_flatten, map_take, hn]
  have h_ex : ∃ x ∈ P, i < x := ⟨_, length_flatten_mem_partialSums_map_length L, h⟩
  have hj' : findIdx (· > i) P = j + 1 := by
    have : findIdx (· > i) P ≠ 0 := by
      have h_idx := findIdx_getElem (· > i) P h_ex
      simp [P, getElem_partialSums] at h_idx
      omega
    omega
  have h_get := findIdx_getElem (· > i) P h_ex
  rw [hj', hP (by omega), take_succ_getElem hj, flatten_append, length_append, hP (by omega)] at h_get
  have h_min : P[j] ≤ i := by
    have := findIdx_min (· > i) P (m := j) (by omega)
    simpa using this
  rw [hP (by omega)] at h_min
  simp at h_get
  omega
