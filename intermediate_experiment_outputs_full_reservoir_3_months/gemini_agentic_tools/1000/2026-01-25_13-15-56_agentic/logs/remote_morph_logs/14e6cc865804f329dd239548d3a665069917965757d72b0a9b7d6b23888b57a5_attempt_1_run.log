    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N₀, hN₀, hx_in_B⟩
    let S₀ := sSup (B N₀ hN₀ \ {x})
    let R := sSup (D.carrier \ {N₀})
    have ha_N₀ : a ≤ N₀ := ha.trans (hB N₀ hN₀ ▸ le_sSup hx_in_B)
    have h_SR : sSup ((⋃ N, ⋃ hN, B N hN) \ {x}) ≤ S₀ ⊔ R := by
      apply sSup_le; rintro y ⟨hy_union, hy_neq_x⟩
      simp only [Set.mem_iUnion] at hy_union
      rcases hy_union with ⟨N, hN, hy_B⟩
      by_cases h_eq : N = N₀
