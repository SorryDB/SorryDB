def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N₀, hN₀, hx⟩
    let S₀ := sSup (B N₀ hN₀ \ {x})
    let R := sSup (D.carrier \ {N₀})
    have h_SR : sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) ≤ S₀ ⊔ R := by
      apply sSup_le
      rintro y ⟨hy_union, hy_neq_x⟩
      simp only [Set.mem_iUnion] at hy_union
      rcases hy_union with ⟨N, hN_mem, hy_B⟩
      by_cases h_eq : N = N₀
      · subst h_eq
        exact le_sup_of_le_left (le_sSup ⟨hy_B, hy_neq_x⟩)
      · exact le_sup_of_le_right ((hB N hN_mem ▸ le_sSup hy_B).trans (le_sSup ⟨hN_mem, h_eq⟩))
    have h_disj_N₀R : Disjoint N₀ R := D.sSupIndep' N₀ hN₀
    have ha_S₀ : a ≤ S₀ := by
      have ha_N₀ : a ≤ N₀ := ha.trans (hB N₀ hN₀ ▸ le_sSup hx)
      have hS₀_N₀ : S₀ ≤ N₀ := hB N₀ hN₀ ▸ sSup_le_sSup (Set.diff_subset)
      have h_inf : a ≤ (S₀ ⊔ R) ⊓ N₀ := le_inf (ha'.trans h_SR) ha_N₀
      rwa [IsModularLattice.modular S₀ R N₀ hS₀_N₀, h_disj_N₀R.symm.inf_eq, sup_bot] at h_inf
    exact (le_inf ha ha_S₀).trans (hB' N₀ hN₀ x hx).le_bot
```
