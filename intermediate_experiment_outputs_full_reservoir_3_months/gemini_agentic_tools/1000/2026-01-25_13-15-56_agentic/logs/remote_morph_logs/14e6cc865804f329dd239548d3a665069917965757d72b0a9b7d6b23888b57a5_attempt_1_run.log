def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N₀, hN₀_union⟩
    rcases hN₀_union with ⟨hN₀, hx_in_B⟩
    let S₀ := sSup (B N₀ hN₀ \ {x})
    let R := sSup (D.carrier \ {N₀})
    have h_SR : sSup ((⋃ N, ⋃ hN, B N hN) \ {x}) ≤ S₀ ⊔ R := by
      apply sSup_le; rintro y ⟨hy_union, hy_neq_x⟩
      simp only [Set.mem_iUnion] at hy_union
      rcases hy_union with ⟨N, hN_union⟩
      rcases hN_union with ⟨hN, hy_B⟩
      by_cases h_eq : N = N₀
      · subst h_eq; exact le_sup_of_le_left (le_sSup ⟨hy_B, hy_neq_x⟩)
      · refine le_sup_of_le_right (le_sSup_of_le ⟨N, h_eq⟩ ?_)
        rw [hB N hN]; exact le_sSup hy_B
    have ha_N₀ : a ≤ N₀ := by rw [hB N₀ hN₀]; exact ha.trans (le_sSup hx_in_B)
    have hS₀_N₀ : S₀ ≤ N₀ := by rw [hB N₀ hN₀]; exact sSup_le_sSup Set.diff_subset
    have ha_S₀ : a ≤ S₀ := by
      have h_inf : a ≤ (S₀ ⊔ R) ⊓ N₀ := le_inf (ha'.trans h_SR) ha_N₀
      have h_mod := IsModularLattice.sup_inf_assoc_of_le hS₀_N₀ R
      have h_disj : R ⊓ N₀ ≤ ⊥ := D.sSupIndep' N₀ hN₀ (R ⊓ N₀) inf_le_right inf_le_left
      rw [h_mod] at h_inf
      exact h_inf.trans (sup_le le_rfl h_disj)
    exact hB' N₀ hN₀ x hx_in_B a ha ha_S₀
