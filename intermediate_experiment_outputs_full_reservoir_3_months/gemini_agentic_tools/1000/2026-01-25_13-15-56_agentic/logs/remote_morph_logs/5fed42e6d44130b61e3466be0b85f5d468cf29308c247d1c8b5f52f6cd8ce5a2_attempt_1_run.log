/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let m := (Finset.univ.filter (fun s => biasedEnergy net s < biasedEnergy net x)).card
  induction m using Nat.strong_induction_on generalizing x
  case h m n_ih =>
    if hf : biasedIsFixedPoint net x then
      exact ⟨BiasedUpdateSeq.nil x, hf⟩
    else
      let i := Classical.choose (Classical.not_forall.mp hf)
      have hi : biasedUpdateState net x i ≠ x := Classical.choose_spec (Classical.not_forall.mp hf)
      let x' := biasedUpdateState net x i
      have hlt : biasedEnergy net x' < biasedEnergy net x := by
        have h1 := biasedEnergy_decreasing net x i
        have h2 := (biasedEnergy_fixed_point_iff_no_change net x i).not.mpr hi
        simp [biasedEnergyDiff] at h1 h2
        linarith
      have h_m' : (Finset.univ.filter (fun s => biasedEnergy net s < biasedEnergy net x')).card < m := by
        apply Finset.card_lt_card
        apply Finset.ssubset_of_subset_of_exists
        · intro s hs
          simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hs ⊢
          exact hs.trans hlt
        · use x'
          simp only [Finset.mem_filter, Finset.mem_univ, true_and, hlt]
          simp only [lt_self_iff_false, not_false_eq_true, and_self]
      rcases n_ih _ h_m' x' rfl with ⟨seq, hseq⟩
      exact ⟨BiasedUpdateSeq.cons x i seq, hseq⟩
