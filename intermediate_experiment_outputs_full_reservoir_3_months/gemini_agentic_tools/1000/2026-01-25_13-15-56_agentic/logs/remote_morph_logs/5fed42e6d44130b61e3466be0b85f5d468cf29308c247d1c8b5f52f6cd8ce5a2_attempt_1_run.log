/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let rec go x : ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target :=
    if hf : biasedIsFixedPoint net x then ⟨BiasedUpdateSeq.nil x, hf⟩ else
      let i := Classical.choose (Classical.not_forall.mp hf)
      let hi := Classical.choose_spec (Classical.not_forall.mp hf)
      let ⟨seq, hseq⟩ := go (biasedUpdateState net x i)
      ⟨BiasedUpdateSeq.cons x i seq, hseq⟩
  termination_by (Finset.univ.filter (fun s => biasedEnergy net s < biasedEnergy net x)).card
  decreasing_by
    apply Finset.card_lt_card; rw [Finset.ssubset_iff]
    let i := Classical.choose (Classical.not_forall.mp hf)
    let hi := Classical.choose_spec (Classical.not_forall.mp hf)
    have hlt : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x :=
      lt_of_sub_neg ((biasedEnergy_decreasing net x i).lt_of_ne ((biasedEnergy_fixed_point_iff_no_change net x i).not.mpr hi))
    use biasedUpdateState net x i; simp [hlt]
    exact ⟨fun y hy => hy.trans hlt, hlt.not_le⟩
  exact go x
```
