  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        let n := (l.take idx).flatten.length
        have h_len : n + idx1 < (l.set idx l1).flatten.length := by
          rw [List.set_eq_take_cons_drop hidx, List.flatten_append, List.flatten_cons]
          simp only [List.length_append, List.length_cons, List.length_flatten, n]
          omega
        let idx' : Fin (l.set idx l1).flatten.length := ⟨n + idx1, h_len⟩
        exists idx'
        constructor
        · rw [List.set_eq_take_cons_drop hidx, List.set_eq_take_cons_drop hidx]
          simp only [List.flatten_append, List.flatten_cons]
          induction (l.take idx).flatten with
          | nil =>
            simp only [List.nil_append, List.length_nil, Nat.zero_add]
            induction idx1 generalizing l1 with
            | zero => cases l1 with | nil => contradiction | cons hd tl => simp [List.eraseIdx_cons_zero]
            | succ k IH =>
              cases l1 with | nil => contradiction | cons hd tl =>
                simp only [List.eraseIdx_cons_succ, List.append_assoc, List.cons_append, List.cons.injEq, true_and]
                apply IH; simp at hidx1; exact hidx1
          | cons hd tl IH =>
            simp only [List.length_cons, List.cons_append]
            have : tl.length + 1 + idx1 = (tl.length + idx1) + 1 := by omega
            rw [this, List.eraseIdx_cons_succ, IH]
        · rw [List.set_eq_take_cons_drop hidx]
          simp only [List.flatten_append, List.flatten_cons]
          rw [List.getElem_append_right]
          · simp only [Nat.add_sub_cancel_left, List.getElem_append_left hidx1]
          · simp only [Nat.not_lt, Nat.le_add_right]
