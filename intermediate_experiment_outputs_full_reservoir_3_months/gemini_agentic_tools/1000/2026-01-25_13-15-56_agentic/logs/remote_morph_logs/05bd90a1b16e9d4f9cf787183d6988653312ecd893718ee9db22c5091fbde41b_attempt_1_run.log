  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        revert idx hidx
        induction l with
        | nil => intros; contradiction
        | cons hd tl IH =>
          intros idx hidx
          cases idx with
          | zero =>
            simp only [List.set, List.flatten_cons]
            have h_len : idx1 < (l1 ++ tl.flatten).length := by
              rw [List.length_append]
              exact Nat.lt_of_lt_of_le hidx1 (Nat.le_add_right _ _)
            exists ⟨idx1, h_len⟩
            constructor
            · induction l1 generalizing idx1 with
              | nil => contradiction
              | cons h t IHl1 =>
                cases idx1 with
                | zero => rfl
                | succ j =>
                  simp only [List.eraseIdx, List.cons_append, List.cons.injEq, true_and]
                  apply IHl1; simp at hidx1; exact Nat.lt_of_succ_lt_succ hidx1
            · simp [hidx1]
          | succ i =>
            simp only [List.length_cons, Nat.succ_lt_succ_iff] at hidx
            obtain ⟨idx_tl, h_eq, h_get⟩ := IH i hidx
            simp only [List.set, List.flatten_cons]
            have h_len : hd.length + idx_tl.1 < (hd ++ (tl.set i l1).flatten).length := by
              rw [List.length_append]
              exact Nat.add_lt_add_left idx_tl.2 _
            exists ⟨hd.length + idx_tl.1, h_len⟩
            constructor
            · rw [h_eq]
              induction hd with
              | nil => rfl
              | cons h t IHhd =>
                simp only [List.eraseIdx, List.cons_append, List.cons.injEq, true_and]
                exact IHhd
            · simp [h_get]
