  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        induction l generalizing idx with
        | nil => contradiction
        | cons hd tl IH =>
          cases idx with
          | zero =>
            simp only [List.set, List.flatten]
            let n := idx1
            have h_len : n < (l1 ++ tl.flatten).length := by
              rw [List.length_append]; exact Nat.lt_of_lt_of_le hidx1 (Nat.le_add_right _ _)
            exists ⟨n, h_len⟩
            constructor
            · clear IH
              induction l1 generalizing idx1 hidx1 with
              | nil => contradiction
              | cons h t IH_l1 =>
                cases idx1 with
                | zero => rfl
                | succ j =>
                  simp only [List.eraseIdx, List.cons_append]
                  congr 1
                  apply IH_l1
                  exact Nat.lt_of_succ_lt_succ hidx1
            · rw [List.getElem_append_left hidx1]
