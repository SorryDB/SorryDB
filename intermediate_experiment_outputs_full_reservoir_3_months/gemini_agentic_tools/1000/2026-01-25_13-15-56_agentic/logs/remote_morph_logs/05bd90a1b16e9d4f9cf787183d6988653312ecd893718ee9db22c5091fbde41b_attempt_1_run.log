            simp only [List.length_cons, Nat.succ_lt_succ_iff] at hidx
            obtain ⟨idx_tl, h_eq, h_get⟩ := IH (hidx := hidx)
            let n := hd.length + idx_tl.1
            have h_len : n < (hd ++ (tl.set i l1).flatten).length := by
              rw [List.length_append]; exact Nat.add_lt_add_left idx_tl.2 _
            exists ⟨n, h_len⟩
            constructor
            · simp only [List.set, List.flatten, h_eq]
              clear IH h_eq h_get idx_tl hidx1
              induction hd with
              | nil => rfl
              | cons h t IH_hd =>
                simp only [List.cons_append, List.length_cons, List.eraseIdx]
                congr 1
                exact IH_hd
            · simp only [List.set, List.flatten]
              rw [List.getElem_append_right (Nat.le_add_right hd.length idx_tl.1)]
              simp only [Nat.add_sub_cancel_left, h_get]

