    | cons h p' ih =>
      simp [permMapWalk, LoopWalk.map, darts] at ih ⊢
      exact ih
    | loop p' ih =>
      simp [permMapWalk, LoopWalk.map, darts] at ih ⊢
      exact ih
  have h_edges : (permMapWalk n s p.snd).edges = p.snd.edges.map (Sym2.map s) := by
    simp [edges, h_darts, List.map_map, dartEdge, Sym2.map_mk, Prod.map]
