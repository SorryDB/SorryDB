lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  simp only [edgeSet, edges]
  have h_darts : ∀ {u v : Fin n} (w : (K n).LoopWalk u v), (permMapWalk n s w).darts = w.darts.map (Prod.map s s) := by
    intros u v w
    induction w with
    | nil => simp [permMapWalk, LoopWalk.map, darts]
    | cons h p' ih =>
      simp [permMapWalk, LoopWalk.map, darts, ih, Prod.map]
      constructor <;> rfl
    | loop p' ih => simp [permMapWalk, LoopWalk.map, darts, ih, Prod.map]
  rw [h_darts, List.map_map]
  have h_comp : ∀ d, dartEdge (Prod.map s s d) = (Sym2.map s) (dartEdge d) := by
    intro ⟨u, v⟩; simp [dartEdge, Sym2.map_mk]
  simp_rw [h_comp, ← List.map_map, ← Finset.image_toFinset]
  apply Finset.card_image_of_injective
  exact Sym2.map_injective s.injective
```
