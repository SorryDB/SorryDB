lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  rw [hs]
  simp only [edgeSet, edges]
  have h_darts : ∀ {u v : Fin n} (w : (K n).LoopWalk u v), (permMapWalk n s w).darts = w.darts.map (Prod.map (⇑s) (⇑s)) := by
    intros u v w
    induction w with
    | nil => rfl
    | cons h p' ih =>
      simp [permMapWalk, LoopWalk.map, darts, ih]
      rfl
    | loop p' ih =>
      simp [permMapWalk, LoopWalk.map, darts, ih]
      rfl
  rw [h_darts, List.map_map]
  have h_comp : (fun d => dartEdge (Prod.map (⇑s) (⇑s) d)) = (Sym2.map (⇑s)) ∘ dartEdge := by
    ext ⟨u, v⟩; simp [dartEdge, Sym2.map_mk]
  rw [h_comp, ← List.map_map]
  have h_finset : (p.snd.darts.map (Sym2.map (⇑s) ∘ dartEdge)).toFinset = (p.snd.darts.map dartEdge).toFinset.image (Sym2.map (⇑s)) := by
    simp [List.toFinset, Multiset.toFinset_map]
  rw [h_finset]
  apply Finset.card_image_of_injective
  exact Sym2.map.injective s.injective

