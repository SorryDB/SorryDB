lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  dsimp
  have h_edges : ∀ {u v} (w : (K n).LoopWalk u v), (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
    intros u v w
    induction w with
    | nil => simp
    | cons h p' ih => simp [ih, LoopWalk.dartEdge, Sym2.map_apply]
    | loop p' ih => simp [ih, LoopWalk.dartEdge, Sym2.map_apply]
  rw [LoopWalk.edgeSet, LoopWalk.edgeSet, h_edges, List.toFinset_map]
  apply Finset.card_image_of_injective
  exact Sym2.map.injective s.injective
```
