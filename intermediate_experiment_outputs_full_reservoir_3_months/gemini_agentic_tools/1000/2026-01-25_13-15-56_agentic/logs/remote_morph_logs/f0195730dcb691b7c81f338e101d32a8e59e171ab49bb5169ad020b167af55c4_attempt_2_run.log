lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  have h_darts : ∀ {u v : Fin n} (w : (K n).LoopWalk u v),
      (w.map (K n) (permMap' n s)).darts = w.darts.map (Prod.map s s) := by
    intros u v w
    induction w with
    | nil => rfl
    | cons h p' ih =>
      simp only [LoopWalk.map, darts, ih, List.map_cons, Prod.map_apply]
    | loop p' ih =>
      simp only [LoopWalk.map, darts, ih, List.map_cons, Prod.map_apply]
  have h_edge_set : (permMapWalk n s p.2).edgeSet = p.2.edgeSet.image (Sym2.map s) := by
    ext e
    simp only [edgeSet, edges, permMapWalk, h_darts, List.map_map, List.mem_toFinset, List.mem_map, Finset.mem_image]
    constructor
    · rintro ⟨d, ⟨d₀, hd₀, rfl⟩, rfl⟩
      exact ⟨dartEdge d₀, ⟨d₀, hd₀, rfl⟩, rfl⟩
    · rintro ⟨_, ⟨d₀, hd₀, rfl⟩, rfl⟩
      exact ⟨Prod.map s s d₀, ⟨d₀, hd₀, rfl⟩, rfl⟩
  rw [h_edge_set]
  exact (Finset.card_image_of_injective _ (Sym2.map.injective s.injective)).symm

