lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  have h_darts : ∀ {u v : Fin n} (w : (K n).LoopWalk u v),
      (permMapWalk n s w).darts = w.darts.map (Prod.map s s) := by
    intro u v w
    induction w with
    | nil => rfl
    | cons h p' ih =>
      simp [permMapWalk, LoopWalk.map, darts, Prod.map]
      exact ih
    | loop p' ih =>
      simp [permMapWalk, LoopWalk.map, darts]
      exact ih
  have h_edges : (permMapWalk n s p.2).edges = p.2.edges.map (Sym2.map s) := by
    simp [edges, h_darts, List.map_map, dartEdge, Prod.map_apply, Sym2.map_mk]
  have h_edge_set : (permMapWalk n s p.2).edgeSet = p.2.edgeSet.image (Sym2.map s) := by
    rw [edgeSet, edgeSet, h_edges, ← Finset.image_toFinset]
  rw [h_edge_set, Finset.card_image_of_injective _ (Sym2.map.injective s.injective)]
```
