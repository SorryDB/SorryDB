  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  simp only [edgeSet]
  have h_edges : ∀ {u v} (w : (K n).LoopWalk u v), (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
