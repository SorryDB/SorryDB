  have h_edge_set : (permMapWalk n s p.2).edgeSet = p.2.edgeSet.image (Sym2.map s) := by
    simp [edgeSet, h_edges, List.toFinset_map]
  rw [h_edge_set]
  apply Finset.card_image_of_injective
  exact Sym2.map_injective s.injective
