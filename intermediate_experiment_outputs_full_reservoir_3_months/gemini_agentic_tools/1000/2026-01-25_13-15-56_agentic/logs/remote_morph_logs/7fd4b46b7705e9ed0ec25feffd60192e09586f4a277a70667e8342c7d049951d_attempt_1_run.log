import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_126 (x a : ℕ) (h₀ : 0 < x ∧ 0 < a) (h₁ : Nat.gcd a 40 = x + 3)
  (h₂ : Nat.lcm a 40 = x * (x + 3))
  (h₃ : ∀ b : ℕ, 0 < b → Nat.gcd b 40 = x + 3 ∧ Nat.lcm b 40 = x * (x + 3) → a ≤ b) : a = 8 := by
  have h_prod : a * 40 = (Nat.gcd a 40) * (Nat.lcm a 40) := (Nat.gcd_mul_lcm a 40).symm
  have h_val : a * 40 = x * (x + 3)^2 := by
    rw [h_prod, h₁, h₂]
    ring
  have h_div : x + 3 ∣ 40 := h₁ ▸ Nat.gcd_dvd_right a 40
  have h_g_ge_4 : x + 3 ≥ 4 := by linarith [h₀.1]
  have h_g_vals : x + 3 ∈ [4, 5, 8, 10, 20, 40] := by
    have h_divs : x + 3 ∈ divisors 40 := Nat.mem_divisors.mpr ⟨h_div, by norm_num⟩
    revert h_divs h_g_ge_4
    decide
  rcases h_g_vals with (_|_|_|_|_|_)
  · have hx : x = 1 := by linarith
    subst hx; rw [h_val] at h₁; norm_num at h₁
  · have hx : x = 2 := by linarith
    subst hx; rw [h_val] at h₁; norm_num at h₁
  · have hx : x = 5 := by linarith
    subst hx
    have : a * 40 = 320 := by
      rw [h_val]
      norm_num
    exact Nat.eq_of_mul_eq_mul_right (by norm_num) this
  · have hx : x = 7 := by linarith
    subst hx; rw [h_val] at h₁; norm_num at h₁
  · have hx : x = 17 := by linarith
    subst hx
    have ha : a = 170 := by linarith [h_val]
    subst ha; norm_num at h₁
  · have hx : x = 37 := by linarith
    subst hx
    have ha : a = 1480 := by linarith [h_val]
    exfalso
    have h_b8 : Nat.gcd 8 40 = 37 + 3 ∧ Nat.lcm 8 40 = 37 * (37 + 3) := by
      norm_num
    have : a ≤ 8 := h₃ 8 (by norm_num) h_b8
    linarith
