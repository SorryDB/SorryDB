import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = answer(92) := by
  let g n := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have g_2n : ∀ n > 0, g (2 * n) = g n := by
    intro n hn
    simp [g, Nat.digits_base_mul (by omega : 1 < 2) hn, List.reverse_cons, Nat.ofDigits_append_zero]
  have g_2n1 : ∀ n, g (2 * n + 1) = g n + 2 ^ (Nat.digits 2 n).length := by
    intro n
    cases n with
    | zero => simp [g, Nat.digits_of_two_le_of_pos]
    | succ n =>
      have hn : n + 1 > 0 := by omega
      simp [g, Nat.digits_of_two_le_of_pos (by omega : 2 ≤ 2) hn, List.reverse_cons, Nat.ofDigits_append]
      rfl
  have g_4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    rw [show 4 * n + 1 = 2 * (2 * n) + 1 by omega, g_2n1, g_2n hn, g_2n1]
    rw [show (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 by
      rw [Nat.digits_base_mul (by omega : 1 < 2) hn]; rfl]
    rw [Nat.pow_succ]; omega
  have g_4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    rw [show 4 * n + 3 = 2 * (2 * n + 1) + 1 by omega, g_2n1, g_2n1]
    rw [show (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 by
      rw [Nat.digits_of_two_le_of_pos (by omega : 2 ≤ 2) (by omega : 0 < 2 * n + 1)]; rfl]
    rw [g_2n1, Nat.pow_succ]; omega
  have h_fg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with | zero => simp at hn | succ n =>
      match n + 1 with
      | 1 => exact h₁
      | 2 => rw [h₃ 1 (by omega), h₁, g_2n 1 (by omega)]; rfl
      | 3 => exact h₂
      | n + 1 =>
        if he : (n + 1) % 2 = 0 then
          have hm : n + 1 = 2 * ((n + 1) / 2) := Nat.div_two_mul_two_of_even (Nat.even_iff.mpr he)
          have hm' : (n + 1) / 2 > 0 ∧ (n + 1) / 2 < n + 1 := by omega
          rw [hm, h₃ _ hm'.1, ih _ hm'.2, g_2n _ hm'.1]
        else if ho : (n + 1) % 4 = 1 then
          have hm : n + 1 = 4 * ((n + 1) / 4) + 1 := by
            have : (n + 1) % 4 = 1 := ho
            rw [← Nat.div_add_mod (n + 1) 4, this]
          have m := (n + 1) / 4
          have hm' : m > 0 ∧ 2 * m + 1 < n + 1 ∧ m < n + 1 := by omega
          rw [hm, h₄ m hm'.1, g_4n1 m hm'.1, ih (2 * m + 1) hm'.2.1, ih m hm'.2.2]
        else
          have ho : (n + 1) % 4 = 3 := by
            have h_odd : (n + 1) % 2 = 1 := Nat.mod_two_ne_zero.mp he
            have h_mod4 := Nat.mod_mul_left_mod (n + 1) 2 2
            omega
          have hm : n + 1 = 4 * ((n + 1) / 4) + 3 := by
            have : (n + 1) % 4 = 3 := ho
            rw [← Nat.div_add_mod (n + 1) 4, this]
          have m := (n + 1) / 4
          have hm' : m > 0 ∧ 2 * m + 1 < n + 1 ∧ m < n + 1 := by omega
          rw [hm, h₅ m hm'.1, g_4n3 m hm'.1, ih (2 * m + 1) hm'.2.1, ih m hm'.2.2]
  have h_count : (Finset.filter (fun n => g n = n) (Finset.Icc 1 1988)).card = 92 := by
    native_decide
  rw [Finset.filter_congr h_fg, h_count]
