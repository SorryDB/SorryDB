    rw [Nat.digits_def' (by omega : 1 < 2) (by omega : 0 < 2 * n + 1)]
    simp [Nat.ofDigits_append, Nat.ofDigits]
  have g_4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    rw [show 4 * n + 1 = 2 * (2 * n) + 1 by omega, g_2n1, g_2n n hn, g_2n1]
    have : (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 := by
      rw [Nat.digits_def' (by omega) (by omega)]; simp [hn]
    rw [this, Nat.pow_succ]; omega
  have g_4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    rw [show 4 * n + 3 = 2 * (2 * n + 1) + 1 by omega, g_2n1, g_2n1]
    have : (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 := by
      rw [Nat.digits_def' (by omega) (by omega)]; simp
    rw [this, Nat.pow_succ]; omega
  have h_fg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
