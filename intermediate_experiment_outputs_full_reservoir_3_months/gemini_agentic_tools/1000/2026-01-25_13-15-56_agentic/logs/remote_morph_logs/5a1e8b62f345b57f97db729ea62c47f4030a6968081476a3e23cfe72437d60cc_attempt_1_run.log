        rw [hm, h₃ (n / 2) m_pos, ih (n / 2) (by omega) (by simp; omega), g_2n (n / 2) m_pos]
      else if ho : n % 4 = 1 then
        have m_pos : n / 4 > 0 := by omega
        have hm : n = 4 * (n / 4) + 1 := by rw [← Nat.div_add_mod n 4, ho]
        rw [hm, h₄ (n / 4) m_pos, g_4n1 (n / 4) m_pos, ih (2 * (n / 4) + 1) (by omega) (by simp; omega), ih (n / 4) (by omega) (by simp; omega)]
