import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = answer(92) := by
  let g (n : ℕ) : ℕ := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have h_digits_2n : ∀ n > 0, Nat.digits 2 (2 * n) = 0 :: Nat.digits 2 n := by
    intro n hn
    rw [Nat.digits_def' (by omega) (by omega)]
    show (2 * n) % 2 :: Nat.digits 2 (2 * n / 2) = 0 :: Nat.digits 2 n
    rw [Nat.mul_mod_right, Nat.mul_div_right]; omega
  have h_digits_2n1 : ∀ n, Nat.digits 2 (2 * n + 1) = 1 :: Nat.digits 2 n := by
    intro n
    rw [Nat.digits_def' (by omega) (by omega)]
    show (2 * n + 1) % 2 :: Nat.digits 2 ((2 * n + 1) / 2) = 1 :: Nat.digits 2 n
    have h1 : (2 * n + 1) % 2 = 1 := by omega
    have h2 : (2 * n + 1) / 2 = n := by omega
    rw [h1, h2]
  have g_2n : ∀ n > 0, g (2 * n) = g n := by
    intro n hn
    unfold g; rw [h_digits_2n n hn, List.reverse_cons, Nat.ofDigits_append]
    simp [Nat.ofDigits]
  have g_2n1 : ∀ n, g (2 * n + 1) = g n + 2 ^ (Nat.digits 2 n).length := by
    intro n
    unfold g; rw [h_digits_2n1 n, List.reverse_cons, Nat.ofDigits_append]
    simp [Nat.ofDigits]
  have len_2n : ∀ n > 0, (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 := by
    intro n hn; rw [h_digits_2n n hn]; simp
  have len_2n1 : ∀ n, (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 := by
    intro n; rw [h_digits_2n1 n]; simp
  have g_4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    have : 4 * n + 1 = 2 * (2 * n) + 1 := by omega
    rw [this, g_2n1 (2 * n), g_2n n hn, g_2n1 n, len_2n n hn, Nat.pow_succ]
    omega
  have g_4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    have : 4 * n + 3 = 2 * (2 * n + 1) + 1 := by omega
    rw [this, g_2n1 (2 * n + 1), g_2n1 n, len_2n1 n, Nat.pow_succ, g_2n1 n]
    omega
  have h_fg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      if h1 : n = 1 then rw [h1, h₁]; unfold g; rfl
      else if h2 : n = 2 then
        rw [h2, h₃ 1 (by omega), h₁, g_2n 1 (by omega), h₁]; unfold g; rfl
      else if h3 : n = 3 then rw [h3, h₂]; unfold g; rfl
      else if he : n % 2 = 0 then
        have m_pos : n / 2 > 0 := by omega
        have hm : n = 2 * (n / 2) := by rw [Nat.mul_comm, ← Nat.div_add_mod n 2, he, Nat.add_zero]
        rw [hm, h₃ (n / 2) m_pos, ih (n / 2) (by omega) (by simp; omega), g_2n (n / 2) m_pos]
      else if ho : n % 4 = 1 then
        have m_pos : n / 4 > 0 := by omega
        have hm : n = 4 * (n / 4) + 1 := by rw [← Nat.div_add_mod n 4, ho]
        rw [hm, h₄ (n / 4) m_pos, g_4n1 (n / 4) m_pos, ih (2 * (n / 4) + 1) (by omega) (by simp; omega), ih (n / 4) (by omega) (by simp; omega)]
      else
        have ho3 : n % 4 = 3 := by
          have h_odd : n % 2 = 1 := Nat.mod_two_ne_zero.mp (by omega)
          have := Nat.mod_lt n (by omega : 0 < 4); revert this h_odd ho; omega
        have m_pos : n / 4 > 0 := by omega
        have hm : n = 4 * (n / 4) + 3 := by rw [← Nat.div_add_mod n 4, ho3]
        rw [hm, h₅ (n / 4) m_pos, g_4n3 (n / 4) m_pos, ih (2 * (n / 4) + 1) (by omega) (by simp; omega), ih (n / 4) (by omega) (by simp; omega)]
  have h_count : (Finset.filter (fun n => g n = n) (Finset.Icc 1 1988)).card = 92 := by
    native_decide
  rw [Finset.filter_congr (fun n hn => iff_of_eq (by rw [h_fg n hn])), h_count]

