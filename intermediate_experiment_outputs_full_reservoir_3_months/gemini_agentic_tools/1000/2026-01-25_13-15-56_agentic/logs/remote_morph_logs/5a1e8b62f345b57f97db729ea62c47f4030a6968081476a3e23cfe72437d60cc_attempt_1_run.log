import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = answer(92) := by
  let g (n : ℕ) : ℕ := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have g_2n : ∀ n > 0, g (2 * n) = g n := by
    intro n hn
    have h_digits : Nat.digits 2 (2 * n) = 0 :: Nat.digits 2 n := by
      rw [Nat.digits_def' (by omega : 1 < 2) (by omega : 0 < 2 * n)]; simp [hn]
    simp [g, h_digits, List.reverse_cons, Nat.ofDigits_append]
  have g_2n1 : ∀ n, g (2 * n + 1) = g n + 2 ^ (Nat.digits 2 n).length := by
    intro n
    cases n with
    | zero => rfl
    | succ n =>
      have h_digits : Nat.digits 2 (2 * (n + 1) + 1) = 1 :: Nat.digits 2 (n + 1) := by
        rw [Nat.digits_def' (by omega : 1 < 2) (by omega : 0 < 2 * (n + 1) + 1)]; simp
      simp [g, h_digits, List.reverse_cons, Nat.ofDigits_append]
  have g_4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    rw [show 4 * n + 1 = 2 * (2 * n) + 1 by omega, g_2n1 (2 * n), g_2n n hn, g_2n1 n]
    have : (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 := by
      rw [Nat.digits_def' (by omega : 1 < 2) (by omega : 0 < 2 * n)]; simp [hn]
    rw [this, Nat.pow_succ]; omega
  have g_4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    rw [show 4 * n + 3 = 2 * (2 * n + 1) + 1 by omega, g_2n1 (2 * n + 1), g_2n1 n]
    have : (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 := by
      rw [Nat.digits_def' (by omega : 1 < 2) (by omega : 0 < 2 * n + 1)]; simp
    rw [this, g_2n1 n, Nat.pow_succ]; omega
  have h_fg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      if h1 : n = 1 then rw [h1, h₁]; rfl
      else if h2 : n = 2 then rw [h2, h₃ 1 (by omega), h₁, g_2n 1 (by omega)]; rfl
      else if h3 : n = 3 then rw [h3, h₂]; rfl
      else if he : n % 2 = 0 then
        have h_even : Even n := Nat.even_iff.mpr he
        obtain ⟨m, hm⟩ := h_even
        have m_pos : m > 0 := by simp at hn; omega
        rw [hm, h₃ m m_pos, ih m (by omega) (by simp at hn; omega), g_2n m m_pos]
      else if ho : n % 4 = 1 then
        let m := n / 4; have m_pos : m > 0 := by simp at hn; omega
        have hm : n = 4 * m + 1 := by rw [← Nat.div_add_mod n 4, ho]
        rw [hm, h₄ m m_pos, g_4n1 m m_pos, ih (2 * m + 1) (by omega) (by simp at hn; omega), ih m (by omega) (by simp at hn; omega)]
      else
        have ho3 : n % 4 = 3 := by
          have : n % 2 = 1 := Nat.mod_two_ne_zero.mp (by assumption)
          omega
        let m := n / 4; have m_pos : m > 0 := by simp at hn; omega
        have hm : n = 4 * m + 3 := by rw [← Nat.div_add_mod n 4, ho3]
        rw [hm, h₅ m m_pos, g_4n3 m m_pos, ih (2 * m + 1) (by omega) (by simp at hn; omega), ih m (by omega) (by simp at hn; omega)]
  have h_count : (Finset.filter (fun n => g n = n) (Finset.Icc 1 1988)).card = 92 := by
    native_decide
  rw [Finset.filter_congr (fun n hn => by rw [h_fg n hn]), h_count]

