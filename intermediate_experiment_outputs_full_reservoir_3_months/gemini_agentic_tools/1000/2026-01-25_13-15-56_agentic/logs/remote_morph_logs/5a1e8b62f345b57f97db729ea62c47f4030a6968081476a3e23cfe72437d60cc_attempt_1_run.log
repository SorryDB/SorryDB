import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = answer(92) := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have h_g_rec : ∀ n > 0,
    (g (2 * n) = g n) ∧
    (g (4 * n + 1) = 2 * g (2 * n + 1) - g n) ∧
    (g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n) := by
    intro n hn
    let digits := Nat.digits 2 n
    let k := digits.length
    have h_len_digits : (Nat.digits 2 n).length = k := rfl
    have h_digits_pos : 0 < k := by
      subst h_len_digits; rw [Nat.digits_len_two hn]; omega
    have h_last_one : digits.reverse.head? = some 1 := by
      subst digits; rw [List.head?_reverse]; exact Nat.digits_last_bit_two hn
    have h_g_val : g n = Nat.ofDigits 2 digits.reverse := by simp [g, hn]
    have h_g_2n : g (2 * n) = g n := by
      simp [g, Nat.digits_two_mul_zero hn, List.reverse_cons]; rfl
    have h_g_2n1 : g (2 * n + 1) = 2 ^ k + g n := by
      simp [g, Nat.digits_two_mul_add_one n, List.reverse_cons, Nat.ofDigits_append, h_g_val]
      omega
    have h_g_4n1 : g (4 * n + 1) = 2 ^ (k + 1) + g n := by
      have h4n1 : 4 * n + 1 = 2 * (2 * n) + 1 := by omega
      simp [h4n1, g, Nat.digits_two_mul_add_one (2 * n), Nat.digits_two_mul_zero hn, List.reverse_cons, List.reverse_cons, Nat.ofDigits_append, h_g_val]
      omega
    have h_g_4n3 : g (4 * n + 3) = 2 ^ (k + 1) + 2 ^ k + g n := by
      have h4n3 : 4 * n + 3 = 2 * (2 * n + 1) + 1 := by omega
      simp [h4n3, g, Nat.digits_two_mul_add_one (2 * n + 1), Nat.digits_two_mul_add_one n, List.reverse_cons, List.reverse_cons, Nat.ofDigits_append, h_g_val]
      omega
    repeat constructor
    · exact h_g_2n
    · rw [h_g_2n1, h_g_4n1]; omega
    · rw [h_g_2n1, h_g_4n3]; omega
  have h_fg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with
      | zero => contradiction
      | succ n =>
        match n + 1 with
        | 1 => exact h₁
        | 2 => rw [h₃ 1, h_g_rec 1 |>.1, ih 1 (by omega)]; omega
        | 3 => exact h₂
        | n + 1 =>
          if h_even : (n + 1) % 2 = 0 then
            obtain ⟨m, hm⟩ := Nat.even_iff_exists_two_mul.mp (Nat.even_iff.mpr h_even)
            rw [hm, h₃ m (by omega), h_g_rec m (by omega) |>.1, ih m (by omega)]
          else
            have h_odd : (n + 1) % 2 = 1 := Nat.mod_two_ne_zero.mp h_even
            obtain ⟨m, hm⟩ := Nat.exists_eq_two_mul_add_one.mpr h_odd
