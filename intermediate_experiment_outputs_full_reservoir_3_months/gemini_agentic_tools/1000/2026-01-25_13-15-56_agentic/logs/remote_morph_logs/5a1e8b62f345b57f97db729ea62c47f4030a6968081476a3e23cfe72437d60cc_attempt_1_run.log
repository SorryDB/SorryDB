    intro n; rw [Nat.digits_def' (by norm_num) (by omega)]
    show (2 * n + 1) % 2 :: Nat.digits 2 ((2 * n + 1) / 2) = 1 :: Nat.digits 2 n
    have : (2 * n + 1) % 2 = 1 := by omega
    have : (2 * n + 1) / 2 = n := by omega
    rw [this, ‹(2 * n + 1) % 2 = 1›]
  have g_2n : ∀ n > 0, g (2 * n) = g n := by
    intro n hn; unfold g; rw [h_digits_2n n hn, List.reverse_cons, Nat.ofDigits_append]
    simp [Nat.ofDigits]
  have g_2n1 : ∀ n, g (2 * n + 1) = g n + 2 ^ (Nat.digits 2 n).length := by
    intro n; unfold g; rw [h_digits_2n1 n, List.reverse_cons, Nat.ofDigits_append]
    simp [Nat.ofDigits]
  have len_2n : ∀ n > 0, (Nat.digits 2 (2 * n)).length = (Nat.digits 2 n).length + 1 := by
    intro n hn; rw [h_digits_2n n hn]; simp
  have len_2n1 : ∀ n, (Nat.digits 2 (2 * n + 1)).length = (Nat.digits 2 n).length + 1 := by
    intro n; rw [h_digits_2n1 n]; simp
  have g_4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    have h1 : 4 * n + 1 = 2 * (2 * n) + 1 := by omega
    have h2 : 2 * n > 0 := by omega
    rw [h1, g_2n1 (2 * n), g_2n n hn, g_2n1 n, len_2n n hn, Nat.pow_succ]
    omega
  have g_4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    have h1 : 4 * n + 3 = 2 * (2 * n + 1) + 1 := by omega
    rw [h1, g_2n1 (2 * n + 1), g_2n1 n, len_2n1 n, Nat.pow_succ]
    omega
  have h_fg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
