Released under Apache 2.0 license as described in the file LICENSE.
Authors: Shalev Wengrowsky
-/

import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN, PMF.uniformOfFintype_apply]
  simp only [ENNReal.tsum_fintype, Set.indicator_apply, Fintype.card_pi, Fintype.card_fin, Digit, one_div]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  have h9n' : (9 : ENNReal) ^ n ≠ ⊤ := by norm_num
  rw [← Finset.sum_div, Finset.sum_ite, Finset.sum_const, nsmul_eq_mul, mul_one, mul_zero, add_zero]
  have h_card : (Finset.univ.filter (fun s => is_good_seq s)).card = 9 ^ n - (8 ^ n + 5 ^ n - 4 ^ n) := by
    let S := Finset.univ (α := DigitSeq n)
    let A := S.filter (fun s => ∀ i, to_nat_digit (s i) ≠ 5)
    let B := S.filter (fun s => ∀ i, to_nat_digit (s i) % 2 ≠ 0)
    have h_good : S.filter (fun s => is_good_seq s) = (A ∪ B)ᶜ := by
      ext s; simp [is_good_seq, to_nat_digit, Nat.dvd_iff_prime_pow_dvd_list_prod, A, B]
      rw [← Nat.prime_two, ← Nat.prime_five]
      simp [Nat.dvd_iff_exists_prime_dvd, Finset.prod_nat_pos]
      constructor
      · intro h; push_neg; constructor
        · obtain ⟨i, hi⟩ := h.2; use i; exact hi
        · obtain ⟨i, hi⟩ := h.1; use i; exact hi
      · intro h; constructor
        · obtain ⟨i, hi⟩ := h.2; use i; exact hi
        · obtain ⟨i, hi⟩ := h.1; use i; exact hi
    rw [h_good, Finset.card_compl, Finset.card_union, A, B]
    simp only [Finset.card_filter, Fintype.card_pi, Fintype.card_fin, Digit]
    have hA : (Finset.univ.filter fun s : DigitSeq n => ∀ i : Fin n, to_nat_digit (s i) ≠ 5).card = 8 ^ n := by
      rw [← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 8
    have hB : (Finset.univ.filter fun s : DigitSeq n => ∀ i : Fin n, to_nat_digit (s i) % 2 ≠ 0).card = 5 ^ n := by
      rw [← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 5
    have hAB : (A ∩ B).card = 4 ^ n := by
      simp [A, B, ← Finset.filter_and]; rw [← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 4
    rw [hA, hB, hAB]
  rw [h_card, ENNReal.ofNat_sub, ENNReal.sub_div, ENNReal.div_self h9n h9n']
  · simp only [Nat.cast_add, Nat.cast_sub, ENNReal.ofNat_sub, ENNReal.ofNat_add, ENNReal.ofNat_pow]
    rw [ENNReal.add_div, ENNReal.sub_div, ← ENNReal.pow_div_pow, ← ENNReal.pow_div_pow, ← ENNReal.pow_div_pow]
    · norm_num
    · exact Nat.cast_le.mpr (Nat.pow_le_pow_of_le_left (by norm_num) n)
  · exact Nat.cast_le.mpr (by
      have : 8 ^ n + 5 ^ n ≤ 9 ^ n + 4 ^ n := by
        induction n with
        | zero => norm_num
        | succ n ih =>
          have : 8 * 8 ^ n + 5 * 5 ^ n ≤ 9 * 9 ^ n + 4 * 4 ^ n := by
            calc 8 * 8 ^ n + 5 * 5 ^ n ≤ 8 * (8 ^ n + 5 ^ n) := by nlinarith
                _ ≤ 8 * (9 ^ n + 4 ^ n) := by rel [ih]
                _ ≤ 9 * 9 ^ n + 4 * 4 ^ n := by nlinarith [Nat.pow_pos (by norm_num : 0 < 9) n]
          exact this
      exact Nat.sub_le_of_le_add (by rw [Nat.add_comm]; exact this))

end Usa1972P3

