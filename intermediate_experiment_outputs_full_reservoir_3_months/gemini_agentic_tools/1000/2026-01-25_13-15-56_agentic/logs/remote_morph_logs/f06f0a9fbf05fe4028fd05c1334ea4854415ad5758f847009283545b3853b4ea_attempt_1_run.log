import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN]
  classical
  simp only [PMF.uniformOfFintype_apply, Set.indicator_apply, Finset.sum_ite,
    Finset.filter_univ, Finset.sum_const, nsmul_eq_mul, mul_one, mul_zero,
    add_zero, Fintype.card_pi, Fintype.card_fin, Digit]
  let S := Finset.univ (α := DigitSeq n)
  let A := S.filter (fun s => ∀ i, to_nat_digit (s i) ≠ 5)
  let B := S.filter (fun s => (to_nat_digit (s i)) % 2 ≠ 0)
  have hA : A.card = 8 ^ n := by
    let tA := fun (_ : Fin n) ↦ (Finset.univ.filter (fun d : Digit ↦ to_nat_digit d ≠ 5))
    have : A = Finset.univ.pi tA := by ext; simp [A, tA]
    rw [this, Finset.card_pi]; simp [tA, to_nat_digit]; decide
  have hB : B.card = 5 ^ n := by
    let tB := fun (_ : Fin n) ↦ (Finset.univ.filter (fun d : Digit ↦ to_nat_digit d % 2 ≠ 0))
    have : B = Finset.univ.pi tB := by ext; simp [B, tB]
    rw [this, Finset.card_pi]; simp [tB, to_nat_digit]; decide
  have hAB : (A ∩ B).card = 4 ^ n := by
    let tAB := fun (_ : Fin n) ↦ (Finset.univ.filter (fun d : Digit ↦ to_nat_digit d ≠ 5 ∧ to_nat_digit d % 2 ≠ 0))
    have : A ∩ B = Finset.univ.pi tAB := by ext; simp [A, B, tAB, ← Finset.filter_and]
    rw [this, Finset.card_pi]; simp [tAB, to_nat_digit]; decide
  have h_good : S.filter is_good_seq = (A ∪ B)ᶜ := by
    ext s; simp [is_good_seq, to_nat_digit, A, B]
    rw [Nat.Coprime.mul_dvd_iff_dvd_and_dvd Nat.coprime_two_five,
        Nat.Prime.dvd_prod_iff Nat.prime_two, Nat.Prime.dvd_prod_iff Nat.prime_five]
    push_neg; rfl
  rw [h_good, Finset.card_compl, Finset.card_union, hA, hB, hAB]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  have h9n' : (9 : ENNReal) ^ n ≠ ⊤ := by norm_num
  simp only [ENNReal.ofNat_pow, Nat.cast_sub (Finset.card_le_univ _),
    Nat.cast_sub (Finset.card_inter_le_left _ _), Nat.cast_add]
  rw [ENNReal.sub_div, ENNReal.div_self h9n h9n', ENNReal.sub_div, ENNReal.add_div]
  repeat' rw [← ENNReal.div_pow]
  norm_num

end Usa1972P3
```
