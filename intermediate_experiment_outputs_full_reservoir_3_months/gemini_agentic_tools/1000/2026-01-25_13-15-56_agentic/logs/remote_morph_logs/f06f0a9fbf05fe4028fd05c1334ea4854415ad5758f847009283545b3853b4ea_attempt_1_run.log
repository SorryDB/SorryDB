import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  have h9n' : (9 : ENNReal) ^ n ≠ ⊤ := by norm_num
  simp only [PMF.uniformOfFintype_apply, Set.indicator_apply, Fintype.card_pi, Fintype.card_fin, Digit, one_div,
    ← Finset.sum_div, Finset.sum_ite, Finset.sum_const, nsmul_eq_mul, mul_one, mul_zero, add_zero]
  rw [ENNReal.sub_div, ENNReal.sub_div, ENNReal.add_div, ENNReal.div_self h9n h9n']
  repeat rw [← ENNReal.div_pow]
  norm_num
  congr 1
  norm_cast
  let S := Finset.univ (α := DigitSeq n)
  let A := S.filter (fun s => ∀ i, to_nat_digit (s i) ≠ 5)
  let B := S.filter (fun s => ∀ i, to_nat_digit (s i) % 2 ≠ 0)
  have h_good : S.filter (fun s => is_good_seq s) = S.filter (fun s => (s ∉ A) ∧ (s ∉ B)) := by
    ext s; simp [is_good_seq, to_nat_digit, A, B]
    rw [Nat.dvd_iff_prime_pow_dvd_list_prod, Nat.dvd_iff_prime_pow_dvd_list_prod]
    · simp [Nat.prime_two, Nat.prime_five, Finset.prod_nat_pos]
      constructor
      · intro h; push_neg; constructor
        · obtain ⟨i, hi⟩ := h.2; use i; exact hi
        · obtain ⟨i, hi⟩ := h.1; use i; exact hi
      · intro h; constructor
        · obtain ⟨i, hi⟩ := h.2; use i; exact hi
        · obtain ⟨i, hi⟩ := h.1; use i; exact hi
    · exact Nat.prime_five
    · exact Nat.prime_two
  have h_card_good : (S.filter is_good_seq).card = 9^n - 8^n - 5^n + 4^n := by
    cases n with
    | zero => norm_num [is_good_seq, to_nat_digit]
    | succ n =>
      have hA : A.card = 8 ^ (n + 1) := by
        rw [← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 8
      have hB : B.card = 5 ^ (n + 1) := by
        rw [← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 5
      have hAB : (A ∩ B).card = 4 ^ (n + 1) := by
        simp [A, B, ← Finset.filter_and, ← Fintype.card_pi]; congr; simp [to_nat_digit]; exact Nat.card_fin 4
      rw [h_good]
      have : S.filter (fun s => s ∉ A ∧ s ∉ B) = (A ∪ B)ᶜ := by
        ext x; simp; constructor <;> intro h <;> simp [h]
      rw [this, Finset.card_compl, Finset.card_union, hA, hB, hAB]
      simp only [Fintype.card_pi, Fintype.card_fin, Digit]
      omega
  exact h_card_good

end Usa1972P3

