import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN]
  classical
  simp only [PMF.uniformOfFintype_apply, Set.indicator_apply, ENNReal.tsum_eq_sum, Fintype.card_pi,
    Fintype.card_fin, Digit, one_div, ← Finset.sum_div, Finset.sum_ite, Finset.sum_const,
    nsmul_eq_mul, mul_one, mul_zero, add_zero]
  let S : Finset (DigitSeq n) := Finset.univ
  let A := S.filter (fun s => ∀ i, to_nat_digit (s i) ≠ 5)
  let B := S.filter (fun s => ∀ i, to_nat_digit (s i) % 2 ≠ 0)
  have h_card (P : Digit → Prop) [DecidablePred P] :
      (S.filter (fun s => ∀ i, P (s i))).card = (Finset.univ.filter P).card ^ n := by
    simp [S, Finset.filter_univ]
    rw [← Fintype.card_pi]
    exact Fintype.card_congr (Equiv.piSubtypeProperty (λ _ => Digit) (λ _ d => P d))
  have hA : A.card = 8 ^ n := by rw [h_card]; congr; decide
  have hB : B.card = 5 ^ n := by rw [h_card]; congr; decide
  have hAB : (A ∩ B).card = 4 ^ n := by rw [← Finset.filter_and, h_card]; congr; decide
  have h_good : S.filter is_good_seq = (A ∪ B)ᶜ := by
    ext s; simp [is_good_seq, to_nat_digit, A, B]
    rw [Nat.Coprime.mul_dvd_iff_dvd_and_dvd (by norm_num : Nat.Coprime 2 5)]
    simp [Prime.dvd_finset_prod_iff Nat.prime_two, Prime.dvd_finset_prod_iff Nat.prime_five, to_nat_digit]
    have h5 (d : Digit) : 5 ∣ d.val + 1 ↔ d.val + 1 = 5 := by
      have := d.2; simp at this; constructor <;> omega
    have h2 (d : Digit) : 2 ∣ d.val + 1 ↔ (d.val + 1) % 2 = 0 := by rw [Nat.dvd_iff_mod_eq_zero]
    simp [h5, h2]; constructor
    · rintro ⟨⟨i, hi⟩, ⟨j, hj⟩⟩; constructor
      · intro h; exact hi (h i)
      · rw [← not_forall]; intro h; exact hj (h j)
    · rintro ⟨h1, h2⟩; rw [← not_forall] at h1 h2; simp at h1 h2; exact ⟨h1, h2⟩
  rw [h_good, Finset.card_compl, Finset.card_union, hA, hB, hAB]
  simp only [ENNReal.ofNat_pow, Fintype.card_pi, Fintype.card_fin, Digit]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  have h9n' : (9 : ENNReal) ^ n ≠ ⊤ := by norm_num
  rw [Nat.cast_sub (Finset.card_le_univ _), ENNReal.sub_div, ENNReal.div_self h9n h9n']
  rw [Nat.cast_sub (Finset.card_inter_le_left _ _), ENNReal.sub_div, ENNReal.add_div]
  repeat' rw [← ENNReal.div_pow]
  norm_num

end Usa1972P3
```
