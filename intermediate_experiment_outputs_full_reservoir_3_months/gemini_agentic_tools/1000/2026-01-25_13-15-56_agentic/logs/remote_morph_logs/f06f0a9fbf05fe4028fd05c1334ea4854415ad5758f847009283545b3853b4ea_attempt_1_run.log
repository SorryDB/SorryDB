import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN, PMF.uniformOfFintype_apply]
  simp only [ENNReal.tsum_fintype, Finset.sum_const, nsmul_eq_mul, Fintype.card_pi, Fintype.card_fin,
    Digit, one_div, one_mul]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  rw [ENNReal.mul_inv_cancel h9n (by simp)]
  have h_card : Fintype.card (@good_seqs n) = 9 ^ n - (8 ^ n + 5 ^ n - 4 ^ n) := by
    cases n with
    | zero => simp [good_seqs, is_good_seq]
    | succ n =>
      simp only [good_seqs, is_good_seq, Nat.dvd_gcd_iff_dvd_left (by norm_num), Nat.dvd_prime Nat.prime_two,
        Nat.dvd_prime Nat.prime_five, Nat.dvd_iff_mod_eq_zero, ← Finset.univ_filter_card_op]
      have : ∀ (s : DigitSeq (n + 1)), (∀ i, (s i).val + 1 ≠ 5) ∨ (∀ i, ((s i).val + 1) % 2 ≠ 0) ↔
          s ∈ (Finset.univ.filter (fun s => ∀ i, (s i).val + 1 ≠ 5)) ∪
               (Finset.univ.filter (fun s => ∀ i, ((s i).val + 1) % 2 ≠ 0)) := by simp
      rw [Finset.card_compl, Fintype.card_pi, Fintype.card_fin, Finset.card_union,
        Finset.card_filter, Finset.card_filter, Finset.card_filter]
      simp only [Fintype.card_pi, Fintype.card_fin, Digit, to_nat_digit, Nat.mod_mod,
        Finset.univ_filter_card_op, Fintype.card_fin, Nat.succ_eq_add_one]
      congr <;> { norm_num; rfl }
  rw [h_card]
  norm_cast
  simp only [ENNReal.ofNat_sub, ENNReal.ofNat_add, ENNReal.ofNat_pow]
  rw [ENNReal.sub_div, ENNReal.sub_div, ENNReal.add_div]
  repeat rw [ENNReal.div_self h9n (by simp)]
  repeat rw [ENNReal.pow_div_pow]
  norm_num
```
