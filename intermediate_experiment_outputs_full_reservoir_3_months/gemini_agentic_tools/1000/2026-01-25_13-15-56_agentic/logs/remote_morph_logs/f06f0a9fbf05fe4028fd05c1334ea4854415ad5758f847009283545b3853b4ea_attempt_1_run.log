import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype, unifDistN]
  classical
  simp only [PMF.uniformOfFintype_apply, Finset.sum_const, nsmul_eq_mul, Finset.card_univ,
    Fintype.card_pi, Fintype.card_fin, Digit, one_div]
  let S : Finset (DigitSeq n) := Finset.univ
  let Q2 := fun (d : Digit) ↦ ¬ 2 ∣ (to_nat_digit d)
  let Q5 := fun (d : Digit) ↦ ¬ 5 ∣ (to_nat_digit d)
  let E2 := S.filter (fun s ↦ ∀ i, Q2 (s i))
  let E5 := S.filter (fun s ↦ ∀ i, Q5 (s i))
  have h_card (P : Digit → Prop) [DecidablePred P] :
      (Finset.univ.filter (fun s : DigitSeq n ↦ ∀ i, P (s i))).card = (Finset.univ.filter P).card ^ n := by
    let f : {s : DigitSeq n // ∀ i, P (s i)} ≃ (Fin n → {d : Digit // P d}) :=
      (Equiv.subtypePi (fun _ => Digit) (fun _ d => P d)).symm
    have h1 : (Finset.univ.filter (fun s : DigitSeq n ↦ ∀ i, P (s i))).card = Fintype.card {s : DigitSeq n // ∀ i, P (s i)} := by
      simp [Finset.card_filter, Fintype.card_subtype, Finset.card_univ]
    rw [h1, Fintype.card_congr f, Fintype.card_pi, Fintype.card_fin, Fintype.card_subtype, Finset.card_univ]
  have hE2 : E2.card = 5 ^ n := by rw [h_card]; congr; decide
  have hE5 : E5.card = 8 ^ n := by rw [h_card]; congr; decide
  have hE25 : (E2 ∩ E5).card = 4 ^ n := by rw [← Finset.filter_and, h_card]; congr; simp [Q2, Q5]; decide
  have h_good : S.filter is_good_seq = (E2 ∪ E5)ᶜ := by
    ext s; simp [is_good_seq, E2, E5, Q2, Q5, to_nat_digit]
    rw [Nat.mul_dvd_iff_dvd_and_dvd_of_coprime (by norm_num : Nat.Coprime 2 5),
      Nat.Prime.dvd_prod_iff Nat.prime_two, Nat.Prime.dvd_prod_iff Nat.prime_five]
    push_neg; rfl
  rw [h_good, Finset.card_compl, Finset.card_union]
  simp only [hE2, hE5, hE25, ENNReal.ofNat_pow, Fintype.card_pi, Fintype.card_fin, Digit]
  have h9n : (9 : ENNReal) ^ n ≠ 0 := by norm_num
  have h9n' : (9 : ENNReal) ^ n ≠ ⊤ := by norm_num
  rw [ENNReal.ofNat_sub (Finset.card_le_univ _), ENNReal.sub_div, ENNReal.div_self h9n h9n']
  rw [ENNReal.ofNat_sub (Finset.card_inter_le_left _ _), ENNReal.sub_div, ENNReal.ofNat_add, ENNReal.add_div]
  repeat' rw [← ENNReal.div_pow]
  norm_num

end Usa1972P3
```
