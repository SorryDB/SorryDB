lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  rw [decomposition_of_refinement, sSup_iUnion]
  apply le_antisymm
  · refine iSup_le (fun D hD ↦ ?_)
    have ⟨a, ha, hasup⟩ : ∃ a ∈ S, sSup D = a := by
      let a := sSup D
      use a
      have : ∃! D' ∈ R, a = sSup D' := sorry
      exact ⟨sorry, rfl⟩
    rw [← hasup]
    exact le_sSup ha
  · refine sSup_le (fun a ha ↦ ?_)
    obtain ⟨D, hD, hD_spec⟩ := (R.carrier_span a).exists
    rw [hD_spec]
    exact le_iSup₂ D hD
```
