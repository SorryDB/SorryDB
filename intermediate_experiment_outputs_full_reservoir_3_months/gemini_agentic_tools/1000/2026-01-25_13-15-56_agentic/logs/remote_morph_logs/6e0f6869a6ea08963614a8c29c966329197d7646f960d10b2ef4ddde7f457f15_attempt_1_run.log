def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  propext ⟨fun h => by
    subst h; unfold beq
    have h_go : ∀ i, beq.go x x i := by
      intro i; induction i with
      | zero => simp [beq.go]
      | succ i ih => simp [beq.go, ih]
    apply h_go,
  fun h => by
    rw [self_eq_bb x, self_eq_bb y]; unfold bb
    congr; funext i _; congr
    let n := w - 1
    have hg : ∀ j, beq.go x y j → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
      intro j hj k hk; induction j generalizing k with
      | zero =>
        simp [beq.go] at hj; have : k = 0 := Nat.eq_zero_of_le_zero hk; subst this
        exact hj
      | succ j ih =>
        simp [beq.go] at hj
        cases Nat.eq_or_lt_of_le hk with
        | inl he => subst he; exact hj.1
        | inr hl => exact ih hj.2 k (Nat.le_of_lt_succ hl)
    unfold beq at h
    have hi : i.val ≤ n := by
      cases w with
      | zero => cases i
      | succ w' => exact Nat.le_of_lt_succ i.isLt
    have h_res := hg n h (n - i.val) (Nat.sub_le n i.val)
    rw [Nat.sub_sub_self hi] at h_res; exact h_res⟩
