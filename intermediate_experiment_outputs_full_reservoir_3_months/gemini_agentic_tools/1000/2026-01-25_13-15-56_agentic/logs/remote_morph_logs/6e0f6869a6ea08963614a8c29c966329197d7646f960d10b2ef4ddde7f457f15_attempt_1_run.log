def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  propext ⟨fun h => by
    subst h; unfold beq
    induction (w - 1) with
    | zero => simp [beq.go]
    | succ i ih => simp [beq.go, ih],
  fun h => by
    rw [self_eq_bb x, self_eq_bb y]
    unfold bb; congr; funext i _
    unfold beq at h
    have h_go : ∀ j, beq.go x y j = true → ∀ k ≤ j, x.getLsbD ((w - 1) - k) = y.getLsbD ((w - 1) - k) := by
      intro j hj k hk
      induction j generalizing k with
      | zero =>
        unfold beq.go at hj
        have : k = 0 := Nat.eq_zero_of_le_zero hk
        subst this
        exact Bool.beq_eq_true_iff.mp hj
      | succ j ih =>
        unfold beq.go at hj
        rw [Bool.and_eq_true, Bool.beq_eq_true_iff] at hj
        cases Nat.eq_or_lt_of_le hk with
        | inl he => subst he; exact hj.1
        | inr hl => exact ih hj.2 k (Nat.le_of_lt_succ hl)
    cases w with
    | zero => cases i
    | succ w' =>
      let n := w'
      have hi : i.val ≤ n := Nat.le_of_lt_succ i.isLt
      have h_res := h_go n h (n - i.val) (Nat.sub_le n i.val)
      rw [Nat.sub_sub_self hi] at h_res
      simp [h_res]⟩
