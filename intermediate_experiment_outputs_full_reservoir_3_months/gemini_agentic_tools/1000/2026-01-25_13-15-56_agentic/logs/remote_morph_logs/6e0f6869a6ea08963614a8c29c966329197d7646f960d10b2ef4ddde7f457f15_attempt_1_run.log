def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext
  constructor
  · intro h; subst h; unfold beq
    induction w - 1 with
    | zero => simp [beq.go]
    | succ i ih => simp [beq.go, ih]
  · intro h; apply BitVec.ext; intro i; unfold beq at h
    let n := w - 1
    have hi : i.val ≤ n := Nat.le_of_lt_succ (by
      have : w = n + 1 := (Nat.succ_pred_eq_of_pos (Fin.pos i)).symm
      rw [this] at i; exact i.isLt)
    have hg : ∀ j, beq.go x y j → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
      intro j hj k hk
      induction j generalizing k with
      | zero =>
        have : k = 0 := Nat.eq_zero_of_le_zero hk; subst this
        simp [beq.go] at hj; exact hj
      | succ j ih =>
        simp [beq.go] at hj
        cases Nat.eq_or_lt_of_le hk with
        | inl heq => subst heq; exact hj.1
        | inr hlt => exact ih hj.2 (Nat.le_of_lt_succ hlt)
    have := hg n h (n - i.val) (Nat.sub_le n i.val)
    rw [Nat.sub_sub_self hi] at this; exact this
```
