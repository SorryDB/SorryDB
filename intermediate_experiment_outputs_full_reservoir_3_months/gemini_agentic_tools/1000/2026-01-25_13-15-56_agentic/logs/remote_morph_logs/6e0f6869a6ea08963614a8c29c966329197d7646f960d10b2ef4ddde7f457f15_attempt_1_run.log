def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  propext ⟨fun h => by
    subst h; unfold beq
    induction (w - 1) with
    | zero => simp [beq.go]
    | succ i ih => simp [beq.go, ih],
  fun h => by
    cases w with
    | zero =>
      cases x; cases y; congr; apply Fin.eq_of_val_eq
      have hx := toFin.isLt; have hy := toFin.isLt
      simp [Nat.pow_zero] at hx hy
      have hvx : toFin.val = 0 := Nat.le_zero.mp (Nat.le_of_lt_succ hx)
      have hvy : toFin.val = 0 := Nat.le_zero.mp (Nat.le_of_lt_succ hy)
      rw [hvx, hvy]
    | succ w' =>
      rw [self_eq_bb x, self_eq_bb y]
      unfold bb; congr; funext i s
      let n := w'
      unfold beq at h
      have h_go : ∀ j, beq.go x y j = true → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
        intro j hj k hk
        induction j generalizing k with
        | zero =>
          simp [beq.go] at hj
          have : k = 0 := Nat.le_zero.mp hk
          subst this
          cases hx : x.getLsbD n <;> cases hy : y.getLsbD n <;> simp [hx, hy] at hj
          · exact hx.trans hy.symm
        | succ j ih =>
          simp [beq.go, Bool.and_eq_true] at hj
          cases hj with | intro h1 h2 =>
          cases Nat.eq_or_lt_of_le hk with
          | inl he => 
            subst he
            cases hx : x.getLsbD (n - (j + 1)) <;> cases hy : y.getLsbD (n - (j + 1)) <;> simp [hx, hy] at h1
            · exact hx.trans hy.symm
          | inr hl =>
