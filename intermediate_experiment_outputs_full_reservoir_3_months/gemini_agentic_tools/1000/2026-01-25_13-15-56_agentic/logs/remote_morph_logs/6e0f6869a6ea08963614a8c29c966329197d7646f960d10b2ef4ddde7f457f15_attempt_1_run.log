def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · rintro rfl; unfold beq; induction w - 1 with
    | zero => simp [beq.go]
    | succ i ih => simp [beq.go, ih]
  · intro h; apply BitVec.ext; intro ⟨i, hi⟩; unfold beq at h
    let n := w - 1; have hi' : i ≤ n := Nat.le_of_lt_succ hi
    have : ∀ j, beq.go x y j → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
      intro j hg k hk; induction j with
      | zero =>
        have := Nat.eq_zero_of_le_zero hk; subst this
        simp [beq.go] at hg; exact hg
      | succ j ih =>
        simp [beq.go] at hg; cases Nat.eq_or_lt_of_le hk with
        | inl heq => subst heq; simp [hg]
        | inr hlt => exact ih hg.2 k (Nat.le_of_lt_succ hlt)
    rw [← Nat.sub_sub_self hi']; exact this n h (n - i) (Nat.sub_le n i)
```
