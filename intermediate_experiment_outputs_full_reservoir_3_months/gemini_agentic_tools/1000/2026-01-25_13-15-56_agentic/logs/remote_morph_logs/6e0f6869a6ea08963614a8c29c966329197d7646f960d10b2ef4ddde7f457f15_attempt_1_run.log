def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  propext ⟨fun h => by
    subst h; unfold beq
    cases w with
    | zero => simp [beq.go]
    | succ w' =>
      induction w' with
      | zero => simp [beq.go]
      | succ i ih => simp [beq.go, ih],
  fun h => by
    rw [self_eq_bb x, self_eq_bb y]; unfold bb
    let n := w - 1
    have hg : ∀ j, beq.go x y j = true → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
      intro j hj k hk
      induction j generalizing k with
      | zero => simp [beq.go] at hj; rw [Nat.eq_zero_of_le_zero hk, hj]
      | succ j ih =>
        simp [beq.go] at hj
        cases Nat.eq_or_lt_of_le hk with
        | inl heq => rw [heq]; exact hj.1
        | inr hlt => exact ih hj.2 k (Nat.le_of_lt_succ hlt)
