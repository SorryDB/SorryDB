def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  propext ⟨fun h => by
    subst h; unfold beq
    let n := w - 1
    have h_go : ∀ i, beq.go x x i = true := by
      intro i
      induction i with
      | zero => simp [beq.go]
      | succ i ih => simp [beq.go, ih]
    apply h_go,
  fun h => by
    rw [self_eq_bb x, self_eq_bb y]
    unfold bb
    congr
    funext i _
    let n := w - 1
    unfold beq at h
    have h_go : ∀ j, beq.go x y j = true → ∀ k ≤ j, x.getLsbD (n - k) = y.getLsbD (n - k) := by
      intro j hj k hk
      induction j generalizing k with
      | zero =>
        simp [beq.go] at hj
        have : k = 0 := Nat.eq_zero_of_le_zero hk
        rw [this]
        cases hx : x.getLsbD n <;> cases hy : y.getLsbD n <;> simp [hx, hy] at hj <;> (rfl || contradiction)
      | succ j ih =>
        simp [beq.go, Bool.and_eq_true] at hj
        cases Nat.eq_or_lt_of_le hk with
        | inl he => 
          rw [he]
          cases hx : x.getLsbD (n - (j + 1)) <;> cases hy : y.getLsbD (n - (j + 1)) <;> simp [hx, hy] at hj <;> (rfl || contradiction)
        | inr hl =>
          exact ih hj.2 k (Nat.le_of_lt_succ hl)
    cases w with
    | zero => cases i
    | succ w' =>
      have hi : i.val ≤ n := Nat.le_of_lt_succ i.isLt
      have h_res := h_go n h (n - i.val) (Nat.sub_le n i.val)
      rwa [Nat.sub_sub_self hi] at h_res⟩

