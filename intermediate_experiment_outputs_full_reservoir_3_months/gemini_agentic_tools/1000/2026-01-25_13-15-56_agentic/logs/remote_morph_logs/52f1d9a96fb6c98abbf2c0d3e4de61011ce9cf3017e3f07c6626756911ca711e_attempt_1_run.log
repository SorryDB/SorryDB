@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have h_aux : ∀ {a b c : ℝ}, 0 ≤ a → 0 ≤ b → 0 ≤ c → a + b + c = 1 → a ≤ b → a ≤ c →
      0 ≤ b * c + c * a + a * b - 2 * a * b * c ∧ b * c + c * a + a * b - 2 * a * b * c ≤ (7 : ℝ) / (27 : ℝ) := by
    intro a b c ha hb hc habc hab hac
    have ha_le : a ≤ 1 / 3 := by linarith
    have hf : b * c + c * a + a * b - 2 * a * b * c = b * c * (1 - 2 * a) + a * (1 - a) := by nlinarith [habc]
    constructor
    · rw [hf]; nlinarith
    · rw [hf]
      have hbc : b * c ≤ (1 - a)^2 / 4 := by
        have : b + c = 1 - a := by linarith
        nlinarith
      have h1 : b * c * (1 - 2 * a) + a * (1 - a) ≤ (1 - a)^2 / 4 * (1 - 2 * a) + a * (1 - a) := by
        have : 1 - 2 * a ≥ 0 := by linarith
        nlinarith
      have h2 : (1 - a)^2 / 4 * (1 - 2 * a) + a * (1 - a) = 7 / 27 - (1 - 3 * a)^2 * (1 + 6 * a) / 108 := by ring
      have h3 : (1 - 3 * a)^2 * (1 + 6 * a) / 108 ≥ 0 := by nlinarith
      linarith
  have h_min : (x ≤ y ∧ x ≤ z) ∨ (y ≤ x ∧ y ≤ z) ∨ (z ≤ x ∧ z ≤ y) := by
    rcases le_total x y with hxy | hyx
    · rcases le_total x z with hxz | hzx
      · left; exact ⟨hxy, hxz⟩
      · right; right; exact ⟨hzx, by linarith⟩
    · rcases le_total y z with hyz | hzy
      · right; left; exact ⟨hyx, hyz⟩
      · right; right; exact ⟨by linarith, hzy⟩
  rcases h_min with h | h | h
  · exact h_aux h₀.1 h₀.2.1 h₀.2.2 h₁ h.1 h.2
  · have : y * z + z * x + x * y - 2 * x * y * z = x * z + z * y + y * x - 2 * y * x * z := by ring
    rw [this]
    exact h_aux h₀.2.1 h₀.1 h₀.2.2 (by linarith) h.1 h.2
  · have : y * z + z * x + x * y - 2 * x * y * z = x * y + y * z + z * x - 2 * z * x * y := by ring
    rw [this]
    exact h_aux h₀.2.2 h₀.1 h₀.2.1 (by linarith) h.1 h.2

