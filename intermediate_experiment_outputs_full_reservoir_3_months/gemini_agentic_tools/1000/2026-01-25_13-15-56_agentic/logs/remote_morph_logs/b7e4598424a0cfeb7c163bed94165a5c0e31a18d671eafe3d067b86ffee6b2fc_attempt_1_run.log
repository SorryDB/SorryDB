lemma mem_existsOf_of_flip {Hist L R lr_nlf} {tab : Tableau Hist (L, R, some lr_nlf)}
    (s : PathIn tab.flip) (s_in : s ∈ (exitsOf tab.flip : List (PathIn tab.flip)))
    : (PathIn_type_flip_flip ▸ s.flip) ∈ exitsOf tab := by
  induction tab generalizing s
  case lrep =>
    simp [exitsOf, Tableau.flip] at s_in
  case pdl nrep bas r next ih =>
    simp [exitsOf, Tableau.flip, Sequent.isLoaded, List.mem_map] at s_in ⊢
    rcases s_in with ⟨e, e_in, rfl⟩
    use PathIn_type_flip_flip ▸ e.flip
    simp [ih e_in, PathIn.flip]
  case loc nrep nbas lt next ih =>
    simp [exitsOf, Tableau.flip, Sequent.isLoaded, List.mem_flatMap, List.mem_attach, Subtype.exists, List.mem_map] at s_in
    rcases s_in with ⟨Yf, Yf_in, e, e_in, rfl⟩
    rcases exists_flip_of_endNodesOf Yf_in with ⟨Y, rfl, Y_in⟩
    simp [exitsOf, Sequent.isLoaded, List.mem_flatMap, List.mem_attach, List.mem_map]
    use Y, Y_in
    by_cases h : Y.isLoaded
    · simp [h]
      use PathIn_type_flip_flip ▸ e.flip
      simp [ih Y Y_in e e_in, PathIn.flip]
    · simp [h] at e_in ⊢
      subst e_in
      simp [PathIn.flip]
```
