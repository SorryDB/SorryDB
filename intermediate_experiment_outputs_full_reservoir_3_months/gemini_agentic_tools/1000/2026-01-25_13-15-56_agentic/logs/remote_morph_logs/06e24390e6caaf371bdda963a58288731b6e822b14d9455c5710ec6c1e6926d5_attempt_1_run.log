        map_eval_pi (fun _ ↦ gaussianReal 0 1), variance_gaussianReal 0 zero_lt_one, mul_one]
    · exact (indepFuns_pi_eval _).comp (fun i y ↦ y * L (stdOrthonormalBasis ℝ E i))
        (fun i ↦ measurable_id.mul_const _)
    · intro i _; exact Integrable.mul_const (integrable_eval_pi
        (memLp_one_iff_integrable.mp (memLp_id_gaussianReal 1))) _
  · rw [integral_finset_sum]
    · simp_rw [integral_mul_const, integral_eval_pi
        (memLp_one_iff_integrable.mp (memLp_id_gaussianReal 1)),
        integral_gaussianReal 0 1, mul_zero, Finset.sum_const_zero]
    · intro i _; exact Integrable.mul_const (integrable_eval_pi
        (memLp_one_iff_integrable.mp (memLp_id_gaussianReal 1))) _
