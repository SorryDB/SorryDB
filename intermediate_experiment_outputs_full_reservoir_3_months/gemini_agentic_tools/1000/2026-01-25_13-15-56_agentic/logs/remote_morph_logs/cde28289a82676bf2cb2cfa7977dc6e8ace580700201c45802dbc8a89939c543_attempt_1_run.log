lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕] [IsFiniteMeasure μ]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  have hXn : Integrable (X n) μ := hX.integrable n
  have hX0 : Integrable (X ⊥) μ := hX.integrable ⊥
  have h_int : Integrable (|X n| + |X ⊥|) μ := hXn.abs.add hX0.abs
  let Y := fun (p : Unit × ℕ) ↦ μ[|X n| + |X ⊥| | (hτ p.2).measurableSpace]
  have hY : UniformIntegrable Y 1 μ :=
    (uniformIntegrable_subsingleton (f := fun _ : Unit ↦ |X n| + |X ⊥|) le_rfl (by simp)
      (memLp_one_iff_integrable.2 h_int)).condExp' (fun i ↦ (hτ i).measurableSpace_le)
  uniformIntegrable_of_dominated (hY.comp (fun i ↦ ((), i)))
    (fun i ↦ (hX.integrable_stoppedValue (hτ i) (hτ_le i)).aestronglyMeasurable)
    (fun i ↦ ⟨i, by
      have h_le := stoppedValue_ae_le_condExp_of_le hX (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl)
      have h_ge : μ[X ⊥ | (hτ i).measurableSpace] ≤ᵐ[μ] stoppedValue X (τ i) :=
        hX.condExp_stoppedValue_ae_le (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le)
      filter_upwards [h_le, h_ge,
        condExp_mono (memLp_one_iff_integrable.1 (memLp_one_iff_integrable.2 hXn))
          (memLp_one_iff_integrable.1 (memLp_one_iff_integrable.2 h_int))
          (ae_of_all μ (fun ω ↦ (le_add_of_nonneg_right (abs_nonneg _)).trans (le_abs_self _))),
        condExp_mono (memLp_one_iff_integrable.1 (memLp_one_iff_integrable.2 hX0))
          (memLp_one_iff_integrable.1 (memLp_one_iff_integrable.2 h_int))
          (ae_of_all μ (fun ω ↦ (le_add_of_nonneg_left (abs_nonneg _)).trans (neg_le_abs_self _).symm))] with ω h_le_ω h_ge_ω h_M1 h_M2
      rw [Real.norm_eq_abs]
      refine abs_le_of_le_of_le (h_le_ω.trans h_M1) (h_M2.trans h_ge_ω)⟩)
```
