lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕] [IsFiniteMeasure μ]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let g := fun i ↦ μ[X n | (hτ i).measurableSpace]
  let h := fun i ↦ μ[X n - X ⊥ | (hτ i).measurableSpace]
  have hg : UniformIntegrable g 1 μ :=
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
      (memLp_one_iff_integrable.2 (hX.integrable n))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  have hh : UniformIntegrable h 1 μ :=
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n - X ⊥) le_rfl (by simp)
      (memLp_one_iff_integrable.2 ((hX.integrable n).sub (hX.integrable ⊥)))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  refine uniformIntegrable_of_dominated (hg.add le_rfl hh)
    (fun i ↦ (hX.integrable_stoppedValue (hτ i) (hτ_le i)).aestronglyMeasurable) (fun i ↦ ⟨i, ?_⟩)
  filter_upwards [hX.stoppedValue_ae_le_condExp_of_le (hτ i) (isStoppingTime_const 𝓕 n) (hτ_le i) (fun _ ↦ le_rfl),
    hX.stoppedValue_ae_le_condExp_stoppedValue (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le) (hτ_le i)] with ω h_le h_ge
  rw [Real.norm_eq_abs, abs_le]
  have h_bound : stoppedValue X (τ i) ω ≥ g i ω - h i ω := by
    simp only [g, h, sub_le_iff_le_add, ← condExp_add (hX.integrable n) ((hX.integrable n).sub (hX.integrable ⊥)).neg]
    simp only [sub_eq_add_neg, neg_add_rev, neg_neg, add_assoc, add_comm (X ⊥) _, ← add_assoc, add_neg_cancel_left]
    exact h_ge
  exact ⟨h_bound.trans (le_add_of_nonneg_right (abs_nonneg _)), h_le.trans (le_add_of_nonneg_right (abs_nonneg _))⟩

