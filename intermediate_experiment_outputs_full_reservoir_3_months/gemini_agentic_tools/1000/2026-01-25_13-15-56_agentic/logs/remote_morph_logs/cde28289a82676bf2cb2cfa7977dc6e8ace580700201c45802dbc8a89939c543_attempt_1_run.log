    [SigmaFiniteFiltration μ 𝓕] [IsFiniteMeasure μ]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M := fun i ↦ μ[X n | (hτ i).measurableSpace]
  have hM : UniformIntegrable M 1 μ :=
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
      (fun _ ↦ memLp_one_iff_integrable.2 (Submartingale.integrable hX n))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  let Z := fun i ↦ M i - stoppedValue X (τ i)
  have hZ : UniformIntegrable Z 1 μ :=
    uniformIntegrable_of_dominated
      (((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n - X ⊥) le_rfl (by simp)
        (fun _ ↦ memLp_one_iff_integrable.2 ((Submartingale.integrable hX n).sub (Submartingale.integrable hX ⊥)))).condExp'
