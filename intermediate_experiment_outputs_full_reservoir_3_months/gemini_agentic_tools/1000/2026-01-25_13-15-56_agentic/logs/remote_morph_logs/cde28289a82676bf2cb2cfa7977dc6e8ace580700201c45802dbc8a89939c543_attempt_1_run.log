      (h𝓕 := fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  let Z := fun i ↦ M i - stoppedValue X (τ i)
  have hZ : UniformIntegrable Z 1 μ :=
