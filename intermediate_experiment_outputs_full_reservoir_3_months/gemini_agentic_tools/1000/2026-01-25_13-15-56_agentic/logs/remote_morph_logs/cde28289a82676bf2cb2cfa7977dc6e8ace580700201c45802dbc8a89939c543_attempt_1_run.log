      (fun i ↦ ⟨i, by
        filter_upwards [hX.stoppedValue_ae_le_condExp_of_le (hτ i) (isStoppingTime_const 𝓕 n) (hτ_le i) (fun _ ↦ le_rfl),
          hX.condExp_stoppedValue_ae_le bot_le (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le) (hτ_le i) (fun _ ↦ bot_le)] with ω hle hge
        simp only [Z, M, Pi.sub_apply, norm_eq_abs, abs_of_nonneg (sub_nonneg.2 hle)]
        exact sub_le_sub_left hge _⟩)
  exact (hM.norm.add le_rfl hZ.norm).ae_eq (fun i ↦ ae_of_all _ (fun ω ↦ by
    simp only [M, Z, Pi.add_apply, Pi.norm_apply, norm_eq_abs]
