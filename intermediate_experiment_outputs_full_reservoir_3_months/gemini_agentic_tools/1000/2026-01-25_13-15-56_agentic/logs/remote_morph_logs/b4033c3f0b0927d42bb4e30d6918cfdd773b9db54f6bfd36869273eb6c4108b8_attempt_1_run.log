/-!

### E.3. The position when the velocity is zero

We show that the position is equal to `√(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) ` when
the velocity is zero, as long as the initial conditions are not both zero.
This is currently a TODO.

-/

lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hE := congr_fun (trajectory_energy S IC) t
  simp [energy, kineticEnergy, potentialEnergy, real_inner_self_eq_norm_sq] at hE
  have hω0 := ω_neq_zero S
  have hω2 := ω_sq S
  have hm0 : S.m ≠ 0 := fun h => hω0 (by rw [hω2, h, div_zero]; simp)
  have hk0 : S.k = S.m * S.ω^2 := by field_simp [hω2, hm0]; ring
  rw [← norm_sq_eq_zero, eq_comm, Real.sqrt_eq_iff_sq_eq (by positivity) (norm_nonneg _)]
  rw [hk0] at hE
  field_simp [hm0, hω0] at hE ⊢
  rw [← hE]
  simp
