/-!

### E.3. The position when the velocity is zero

We show that the position is equal to `√(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) ` when
the velocity is zero, as long as the initial conditions are not both zero.
This is currently a TODO.

-/

lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hE := congr_fun (trajectory_energy S IC) t
  simp [energy, kineticEnergy, potentialEnergy, real_inner_self_eq_norm_sq] at hE
  have hω0 := ω_neq_zero S
  have hω2 := ω_sq S
  have hm : S.m ≠ 0 := by
    intro h
    have h' := ω_sq S
    rw [h, div_zero] at h'
    exact hω0 (sq_eq_zero_iff.mp h')
  have hk : S.k = S.m * S.ω^2 := by
    rw [hω2]
    field_simp [hm]
  rw [hk] at hE
  have hE' : ‖∂ₜ (IC.trajectory S) t‖^2 + S.ω^2 * ‖(IC.trajectory S) t‖^2 = ‖IC.v₀‖^2 + S.ω^2 * ‖IC.x₀‖^2 := by
    apply (mul_right_inj' (show (2⁻¹ * S.m : ℝ) ≠ 0 from by simp [hm])).mp
    rw [hE]
    ring
  rw [← norm_eq_zero, ← sq_eq_zero_iff, hE', eq_comm, Real.sqrt_eq_iff_sq_eq _ (norm_nonneg _)]
  · field_simp [hω0]
    constructor <;> intro h
    · nlinarith
    · field_simp [hω0] at h
      nlinarith
  · positivity
