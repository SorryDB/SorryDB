lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hE := congr_fun (trajectory_energy S IC) t
  simp [energy, kineticEnergy, potentialEnergy, real_inner_self_eq_norm_sq] at hE
  have hω0 := ω_neq_zero S
  have hm : S.m ≠ 0 := by
    intro h
    have h' : S.ω ^ 2 = 0 := by rw [ω_sq S, h, div_zero]
    exact hω0 (sq_eq_zero_iff.mp h')
  have hkm : S.k = S.m * S.ω ^ 2 := by
    have hωsq := ω_sq S
    field_simp [hωsq, hm]
  rw [← norm_eq_zero, ← sq_eq_zero_iff]
  rw [Real.sqrt_eq_iff_sq_eq (by positivity) (norm_nonneg _)]
  · field_simp [hω0]
    constructor <;> intro h <;> nlinarith [hE, hkm]
