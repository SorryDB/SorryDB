import CatDG.Diffeology.LocallyModelled

universe u

variable {X Y Z : Type u} [DiffeologicalSpace X] [DiffeologicalSpace Y] [DiffeologicalSpace Z]
  {n m k : ℕ} [hX : IsOrbifold n X] [hY : IsOrbifold m Y] [hZ : IsOrbifold k Z]

