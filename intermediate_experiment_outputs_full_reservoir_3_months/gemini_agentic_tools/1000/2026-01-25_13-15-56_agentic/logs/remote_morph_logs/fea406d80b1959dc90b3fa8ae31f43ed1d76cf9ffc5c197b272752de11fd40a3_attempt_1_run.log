import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let k := (n + 1).sqrt
  have hk_sq_le : k * k ≤ n + 1 := Nat.sqrt_le (n + 1)
  have hk_lt_succ_sq : n + 1 < (k + 1) * (k + 1) := Nat.lt_succ_sqrt (n + 1)
  have hk10 : 10 ≤ k := Nat.le_sqrt.mpr (by omega)
  let m := k - 1
  have hm : 9 ≤ m := by dsimp [m]; omega
  have hm_k : m + 1 = k := by dsimp [m]; omega
  let x := 2 * m * m - 4 * m
  let y := 2 * m * m + 1
  let z := 2 * m * m + 4 * m
  have hxm : 4 * m ≤ 2 * m * m := by nlinarith
  have hx_range : n ≤ x := by
    zify [hxm, hm_k] at hk_lt_succ_sq ⊢
    nlinarith
  have hz_range : z ≤ 2 * n := by
    zify [hxm, hm_k] at hk_sq_le ⊢
    nlinarith
  have hxy : x < y := by
    dsimp [x, y]
    have : 2 * m * m - 4 * m ≤ 2 * m * m := Nat.sub_le _ _
    exact this.trans_lt (Nat.lt_succ_self _)
  have hyz : y < z := by dsimp [y, z]; omega
  let I := Finset.Icc n (2 * n)
  have hxI : x ∈ I := Finset.mem_Icc.mpr ⟨hx_range, hxy.le.trans (hyz.le.trans hz_range)⟩
  have hyI : y ∈ I := Finset.mem_Icc.mpr ⟨hx_range.trans hxy.le, hyz.le.trans hz_range⟩
  have hzI : z ∈ I := Finset.mem_Icc.mpr ⟨(hx_range.trans hxy.le).trans hyz.le, hz_range⟩
  have hsqxy : IsSquare (x + y) := by
    use 2 * m - 1
    apply Nat.cast_inj (R := ℤ).mp
    push_cast
    rw [Nat.cast_sub hxm, Nat.cast_sub (by omega : 1 ≤ 2 * m)]
    dsimp [x, y]
    ring
  have hsqxz : IsSquare (x + z) := by
    use 2 * m
    apply Nat.cast_inj (R := ℤ).mp
    push_cast
    rw [Nat.cast_sub hxm]
    dsimp [x, z]
    ring
  have hsqyz : IsSquare (y + z) := by
    use 2 * m + 1
    apply Nat.cast_inj (R := ℤ).mp
    push_cast
    dsimp [y, z]
    ring
  by_cases hxS : x ∈ S
  · by_cases hyS : y ∈ S
    · left; exact ⟨x, hxS, y, hyS, hxy.ne, hsqxy⟩
    · by_cases hzS : z ∈ S
      · left; exact ⟨x, hxS, z, hzS, (hxy.trans hyz).ne, hsqxz⟩
      · right; exact ⟨y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, hyz.ne, hsqyz⟩
  · by_cases hyS : y ∈ S
    · by_cases hzS : z ∈ S
      · left; exact ⟨y, hyS, z, hzS, hyz.ne, hsqyz⟩
      · right; exact ⟨x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, (hxy.trans hyz).ne, hsqxz⟩
    · right; exact ⟨x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, hxy.ne, hsqxy⟩

end IMO2021P1
