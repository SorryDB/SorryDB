import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let I := Finset.Icc n (2 * n)
  let m := (n + 1).sqrt - 1
  have hm : 9 ≤ m := Nat.sub_le_sub_right (Nat.le_sqrt.mpr (by linarith)) 1
  let y := 2 * m ^ 2 - 4 * m
  let x := 2 * m ^ 2 + 1
  let z := 2 * m ^ 2 + 4 * m
  have h1 : (m + 1) ^ 2 ≤ n + 1 := Nat.sqrt_le (n + 1)
  have h2 : n + 1 < (m + 2) ^ 2 := Nat.lt_succ_sqrt (n + 1)
  have hy : n ≤ y := by zify [y, hm]; zify at h2; nlinarith
  have hz : z ≤ 2 * n := by zify [z, hm]; zify at h1; nlinarith
  have hyx : y < x := by dsimp [y, x]; zify [hm]; linarith
  have hxz : x < z := by dsimp [x, z]; zify [hm]; linarith
  have hyI : y ∈ I := Finset.mem_Icc.mpr ⟨hy, by linarith⟩
  have hxI : x ∈ I := Finset.mem_Icc.mpr ⟨by linarith, by linarith⟩
  have hzI : z ∈ I := Finset.mem_Icc.mpr ⟨by linarith, hz⟩
  have hsyx : IsSquare (y + x) := ⟨2 * m - 1, by zify [y, x, hm]; ring⟩
  have hsyz : IsSquare (y + z) := ⟨2 * m, by zify [y, z, hm]; ring⟩
  have hsxz : IsSquare (x + z) := ⟨2 * m + 1, by zify [x, z, hm]; ring⟩
