import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let Sn := Nat.sqrt (n + 1)
  let m := Sn - 1
  have hSn : 10 ≤ Sn := Nat.le_sqrt.mpr (by omega)
  have hm : 9 ≤ m := Nat.sub_le_sub_right hSn 1
  let y := 2 * m * (m - 2)
  let x := 2 * m ^ 2 + 1
  let z := 2 * m ^ 2 + 4 * m
  have hy : n ≤ y := by
    have hSn_lt := Nat.lt_sqrt_succ (n + 1)
    zify [hm, hSn] at *
    omega
  have hz : z ≤ 2 * n := by
    have hSn_le := Nat.sqrt_le (n + 1)
    zify [hm, hSn] at *
    omega
  have hyx : y < x := by dsimp [y, x]; omega
  have hxz : x < z := by dsimp [x, z]; omega
  let I := Finset.Icc n (2 * n)
  have hyI : y ∈ I := Finset.mem_Icc.mpr ⟨hy, by omega⟩
  have hxI : x ∈ I := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hzI : z ∈ I := Finset.mem_Icc.mpr ⟨by omega, hz⟩
  have hsyx : IsSquare (y + x) := ⟨2 * m - 1, by zify [hm]; dsimp [y, x]; ring⟩
  have hsyz : IsSquare (y + z) := ⟨2 * m, by zify [hm]; dsimp [y, z]; ring⟩
  have hsxz : IsSquare (x + z) := ⟨2 * m + 1, by zify [hm]; dsimp [x, z]; ring⟩
  if hyS : y ∈ S then
    if hxS : x ∈ S then left; use y, hyS, x, hxS, hyx.ne, hsyx
    else if hzS : z ∈ S then left; use y, hyS, z, hzS, (hyx.trans hxz).ne, hsyz
    else right; use x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, hxz.ne, hsxz
  else
    if hxS : x ∈ S then
      if hzS : z ∈ S then left; use x, hxS, z, hzS, hxz.ne, hsxz
      else right; use x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, hxz.ne, hsxz
    else right; use y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, hyx.ne, hsyx

end IMO2021P1

