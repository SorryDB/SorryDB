    have h10'' : 10 ≤ (n + 1).sqrt := Nat.le_sqrt.mpr h10'
    omega
  have hm_sqrt : (n + 1).sqrt = m + 1 := by
    have h10 : 10 ≤ (n + 1).sqrt := Nat.le_sqrt.mpr (by omega)
    omega
  have h_sqrt_le : (m + 1) ^ 2 ≤ n + 1 := by
    rw [← hm_sqrt]; apply Nat.sqrt_le
  have h_lt_sqrt_succ : n + 1 < (m + 2) ^ 2 := by
