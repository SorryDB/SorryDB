import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let m := Nat.sqrt (n + 1) - 1
  have hm : 9 ≤ m := by
    have h10 : 10 ≤ Nat.sqrt (n + 1) := Nat.le_sqrt.mpr (by linarith)
    exact Nat.le_sub_one_of_le (by linarith) h10
  let y := 2 * m ^ 2 - 4 * m
  let x := 2 * m ^ 2 + 1
  let z := 2 * m ^ 2 + 4 * m
  have hy : n ≤ y := by
    have h_sqrt := Nat.lt_sqrt.mp (Nat.lt_succ_self (Nat.sqrt (n + 1)))
    have : m ^ 2 - 8 * m ≥ 2 := by
      rw [Nat.sq, ← Nat.mul_sub_left_distrib]
      calc m * (m - 8) ≥ 9 * (9 - 8) := Nat.mul_le_mul hm (by omega)
           _ = 9 := by norm_num
           _ ≥ 2 := by norm_num
    omega
  have hz : z ≤ 2 * n := by
    have h_sqrt := Nat.sqrt_le (n + 1)
    have : (m + 1) ^ 2 ≤ n + 1 := Nat.pow_le_pow_of_le_left h_sqrt 2
    rw [Nat.sq, Nat.succ_pow_two] at this
    omega
  have hyx : y < x := by omega
  have hxz : x < z := by omega
  let I := Finset.Icc n (2 * n)
  have hyI : y ∈ I := Finset.mem_Icc.mpr ⟨hy, by omega⟩
  have hxI : x ∈ I := Finset.mem_Icc.mpr ⟨by omega, by omega⟩
  have hzI : z ∈ I := Finset.mem_Icc.mpr ⟨by omega, hz⟩
  have hsyx : IsSquare (y + x) := ⟨2 * m - 1, by
    rw [Nat.sq] at *; have : 4 * m ≤ 4 * m * m := by linarith
    zify [this]; ring⟩
  have hsyz : IsSquare (y + z) := ⟨2 * m, by rw [Nat.sq] at *; ring⟩
  have hsxz : IsSquare (x + z) := ⟨2 * m + 1, by rw [Nat.sq] at *; ring⟩
  if hxS : x ∈ S then
    if hyS : y ∈ S then
      left; use y, hyS, x, hxS, hyx.ne, hsyx
    else if hzS : z ∈ S then
      left; use x, hxS, z, hzS, hxz.ne, hsxz
    else
      right; use y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, (hyx.trans hxz).ne, hsyz
  else
    if hyS : y ∈ S then
      if hzS : z ∈ S then
        left; use y, hyS, z, hzS, (hyx.trans hxz).ne, hsyz
      else
        right; use x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, hxz.ne, hsxz
    else
      right; use y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, hyx.ne.symm, hsyx

end IMO2021P1
