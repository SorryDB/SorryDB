import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let I := Finset.Icc n (2 * n)
  let m := (n + 1).sqrt - 1
  have h10 : 10 ≤ (n + 1).sqrt := Nat.le_sqrt.mpr (by omega)
  have h_sqrt : (n + 1).sqrt = m + 1 := by dsimp [m]; omega
  have hm : 9 ≤ m := by dsimp [m]; omega
  have h1 : (m + 1) * (m + 1) ≤ n + 1 := h_sqrt ▸ Nat.sqrt_le (n + 1)
  have h2 : n + 1 < (m + 2) * (m + 2) := h_sqrt ▸ Nat.lt_succ_sqrt (n + 1)
  let x := 2 * m ^ 2 - 4 * m
  let y := 2 * m ^ 2 + 1
  let z := 2 * m ^ 2 + 4 * m
  have hxm : 4 * m ≤ 2 * m ^ 2 := by nlinarith
  have hx : n ≤ x := by
    dsimp [x]; apply Int.le_of_ofNat_le; rw [Nat.cast_sub hxm]
    zify at h2 ⊢; nlinarith
  have hz : z ≤ 2 * n := by dsimp [z]; zify at h1; nlinarith
  have hxy : x < y := by dsimp [x, y]; zify [hxm]; nlinarith
  have hyz : y < z := by dsimp [y, z]; nlinarith
  have hxI : x ∈ I := Finset.mem_Icc.mpr ⟨hx, (hxy.trans hyz).le.trans hz⟩
  have hyI : y ∈ I := Finset.mem_Icc.mpr ⟨hx.trans hxy.le, hyz.le.trans hz⟩
  have hzI : z ∈ I := Finset.mem_Icc.mpr ⟨hx.trans (hxy.trans hyz).le, hz⟩
  have hsqxy : IsSquare (x + y) := ⟨2 * m - 1, by
    apply Nat.cast_inj (R := ℤ).mp; push_cast; rw [Nat.cast_sub hxm]; ring⟩
  have hsqxz : IsSquare (x + z) := ⟨2 * m, by
    apply Nat.cast_inj (R := ℤ).mp; push_cast; rw [Nat.cast_sub hxm]; ring⟩
  have hsqyz : IsSquare (y + z) := ⟨2 * m + 1, by
    apply Nat.cast_inj (R := ℤ).mp; push_cast; ring⟩
  by_cases hxS : x ∈ S
  · by_cases hyS : y ∈ S
    · left; exact ⟨x, hxS, y, hyS, hxy.ne, hsqxy⟩
    · by_cases hzS : z ∈ S
      · left; exact ⟨x, hxS, z, hzS, (hxy.trans hyz).ne, hsqxz⟩
      · right; exact ⟨y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, hyz.ne, hsqyz⟩
  · by_cases hyS : y ∈ S
    · by_cases hzS : z ∈ S
      · left; exact ⟨y, hyS, z, hzS, hyz.ne, hsqyz⟩
      · right; exact ⟨x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, z, Finset.mem_sdiff.mpr ⟨hzI, hzS⟩, (hxy.trans hyz).ne, hsqxz⟩
    · right; exact ⟨x, Finset.mem_sdiff.mpr ⟨hxI, hxS⟩, y, Finset.mem_sdiff.mpr ⟨hyI, hyS⟩, hxy.ne, hsqxy⟩

end IMO2021P1

