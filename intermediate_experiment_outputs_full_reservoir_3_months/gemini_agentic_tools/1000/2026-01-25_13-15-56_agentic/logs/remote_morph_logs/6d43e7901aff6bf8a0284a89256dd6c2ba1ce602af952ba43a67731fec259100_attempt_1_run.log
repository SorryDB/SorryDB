/- The Ackermann function, defined using pattern matching notation. -/
def A : ℕ → ℕ → ℕ
| 0,     n     => n + 1
| m + 1, 0     => A m 1
| m + 1, n + 1 => A m (A (m + 1) n)

def myA : ℕ → ℕ → ℕ :=
  Nat.rec (motive := fun _ => ℕ → ℕ) (fun n => n + 1)
    (fun m f_m => Nat.rec (motive := fun _ => ℕ) (f_m 1) (fun n f_mn => f_m f_mn))

example : A = myA := by
  funext m n
  induction m generalizing n with
  | zero => rw [A]; rfl
  | succ m ih =>
    induction n with
    | zero => rw [A, ih]; rfl
    | succ n ih_n => rw [A, ih_n, ih]; rfl
```
