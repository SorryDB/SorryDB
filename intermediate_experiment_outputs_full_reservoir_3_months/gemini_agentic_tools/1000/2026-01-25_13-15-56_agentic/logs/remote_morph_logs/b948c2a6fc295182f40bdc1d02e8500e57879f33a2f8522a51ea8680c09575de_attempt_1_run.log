  r := LoopWalkEquiv n
  iseqv := by
    constructor
    · intro x
      let s := Equiv.refl (Fin n)
      unfold LoopWalkEquiv
      use s
      have hs (y : Fin n):  s y = y := by
        unfold s
        simp
      use hs x.1
      induction x.2 with
