      cases h_uv; cases h_pq
      use s.symm, (s.symm_apply_apply u)
      have h_id {u' v'} (p' : (K n).LoopWalk u' v') : permMapWalk n (Equiv.refl _) p' = p' := by
        induction p' with
        | nil => rfl
        | cons h q ih => simp [permMapWalk, LoopWalk.map, ih, permMap', permMap]
        | loop q ih => simp [permMapWalk, LoopWalk.map, ih, permMap', permMap]
      have h_comp {u' v'} (s1 s2 : Equiv.Perm (Fin n)) (p' : (K n).LoopWalk u' v') :
        permMapWalk n s2 (permMapWalk n s1 p') = permMapWalk n (s1.trans s2) p' := by
        induction p' with
