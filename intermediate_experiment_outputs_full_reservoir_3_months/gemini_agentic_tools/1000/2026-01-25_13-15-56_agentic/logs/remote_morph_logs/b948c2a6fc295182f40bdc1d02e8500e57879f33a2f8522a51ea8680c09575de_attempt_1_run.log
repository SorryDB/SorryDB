          permMapWalk n s2 (permMapWalk n s1 p) = permMapWalk n (s1.trans s2) p := by
        induction p with
        | nil => rfl
        | cons h q ih => simp [permMapWalk, LoopWalk.map, ih]
        | loop q ih => simp [permMapWalk, LoopWalk.map, ih]
      have h_id {u v} (p : (K n).LoopWalk u v) : permMapWalk n (Equiv.refl _) p = p := by
