        | cons h q ih => simp [permMapWalk, LoopWalk.map, ih, permMap', permMap, Equiv.trans_apply]
        | loop q ih => simp [permMapWalk, LoopWalk.map, ih, permMap', permMap]
      rw [h_comp, Equiv.self_trans_symm, h_id]
