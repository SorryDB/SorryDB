def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    have h_id {u v} (p : (K n).LoopWalk u v) : permMapWalk n (Equiv.refl _) p = p := by
      induction p with
      | nil => rfl
      | cons h q ih => simp [permMapWalk, LoopWalk.map, ih]
      | loop q ih => simp [permMapWalk, LoopWalk.map, ih]
    have h_comp {u v} (s1 s2 : Equiv.Perm (Fin n)) (p : (K n).LoopWalk u v) :
        permMapWalk n s2 (permMapWalk n s1 p) = permMapWalk n (s1.trans s2) p := by
      induction p with
      | nil => rfl
      | cons h q ih => simp [permMapWalk, LoopWalk.map, ih]
      | loop q ih => simp [permMapWalk, LoopWalk.map, ih]
    constructor
    · rintro ⟨u, p⟩; use Equiv.refl _, rfl; apply h_id
    · rintro ⟨u, p⟩ ⟨v, q⟩ ⟨s, h_eq, h_p⟩
      subst h_eq; simp at h_p; subst h_p
      use s.symm, rfl; simp [permMapWalk, h_comp, h_id]
    · rintro ⟨u, p⟩ ⟨v, q⟩ ⟨w, r⟩ ⟨s1, h_eq1, h_p1⟩ ⟨s2, h_eq2, h_p2⟩
      subst h_eq1; simp at h_p1; subst h_p1
      subst h_eq2; simp at h_p2; subst h_p2
      use s1.trans s2, rfl; simp [permMapWalk, h_comp]

