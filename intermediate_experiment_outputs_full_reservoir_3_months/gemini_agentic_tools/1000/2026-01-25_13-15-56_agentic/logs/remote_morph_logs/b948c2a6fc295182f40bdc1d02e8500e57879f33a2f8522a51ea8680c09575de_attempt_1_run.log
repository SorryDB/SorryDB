def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    let action (s : Equiv.Perm (Fin n)) (x : ClosedLoopWalk (K n)) : ClosedLoopWalk (K n) :=
      ⟨s x.1, permMapWalk n s x.2⟩
    have h_id (x : ClosedLoopWalk (K n)) : action (Equiv.refl _) x = x := by
      cases x with | mk u p =>
      suffices ∀ {u v} (p : (K n).LoopWalk u v), p.map (K n) (permMap' n (Equiv.refl _)) = p from Sigma.ext rfl (this p)
      intro u v p; induction p with
      | nil => rfl
      | cons h p ih => simp [LoopWalk.map, ih]; congr
      | loop p ih => simp [LoopWalk.map, ih]; congr
    have h_comp (s1 s2 : Equiv.Perm (Fin n)) (x : ClosedLoopWalk (K n)) :
      action s2 (action s1 x) = action (s1.trans s2) x := by
      cases x with | mk u p =>
      suffices ∀ {u v} (p : (K n).LoopWalk u v), (p.map (K n) (permMap' n s1)).map (K n) (permMap' n s2) = p.map (K n) (permMap' n (s1.trans s2)) from Sigma.ext rfl (this p)
      intro u v p; induction p with
      | nil => rfl
      | cons h p ih => simp [LoopWalk.map, ih]; congr
      | loop p ih => simp [LoopWalk.map, ih]; congr
    constructor
