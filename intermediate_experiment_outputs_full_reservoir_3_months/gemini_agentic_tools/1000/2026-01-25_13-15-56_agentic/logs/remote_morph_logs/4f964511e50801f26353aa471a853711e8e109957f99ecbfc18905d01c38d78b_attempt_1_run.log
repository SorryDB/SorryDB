/-- The center of mass of a solid sphere located at the origin is `0`. -/
lemma solidSphere_centerOfMass {d : ℕ} (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere d.succ m R).centerOfMass = 0 := by
  ext i
  simp [centerOfMass, solidSphere, solidSphere_mass m R hr]
  have h1 : ∫ x in Metric.closedBall (0 : Space d.succ) R, x i ∂volume = 0 := by
    let s := Metric.closedBall (0 : Space d.succ) R
    have h_sym : ∫ x in s, x i ∂volume = ∫ x in s, (-x) i ∂volume := by
      rw [← MeasureTheory.integral_comp_neg (μ := volume), Measure.map_neg_volume]
      congr 1
      ext x
      simp [Metric.closedBall, dist_neg_zero]
    simp only [Pi.neg_apply, integral_neg] at h_sym
    exact self_eq_neg.mp h_sym
  simp [h1]

end RigidBody
