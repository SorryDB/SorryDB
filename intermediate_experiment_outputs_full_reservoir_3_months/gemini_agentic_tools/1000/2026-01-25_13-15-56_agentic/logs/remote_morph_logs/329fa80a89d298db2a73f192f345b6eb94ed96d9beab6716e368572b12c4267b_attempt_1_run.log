lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  have h_norm : ‖μ.integral‖ = 0 := by
    apply ContinuousLinearMap.opNorm_eq_zero.mpr
    ext f
    exact h f
  rw [← ComplexMeasure.norm_integral_eq_variation μ] at h_norm
  have h_var_univ : μ.variation Set.univ = 0 :=
    (ENNReal.toReal_eq_zero_iff.mp h_norm).resolve_right
      μ.isFiniteMeasure_ennreal_variation.measure_univ_lt_top.ne
  ext i hi
  have h_le := VectorMeasure.ennnorm_apply_le_variation μ i
  have h_i_zero : μ.variation i = 0 :=
    Measure.measure_mono_null (Set.subset_univ i) h_var_univ
  rw [h_i_zero] at h_le
  exact nnnorm_eq_zero.mp (ENNReal.coe_eq_zero.mp (le_zero_iff.mp h_le))
```
