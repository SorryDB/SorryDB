lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  apply VectorMeasure.eq_zero_of_totalVariation_eq_zero
  apply MeasureTheory.Measure.eq_zero_of_forall_lintegral_eq_zero
  intro f hf
  /- The total variation measure |μ| is a finite Borel measure on a locally compact
  Hausdorff space. The integral of any f ∈ C₀(X) with respect to μ is zero.
  By the polar decomposition dμ = h d|μ| and the density of continuous functions
  vanishing at infinity in L¹(|μ|), the total variation |μ| must be zero. -/
  rw [← ENNReal.toReal_eq_zero_iff]
  · have h_norm : ‖μ.integral‖ = 0 := by
      ext f
      exact h f
    /- In the context of Riesz Representation, the norm of the linear functional
    is equal to the total variation of the measure. -/
    rw [← ComplexMeasure.totalVariation_univ_eq_norm_integral μ]
    simp [h_norm]
  · exact μ.isFiniteMeasure_ennreal_variation.measure_univ_lt_top.ne
```
