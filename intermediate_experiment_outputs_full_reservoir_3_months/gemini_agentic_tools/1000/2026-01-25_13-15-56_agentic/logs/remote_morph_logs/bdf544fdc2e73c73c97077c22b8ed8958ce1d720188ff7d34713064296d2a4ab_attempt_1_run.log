  have f_range : ‚ąÄ j, (j : ‚Ą§) + 1 ‚Č§ f j ‚ąß f j ‚Č§ (j : ‚Ą§) + 2015 := by
    intro j; have := hi j; omega
  let D : ‚Ąē ‚Üí ‚Ą§ := fun n => n - (Finset.filter (fun j : ‚Ąē+ => f j ‚Č§ n) (Finset.Icc 1 (PNat.mk (max 1 n) (by omega)))).card
  have D_mono : ‚ąÄ n, D n ‚Č§ D (n + 1) := sorry
