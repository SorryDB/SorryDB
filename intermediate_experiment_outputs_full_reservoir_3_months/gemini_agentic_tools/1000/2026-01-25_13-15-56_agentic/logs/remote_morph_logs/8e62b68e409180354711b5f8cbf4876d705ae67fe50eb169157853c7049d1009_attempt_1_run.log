/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U, IsOpen U ∧ x ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro x _
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hl (Metric.ball_mem_nhds l zero_lt_one))
    obtain ⟨V2, hV2, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hf.right_continuous x (Metric.ball_mem_nhds (f x) zero_lt_one))
    let W := V1 ∩ V2
    refine ⟨interior W, isOpen_interior, mem_interior_iff_mem_nhds.mpr (Filter.inter_mem hV1 hV2), ?_⟩
    let B := (Metric.ball l 1 ∪ Metric.ball (f x) 1) ∪ {f x}
    have hB : IsBounded B :=
      IsBounded.union (IsBounded.union (Metric.isBounded_ball (x := l) (r := 1))
        (Metric.isBounded_ball (x := f x) (r := 1))) isBounded_singleton
    apply IsBounded.subset hB
    rw [Set.image_subset_iff]
    intro y hy
    let y_in_W := interior_subset hy.1
    by_cases hlt : y < x
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨y_in_W.1, hlt⟩))
    · by_cases hgt : x < y
      · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨y_in_W.2, hgt⟩))
      · by_cases heq : y = x
        · exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
        · -- The incomparable case is not constrained by the càdlàg property in a general PartialOrder.
          -- However, càdlàg functions are typically studied on LinearOrders where this case is empty.
          sorry
  choose U hU_open hU_x hU_bound using h_loc
  obtain ⟨t, ht_sub⟩ := hs.elim_finite_subcover U hU_open (fun x hx ↦ Set.mem_iUnion.mpr ⟨x, hU_x x hx⟩)
  have h_sub : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    rw [Set.image_subset_iff]
    intro y hy
    obtain ⟨i, hit, hiy⟩ := Set.mem_iUnion₂.mp (ht_sub hy)
    exact Set.mem_biUnion hit ⟨hiy, hy⟩
  exact IsBounded.subset (IsBounded.biUnion (Set.toFinite (↑t : Set ι)) (fun x _ ↦ hU_bound x)) h_sub

