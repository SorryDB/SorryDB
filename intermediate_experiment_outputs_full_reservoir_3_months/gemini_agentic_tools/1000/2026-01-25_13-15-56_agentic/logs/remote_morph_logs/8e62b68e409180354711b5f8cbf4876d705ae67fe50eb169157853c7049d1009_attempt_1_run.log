/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U, IsOpen U ∧ x ∈ U ∧ IsBounded (f '' (U ∩ s)) := by
    intro x _
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hl (Metric.ball_mem_nhds l zero_lt_one))
    obtain ⟨V2, hV2, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hf.right_continuous x (Metric.ball_mem_nhds (f x) zero_lt_one))
    let W := V1 ∩ V2
    refine ⟨interior W, isOpen_interior, mem_interior_iff_mem_nhds.mpr (Filter.inter_mem hV1 hV2), ?_⟩
    let B := (Metric.ball l 1) ∪ (Metric.ball (f x) 1) ∪ {f x}
    apply IsBounded.subset (IsBounded.union (IsBounded.union Metric.isBounded_ball Metric.isBounded_ball) (isBounded_singleton (f x)))
    intro y hy
    obtain ⟨z, ⟨hz_W, hz_s⟩, rfl⟩ := hy
    let hz_V := interior_subset hz_W
    by_cases hlt : z < x
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hz_V.1, hlt⟩))
    · by_cases heq : z = x
      · exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
      · by_cases hgt : x < z
        · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hz_V.2, hgt⟩))
        · sorry -- For PartialOrder, incomparable points are not constrained by Cadlag property.
  choose U hU_open hU_x hU_bound using h_loc
  obtain ⟨t, ht_sub⟩ := hs.elim_finite_subcover (fun i : s ↦ U i i.2) (fun i ↦ hU_open i i.2)
    (fun x hx ↦ Set.mem_iUnion.mpr ⟨⟨x, hx⟩, hU_x x hx⟩)
  apply IsBounded.subset (IsBounded.biUnion (Finset.finite_toSet t) (fun i _ ↦ hU_bound i i.2))
  rw [Set.image_subset_iff]
  intro y hy
  obtain ⟨i, hi_t, hi_U⟩ := Set.mem_iUnion.mp (ht_sub hy)
  exact Set.mem_biUnion hi_t ⟨hi_U, hy⟩
```
