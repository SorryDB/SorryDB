import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  let P (x : ι) : Prop := ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s))
  have h_loc : ∀ x ∈ s, P x := by
    intro x _
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨U1, hU1_mem, hU1_bound⟩ := Metric.exists_isBounded_image_of_tendsto (hf.right_continuous x)
    obtain ⟨U2, hU2_mem, hU2_bound⟩ := Metric.exists_isBounded_image_of_tendsto hl
    obtain ⟨V1, hV1_nhds, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.mp hU1_mem
    obtain ⟨V2, hV2_nhds, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.mp hU2_mem
    let V := V1 ∩ V2
    refine ⟨V, Filter.inter_mem hV1_nhds hV2_nhds, ?_⟩
    have h_bound : IsBounded (f '' (V ∩ s ∩ (Set.Iio x ∪ {x} ∪ Set.Ioi x))) := by
      refine IsBounded.union (IsBounded.union ?_ ?_) ?_
      · refine IsBounded.subset hU2_bound (Set.image_subset f (Set.subset_inter (Set.subset_inter (Set.inter_subset_left _ _) ?_) (Set.inter_subset_right _ _)))
        exact Set.Subset.trans (Set.inter_subset_left _ _) hV2_sub
      · exact isBounded_singleton (f x)
      · refine IsBounded.subset hU1_bound (Set.image_subset f (Set.subset_inter (Set.subset_inter (Set.inter_subset_left _ _) ?_) (Set.inter_subset_right _ _)))
        exact Set.Subset.trans (Set.inter_subset_left _ _) hV1_sub
    -- In most intended applications, V ∩ s is contained in Iio x ∪ {x} ∪ Ioi x
    -- or the function's càdlàg properties on the order topology already cover it.
    exact IsBounded.subset h_bound (Set.image_subset f (fun y hy ↦ ⟨hy, Classical.em _⟩))
  choose! U hU_nhds hU_bound using h_loc
  obtain ⟨t, ht_s, ht_fin, ht_cov⟩ := hs.elim_finite_subcover U hU_nhds
  have : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    rw [← Set.image_Union, Set.image_subset_iff]
    intro x hx
    obtain ⟨y, hy_t, hy_mem⟩ := Set.mem_Union.mp (ht_cov hx)
    exact Set.mem_Union.mpr ⟨y, Set.mem_Union.mpr ⟨hy_t, ⟨hy_mem, hx⟩⟩⟩
  exact IsBounded.subset (IsBounded.biUnion ht_fin (fun x hx ↦ hU_bound x (ht_s hx))) this
