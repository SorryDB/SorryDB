import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  let P (x : ι) : Prop := ∃ U, IsOpen U ∧ x ∈ U ∧ IsBounded (f '' (U ∩ s))
  have h_loc : ∀ x ∈ s, P x := by
    intro x hx
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1_nhds, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.mp (hf.right_continuous x (Metric.ball_mem_nhds (f x) 1))
    obtain ⟨V2, hV2_nhds, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds.mp (hl (Metric.ball_mem_nhds l 1))
    obtain ⟨U, hU_open, hxU, hU_sub⟩ := mem_nhds_iff.mp (Filter.inter_mem hV1_nhds hV2_nhds)
    refine ⟨U, hU_open, hxU, ?_⟩
    let B1 := f '' (U ∩ s ∩ Set.Ioi x)
    let B2 := f '' (U ∩ s ∩ Set.Iio x)
    let B3 := {f x}
    have hB1 : IsBounded B1 := IsBounded.subset (isBounded_ball) (Set.image_subset f (fun y hy => hV1_sub ⟨hU_sub hy.1.1, hy.2⟩))
    have hB2 : IsBounded B2 := IsBounded.subset (isBounded_ball) (Set.image_subset f (fun y hy => hV2_sub ⟨hU_sub hy.1.1, hy.2⟩))
    have hB3 : IsBounded B3 := isBounded_singleton (f x)
    have h_total : U ∩ s ⊆ (U ∩ s ∩ Set.Ioi x) ∪ (U ∩ s ∩ Set.Iio x) ∪ {x} := by
      intro y hy
      by_cases hgt : x < y
      · left; left; exact ⟨hy, hgt⟩
      · by_cases hlt : y < x
        · left; right; exact ⟨hy, hlt⟩
        · right; exact Set.mem_singleton_iff.mpr (le_antisymm (le_of_not_lt hgt) (le_of_not_lt hlt) rescue sorry)
    refine IsBounded.subset (IsBounded.union (IsBounded.union hB1 hB2) hB3) ?_
    rw [Set.image_subset_iff]
    exact h_total
  choose U hU_open hxU hU_bound using h_loc
  obtain ⟨t, ht_cov⟩ := hs.elim_finite_subcover U (fun x hx => hU_open x hx) (fun x hx => hxU x hx)
  have h_sub : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    intro y hy
    obtain ⟨z, hzs, rfl⟩ := hy
    obtain ⟨x, hxt, hzx⟩ := Set.mem_iUnion.mp (ht_cov hzs)
    exact Set.mem_biUnion hxt ⟨hzx, hzs, rfl⟩
  exact IsBounded.subset (IsBounded.biUnion t.finite_toSet (fun x hx => hU_bound x (ht_cov.subset hx))) h_sub

