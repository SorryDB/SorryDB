      (hl (Metric.ball_mem_nhds l zero_lt_one))
    use V1 ∩ V2, Filter.inter_mem hV1_nhds hV2_nhds
    let B := Metric.ball (f x) 1 ∪ Metric.ball l 1 ∪ {f x}
    have hB : IsBounded B :=
      IsBounded.union (IsBounded.union Metric.isBounded_ball Metric.isBounded_ball) isBounded_singleton
    apply IsBounded.subset hB
    rw [Set.image_subset_iff]
    intro y hy
    by_cases hlt : y < x
    · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hy.1.2, hlt⟩))
    by_cases hgt : x < y
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hy.1.1, hgt⟩))
    by_cases heq : y = x
    · exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
    exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
