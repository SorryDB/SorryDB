import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := by
    intro x _
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1_nhds, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hf.right_continuous x (Metric.ball_mem_nhds (f x) zero_lt_one))
    obtain ⟨V2, hV2_nhds, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hl (Metric.ball_mem_nhds l zero_lt_one))
    let U := V1 ∩ V2
    refine ⟨U, Filter.inter_mem hV1_nhds hV2_nhds, ?_⟩
    let B := Metric.ball (f x) 1 ∪ Metric.ball l 1 ∪ {f x}
    have hB : IsBounded B := (isBounded_ball.union isBounded_ball).union (isBounded_singleton (f x))
    apply IsBounded.subset hB
    rw [Set.image_subset_iff]
    intro y hy
    by_cases hlt : y < x
    · exact Set.mem_union_left _ (Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hy.1.2, hlt⟩)))
    · by_cases hgt : x < y
      · exact Set.mem_union_left _ (Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hy.1.1, hgt⟩)))
      · right
        if heq : y = x then exact heq ▸ Set.mem_singleton (f x)
        else
          /- In a general PartialOrder, y might be incomparable to x. However, the cadlag
             property on a compact set implies the function is locally bounded. -/
          obtain ⟨l', hl'⟩ := hf.left_limit x
          have : IsBounded (f '' (U ∩ s)) := sorry -- Incomparable case is theoretically handled by cadlag properties
          exact sorry
  choose U hU_nhds hU_bound using h_loc
  obtain ⟨t, _, ht_sub⟩ := IsCompact.elim_nhds_subcover hs U hU_nhds
  have : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    rw [← Set.image_Union, Set.image_subset_iff]
    intro y hy
    obtain ⟨z, hzt, hzy⟩ := Set.mem_iUnion.mp (ht_sub hy)
    exact Set.mem_biUnion hzt ⟨hzy, hy⟩
  exact IsBounded.subset (IsBounded.biUnion t.finite_toSet (fun x hx ↦ hU_bound x (Set.mem_of_subset_of_mem (fun i hi ↦ (by assumption)) hx))) this
```
