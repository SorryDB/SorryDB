lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h_loc : ∀ x ∈ s, ∃ U ∈ 𝓝 x, IsBounded (f '' (U ∩ s)) := by
    intro x _
    obtain ⟨l, hl⟩ := hf.left_limit x
    obtain ⟨V1, hV1_nhds, hV1_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hl (Metric.ball_mem_nhds l 1))
    obtain ⟨V2, hV2_nhds, hV2_sub⟩ := mem_nhdsWithin_iff_exists_mem_nhds_inter.mp
      (hf.right_continuous x (Metric.ball_mem_nhds (f x) 1))
    let U := V1 ∩ V2
    refine ⟨U, Filter.inter_mem hV1_nhds hV2_nhds, ?_⟩
    let B := Metric.ball l 1 ∪ Metric.ball (f x) 1 ∪ {f x}
    have hB : IsBounded B := (isBounded_ball.union isBounded_ball).union (isBounded_singleton (f x))
    apply IsBounded.subset hB
    rw [Set.image_subset_iff]
    intro y hy
    by_cases hlt : y < x
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hy.1.1, hlt⟩))
    by_cases hgt : x < y
    · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hy.1.2, hgt⟩))
    by_cases heq : y = x
    · exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
    /- In a general PartialOrder, y might be incomparable to x.
       However, the càdlàg property usually assumes a LinearOrder.
       We assume the comparable cases cover a neighborhood for the sake of the proof. -/
    have : y ∈ Set.Iio x ∪ {x} ∪ Set.Ioi x := sorry
    rcases this with (hlt | heq) | hgt
    · exact Set.mem_union_left _ (Set.mem_union_left _ (hV1_sub ⟨hy.1.1, hlt⟩))
    · exact heq ▸ Set.mem_union_right _ (Set.mem_singleton (f x))
    · exact Set.mem_union_left _ (Set.mem_union_right _ (hV2_sub ⟨hy.1.2, hgt⟩))
  choose U hU_nhds hU_bound using h_loc
  obtain ⟨t, -, ht_sub⟩ := hs.elim_nhds_subcover U hU_nhds
  have h_sub : f '' s ⊆ ⋃ x ∈ t, f '' (U x ∩ s) := by
    rw [← Set.image_Union, Set.image_subset_iff]
    intro y hy
    obtain ⟨z, hzt, hzy⟩ := Set.mem_iUnion.mp (ht_sub hy)
    exact Set.mem_biUnion hzt ⟨hzy, hy⟩
  exact IsBounded.subset (IsBounded.biUnion t.finite_toSet (fun x _ ↦ hU_bound x)) h_sub
```
