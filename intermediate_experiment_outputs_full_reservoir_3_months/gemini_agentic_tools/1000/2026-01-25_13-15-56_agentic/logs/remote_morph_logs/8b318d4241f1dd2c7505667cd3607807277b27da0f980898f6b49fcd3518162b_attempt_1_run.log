  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  by_cases hp_prime : p.Prime
  · unfold Factorization.balance Factorization.sum initial
    set n := P.n; set M := P.M; set L := P.L
    set I := Multiset.Ico (n - n / M) n
    set S := (n / L).smoothNumbers
    push_cast
    simp only [Multiset.map_map, Function.comp_apply]
    have h_sum : ((Multiset.filter (· ∈ S) (Multiset.replicate M I).join).map (fun m ↦ (m.factorization p : ℝ))).sum =
        (M : ℝ) * ((I.filter (· ∈ S)).map (fun m ↦ (m.factorization p : ℝ))).sum := by
      rw [Multiset.filter_join, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate,
        Multiset.sum_replicate, nsmul_eq_mul]
