    have hlog : 0 ≤ Real.log P.n := Real.log_nonneg (by exact_mod_cast h_n.le)
    have : 0 ≤ (P.M : ℝ) * Real.log P.n + (P.M : ℝ) * (P.L : ℝ)^2 * (primeCounting P.n) := by
      positivity
