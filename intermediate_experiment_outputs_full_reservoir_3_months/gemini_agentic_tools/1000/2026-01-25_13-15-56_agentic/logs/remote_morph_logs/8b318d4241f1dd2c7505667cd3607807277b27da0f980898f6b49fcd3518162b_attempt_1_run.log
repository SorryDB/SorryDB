@[blueprint
  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)
  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  unfold Factorization.balance Factorization.sum initial
  set k := P.n / P.M
  let I := Multiset.Ico (P.n - k) P.n
  let smooth m := m ∈ (P.n / P.L).smoothNumbers
  simp only [Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate,
    smul_eq_mul]
  push_cast
  let sum_all := (I.map (fun m => (m.factorization p : ℤ))).sum
  let sum_Sc := (I.filter (fun m => ¬ smooth m) |>.map (fun m => (m.factorization p : ℤ))).sum
  have h_sum_decomp : (↑(Multiset.filter smooth I |>.map (·.factorization p)).sum : ℝ) = ↑sum_all - ↑sum_Sc := by
    push_cast; rw [← Multiset.sum_map_add, Multiset.filter_add_filter_not]; rfl
  rw [h_sum_decomp, mul_sub, sub_sub]
  have h_leg : (P.M : ℝ) * sum_all - (P.n.factorial.factorization p) ≥ - (P.M : ℝ) * Real.log P.n := by
    sorry
  have h_smooth : (P.M : ℝ) * sum_Sc ≤ (P.M : ℝ) * (P.L : ℝ)^2 * (primeCounting P.n) := by
    sorry
  linarith
```
