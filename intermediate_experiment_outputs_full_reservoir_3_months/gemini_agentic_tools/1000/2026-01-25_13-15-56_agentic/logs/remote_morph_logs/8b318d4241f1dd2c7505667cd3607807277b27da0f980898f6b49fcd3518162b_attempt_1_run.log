    push_cast; simp [← Multiset.sum_add, ← Multiset.map_add, Multiset.filter_add_filter_not]
  rw [h_sum]; push_cast; rw [h_decomp]
  have h_leg : (M : ℝ) * (I.map (fun m ↦ (m.factorization p : ℤ))).sum - (n.factorial.factorization p : ℤ) ≥ - (M : ℝ) * Real.log n := by
    sorry
  have h_smooth : (M : ℝ) * (I.filter (fun m ↦ ¬ smooth m) |>.map (fun m ↦ (m.factorization p : ℤ))).sum ≤ (M : ℝ) * (L : ℝ)^2 * (primeCounting n) := by
    sorry
  linarith
