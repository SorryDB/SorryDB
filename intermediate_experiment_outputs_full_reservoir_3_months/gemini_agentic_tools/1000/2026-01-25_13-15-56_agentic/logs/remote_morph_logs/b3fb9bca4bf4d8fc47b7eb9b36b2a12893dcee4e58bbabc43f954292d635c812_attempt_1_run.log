        have h_not6_m := h_not6 m
        have h_not6_m1 := h_not6 (m + 1)
        have h_cos1 : cos ((p m).1.val * π / 12) ≠ 0 := h_cos _ h_not6_m.1
        have h_cos2 : cos ((p (m + 1)).1.val * π / 12) ≠ 0 := h_cos _ h_not6_m1.1
        have h_cos3 : cos (((p m).1.val + (p (m + 1)).1.val) * π / 12) ≠ 0 := by
          have hp1 : (p (m + 1)).1 = (p m).2 := rfl
          rw [hp1]
          have h_p_sum : ((p m).1.val + (p m).2.val : ℝ) * (π / 12) =
            (p (m + 1)).2.val * (π / 12) + ((p m).1.val + (p m).2.val) / 12 * π := by
            field_simp [Real.pi_ne_zero]; norm_cast; rw [Nat.div_add_mod]; ring
          rw [h_p_sum, cos_add_int_mul_pi]
          simp [h_cos _ h_not6_m1.2]
