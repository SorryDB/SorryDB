    have : k = 0 := by linarith
    subst this; have : x.val = 6 := by linarith
    exact hx (Fin.ext this)
  have h_a : ∀ n ≥ 1, a n = tan ((p (n - 1)).1.val * π / 12) := by
    intro n hn; induction n using Nat.strong_induction_on with
    | h n IH =>
      match n with
      | 0 => linarith
      | 1 => rw [h₀]; simp [p, Real.tan_pi_div_four, show (3:ℝ)*π/12 = π/4 by ring]
