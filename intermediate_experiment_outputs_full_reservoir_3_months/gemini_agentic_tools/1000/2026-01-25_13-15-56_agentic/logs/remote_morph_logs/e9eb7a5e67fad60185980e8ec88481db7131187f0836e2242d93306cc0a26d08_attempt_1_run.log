/-- The moment of inertia tensor of a solid sphere through its center of mass is
  `2/5 m R^2 * I`. -/
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  ext i j
  simp only [inertiaTensor, solidSphere, Matrix.smul_apply, Matrix.one_apply, LinearMap.coe_mk,
    AddHom.coe_mk, ContMDiffMap.coeFn_mk]
  have hV : volume.real (Metric.closedBall (0 : Space 3) R) ≠ 0 := by
    refine (measureReal_ne_zero_iff ?_).mpr ?_
    · apply Space.volume_closedBall_neq_top
    · apply Space.volume_closedBall_neq_zero 0 R (NNReal.coe_pos.mpr (pos_iff_ne_zero.mpr hr))
  split_ifs with h
  · subst h
    simp only [if_true, mul_one]
    rw [integral_sub, integral_finset_sum]
    · simp only [Space.integral_coord_sq_closedBall, Finset.sum_const, Finset.card_univ,
        Fintype.card_fin]
      field_simp [hV]
      ring
    · intro k _
      apply ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
      continuity
    · apply ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
      continuity
    · apply integrable_finset_sum
      intro k _
      apply ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
      continuity
  · simp only [h, if_false, mul_zero, zero_sub]
    rw [integral_neg, Space.integral_coord_mul_closedBall R h]
    · simp
    · apply ContinuousOn.integrableOn_compact (isCompact_closedBall 0 R)
      continuity

end RigidBody
