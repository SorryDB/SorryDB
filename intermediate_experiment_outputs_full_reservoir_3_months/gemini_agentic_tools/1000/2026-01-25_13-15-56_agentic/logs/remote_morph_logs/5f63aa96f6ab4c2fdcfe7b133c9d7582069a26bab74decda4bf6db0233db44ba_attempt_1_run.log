theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf (s : S k) : f (f s) = s := congr_fun (linearInvo_sq k) s
  have h_card (P : Set (S k)) (hP : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h_eq : Fintype.card P = Fintype.card (Pᶜ : Set (S k)) := by
      apply Fintype.card_congr
      exact {
        toFun := fun ⟨s, hs⟩ => ⟨f s, (hP s).mp hs⟩,
        invFun := fun ⟨s, hs⟩ => ⟨f s, (hP (f s)).mpr (by rwa [hf])⟩,
        left_inv := fun s => by ext; simp [hf],
        right_inv := fun s => by ext; simp [hf]
      }
    rw [two_mul, h_eq, ← Fintype.card_sum, Fintype.card_congr (Equiv.sumCompl P).symm]
  have hT : ∀ s : S k, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, h_prop⟩ := s
    obtain ⟨h1, _, _⟩ := h_prop
    have hz : z ≠ 0 := by
      intro hz; apply_fun (· % 4) at h1; rw [hz] at h1
      norm_num at h1
    simp [T, f, linearInvo, hz]; omega
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, h_prop⟩ := s
    obtain ⟨h1, _, _⟩ := h_prop
    have hne : x - y + z ≠ 0 := by
      intro h0
      have hsq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by nlinarith
      have hsq_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        rw [← Int.natAbs_pow, hsq]; simp
      exact Nat.Prime.not_isSquare hk.out ⟨(x + y).natAbs, hsq_nat.symm⟩
    simp [U, f, linearInvo, hne]; omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
