theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf := linearInvo_sq k
  have h_card (P : Set (S k)) (hP : ∀ s : S k, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h_sum := Fintype.card_congr (Equiv.sumCompl (· ∈ P)).symm
    simp only [Fintype.card_sum] at h_sum
    rw [h_sum, two_mul, add_right_inj]
    apply Fintype.card_congr
    refine Equiv.ofBijective (fun (s : {x // x ∈ P}) => (⟨f s.1, (hP s.1).mp s.2⟩ : {x // x ∉ P})) ⟨?_, ?_⟩
    · intro ⟨s1, h1⟩ ⟨s2, h2⟩ h
      simp at h
      apply_fun f at h
      simp [congr_fun hf] at h
      exact Subtype.ext h
    · intro ⟨s, hs⟩
      have h_f_in_P : f s ∈ P := by
        have h := hP (f s)
        rw [congr_fun hf] at h
        exact h.mpr hs
      exact ⟨⟨f s, h_f_in_P⟩, Subtype.ext (congr_fun hf s)⟩
  have hT : ∀ s : S k, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    have h_eq := hS.1
    simp [T, linearInvo]
    have hz_ne : z ≠ 0 := by
      intro hz; subst hz
      apply_fun (fun (m : ℤ) => (m : ZMod 4)) at h_eq
      norm_num at h_eq
    constructor <;> intro <;> linarith
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    have h_eq_S := hS.1
    simp [U, linearInvo]
    have h_ne : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by nlinarith
      have h_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        zify
        rw [Int.natAbs_sq, h_sq]
      exact hk.out.not_isSquare ⟨_, by rw [← h_nat, pow_two]⟩
    constructor <;> intro <;> linarith
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]

