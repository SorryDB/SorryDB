    constructor
    · intro ⟨s1, h1⟩ ⟨s2, h2⟩ h; ext; apply_fun f at h; simpa [congr_fun hf] using h
    · intro ⟨s, hs⟩
      have : f s ∈ P := by rwa [hP, show f (f s) = s from congr_fun hf s]
      exact ⟨⟨f s, this⟩, by ext; simp [congr_fun hf]⟩
