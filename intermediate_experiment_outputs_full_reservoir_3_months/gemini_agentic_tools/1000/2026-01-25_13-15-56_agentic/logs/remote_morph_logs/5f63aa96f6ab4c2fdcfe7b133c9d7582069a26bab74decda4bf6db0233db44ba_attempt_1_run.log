  have h_card (P : Set (S k)) (hP : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h1 : Fintype.card (S k) = Fintype.card P + Fintype.card (Pᶜ : Set (S k)) :=
      (Fintype.card_congr (Equiv.sumCompl P).symm).trans (Fintype.card_sum _ _)
    have h2 : Fintype.card P = Fintype.card (Pᶜ : Set (S k)) := by
      apply Fintype.card_congr
      exact {
        toFun := fun s => ⟨f s.1, (hP s.1).mp s.2⟩,
        invFun := fun s => ⟨f s.1, by
          have h := hP (f s.1)
          rw [hf] at h
          exact h.symm.mpr s.2⟩,
        left_inv := fun s => by ext; simp [hf],
        right_inv := fun s => by ext; simp [hf]
