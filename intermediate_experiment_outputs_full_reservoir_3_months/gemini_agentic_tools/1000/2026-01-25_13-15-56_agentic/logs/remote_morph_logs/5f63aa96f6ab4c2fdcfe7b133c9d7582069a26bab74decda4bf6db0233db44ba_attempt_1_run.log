theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have h_inv (P : Set (S k)) (h : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have : Fintype (Pᶜ : Set (S k)) := Fintype.ofFinite Pᶜ
    have h_card := Fintype.card_subtype_add_card_subtype_compl P
    rw [← h_card, two_mul, add_right_inj]
    apply Fintype.card_congr
    refine ⟨fun ⟨s, hs⟩ => ⟨f s, (h s).mp hs⟩, fun ⟨s, hs⟩ => ⟨f s, (h (f s)).mpr ?_⟩, ?_, ?_⟩
    · rwa [show f (f s) = s from congr_fun (linearInvo_sq k) s]
    · intro ⟨s, hs⟩; ext; exact congr_fun (linearInvo_sq k) s
    · intro ⟨s, hs⟩; ext; exact congr_fun (linearInvo_sq k) s
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_inv (T k), h_inv (U k)]
  · intro ⟨⟨x, y, z⟩, h, hx, hy⟩
    simp only [U, linearInvo, Set.mem_setOf_eq, Subtype.mk.injEq, Prod.mk.injEq, Set.mem_compl_iff,
      not_lt]
    have h_eq : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y) ^ 2 = 4 * k + 1 := by nlinarith
      have hp : (4 * k + 1 : ℕ).Prime := hk.out
      have : IsSquare (4 * k + 1 : ℕ) := ⟨(x + y).natAbs, by zify; rw [Int.natAbs_sq, h_sq]⟩
      exact hp.not_isSquare this
    constructor <;> intro hz <;> linarith
  · intro ⟨⟨x, y, z⟩, h, hx, hy⟩
    simp only [T, linearInvo, Set.mem_setOf_eq, Subtype.mk.injEq, Prod.mk.injEq, Set.mem_compl_iff,
      not_lt]
