theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf : ∀ s, f (f s) = s := fun s => congr_fun (linearInvo_sq k) s
  have h_card (P : Set (S k)) (hP : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    rw [two_mul, ← Fintype.card_congr (Equiv.sumCompl P).symm, Fintype.card_sum]
    simp only [Fintype.card_coe]
    rw [add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun s => ⟨f s.1, (hP s.1).mp s.2⟩,
      invFun := fun s => ⟨f s.1, (hP (f s.1)).mpr (by simpa [hf] using s.2)⟩,
      left_inv := fun s => Subtype.ext (hf s.1),
      right_inv := fun s => Subtype.ext (hf s.1)
    }
  have hT : ∀ s : S k, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, h⟩ := s
    have hz : z ≠ 0 := by
      intro hz; subst hz; obtain ⟨h1, _, _⟩ := h
      have hmod : (4 * x * y + 0 ^ 2 : ZMod 4) = (4 * k + 1 : ZMod 4) := by rw [← h1]; simp
      simp at hmod
    simp [T, f, linearInvo]
    omega
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, h⟩ := s
    have hne : x - y + z ≠ 0 := by
      intro h0; obtain ⟨h1, _, _⟩ := h
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by nlinarith
      have h_is_sq : IsSquare (4 * k + 1 : ℕ) := ⟨(x + y).natAbs, by
        rw [← Int.natAbs_pow, h_sq]; simp⟩
      exact hk.out.not_isSquare h_is_sq
    simp [U, f, linearInvo]
    omega
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]

