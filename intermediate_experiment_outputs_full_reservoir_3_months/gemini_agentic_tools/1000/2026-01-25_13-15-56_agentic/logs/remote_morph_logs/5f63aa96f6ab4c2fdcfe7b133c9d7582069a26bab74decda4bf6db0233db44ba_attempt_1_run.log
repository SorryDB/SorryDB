theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf : ∀ s, f (f s) = s := fun s => congr_fun (linearInvo_sq k) s
  have h_card (P : Set (S k)) (hP : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h_sum := Fintype.card_congr (Equiv.sumCompl P).symm
    simp only [Fintype.card_sum, Fintype.card_coe] at h_sum
    rw [h_sum, two_mul, add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun s => ⟨f s.1, (hP s.1).mp s.2⟩,
      invFun := fun s => ⟨f s.1, (hP (f s.1)).mpr (by simpa [hf] using s.2)⟩,
      left_inv := fun s => Subtype.ext (hf s.1),
      right_inv := fun s => Subtype.ext (hf s.1)
    }
  have hT : ∀ s : S k, s ∈ T k ↔ f s ∉ T k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS⟩ := s
    have hz_ne : z ≠ 0 := by
      intro hz; subst hz
      have h_eq := hS.1
      apply_fun (fun m => m % 4) at h_eq
      simp at h_eq
    simp [T, linearInvo]; constructor <;> intro <;> linarith
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, hS⟩ := s
    have h_ne : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by linear_combination hS.1 + h_eq * (x - y - z)
      have h_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        rw [← Int.natAbs_pow, h_sq, Int.natAbs_ofNat]
      exact hk.out.not_isSquare ⟨(x + y).natAbs, by rw [pow_two, h_nat]⟩
    simp [U, linearInvo]; constructor <;> intro <;> linarith
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]

