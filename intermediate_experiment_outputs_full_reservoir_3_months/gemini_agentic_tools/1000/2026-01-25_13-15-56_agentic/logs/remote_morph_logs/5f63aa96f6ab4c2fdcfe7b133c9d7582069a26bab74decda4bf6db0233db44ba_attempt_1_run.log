theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let f := linearInvo k
  have hT : ∀ s, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, h, hx, hy⟩
    simp [T, linearInvo, f]
    have : z ≠ 0 := by
      intro hz; subst hz
      apply_fun (· % 4) at h
      norm_num [Int.add_emod, Int.mul_emod] at h
    exact ⟨fun hz => hz.le, fun hz => hz.lt_of_ne (Ne.symm this)⟩
  have hU : ∀ s, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, h, hx, hy⟩
    simp [U, linearInvo, f]
    have h_ne : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y)^2 = 4 * k + 1 := by nlinarith
      have hp : (4 * k + 1 : ℕ).Prime := hk.out
      exact hp.not_isSquare ⟨(x + y).natAbs, by zify; rw [Int.natAbs_sq, h_sq]⟩
    exact ⟨fun h_gt => by linarith, fun h_ge => by linarith⟩
  have card_half (P : Set (S k)) [Fintype P] [Fintype Pᶜ] (h : ∀ s, s ∈ P ↔ f s ∉ P) :
      2 * Fintype.card P = Fintype.card (S k) := by
    rw [two_mul, ← Fintype.card_add_card_compl P, add_left_inj]
    apply Fintype.card_congr
    exact {
      toFun := fun ⟨s, hs⟩ => ⟨f s, (h s).mp hs⟩
      invFun := fun ⟨s, hs⟩ => ⟨f s, (h (f s)).mpr (by rwa [show f (f s) = s from congr_fun (linearInvo_sq k) s])⟩
      left_inv := fun ⟨s, hs⟩ => by ext; exact congr_fun (linearInvo_sq k) s
      right_inv := fun ⟨s, hs⟩ => by ext; exact congr_fun (linearInvo_sq k) s }
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [card_half (T k) hT, card_half (U k) hU]
```
