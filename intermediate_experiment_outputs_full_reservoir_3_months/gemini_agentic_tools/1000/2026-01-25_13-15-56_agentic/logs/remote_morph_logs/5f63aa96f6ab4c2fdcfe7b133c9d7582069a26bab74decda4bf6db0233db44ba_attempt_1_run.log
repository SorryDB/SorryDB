theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf := linearInvo_sq k
  have h_card (P : Set (S k)) (hP : ∀ s : S k, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h_sum := Fintype.card_congr (Equiv.sumCompl (· ∈ P)).symm
    rw [Fintype.card_sum] at h_sum
    rw [two_mul, h_sum, add_right_inj]
    apply Fintype.card_congr
    refine Equiv.ofBijective (fun (s : P) => (⟨f s.1, (hP s.1).mp s.2⟩ : {x // x ∉ P})) ⟨?_, ?_⟩
    · intro ⟨s1, h1⟩ ⟨s2, h2⟩ h
      ext; apply_fun f at h; simpa [congr_fun hf] using h
    · intro ⟨s, hs⟩
      have : f s ∈ P := by
        have := (hP (f s)).symm
        rwa [show f (f s) = s from congr_fun hf s] at this
      exact ⟨⟨f s, this⟩, by ext; simp [congr_fun hf]⟩
  have hT : ∀ s : S k, s ∈ T k ↔ f s ∉ T k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [T, linearInvo, Set.mem_setOf_eq, Set.mem_compl_iff]
    have hz_ne : z ≠ 0 := by
      intro hz; subst hz
      obtain ⟨hS1, _, _⟩ := hS
      apply_fun (fun (m : ℤ) => (m : ZMod 4)) at hS1
      simp at hS1
    constructor <;> intro <;> linarith
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hS⟩
    simp [U, linearInvo, Set.mem_setOf_eq, Set.mem_compl_iff]
    have h_ne : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        obtain ⟨hS1, _, _⟩ := hS
        nlinarith
      have : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        apply Int.ofNat_inj.1
        rw [Int.natAbs_sq, h_sq]
        simp
      exact (Fact.out : (4 * k + 1 : ℕ).Prime).not_isSquare ⟨_, this⟩
    constructor <;> intro <;> linarith
  apply Nat.mul_left_cancel (show 0 < 2 by norm_num)
  rw [h_card (U k) hU, h_card (T k) hT]
