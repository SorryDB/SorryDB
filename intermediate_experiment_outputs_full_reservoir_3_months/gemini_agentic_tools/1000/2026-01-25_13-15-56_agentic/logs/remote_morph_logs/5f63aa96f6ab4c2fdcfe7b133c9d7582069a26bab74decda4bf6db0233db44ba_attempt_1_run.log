    simp [T, f, linearInvo, hz]; constructor <;> intro <;> linarith
  have hU : ∀ s : S k, s ∈ U k ↔ f s ∉ U k := by
    intro s; obtain ⟨⟨x, y, z⟩, h⟩ := s
