theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  classical
  let f := linearInvo k
  have hf : ∀ s, f (f s) = s := fun s => congr_fun (linearInvo_sq k) s
  have h_card (P : Set (S k)) (hP : ∀ s, s ∈ P ↔ f s ∉ P) : 2 * Fintype.card P = Fintype.card (S k) := by
    have h1 := Fintype.card_congr (Equiv.sumCompl P).symm
    simp only [Fintype.card_sum, Fintype.card_coe] at h1
    rw [two_mul, h1, add_left_inj]
    apply Fintype.card_congr
    exact
    { toFun := fun s => ⟨f s.1, (hP s.1).mp s.2⟩,
      invFun := fun s => ⟨f s.1, (hP (f s.1)).mpr (by simpa [hf] using s.2)⟩,
      left_inv := fun s => Subtype.ext (hf s.1),
      right_inv := fun s => Subtype.ext (hf s.1) }
  apply Nat.mul_left_cancel (by norm_num : 0 < 2)
  rw [h_card (U k), h_card (T k)]
  · intro s; obtain ⟨⟨x, y, z⟩, hS⟩ := s
    have hz_ne : z ≠ 0 := by
      intro hz; subst hz
      have h := hS.1
      apply_fun (fun m => (m : ZMod 4)) at h
      simp at h
    simp [f, T, linearInvo]; constructor <;> intro <;> linarith
  · intro s; obtain ⟨⟨x, y, z⟩, hS⟩ := s
    have h_ne : x - y + z ≠ 0 := by
      intro h_eq
      have h_sq : (x + y) ^ 2 = (4 * k + 1 : ℤ) := by
        linear_combination hS.1 + h_eq * (x - y - z)
      have h_nat : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        rw [← Int.natAbs_pow, h_sq]
        simp
      exact (Fact.out : (4 * k + 1).Prime).not_isSquare ⟨(x + y).natAbs, h_nat.symm⟩
    simp [f, U, linearInvo]; constructor <;> intro <;> linarith
