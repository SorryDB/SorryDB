/-- All zeros of the Riemann zeta function outside the critical strip are simple zeros.
    This means if ζ(s) = 0 and s is not in the critical strip (s.re ≤ 0 or s.re ≥ 1),
    then the derivative at that point is non-zero: ζ'(s) ≠ 0. -/
theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 :=
  fun s hcs hζ => by
    have h_re : s.re ≤ 0 ∨ 1 ≤ s.re := by
      contrapose! hcs
      exact hcs
    cases h_re with
    | inr h_ge_one =>
      exact (riemannZeta_ne_zero_of_one_le_re h_ge_one hζ).elim
    | inl h_le_zero =>
      have h_lt_zero : s.re < 0 := by
        by_cases h0 : s.re = 0
        · exact (riemannZeta_ne_zero_of_re_eq_zero h0 hζ).elim
        · exact h_le_zero.lt_of_ne h0
      obtain ⟨n, rfl⟩ := (riemannZeta_eq_zero_iff_re_lt_zero h_lt_zero).mp hζ
      exact riemannZeta_deriv_ne_zero_neg_even n
```
