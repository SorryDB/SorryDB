/-- All zeros of the Riemann zeta function outside the critical strip are simple zeros.
    This means if ζ(s) = 0 and s is not in the critical strip (s.re ≤ 0 or s.re ≥ 1),
    then the derivative at that point is non-zero: ζ'(s) ≠ 0. -/
theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 := by
  intro s hcs hζ
  have h_re : s.re ≤ 0 := by
    contrapose! hζ
    exact riemannZeta_ne_zero_of_one_le_re (le_of_not_gt (fun h => hcs ⟨hζ, h⟩))
  have h_s : s ≠ 1 := by
    intro h; subst h; exact riemannZeta_one_ne_zero hζ
  have h_deriv : HasDerivAt riemannZeta (deriv riemannZeta s) s := differentiable_riemannZeta h_s |>.hasDerivAt
  let Λ := completedRiemannZeta
  have h_Λ_eq : ∀ z, Λ z = (1 / 2) * z * (z - 1) * (π : ℂ) ^ (-z / 2) * Gamma (z / 2) * riemannZeta z := completedRiemannZeta_eq
  have h_Λ_one_sub : ∀ z, Λ (1 - z) = Λ z := completedRiemannZeta_one_sub
  -- Trivial zeros occur at s = -2n. At these points, the Gamma factor has a simple pole,
  -- while the completed zeta function Λ(s) is non-zero (since its zeros are nontrivial).
  -- This implies the zero of riemannZeta at s must be simple.
  sorry
```
