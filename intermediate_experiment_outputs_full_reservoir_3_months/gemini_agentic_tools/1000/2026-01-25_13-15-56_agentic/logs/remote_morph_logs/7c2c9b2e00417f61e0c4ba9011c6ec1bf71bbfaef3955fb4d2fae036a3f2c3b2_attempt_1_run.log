import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f (k : ℕ) := move^[k] (p, 0)
  let p_ k := (f k).1
  let v_ k := (f k).2
  let x (k : ℕ) (i : Fin 2021) : ZMod 2 := if (p_ k) i < v_ k then 1 else 0
  let m (k : ℕ) : ZMod 2 := ∑ i, x k i * (1 + x k (i + 1))
  have v_val : ∀ k ≤ 2021, (v_ k).val = k % 2021 := by
    intro k hk; induction k with | zero => rfl | succ k ih =>
      rw [v_, iterate_succ_apply', move, ih (Nat.le_of_succ_le hk), Fin.ext_iff]; simp
  have m_step : ∀ k < 2021, m (k + 1) = m k + 1 := by
    intro k hk
    let h_k := (p_ k).symm (v_ k)
    let c : ZMod 2 := if k = 2020 then 1 else 0
    have xi : ∀ i, x (k + 1) i = x k i + (if i = h_k then 1 else 0) + c := by
      intro i; simp [x, v_val k (Nat.le_of_lt hk), v_val (k+1) (Nat.succ_le_of_lt hk), p_, v_]
      rw [iterate_succ_apply', move]; simp [Equiv.trans_apply, Equiv.swap_apply_def, Position.swapped]
      split_ifs with h1 h2 h3 h4 h5 h6 h7 <;> try rfl
      · exact (h6 ((p_ k).injective (by rw [h7, ← h1]; rfl))).elim
      · rcases Nat.lt_trichotomy k 2020 with hlt | heq | hgt
        · simp [hlt, heq] at h3; rw [Nat.mod_eq_of_lt (Nat.succ_lt_of_lt hlt)] at h3; exact (h5 h3).elim
        · simp [heq] at h4; rw [Nat.mod_self] at h4; exact (h5 h4).elim
        · exact (Nat.not_lt_of_le (Nat.succ_le_of_lt hk) hgt).elim
      · rw [← h1] at h7; simp at h7; exact (Fin.vne_iff.mpr h4 h7).elim
    have h_w : x k (h_k - 1) = x k (h_k + 1) := by
      let v := v_ k; specialize h v; rw [Position.nth, v_val k (Nat.le_of_lt hk)] at h
      have : (f k.val).2 = v := rfl
      simp [this, Position.swapped, x, p_] at h ⊢
      let a := (p_ k) (h_k - 1); let b := (p_ k) (h_k + 1)
      have nea : a ≠ v := by intro e; exact (Fin.sub_self _ 1).1 ((p_ k).injective (by rw [e]; rfl))
      have neb : b ≠ v := by intro e; exact (Fin.add_self _ 1).1 ((p_ k).injective (by rw [e]; rfl))
      rcases lt_trichotomy a.val v.val with h1 | h1 | h1 <;>
      rcases lt_trichotomy b.val v.val with h2 | h2 | h2
      all_goals (try simp_all; try rfl; try exact (nea (Fin.ext h1)).elim; try exact (neb (Fin.ext h2)).elim)
    simp [m, xi, add_mul, mul_add, Finset.sum_add_distrib, Finset.sum_const, Finset.sum_ite]
    have hne : h_k + 1 ≠ h_k := by intro e; exact (Fin.add_self _ 1).1 e
    have hne' : h_k - 1 + 1 = h_k := Fin.sub_add_cancel _ _
    simp [hne, hne', h_w, add_assoc, ← Finset.sum_equiv (Equiv.addRight 1) (fun i => x k i)]
  have m_0 : m 0 = 0 := by simp [m, x, v_val 0 (by decide)]
  have m_2021 : m 2021 = 0 := by simp [m, x, v_val 2021 (by decide)]
  have : m 2021 = m 0 + (2021 : ZMod 2) := by
