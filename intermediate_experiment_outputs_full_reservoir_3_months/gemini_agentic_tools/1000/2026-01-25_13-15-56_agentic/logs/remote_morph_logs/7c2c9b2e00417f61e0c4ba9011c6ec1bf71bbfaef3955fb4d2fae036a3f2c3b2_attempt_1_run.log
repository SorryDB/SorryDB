    have vk1 : v_ (k + 1) = hkf + 1 := by rw [v_, iterate_succ_apply, move, vk]; rfl
    let hk_hole := (p_ k).symm hkf
    have h_xk : ∀ i, x (k + 1) i = x k i + if i = hk_hole then 1 else 0 := by
      intro i; simp [x, vk, vk1, v_val k (Nat.le_of_lt hk)]
      rw [v_, iterate_succ_apply, move, vk]; simp [Position.swapped, Equiv.trans_apply, Equiv.swap_apply_def]
      let a := p_ k (hk_hole - 1); let b := p_ k (hk_hole + 1)
      have h_ab : (a.val < k ↔ b.val < k) := by
        specialize h hkf; rw [Position.nth, ← v_, vk] at h
        simp [Position.swapped, vk, hk_hole] at h
        rcases lt_trichotomy a.val k with h1 | h1 | h1 <;>
        rcases lt_trichotomy b.val k with h2 | h2 | h2
