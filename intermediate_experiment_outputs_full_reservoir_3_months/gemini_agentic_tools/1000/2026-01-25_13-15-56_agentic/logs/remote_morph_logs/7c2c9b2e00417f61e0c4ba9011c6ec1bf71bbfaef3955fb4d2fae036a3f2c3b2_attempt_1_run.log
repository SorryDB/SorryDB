import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f (n : ℕ) := move^[n] (p, 0)
  let p_ (n : ℕ) := (f n).1
  let x (n : ℕ) (i : Fin 2021) : ZMod 2 := if (p_ n i).val < n then 1 else 0
  let m (n : ℕ) : ZMod 2 := ∑ i, x n i * x n (i + 1)
  have f_step : ∀ n, f (n + 1) = move (f n) := fun n => by rw [f, Function.iterate_succ_apply']
  have v_val : ∀ n, (f n).2 = (n : Fin 2021) := by
    intro n; induction n with | zero => rfl | succ n ih => rw [f_step, move, ih]; rfl
  have m_step : ∀ n < 2021, m (n + 1) = m n := by
    intro n hn
    let k : Fin 2021 := ⟨n, hn⟩
    have v_n : (f n).2 = k := by rw [v_val, Fin.ext_iff]; simp [hn]
    let h_n := (p_ n).symm k
    have p_n_hn : p_ n h_n = k := (p_ n).apply_symm_apply k
    let a := p_ n (h_n - 1)
    let b := p_ n (h_n + 1)
    have ha : a ≠ k := (p_ n).injective.ne (by simp [Fin.ext_iff]; intro e; omega)
    have hb : b ≠ k := (p_ n).injective.ne (by simp [Fin.ext_iff]; intro e; omega)
    have x_eq : x n (h_n - 1) = x n (h_n + 1) := by
      specialize h k; simp [Position.nth, Position.swapped, v_n, p_n_hn, p_, f] at h
      simp [x, a, b, k]; rcases lt_trichotomy a k with h1|h1|h1 <;> rcases lt_trichotomy b k with h2|h2|h2
      all_goals (try simp_all; try exact (ha h1).elim; try exact (hb h2).elim)
    have p_next : p_ (n + 1) = (p_ n).trans (Equiv.swap a b) := by
      rw [p_, f_step, move, v_n, Position.swapped, p_n_hn]; rfl
    have x_next : ∀ i, x (n + 1) i = x n i + if i = h_n then 1 else 0 := by
      intro i; simp [x, p_next, Equiv.trans_apply]; by_cases hi : i = h_n
      · simp [hi, p_n_hn, Equiv.swap_apply_of_ne_of_ne ha.symm hb.symm, k]; omega
      · have hni : p_ n i ≠ k := (p_ n).injective.ne hi
        rw [Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff, or_iff_left hni]; by_cases hia : i = h_n - 1
        · simp [hia, Equiv.swap_apply_left, x_eq]; rfl
        · by_cases hib : i = h_n + 1
          · simp [hib, Equiv.swap_apply_right, x_eq]; rfl
          · simp [hi, hia, hib, Equiv.swap_apply_of_ne_of_ne ((p_ n).injective.ne hia) ((p_ n).injective.ne hib)]
    simp [m, x_next, add_mul, mul_add, Finset.sum_add_distrib]
    have h_h1 : ∀ i, i + 1 = h_n ↔ i = h_n - 1 := fun i => ⟨Fin.eq_sub_of_add_eq, fun e => by rw [e, Fin.sub_add_cancel]⟩
    have h_h2 : ∀ i, i = h_n ∧ i + 1 = h_n ↔ False := fun i => by simp [Fin.ext_iff]; intro e; omega
    simp [Finset.sum_ite, h_h1, h_h2, x]
  have m_0 : m 0 = 0 := by simp [m, x]
  have m_2021 : m 2021 = 1 := by
    simp [m, x]; have : ∀ i, x 2021 i = 1 := fun i => by simp [x]; exact (p_ 2021 i).is_lt
    simp [this, Finset.sum_const, Fintype.card_fin]; rfl
  have m_final : m 2021 = m 0 := by
    have : ∀ n ≤ 2021, m n = m 0 := by
      intro n hn; induction n with | zero => rfl | succ n ih =>
        have hlt : n < 2021 := Nat.lt_of_succ_le hn
        rw [m_step n hlt, ih (Nat.le_of_lt hlt)]
    exact this 2021 (Nat.le_refl _)
  simp [m_0, m_2021] at m_final

end IMO2021P5

