import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let p_ n := (move^[n] (p, 0)).1
  let v_ n := (move^[n] (p, 0)).2
  let x n i : ZMod 2 := if (p_ n i).val < n then 1 else 0
  let m n : ZMod 2 := ∑ i, x n i * x n (i + 1)
  have v_val : ∀ n, v_ n = (n : Fin 2021) := fun n => by
    induction n with | zero => rfl | succ n ih => rw [v_, Function.iterate_succ_apply, move, ih]; rfl
  have x_step : ∀ n < 2021, ∀ i, x (n + 1) i = if i = (p_ n).symm n then 1 else if i = (p_ n).symm n - 1 then x n (i + 2) else if i = (p_ n).symm n + 1 then x n (i - 2) else x n i := by
    intro n hn i; let h_n := (p_ n).symm n; have p_n_hn : p_ n h_n = n := (p_ n).apply_symm_apply n
    rw [x, x]; split_ifs with hi h1 h2
    · rw [p_, Function.iterate_succ_apply, move, Equiv.trans_apply, p_n_hn, Equiv.swap_apply_right]; simp [hi, v_val, hn]
    · rw [p_, Function.iterate_succ_apply, move, Equiv.trans_apply, hi]; simp [Position.swapped, v_val, p_n_hn, Equiv.swap_apply_left]; rw [Fin.val_lt_iff, Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff]; simp [p_n_hn]
    · rw [p_, Function.iterate_succ_apply, move, Equiv.trans_apply, hi]; simp [Position.swapped, v_val, p_n_hn, Equiv.swap_apply_right]; rw [Fin.val_lt_iff, Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff]; simp [p_n_hn]
    · rw [p_, Function.iterate_succ_apply, move, Equiv.trans_apply, hi, Equiv.swap_apply_of_ne_of_ne]; rw [Fin.val_lt_iff, Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff]; simp [hi, p_n_hn]
      · intro e; exact h1 (by rw [e, Fin.sub_add_cancel])
      · intro e; exact h2 (by rw [e, Fin.add_sub_cancel])
  have m_step : ∀ n < 2021, m (n + 1) = m n := by
    intro n hn; let h_n := (p_ n).symm n; have p_n_hn : p_ n h_n = n := (p_ n).apply_symm_apply n
    have xn_h : x n h_n = 0 := by simp [x, p_n_hn]
    specialize h ⟨n, hn⟩; rw [Position.nth, v_val] at h; simp [Position.swapped, p_n_hn] at h
    let a := p_ n (h_n - 1); let b := p_ n (h_n + 1)
    have ha : a ≠ n := by intro e; exact (Fin.sub_eq_self_iff.1 ((p_ n).injective (e.trans p_n_hn.symm)) (by decide)).elim
    have hb : b ≠ n := by intro e; exact (Fin.add_eq_self_iff.1 ((p_ n).injective (e.trans p_n_hn.symm)) (by decide)).elim
    have x_ab : x n (h_n - 1) = x n (h_n + 1) := by simp [x, a, b]; rcases lt_trichotomy a.val n with h1|h1|h1 <;> rcases lt_trichotomy b.val n with h2|h2|h2 <;> simp_all
    rw [m, m, ← Finset.sum_sub_distrib]; have h_dis : ∀ i ∉ ({h_n, h_n - 1, h_n + 1, h_n - 2} : Finset (Fin 2021)), x (n + 1) i * x (n + 1) (i + 1) - x n i * x n (i + 1) = 0 := by
      intro i hi; rw [x_step n hn i, x_step n hn (i + 1)]; simp at hi; repeat (split_ifs with hi2 <;> try (exfalso; simp [hi2] at hi; done)); rfl
    rw [Finset.sum_eq_sum_diff_forall_hom_zero _ _ h_dis]; simp; rw [x_step n hn h_n, x_step n hn (h_n - 1), x_step n hn (h_n + 1), x_step n hn (h_n - 2), x_step n hn (h_n + 1 + 1)]; simp [xn_h, x_ab]; ring
  have m_0 : m 0 = 0 := by simp [m, x]
  have m_2021 : m 2021 = 1 := by rw [m]; have : ∀ i, x 2021 i = 1 := fun i => by simp [x, (p_ 2021 i).is_lt]; simp [this, (by decide : (2021 : ZMod 2) = 1)]
  have m_final : m 2021 = m 0 := by induction 2021 with | zero => rfl | succ n ih => rw [m_step n (Nat.lt_succ_self n), ih]
  exact (by simp [m_2021, m_0] at m_final)

