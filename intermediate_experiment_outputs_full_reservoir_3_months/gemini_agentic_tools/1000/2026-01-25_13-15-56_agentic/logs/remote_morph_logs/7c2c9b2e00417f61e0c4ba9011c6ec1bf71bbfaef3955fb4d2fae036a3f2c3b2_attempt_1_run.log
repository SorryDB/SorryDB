import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let P (k : ℕ) : Position × Fin 2021 := move^[k] (p, 0)
  let p_ (k : ℕ) : Position := (P k).1
  let m (k : ℕ) : ℕ := (Finset.univ.filter (fun i : Fin 2021 => (p_ k i).val < k ∧ ¬((p_ k (i + 1)).val < k))).card
  have m_parity : ∀ k < 2021, (m (k + 1) : ZMod 2) = m k + 1 := by
    intro k hk
    let kf : Fin 2021 := ⟨k, hk⟩
    have n_k : (P k).2 = kf := by
      induction k with
      | zero => rfl
      | succ k ih =>
        have hks : k < 2021 := Nat.lt_of_succ_lt hk
        simp [P, iterate_succ_apply, move, ih hks]
    let h_k := (p_ k).symm kf
    let w := (p_ k).swapped kf
    have h_w : (w.1.val < k ↔ w.2.val < k) := by
      specialize h kf
      have p_nth : p.nth kf = p_ k := by simp [Position.nth, P]
      rw [p_nth] at h
      simp [Position.swapped] at h
      rcases lt_trichotomy w.1.val k with h1 | h1 | h1 <;>
      rcases lt_trichotomy w.2.val k with h2 | h2 | h2
      all_goals (try simp [h1, h2] at h ⊢; try rfl)
      · have : (p_ k (h_k - 1)).val = k := by simp [Position.swapped] at h1; rw [h1]
        have : h_k - 1 = h_k := (p_ k).injective (by simp [this, h_k])
        exact (sub_self_iff_eq_zero.mp (by rw [this])).elim (by decide)
      · have : (p_ k (h_k + 1)).val = k := by simp [Position.swapped] at h2; rw [h2]
        have : h_k + 1 = h_k := (p_ k).injective (by simp [this, h_k])
        exact (add_self_iff_eq_zero.mp (by rw [Fin.ext_iff] at this; simp at this; rw [this]; decide)).elim (by decide)
    have S_inv : ∀ i, (p_ (k + 1) i).val < k ↔ (p_ k i).val < k := by
      intro i
      simp [p_, P, iterate_succ_apply, move, n_k]
      by_cases hi : i = h_k - 1
      · simp [hi, w, h_w]
      · by_cases hi2 : i = h_k + 1
        · simp [hi2, w, h_w]
        · have : (p_ k).trans (Equiv.swap w.1 w.2) i = p_ k i := by
            simp [Equiv.trans_apply, Equiv.swap_apply_def]
            split_ifs with h1 h2
            · have : i = h_k - 1 := (p_ k).injective (by simp [h1, w])
              contradiction
            · have : i = h_k + 1 := (p_ k).injective (by simp [h2, w])
              contradiction
          simp [this]
    have S_succ : ∀ i, (p_ (k + 1) i).val < k + 1 ↔ (p_ k i).val < k ∨ i = h_k := by
      intro i
      rw [Nat.lt_succ_iff_lt_or_eq, ← S_inv i]
      constructor
      · rintro (h1 | h1)
        · left; exact h1
        · right
          simp [p_, P, iterate_succ_apply, move, n_k] at h1
          have h_move : (p_ k).trans (Equiv.swap w.1 w.2) i = kf := Fin.ext h1
          have h_k_val : p_ k h_k = kf := by simp [h_k]
          have : i = h_k := by
            let e := Equiv.swap w.1 w.2
            have : e (p_ k i) = p_ k h_k := by rw [h_move, h_k_val]
            have : p_ k i = e (p_ k h_k) := by rw [← this, Equiv.symm_apply_apply]
            have : p_ k i = p_ k h_k := by
              simp [this, Equiv.swap_apply_def, w]
              split_ifs with h1 h2
              · exact (p_ k).injective (by simp [h1, h_k])
              · exact (p_ k).injective (by simp [h2, h_k])
            exact (p_ k).injective this
          exact this
      · rintro (h1 | h1)
        · left; exact h1
        · right; simp [p_, P, iterate_succ_apply, move, n_k, h1, h_k]
    let χ (k : ℕ) (i : Fin 2021) : ZMod 2 := if (p_ k i).val < k then 1 else 0
    have m_val : ∀ k, (m k : ZMod 2) = ∑ i : Fin 2021, χ k i * (1 - χ k (i + 1)) := by
      intro k; simp [m, χ, Finset.sum_ite, Finset.filter_filter]
    have χ_step : ∀ i, χ (k + 1) i = χ k i + (if i = h_k then 1 else 0) := by
      intro i; rw [χ, χ, S_succ]
      by_cases hi : i = h_k
      · simp [hi, h_k, χ]
      · simp [hi]
    rw [m_val, m_val, Finset.sum_congr rfl (fun i _ => χ_step i)]
    simp [add_mul, mul_add, mul_sub, sub_add, Finset.sum_add_distrib, χ_step]
    have h_hk : χ k h_k = 0 := by simp [χ, h_k]
    have h_hk1 : χ k (h_k + 1) = χ k (h_k + 1) := rfl
    simp [h_hk, Finset.sum_ite, h_hk1]
    rw [add_comm, ← add_assoc, add_right_inv, zero_add, add_comm]
    have : (1 : ZMod 2) - χ k (h_k + 1) - χ k (h_k - 1) = 1 := by
      have : χ k (h_k + 1) = χ k (h_k - 1) := by simp [χ, w, h_w]
      simp [this]
    exact this
  have m_0 : m 0 = 0 := by simp [m]
  have m_2021 : m 2021 = 0 := by
    simp [m]
    intro i
    have : (p_ 2021 i).val < 2021 := (p_ 2021 i).is_lt
    simp [this]
  have m_2021_parity : (m 2021 : ZMod 2) = 2021 := by
    induction 2021 with
    | zero => simp [m_0]
    | succ k ih =>
      have hks : k < 2021 := Nat.lt_succ_self k
      rw [m_parity k hks, ih]
      simp
  simp [m_2021] at m_2021_parity

