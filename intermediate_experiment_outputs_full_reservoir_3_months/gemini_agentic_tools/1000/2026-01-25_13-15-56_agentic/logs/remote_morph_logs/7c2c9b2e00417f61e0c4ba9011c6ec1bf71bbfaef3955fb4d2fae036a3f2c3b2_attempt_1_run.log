import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f k := (move^[k] (p, 0)).1
  let S k i := (f k i).val < k
  let m k := (Finset.univ.filter (λ i : Fin 2021 => S k i ∧ ¬S k (i + 1))).card
  have step : ∀ k < 2021, (m (k + 1) : ZMod 2) = m k + 1 := by
    intro k hk
    let a := (f k).swapped k
    have ha : (a.1.val < k) ↔ (a.2.val < k) := by
      specialize h k; simp [Position.swapped] at h ⊢
      rcases a.1.val.lt_or_gt k.val with hl | hg <;> rcases a.2.val.lt_or_gt k.val with hl2 | hg2 <;> simp [hl, hg, hl2, hg2] at h ⊢
      exacts [h.elim, h.elim]
    have hf : ∀ i, S (k + 1) i ↔ S k i ∨ f (k + 1) i = k := by
      intro i; simp [S, iterate_succ_apply', move, f]
      rw [Nat.lt_succ_iff, le_iff_lt_or_eq, ← (f k).symm_apply_apply i]
      by_cases hi : (f k).symm (f k i) = (f k).symm a.1 <;> by_cases hi2 : (f k).symm (f k i) = (f k).symm a.2
      · simp [hi, hi2, ha]
      · simp [hi, hi2, ha]
      · simp [hi, hi2, ha]
      · simp [hi, hi2]
    let h_pos := (f (k + 1)).symm k
    have hS : ∀ i, S (k + 1) i ↔ S k i ∨ i = h_pos := by intro i; rw [hf]; simp [h_pos]
    have hk_not_S : h_pos ∉ Finset.univ.filter (S k) := by simp [S, f, h_pos, move_pow_succ, move]
    set s0 := Finset.univ.filter (S k)
    have m_val : m k = (s0.filter (λ i => i + 1 ∉ s0)).card := by simp [m, s0]
    have m_next : m (k + 1) = ((s0 ∪ {h_pos}).filter (λ i => i + 1 ∉ s0 ∪ {h_pos})).card := by simp [m, hS, s0]
    have h_next : (m (k + 1) : ZMod 2) = m k + 1 := by
      have h1 : h_pos + 1 ∈ s0 ↔ h_pos - 1 ∈ s0 := by
        simp [s0, S, f, h_pos, move_pow_succ, move, Position.swapped, ha]
      by_cases hin : h_pos + 1 ∈ s0
      · have : m (k + 1) = m k - 1 := sorry -- Boundary at h_pos-1 is removed
        simp [this]
      · have : m (k + 1) = m k + 1 := sorry -- New boundary at h_pos is added
        simp [this]
    exact h_next
  have h_total : (m 2021 : ZMod 2) = m 0 + 2021 := by
    induction' 2021 with k ih
    · simp
    · rw [step k (Nat.lt_succ_self k), ih, Nat.cast_succ, add_assoc]
  have h0 : m 0 = 0 := by simp [m, S]
  have hn : m 2021 = 0 := by
    simp [m, S, f]
    have : ∀ i, (f 2021 i).val < 2021 := λ i => (f 2021 i).is_lt
    simp [this]
  simp [h0, hn] at h_total
