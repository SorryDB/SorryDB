import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f n := move^[n] (p, 0)
  let p_ n := (f n).1
  let v_ n := (f n).2
  let x (n : ℕ) (i : Fin 2021) : ZMod 2 := if p_ n i < (n : Fin 2021) then 1 else 0
  let m (n : ℕ) : ZMod 2 := ∑ i : Fin 2021, x n i * (1 + x n (i + 1))
  have v_val : ∀ n, v_ n = (n : Fin 2021) := by
    intro n; induction n with | zero => rfl | succ n ih => rw [v_, iterate_succ_apply, move, ih]; rfl
  have m_step : ∀ k < 2021, m (k + 1) = m k + 1 := by
    intro k hk
    let vk : Fin 2021 := ⟨k, hk⟩
    let h_k := (p_ k).symm vk
    have p_k_hk : p_ k h_k = vk := (p_ k).apply_symm_apply vk
    have h_xk : ∀ i, x (k + 1) i = x k i + if i = h_k then 1 else 0 := by
      intro i; simp [x, v_val, p_]
      rw [iterate_succ_apply, move, v_val]; simp [Equiv.trans_apply, Position.swapped, v_val]
      by_cases hi : i = h_k
      · simp [hi, p_k_hk]; rw [Fin.val_lt_iff]; omega
      · have hne : p_ k i ≠ vk := (p_ k).injective.ne hi
        have : (Equiv.swap (p_ k (h_k - 1)) (p_ k (h_k + 1)) (p_ k i)) < (k + 1 : Fin 2021) ↔
               (Equiv.swap (p_ k (h_k - 1)) (p_ k (h_k + 1)) (p_ k i)) < vk := by
          rw [Fin.lt_iff_val_lt_val, Fin.val_add_one, Nat.mod_eq_of_lt (Nat.succ_lt_of_lt_of_le hk (by decide))]
          rw [Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff]; simp [hne]
        rw [this]; specialize h vk; rw [Position.nth, v_val] at h
        simp [vk, p_k_hk, Position.swapped, p_] at h
        let a := p_ k (h_k - 1); let b := p_ k (h_k + 1)
        have ha : a ≠ vk := (p_ k).injective.ne (by simp [h_k]; intro e; exact (Fin.sub_eq_self_iff.1 e (by decide)).elim)
        have hb : b ≠ vk := (p_ k).injective.ne (by simp [h_k]; intro e; exact (Fin.add_eq_self_iff.1 e (by decide)).elim)
        have hab : (a < vk ↔ b < vk) := by
          rcases lt_trichotomy a vk with h1|h1|h1 <;> rcases lt_trichotomy b vk with h2|h2|h2
          all_goals (simp_all; try exact ha (Fin.ext h1); try exact hb (Fin.ext h2))
        by_cases hi1 : i = h_k - 1 <;> by_cases hi2 : i = h_k + 1
        all_goals (simp_all [Equiv.swap_apply_left, Equiv.swap_apply_right, Equiv.swap_apply_of_ne_of_ne, hab])
    simp [m, h_xk, add_mul, mul_add, Finset.sum_add_distrib]
    have h_ne : h_k + 1 ≠ h_k := by intro e; exact (Fin.add_right_cancel e 1).elim
    have h_ne2 : h_k - 1 + 1 = h_k := Fin.sub_add_cancel _ _
    simp [h_ne, h_ne2, x, p_k_hk]
    have : x k (h_k - 1) = x k (h_k + 1) := by
      specialize h ⟨k, hk⟩; rw [Position.nth, v_val] at h; simp [vk, p_k_hk, Position.swapped, p_] at h
      let a := p_ k (h_k - 1); let b := p_ k (h_k + 1)
      simp [x, a, b]; rcases lt_trichotomy a vk with h1|h1|h1 <;> rcases lt_trichotomy b vk with h2|h2|h2
      all_goals (simp_all; try exact (p_ k).injective.ne (by simp [h_k]) (Fin.ext h1); try exact (p_ k).injective.ne (by simp [h_k]) (Fin.ext h2))
    simp [this]
  have m_0 : m 0 = 0 := by simp [m, x]
  have m_2021 : m 2021 = 0 := by
    simp [m, x]; have : ∀ i, x 2021 i = 1 := fun i => by simp [x]; apply Fin.is_lt
    simp [this]
  have : m 2021 = m 0 + (2021 : ZMod 2) := by
    induction 2021 with | zero => rfl | succ k ih => rw [m_step k (Nat.lt_succ_self k), ih]; simp
  simp [m_0, m_2021] at this

