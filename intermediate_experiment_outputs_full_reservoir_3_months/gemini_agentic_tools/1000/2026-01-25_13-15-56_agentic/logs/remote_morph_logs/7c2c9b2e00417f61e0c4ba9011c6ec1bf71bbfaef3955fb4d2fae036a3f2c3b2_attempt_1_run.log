import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f n := move^[n] (p, 0)
  let p_ n := (f n).1
  let v_ n := (f n).2
  let x (n : ℕ) (i : Fin 2021) : ZMod 2 := if (p_ n i).val < n then 1 else 0
  let m (n : ℕ) : ZMod 2 := ∑ i, x n i * x n (i + 1)
  have v_val : ∀ n, v_ n = (n : Fin 2021) := by
    intro n; induction n with | zero => rfl | succ n ih => rw [v_, Function.iterate_succ_apply', move, ih]; rfl
  have m_step : ∀ n < 2021, m (n + 1) = m n := by
    intro n hn
    let vn : Fin 2021 := ⟨n, hn⟩
    have v_n_val : v_ n = vn := v_val n
    let h_n := (p_ n).symm vn
    have p_n_hn : p_ n h_n = vn := (p_ n).apply_symm_apply _
    let a := p_ n (h_n - 1)
    let b := p_ n (h_n + 1)
    have ha : a ≠ vn := (p_ n).injective.ne (by simp [Fin.ext_iff]; omega)
    have hb : b ≠ vn := (p_ n).injective.ne (by simp [Fin.ext_iff]; omega)
    have x_ab : x n (h_n - 1) = x n (h_n + 1) := by
      specialize h vn; simp [Position.nth, Position.swapped, v_n_val, p_n_hn, p_] at h
      simp [x, a, b]; rcases lt_trichotomy a vn with h1|h1|h1 <;> rcases lt_trichotomy b vn with h2|h2|h2
      all_goals (try simp_all; try exact ha (Fin.ext h1); try exact hb (Fin.ext h2))
    have h_p : p_ (n + 1) = (p_ n).trans (Equiv.swap a b) := by rw [p_, Function.iterate_succ_apply', move, v_n_val, Position.swapped, p_n_hn, p_]; rfl
    have h_xi : ∀ i, x (n + 1) i = if i = h_n then 1 else if i = h_n - 1 then x n (h_n + 1) else if i = h_n + 1 then x n (h_n - 1) else x n i := by
      intro i; simp [x, h_p, Equiv.trans_apply]; by_cases hi : i = h_n
      · simp [hi, p_n_hn, Equiv.swap_apply_of_ne_of_ne ha.symm hb.symm]; rw [Nat.lt_succ_iff]; exact le_refl _
      · have hni : p_ n i ≠ vn := (p_ n).injective.ne hi
        rw [Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff, or_iff_left hni]
        by_cases hi1 : i = h_n - 1
        · simp [hi1, Equiv.swap_apply_left]; rfl
        · by_cases hi2 : i = h_n + 1
          · simp [hi2, Equiv.swap_apply_right]; rfl
          · simp [hi, hi1, hi2, Equiv.swap_apply_of_ne_of_ne ((p_ n).injective.ne hi1) ((p_ n).injective.ne hi2)]; rfl
    let d (i : Fin 2021) := x (n + 1) i * x (n + 1) (i + 1) - x n i * x n (i + 1)
    have d_zero : ∀ i ∉ ({h_n - 2, h_n - 1, h_n, h_n + 1} : Finset (Fin 2021)), d i = 0 := by
      intro i hi; simp at hi; have i_nh : i ≠ h_n := hi.2.2.1; have i1_nh : i + 1 ≠ h_n := by intro e; exact hi.2.1 (Fin.eq_sub_of_add_eq e);
      have i_nhm : i ≠ h_n - 1 := hi.2.1; have i1_nhm : i + 1 ≠ h_n - 1 := by intro e; exact hi.1 (Fin.eq_sub_of_add_eq (e.trans (by rfl)));
      have i_nhp : i ≠ h_n + 1 := hi.2.2.2; have i1_nhp : i + 1 ≠ h_n + 1 := by intro e; exact hi.2.2.1 (add_right_cancel e);
      simp [d, h_xi, i_nh, i_nhm, i_nhp, i1_nh, i1_nhm, i1_nhp]
    rw [m, m, ← Finset.sum_sub_distrib, Finset.sum_eq_sum_diff_forall_hom_zero _ _ d_zero]; simp [d, h_xi, x_ab]; have xn_hn : x n h_n = 0 := by simp [x, p_n_hn]
    simp [xn_hn, x_ab]; ring
  have m_0 : m 0 = 0 := by simp [m, x]
  have m_2021 : m 2021 = 1 := by
    simp [m, x]; have : ∀ i, x 2021 i = 1 := fun i => by simp [x]; exact (p_ 2021 i).is_lt
    simp [this, (by decide : (2021 : ZMod 2) = 1)]
  have m_final : m 2021 = m 0 := by induction 2021 with | zero => rfl | succ n ih => rw [m_step n (Nat.lt_succ_self n), ih]
  simp [m_0, m_2021] at m_final

end IMO2021P5
