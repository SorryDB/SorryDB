  let P (k : ℕ) := move^[k] (p, 0)
  let p_ k := (P k).1
  let v_ k := (P k).2
  let x (k : ℕ) (i : Fin 2021) : ZMod 2 := if (p_ k i).val < (v_ k).val then 1 else 0
  let m (k : ℕ) : ZMod 2 := ∑ i : Fin 2021, x k i * (1 + x k (i + 1))
  have v_step : ∀ k, v_ (k + 1) = v_ k + 1 := fun k => by rw [v_, iterate_succ_apply, move]; rfl
  have v_val : ∀ k ≤ 2021, (v_ k).val = k % 2021 := by
    intro k _; induction k with | zero => rfl | succ k ih =>
      rw [v_step, Fin.val_add_one]; rw [ih (Nat.le_of_succ_le ‹_›)]; rfl
  have h_x_iff : ∀ k < 2021, x k ((p_ k).symm (v_ k) - 1) = x k ((p_ k).symm (v_ k) + 1) := by
    intro k hk; specialize h (v_ k); simp [Position.swapped, Position.nth, p_, P] at h
    let a := p_ k ((p_ k).symm (v_ k) - 1); let b := p_ k ((p_ k).symm (v_ k) + 1)
    have : (a.val < (v_ k).val ↔ b.val < (v_ k).val) := by
      have nea : a ≠ v_ k := by
        intro e; have : (p_ k).symm a = (p_ k).symm (v_ k) := by rw [e]
        simp at this; exact (Fin.sub_self _ 1).1 (by simp [this])
      have neb : b ≠ v_ k := by
        intro e; have : (p_ k).symm b = (p_ k).symm (v_ k) := by rw [e]
        simp at this; exact (Fin.add_self _ 1).1 (by simp [this])
      rcases lt_trichotomy a.val (v_ k).val with h1 | h1 | h1 <;>
      rcases lt_trichotomy b.val (v_ k).val with h2 | h2 | h2
      all_goals (try simp_all; try rfl; try exact (nea (Fin.ext h1)).elim; try exact (neb (Fin.ext h2)).elim)
    simp [x, this]
  have m_step : ∀ k < 2021, m (k + 1) = m k + 1 := by
    intro k hk; let ik := (p_ k).symm (v_ k)
    have xi : ∀ i, x (k + 1) i = x k i + (if i = ik then 1 else 0) := by
