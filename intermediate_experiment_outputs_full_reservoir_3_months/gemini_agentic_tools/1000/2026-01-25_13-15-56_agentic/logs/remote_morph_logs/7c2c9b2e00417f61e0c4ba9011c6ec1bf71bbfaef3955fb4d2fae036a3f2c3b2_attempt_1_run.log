import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let f n := move^[n] (p, 0)
  let p_ n := (f n).1
  let v_ n := (f n).2
  let x n i : ZMod 2 := if (p_ n i).val < n then 1 else 0
  let m n : ZMod 2 := ∑ i : Fin 2021, x n i * x n (i + 1)
  have v_val : ∀ n < 2021, v_ n = (n : Fin 2021) := by
    intro n hn
    induction n with
    | zero => rfl
    | succ n ih =>
      rw [v_, Function.iterate_succ_apply, move, ← v_, ih (Nat.lt_of_succ_lt hn)]
      simp [Fin.ext_iff, Nat.mod_eq_of_lt hn]
  have m_step : ∀ n < 2021, m (n + 1) = m n := by
    intro n hn
    have vn : v_ n = (n : Fin 2021) := v_val n hn
    let h_n := (p_ n).symm ⟨n, hn⟩
    have p_n_hn : p_ n h_n = ⟨n, hn⟩ := (p_ n).apply_symm_apply _
    have x_step : ∀ i, x (n + 1) i = x n i + if i = h_n then 1 else 0 := by
      intro i
      simp [x, p_, Function.iterate_succ_apply, move, vn]
      let a := (p_ n) (h_n - 1)
      let b := (p_ n) (h_n + 1)
      have ha : a ≠ ⟨n, hn⟩ := (p_ n).injective.ne (by intro e; have : (1 : Fin 2021) = 0 := by simpa [Fin.ext_iff] using e; omega)
      have hb : b ≠ ⟨n, hn⟩ := (p_ n).injective.ne (by intro e; have : (1 : Fin 2021) = 0 := by simpa [Fin.ext_iff] using e; omega)
      have hab : (a < ⟨n, hn⟩ ↔ b < ⟨n, hn⟩) := by
        specialize h ⟨n, hn⟩; rw [Position.nth, Position.swapped] at h; simp [vn, p_n_hn, p_] at h
        rcases lt_trichotomy a ⟨n, hn⟩ with h1|h1|h1 <;> rcases lt_trichotomy b ⟨n, hn⟩ with h2|h2|h2
        all_goals (simp_all; try exact ha h1; try exact hb h2)
      rw [Nat.lt_succ_iff, le_iff_lt_or_eq, ← Fin.ext_iff]
      by_cases hi : i = h_n
      · simp [hi, p_n_hn, Equiv.swap_apply_of_ne_of_ne ha.symm hb.symm, x]
      · have h_ni : p_ n i ≠ ⟨n, hn⟩ := (p_ n).injective.ne hi
        simp [hi, h_ni, x]
        by_cases hia : p_ n i = a
        · simp [hia, Equiv.swap_apply_left, hab]
        · by_cases hib : p_ n i = b
          · simp [hib, Equiv.swap_apply_right, hab]
          · simp [Equiv.swap_apply_of_ne_of_ne hia hib]
    simp [m, x_step, add_mul, mul_add, Finset.sum_add_distrib]
    have h_h1 : ∀ i, i + 1 = h_n ↔ i = h_n - 1 := fun i => by rw [← Fin.sub_eq_iff_eq_add]; rfl
    have h_h2 : ∀ i, i = h_n ∧ i + 1 = h_n ↔ False := fun i => by simp [Fin.ext_iff]; intro e; omega
    simp [Finset.sum_ite, h_h1, h_h2, x]
    let a := (p_ n) (h_n - 1)
    let b := (p_ n) (h_n + 1)
    have hab : (a.val < n ↔ b.val < n) := by
      specialize h ⟨n, hn⟩; rw [Position.nth, Position.swapped] at h; simp [vn, p_n_hn, p_] at h
      have ha : a ≠ ⟨n, hn⟩ := (p_ n).injective.ne (by intro e; have : (1 : Fin 2021) = 0 := by simpa [Fin.ext_iff] using e; omega)
      have hb : b ≠ ⟨n, hn⟩ := (p_ n).injective.ne (by intro e; have : (1 : Fin 2021) = 0 := by simpa [Fin.ext_iff] using e; omega)
      rcases lt_trichotomy a ⟨n, hn⟩ with h1|h1|h1 <;> rcases lt_trichotomy b ⟨n, hn⟩ with h2|h2|h2
      all_goals (simp_all; try exact ha h1; try exact hb h2)
    simp [hab]
  have m_0 : m 0 = 0 := by simp [m, x]
  have m_2021 : m 2021 = 1 := by
    simp [m, x]
    have : ∀ i : Fin 2021, x 2021 i = 1 := fun i => by simp [x]; exact (p_ 2021 i).is_lt
    simp [this, Fintype.card_fin]
  have m_final : m 2021 = m 0 := by
    induction 2021 with
    | zero => rfl
    | succ n ih => rw [m_step n (Nat.lt_succ_self n), ih]
  simp [m_0, m_2021] at m_final

end IMO2021P5
