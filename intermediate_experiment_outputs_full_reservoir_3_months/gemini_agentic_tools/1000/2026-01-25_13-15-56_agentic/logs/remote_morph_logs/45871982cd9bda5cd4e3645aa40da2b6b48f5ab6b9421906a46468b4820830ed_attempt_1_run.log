    have S_len_def : ∀ k, S.length = 2 * m - 2 - v S k + c k := by
      intro k
      have := noHo_exp_and_known_needs_many_calls S noHo_S k (S_allExp k) (fun j => S_allExp j k)
      exact (Nat.add_tsub_cancel_of_le this).symm
