import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  if hn : n < 3 then
    cases' n with n
    · left; use 0; intro j; simp [Finset.card_eq_zero.1 hn.symm] at j; exact j.elim0
    · cases' n with n
      · left; use 0; intro j; subst j; have : Subsingleton (Fin 1) := inferInstance; have : Subsingleton S := by rw [← Finset.card_eq_one] at hn; exact { elim := fun x y => by obtain ⟨i, hi⟩ := p₁.surjective x; obtain ⟨l, hl⟩ := p₁.surjective y; rw [← hi, ← hl, Subsingleton.elim i l] }
        exact Subsingleton.elim (p₂ 0) (p₁ 0)
      · left; let i0 := p₁.symm (p₂ 0)
        use i0; intro j; fin_cases j
        · simp
        · have hS2 : S.card = 2 := by linarith
          have : j = 1 := by exact Fin.ext (by simp [j])
          subst this
          have h0 : p₂ 0 = p₁ i0 := by simp
          have h1 : p₂ 1 ≠ p₂ 0 := p₂.injective.ne (by simp)
          have h2 : p₁ (1 + i0) ≠ p₁ i0 := p₁.injective.ne (by simp)
          have h_elem : ∀ x ∈ S, x = p₂ 0 ∨ x = p₂ 1 := by
            intro x hx; obtain ⟨i, hi⟩ := p₂.surjective ⟨x, hx⟩; fin_cases i <;> simp at hi <;> simp [hi]
          have := h_elem (p₁ (1 + i0)) (p₁ (1 + i0)).2
          rcases this with e | e
          · exfalso; exact h2 e
          · exact e.symm
  else
    have : NeZero n := ⟨by linarith⟩
    let Rel (a b : ℕ) : Prop := ∃ x, 0 < x ∧ a * b = x ^ 2 + x + k
    have h_low_deg : ∀ a ∈ S, {b ∈ S | Rel a b ∧ b < a}.card ≤ 2 := by
      intro a ha
      have hpa : a.Prime := (hS a ha).2
      have h_roots : {x ∈ Finset.range a | (x ^ 2 + x + k) % a = 0}.card ≤ 2 := by
        let P : (ZMod a)[X] := Polynomial.X^2 + Polynomial.X + Polynomial.C (k : ZMod a)
        have hP : P ≠ 0 := by intro h; have := (Polynomial.coeff P 2); simp [P] at this
        have := Polynomial.card_roots_le_degree (p := P)
        simp [P] at this
        let roots_zmod := (P.roots).toFinset
        have h_sub : {x ∈ Finset.range a | (x ^ 2 + x + k) % a = 0} ⊆ roots_zmod.map (ZMod.valEmbedding a) := by
          intro x hx; simp at hx ⊢; use ↑x; constructor
          · rw [Polynomial.IsRoot, Polynomial.eval_add, Polynomial.eval_add, Polynomial.eval_pow, Polynomial.eval_X, Polynomial.eval_C]
            simp; rw [← ZMod.val_eq_zero]; simp [hx.2]
          · exact ZMod.val_nat_cast x
        exact (Finset.card_le_card h_sub).trans (by simp; exact this)
      apply (Finset.card_le_card (fun b hb ↦ by
        simp at hb; obtain ⟨x, hx_pos, hx_eq⟩ := hb.1
        have hx_lt : x < a := by
          have : x^2 < x^2 + x + k := by linarith
          rw [← hx_eq] at this; exact (Nat.mul_lt_mul_left (hk.trans_le (by linarith))).mp (this.trans (by rw [mul_comm]; exact Nat.mul_lt_mul_of_pos_right hb.2 (hk.trans_le (by linarith))))
        simp; use x; simp [hx_lt]; rw [← hx_eq]; simp)).trans h_roots
    have h_edges : ∀ {p : Fin n ≃ S}, Condition k S p → ∀ i, { (p i : ℕ), (p (i + 1) : ℕ) } ⊆ { b ∈ S | Rel (p i) b } := by
      intro p hp i; intro b hb; simp at hb; simp
      rcases hb with rfl | rfl
      · use (p i).2; rw [mul_comm]; exact hp (i - 1)
      · use (p (i + 1)).2; exact hp i
    have h_unique_edges : ∀ i, { (p₁ i : ℕ), (p₁ (i + 1) : ℕ) } = { (p₂ (p₂.symm (p₁ i)) : ℕ), (p₂ (p₂.symm (p₁ i) + 1) : ℕ) } ∨ { (p₁ i : ℕ), (p₁ (i + 1) : ℕ) } = { (p₂ (p₂.symm (p₁ i)) : ℕ), (p₂ (p₂.symm (p₁ i) - 1) : ℕ) } := sorry
    sorry
