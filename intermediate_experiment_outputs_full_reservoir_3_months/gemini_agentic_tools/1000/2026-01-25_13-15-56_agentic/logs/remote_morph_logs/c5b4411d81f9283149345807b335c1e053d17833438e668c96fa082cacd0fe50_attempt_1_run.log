import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  set E := {e : Finset ℕ | ∃ a ∈ S, ∃ b ∈ S, e = {a, b} ∧ ∃ x > 0, a * b = x^2 + x + k}
  have deg_max (T : Finset ℕ) (hT : T ⊆ S) (hT_nonempty : T.Nonempty) :
    let m := T.max' hT_nonempty
    {e ∈ E | m ∈ e ∧ e ⊆ T}.card ≤ 2 := by
    intro m
    let roots := {x : ℕ | x < m ∧ (x^2 + x + k) % m = 0}
    have roots_le_2 : roots.Finite ∧ roots.toFinset.card ≤ 2 := by
      have hm : 1 < m := (hS m (hT (T.max'_mem hT_nonempty))).2.two_le
      refine ⟨(Set.finite_mem_finset (Finset.range m)).subset (λ x hx => by simp; exact hx.1), ?_⟩
      have : m.Prime := (hS m (hT (T.max'_mem hT_nonempty))).2
      exact Nat.card_roots_finite_field_poly (p := m) (Polynomial.X^2 + Polynomial.X + Polynomial.C (k : ZMod m)) (by simp)
    have e_subset : {e ∈ E | m ∈ e ∧ e ⊆ T} ⊆ (λ x => {m, (x^2 + x + k) / m}) '' roots := by
      rintro e ⟨⟨a, ha, b, hb, rfl, x, hx, h_eq⟩, hm_in, he_sub⟩
      simp at hm_in; rcases hm_in with rfl | rfl
      · have : b < m ∨ b = m := hT he_sub (by simp)
        if h_bm : b = m then
          exfalso; rw [h_bm] at h_eq; linarith [hS m (hT (T.max'_mem hT_nonempty)), hx]
        else
          have h_bm : b < m := (hT he_sub (by simp)).lt_of_ne h_bm
          have hx_m : x < m := by
            have : x^2 < x^2 + x + k := by linarith
            rw [← h_eq] at this; linarith [h_bm]
          refine ⟨x, ⟨hx_m, ?_⟩, ?_⟩
          · rw [← h_eq]; simp
          · rw [h_eq]; simp
      · have : a < m ∨ a = m := hT he_sub (by simp)
        if h_am : a = m then
          exfalso; rw [h_am] at h_eq; linarith [hS m (hT (T.max'_mem hT_nonempty)), hx]
        else
          have h_am : a < m := (hT he_sub (by simp)).lt_of_ne h_am
          have hx_m : x < m := by
            have : x^2 < x^2 + x + k := by linarith
            rw [← h_eq] at this; linarith [h_am]
          refine ⟨x, ⟨hx_m, ?_⟩, ?_⟩
          · rw [← h_eq]; simp
          · rw [h_eq, mul_comm]; simp
    exact (Finset.card_le_card (e_subset.toFinset)).trans (by simp; exact roots_le_2.2)
  have edge_p1 : ∀ i : Fin n, {p₁ i, p₁ (i + 1)} ∈ E := λ i => ⟨p₁ i, (p₁ i).2, p₁ (i + 1), (p₁ (i + 1)).2, rfl, hp₁ i⟩
  have edge_p2 : ∀ i : Fin n, {p₂ i, p₂ (i + 1)} ∈ E := λ i => ⟨p₂ i, (p₂ i).2, p₂ (i + 1), (p₂ (i + 1)).2, rfl, hp₂ i⟩
  induction S using Finset.strong_induction_on with
  | H T ih =>
    if h_empty : T.Empty then
      left; use 0; intro j; simp [h_empty] at j; exact j.elim0
    else
      have hT_nonempty : T.Nonempty := Finset.nonempty_of_not_empty h_empty
      let m := T.max' hT_nonempty
      have h_m_edges : ∀ {p : Fin n ≃ T}, (∀ i, {p i, p (i + 1)} ∈ E) → {p (p.symm m - 1), p (p.symm m + 1)} = {e \ {m} | e ∈ E, m ∈ e, e ⊆ T}.image (λ s => s.anyElement) := sorry
      sorry
