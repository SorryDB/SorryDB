import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  if hn : n < 3 then
    cases n with
    | zero =>
      simp [Finset.card_eq_zero] at hn
      have : Subsingleton (Fin 0 ≃ ↥S) := by rw [hn]; infer_instance
      left; use 0; intro j; exact j.elim0
    | succ n =>
      cases n with
      | zero =>
        left; use 0; intro j; simp; exact p₁.ext_iff.mp (Subsingleton.elim p₂ p₁) j
      | succ n =>
        left; use (p₁.symm (p₂ 0)); intro j
        fin_cases j
        · simp
        · fin_cases n
          · have h : n = 0 := rfl
            have hj : j = 1 := rfl
            simp [hj, h]
            have : ∀ (x y : S), x = y ∨ x ≠ y := λ x y => em (x = y)
            obtain h0 | h0 := this (p₂ 1) (p₁ (1 + p₁.symm (p₂ 0)))
            · exact h0
            · have : S.card = 2 := by linarith
              have hS_elems : ∀ x : S, x = p₂ 0 ∨ x = p₂ 1 := by
                intro x; obtain ⟨i, hi⟩ := p₂.surjective x; fin_cases i <;> simp [hi]
              have : p₁ (1 + p₁.symm (p₂ 0)) = p₂ 0 := by
                obtain h1 | h1 := hS_elems (p₁ (1 + p₁.symm (p₂ 0)))
                · exact h1
                · contradiction
              rw [this]
              have h_eq : p₁ (p₁.symm (p₂ 0)) = p₂ 0 := p₁.apply_symm_apply (p₂ 0)
              have h_cycle : p₁ 0 ≠ p₁ 1 := by simp [Fin.ext_iff]
              have h_p1_elems : ∀ x : S, x = p₁ 0 ∨ x = p₁ 1 := by
                intro x; obtain ⟨i, hi⟩ := p₁.surjective x; fin_cases i <;> simp [hi]
              contradiction
  else
    have h_deg : ∀ a ∈ S, {b ∈ S | ∃ x > 0, (a : ℕ) * b = x^2 + x + k}.card ≤ 2 := sorry
    have h_edges : ∀ i, {p₁ (i - 1), p₁ (i + 1)} = {b ∈ S | ∃ x > 0, (p₁ i : ℕ) * b = x ^ 2 + x + k} := by
      intro i
      have h1 : p₁ (i + 1) ∈ {b ∈ S | ∃ x > 0, (p₁ i : ℕ) * b = x ^ 2 + x + k} := by
        simp; exact hp₁ i
      have h2 : p₁ (i - 1) ∈ {b ∈ S | ∃ x > 0, (p₁ i : ℕ) * b = x ^ 2 + x + k} := by
        simp; have h := hp₁ (i - 1); simp at h; rw [mul_comm]; exact h
      have h_diff : p₁ (i + 1) ≠ p₁ (i - 1) := by
        intro h; apply_fun p₁.symm at h; simp at h
        have : (2 : Fin n) = 0 := by rw [← sub_eq_zero] at h; exact h
        have : n ∣ 2 := (Fin.ext_iff.mp this)
        linarith
      refine (Finset.eq_of_subset_of_card_le (λ b hb => ?_) ?_).symm
      · simp at hb; rcases hb with rfl | rfl <;> assumption
      · rw [Finset.card_doubleton h_diff.symm]
        apply h_deg; exact (p₁ i).2
    have h_same_edges : ∀ i, {p₂ (i - 1), p₂ (i + 1)} = {p₁ (p₁.symm (p₂ i) - 1), p₁ (p₁.symm (p₂ i) + 1)} := by
      intro i
      rw [h_edges, h_edges]
      simp
    sorry
