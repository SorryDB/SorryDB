      revert k_f i0; rw [‹n = 2›]; intro k_f i_f; fin_cases k_f <;> fin_cases i_f <;>
      simp [← hk_f]
    rcases h_S (p₂ 1) with e | e
    · exfalso; exact h_p2_ne (e.trans (by simp [i0]))
    · exact e
