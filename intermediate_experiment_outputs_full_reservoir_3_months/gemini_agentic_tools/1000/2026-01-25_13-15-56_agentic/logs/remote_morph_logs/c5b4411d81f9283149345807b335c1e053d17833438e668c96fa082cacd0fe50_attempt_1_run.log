    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  rcases h_n : #S with _ | n'
  · sorry
  · haveI : NeZero #S := ⟨by rw [h_n]; exact Nat.succ_ne_zero _⟩
    rcases n' with rfl | n''
    · left; use 0; intro j
      haveI : Subsingleton ↥S := Fintype.card_le_one_iff_subsingleton.mpr (by simp [h_n])
      apply Subsingleton.elim
    · rcases n'' with rfl | n'''
      · let i := p₁.symm (p₂ 0)
        have hi : p₁ i = p₂ 0 := p₁.apply_symm_apply (p₂ 0)
        left; use i; intro j
        have h_n2 : #S = 2 := h_n.trans rfl
        revert j i; rw [h_n2]; intro j i; fin_cases j
        · simp [hi]
        · have h_S : ∀ x : ↥S, x = p₁ i ∨ x = p₁ (i + 1) := by
            intro x; obtain ⟨k_f, hk_f⟩ := p₁.surjective x
            revert k_f i; intro k_f i; fin_cases k_f <;> fin_cases i <;> simp [← hk_f]
          rcases h_S (p₂ 1) with e | e
          · exfalso; exact p₂.injective.ne (by decide) (e.trans hi.symm)
          · exact e
      · -- Case n ≥ 3: The uniqueness follows from the property that for any p ∈ S,
        -- there are at most two q < p such that pq = x² + x + k. This implies any
        -- Hamiltonian cycle in the graph of allowed edges is unique up to rotation/reflection.
        sorry
