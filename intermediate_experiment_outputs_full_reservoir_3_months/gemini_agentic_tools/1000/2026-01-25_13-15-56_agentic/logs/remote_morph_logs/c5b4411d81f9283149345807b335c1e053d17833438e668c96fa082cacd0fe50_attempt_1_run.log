    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  if h_n0 : n = 0 then
    sorry
  else if h_n1 : n = 1 then
    left; use ⟨0, by omega⟩; intro j
    haveI : Subsingleton (Fin n) := ⟨λ a b => Fin.ext (by 
      have ha := a.is_lt; have hb := b.is_lt; rw [h_n1] at ha hb; 
      have : a.val = 0 := Nat.eq_zero_of_le_zero (Nat.le_of_lt_succ ha);
      have : b.val = 0 := Nat.eq_zero_of_le_zero (Nat.le_of_lt_succ hb);
      rw [this, ‹b.val = 0›])⟩
    haveI : Subsingleton S := by rw [← Fintype.card_coe, Finset.coe_sort_coe, ← h_n1]; infer_instance
    apply Subsingleton.elim
  else if h_n2 : n = 2 then
    left; let i := p₁.symm (p₂ 0); use i; intro j
    have hj : j = 0 ∨ j = 1 := by 
      have := j.is_lt; rw [h_n2] at this; rcases Nat.lt_succ_iff.mp this with h|h
      · left; exact Fin.ext h
      · right; exact Fin.ext (Nat.le_antisymm h (by exact Nat.succ_le_iff.mpr (by omega)))
    rcases hj with rfl | rfl
    · show p₂ 0 = p₁ (0 + i); simp; exact (p₁.apply_symm_apply (p₂ 0)).symm
    · show p₂ 1 = p₁ (1 + i)
      have : ∀ x, x = p₂ 0 ∨ x = p₂ 1 := by 
        intro x; obtain ⟨k_f, hk_f⟩ := p₂.surjective x; 
        have : k_f = 0 ∨ k_f = 1 := by
          have := k_f.is_lt; rw [h_n2] at this; rcases Nat.lt_succ_iff.mp this with h|h
          · left; exact Fin.ext h
          · right; exact Fin.ext (Nat.le_antisymm h (by exact Nat.succ_le_iff.mpr (by omega)))
        rcases this with rfl | rfl <;> simp [hk_f]
      have h_cases : p₁ (1 + i) = p₂ 0 ∨ p₁ (1 + i) = p₂ 1 := this (p₁ (1 + i))
      rcases h_cases with e | e
      · exfalso; have h_ne : 1 + i ≠ i := by 
          intro h; have : (1 : Fin 2) = 0 := by rw [h_n2] at h; injection h; omega
          injection this
        have : p₁ (1 + i) ≠ p₁ i := p₁.injective.ne h_ne
        rw [e, (p₁.apply_symm_apply (p₂ 0)).symm] at this; exact this rfl
      · exact e.symm
  else
    -- Case n ≥ 3: The uniqueness follows from the property that for any p ∈ S,
    -- its neighbors in any such cycle must be the two roots of x² + x + k ≡ 0 (mod p).
    -- This property implies that the set of edges is uniquely determined by S and k.
    sorry

