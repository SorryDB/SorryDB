import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have n_pos : 0 < S.card := by
    by_contra h
    simp at h
    rw [h] at p₁
    exact (p₁.toFun 0).2.2
  let n := S.card
  set d := 4 * k - 1
  have hd : d % 4 = 3 := by
    rw [Nat.sub_mul_mod_core (by linarith)]
    simp
  let Rel (a b : ℕ) : Prop := ∃ x, 0 < x ∧ a * b = x^2 + x + k
  have rel_iff (a b : ℕ) : Rel a b ↔ ∃ y, y > 1 ∧ Odd y ∧ 4 * a * b - d = y^2 := by
    constructor
    · rintro ⟨x, hx, h⟩
      use 2 * x + 1
      have h_odd : Odd (2 * x + 1) := ⟨x, rfl⟩
      refine ⟨by linarith, h_odd, ?_⟩
      rw [add_sq, mul_pow, ← mul_assoc]
      nth_rw 3 [← h]
      simp; ring
    · rintro ⟨y, hy, h_odd, h⟩
      obtain ⟨x, hx⟩ := h_odd.exists_bit1
      use x
      rw [hx] at hy
      refine ⟨by linarith, ?_⟩
      rw [hx, add_sq, mul_pow] at h
      linarith
  have h_neighbors : ∀ i : Fin n, Rel (p₁ i) (p₁ (i + 1)) := hp₁
  have h_neighbors2 : ∀ i : Fin n, Rel (p₂ i) (p₂ (i + 1)) := hp₂
  have deg_le_2 (a : ℕ) (ha : a ∈ S) : {b ∈ S | Rel a b}.card ≤ 2 := by
    set B := {b ∈ S | Rel a b}
    let f (b : ℕ) : ℕ := (Nat.sqrt (4 * a * b - d))
    have f_inj : ∀ b ∈ B, (f b)^2 = 4 * a * b - d := by
      intro b hb; simp at hb; obtain ⟨y, hy, ho, hq⟩ := (rel_iff a b).1 hb.2
      rw [hq, Nat.sqrt_set__sq]; rfl
    have f_odd : ∀ b ∈ B, Odd (f b) := by
      intro b hb; simp at hb; obtain ⟨y, hy, ho, hq⟩ := (rel_iff a b).1 hb.2
      rw [hq, Nat.sqrt_set__sq]; exact ho
    have f_mod : ∀ b ∈ B, (f b)^2 ≡ (d : ℤ) * (-1) [ZMOD a] := by
      intro b hb; simp at hb; obtain ⟨y, hy, ho, hq⟩ := (rel_iff a b).1 hb.2
      apply_fun (fun x => (x : ℤ)) at hq
      rw [hq]
      simp [Int.ModEq]
      ring_nf
      exact Int.dvd_zero _
    have f_range : ∀ b ∈ B, b < a → f b < 2 * a := by
      intro b hb hba; obtain ⟨y, hy, ho, hq⟩ := (rel_iff a b).1 (by simp at hb; exact hb.2)
      have : y^2 = 4 * a * b - d < 4 * a^2 := by linarith
      rw [hq] at this
      exact (Nat.pow_lt_pow_iff_left (by linarith) (by linarith)).1 this
    let sS := S.val.sort (· ≤ ·)
    induction S using Finset.strong_induction_on with
    | H s ih =>
      obtain ⟨s_max, hs_max, h_max⟩ := S.exists_maximal
      if h_is_max : a = s_max then
        have b_lt_a : ∀ b ∈ B, b < a := by
          intro b hb; simp at hb
          have : b ≤ a := h_max b hb.1
          exact this.lt_of_ne (λ h => by
            rw [h] at hb; obtain ⟨x, hx, heq⟩ := hb.2
            have : a * a = x^2 + x + k > a^2 := sorry -- impossible for primes
            contradiction)
        have : ∀ b ∈ B, f b < 2 * a := λ b hb => f_range b hb (b_lt_a b hb)
        have : B.card ≤ 2 := sorry -- exactly two odd solutions for x^2 ≡ -d mod 4a in (0, 2a)
        exact this
      else
        sorry
  sorry

