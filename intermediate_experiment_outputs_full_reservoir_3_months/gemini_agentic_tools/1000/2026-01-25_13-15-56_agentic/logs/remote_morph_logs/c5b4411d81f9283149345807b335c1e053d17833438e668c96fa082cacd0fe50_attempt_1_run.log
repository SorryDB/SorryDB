import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  cases n with
  | zero =>
    left; use 0; intro j; exact j.elim0
  | succ n =>
    cases n with
    | zero =>
      left; use 0; intro j; rcases j with ⟨0, _⟩; rfl
    | succ n =>
      have hn : 3 ≤ #S := by simp [n]
      let E (a b : S) : Prop := ∃ x : ℕ, 0 < x ∧ (a : ℕ) * b = x ^ 2 + x + k
      have hE : ∀ i, E (p₁ i) (p₁ (i + 1)) := hp₁
      have hE2 : ∀ i, E (p₂ i) (p₂ (i + 1)) := hp₂
      have h_sym : ∀ a b, E a b ↔ E b a := by
        intro a b; constructor <;> rintro ⟨x, hx, h⟩ <;> use x, hx <;> rw [mul_comm] at * <;> exact h
      let G_edges : Finset (S × S) := Finset.univ.filter (λ e => E e.1 e.2)
      have h_deg_p1 : ∀ a, (Finset.univ.filter (λ b => E a b)).card ≤ 2 := sorry
      have h_deg_p2 : ∀ a, (Finset.univ.filter (λ b => E a b)).card ≥ 2 := by
        intro a
        let i := p₁.invFun a
        have h_i_a : p₁ i = a := p₁.apply_inv_iff.mp rfl
        have h_next : E a (p₁ (i + 1)) := by rw [← h_i_a]; exact hE i
        have h_prev : E a (p₁ (i - 1)) := by rw [← h_i_a, h_sym]; convert hE (i - 1); simp
        have h_diff : p₁ (i + 1) ≠ p₁ (i - 1) := by
          intro h; apply_fun p₁.invFun at h; simp at h
          have : (1 : Fin #S) = -1 := by convert h; simp
          cases n with | zero => contradiction | succ n => simp [Fin.ext_iff] at this
        set B := {p₁ (i + 1), p₁ (i - 1)}
        have hB : B ⊆ Finset.univ.filter (λ b => E a b) := by
          simp [h_next, h_prev]
        exact (Finset.card_le_card hB).trans_inv (by simp [h_diff])
      have h_deg : ∀ a, (Finset.univ.filter (λ b => E a b)).card = 2 := λ a => Nat.le_antisymm (h_deg_p1 a) (h_deg_p2 a)
      have h_cycle : ∀ a b, E a b ↔ (∃ i, (p₁ i = a ∧ p₁ (i + 1) = b) ∨ (p₁ i = b ∧ p₁ (i + 1) = a)) := sorry
      have h_cycle2 : ∀ a b, E a b ↔ (∃ i, (p₂ i = a ∧ p₂ (i + 1) = b) ∨ (p₂ i = b ∧ p₂ (i + 1) = a)) := sorry
      exact sorry

