    cases' j using Fin.cases with j1
    · simp [i]
    · cases' j1 using Fin.cases with j2
      · have h_S2 : ∀ x : S, x = p₁ i ∨ x = p₁ (i + 1) := by
          intro x; obtain ⟨k_fin, hk_fin⟩ := p₁.surjective x
          cases' k_fin using Fin.cases with k1
          · left; exact hk_fin.symm
          · cases' k1 using Fin.cases with k2
            · right; congr; exact Fin.ext (by simp)
            · exact k2.elim0
