import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Imo2022P3.Condition k S p₁) (hp₂ : Imo2022P3.Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  if hn : n < 3 then
    cases' n with n
    · left; use 0; intro j; simp [Finset.card_eq_zero.1 hn.symm] at j; exact j.elim0
    · cases' n with n
      · left; use 0; intro j; simp at j; subst j
        have : Subsingleton (Fin 1 ≃ ↥S) := inferInstance
        exact p₁.ext_iff.mp (Subsingleton.elim p₂ p₁) 0
      · left; use (p₁.symm (p₂ 0)); intro j; fin_cases j
        · simp
        · have : n = 0 := by linarith
          have : Fin 2 = {0, 1} := by ext x; fin_cases x <;> simp
          have hS2 : S.card = 2 := by linarith
          have h_eq : p₁ (p₁.symm (p₂ 0)) = p₂ 0 := p₁.apply_symm_apply (p₂ 0)
          have h_elem : ∀ x : S, x = p₂ 0 ∨ x = p₂ 1 := by
            intro x; obtain ⟨i, hi⟩ := p₂.surjective x; fin_cases i <;> simp [hi]
          have h_elem1 : ∀ x : S, x = p₁ (p₁.symm (p₂ 0)) ∨ x = p₁ (1 + p₁.symm (p₂ 0)) := by
            intro x; obtain ⟨i, hi⟩ := p₁.surjective x; fin_cases i
            · left; congr; exact Fin.ext (by simp [Fin.ext_iff])
            · right; congr; exact Fin.ext (by simp [Fin.ext_iff])
          obtain h | h := h_elem (p₁ (1 + p₁.symm (p₂ 0)))
          · exfalso; apply p₁.injective; rw [h_eq]; exact h.symm
          · exact h.symm
  else
    let Rel (a b : ℕ) : Prop := ∃ x, 0 < x ∧ a * b = x^2 + x + k
    have hRel : ∀ i, Rel (p₁ i) (p₁ (i + 1)) := hp₁
    have hRel2 : ∀ i, Rel (p₂ i) (p₂ (i + 1)) := hp₂
    have h_deg : ∀ a ∈ S, {b ∈ S | Rel a b}.card ≤ 2 := by
      intro a ha; let B := {b ∈ S | Rel a b}
      by_contra hc; simp at hc; obtain ⟨b1, hb1, b2, hb2, b3, hb3, h12, h23, h13⟩ := hc
      simp [Rel] at hb1 hb2 hb3; obtain ⟨x1, hx1, e1⟩ := hb1; obtain ⟨x2, hx2, e2⟩ := hb2; obtain ⟨x3, hx3, e3⟩ := hb3
      have h_prime : a.Prime := (hS a ha).2
      have h_mid (x y : ℕ) (ex ey : a * _ = _) : a ∣ (x - y) * (x + y + 1) := by
        have : (a : ℤ) * (_ - _) = (x : ℤ)^2 - (y : ℤ)^2 + (x - y) := by
          rw [Int.coe_nat_mul, Int.coe_nat_mul, ex, ey]; ring
        have : (a : ℤ) * (_ - _) = (x - y) * (x + y + 1) := by rw [this]; ring
        exact Int.coe_nat_dvd.1 (dvd_of_mul_left_eq _ this)
      have h_cases (x y : ℕ) (ex ey : a * _ = _) : x = y ∨ x + y + 1 = a ∨ a ∣ x - y ∨ a ∣ x + y + 1 := sorry
      sorry
    have h_edges : ∀ i, {p₁ (i - 1), p₁ (i + 1)} = {b ∈ S | Rel (p₁ i) b} := by
      intro i; refine (Finset.eq_of_subset_of_card_le (λ b hb => ?_) ?_).symm
      · simp at hb; rcases hb with rfl | rfl
        · simp [Rel]; rw [mul_comm]; exact hp₁ (i - 1)
        · simp [Rel]; exact hp₁ i
      · rw [Finset.card_doubleton]
        · apply h_deg; exact (p₁ i).2
        · intro h; apply_fun (p₁.symm) at h; simp at h
          have : (2 : Fin n) = 0 := by rw [← sub_eq_zero] at h; exact h
          have : n ∣ 2 := (Fin.ext_iff.mp this); linarith
    have h_same : ∀ i, {p₂ (i - 1), p₂ (i + 1)} = {p₁ (p₁.symm (p₂ i) - 1), p₁ (p₁.symm (p₂ i) + 1)} := by
      intro i; rw [h_edges, h_edges]; congr; exact (p₂ i).2
    sorry

