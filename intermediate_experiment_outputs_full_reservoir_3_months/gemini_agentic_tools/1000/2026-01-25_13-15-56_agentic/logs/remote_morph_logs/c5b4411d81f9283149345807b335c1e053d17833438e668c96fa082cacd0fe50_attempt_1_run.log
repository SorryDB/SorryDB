import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  have : n = #S := rfl
  let Rel (a b : ℕ) : Prop := ∃ x, 0 < x ∧ a * b = x ^ 2 + x + k
  have hRel_symm : ∀ a b, Rel a b ↔ Rel b a := fun a b ↦ by simp [Rel, mul_comm]
  have h_low_deg : ∀ a ∈ S, {b ∈ S | Rel a b ∧ b < a}.card ≤ 2 := by
    intro a ha
    let roots := {x ∈ Finset.range a | (x^2 + x + k) % a = 0}
    have : roots.card ≤ 2 := by
      have : (hS a ha).2.Prime := (hS a ha).2
      have h1 : 1 < a := this.two_le
      let P : (ZMod a)[X] := Polynomial.X^2 + Polynomial.X + Polynomial.C (k : ZMod a)
      have hP : P ≠ 0 := by intro h; have := (Polynomial.coeff P 2); simp at this
      have : (P.roots).toFinset.card ≤ 2 := (Polynomial.card_roots_finite_field_poly hP).trans (by simp)
      apply (Finset.card_le_card (fun x hx ↦ by
        simp at hx; simp
        have : (x : ZMod a)^2 + (x : ZMod a) + (k : ZMod a) = 0 := by
          rw [← ZMod.val_eq_zero, ZMod.val_add, ZMod.val_add, ZMod.val_pow, ZMod.val_nat_cast, ZMod.val_nat_cast, ZMod.val_nat_cast]
          simp [hx.2]
        exact this)).trans this
    apply (Finset.card_le_card (fun b hb ↦ by
      simp at hb; obtain ⟨x, hx1, hx2⟩ := hb.1
      have : x < a := by
        have : x^2 < x^2 + x + k := by linarith
        rw [← hx2] at this; exact (Nat.mul_lt_mul_left (hk.trans_le (by linarith))).mp (this.trans (by rw [mul_comm]; exact Nat.mul_lt_mul_of_pos_right hb.2 (hk.trans_le (by linarith))))
      simp; use x; simp [this]; rw [← hx2]; simp)).trans this
  have h_edges : ∀ {p : Fin n ≃ S}, Condition k S p → ∀ i, { (p i : ℕ), (p (i + 1) : ℕ) } = { b ∈ S | Rel (p i) b } ∩ { b ∈ S | ∃ x < p i, Rel (p i) b ∨ True } := sorry
  if hn : n < 3 then
    match n with
    | 0 => left; use 0; intro j; exact j.elim0
    | 1 => left; use 0; intro j; have : j = 0 := Subsingleton.elim _ _; subst j; simp
    | 2 =>
      let s := S.toUint32 -- just dummy
      have h_bij : ∀ p₁ p₂ : Fin 2 ≃ S, (∃ i, ∀ j, p₂ j = p₁ (j + i)) := by
        intro p₁ p₂; obtain ⟨s0, s1, hS_eq⟩ := Finset.card_eq_two.mp (this.symm.trans rfl)
        have : (p₂ 0 = p₁ 0 ∧ p₂ 1 = p₁ 1) ∨ (p₂ 0 = p₁ 1 ∧ p₂ 1 = p₁ 0) := by
          have : ∀ i, p₁ i ∈ S := fun i ↦ (p₁ i).2
          have : ∀ i, p₂ i ∈ S := fun i ↦ (p₂ i).2
          obtain rfl | rfl := p₁.symm.surjective (p₂ 0) <;> simp
        rcases this with ⟨h0, h1⟩ | ⟨h0, h1⟩
        · use 0; intro j; fin_cases j <;> simp [*]
        · use 1; intro j; fin_cases j <;> simp [*]
      left; exact h_bij p₁ p₂
  else
    have h_same_edges : ∀ i, { (p₂ i : ℕ), (p₂ (i + 1) : ℕ) } = { (p₁ (p₁.symm (p₂ i)) : ℕ), (p₁ (p₁.symm (p₂ i) + 1) : ℕ) } := sorry
    have h_rotate : (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := sorry
    exact h_rotate

