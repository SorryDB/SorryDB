/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    · ext x
      simp only [LinearMap.convMul_apply, LinearMap.comp_apply, TensorProduct.map_tmul,
        LinearMap.mul'_apply, TensorProduct.tmul_mul_tmul, toLinearMap_antipodeAlgHom]
      rw [IsCocomm.comm_comp_comul, ← Coalgebra.coassoc, ← Coalgebra.coassoc]
      simp only [LinearMap.comp_apply, TensorProduct.map_tmul, TensorProduct.comm_tmul,
        Coalgebra.coassoc, ← LinearMap.convMul_apply, LinearMap.antipode_mul_id,
        convOne_def, Algebra.linearMap_apply, TensorProduct.algebraMap_apply]
      simp
    · exact LinearMap.comul_right_inv

end HopfAlgebra
end BialgHom
