/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comulAlgHom R C)
    · let f : C →ₐc[R] C ⊗[R] C :=
      { comulAlgHom R C with
        counit_comp := AlgHom.toLinearMap_injective <| by ext; simp
        map_comp_comul := AlgHom.toLinearMap_injective <| by
          ext; simp only [AlgHom.toLinearMap_comp, Algebra.TensorProduct.map_toLinearMap,
            LinearMap.comp_assoc]
          rw [Coalgebra.comm_comp_comul, ← Coalgebra.coassoc, ← Coalgebra.coassoc, Coalgebra.comm_comp_comul] }
      exact AlgHom.inv_convMul_cancel f
    · AlgHom.toLinearMap_injective <| by
        rw [AlgHom.toLinearMap_convMul, AlgHom.toLinearMap_one]
        exact LinearMap.comul_right_inv

end HopfAlgebra
end BialgHom
