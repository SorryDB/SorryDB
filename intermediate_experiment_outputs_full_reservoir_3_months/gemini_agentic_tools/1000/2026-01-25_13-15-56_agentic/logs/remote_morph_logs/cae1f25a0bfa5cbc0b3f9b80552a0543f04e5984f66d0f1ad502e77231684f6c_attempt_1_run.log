/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    · have hS : (antipode R : C ⊗[R] C →ₗ[R] C ⊗[R] C) = antipode R ⊗ₘ antipode R := by
        ext; simp [antipode_mul, antipode_one]
      rw [← hS, ← AlgHom.toLinearMap_convMul, ← AlgHom.toLinearMap_one, AlgHom.toLinearMap_injective]
      let f : C →ₐc[R] C ⊗[R] C :=
      { comulAlgHom R C with
        counit_comp := by ext; simp
        map_comp_comul := by ext; simp [Coalgebra.IsCocomm.comm_comp_comul R C] }
      exact AlgHom.inv_convMul_cancel f
    · exact LinearMap.comul_right_inv

end HopfAlgebra
end BialgHom
