/-- From a resolution of identity `E_{a}` and for each `x y : H`, the map `s => ⟪x, E_{a} s y⟫_ℂ`
gives complex measure. The integraion of the identity map against it gives back the expectation
value `⟪x, a y⟫_ℂ`. Check that
`⟪x, cfcHom ha f y⟫_ℂ = (toComplexMeasure (toResolutionOfIdentity ha) x y).integral f` for step
functions `f`, and infer that it holds for all Borel/continuous functions. Apply it to the identity
map.
cf. Rudin "Functional Analysis" Theorem 12.21, Theorem 12.22.
-/
theorem SpectralDecomposition (x y : H) :
    ⟪x, a y⟫_ℂ = (toComplexMeasure (toResolutionOfIdentity ha) x y).integral
    (Function.Embedding.subtype (spectrum ℂ a)) := by
  let f : C(spectrum ℂ a, ℂ) := ⟨Subtype.val, continuous_subtype_val⟩
  have hμ : toComplexMeasure (toResolutionOfIdentity ha) x y = cfc_toComplexMeasure ha x y := by
    ext s hs
    simp [toResolutionOfIdentity, toComplexMeasure, toBoundedBilin, continuousLinearMapOfBilin_apply, hs]
    erw [ComplexRMK.rieszMeasure_apply _ _ hs, ComplexRMK.integral_rieszMeasure]
    simp [cfc_toLinearFunctional_apply]
  rw [hμ]
  have h_int : (cfc_toComplexMeasure ha x y).integral (Function.Embedding.subtype (spectrum ℂ a)) = ⟪x, cfcHom ha.isStarNormal f y⟫_ℂ := by
    simp [cfc_toComplexMeasure]
    erw [ComplexRMK.integral_rieszMeasure]
    simp [cfc_toLinearFunctional_apply]
  erw [h_int, cfcHom_id ha.isStarNormal]
```
