import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  let L := fun (k : ℕ) => ∑ i : Fin n, dist (P i) (P (i + (k : Fin n)))
  have h2d : (2 * d : ℝ) = ∑ k in Finset.Icc 2 (n - 2), L k := by
    rw [hd]
    have : (2 : ℝ) * (1 / 2 * ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j)) = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by field_simp
    rw [this, Finset.sum_comm]
    sorry
  have h_p_pos : (0 : ℝ) < p := sorry
  have h_Lk_lower : ∀ k ∈ Finset.Icc 1 (n - 2), L k + L (k + 1) > 2 * p := sorry
  have h_Lk_upper : ∀ k ∈ Finset.Icc 2 (n - 2), L k < min k (n - k) * p := sorry
  constructor
  · have h_sum_lower : ∑ k in Finset.Icc 1 (n - 2), (L k + L (k + 1)) > 2 * (n - 2) * p := by
      apply Finset.sum_gt_sum
      · intros; apply h_Lk_lower; assumption
      · use 1; simp; constructor <;> linarith
    have h_Lk_sum : ∑ k in Finset.Icc 1 (n - 2), (L k + L (k + 1)) = 4 * d + 2 * p := by
      have hL1 : L 1 = p := by rw [hp]; simp [L]
      have hLn : L (n - 1) = p := sorry
      rw [Finset.sum_add_distrib, h2d]
      sorry
    rw [h_Lk_sum] at h_sum_lower
    field_simp [h_p_pos]
    linarith
  · have h_sum_upper : ∑ k in Finset.Icc 2 (n - 2), L k < (∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ)) * p := by
      rw [Finset.sum_mul]
      apply Finset.sum_lt_sum
      · intros; apply h_Lk_upper; assumption
      · use 2; simp; linarith
    have h_arith_sum : ∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ) = ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
      sorry
    rw [← h2d, h_arith_sum] at h_sum_upper
    field_simp [h_p_pos]
    exact h_sum_upper
