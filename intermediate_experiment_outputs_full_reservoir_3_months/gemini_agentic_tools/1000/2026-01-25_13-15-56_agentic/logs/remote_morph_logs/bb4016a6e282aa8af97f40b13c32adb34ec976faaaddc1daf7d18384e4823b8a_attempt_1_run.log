import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : 0 < (p : ℝ) := by
    rw [hp]; apply Finset.sum_pos; · intro i _; apply dist_pos.mpr; intro h
    have h1 : (i + 1 : Fin n) + 1 ≠ i + 1 - 1 := by
      intro h_eq; have : (2 : Fin n) = 0 := by rw [← h_eq]; simp; ring
      have : n ∣ 2 := by apply_fun (fun x => x.val) at this; simp at this; exact this
      omega
    have h2 : (i + 1 : Fin n) + 1 ≠ i + 1 := by
      intro h_eq; have : (1 : Fin n) = 0 := by rw [← h_eq]; simp; ring
      have : n ∣ 1 := by apply_fun (fun x => x.val) at this; simp at this; exact this
      omega
    have h_angle := hP (i + 1) ((i + 1) + 1) h1 h2
    rw [← h] at h_angle; simp [EuclideanGeometry.oangle_self_left] at h_angle
    · use 0; simp
  let L (k : ℕ) : ℝ := ∑ i : Fin n, dist (P i) (P (i + (k : Fin n)))
  have h2d : 2 * (d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), L k := by
    rw [hd]; push_cast; field_simp; rw [Finset.sum_comm]; apply Finset.sum_congr rfl; intro i _; rw [L]
    let f (k : ℕ) : Fin n := i + (k : Fin n)
    have hf : ∀ k ∈ Finset.Icc 2 (n - 2), f k ∈ Finset.univ \ {i - 1, i, i + 1} := by
      intro k hk; simp at hk; simp [f]; constructor
      · intro h; apply_fun (fun x => (x.1 + n - i.1) % n) at h; simp at h; omega
      · constructor
        · intro h; apply_fun (fun x => (x.1 + n - i.1) % n) at h; simp at h; omega
        · intro h; apply_fun (fun x => (x.1 + n - i.1) % n) at h; simp at h; omega
    rw [← Finset.sum_bij (fun k _ => f k) (fun k hk => hf k hk)]
    · intro k1 hk1 k2 hk2 heq; simp [f] at heq; apply_fun (fun x => (x.1 + n - i.1) % n) at heq; simp at heq
      simp at hk1 hk2; omega
    · intro j hj; simp at hj; use (j.1 + n - i.1) % n; constructor
      · simp; omega
      · simp [f]; omega
  constructor
  · rw [lt_div_iff₀ hp_pos, ← h2d]
    have hLk : ∀ k ∈ Finset.Icc 2 (n - 2), (p : ℝ) < L k := sorry
    have h_card : (Finset.Icc 2 (n - 2)).card = n - 3 := by simp [Finset.card_Icc]; omega
    rw [mul_comm, ← h_card, ← Finset.sum_const]; apply Finset.sum_lt_sum
    · intro k hk; exact hLk k hk
    · use 2; simp [hn]; omega
  · rw [div_lt_iff₀ hp_pos, ← h2d]
    have hLk : ∀ k ∈ Finset.Icc 2 (n - 2), L k < (min k (n - k) : ℝ) * p := sorry
    have h_sum_min : (∑ k ∈ Finset.Icc 2 (n - 2), (min k (n - k) : ℝ)) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2 := sorry
    rw [← h_sum_min, Finset.sum_mul]; apply Finset.sum_lt_sum
    · intro k hk; exact hLk k hk
    · use 2; simp [hn]; omega

