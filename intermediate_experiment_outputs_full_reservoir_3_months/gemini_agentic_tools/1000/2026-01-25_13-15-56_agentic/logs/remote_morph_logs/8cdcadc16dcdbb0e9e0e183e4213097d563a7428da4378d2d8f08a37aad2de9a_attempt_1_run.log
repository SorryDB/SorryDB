    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have hb : 0 < b := hd0.trans_le (hdc.trans hcb)
  have hc : 0 < c := hd0.trans_le hdc
  have hd : 0 < d := hd0
  have h_am_gm : a ^ a * b ^ b * c ^ c * d ^ d ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let z : Fin 4 → ℝ := ![a, b, c, d]
    have hw : ∀ i, 0 ≤ w i := by intro i; fin_cases i <;> simp [w] <;> linarith
    have hw' : ∑ i, w i = 1 := by simp [w, h1]
    have hz : ∀ i, 0 ≤ z i := by intro i; fin_cases i <;> simp [z] <;> linarith
    have h := Real.geom_mean_le_arith_mean_weighted Finset.univ w z (fun i _ => hw i) (by simp; exact hw') (fun i _ => hz i)
    simp [w, z] at h
    convert h using 1
    · ring
    · ring
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) < 1 := by
    have h_diff : 1 - (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) =
      b * (a ^ 2 - b ^ 2) + c * (a ^ 2 - c ^ 2) + d * (a ^ 2 - d ^ 2) +
      a * (b ^ 2 + c ^ 2 + d ^ 2) + 2 * a * b * (a - b) + 2 * a * c * (a - c) + 2 * a * d * (a - d) +
      2 * (a * b * c + a * b * d + a * c * d + b * c * d) + 4 * b * c * d := by
      calc 1 - (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2)
        _ = (a + b + c + d) ^ 3 - (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by rw [h1, one_pow]
        _ = a^2*b + a^2*c + a^2*d + b^2*a + c^2*a + d^2*a + 6*a*b*c + 6*a*b*d + 6*a*c*d + 6*b*c*d +
