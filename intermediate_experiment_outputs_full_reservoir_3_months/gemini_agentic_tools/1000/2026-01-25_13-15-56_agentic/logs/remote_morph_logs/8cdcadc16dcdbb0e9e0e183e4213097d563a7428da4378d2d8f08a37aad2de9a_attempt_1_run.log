import Mathlib


namespace IMO2020P2

theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha0 : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have hb0 : 0 < b := hd0.trans_le (hdc.trans hcb)
  have hc0 : 0 < c := hd0.trans_le hdc
  have h_am_gm : a ^ a * b ^ b * c ^ c * d ^ d ≤ a * a + b * b + c * c + d * d := by
    have h_cvx : ConvexOn ℝ (Set.Ioi 0) (fun x => x * Real.log x) :=
      convexOn_id_mul_log
    have h_jensen := h_cvx.map_sum_le (fun _ _ => ha0.le.trans (by i some))
      (fun _ _ => by i some) h1 (fun i => i)
    sorry
  have h_key : (a + 2 * b + 3 * c + 4 * d) * (a^a * b^b * c^c * d^d) < (a + b + c + d) ^ 2 := by
    calc (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d
      _ < (a + b + c + d) * (a + b + c + d) := by
        have h_alt : (a + 2 * b + 3 * c + 4 * d) * a^a * b^b * c^c * d^d < 1 := by
          have : a^a * b^b * c^c * d^d < a + b + c + d := sorry
          sorry
        sorry
      _ = 1 := by rw [h1, one_pow]
  exact h_key

