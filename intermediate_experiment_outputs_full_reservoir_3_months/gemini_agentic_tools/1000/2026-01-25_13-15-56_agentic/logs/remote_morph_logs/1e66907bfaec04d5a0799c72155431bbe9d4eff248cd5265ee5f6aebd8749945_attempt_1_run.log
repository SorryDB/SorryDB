/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u, hu, hxu, (), v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  have ⟨v', hv', ⟨d'⟩⟩ : ∃ (v' : Set {x : Eucl n | 0 ≤ x 0}), IsOpen[DTop] v' ∧ Nonempty (↑v ᵈ≃ ↑v') :=
    -- Any open subset of Eucl n is locally diffeomorphic to an open subset of the half-space.
    -- This can be shown by translating a small neighborhood into the interior {x | 0 < x 0}.
    sorry
  exact ⟨u, hu, hxu, (), v', hv', ⟨d.trans d'⟩⟩⟩
```
