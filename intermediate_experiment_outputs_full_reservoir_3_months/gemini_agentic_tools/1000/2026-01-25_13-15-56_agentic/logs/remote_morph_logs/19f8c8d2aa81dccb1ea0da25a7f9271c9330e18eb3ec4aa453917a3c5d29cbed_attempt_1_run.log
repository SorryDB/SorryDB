        rw [mul_eq_zero, sub_eq_zero]
        intro h_or
        cases h_or <;> [simpa using h'; simpa using h'']
      simp [h_nz]
    | succ i =>
      apply ih (Nat.lt_of_succ_lt_succ h)
      · simpa using h'
      · simpa using h''
