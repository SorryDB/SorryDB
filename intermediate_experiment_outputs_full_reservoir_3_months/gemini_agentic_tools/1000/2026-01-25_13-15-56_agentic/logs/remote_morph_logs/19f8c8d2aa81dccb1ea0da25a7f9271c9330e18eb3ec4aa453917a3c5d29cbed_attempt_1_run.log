lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  induction w generalizing i args cs with
  | zero => cases h
  | succ w ih =>
    have h_fold_n : ∀ (bs : List (ZMod p)) (c : Cs p (ZMod p)),
      c.eval = .n → (List.foldl assert_bit_e c bs).eval = .n := by
      intro bs c hc
      induction bs generalizing c with
      | nil => exact hc
      | cons b bs ih' =>
        simp only [List.foldl_cons]
        apply ih'
        unfold assert_bit_e Cs.eval
        split_ifs <;> [exact hc; rfl]
    have h_args : args = Vector.insertIdx args.tail 0 args.head := by
      simp only [Vector.insertIdx_zero]
      ext j hj
      match j with
      | .zero => simp; rfl
      | .succ j => simp [add_comm]
    rw [h_args]
    unfold assert_bits_e Vector.foldl
    simp only [Vector.insertIdx_zero, Vector.toList_cons, List.foldl_cons]
    cases i with
    | zero =>
      apply h_fold_n
      unfold assert_bit_e Cs.eval Exp.eval
      have : args.head * (1 - args.head) ≠ 0 := by
        rw [mul_eq_zero, sub_eq_zero]
        have h0 : args[0] = args.head := by simp
        rw [← h0] at h' h''
        simp [h', h'']
      simp [this]
    | succ i =>
      apply ih (Nat.lt_of_succ_lt_succ h) (cs := assert_bit_e cs args.head)
      · have : args.tail[i] = args[i.succ] := by simp
        rw [this]; exact h'
      · have : args.tail[i] = args[i.succ] := by simp
        rw [this]; exact h''
