        intro w args
        induction w with
        | zero => intros c hc; rw [assert_bits_e, Vector.foldl_nil, hc]
        | succ w ih' =>
          intros c hc
          rw [Vector.cons_head_tail args, assert_bits_e, Vector.foldl_cons]
          apply ih'
          unfold assert_bit_e Cs.eval
          split_ifs; exact hc; rfl
      apply h_nil
      unfold assert_bit_e Cs.eval
      have h_nz : args.head * (1 - args.head) ≠ 0 := by
        intro h_z
        rw [mul_eq_zero, sub_eq_zero] at h_z
        cases h_z with
        | inl hz => exact h' hz
        | inr hz => exact h'' hz
      simp [h_nz, Exp.eval]
    | succ i =>
      simp only [h_cons, Vector.get_cons_succ] at h' h''
      exact ih (Nat.lt_of_succ_lt_succ h) h' h''
