    simp only [h_cons, assert_bits_e, Vector.foldl_cons]
    cases i with
    | zero =>
      simp only [h_cons, Vector.get_cons_zero] at h' h''
      have h_nil : ∀ {w : ℕ} {args : Vector (ZMod p) w} {c : Cs p (ZMod p)},
