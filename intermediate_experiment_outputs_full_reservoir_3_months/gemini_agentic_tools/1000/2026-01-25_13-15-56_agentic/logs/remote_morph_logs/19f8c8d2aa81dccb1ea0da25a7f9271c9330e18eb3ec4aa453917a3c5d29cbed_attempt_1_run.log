      rw [Vector.eq_nil bs]
      unfold assert_bits_e Vector.foldl
      simp [hcs]
    | succ w ih' =>
      rw [Vector.cons_head_tail bs]
      unfold assert_bits_e Vector.foldl
      simp
      apply ih'
      unfold assert_bit_e Cs.eval
      simp [hcs]
      split_ifs <;> [exact hcs; rfl]
  induction w generalizing i args cs with
  | zero => cases h
