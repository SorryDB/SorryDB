import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩}
  obtain ⟨J, hJ_card, hJ_color⟩ : ∃ J : Finset (Fin (2 * n)), J.card = n ∧
      ∀ i, (∑ k ∈ J, ((pairs k).filter (fun j => c j = i)).card) = 2 := by
    sorry
  let S := J.biUnion pairs
  use S
  constructor
  · have h_sum_S : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion]
      · simp_rw [Finset.sum_pair (show (⟨k, by omega⟩ : Fin (4 * n)) ≠ ⟨4 * n - 1 - k, by omega⟩ by simp [Fin.ext_iff]; omega)]
        simp [hJ_card, Finset.sum_const, nsmul_eq_mul]
        omega
      · intro k1 _ k2 _ hne; simp [pairs, Finset.disjoint_iff_ne]; intro x hx y hy; simp [Fin.ext_iff] at *; omega
    have h_sum_all : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [Finset.sum_univ_eq_sum_range]
      simp [Finset.sum_range_id, nsmul_eq_mul]
      omega
    rw [← Finset.sum_add_sum_compl S, h_sum_S] at h_sum_all
    omega
  · intro i
    rw [Finset.filter_biUnion, Finset.card_biUnion]
    · exact hJ_color i
    · intro k1 _ k2 _ hne; apply Finset.disjoint_filter_filter
      simp [pairs, Finset.disjoint_iff_ne]; intro x hx y hy; simp [Fin.ext_iff] at *; omega

