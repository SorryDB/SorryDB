import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (k : Fin (2 * n)) : Finset (Fin (4 * n)) :=
    {⟨k.val, by omega⟩, ⟨4 * n - 1 - k.val, by omega⟩}
  have h_sum_pair : ∀ k, ∑ i ∈ pairs k, ((i : ℕ) + 1) = 4 * n + 1 := by
    intro k
    have hne : (⟨k.val, by omega⟩ : Fin (4 * n)) ≠ ⟨4 * n - 1 - k.val, by omega⟩ := by
      simp [Fin.ext_iff]; omega
    rw [Finset.sum_pair hne]
    simp; omega
  have h_disjoint : ∀ k1 k2, k1 ≠ k2 → Disjoint (pairs k1) (pairs k2) := by
    intro k1 k2 hne
    simp [pairs, Finset.disjoint_iff_ne]
    intro x hx y hy
    simp at hx hy
    rcases hx with rfl | rfl <;> rcases hy with rfl | rfl <;> simp [Fin.ext_iff] at * <;> omega
  obtain ⟨J, hJ_card, hJ_color⟩ : ∃ J : Finset (Fin (2 * n)), J.card = n ∧
      ∀ i, #{j ∈ J.biUnion pairs | c j = i} = 2 := by
    sorry
  let S := J.biUnion pairs
  use S
  constructor
  · have h_sum_S : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion (fun k1 _ k2 _ hne => h_disjoint k1 k2 hne)]
      simp [h_sum_pair, hJ_card]
    have h_sum_all : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [Finset.sum_add_distrib, Finset.sum_const, Finset.card_univ]
      simp [Finset.sum_fin_eq_sum_range, Finset.sum_range_id]
      rcases n with rfl | n
      · simp
      · have : 2 * (4 * (n + 1) * (4 * (n + 1) - 1) / 2 + 4 * (n + 1)) = 2 * (2 * (n + 1) * (4 * (n + 1) + 1)) := by
          rw [Nat.mul_add, Nat.mul_div_cancel']
          · ring
          · show 2 ∣ 4 * (n + 1) * (4 * (n + 1) - 1)
            omega
        omega
    rw [← Finset.sum_add_sum_compl S] at h_sum_all
    rw [h_sum_S] at h_sum_all
    omega
  · exact hJ_color

