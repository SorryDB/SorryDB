import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (k : Fin (2 * n)) : Finset (Fin (4 * n)) :=
    {⟨k.val, by omega⟩, ⟨4 * n - 1 - k.val, by omega⟩}
  have h_disjoint : ∀ k1 k2, k1 ≠ k2 → Disjoint (pairs k1) (pairs k2) := by
    intro k1 k2 hne
    simp [pairs, Finset.disjoint_iff_ne, Fin.ext_iff]
    intro x hx y hy
    rcases hx with rfl | rfl <;> rcases hy with rfl | rfl <;> omega
  obtain ⟨J, hJ_card, hJ_color⟩ : ∃ J : Finset (Fin (2 * n)), J.card = n ∧
      ∀ i, #{j ∈ J.biUnion pairs | c j = i} = 2 := by
    sorry
  let S := J.biUnion pairs
  use S
  constructor
  · have h_sum_pair : ∀ k, ∑ i ∈ pairs k, ((i : ℕ) + 1) = 4 * n + 1 := by
      intro k
      have hne : (⟨k.val, by omega⟩ : Fin (4 * n)) ≠ ⟨4 * n - 1 - k.val, by omega⟩ := by
        simp [Fin.ext_iff]; omega
      rw [Finset.sum_pair hne]
      simp; omega
    have h_sum_S : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion (fun k1 _ k2 _ hne => h_disjoint k1 k2 hne)]
      rw [Finset.sum_congr rfl (fun k _ => h_sum_pair k)]
      simp [hJ_card, Finset.sum_const]
    have h_sum_all : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [Fin.sum_univ_eq_sum_range]
      simp_rw [Nat.add_comm]
      rw [Finset.sum_add_distrib, Finset.sum_const, Finset.sum_range_id, Finset.card_range]
      rw [Nat.mul_comm (4 * n), Nat.mul_assoc, Nat.mul_div_cancel_left _ (Nat.succ_pos 1)]
      omega
    rw [h_sum_S]
    rw [← Finset.sum_add_sum_compl S, h_sum_S] at h_sum_all
    omega
  · exact hJ_color
