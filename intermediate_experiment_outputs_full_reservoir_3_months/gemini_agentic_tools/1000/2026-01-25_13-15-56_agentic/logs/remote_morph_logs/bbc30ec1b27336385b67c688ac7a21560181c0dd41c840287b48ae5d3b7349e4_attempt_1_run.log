namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩}
  obtain ⟨J, hJ_card, hJ_color⟩ : ∃ J : Finset (Fin (2 * n)), J.card = n ∧
      ∀ i, (J.sum fun k => (if c ⟨k, by omega⟩ = i then 1 else 0) + (if c ⟨4 * n - 1 - k, by omega⟩ = i then 1 else 0)) = 2 := by
    sorry
  let S := J.biUnion pairs
  use S
  constructor
  · have hS_sum : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion]
      · simp only [Finset.sum_pair, Fin.coe_mk, Finset.sum_const, nsmul_eq_mul]
        have h_p (k : Fin (2 * n)) : (pairs k).card = 2 := by
          apply Finset.card_pair; intro hh; simp [Fin.ext_iff] at hh; omega
        have h_sum_p (k : Fin (2 * n)) : ∑ i ∈ pairs k, ((i : ℕ) + 1) = 4 * n + 1 := by
          simp [pairs]; omega
        simp_rw [h_sum_p, hJ_card, Finset.sum_const, nsmul_eq_mul]
      · intro k1 _ k2 _ hne; simp [pairs, Finset.disjoint_iff_ne]; intro x hx y hy; simp [hne.symm] at *; omega
    have total_sum : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      rw [Fin.sum_univ_eq_sum_range]
      simp [Nat.sum_range_add_one, Nat.sum_range_id]
      omega
    rw [← Finset.sum_add_sum_compl S, hS_sum] at total_sum
    omega
  · intro i
    rw [Finset.filter_biUnion, Finset.card_biUnion]
    · simp only [pairs, Finset.filter_insert, Finset.filter_singleton, Finset.mem_singleton]
      convert hJ_color i
      funext k
      congr
      by_cases h1 : c ⟨k, by omega⟩ = i <;> by_cases h2 : c ⟨4 * n - 1 - k, by omega⟩ = i <;> simp [h1, h2]
    · intro k1 hk1 k2 hk2 hne; apply Finset.disjoint_filter_filter; simp [pairs, Finset.disjoint_iff_ne]; intro x hx y hy; simp [hne.symm] at *; omega

