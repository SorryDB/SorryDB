import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  obtain ⟨G, hG⟩ : ∃ G : SimpleGraph (Fin (4 * n)), (∀ i, G.degree i = 1) ∧
    ∀ i, (G.neighborFinset i).image c = {c i} := by sorry
  let pairs : Finset (Finset (Fin (4 * n))) := Finset.univ.partition (fun i => (i : ℕ) / 2)
  let graph_edges : Finset (Finset (Fin n)) := Finset.univ.image (fun i : Fin (2 * n) => {c ⟨2 * i, by omega⟩, c ⟨2 * i + 1, by omega⟩})
  obtain ⟨S, hS_sum, hS_color⟩ : ∃ S : Finset (Fin (4 * n)),
    (∑ i ∈ S, ((i : ℕ) + 1) = (2 * n * (4 * n + 1))) ∧ (∀ i, #{j ∈ S | c j = i} = 2) := by sorry
  use S
  refine ⟨?_, hS_color⟩
  have total_sum : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
    simp [Finset.sum_range_id, ← Nat.sum_range_add_one, Nat.sum_range_id]
    omega
  rw [← total_sum, Finset.sum_add_sum_compl S] at total_sum
  omega

