    (h : X ⟂ᵢ[Z, hZ; μ] Y) :
    X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
  rw [CondIndepFun, Kernel.indepFun_iff_measure_inter_preimage_eq_mul] at h ⊢
  intro s t hs ht
  let mZ := MeasurableSpace.comap Z mδ
  let κ := condExpKernel μ mZ
  have hZ_meas : Measurable[mZ] Z := measurable_id'' le_rfl
