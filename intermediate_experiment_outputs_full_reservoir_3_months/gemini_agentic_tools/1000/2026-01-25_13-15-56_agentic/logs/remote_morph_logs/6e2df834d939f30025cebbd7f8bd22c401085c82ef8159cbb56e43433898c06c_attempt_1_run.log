lemma CondIndepFun.prod_right [StandardBorelSpace α] [StandardBorelSpace β] [Nonempty β]
    [StandardBorelSpace γ] [Nonempty γ] [StandardBorelSpace δ] [Nonempty δ] [IsFiniteMeasure μ]
    {X : α → β} {Y : α → γ} {Z : α → δ}
    (hX : Measurable X) (hY : Measurable Y) (hZ : Measurable Z)
    (h : X ⟂ᵢ[Z, hZ; μ] Y) :
    X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
  rw [CondIndepFun, Kernel.indepFun_iff_measure_inter_preimage_eq_mul] at h ⊢
  intro s t hs ht
  have h_meas : MeasurableSet {a | (Y a, Z a) ∈ t} := measurable_prod_mk_iff.mp ht
  let κ := condKernel Z μ
  have h_prop : ∀ᵐ z ∂(μ.map Z), κ z {a | X a ∈ s ∧ (Y a, Z a) ∈ t}
      = κ z ({a | X a ∈ s} ∩ {a | Y a ∈ (Prod.fst '' (t ∩ {p | p.2 = z}))}) := by
    filter_upwards [condKernel_ae_eq_composition_cnt Z μ] with z hz
    apply measure_congr
    intro a
    simp only [Set.mem_inter_iff, Set.mem_setOf_eq]
    constructor
    · rintro ⟨hXa, hYZa⟩
      have : Z a = z := by
        have : a ∈ Z ⁻¹' {z} := (ae_condKernel_Z_eq_one hZ μ).ae_seq_mem hz
        exact this
      refine ⟨hXa, ?_⟩
      use (Y a, Z a)
      simp [hYZa, this]
    · rintro ⟨hXa, b, ⟨hb_t, hb_z⟩, hb_Y⟩
      refine ⟨hXa, ?_⟩
      convert hb_t
      ext
      · exact hb_Y.symm
      · rw [hb_z]
        exact ((ae_condKernel_Z_eq_one hZ μ).ae_seq_mem hz).symm
  filter_upwards [h_prop, h s (Prod.fst '' (t ∩ {p | p.2 = z})) hs (measurable_set_fst (ht.inter (measurable_prod_mk_iff.mple rfl)))] with z hz h_indep
  rw [hz, h_indep]
  congr 1
  -- The rest is similar manipulation for the second factor
  apply measure_congr
  intro a
  constructor
  · rintro hYZa
    use (Y a, Z a)
    simp [hYZa, (ae_condKernel_Z_eq_one hZ μ).ae_seq_mem hz]
  · rintro ⟨b, ⟨hb_t, hb_z⟩, hb_Y⟩
    convert hb_t
    ext
    · exact hb_Y.symm
    · rw [hb_z]
      exact ((ae_condKernel_Z_eq_one hZ μ).ae_seq_mem hz).symm
```
