  have h_eq : (fun ω ↦ (Y ω, Z ω)) ⁻¹' t ∩ {ω | Z ω = Z a} = (Y ⁻¹' {y | (y, Z a) ∈ t}) ∩ {ω | Z ω = Z a} := by
    ext ω; simp; intro h_za; rw [h_za]
  have h_meas_t : MeasurableSet {y | (y, Z a) ∈ t} := measurable_prod_mk_left ht
  have h_inter_eq : κ a (X ⁻¹' s ∩ (fun ω ↦ (Y ω, Z ω)) ⁻¹' t) = κ a (X ⁻¹' s ∩ Y ⁻¹' {y | (y, Z a) ∈ t}) := by
    rw [← measure_inter_congr ha, ← Set.inter_assoc, h_eq, Set.inter_assoc, measure_inter_congr ha]
