    rw [cfc_comp_smul NNReal.sqrt (s ^ 2) (Aᴴ * A) hA NNReal.continuous_sqrt.continuousOn (NNReal.continuous_sqrt.comp (continuous_mul_left (s ^ 2))).continuousOn]
    rw [show (NNReal.sqrt ∘ (s ^ 2 • ·)) = s • NNReal.sqrt by funext; simp [NNReal.sqrt_mul]]
    rw [cfc_smul s NNReal.sqrt (Aᴴ * A) hA NNReal.continuous_sqrt.continuousOn]
    simp [s, RCLike.real_smul_eq_coe_smul]
  rw [h_sqrt]
  simp [trace_smul, RCLike.smul_re]
