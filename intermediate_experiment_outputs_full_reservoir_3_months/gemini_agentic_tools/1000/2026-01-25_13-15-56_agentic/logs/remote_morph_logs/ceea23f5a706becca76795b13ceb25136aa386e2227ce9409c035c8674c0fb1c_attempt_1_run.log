    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E' ] [NormedSpace ℝ E' ] [FiniteDimensional ℝ E' ]
    {H' : Type*} [TopologicalSpace H'] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_, ContMDiffOn.dsmooth_restrict⟩
  rw [contMDiffWithinAt_iff_contMDiffAt hs hxs]
  let e := extChartAt I x
  let n := Module.finrank ℝ E
  let L := (ContinuousLinearEquiv.ofFinrankEq (Module.finrank_euclideanSpace_fin (𝕜 := ℝ) (n := n)).symm)
  obtain ⟨ε, ε_pos, hε⟩ := Metric.mem_nhds_iff.1
    ((e.open_target.inter (hs.preimage e.continuous_symm)).mem_nhds (by simp [hxs]))
  let c := ε / 2 / (‖L.toContinuousLinearMap‖ + 1)
  let L' := c • L.toContinuousLinearMap
  let h (z : Eucl n) : E := e x + L' ((1 + ‖z‖^2).sqrt⁻¹ • z)
  have h_smooth : ContDiff ℝ ∞ h := by fun_prop
  have h_range : range h ⊆ e.target ∩ e.symm ⁻¹' s := by
    intro z; refine hε ?_; simp only [h, dist_eq_norm, add_sub_cancel_left]
    refine (norm_smul_le _ _).trans_lt ?_
    rw [Real.norm_eq_abs, Real.abs_of_nonneg (by positivity)]
    have hnorm : ‖(1 + ‖z‖^2).sqrt⁻¹ • z‖ < 1 := by
      rw [norm_smul, Real.norm_eq_abs, Real.abs_of_nonneg (by positivity),
        inv_mul_lt_iff₀ (by positivity), one_mul, Real.sqrt_lt_sqrt_iff (by positivity)]
      simp
    refine (mul_lt_mul_of_pos_left hnorm (by positivity)).trans_le ?_
    simp only [L', ContinuousLinearMap.smul_apply, norm_smul, Real.norm_eq_abs, Real.abs_of_nonneg (by positivity)]
    refine (mul_le_mul_of_nonneg_left (L.toContinuousLinearMap.le_op_norm _) (by positivity)).trans ?_
    simp only [norm_id, mul_one]; linarith [norm_nonneg L.toContinuousLinearMap]
  let p : Eucl n → M := e.symm ∘ h
  have hp : IsPlot[m.toDiffeology] p := isPlot_iff_contMDiff.2 <|
    contMDiffOn_chart_symm.comp_contMDiff h_smooth.contMDiff (h_range.trans (inter_subset_left))
  have hfp : ContMDiff (𝓡 n) I' ∞ (f ∘ p) := by
    let p_s : Eucl n → s := fun z ↦ ⟨p z, (h_range (mem_range_self z)).2⟩
    have hp_s : IsPlot[instDiffeologicalSpaceSubtype] p_s := hp
    exact isPlot_iff_contMDiff.1 (hf p_s hp_s)
  have h_deriv : HasFDerivAt h (L' : Eucl n →L[ℝ] E) 0 := by
    simp only [h]; refine hasFDerivAt_const_add.2 ?_
    have m1 : HasFDerivAt (fun z : Eucl n ↦ (1 + ‖z‖^2).sqrt⁻¹) 0 0 := by
      have := (hasFDerivAt_id 0).norm_sq.const_add 1; rw [Real.sqrt_one] at this
      exact (hasFDerivAt_sqrt (by norm_num) this).inv (by norm_num)
    convert (m1.smul (hasFDerivAt_id 0)).const_smul L' using 1; simp
  let L'_equiv := L.units_smul (Units.mk0 c (by positivity))
  obtain ⟨h_inv, -, h_left, -⟩ := (h_smooth.hasStrictFDerivAt_of_hasFDerivAt h_deriv).local_inverse h h_deriv.fderiv 0
  have : ContMDiffAt (𝓘(ℝ, E)) I' ∞ (f ∘ e.symm) (e x) := by
    have eq : f ∘ e.symm =ᶠ[𝓝 (e x)] (f ∘ p) ∘ h_inv := by
      filter_upwards [h_left] with y hy; simp [p, ← hy]
    refine ContMDiffAt.congr_of_eventuallyEq ?_ eq
    exact hfp.contMDiffAt.comp (e x) (h_smooth.local_inverse_contDiff L'_equiv h_deriv.fderiv (by rfl)).contMDiffAt
  exact this.comp x (e.contMDiffAt (mem_chart_source H x))
```
