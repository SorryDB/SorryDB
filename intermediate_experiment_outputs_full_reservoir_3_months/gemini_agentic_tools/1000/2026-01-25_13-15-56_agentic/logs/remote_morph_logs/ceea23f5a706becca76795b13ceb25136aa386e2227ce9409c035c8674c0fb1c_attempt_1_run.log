This could probably be proven in quite a lot greater generality. -/
theorem IsOpen.dsmooth_iff_smoothOn {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [FiniteDimensional ℝ E] {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E'] [NormedSpace ℝ E'] [FiniteDimensional ℝ E']
    {H' : Type*} [TopologicalSpace H' ] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_, ContMDiffOn.dsmooth_restrict⟩
  rw [contMDiffWithinAt_iff_contMDiffAt hs]
  have hf_cont : ContinuousAt f x := (hf.continuous.continuousAt hxs).comp (continuousAt_subtype_val x hxs)
  refine contMDiffAt_iff.2 ⟨hf_cont, ?_⟩
  let φ := chartAt H x; let ψ := φ.extend I
  set n := FiniteDimensional.finrank ℝ E
  let L := (ContinuousLinearEquiv.ofFinrankEq (FiniteDimensional.finrank_eucl_n n).symm)
  let z0 := L.symm (ψ x)
  have h_nhds : ψ.target ∩ ψ.symm ⁻¹' s ∈ 𝓝 (ψ x) := 
    (ψ.open_target.inter (hs.preimage ψ.continuous_symm)).mem_nhds ⟨ψ.map_source φ.mem_chart_source, hxs⟩
  obtain ⟨ε, ε_pos, hε⟩ := Metric.mem_nhds_iff.1 (L.continuous.continuousAt.preimage_mem_nhds h_nhds)
  let h (z : Eucl n) : E := ψ x + (ε / 2) • (1 + ‖z‖^2).sqrt⁻¹ • L z
  have h_range : range h ⊆ ψ.target ∩ ψ.symm ⁻¹' s := by
    intro z; refine hε ?_; simp [h, dist_eq_norm, norm_smul, norm_inv, Real.norm_eq_abs, 
      Real.abs_of_nonneg (Real.sqrt_nonneg _)]
    refine (mul_lt_iff_lt_one₀ (by positivity)).2 ?_
    exact (inv_mul_lt_iff₀ (by positivity)).2 (lt_sqrt_one_add_norm_sq z)
  let p : Eucl n → M := ψ.symm ∘ h
  have p_smooth : ContMDiff (𝓡 n) I ∞ p := (contMDiffOn_chart_symm).comp_contMDiff 
    ((contDiff_const.add (contDiff_const.smul ((contDiff_const.add contDiff_norm_sq_eucl).sqrt.inv 
    (fun z ↦ by positivity)).smul L.toContinuousLinearMap.contDiff)).contMDiff) (h_range.trans (inter_subset_left))
  have p_in_s : range p ⊆ s := h_range.trans (inter_subset_right)
  let p' : Eucl n → s := fun z ↦ ⟨p z, p_in_s (mem_range_self z)⟩
  have hp' : IsPlot[instDiffeologicalSpaceSubtype] p' := p_smooth
  have hfp : ContMDiff (𝓡 n) I' ∞ (f ∘ p) := isPlot_iff_contMDiff.1 (hf p' hp')
  let f_loc := f ∘ ψ.symm
  have h_loc : f_loc ∘ h = f ∘ p := rfl
  have h_diff : ContDiffAt ℝ ∞ h 0 := by fun_prop
  have h_inv : HasFDerivAt h (ε / 2 • L.toContinuousLinearMap) 0 := by
    simp only [h]; refine hasFDerivAt_const_add.2 ?_
    have m1 : HasFDerivAt (fun z : Eucl n ↦ (1 + ‖z‖^2).sqrt⁻¹) 0 0 := by
      have := (hasFDerivAt_id 0).norm_sq.const_add 1; rw [Real.sqrt_one, hasFDerivAt_sqrt (by norm_num)] at this
      exact this.inv (by norm_num)
    convert (m1.smul (L.toContinuousLinearMap.hasFDerivAt 0)).const_smul (ε / 2) using 1
    simp only [ContinuousLinearMap.smul_right_apply, ContinuousLinearMap.zero_apply, smul_zero, 
      id_eq, _root_.zero_smul, add_zero, one_smul]
  have h_ident : (ε / 2 • L.toContinuousLinearMap).IsThrottle := 
    (L.toContinuousLinearEquiv.units_smul (Units.mk0 (ε/2) (by positivity))).isThrottle
  obtain ⟨h_inv_map, -, h_left, -⟩ := (h_diff.hasStrictFDerivAt_of_hasFDerivAt h_inv).local_inverse h h_inv.fderiv 0
  have : ContMDiffAt (𝓘(ℝ, E)) I' ∞ f_loc (ψ x) := by
    have : f_loc = (f ∘ p) ∘ h_inv_map := by
      ext y; obtain ⟨z, hz⟩ := h_left.surjective_nhds (ψ.open_target.mem_nhds (ψ.map_source φ.mem_chart_source)) y
      simp [← hz.1, h_loc]
    rw [this]; exact hfp.contMDiffAt.comp (ψ x) (h_diff.local_inverse_contDiff _ _ _).contMDiffAt
  exact this.contDiffAt
