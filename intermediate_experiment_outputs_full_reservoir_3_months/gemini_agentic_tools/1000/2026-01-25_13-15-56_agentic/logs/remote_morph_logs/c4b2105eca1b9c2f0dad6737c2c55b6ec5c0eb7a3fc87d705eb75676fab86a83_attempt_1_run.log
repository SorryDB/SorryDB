        have : (s ⁻¹' {v}).indicator (fun _ ↦ v) = v • (s ⁻¹' {v}).indicator (fun _ ↦ 1) := by
          ext x; simp [Set.indicator_apply]; split_ifs <;> simp
        rw [this]; refine (T_submult _ v).trans ?_
        simp only [eLpNorm_smul, enorm_eq_self]
        have h_v_nz := ENNReal.coe_ne_zero.2 (Finset.mem_erase.1 hv).1
        have h_mu : μ (s ⁻¹' {v}) < ⊤ := by
          have h_le : (v : ℝ≥0∞) * μ (s ⁻¹' {v}) ≤ eLpNorm s 1 μ := by
            rw [eLpNorm_eq_lintegral_enorm one_ne_zero ENNReal.coe_ne_top]
            simp only [enorm_eq_self, ENNReal.toReal_one, ENNReal.rpow_one]
            rw [lintegral_nnreal_eq_lintegral, ← lintegral_indicator_const (s.measurableSet_fiber v)]
            apply lintegral_mono
            intro x; simp only [Set.indicator_apply]; split_ifs with hx <;> simp [hx]
          have h_s_f : eLpNorm s 1 μ ≤ eLpNorm f 1 μ := eLpNorm_mono (fun x ↦ ENNReal.coe_mono (h_s_le x))
          exact (ENNReal.le_div_iff_mul_le (Or.inl h_v_nz) (Or.inl ENNReal.coe_ne_top)).2 (h_le.trans h_s_f) |>.trans_lt hf'.2
        have h_rw := (hT (s ⁻¹' {v}) G (s.measurableSet_fiber v) h_mu hG hG').2
        simp only [p_eq, p'_ne_top, ENNReal.inv_top, ENNReal.toReal_zero, ENNReal.rpow_one, ENNReal.rpow_zero, mul_one] at h_rw
        refine (ENNReal.mul_le_mul_left' h_rw v).trans ?_
        rw [mul_assoc, mul_comm ↑c, ← mul_assoc, lintegral_indicator_const (s.measurableSet_fiber v)]
        simp
    exact h_s_norm.trans (mul_le_mul_left' (eLpNorm_mono (fun x ↦ ENNReal.coe_mono (h_s_le x))) ↑c)
