/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun n =>
    ( -((n : ℚ) + 1) * ((n : ℚ) + 2),
      ((n : ℚ) + 1) / ((n : ℚ) + 2) ^ 2,
      -((n : ℚ) + 2) / ((n : ℚ) + 1) ^ 2 )
  apply Set.Infinite.mono (s := Set.range f)
  · rintro _ ⟨n, rfl⟩
    simp only [Set.mem_setOf_eq]
    let x := (f n).1
    let y := (f n).2.1
    let z := (f n).2.2
    have d1 : (n : ℚ) + 1 ≠ 0 := by nlinarith [Nat.cast_nonneg n]
    have d2 : (n : ℚ) + 2 ≠ 0 := by nlinarith [Nat.cast_nonneg n]
    have d3 : (n : ℚ) ^ 2 + 3 * (n : ℚ) + 3 ≠ 0 := by nlinarith [Nat.cast_nonneg n]
    have hx_ne : x ≠ 1 := by dsimp [x, f]; nlinarith [Nat.cast_nonneg n]
    have hy_ne : y ≠ 1 := by dsimp [y, f]; field_simp [d2]; nlinarith [Nat.cast_nonneg n]
    have hz_ne : z ≠ 1 := by dsimp [z, f]; field_simp [d1]; nlinarith [Nat.cast_nonneg n]
    have hf_xyz : x * y * z = 1 := by dsimp [x, y, z, f]; field_simp [d1, d2]; ring
    have hf_sum : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1 := by
      field_simp [hx_ne, hy_ne, hz_ne]
      dsimp [x, y, z, f]
      field_simp [d1, d2, d3]
      ring
    exact ⟨x, y, z, ⟨hx_ne, hy_ne, hz_ne⟩, hf_xyz, hf_sum, rfl⟩
  · apply Set.infinite_range_of_injective
    intro n m h
    simp only [f, Prod.mk.injEq] at h
    have h1 : ((n : ℚ) + 1) * ((n : ℚ) + 2) = ((m : ℚ) + 1) * ((m : ℚ) + 2) := by
      simpa [neg_inj] using h.1
    have : (n : ℚ) = (m : ℚ) := by nlinarith [Nat.cast_nonneg n, Nat.cast_nonneg m]
    exact Nat.cast_inj.1 this
