import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  sorry

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun n =>
    ( -(n + 2 : ℚ) / (n + 1 : ℚ) ^ 2,
      -(n + 1 : ℚ) * (n + 2 : ℚ),
      (n + 1 : ℚ) / (n + 2 : ℚ) ^ 2 )
  have hf : ∀ n, let (x, y, z) := f n;
      (x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) ∧ x * y * z = 1 ∧ x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1 := by
    intro n
    set x := -(n + 2 : ℚ) / (n + 1 : ℚ) ^ 2
    set y := -(n + 1 : ℚ) * (n + 2 : ℚ)
    set z := (n + 1 : ℚ) / (n + 2 : ℚ) ^ 2
    have d1 : (n + 1 : ℚ) ≠ 0 := by norm_cast; exact n.succ_ne_zero
    have d2 : (n + 2 : ℚ) ≠ 0 := by norm_cast; exact n.succ.succ_ne_zero
    have d3 : (n : ℚ) ^ 2 + 3 * n + 3 ≠ 0 := by
      intro h; have : (n : ℚ) ^ 2 + 3 * n + 3 ≥ 3 := by nlinarith [Nat.cast_nonneg n]
      linarith
    have hx1 : x - 1 = -((n : ℚ) ^ 2 + 3 * n + 3) / (n + 1) ^ 2 := by field_simp [x, d1]; ring
    have hy1 : y - 1 = -((n : ℚ) ^ 2 + 3 * n + 3) := by field_simp [y]; ring
    have hz1 : z - 1 = -((n : ℚ) ^ 2 + 3 * n + 3) / (n + 2) ^ 2 := by field_simp [z, d2]; ring
    have hx_ne : x ≠ 1 := by rw [← sub_ne_zero, hx1]; field_simp [d1, d3]
    have hy_ne : y ≠ 1 := by rw [← sub_ne_zero, hy1]; exact d3
    have hz_ne : z ≠ 1 := by rw [← sub_ne_zero, hz1]; field_simp [d2, d3]
    refine ⟨⟨hx_ne, hy_ne, hz_ne⟩, ⟨?_, ?_⟩⟩
    · field_simp [x, y, z, d1, d2]; ring
    · rw [hx1, hy1, hz1]; field_simp [d1, d2, d3]; ring
  apply Set.Infinite.mono (s := Set.range f)
  · rintro t ⟨n, rfl⟩
    exact ⟨(f n).1, (f n).2.1, (f n).2.2, (hf n).1, (hf n).2.1, (hf n).2.2, rfl⟩
  · apply Set.infinite_range_of_injective
    intro n m h
    simp [f] at h; have h2 := h.2.1; simp at h2
    have h3 : n ^ 2 + 3 * n + 2 = m ^ 2 + 3 * m + 2 := by
      have h4 : (n : ℚ) ^ 2 + 3 * (n : ℚ) + 2 = (m : ℚ) ^ 2 + 3 * (m : ℚ) + 2 := by linarith [h2]
      norm_cast at h4
    have mono : StrictMono (fun (n : ℕ) => n ^ 2 + 3 * n + 2) := by
      intro a b hab; nlinarith
    exact mono.injective h3

