    have hy1 : y - 1 = -((n : ℚ) ^ 2 + 4 * n + 7) / (n + 1) ^ 2 := by
      rw [hy, f]; field_simp [d1s]; ring
    have hz1 : z - 1 = -((n : ℚ) ^ 2 + 4 * n + 7) / 4 := by
      rw [hz, f]; field_simp; ring
    have hx_ne : x ≠ 1 := by rw [← sub_ne_zero, hx1]; field_simp [d3, d2s]
    have hy_ne : y ≠ 1 := by rw [← sub_ne_zero, hy1]; field_simp [d3, d1s]
    have hz_ne : z ≠ 1 := by rw [← sub_ne_zero, hz1]; field_simp [d3]
    refine ⟨⟨hx_ne, hy_ne, hz_ne⟩, ?_, ?_⟩
    · rw [hx, hy, hz, f]; field_simp [d1s, d2s]; ring
