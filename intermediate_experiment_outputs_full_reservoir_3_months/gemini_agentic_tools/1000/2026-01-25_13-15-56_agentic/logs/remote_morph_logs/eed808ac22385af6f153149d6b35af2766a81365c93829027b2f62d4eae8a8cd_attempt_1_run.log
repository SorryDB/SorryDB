theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun n =>
    ( 2 * (n + 1 : ℚ) / (n + 3 : ℚ) ^ 2,
      -2 * (n + 3 : ℚ) / (n + 1 : ℚ) ^ 2,
      -((n + 1 : ℚ) * (n + 3 : ℚ)) / 4 )
  have hf : ∀ n, ((f n).1 ≠ 1 ∧ (f n).2.1 ≠ 1 ∧ (f n).2.2 ≠ 1) ∧
      (f n).1 * (f n).2.1 * (f n).2.2 = 1 ∧
      (f n).1 ^ 2 / ((f n).1 - 1) ^ 2 + (f n).2.1 ^ 2 / ((f n).2.1 - 1) ^ 2 + (f n).2.2 ^ 2 / ((f n).2.2 - 1) ^ 2 = 1 := by
    intro n
    have d1 : (n + 1 : ℚ) ≠ 0 := by norm_cast; exact n.succ_ne_zero
    have d2 : (n + 3 : ℚ) ≠ 0 := by norm_cast; exact n.succ.succ.succ_ne_zero
    have d1s : (n + 1 : ℚ) ^ 2 ≠ 0 := pow_ne_zero 2 d1
    have d2s : (n + 3 : ℚ) ^ 2 ≠ 0 := pow_ne_zero 2 d2
    have d3 : (n : ℚ) ^ 2 + 4 * n + 7 ≠ 0 := by nlinarith [Nat.cast_nonneg n]
    set x := (f n).1 with hx
