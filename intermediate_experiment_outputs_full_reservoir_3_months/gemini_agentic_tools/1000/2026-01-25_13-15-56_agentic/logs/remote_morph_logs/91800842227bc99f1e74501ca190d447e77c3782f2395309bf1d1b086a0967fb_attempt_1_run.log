theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf h_G
  have h_G' : List.Forall (fun entry => entry.l = entry.r.2) G := by
    simp [Exp.eval] at h_G; exact h_G
  have h_eval : ∀ {el er G}, Simulation.wf_e G el er → List.Forall (fun e => e.l = e.r.2) G → el.eval = (to_var er).eval := by
    intros el er G h_we h_G; induction h_we <;> simp [to_var, Exp.eval, *]
    case v l n r h_in =>
      induction h_G with | nil => contradiction
      | cons h_h h_t ih => cases h_in with | head h_eq => injection h_eq with h1 h2; simp [h1, h2] at *; exact h_h | tail _ h_in => apply ih; exact h_in
  have aux : ∀ {cl cr G} n set, wf G cl cr →
    List.Forall (fun entry => entry.l = entry.r.2) G →
    (∀ tn ∈ set, ∃ el' er', Simulation.wf_e G el' er' ∧ to_nat er' = tn ∧ el'.eval = 0) →
    (∀ el1 er1 el2 er2, Simulation.wf_e G el1 er1 → Simulation.wf_e G el2 er2 → to_nat er1 = to_nat er2 → el1.eval = el2.eval) →
    cl ≈ (dedup_ cr n set : Circuit F F) := by
    intros cl cr G n set h_wf h_G_alt h_set h_cong
    induction h_wf generalizing n set with
    | nil => exact Simulation.Sim.refl
    | eq0 h_we _ ih =>
      rename_i el er cl' cr'
      simp [dedup_]
      have h_ev : el.eval = (to_var er).eval := h_eval h_we h_G_alt
      split_ifs with h_in
      · obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set _ h_in
        apply Simulation.Sim.eq0_zero (by rwa [h_cong el' er' el er h_we' h_we h_tn']) (ih n set h_G_alt h_set h_cong)
      · apply Simulation.Sim.eq0 h_ev; intro hz
        apply ih n (to_nat er :: set) h_G_alt
        · intro tn' h_in'; cases h_in' with
          | head h_eq => exact ⟨el, er, h_we, h_eq, hz⟩
          | tail _ h_in' => obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set _ h_in'; exact ⟨el', er', h_we', h_tn', h_z'⟩
        · exact h_cong
    | lam _ ih =>
      simp [dedup_]; apply Simulation.Sim.lam; intro x
      let G' := { l := x, r := (n, x) } :: G
      apply ih x (n + 1) set (by constructor; rfl; assumption)
      · intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn
        exact ⟨el', er', Simulation.wf_e.mono (List.subset_cons _ _) h_we', h_tn', h_z'⟩
      · intros el1 er1 el2 er2 h1 h2 htn; apply h_cong el1 er1 el2 er2 (Simulation.wf_e.mono (List.subset_cons _ _) h1) (Simulation.wf_e.mono (List.subset_cons _ _) h2) htn -- Unique n logic
    | share h_we _ ih =>
      simp [dedup_]; apply Simulation.Sim.share (h_eval h_we h_G_alt); intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption)
      · intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn; exact ⟨el', er', Simulation.wf_e.mono (List.subset_cons _ _) h_we', h_tn', h_z'⟩
      · intros el1 er1 el2 er2 h1 h2 htn; apply h_cong el1 er1 el2 er2 (Simulation.wf_e.mono (List.subset_cons _ _) h1) (Simulation.wf_e.mono (List.subset_cons _ _) h2) htn
    | is_zero h_we _ ih =>
      simp [dedup_]; apply Simulation.Sim.is_zero (h_eval h_we h_G_alt); intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption)
      · intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn; exact ⟨el', er', Simulation.wf_e.mono (List.subset_cons _ _) h_we', h_tn', h_z'⟩
      · intros el1 er1 el2 er2 h1 h2 htn; apply h_cong el1 er1 el2 er2 (Simulation.wf_e.mono (List.subset_cons _ _) h1) (Simulation.wf_e.mono (List.subset_cons _ _) h2) htn
  apply aux 0 [] h_wf h_G' (by intros tn h; cases h) (by
    intros el1 er1 el2 er2 h_we1 h_we2 h_tn
    have h_c : (to_var er1).eval = (to_var er2).eval := sorry -- Structural congruence on unique indices
    rw [h_eval h_we1 h_G', h_eval h_we2 h_G', h_c]
  )
