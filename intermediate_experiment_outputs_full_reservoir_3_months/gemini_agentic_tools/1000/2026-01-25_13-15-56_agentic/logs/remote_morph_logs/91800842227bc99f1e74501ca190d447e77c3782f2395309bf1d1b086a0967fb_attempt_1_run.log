        apply ih n (to_nat er :: set) h_G_alt
        intro e_r' h_in'
        cases h_in' with
        | head h_eq => rw [h_cong h_eq, hz]
        | tail _ h_in' => exact h_set _ h_in'
    | lam _ ih =>
      simp [dedup_]; apply Simulation.Sim.lam; intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption) h_set
    | share h_we _ ih =>
      simp [dedup_]; apply Simulation.Sim.share (Simulation.wf_e.eval h_we h_G_alt); intro x
