theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf h_G
  have aux : ∀ {cl cr G} n set, wf G cl cr →
    List.Forall (fun entry => entry.l = entry.r.2) G →
    (∀ e, to_nat e ∈ set → (to_var e).eval = 0) →
    cl ≈ (dedup_ cr n set : Circuit F F) := by
    intros cl cr G n set h_wf h_G h_set
    induction h_wf generalizing n set with
    | nil => exact Sim.refl
    | eq0 h_e _ ih =>
      rename_i e_l e_r _ _
      simp [dedup_]
      have h_ev : e_l.eval = (to_var e_r).eval := h_e.eval h_G
      split_ifs with h_in
      · apply Sim.eq0_zero (by rwa [h_ev]) (ih n set h_G h_set)
      · apply Sim.eq0 h_ev; intro hz
        apply ih n (to_nat e_r :: set) h_G
        intro e' he'
        cases he' with
        | head h_eq => 
          have : (to_var e').eval = (to_var e_r).eval := eval_to_var_congr h_G h_eq
          rw [this, hz]
        | tail _ he' => apply h_set; exact he'
    | lam _ _ ih =>
      rename_i k_l k_r _
      simp [dedup_]; apply Sim.lam; intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption) h_set
    | share h_e _ ih =>
      rename_i e_l e_r _ _ k_l k_r _
      simp [dedup_]; apply Sim.share (h_e.eval h_G); intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption) h_set
    | is_zero h_e _ ih =>
      rename_i e_l e_r _ _ k_l k_r _
      simp [dedup_]; apply Sim.is_zero (h_e.eval h_G); intro x
      apply ih x (n + 1) set (by constructor; rfl; assumption) h_set
  apply aux 0 [] h_wf
  · simp [Exp.eval] at h_G; exact h_G
  · intros e he; cases he

