  have h_cong : ∀ {e1 e2 : Exp F (Nat × F)}, to_nat e1 = to_nat e2 → (to_var e1).eval = (to_var e2).eval := by
    intro e1 e2 h; induction e1 generalizing e2 <;> cases e2 <;> simp [to_nat, to_var, Exp.eval] at *
    case v.v => assumption
