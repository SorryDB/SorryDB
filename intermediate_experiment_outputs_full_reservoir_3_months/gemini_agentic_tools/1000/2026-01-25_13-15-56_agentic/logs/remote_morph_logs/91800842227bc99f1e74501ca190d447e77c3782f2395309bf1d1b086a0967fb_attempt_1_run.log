theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h hG
  have aux : ∀ {cl cr G} n set, wf G cl cr → List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G → (∀ e ∈ set, (Exp.eval (fun i => (G.find? (fun entry => entry.r.1 = i)).get.l) e) = 0) → cl ≈ dedup_ cr n set := by
    intros cl cr G n set h
    induction h generalizing n set with
    | nil => intros; simp [dedup_]; apply Sim.refl
    | eq0 e _ _ _ ih =>
      intros hG hset
      simp [dedup_]; split_ifs with h_in
      · rw [Sim.eq0_zero, ih n set hG hset]
        rw [←wf_eval_to_var ‹wf _ _ _› hG, wf_eval_to_nat ‹wf _ _ _› hG, hset _ h_in]
      · apply Sim.eq0; apply ih n (to_nat e :: set) hG
        intro e' he'; cases he' with
        | head => rw [←wf_eval_to_var ‹wf _ _ _› hG, wf_eval_to_nat ‹wf _ _ _› hG]; rfl
        | tail _ he' => apply hset _ he'
    | lam _ _ _ ih =>
      intros hG hset
      simp [dedup_]; apply Sim.lam; intro x; apply ih (n + 1) set (by intro entry; cases entry <;> simp [hG])
      intro e he; rw [find?_id_G]; apply hset _ he
    | share e _ _ _ ih =>
      intros hG hset
      simp [dedup_]; apply Sim.share (by rw [←wf_eval_to_var ‹wf _ _ _› hG]; rfl)
      intro x; apply ih (n + 1) set (by intro entry; cases entry <;> simp [hG])
      intro e he; rw [find?_id_G]; apply hset _ he
    | is_zero e _ _ _ ih =>
      intros hG hset
      simp [dedup_]; apply Sim.is_zero (by rw [←wf_eval_to_var ‹wf _ _ _› hG]; rfl)
      intro x; apply ih (n + 1) set (by intro entry; cases entry <;> simp [hG])
      intro e he; rw [find?_id_G]; apply hset _ he
  apply aux 0 [] h hG; intros e he; cases he
```
