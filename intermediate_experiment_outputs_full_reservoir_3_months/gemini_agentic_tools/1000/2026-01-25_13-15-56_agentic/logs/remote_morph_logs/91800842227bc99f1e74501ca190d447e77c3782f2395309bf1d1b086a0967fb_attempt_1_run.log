      simp [dedup_]
      have h_ev : el.eval = (to_var er).eval := Simulation.wf_e.eval h_we h_G_alt
      split_ifs with h_in
      · apply Simulation.Sim.eq0_zero h_ev (ih n set h_G_alt h_set)
