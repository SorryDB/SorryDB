  have h_G_all : ∀ e ∈ G, e.l = e.r.2 := by
    intros e h_in; rw [List.forall_iff_forall_mem] at h_G; specialize h_G _ h_in
    simp [Exp.eval] at h_G; exact h_G
  have h_eval : ∀ {el : Exp F F} {er : Exp F (Nat × F)} {G : List (Entry F (Nat × F))},
    wf_e G el er → (∀ e ∈ G, e.l = e.r.2) → el = to_var er := by
