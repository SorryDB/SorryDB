    case add.add ihl ihr => rw [ihl (by assumption), ihr (by assumption)]
    case mul.mul ihl ihr => rw [ihl (by assumption), ihr (by assumption)]
    case sub.sub ihl ihr => rw [ihl (by assumption), ihr (by assumption)]
    all_goals contradiction
  have aux : ∀ {cl cr G} n set, wf G cl cr →
    List.Forall (fun entry => entry.l = entry.r.2) G →
    (∀ e_r, to_nat e_r ∈ set → (to_var e_r).eval = 0) →
    cl ≈ (dedup_ cr n set : Circuit F F) := by
    intros cl cr G n set h_wf h_G_alt h_set
    induction h_wf generalizing n set with
    | nil => exact Simulation.Sim.refl
    | eq0 h_we h_w ih =>
