theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf h_G
  have h_G_f : G.Forall (fun e => e.l = e.r.2) := by
    simp [Exp.eval] at h_G; exact h_G
  have aux : ∀ {cl cr G} n set, wf G cl cr →
    G.Forall (fun e => e.l = e.r.2) →
    (∀ tn ∈ set, ∃ el er, wf_e G el er ∧ to_nat er = tn ∧ el.eval = 0) →
    cl ≈ dedup_ cr n set := by
    intros cl cr G n set h_wf h_G_f h_set
    induction h_wf generalizing n set with
    | nil => exact Sim.refl
    | eq0 h_we h_w ih =>
      rename_i el er cl' cr'
      simp [dedup_]
      have h_ev : el.eval = (to_var er).eval := h_we.eval h_G_f
      split_ifs with h_in
      · obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set _ h_in
        have h_eq : el.eval = el'.eval := h_we.eval_to_nat_eq h_we' h_tn'
        exact Sim.eq0_zero (by rw [h_eq, h_z']) (ih n set h_set)
      · apply Sim.eq0 h_ev; intro hz
        apply ih n (to_nat er :: set)
        intro tn' h_in'; cases h_in' with
        | head h_eq => exact ⟨el, er, h_we, h_eq, hz⟩
        | tail _ h_in' => obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set _ h_in'; exact ⟨el', er', h_we'.mono (by simp), h_tn', h_z'⟩
    | lam h_w ih =>
      simp [dedup_]; apply Sim.lam; intro x
      apply ih x (n + 1) set (by simp [h_G_f])
      intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn
      exact ⟨el', er', h_we'.mono (by simp), h_tn', h_z'⟩
    | share h_we h_w ih =>
      simp [dedup_]; apply Sim.share (h_we.eval h_G_f); intro x
      apply ih x (n + 1) set (by simp [h_G_f])
      intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn
      exact ⟨el', er', h_we'.mono (by simp), h_tn', h_z'⟩
    | is_zero h_we h_w ih =>
      simp [dedup_]; apply Sim.is_zero (h_we.eval h_G_f); intro x
      apply ih x (n + 1) set (by simp [h_G_f])
      intro tn h_tn; obtain ⟨el', er', h_we', h_tn', h_z'⟩ := h_set tn h_tn
      exact ⟨el', er', h_we'.mono (by simp), h_tn', h_z'⟩
  apply aux 0 [] h_wf h_G_f (by intros tn h; cases h)
