  | succ m hm ih =>
    have he : 0 < e := exp_pos 1
    have hm_pos : 0 < (m : ℝ) := by positivity
    have hm1_pos : 0 < (m + 1 : ℝ) := by positivity
    rw [Nat.factorial_succ, Nat.cast_mul, Nat.cast_succ]
