theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  induction' n, hn using Nat.le_induction with n hn IH
  · have h_e_pos : 0 < e := exp_pos 1
    rw [Nat.factorial_two, Nat.cast_ofNat, div_pow, mul_div, div_lt_iff (pow_pos h_e_pos 2),
      pow_two, mul_assoc, mul_lt_mul_left h_e_pos, mul_comm, ← lt_div_iff (by norm_num : (0 : ℝ) < 2), norm_num]
    exact Real.add_one_lt_exp 1 (by norm_num)
  · have h_n_pos : 0 < (n : ℝ) := by positivity
    have h_n1_pos : 0 < (n + 1 : ℝ) := by positivity
    rw [Nat.factorial_succ, Nat.cast_mul, Nat.cast_succ]
    refine' lt_of_le_of_lt _ (mul_lt_mul_of_pos_left IH h_n1_pos)
    rw [mul_assoc, mul_le_mul_left (exp_pos 1), div_pow, div_pow, pow_succ e, ← div_div,
      le_div_iff (pow_pos (exp_pos 1) n), mul_assoc, mul_div_cancel_left₀ _ (pow_pos (exp_pos 1) n).ne',
      mul_comm, ← div_le_iff h_n1_pos, pow_succ, mul_div_cancel_left₀ _ h_n1_pos.ne', ← div_pow,
      add_div, div_self h_n_pos.ne']
    exact (pow_le_pow_left₀ (by positivity) (Real.add_one_le_exp (1 / n)) n).trans_eq
      (by rw [← Real.exp_nat_mul, mul_one_div_cancel h_n_pos.ne']; rfl)
