    ∃ e_result e2 e4 e8 eq_choice,
    mul_by_cofactor e = ok e_result ∧
    add e e = ok e2 ∧
    add e2 e2 = ok e4 ∧
    add e4 e4 = ok e8 ∧
    ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq e_result e8 = ok eq_choice ∧
