lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have h_indep := R.carrier_indep I hI
  specialize h_indep hI'
  have : b ≤ a ⊓ sSup ((⋃ J ∈ R, J) \ {a}) := le_inf hb hb'
  have h_disj : a ⊓ sSup (I \ {a}) = ⊥ := h_indep.le_bot.antisymm bot_le
  have h_union : (⋃ J ∈ R, J) \ {a} = (I \ {a}) ∪ (⋃ J ∈ R \ {I}, J) := by
    ext x; simp; constructor
    · rintro ⟨⟨J, hJ, hxJ⟩, hxa⟩
      by_cases hJI : J = I
      · left; exact ⟨hJI ▸ hxJ, hxa⟩
        subst hJI; exact ⟨hxJ, hxa⟩
      · right; use J, hJ, hJI, hxJ
    · rintro (⟨hxI, hxa⟩ | ⟨J, hJ, hJI, hxJ⟩)
      · refine ⟨⟨I, hI, hxI⟩, hxa⟩
      · refine ⟨⟨J, hJ, hxJ⟩, ?_⟩
        intro hxa; subst hxa
        have h_span := R.carrier_span (sSup J)
        · have : J = I := by
            obtain ⟨s, hs, hs'⟩ := (exists_unique_iff_exists_and_unique).1 (R.carrier_span (sSup J))
            -- This is where we need the uniqueness of D for each s in S
            sorry
          exact hJI this
  sorry
```
