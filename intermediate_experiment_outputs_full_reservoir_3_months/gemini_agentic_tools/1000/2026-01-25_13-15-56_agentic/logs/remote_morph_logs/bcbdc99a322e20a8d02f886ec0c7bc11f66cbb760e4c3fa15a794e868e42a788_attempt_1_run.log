theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold maxStrength maxStrength_postcond
  simp [maxStrength_precond] at h_precond
  let ps := (List.range (2 ^ nums.length)).map fun mask =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let p1 := (ps.filter (· ≠ [])).map (fun s => List.foldl (fun acc x => acc * x) 1 s)
  let p2 := (nums.sublists.filter (· ≠ [])).map (fun s => List.foldl (· * ·) 1 s)
  have h_eq : ∀ x, x ∈ p1 ↔ x ∈ p2 := by
    intro x; simp [p1, p2, ps, List.mem_sublists]
    constructor
    · rintro ⟨mask, ⟨_, rfl⟩, h_ne, rfl⟩
      refine ⟨_, ?_, h_ne, rfl⟩
      sorry
    · rintro ⟨s, h_sub, h_ne, rfl⟩
      sorry
  have h_ne : p1 ≠ [] := by
    cases nums with
    | nil => contradiction
    | cons x xs =>
      have h_x_in_p1 : x ∈ p1 := by
        simp [p1, ps]
        let mask := 1
        use mask
        constructor
        · apply Nat.one_lt_pow <;> simp; omega
        · constructor
          · simp [List.foldr, nums.length]; sorry
          · simp
      exact List.ne_nil_of_mem h_x_in_p1
  cases h_m : p1.max? with
  | none => exfalso; exact h_ne (List.max?_eq_none_iff.1 h_m)
  | some r =>
    simp [h_m]
    have h_max := List.max?_eq_some_iff.1 h_m
    constructor
    · simp [List.contains_iff, ← h_eq, h_max.1]
    · simp [List.all_eq_true]; intro x hx; apply h_max.2; rwa [h_eq]
  -- !benchmark @end proof
