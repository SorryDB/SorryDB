          simp [ps_f]; apply List.foldr_congr; intro i _ _; rw [Nat.shiftRight_add]; simp [Nat.add_comm]
        rw [h_s']
        have h_sub : (ps_f xs (m >>> 1)).Sublist xs := (ih _).mp ⟨m >>> 1, Nat.shiftRight_lt_pow hm (by simp), rfl⟩
        split <;> simp [*]
        · apply List.Sublist.cons₂; exact h_sub
        · apply List.Sublist.cons; exact h_sub
      · intro h
        cases h with
        | slnil =>
          use 0; simp [p1_subsets, ps_f, pow_succ]
          induction xs with
          | nil => simp [ps_f, List.range_succ']
          | cons y ys ih2 => 
            rw [ps_f, List.length_cons, List.range_succ', List.foldr_cons, List.foldr_map]
            simp [Nat.shiftRight_zero]; exact ih2
        | cons y ys h_sub =>
          obtain ⟨m, hm, hps⟩ := (ih _).mpr h_sub
          use 2 * m; constructor
          · rw [pow_succ]; exact Nat.mul_lt_mul_of_pos_right hm (by simp)
          · rw [ps_f, List.length_cons, List.range_succ', List.foldr_cons, List.foldr_map]
            simp [Nat.shiftRight_zero, Nat.mul_comm 2 m]
            have : (2 * m).shiftRight 1 = m := by simp [Nat.shiftRight_1, Nat.mul_div_right]
            apply List.foldr_congr; intro i _ _; rw [Nat.shiftRight_add]; simp [Nat.add_comm, this]
            exact hps
        | cons₂ y ys h_sub =>
          obtain ⟨m, hm, hps⟩ := (ih _).mpr h_sub
          use 2 * m + 1; constructor
          · rw [pow_succ]; omega
          · rw [ps_f, List.length_cons, List.range_succ', List.foldr_cons, List.foldr_map]
            simp [Nat.shiftRight_zero]
            have h1 : (2 * m + 1).shiftRight 0 = 2 * m + 1 := rfl
            have h2 : (2 * m + 1).shiftRight 1 = m := by simp [Nat.shiftRight_1]; omega
            simp [h1, h2]
            apply List.foldr_congr; intro i _ _; rw [Nat.shiftRight_add]; simp [Nat.add_comm, h2]
            exact hps
  have h_prod_equiv : ∀ x, x ∈ products1 ↔ x ∈ products2 := by
    intro x; simp [products1, products2, h_sublist_equiv, List.mem_sublists]
  have h_p1_ne : products1 ≠ [] := by
    have h_nums_in : nums ∈ p1_subsets := (h_sublist_equiv nums).mpr (List.Sublist.refl nums)
    exact List.ne_nil_of_mem (List.mem_map_of_mem (List.foldl (· * ·) 1) (List.mem_filter_of_mem h_nums_in (by simp [h_precond])))
  cases h_m : products1.max? with
  | none => exfalso; exact h_p1_ne (List.max?_eq_none_iff.1 h_m)
  | some res =>
    simp [h_m, List.contains_iff_mem, ← h_prod_equiv, List.all_eq_true]
    exact List.max?_eq_some_iff.1 h_m
  -- !benchmark @end proof
