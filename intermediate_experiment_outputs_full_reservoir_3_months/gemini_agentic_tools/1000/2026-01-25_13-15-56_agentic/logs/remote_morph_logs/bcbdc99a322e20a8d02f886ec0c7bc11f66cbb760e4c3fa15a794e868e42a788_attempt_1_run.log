theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold maxStrength maxStrength_postcond
  simp [maxStrength_precond] at h_precond
  let ps_f (l : List ℤ) (mask : ℕ) : List ℤ :=
    (List.range l.length).foldr (fun i acc =>
      if (mask >>> i).land 1 = 1 then l[i]! :: acc else acc) []
  let p1_subsets := (List.range (2 ^ nums.length)).map (ps_f nums)
  let p1 := (p1_subsets.filter (· ≠ [])).map (fun s => s.foldl (· * ·) 1)
  let p2_subsets := nums.sublists
  let p2 := (p2_subsets.filter (· ≠ [])).map (fun s => s.foldl (· * ·) 1)
  have h_mem : ∀ s, s ∈ p1_subsets ↔ s <+ nums := by
    intro s; induction nums generalizing s with
    | nil =>
      simp [p1_subsets, ps_f, List.range]; constructor
      · rintro ⟨m, hm, rfl⟩; simp at hm; simp [hm, List.Sublist.nil]
      · intro h; use 0; simp [List.eq_nil_of_sublist_nil h, List.Sublist.nil]
    | cons x xs ih =>
      constructor
      · rintro ⟨m, hm, rfl⟩
        rw [ps_f, List.range_succ', List.foldr_map]
        simp [Nat.shiftRight_zero]
        split
        · apply List.Sublist.cons₂
          rw [← ih]; use (m >>> 1); constructor
          · exact Nat.shiftRight_lt_pow hm (Nat.succ_pos 0)
          · rfl
        · apply List.Sublist.cons
          rw [← ih]; use (m >>> 1); constructor
          · exact Nat.shiftRight_lt_pow hm (Nat.succ_pos 0)
          · rfl
      · intro h; cases h with
        | nil => use 0; simp [p1_subsets, ps_f, pow_succ]
          constructor
          · apply Nat.pos_pow; simp
          · induction xs with
            | nil => simp [ps_f]
            | cons y ys ih2 => 
              rw [ps_f, List.range_succ', List.foldr_map]
              simp [Nat.shiftRight_zero, ih2]
        | cons y ys h' =>
          obtain ⟨m, hm, hps⟩ := (ih _).mpr h'
          use 2 * m; constructor
          · rw [pow_succ]; exact Nat.mul_lt_mul_of_pos_right hm (by simp)
          · rw [ps_f, List.range_succ', List.foldr_map]
            simp [Nat.shiftRight_zero]
            have : (fun i acc => if (2 * m >>> (i + 1)).land 1 = 1 then (x :: xs)[i+1]! :: acc else acc) = (fun i acc => if (m >>> i).land 1 = 1 then xs[i]! :: acc else acc) := by
              funext i acc; simp [Nat.shiftRight_succ, Nat.shiftRight_mul_two]
            rw [this, hps]
        | cons₂ y ys h' =>
          obtain ⟨m, hm, hps⟩ := (ih _).mpr h'
          use 2 * m + 1; constructor
          · rw [pow_succ]; omega
          · rw [ps_f, List.range_succ', List.foldr_map]
            simp [Nat.shiftRight_zero]
            have : (fun i acc => if ((2 * m + 1) >>> (i + 1)).land 1 = 1 then (x :: xs)[i+1]! :: acc else acc) = (fun i acc => if (m >>> i).land 1 = 1 then xs[i]! :: acc else acc) := by
              funext i acc; simp [Nat.shiftRight_succ, Nat.shiftRight_mul_two]
            rw [this, hps]
  have h_eq : ∀ x, x ∈ p1 ↔ x ∈ p2 := by
    intro x; simp [p1, p2, List.mem_filter, List.mem_map, h_mem, List.mem_sublists]
  have h_p1_ne : p1 ≠ [] := by
    have h_mem_nums : nums ∈ p1_subsets := (h_mem nums).mpr (List.Sublist.refl nums)
    have h_mem_prod : List.foldl (· * ·) 1 nums ∈ p1 := by
      simp [p1]; exact ⟨nums, ⟨h_mem_nums, h_precond⟩, rfl⟩
    exact List.ne_nil_of_mem h_mem_prod
  cases h_m : p1.max? with
  | none => exfalso; exact h_p1_ne (List.max?_eq_none_iff.1 h_m)
  | some r =>
    simp [h_m, List.contains_iff_mem, ← h_eq, List.all_eq_true]
    constructor
    · exact List.max?_mem h_m
    · intro x hx; rw [← h_eq] at hx; exact List.le_max? h_m hx
  -- !benchmark @end proof
