theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold maxStrength maxStrength_postcond
  simp only [maxStrength_precond] at *
  let ps := (List.range (2 ^ nums.length)).map fun (mask : Nat) =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc
    ) []
  let p1 := (ps.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let p2 := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have h_eq : ∀ x, x ∈ p1 ↔ x ∈ p2 := by
    sorry
  have h_ne : p1 ≠ [] := by
    cases nums with
    | nil => contradiction
    | cons x xs =>
      have h_len : 1 < 2 ^ (xs.length + 1) := Nat.one_lt_pow (by simp) (by simp)
      have : [x] ∈ ps := by
        simp [ps, h_len]; use 1; simp [h_len, List.range_succ, List.foldr]; split_ifs <;> simp
      have : (List.foldl (· * ·) 1 [x]) ∈ p1 := by
        simp [p1]; exact ⟨[x], ⟨this, by simp⟩, rfl⟩
      intro h; rw [h] at this; simp at this
  generalize h_m : p1.max? = m
  cases m with
  | none => exfalso; exact h_ne (List.max?_eq_none.mp h_m)
  | some r =>
    have h_res : (maxStrength nums h_precond) = r := by
      unfold maxStrength; dsimp; simp [h_m, p1, ps]
    simp [h_res]
    constructor
    · rw [List.contains_iff_mem, ← h_eq]; exact List.mem_of_max?_eq_some h_m
    · rw [List.all_iff_forall]; intro x hx; rw [← h_eq] at hx; exact List.le_max_of_mem hx h_m
  -- !benchmark @end proof
