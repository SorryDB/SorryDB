theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold maxStrength maxStrength_postcond
  simp only [maxStrength_precond] at h_precond
  let ps := (List.range (2 ^ nums.length)).map fun mask =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let p1 := (ps.filter (· ≠ [])).map (fun s => s.foldl (· * ·) 1)
  let p2 := (nums.sublists.filter (· ≠ [])).map (fun s => s.foldl (· * ·) 1)
  have h_eq : ∀ x, x ∈ p1 ↔ x ∈ p2 := by
    intro x; simp only [List.mem_map, List.mem_filter, List.mem_sublists, ne_eq]
    constructor
    · rintro ⟨s, ⟨hs_ps, hne⟩, rfl⟩; refine ⟨s, ⟨?_, hne⟩, rfl⟩; sorry
    · rintro ⟨s, ⟨hs_sub, hne⟩, rfl⟩; refine ⟨s, ⟨?_, hne⟩, rfl⟩; sorry
  have h_p1_ne : p1 ≠ [] := by
    cases nums with
    | nil => contradiction
    | cons x xs =>
      have : x ∈ p1 := by
        simp only [List.mem_map, List.mem_filter, ne_eq, List.mem_range]
        refine ⟨[x], ⟨⟨1, ?_, ?_⟩, by simp⟩, ?_⟩
        · apply Nat.pow_pos; linarith
        · sorry
        · simp
      intro h; rw [h] at this; simp at this
  match h_m : p1.max? with
  | some r =>
    simp only [h_m, Option.getD_some]
    constructor
    · rw [List.contains_iff, ← h_eq]; exact List.mem_of_max?_eq_some h_m
    · rw [List.all_eq_true]; intro x hx; rw [← h_eq] at hx; exact List.le_max_of_mem hx h_m
  | none =>
    exfalso; exact h_p1_ne (List.max?_eq_none.mp h_m)
  -- !benchmark @end proof
