    intro w w_in α φ in_w
    -- "The main challenge" :-)
    -- Need Lemmas 6.18 to 6.19 about pre-states here.
    sorry
  case X_in =>
    unfold WS
    simp
    use (PreState.forms (.fromRoot .stop)).toFinset
    simp [BuildTree.allPreStates, BuildTree.allPreStatePs]
    sorry
