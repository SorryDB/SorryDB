        rw [‚Üź h_cnf_eq, ‚Üź hG]
        exact (coerceLang_mem language.val).mp z.2.1
      obtain ‚ü®z_cfg, hz_cfg_mem, hz_cfg_eq‚ü© := coerceCFGLang_mem_imp_word_of_type z.1 G_cnf.1 z_in_cnf
      sorry
