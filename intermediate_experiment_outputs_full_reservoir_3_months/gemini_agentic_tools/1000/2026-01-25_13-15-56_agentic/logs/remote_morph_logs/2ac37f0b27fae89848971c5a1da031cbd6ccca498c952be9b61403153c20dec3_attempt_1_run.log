      by_cases hqp : q = p; · rwa [hqp]
      have h_qp : q * p ≤ m := Nat.le_of_dvd hpos (Nat.Coprime.mul_dvd (hprime.coprime_iff_not_dvd.mpr hqp) q_dvd hpdvd)
      have : (q : ℝ) < p := by
        have hmn : (m : ℝ) < P.n := cast_lt.mpr (Multiset.mem_Ico.mp hm).2
