      · have : p ≤ x := Nat.le_of_dvd (by linarith [hx.1, hprime.pos]) hp_dvd
        linarith [hprime.pos, this]
      · by_cases hqp : q = p; · rwa [hqp]
        have : q * p ≤ x := Nat.mul_le_of_dvd_of_dvd qprime.one_lt.le hprime.one_lt.le qdvd hp_dvd
        have : (q : ℝ) < p := by
          have : (q : ℝ) * p < (p : ℝ)^2 := by
            calc (q : ℝ) * p ≤ (x : ℝ) := by exact_mod_cast this
              _ < P.n := by exact_mod_cast hx.2
              _ < (p : ℝ)^2 := by rwa [Real.lt_sqrt (Nat.cast_nonneg _) (Nat.cast_nonneg _)] at hp'
          rwa [mul_lt_mul_right (cast_pos.mpr hprime.pos)] at this
        exact (this.trans (Nat.cast_le.mpr hp)).le
    have h_val (x : ℕ) (hx : x ∈ Finset.Ico (P.n - P.n / P.M) P.n) :
        (x.factorization p : ℤ) = if p ∣ x then 1 else 0 := by
      split_ifs with hpdvd
      · rw [Nat.Prime.factorization_eq_one hprime hpdvd]
        intro h_sq_dvd; have : p * p ≤ x := Nat.le_of_dvd (by linarith [hx.1, hprime.pos]) h_sq_dvd
        nlinarith [cast_le.mpr this, (Real.sqrt_lt (cast_nonneg P.n) (cast_nonneg p)).mp hp']
      · rw [factorization_eq_zero_iff]; exact .inr (.inl hpdvd)
    unfold Factorization.balance Factorization.sum initial
