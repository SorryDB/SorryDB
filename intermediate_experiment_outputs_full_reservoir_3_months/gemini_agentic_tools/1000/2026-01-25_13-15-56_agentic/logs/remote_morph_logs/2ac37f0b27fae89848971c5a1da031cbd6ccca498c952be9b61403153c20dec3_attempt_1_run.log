      unfold initial
      simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      rw [← Int.cast_sum, Int.cast_inj]
      congr 1; rw [Multiset.Ico, ← Finset.sum_eq_multiset_sum]
      simp only [Finset.sum_filter, Finset.sum_ite, Finset.sum_const_zero, add_zero, Finset.filter_filter]
      rw [Finset.sum_congr rfl]; intro x hx; simp only [Finset.mem_filter, Finset.mem_Ico] at hx
      have h_sm : x ∈ (P.n / P.L).smoothNumbers := by
        rw [mem_smoothNumbers']; refine ⟨by linarith [hprime.pos, Nat.le_of_dvd (by omega) hx.2], fun q qprime qdvd ↦ ?_⟩
        by_cases hqp : q = p; · rwa [hqp]
        · have : q * p ≤ x := Nat.mul_le_of_dvd_of_dvd qprime.one_lt.le hprime.one_lt.le qdvd hx.2
          have : (q : ℝ) < p := by
            have : (q : ℝ) * p < (p : ℝ)^2 := by
              calc (q : ℝ) * p ≤ (x : ℝ) := by exact_mod_cast this
                _ < P.n := by exact_mod_cast hx.1.2
                _ < (p : ℝ)^2 := by rwa [Real.lt_sqrt (Nat.cast_nonneg _) (Nat.cast_nonneg _)] at hp'
            rwa [mul_lt_mul_right (cast_pos.mpr hprime.pos)] at this
          exact (this.trans (Nat.cast_le.mpr hp)).le
      have h_val : x.factorization p = 1 := by
        apply Nat.Prime.factorization_eq_one hprime hx.2
        intro h_sq_dvd; have : p * p ≤ x := Nat.le_of_dvd (by linarith [hprime.pos, Nat.le_of_dvd (by omega) hx.2]) h_sq_dvd
        linarith [cast_le.mpr this, (Real.sqrt_lt (cast_nonneg P.n) (cast_nonneg p)).mp hp']
      simp [h_sm, h_val]
      rw [Finset.Ico_eq_range_sdiff (Nat.sub_le _ _), Finset.filter_sdiff, Finset.card_sdiff (Finset.filter_mono (Finset.range_mono (Nat.sub_le _ _))),
        Finset.card_range_filter_dvd, Finset.card_range_filter_dvd, hprime.pos]
    rw [Factorization.balance, Factorization.sum, h_fac, h_sum]
    zify; omega
  · have h0 : P.n.factorial.factorization p = 0 := Nat.factorization_eq_zero_of_not_prime p hprime
    have h1 : (P.initial.a.map (·.factorization p)).sum = 0 := Multiset.sum_eq_zero fun m hm ↦ Nat.factorization_eq_zero_of_not_prime p hprime
    rw [Factorization.balance, Factorization.sum, h0, h1]
    simp; positivity

end Erdos392
