      have hpos : m > 0 := Nat.pos_of_dvd_of_pos hpdvd hp_prime.pos
      rw [mem_smoothNumbers']; intro q q_prime q_dvd
      by_cases hqp : q = p; · rwa [hqp]
      have h_qp : q * p ≤ m := Nat.le_of_dvd hpos (Nat.Coprime.mul_dvd (hp_prime.coprime_iff_not_dvd.mpr hqp) q_dvd hpdvd)
      have : (q : ℝ) < p := by
        have hmn : (m : ℝ) < P.n := cast_lt.mpr (Multiset.mem_Ico.mp hm).2
        have hnp : (P.n : ℝ) < (p : ℝ) ^ 2 := (Real.sqrt_lt (cast_nonneg P.n)).mp hp'
        nlinarith [cast_le.mpr h_qp]
      exact (Nat.cast_le.mpr hp).trans' (by exact_mod_cast this.le)
    have h_val : ∀ m ∈ I, p ∣ m → (m.factorization p : ℤ) = 1 := fun m hm hpdvd ↦ by
      have hpos : m > 0 := Nat.pos_of_dvd_of_pos hpdvd hp_prime.pos
      rw [Nat.factorization_def hp_prime, padicValNat_def hp_prime hpos, if_pos hpdvd]
      have : ¬ p ^ 2 ∣ m := fun h_dvd ↦ by
