@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_fac : (P.n.factorial.factorization p : ℤ) = P.n / p := by
      rw [factorial_factorization_eq_div hprime hp']; norm_cast
    unfold Factorization.balance Factorization.sum initial
    let I := Multiset.Ico (P.n - P.n / P.M) P.n
    have h_smooth_of_dvd {m} (hm : m ∈ I) (hpdvd : p ∣ m) : m ∈ (P.n / P.L).smoothNumbers := by
      have hpos : m > 0 := Nat.pos_of_dvd_of_pos hpdvd hprime.pos
      rw [mem_smoothNumbers']; intro q q_prime q_dvd
      by_cases hqp : q = p; · rwa [hqp]
      have h_qp : q * p ≤ m := Nat.le_of_dvd hpos ((hprime.coprime_iff_not_dvd.mpr hqp).mul_dvd q_dvd hpdvd)
      have : (q : ℝ) < p := by
        have hnp : (P.n : ℝ) < (p : ℝ) ^ 2 := (Real.sqrt_lt (cast_nonneg P.n)).mp hp'
        have hmn : (m : ℝ) < P.n := cast_lt.mpr (Multiset.mem_Ico.mp hm).2
        nlinarith [cast_le.mpr h_qp]
      exact (Nat.cast_le.mpr hp).trans' (by exact_mod_cast this.le)
    have h_val {m} (hm : m ∈ I) (hpdvd : p ∣ m) : (m.factorization p : ℤ) = 1 := by
      have hpos : m > 0 := Nat.pos_of_dvd_of_pos hpdvd hprime.pos
      rw [Nat.factorization_def hprime, padicValNat_def hprime hpos, if_pos hpdvd]
      have : ¬ p ^ 2 ∣ m := fun h_dvd ↦ by
        have : p ^ 2 ≤ m := Nat.le_of_dvd hpos h_dvd
        have hnp : (P.n : ℝ) < (p : ℝ) ^ 2 := (Real.sqrt_lt (cast_nonneg P.n)).mp hp'
        have hmn : m < P.n := (Multiset.mem_Ico.mp hm).2
        nlinarith [cast_le.mpr this]
      simp [this]
    have h_sum : ((Multiset.map (fun m ↦ (m.factorization p : ℤ)) P.initial.a)).sum =
        P.M * (I.filter (p ∣ ·)).card := by
      simp [initial, Factorization.sum]; rw [Multiset.filter_join, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
      congr 1; rw [Multiset.sum_filter]
      apply Multiset.sum_congr (Multiset.filter_congr fun m hm ↦ by
        simp; intro h; exact h_smooth_of_dvd hm h) (fun m hm ↦ by
        simp; intro h; exact h_val hm h)
    rw [h_sum, h_fac]; zify
    let A := P.n - P.n / P.M; let B := P.n
    have hMpos : P.M > 0 := by
      have hn_pos : P.n > 0 := by
        have : (P.L : ℝ) ^ 2 < P.n := by nlinarith [P.hL]
        exact_mod_cast (sq_pos_of_pos (cast_pos.mpr P.hL_pos)).trans this
      exact Nat.pos_of_ne_zero fun hM ↦ by simp [hM] at hn_pos
    have h_card_ge : (I.filter (p ∣ ·)).card ≥ (P.n / P.M) / p := by
      rw [Multiset.Ico, ← Finset.card_filter]
      have h_sub : (Finset.range A).filter (p ∣ ·) ⊆ (Finset.range B).filter (p ∣ ·) := fun x hx ↦ by
        simp only [Finset.mem_filter, Finset.mem_range] at hx ⊢; exact ⟨hx.1.trans (Nat.sub_le _ _), hx.2⟩
      rw [← Finset.Ico_range_range, Finset.filter_sdiff, Finset.card_sdiff h_sub]
      have h_card_range (n : ℕ) : (Finset.range n).filter (p ∣ ·).card = (n + p - 1) / p := by
        rcases n.eq_zero_or_pos with rfl | hn; · simp
        rw [← Finset.card_insert_of_not_mem (fun h ↦ (Nat.pos_of_dvd_of_pos (Finset.mem_filter.mp h).2 hprime.pos).ne' rfl),
           ← Finset.filter_insert, Finset.range_eq_Ico, Finset.Ico_insert_succ_left (Nat.zero_le _),
           Nat.Ioc_filter_dvd_card_eq_div, Nat.add_sub_cancel]; · rfl
      rw [h_card_range B, h_card_range A]
      apply Nat.le_sub_of_add_le
      exact (Nat.div_add_div_le_div (A + p - 1) (B - A) p).trans (by
        rw [Nat.add_assoc, Nat.sub_add_cancel (div_le_self B P.M)]; exact le_refl _)
    have h_div_div : (P.M : ℤ) * ((P.n / P.M) / p) ≥ P.n / p - (P.M : ℤ) + 1 := by
      have h_pM_pos : P.M * p > 0 := Nat.mul_pos hMpos hprime.pos
