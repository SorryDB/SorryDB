              have hmn : m < P.n := (Multiset.mem_Ico.mp hm).2
              have hnp : (P.n : ℝ) < (p : ℝ) ^ 2 := by
                rw [Real.lt_sqrt (cast_nonneg _) (cast_nonneg _)] at hp'; exact hp'
              nlinarith [cast_le.mpr this]
            simp [this]
          simp [hpdvd, hsm, h_val]
        · simp [hpdvd, Nat.factorization_eq_zero_iff]
      · simp [hsm, Nat.factorization_eq_zero_iff]
    have h_smooth_of_dvd {m} (hm : m ∈ I) (hpdvd : p ∣ m) : m ∈ (P.n / P.L).smoothNumbers := by
      have hpos : m > 0 := Nat.lt_of_lt_of_le hprime.pos (Nat.le_of_dvd (by intro h; subst h; have := (Multiset.mem_Ico.mp hm).1; have : P.n > 0 := by nlinarith [P.hL, P.hL_pos]; have : P.n / P.M = P.n := by simp_all; omega) hpdvd)
