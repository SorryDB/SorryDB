@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_fac : (P.n.factorial.factorization p : ℤ) = P.n / p := factorial_factorization_eq_div hprime hp'
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
      unfold initial Factorization.sum
      simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      congr 1; rw [Multiset.Ico, ← Finset.sum_eq_multiset_sum]
      simp only [Finset.sum_filter, Finset.sum_ite, Finset.sum_const_zero, add_zero, Finset.filter_filter]
      rw [Finset.sum_congr rfl]; intro x hx; simp only [Finset.mem_filter, Finset.mem_Ico] at hx
      have h_sm : x ∈ (P.n / P.L).smoothNumbers := by
        rw [mem_smoothNumbers']; refine ⟨by linarith [hx.1.1, P.hL_pos], fun q qprime qdvd ↦ ?_⟩
        by_cases hqp : q = p; · rwa [hqp]
        · have : q * p ≤ x := Nat.mul_le_of_dvd_of_dvd qprime.one_lt.le hprime.one_lt.le qdvd hx.2
          have : (q : ℝ) < p := by
            have : (q : ℝ) * p < (p : ℝ)^2 := by
              calc (q : ℝ) * p ≤ x := by exact_mod_cast this
                _ < P.n := by exact_mod_cast hx.1.2
                _ < (p : ℝ)^2 := by rwa [Real.lt_sqrt (Nat.cast_nonneg _) (Nat.cast_nonneg _)] at hp'
            rwa [mul_lt_mul_right (cast_pos.mpr hprime.pos)] at this
          exact this.le.trans hp
      have h_val : x.factorization p = 1 := by
        apply Nat.Prime.factorization_eq_one hprime hx.2
        intro h_sq_dvd; have : p * p ≤ x := Nat.le_of_dvd (by linarith [hx.1.1, P.hL_pos]) h_sq_dvd
        linarith [cast_le.mpr this, (Real.sqrt_lt (cast_nonneg P.n) (cast_nonneg p)).mp hp']
      simp [h_sm, h_val]
    rw [Factorization.balance, h_sum, h_fac, Finset.card_Ico_filter_dvd _ _ hprime.pos]
    have h_M_pos : P.M > 0 := by
      by_contra! hM; simp [hM] at *
      have : p ≤ P.n := hp.trans (Nat.div_le_self _ _)
      have : 1 ≤ P.n / p := Nat.le_div_iff_mul_le hprime.pos |>.mpr (by omega)
      omega
    zify; have := Nat.div_add_mod (P.n / p) P.M; omega
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime p hprime]

end Erdos392
