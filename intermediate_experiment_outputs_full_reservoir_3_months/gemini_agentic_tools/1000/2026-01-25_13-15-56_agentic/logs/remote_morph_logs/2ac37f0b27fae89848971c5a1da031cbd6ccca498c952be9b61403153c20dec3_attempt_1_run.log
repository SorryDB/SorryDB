      simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join,
        Multiset.sum_replicate, smul_eq_mul, ← Finset.sum_eq_multiset_sum, Finset.sum_filter]
      simp only [Finset.sum_ite, Finset.sum_const_zero, add_zero, ite_self,
