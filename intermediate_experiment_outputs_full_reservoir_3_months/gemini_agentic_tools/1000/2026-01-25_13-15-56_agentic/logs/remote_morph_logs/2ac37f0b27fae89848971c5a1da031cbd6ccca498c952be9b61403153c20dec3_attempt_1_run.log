    rw [h_sum, h_count, h_fac]; zify
    have hMpos : P.M > 0 := by have : P.n > 0 := by nlinarith [P.hL, P.hL_pos]; rcases P.M.eq_zero_or_pos with rfl | hM <;> simp_all
    have h_card_ge : (I.filter (p ∣ ·)).card ≥ (P.n / P.M) / p := by
