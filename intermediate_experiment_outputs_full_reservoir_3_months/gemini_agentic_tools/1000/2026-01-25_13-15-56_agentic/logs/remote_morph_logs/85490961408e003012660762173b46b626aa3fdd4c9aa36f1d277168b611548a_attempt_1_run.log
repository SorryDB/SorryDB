    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let T := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt)
  have hP : P = T.circumcenter + T.circumsphere.radius •
    (angleBisector ℝ B A C).direction.unitVector := sorry
  have hX : dist B X = (dist B C + dist A B - dist A C) * dist B C / (dist A B + dist B C + dist A C) := sorry
  have hY : dist C Y = (dist B C + dist A C - dist A B) * dist B C / (dist A B + dist B C + dist A C) := sorry
  have h_PI_PB_PC : dist P I = dist P B ∧ dist P I = dist P C := sorry
  have h_concyclic_PLIX : Concyclic ({P, L, I, X} : Set Pt) := sorry
