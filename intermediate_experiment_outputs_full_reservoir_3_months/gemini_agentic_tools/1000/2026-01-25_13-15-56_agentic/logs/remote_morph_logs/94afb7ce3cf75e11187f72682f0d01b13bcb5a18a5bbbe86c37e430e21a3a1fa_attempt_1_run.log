    rw [← hiX, ← hiY] at h_nat
    have h_inv : (iX.inv ≫ F.homF f) ≫ iY.hom = G.homF f := by
      rw [assoc, ← h_nat, ← assoc, iX.inv_hom_id, id_comp]
    rw [← h_inv, assoc, iY.hom_inv_id, comp_id]
