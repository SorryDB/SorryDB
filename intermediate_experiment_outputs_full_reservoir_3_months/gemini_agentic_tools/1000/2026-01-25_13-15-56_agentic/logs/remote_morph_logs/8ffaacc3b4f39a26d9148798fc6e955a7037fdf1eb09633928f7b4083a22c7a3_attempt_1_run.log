lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f (k : ℕ) (ω : probSpace α R) : (Iic k → I) × (ℕ → α → R) := (fun i ↦ ω.1 i.1, ω.2)
  have hf (k : ℕ) : Measurable (f k) :=
    Measurable.prodMk (measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1 |>.comp measurable_fst)
      measurable_snd
  have h_past : IndepFun (fun ω ↦ ω.1 (n + 1)) (f n) (arrayMeasure ν) := by
    rw [arrayMeasure, indepFun_iff_map_prod_eq_prod_map_map (measurable_pi_apply (n + 1) |>.comp measurable_fst).aemeasurable (hf n).aemeasurable]
    have h1 : IndepFun (fun f : ℕ → I ↦ f (n + 1)) (fun f ↦ fun i : Iic n ↦ f i.1) (Measure.infinitePi fun _ ↦ volume) :=
      (iIndepFun_infinitePi (fun _ ↦ volume)).indepFun_set_set
        (Set.disjoint_left.mpr fun x hx y hy ↦ by subst hx; obtain ⟨i, hi⟩ := hy; subst hi; exact (i.2.trans_lt (Nat.lt_succ_self n)).ne')
        (measurable_pi_apply (n + 1)) (measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1)
    rw [indepFun_iff_map_prod_eq_prod_map_map (measurable_pi_apply (n + 1)).aemeasurable (measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1).aemeasurable] at h1
    have h_map1 : (fun ω : (ℕ → I) × (ℕ → α → R) ↦ (ω.1 (n + 1), (f n ω))) =
        (fun (p : (I × (Iic n → I)) × (ℕ → α → R)) ↦ (p.1.1, (p.1.2, p.2))) ∘
        Prod.map (fun f ↦ (f (n + 1), fun i : Iic n ↦ f i.1)) id := by ext; rfl
    have h_map2 : (fun ω : (ℕ → I) × (ℕ → α → R) ↦ (f n ω)) =
        (fun (p : (Iic n → I) × (ℕ → α → R)) ↦ (p.1, p.2)) ∘
        Prod.map (fun f ↦ fun i : Iic n ↦ f i.1) id := by ext; rfl
    rw [h_map1, Measure.map_map (by fun_prop) (by fun_prop), Measure.map_prod_map (by fun_prop) (measurable_id), h1]
    rw [h_map2, Measure.map_map (by fun_prop) (by fun_prop), Measure.map_prod_map (by fun_prop) (measurable_id)]
    simp only [Measure.prod_assoc, Measure.map_id]
    rfl
  have h_deps (k : ℕ) {x y : probSpace α R} (h : f k x = f k y) : hist alg x k = hist alg y k := by
    induction k with
    | zero =>
      simp only [f, Prod.mk.inj_iff] at h
      ext i : 1
      simp [hist_zero, h.1, h.2]
    | succ k ih =>
      simp only [f, Prod.mk.inj_iff] at h
      have h_fk : f k x = f k y := by
        simp [f, h.2]
        ext i : 1
        exact congr_fun h.1 ⟨i.1, i.2.trans (Nat.le_succ k)⟩
      have h_hist_k := ih h_fk
      have h_next := congr_fun h.1 ⟨k + 1, Nat.le_refl (k + 1)⟩
      ext i : 1
      rw [hist_add_one, hist_add_one]
      simp [h_hist_k, h_next, h.2]
  obtain ⟨φ, hφ, heq⟩ := Measurable.exists_measurable_comp (hf n) (measurable_hist alg n) (h_deps n)
  rw [heq]
  exact h_past.comp measurable_id hφ

end ArrayModel

