lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let F (k : ℕ) (ω : probSpace α R) : (Iic k → I) × (ℕ → α → R) := (fun i ↦ ω.1 i.1, ω.2)
  have hF (k : ℕ) : Measurable (F k) :=
    Measurable.prodMk (measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1 |>.comp measurable_fst)
      measurable_snd
  have h_indep : IndepFun (fun ω ↦ ω.1 (n + 1)) (F n) (arrayMeasure ν) := by
    rw [arrayMeasure, F, indepFun_iff_map_prod_eq_prod_map_map (measurable_pi_apply (n + 1) |>.comp
      measurable_fst).aemeasurable (hF n).aemeasurable]
    have h1 := (iIndepFun_infinitePi fun _ ↦ volume).indepFun_set_set
      (Set.disjoint_singleton_left.mpr fun i hi ↦ (hi.trans_lt (Nat.lt_succ_self n)).ne)
      (measurable_pi_apply (n + 1)) (measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1)
    have h_map1 : (fun ω : (ℕ → I) × (ℕ → α → R) ↦ (ω.1 (n + 1), (fun i : Iic n ↦ ω.1 i.1, ω.2))) =
        (fun (p : (I × (Iic n → I)) × (ℕ → α → R)) ↦ (p.1.1, (p.1.2, p.2))) ∘
        Prod.map (fun f ↦ (f (n + 1), fun i : Iic n ↦ f i.1)) id := by ext; rfl
    have h_map2 : (fun ω : (ℕ → I) × (ℕ → α → R) ↦ (fun i : Iic n ↦ ω.1 i.1, ω.2)) =
        Prod.map (fun f ↦ fun i : Iic n ↦ f i.1) id := by ext; rfl
    rw [h_map1, Measure.map_map (by fun_prop) (by fun_prop), Measure.map_prod_map (by fun_prop)
      measurable_id, h1.map_eq, h_map2, Measure.map_prod_map (by fun_prop) measurable_id]
    simp [Measure.prod_assoc, Measure.map_id]
  let φ (k : ℕ) (p : (Iic k → I) × (ℕ → α → R)) :=
    hist alg (fun i ↦ if hi : i ≤ k then p.1 ⟨i, hi⟩ else (default : I), p.2) k
  have hφ (k : ℕ) : Measurable (φ k) := by
    refine (measurable_hist alg k).comp (Measurable.prodMk ?_ measurable_snd)
    exact measurable_pi_iff.mpr fun i ↦ measurable_dite (fun _ ↦ i ≤ k)
      (fun hi ↦ (measurable_pi_apply ⟨i, hi⟩).comp measurable_fst) (fun _ ↦ measurable_const)
  have h_eq (k : ℕ) (ω : probSpace α R) : hist alg ω k = φ k (F k ω) := by
    induction k with
    | zero => ext i; rw [Unique.eq_default i]; simp [F, hist_zero, φ]
    | succ k ih =>
      ext i; rw [hist_add_one, hist_add_one]
      by_cases hin : i ≤ k
      · simp [hin, ih]
        congr 1; ext j; simp [F]
      · simp [hin]; congr 2
        · simp [ih, F]
        · simp [ih, F]
  rw [funext (h_eq n)]
  exact h_indep.comp measurable_id (hφ n)

end ArrayModel

end Bandit
