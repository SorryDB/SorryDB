/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf S := if Real.pi ∈ S then 1 else 0
  empty := if_neg (not_mem_empty _)
  mono _ _ h := by split_ifs <;> simp [*]
  iUnion_nat s _ := by
    split_ifs with h
    · rcases mem_iUnion.1 h with ⟨i, hi⟩
      exact (if_pos hi).symm.le.trans (ENNReal.le_tsum i)
    · exact zero_le _
