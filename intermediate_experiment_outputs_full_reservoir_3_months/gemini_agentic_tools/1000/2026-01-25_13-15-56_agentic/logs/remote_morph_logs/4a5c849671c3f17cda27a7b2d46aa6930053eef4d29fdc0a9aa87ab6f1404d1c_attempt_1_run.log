lemma DT_list {Γ : List (Formula α)} : (Deduction Ax Γ.toFinset φ) ↔ (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
  constructor;
  . intro h;
    induction h with
    | ctx hφ =>
      induction Γ using List.induction_with_singleton with
      | hnil => simp at hφ
      | hsingle ψ => simp at hφ; subst hφ; grind
      | hcons ψ Γ hΓ ih =>
        rw [List.conj₂_cons_nonempty hΓ]
        simp at hφ; cases hφ with
        | inl h => subst h; grind
        | inr h => specialize ih h; grind
    | thm hφ => grind
    | mp hmp _ ih => grind
    | andIR _ _ ihφ ihψ => grind
  . intro h; exact Deduction.mp h deduct_conj
```
