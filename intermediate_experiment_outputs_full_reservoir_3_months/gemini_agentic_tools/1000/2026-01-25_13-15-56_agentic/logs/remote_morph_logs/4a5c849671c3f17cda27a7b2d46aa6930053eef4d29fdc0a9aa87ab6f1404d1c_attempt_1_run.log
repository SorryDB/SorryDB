        . exact Entailment.trans'' Entailment.and_right (ih h)
    | thm hφ => apply Entailment.imply_left; assumption
    | mp hmp _ ih => exact Entailment.trans'' ih hmp
    | andIR _ _ ihφ ihψ => exact Entailment.and_intro ihφ ihψ
  . intro h; exact Deduction.mp h deduct_conj
