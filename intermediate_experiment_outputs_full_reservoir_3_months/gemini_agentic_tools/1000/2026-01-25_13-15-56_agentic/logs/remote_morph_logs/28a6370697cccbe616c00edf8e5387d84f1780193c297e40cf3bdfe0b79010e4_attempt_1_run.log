/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ, o⟩
  induction σ generalizing S
  case nil =>
    rw [eval_dis] at a_kv_b
    rcases a_kv_b with h|h <;> have := true_of_knowldege h <;> rw [stubbornness] at this <;> simp [this]
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_kv ra] at a_kv_b
      specialize IH (⁻o) a_kv_b; rw [not_in_call_then_invariant_resultSet ra]; exact IH
    case Caller | Callee =>
      constructor
      · -- Part 1: (b, S b) ∈ resultSet a
        rw [eval_dis] at a_kv_b
        cases h_sb : S b
        all_goals
          have a_knows : S⌈⟨C :: σ, o⟩⌉ ⊧ (if S b then K a (b @ b) else K a (‾b @ b)) := by
            simp [h_sb, eval_dis]; cases a_kv_b <;> (rename_i h; have t := true_of_knowldege h; simp [stubbornness, h_sb] at t; exact h)
          unfold resultSet; simp [ra, h_sb]
          cases C <;> simp [roleOfIn] at ra <;> (try subst ra) <;> (try rcases ra with ⟨_, ra⟩; subst ra) <;> simp [h_sb, stubbornness]
          all_goals
            refine ⟨⟨?_, ?_⟩, ?_⟩
            · by_cases b = a <;> try (simp [stubbornness, h_sb]; done)
              by_cases hb : b = other a C
              · subst hb; simp [other, ra] at *; (try left); (try right); (try rename_i _ err; by_cases b = err <;> simp [h_sb, stubbornness])
              · by_cases h_prev : S⌈⟨σ, ⁻o⟩⌉ ⊧ Kv a b
                · specialize IH (⁻o) h_prev; (try left); (try right); exact IH.1
                · exfalso; have t := true_of_knowldege a_knows; unfold resultSet at t; simp [ra, h_sb, stubbornness, other, roleOfIn] at t; simp_all
            · intro h_ref; have := true_of_knowldege h_ref; simp [stubbornness, h_sb] at this
            · intro h_del; specialize h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; simp [stubbornness, h_sb] at h_del
      · -- Part 2: (b, !S b) ∉ resultSet a
        unfold resultSet; simp [ra]
        intro; right
        intro T τ D he hr hc
        rw [eval, stubbornness]
        rw [eval_dis] at a_kv_b
        cases h_sb : S b <;> simp [h_sb] at a_kv_b ⊢
        all_goals
          cases a_kv_b <;> (rename_i h; try (have t := true_of_knowldege h; simp [stubbornness, h_sb] at t))
          specialize h T τ rfl
          simp [equiv, he, hr, hc, ra] at h; rw [stubbornness] at h; exact h
