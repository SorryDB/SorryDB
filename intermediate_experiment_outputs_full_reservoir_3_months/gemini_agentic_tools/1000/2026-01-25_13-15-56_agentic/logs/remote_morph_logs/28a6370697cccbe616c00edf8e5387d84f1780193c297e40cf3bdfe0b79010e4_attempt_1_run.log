    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ, o⟩
  induction σ generalizing S
  case nil =>
    rw [eval_dis] at a_kv_b
    cases a_kv_b with
    | inl h => have := true_of_knowldege h; rw [stubbornness] at this; subst this; simp
    | inr h => have := true_of_knowldege h; rw [stubbornness] at this; subst this; simp
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_kv ra] at a_kv_b
      specialize IH (⁻o) a_kv_b
      rw [not_in_call_then_invariant_resultSet ra]; exact IH
    case Caller =>
      rw [eval_dis] at a_kv_b
      rcases a_kv_b with a_knows_t | a_knows_f
      · have h_b : S b = true := stubbornness _ _ rfl |>.mp (true_of_knowldege a_knows_t)
        constructor
        · unfold resultSet; simp [ra, h_b]
          cases C <;> simp [roleOfIn] at ra <;> subst ra <;> simp [h_b, stubbornness]
          all_goals
            refine ⟨⟨?_, ?_⟩, ?_⟩
            · by_cases h_ba : b = a
              · subst h_ba; left; rw [stubbornness]; exact h_b
              · rename_i _ callee; by_cases h_bc : b = callee
                · subst h_bc; right; (try rename_i _ _ err); (by_cases h_be : b = err <;> simp [h_be, stubbornness, h_b])
                · by_cases h_prev : eval S ⟨σ, ⁻o⟩ (Kv a b)
                  · specialize IH (⁻o) h_prev; left; exact IH.1
                  · have := true_of_knowldege a_knows_t; unfold resultSet at this; simp [roleOfIn, h_b] at this; simp_all
            · intro h_ref; have := true_of_knowldege h_ref; simp [stubbornness, h_b] at this
            · intro h_del; specialize h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; simp [stubbornness, h_b] at h_del
        · unfold resultSet; simp [ra, h_b]
          intro h_in; rcases h_in with ⟨_, h_del⟩
          apply h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; rw [stubbornness, h_b]; simp
      · have h_b : S b = false := stubbornness _ _ rfl |>.mp (true_of_knowldege a_knows_f)
        constructor
        · unfold resultSet; simp [ra, h_b]
          cases C <;> simp [roleOfIn] at ra <;> subst ra <;> simp [h_b, stubbornness]
          all_goals
            refine ⟨⟨?_, ?_⟩, ?_⟩
            · by_cases h_ba : b = a
              · subst h_ba; left; rw [stubbornness]; exact h_b
              · rename_i _ callee; by_cases h_bc : b = callee
                · subst h_bc; right; (try rename_i _ _ err); (by_cases h_be : b = err <;> simp [h_be, stubbornness, h_b])
                · by_cases h_prev : eval S ⟨σ, ⁻o⟩ (Kv a b)
                  · specialize IH (⁻o) h_prev; left; exact IH.1
                  · have := true_of_knowldege a_knows_f; unfold resultSet at this; simp [roleOfIn, h_b] at this; simp_all
            · intro h_ref; have := true_of_knowldege h_ref; simp [stubbornness, h_b] at this
            · intro h_del; specialize h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; simp [stubbornness, h_b] at h_del
        · unfold resultSet; simp [ra, h_b]
          intro h_in; rcases h_in with ⟨_, h_del⟩
          apply h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; rw [stubbornness, h_b]; simp
    case Callee =>
      rw [eval_dis] at a_kv_b
      rcases a_kv_b with a_knows_t | a_knows_f
