                  · have := true_of_knowldege a_knows_t; unfold resultSet at this; simp [roleOfIn, h_b] at this; simp_all
            · intro h_ref; have := true_of_knowldege h_ref; simp [stubbornness, h_b] at this
            · intro h_del; specialize h_del S ⟨⟨σ, ⁻o⟩, rfl⟩ _ equiv_refl rfl rfl; simp [stubbornness, h_b] at h_del
