lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ : (Ω → ℝ≥0∞) → ℝ := fun f ↦ (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nonneg : 0 ≤ φ := fun f ↦ ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ ENNReal.toReal_le_one⟩
  obtain ⟨g, hg, hgap⟩ := komlos_convex hφ_nonneg hφ_bdd
  let h : ℕ → Ω → ℝ := fun n ω ↦ ((1 + g n ω)⁻¹).toReal
  have h_meas n : Measurable (h n) := by
    obtain ⟨s, w, hwi, hw1, hsm, hg_eq⟩ := (convexHull_range_eq_exists_affineCombination ℝ≥0 _).mp (hg n)
    rw [hg_eq]
    have : Measurable (fun ω ↦ (g n ω)) := by
      rw [hg_eq]; simp_rw [Pi.affineCombination_apply, Finset.affineCombination_eq_centerMass,
        Finset.centerMass_eq_sum_smul hw1]
      exact Measurable.sum (fun i _ ↦ Measurable.const_smul (hX _) _)
    exact (this.add_const 1).inv.ennreal_toReal
  have h_cau : CauchySeq (fun n ↦ (⟨h n, h_meas n, by
      refine (lt_of_le_of_lt (lintegral_mono fun ω ↦ ?_) (measure_lt_top P Set.univ)).2
      · simp [h]; exact ENNReal.toReal_le_one ⟩ : MeasureTheory.Lp ℝ 2 P)) := by
    refine MeasureTheory.cauchySeq_Lp_of_tendsto_gap P (fun x ↦ x) (fun x ↦ x⁻¹) ?_ ?_
    · intro ε εpos; obtain ⟨N, hN⟩ := hgap ε εpos; exact ⟨N, fun n m hn hm ↦ by simpa using hN n m hn hm⟩
    · sorry
  obtain ⟨ns, -, -, -, h_ae⟩ := MeasureTheory.Lp.cauchySeq_exists_tendsto_ae h_cau
  refine ⟨fun n ↦ g (ns n), fun ω ↦ (ENNReal.ofReal (h_ae.choose ω))⁻¹ - 1, fun n ↦ ?_, ?_, ?_⟩
  · exact convexHull_mono (Set.range_subset_iff.2 fun m ↦ ⟨m + (ns n - n), by simp [add_assoc, ns.monotone.ge n]⟩)
      (convexHull_mono (fun x ⟨m, hm⟩ ↦ ⟨m, by simpa using hm⟩) (hg (ns n)))
  · exact h_ae.choose_spec.1.ennreal_ofReal.inv.sub_const 1
  · filter_upwards [h_ae.choose_spec.2] with ω hω
    have h_lim : Tendsto (fun n ↦ (1 + g (ns n) ω)⁻¹) atTop (𝓝 (ENNReal.ofReal (h_ae.choose ω))) := by
      rw [ENNReal.tendsto_toReal_iff]; · exact hω; · simp; · positivity
    convert h_lim.inv.sub_const 1 using 1
    simp [ENNReal.sub_add_cancel_of_le ENNReal.one_le_add_left]
