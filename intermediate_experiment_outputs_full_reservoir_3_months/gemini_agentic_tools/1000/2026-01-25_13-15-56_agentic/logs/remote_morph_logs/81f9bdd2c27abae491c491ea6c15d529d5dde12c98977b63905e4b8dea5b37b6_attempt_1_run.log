lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ (f : Ω → ℝ≥0∞) : ℝ := (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nonneg : 0 ≤ φ := fun _ ↦ ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ by
    simp [φ]; apply ENNReal.toReal_mono ENNReal.one_ne_top
    exact (lintegral_mono fun ω ↦ (ENNReal.inv_le_inv.2 ENNReal.one_le_add_left : (1 + X n ω)⁻¹ ≤ 1)).trans (by simp [lintegral_one])⟩
  rcases komlos_convex hφ_nonneg hφ_bdd with ⟨g, hg, hgap⟩
  have hg_meas n : Measurable (g n) := by
    let S := { f : Ω → ℝ≥0∞ | Measurable f }
    have h_conv : Convex ℝ≥0 S := fun f hf f' hf' a b _ _ _ ↦ (hf.const_smul a).add (hf'.const_smul b)
    exact convexHull_min (Set.range_subset_iff.2 fun m ↦ hX (n + m)) h_conv (hg n)
  let u n ω := ((1 + g n ω)⁻¹).toReal
  have hu_meas n : Measurable (u n) := (hg_meas n).add_const 1 |>.inv.ennreal_toReal
  have hu_le_one n ω : u n ω ≤ 1 := by
    apply ENNReal.toReal_mono ENNReal.one_ne_top
    exact ENNReal.inv_le_inv.2 ENNReal.one_le_add_left
  let U n : Lp ℝ 2 P := ⟨AEEqClass.mk (u n) (hu_meas n).aeStronglyMeasurable, memLp_two_iff_integrable.mpr
    ⟨integrable_of_bound 1 (hu_meas n).stronglyMeasurable (eventually_of_forall (hu_le_one n)),
     integrable_of_bound 1 ((hu_meas n).pow_const 2).stronglyMeasurable (eventually_of_forall fun ω ↦ by simpa using pow_le_one _ (by positivity) (hu_le_one n ω))⟩⟩
  have h_cau : CauchySeq U := by
    rw [Metric.cauchySeq_iff]; intro ε εpos
    rcases hgap (ε^2 / 4) (by positivity) with ⟨N, hN⟩
    use N; intro n m hn hm; specialize hN n m hn hm
    let v_n ω := (1 + g n ω)⁻¹; let v_m ω := (1 + g m ω)⁻¹; let v_mid ω := (1 + (2 : ℝ≥0)⁻¹ • (g n + g m) ω)⁻¹
    have h_gap_eq : 2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m)) = (∫⁻ ω, (2⁻¹ * v_n ω + 2⁻¹ * v_m ω - v_mid ω) ∂P).toReal := by
      simp only [φ, ← ENNReal.toReal_mul, ← ENNReal.toReal_add, ← ENNReal.toReal_sub]
      congr 1; rw [lintegral_sub, lintegral_add, lintegral_mul_left, lintegral_mul_left]
      · rfl
      · exact (hg_meas n).add_const 1 |>.inv.const_mul 2⁻¹ |>.add ((hg_meas m).add_const 1 |>.inv.const_mul 2⁻¹)
      · exact (hg_meas n).add (hg_meas m) |>.const_smul (2:ℝ≥0)⁻¹ |>.add_const 1 |>.inv
      · intro ω
        have h_inv : (1 + (2 : ℝ≥0)⁻¹ • (g n + g m) ω) = (2⁻¹ : ℝ≥0) * (1 + g n ω) + (2⁻¹ : ℝ≥0) * (1 + g m ω) := by
          simp only [Pi.add_apply, Pi.smul_apply, smul_add, ENNReal.smul_def, ENNReal.mul_add]
          rw [← add_assoc, add_comm (2⁻¹ * g n ω), add_assoc, ← ENNReal.add_mul, ENNReal.inv_two_add_inv_two, one_mul]
        rw [h_inv]; exact ENNReal.inv_le_add_inv_of_add_eq_one (by norm_num) (by norm_num)
      · refine ENNReal.ne_top_of_le_ne_top (by simp) ?_
        exact (lintegral_mono fun _ ↦ ENNReal.inv_le_inv.2 ENNReal.one_le_add_left).trans (by simp [lintegral_one])
    apply Real.le_sqrt_of_sq_le
    rw [Lp.norm_sub_pow (by norm_num) (hu_meas n).aeStronglyMeasurable (hu_meas m).aeStronglyMeasurable, h_gap_eq]; simp
    refine (integral_le_integral_of_le (Lp.integrable _).pow_const (by positivity) (fun ω ↦ ?_)).trans (by linarith)
