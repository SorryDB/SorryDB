    have hb : v_m ω = ENNReal.ofReal b := (ENNReal.ofReal_toReal (ENNReal.ne_top_of_le_ne_top ENNReal.one_ne_top (ENNReal.inv_le_inv.2 ENNReal.one_le_add_left))).symm
    have hmid : v_mid ω = ENNReal.ofReal (if a + b = 0 then 0 else 2 * a * b / (a + b)) := by
      split_ifs with hab
      · rcases (show a = 0 ∧ b = 0 by linarith [ENNReal.toReal_nonneg (v_n ω), ENNReal.toReal_nonneg (v_m ω)]) with ⟨rfl, rfl⟩; simp [v_mid, Pi.add_apply, Pi.smul_apply, smul_add]; rfl
      · simp only [v_mid, Pi.add_apply, Pi.smul_apply, smul_add, ha, hb]
        rw [ENNReal.ofReal_add (ENNReal.toReal_nonneg _) (ENNReal.toReal_nonneg _), ENNReal.ofReal_inv (by positivity)]; field_simp; ring
    rw [ha, hb, hmid, ← ENNReal.toReal_mul, ← ENNReal.toReal_add, ← ENNReal.toReal_sub]
    · apply ENNReal.toReal_mono (by simp) (ENNReal.ofReal_le_ofReal _); split_ifs with hab <;> [simp [hab]; (field_simp; linarith [sq_nonneg (a - b), a, b, hu_le_one n ω, hu_le_one m ω])]
    · exact ENNReal.ofReal_le_ofReal (by split_ifs with hab <;> [simp; (field_simp; linarith [sq_nonneg (a-b), a, b])])
  rcases cauchySeq_tendsto_of_complete h_cau with ⟨u_lim, hu_lim⟩
  rcases (Lp.tendsto_InMeasure hu_lim).exists_seq_tendsto_ae with ⟨ns, hns, h_ae⟩
  let Y_lim ω := (ENNReal.ofReal (u_lim.toFunction ω))⁻¹ - 1
  refine ⟨fun k ↦ g (ns k), Y_lim, fun k ↦ ?_, u_lim.stronglyMeasurable.measurable.ennreal_ofReal.inv.sub_const 1, ?_⟩
  · have h_subset : convexHull ℝ≥0 (Set.range fun m ↦ X (ns k + m)) ⊆ convexHull ℝ≥0∞ (Set.range fun m ↦ X (k + m)) := by
      refine convexHull_min ?_ ?_
      · intro x ⟨m, hm⟩; exact subset_convexHull ℝ≥0∞ _ ⟨m + (ns k - k), by rw [add_assoc, Nat.add_sub_cancel' (hns.id_le k), hm]⟩
      · intro f hf f' hf' a b ha hb hab; exact (convex_convexHull ℝ≥0∞ _) hf hf' (a : ℝ≥0∞) (b : ℝ≥0∞) (by simp) (by simp) (by simp [hab])
    exact h_subset (hg (ns k))
  · filter_upwards [h_ae] with ω hω
    have : Tendsto (fun k ↦ (1 + g (ns k) ω)⁻¹) atTop (𝓝 (ENNReal.ofReal (u_lim.toFunction ω))) := by
      rw [ENNReal.tendsto_toReal_iff]; · exact hω; · exact ENNReal.ne_top_of_le_ne_top ENNReal.one_ne_top (ENNReal.inv_le_inv.2 ENNReal.one_le_add_left); · exact ENNReal.ofReal_ne_top
    have h_g_lim := this.inv.sub_const 1
    simp_rw [ENNReal.inv_inv, ENNReal.add_sub_cancel_right ENNReal.one_ne_top] at h_g_lim; exact h_g_lim
