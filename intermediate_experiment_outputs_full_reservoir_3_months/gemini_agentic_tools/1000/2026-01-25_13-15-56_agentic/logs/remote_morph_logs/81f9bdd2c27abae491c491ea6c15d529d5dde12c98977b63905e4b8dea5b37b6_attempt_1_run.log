lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let φ (f : Ω → ℝ≥0∞) : ℝ := (∫⁻ ω, (1 + f ω)⁻¹ ∂P).toReal
  have hφ_nonneg : 0 ≤ φ := fun _ ↦ ENNReal.toReal_nonneg
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ ENNReal.toReal_le_of_le ENNReal.one_ne_top
    ((lintegral_mono fun ω ↦ ENNReal.inv_le_one.2 ENNReal.one_le_add_left).trans (by simp))⟩
  let ⟨g, hg, hgap⟩ := komlos_convex hφ_nonneg hφ_bdd
  have hg_meas n : Measurable (g n) :=
    convexHull_min (Set.range_subset_iff.2 fun m ↦ hX (n + m)) (fun f hf f' hf' a b _ _ _ ↦ (hf.const_smul a).add (hf'.const_smul b)) (hg n)
  let u n ω := ((1 + g n ω)⁻¹).toReal
  have hu_meas n : Measurable (u n) := (hg_meas n).add_const 1 |>.inv.ennreal_toReal
  have hu_le_one n ω : u n ω ≤ 1 := ENNReal.toReal_le_of_le ENNReal.one_ne_top (ENNReal.inv_le_one.2 ENNReal.one_le_add_left)
  let U n : Lp ℝ 2 P := ⟨AEEqClass.mk (u n) (hu_meas n).aeStronglyMeasurable, memLp_two_iff_integrable.mpr
    ⟨integrable_of_bound 1 (hu_meas n).stronglyMeasurable (eventually_of_forall (hu_le_one n)),
     integrable_of_bound 1 ((hu_meas n).pow_const 2).stronglyMeasurable (eventually_of_forall fun ω ↦ by simpa using pow_le_one _ (by positivity) (hu_le_one n ω))⟩⟩
  have h_cau : CauchySeq U := by
    rw [Metric.cauchySeq_iff]; intro ε εpos
    let ⟨N, hN⟩ := hgap (ε^2 / 4) (by positivity)
    use N; intro n m hn hm; specialize hN n m hn hm
    let v_n ω := (1 + g n ω)⁻¹; let v_m ω := (1 + g m ω)⁻¹; let v_mid ω := (1 + (2 : ℝ≥0)⁻¹ • (g n + g m) ω)⁻¹
    have h_gap_eq : 2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m)) = (∫⁻ ω, (2⁻¹ * v_n ω + 2⁻¹ * v_m ω - v_mid ω) ∂P).toReal := by
      simp only [φ, ← ENNReal.toReal_mul, ← ENNReal.toReal_add, ← ENNReal.toReal_sub]
      congr 1; rw [lintegral_sub, lintegral_add, lintegral_mul_left, lintegral_mul_left]
      · rfl
      · exact (hg_meas n).add_const 1 |>.inv.const_mul 2⁻¹ |>.add ((hg_meas m).add_const 1 |>.inv.const_mul 2⁻¹)
      · exact (hg_meas n).add (hg_meas m) |>.const_smul (2:ℝ≥0)⁻¹ |>.add_const 1 |>.inv
      · intro ω; exact ENNReal.inv_convex_le _ _ _ _ (by norm_num)
      · refine ENNReal.ne_top_of_le_ne_top (by simp) ?_
        exact (lintegral_mono fun _ ↦ ENNReal.inv_le_one.2 ENNReal.one_le_add_left).trans (by simp)
    apply Real.le_sqrt_of_sq_le
    rw [Lp.norm_sub_pow (by norm_num) (hu_meas n).aeStronglyMeasurable (hu_meas m).aeStronglyMeasurable, h_gap_eq]; simp
    refine (integral_le_integral_of_le (Lp.integrable _).pow_const (by positivity) (fun ω ↦ ?_)).trans (by linarith)
    let a := u n ω; let b := u m ω
    have ha : v_n ω = ENNReal.ofReal a := by rw [ENNReal.ofReal_toReal (ENNReal.ne_top_of_le_ne_top ENNReal.one_ne_top (ENNReal.inv_le_one.2 ENNReal.one_le_add_left))]; rfl
    have hb : v_m ω = ENNReal.ofReal b := by rw [ENNReal.ofReal_toReal (ENNReal.ne_top_of_le_ne_top ENNReal.one_ne_top (ENNReal.inv_le_one.2 ENNReal.one_le_add_left))]; rfl
    have hmid : v_mid ω = ENNReal.ofReal (if a + b = 0 then 0 else 2 * a * b / (a + b)) := by
      split_ifs with hab
      · have : a = 0 ∧ b = 0 := by linarith [a, b, ENNReal.toReal_nonneg (v_n ω), ENNReal.toReal_nonneg (v_m ω)]; simp [this.1, this.2]; rfl
      · simp only [v_mid, Pi.add_apply, Pi.smul_apply, smul_add, ha, hb]
        rw [ENNReal.ofReal_add (by positivity) (by positivity), ENNReal.ofReal_inv (by positivity)]; field_simp; ring
    rw [ha, hb, hmid, ← ENNReal.toReal_mul, ← ENNReal.toReal_add, ← ENNReal.toReal_sub]
    · apply ENNReal.toReal_mono (by simp) (ENNReal.ofReal_le_ofReal _); split_ifs with hab <;> [simp [hab]; (field_simp; linarith [sq_nonneg (a - b), a, b, hu_le_one n ω, hu_le_one m ω])]
    · exact ENNReal.ofReal_le_ofReal (by split_ifs with hab <;> [simp; (field_simp; linarith [sq_nonneg (a-b), a, b])])
  let ⟨u_lim, hu_lim⟩ := cauchySeq_tendsto_of_complete h_cau
  let ⟨ns, hns, h_ae⟩ := (tendsto_InMeasure_of_tendsto_atTop hu_lim).exists_seq_tendsto_ae
  let Y_lim ω := (ENNReal.ofReal (u_lim.toFunction ω))⁻¹ - 1
  refine ⟨fun k ↦ g (ns k), Y_lim, fun k ↦ ?_, u_lim.stronglyMeasurable.measurable.ennreal_ofReal.inv.sub_const 1, ?_⟩
  · exact convexHull_mono (Set.range_subset_iff.2 fun m ↦ ⟨m + (ns k - k), by rw [add_assoc, Nat.add_sub_cancel' (hns.id_le k)]⟩) (hg (ns k))
  · filter_upwards [h_ae] with ω hω
    have : Tendsto (fun k ↦ (1 + g (ns k) ω)⁻¹) atTop (𝓝 (ENNReal.ofReal (u_lim.toFunction ω))) := by
      rw [ENNReal.tendsto_toReal_iff]; · exact hω; · exact ENNReal.ne_top_of_le_ne_top ENNReal.one_ne_top (ENNReal.inv_le_one.2 ENNReal.one_le_add_left); · simp
    have h_g_lim := this.inv.sub_const 1
    simp_rw [ENNReal.inv_inv, ENNReal.add_sub_cancel_right ENNReal.one_ne_top] at h_g_lim; exact h_g_lim

