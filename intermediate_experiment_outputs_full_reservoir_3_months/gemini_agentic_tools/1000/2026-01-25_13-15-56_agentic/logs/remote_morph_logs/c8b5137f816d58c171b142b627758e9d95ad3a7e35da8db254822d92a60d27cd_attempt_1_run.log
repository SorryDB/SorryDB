  have h_log k (hk : k < B) : Nat.log p k < B := by
    if hk0 : k = 0 then rw [hk0, Nat.log_zero_right]; omega
    else
      apply Nat.log_lt_of_lt_pow hk0
      calc k < B := hk
           _ < p ^ B := Nat.lt_pow_self hp.one_lt B
  rw [Nat.factorization_factorial hp (h_log m (by omega)),
      Nat.factorization_factorial hp (h_log n (by omega)),
      Nat.factorization_factorial hp (h_log (m + n) (by omega)),
      Nat.factorization_factorial hp (h_log (2 * m) (by omega)),
      Nat.factorization_factorial hp (h_log (2 * n) (by omega))]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  let d := p ^ i
  have hd : 0 < d := by positivity
  have h_div k : (2 * k) / d = 2 * (k / d) + (2 * (k % d)) / d := by
    conv_lhs => rw [← Nat.div_add_mod k d, mul_add, ← mul_assoc, add_comm]
    rw [Nat.add_mul_div_left _ _ hd, add_comm]
  have h_sum : (m + n) / d = m / d + n / d + (m % d + n % d) / d := by
    conv_lhs => rw [← Nat.div_add_mod m d, ← Nat.div_add_mod n d]
    have : (m / d * d + m % d) + (n / d * d + n % d) = (m / d + n / d) * d + (m % d + n % d) := by ring
    rw [this, add_comm, Nat.add_mul_div_left _ _ hd, add_comm]
  rw [h_div m, h_div n, h_sum]
  let rm := m % d; let rn := n % d
  have : (rm + rn) / d ≤ (2 * rm) / d + (2 * rn) / d := by
    by_cases h : rm + rn < d
    · have : (rm + rn) / d = 0 := by rw [Nat.div_eq_zero_iff hd]; omega
      rw [this]; exact Nat.zero_le _
    · have h_val : (rm + rn) / d = 1 := by
