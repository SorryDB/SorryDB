import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h_pos : 0 < m ! * n ! * (m + n)! := by positivity
  have h_pos' : 0 < (2 * m)! * (2 * n)! := by positivity
  rw [Nat.dvd_iff_factorization_le h_pos.ne' h_pos'.ne']
  intro p
  by_cases hp : p.Prime; swap
  · rw [Nat.factorization_eq_zero_of_not_prime _ hp]; exact zero_le _
  rw [Nat.factorization_mul (Nat.factorial_ne_zero m) (by positivity),
      Nat.factorization_mul (Nat.factorial_ne_zero n) (Nat.factorial_ne_zero (m + n)),
      Nat.factorization_mul (Nat.factorial_ne_zero (2 * m)) (Nat.factorial_ne_zero (2 * n))]
  simp only [Finsupp.coe_add, Pi.add_apply]
  iterate 5 rw [Nat.factorization_factorial hp]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  set d := p ^ i
  have hd : 0 < d := Nat.pos_pow_of_pos i hp.pos
  let rm := m % d
  let rn := n % d
  have hm : m = (m / d) * d + rm := Nat.div_add_mod m d
  have hn : n = (n / d) * d + rn := Nat.div_add_mod n d
  have hmn : m + n = (m / d + n / d) * d + (rm + rn) := by
    rw [hm, hn]; ring
  rw [Nat.add_mul_div_left _ _ hd, Nat.add_mul_div_left _ _ hd]
  rw [show 2 * m = (2 * (m / d)) * d + 2 * rm by rw [hm]; ring, Nat.add_mul_div_left _ _ hd]
  rw [show 2 * n = (2 * (n / d)) * d + 2 * rn by rw [hn]; ring, Nat.add_mul_div_left _ _ hd]
  rw [hmn, Nat.add_mul_div_left _ _ hd]
  simp only [Nat.div_eq_zero (Nat.mod_lt _ hd)]
  set qm := m / d; set qn := n / d
  suffices (rm + rn) / d ≤ (2 * rm) / d + (2 * rn) / d by linarith
  by_cases h : rm + rn < d
  · rw [Nat.div_eq_zero h]; exact zero_le _
  · rw [Nat.div_eq_one h (by linarith [Nat.mod_lt m hd, Nat.mod_lt n hd])]
    have : d ≤ 2 * rm ∨ d ≤ 2 * rn := by linarith
    rcases this with hl | hl
    · exact (Nat.one_le_div_iff hd).mpr hl |>.trans (by linarith)
    · exact (Nat.one_le_div_iff hd).mpr hl |>.trans (by linarith)

