import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  -- Use Legendre's formula to prove divisibility prime by prime.
  have h1 : m ! * n ! * (m + n)! ≠ 0 := by positivity
  have h2 : (2 * m)! * (2 * n)! ≠ 0 := by positivity
  rw [Nat.factorization_prime_le_iff_dvd h1 h2]
  intro p hp
  -- Expand factorization of products.
  rw [Nat.factorization_mul (by positivity) (by positivity),
      Nat.factorization_mul (by positivity) (by positivity),
      Nat.factorization_mul (by positivity) (by positivity)]
  simp only [Finsupp.add_apply]
  -- Use Legendre's formula for the valuation of factorials.
  let b := 2 * m + 2 * n + 1
  have hb : 0 < b := by omega
  have h_log k (hk : k < b) : Nat.log p k < b := by
    if hk0 : k = 0 then rw [hk0, Nat.log_zero_right]; exact hb
    else
      apply Nat.log_lt_of_lt_pow hk0
      calc k < b := hk
           _ < 2 ^ b := Nat.lt_pow_self (Nat.one_lt_succ 1) b
           _ ≤ p ^ b := Nat.pow_le_pow_left hp.two_le b
  rw [Nat.factorization_factorial hp (h_log m (by omega)),
      Nat.factorization_factorial hp (h_log n (by omega)),
      Nat.factorization_factorial hp (h_log (m + n) (by omega)),
      Nat.factorization_factorial hp (h_log (2 * m) (by omega)),
      Nat.factorization_factorial hp (h_log (2 * n) (by omega))]
  -- Compare terms of the sums over prime powers.
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  let d := p ^ i
  have hd : 0 < d := Nat.pow_pos hp.pos i
  -- Relate (2k)/d to k/d and (m+n)/d to m/d and n/d.
  have h_div k : (2 * k) / d = 2 * (k / d) + (2 * (k % d)) / d := by
