import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have ha : m ! * n ! * (m + n)! ≠ 0 := by positivity
  have hb : (2 * m)! * (2 * n)! ≠ 0 := by positivity
  rw [← Nat.factorization_prime_le_iff_dvd ha hb]
  intro p hp
  rw [Nat.factorization_mul (by positivity) (Nat.factorial_ne_zero (m + n)),
      Nat.factorization_mul (Nat.factorial_ne_zero m) (Nat.factorial_ne_zero n),
      Nat.factorization_mul (Nat.factorial_ne_zero (2 * m)) (Nat.factorial_ne_zero (2 * n))]
  simp only [Finsupp.add_apply]
  let b := 2 * m + 2 * n + 1
  have h_log (k : ℕ) (hk : k ≤ 2 * m + 2 * n) : Nat.log p k < b := by
    by_cases hk0 : k = 0
    · subst hk0; rewrite [Nat.log]; exact Nat.succ_pos _
    · apply Nat.log_lt_iff_lt_pow hp.one_lt hk0 |>.mpr
      calc k < p ^ k := Nat.lt_pow_self hp.one_lt k
           _ ≤ p ^ (2 * m + 2 * n) := Nat.pow_le_pow_of_le_right hp.one_lt hk
           _ < p ^ b := Nat.pow_lt_pow_right hp.one_lt (Nat.lt_succ_self _)
  rw [Nat.factorization_factorial hp (h_log m (by linarith)),
      Nat.factorization_factorial hp (h_log n (by linarith)),
      Nat.factorization_factorial hp (h_log (m + n) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * m) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * n) (by linarith))]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  set d := p ^ i
  have hd : 0 < d := Nat.pow_pos hp.pos i
  have h_div_m : 2 * m / d = 2 * (m / d) + 2 * (m % d) / d := by
    rw [show 2 * m = 2 * (m % d) + (2 * (m / d)) * d by rw [Nat.div_add_mod m d]; ring]
    rw [Nat.add_mul_div_left (2 * (m % d)) (2 * (m / d)) hd, add_comm]
  have h_div_n : 2 * n / d = 2 * (n / d) + 2 * (n % d) / d := by
    rw [show 2 * n = 2 * (n % d) + (2 * (n / d)) * d by rw [Nat.div_add_mod n d]; ring]
    rw [Nat.add_mul_div_left (2 * (n % d)) (2 * (n / d)) hd, add_comm]
  have h_div_mn : (m + n) / d = m / d + n / d + (m % d + n % d) / d := by
    rw [show m + n = (m % d + n % d) + (m / d + n / d) * d by rw [Nat.div_add_mod m d, Nat.div_add_mod n d]; ring]
    rw [Nat.add_mul_div_left (m % d + n % d) (m / d + n / d) hd, add_comm]
  rw [h_div_m, h_div_n, h_div_mn]
  let rm := m % d; let rn := n % d
