import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have ha : m ! * n ! * (m + n)! ≠ 0 :=
    Nat.mul_ne_zero (Nat.mul_ne_zero (Nat.factorial_ne_zero m) (Nat.factorial_ne_zero n)) (Nat.factorial_ne_zero (m + n))
  have hb : (2 * m)! * (2 * n)! ≠ 0 :=
    Nat.mul_ne_zero (Nat.factorial_ne_zero (2 * m)) (Nat.factorial_ne_zero (2 * n))
  rw [← Nat.factorization_prime_le_iff_dvd ha hb]
  intro p hp
  rw [Nat.factorization_mul (Nat.mul_ne_zero (Nat.factorial_ne_zero m) (Nat.factorial_ne_zero n)) (Nat.factorial_ne_zero (m + n)),
      Nat.factorization_mul (Nat.factorial_ne_zero m) (Nat.factorial_ne_zero n),
      Nat.factorization_mul (Nat.factorial_ne_zero (2 * m)) (Nat.factorial_ne_zero (2 * n))]
  simp only [Finsupp.add_apply]
  let b := 2 * m + 2 * n + 1
  have h_log k (hk : k ≤ 2 * m + 2 * n) : Nat.log p k < b := by
    if hk0 : k = 0 then
      rw [hk0]
      exact Nat.succ_pos _
    else
      apply Nat.log_lt_of_lt_pow hp.one_lt
      calc k < 2 * m + 2 * n + 1 := Nat.lt_succ_of_le hk
           _ ≤ p ^ (2 * m + 2 * n + 1) := (Nat.lt_pow_self hp.one_lt _).le
  rw [Nat.factorization_factorial hp (h_log m (by linarith)),
      Nat.factorization_factorial hp (h_log n (by linarith)),
      Nat.factorization_factorial hp (h_log (m + n) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * m) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * n) (by linarith))]
  simp only [← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  let d := p ^ i
  have hd : 0 < d := Nat.pow_pos hp.pos i
  have h_split k : (2 * k) / d = 2 * (k / d) + (2 * (k % d)) / d := by
    rw [← Nat.div_add_mod k d]
    have : 2 * (d * (k / d) + k % d) = (2 * (k / d)) * d + 2 * (k % d) := by ring
    rw [Nat.add_mul_div_left (2 * (k % d)) (2 * (k / d)) hd, Nat.add_comm]
  have h_sum : (m + n) / d = m / d + n / d + (m % d + n % d) / d := by
    rw [← Nat.div_add_mod m d, ← Nat.div_add_mod n d]
    have : (d * (m / d) + m % d) + (d * (n / d) + n % d) = (m / d + n / d) * d + (m % d + n % d) := by ring
    rw [Nat.add_mul_div_left (m % d + n % d) (m / d + n / d) hd, Nat.add_comm]
  rw [h_split m, h_split n, h_sum]
  let rm := m % d; let rn := n % d
  have : (rm + rn) / d ≤ (2 * rm) / d + (2 * rn) / d := by
    by_cases h : rm + rn < d
    · rw [Nat.div_eq_zero h]; exact Nat.zero_le _
    · have h1 : (rm + rn) / d = 1 := by
        apply Nat.div_eq_of_le_lt
        · exact not_lt.mp h
        · linarith [Nat.mod_lt m hd, Nat.mod_lt n hd]
      rw [h1]
      have : d ≤ 2 * rm ∨ d ≤ 2 * rn := by linarith [not_lt.mp h]
      rcases this with hl | hr
      · have : 1 ≤ (2 * rm) / d := (Nat.le_div_iff_mul_le hd).mpr (by linarith)
        linarith
      · have : 1 ≤ (2 * rn) / d := (Nat.le_div_iff_mul_le hd).mpr (by linarith)
        linarith
  linarith
