           _ ≤ p ^ b_val := Nat.pow_le_pow_of_le_left hp.two_le b_val
  repeat rw [Nat.factorization_factorial hp (h_log _ (by linarith))]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
