    rw [Nat.add_mul_div_left (m % d + n % d) (m / d + n / d) hd, add_comm]
  rw [hm, hn, hmn]
  let rm := m % d; let rn := n % d
  have : (rm + rn) / d ≤ 2 * rm / d + 2 * rn / d := by
    by_cases h : rm + rn < d
    · rw [Nat.div_eq_zero_of_lt h]; exact zero_le _
    · have h1 : (rm + rn) / d = 1 := by
