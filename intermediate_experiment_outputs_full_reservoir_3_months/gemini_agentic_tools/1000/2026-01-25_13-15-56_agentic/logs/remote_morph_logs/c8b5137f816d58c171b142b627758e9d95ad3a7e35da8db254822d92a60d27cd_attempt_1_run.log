import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have ha : m ! * n ! * (m + n)! ≠ 0 := by positivity
  have hb : (2 * m)! * (2 * n)! ≠ 0 := by positivity
  rw [← Nat.factorization_prime_le_iff_dvd ha hb]
  intro p hp
  rw [Nat.factorization_mul (by positivity) (by positivity),
      Nat.factorization_mul (by positivity) (by positivity),
      Nat.factorization_mul (by positivity) (by positivity)]
  simp only [Finsupp.add_apply]
  let b := 2 * m + 2 * n + 1
  have hb1 : 0 < b := by linarith
  have h_log k (hk : k < b) : Nat.log p k < b := by
    if hk0 : k = 0 then
      rw [hk0, Nat.log_zero p]
      exact hb1
    else
      apply Nat.log_lt_of_lt_pow hp.one_lt
      calc k < b := hk
           _ < 2 ^ b := Nat.lt_pow_self (by linarith) b
           _ ≤ p ^ b := Nat.pow_le_pow_left hp.two_le b
  rw [Nat.factorization_factorial hp (h_log m (by linarith)),
      Nat.factorization_factorial hp (h_log n (by linarith)),
      Nat.factorization_factorial hp (h_log (m + n) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * m) (by linarith)),
      Nat.factorization_factorial hp (h_log (2 * n) (by linarith))]
  simp only [← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  let d := p ^ i
  have hd : 0 < d := Nat.pow_pos hp.pos i
  have h_div k : (2 * k) / d = 2 * (k / d) + (2 * (k % d)) / d := by
    rw [← Nat.div_add_mod k d, mul_add, ← mul_assoc, Nat.mul_add_div_left _ _ hd, add_comm]
  have h_sum : (m + n) / d = m / d + n / d + (m % d + n % d) / d := by
    rw [← Nat.div_add_mod m d, ← Nat.div_add_mod n d]
    have h : (m / d * d + m % d) + (n / d * d + n % d) = (m / d + n / d) * d + (m % d + n % d) := by ring
    rw [h, Nat.mul_add_div_left _ _ hd, add_comm]
  rw [h_div m, h_div n, h_sum]
  let rm := m % d; let rn := n % d
  have : (rm + rn) / d ≤ (2 * rm) / d + (2 * rn) / d := by
    by_cases h : rm + rn < d
    · rw [Nat.div_eq_zero_of_lt h]; exact Nat.zero_le _
    · have h1 : (rm + rn) / d = 1 := by
        apply Nat.le_antisymm
        · apply Nat.le_of_lt_succ
          rw [Nat.div_lt_iff_lt_mul hd]
          linarith [Nat.mod_lt m hd, Nat.mod_lt n hd]
        · rw [Nat.le_div_iff_mul_le hd]
          exact not_lt.mp h
      rw [h1]
      have : d ≤ 2 * rm ∨ d ≤ 2 * rn := by linarith [not_lt.mp h]
      rcases this with hl | hr
      · have : 1 ≤ (2 * rm) / d := (Nat.le_div_iff_mul_le hd).mpr hl
        linarith
      · have : 1 ≤ (2 * rn) / d := (Nat.le_div_iff_mul_le hd).mpr hr
        linarith
  linarith

