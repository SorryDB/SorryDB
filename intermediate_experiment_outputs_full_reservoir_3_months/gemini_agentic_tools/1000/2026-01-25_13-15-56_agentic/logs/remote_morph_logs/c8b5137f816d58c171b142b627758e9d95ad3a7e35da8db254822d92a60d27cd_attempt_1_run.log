      Nat.factorization_mul (Nat.factorial_ne_zero (2 * m)) (Nat.factorial_ne_zero (2 * n))]
  simp only [Finsupp.add_apply]
  let b := 2 * m + 2 * n + 1
  have h_log (k : ℕ) (hk : k ≤ 2 * m + 2 * n) : Nat.log p k < b := by
    if hk0 : k = 0 then rw [hk0, Nat.log_zero]; exact Nat.succ_pos _
    else
