import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_factorization_le (by positivity) (by positivity)
  intro p
  by_cases hp : p.Prime; swap
  · simp [Nat.factorization_eq_zero_of_not_prime _ hp]
  repeat rw [Nat.factorization_mul (by positivity) (by positivity)]
  simp only [Finsupp.coe_add, Pi.add_apply]
  let b := 2 * m + 2 * n + 2
  have h_log k (hk : k ≤ 2 * m + 2 * n) : Nat.log p k < b := by
    apply Nat.log_lt_of_lt_pow hp.one_lt
    calc k ≤ 2 * m + 2 * n := hk
         _ < 2 ^ b := Nat.lt_two_pow b
         _ ≤ p ^ b := Nat.pow_le_pow_of_le_left hp.two_le b
  rw [Nat.factorization_factorial hp (h_log _ (by linarith)),
      Nat.factorization_factorial hp (h_log _ (by linarith)),
      Nat.factorization_factorial hp (h_log _ (by linarith)),
      Nat.factorization_factorial hp (h_log _ (by linarith)),
      Nat.factorization_factorial hp (h_log _ (by linarith))]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i hi
  have hk : 0 < p ^ i := Nat.pos_pow_of_pos i hp.pos
  let rn := m % p ^ i; let rm := n % p ^ i
  have : m = m / p ^ i * p ^ i + rn := (Nat.div_add_mod m _).symm
  have : n = n / p ^ i * p ^ i + rm := (Nat.div_add_mod n _).symm
  rw [this, ‹n = n / p ^ i * p ^ i + rm›]
  rw [show 2 * (m / p ^ i * p ^ i + rn) = (m / p ^ i * 2) * p ^ i + 2 * rn by ring]
  rw [show 2 * (n / p ^ i * p ^ i + rm) = (n / p ^ i * 2) * p ^ i + 2 * rm by ring]
  rw [show (m / p ^ i * p ^ i + rn) + (n / p ^ i * p ^ i + rm) = (m / p ^ i + n / p ^ i) * p ^ i + (rn + rm) by ring]
  repeat rw [Nat.add_mul_div_left _ _ hk]
  repeat rw [Nat.div_eq_zero (Nat.mod_lt _ hk)]
  by_cases h : rn + rm < p ^ i
  · rw [Nat.div_eq_zero h]; linarith
  · rw [Nat.div_eq_one h (by linarith [Nat.mod_lt m hk, Nat.mod_lt n hk])]
    have : p ^ i ≤ 2 * rn ∨ p ^ i ≤ 2 * rm := by linarith
    rcases this with hl | hl
    · exact (Nat.one_le_div_iff hk).mpr hl |>.trans (by linarith)
    · exact (Nat.one_le_div_iff hk).mpr hl |>.trans (by linarith)

