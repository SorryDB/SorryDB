    E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = constD 1 m := by
  rw [GaussLaw, chargeDistribution]
  have h : (1 / ε) • (0 : ChargeDistribution 1) = 0 := by
    ext φ
    simp
  rw [h]
  exact div_eq_zero_iff
