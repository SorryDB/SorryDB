      have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
      linarith [x.val_lt]
    have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by norm_num) hp_dvd
    have : N ^ 2 + 1 < p := by linarith [hp_gtM]
    have : N ^ 2 < n ^ 2 := by linarith
    exact (Nat.pow_lt_pow_iff_left (by norm_num : 0 < 2)).mp this |>.le
