[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 1) 14
  obtain ⟨p, hp_mem, hp_gtM⟩ := (Nat.infinite_setOf_prime_modEq_one 4 (by norm_num)).exists_gt M
  have hp_prime : p.Prime := hp_mem.1
  have hp_mod4 : p % 4 = 1 := hp_mem.2
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp_mod4]; norm_num)
  obtain ⟨x, hx⟩ := this
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs
    · push_cast; rw [ZMod.natCast_zmod_val, hx]
    · push_cast; rw [ZMod.natCast_zmod_val]; ring; rw [hx]; simp
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    have : ((n ^ 2 + 1 : ℕ) : ZMod p) = 0 := by push_cast; rw [hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  have h_2n_lt_p : 2 * n < p := by
    have h_p_odd : p % 2 = 1 := hp_prime.mod_two_eq_one_iff_odd.mpr (by linarith [hp_gtM])
    have h_n_le_half : n ≤ p / 2 := by dsimp [n]; split_ifs <;> linarith [x.val_lt]
    have h_p_val := Nat.div_add_mod p 2
    rw [h_p_odd] at h_p_val
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (n ^ 2 + 1).succ_pos hp_dvd
    have : n ^ 2 ≥ p - 1 := Nat.le_sub_of_add_le h_n2_p
    have : n ^ 2 ≥ N ^ 2 := by linarith [hp_gtM]
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) this
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    have : (k : ZMod p) = - (2 * n : ZMod p) := by
      rw [ZMod.natCast_zmod_val]; dsimp [k]; push_cast; rw [Nat.sub_eq_of_le (by linarith)]; ring
    have : (k : ZMod p) ^ 2 + 4 = 4 * ((n : ZMod p) ^ 2 + 1) := by rw [this]; ring
    have : ((k ^ 2 + 4 : ℕ) : ZMod p) = 0 := by push_cast; rw [this, hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = k ^ 2 + 4 := by
    rw [← Nat.cast_mul, Nat.mul_div_cancel' hp_dvd_k, Nat.cast_add, Nat.cast_pow]; rfl
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [Nat.mul_div_cancel' hp_dvd_k]
    rw [Nat.mul_mod, hp_mod4] at this; simp at this
    have h_k_odd : k % 2 = 1 := by
      rw [k, Nat.sub_mod (by linarith), Nat.mul_mod_right]
      exact hp_prime.mod_two_eq_one_iff_odd.mpr (by linarith [hp_gtM])
    revert h_k_odd this; generalize k % 4 = r; intros; interval_cases r <;> norm_num at *
  have h_k2_gt_2n : (k : ℤ) ^ 2 > 2 * n := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub (by linarith)]; ring
    have : (k : ℤ) ^ 2 - 2 * n = 2 * (m - 1) * n + m * k - 4 := by rw [← hm_val, hp_eq]; ring
    rw [this]
    have hm1 : m = 1 ∨ m ≥ 5 := by
      have : m % 4 = 1 := hm_mod4
      have : m > 0 := Nat.pos_of_mul_pos_right (by linarith [hp_dvd_k, k]) hp_prime.pos
      interval_cases h : m % 4
      · linarith
      · rcases (Nat.le_or_gt 5 m) with h' | h' <;> [right; left] <;> (try exact h'); interval_cases m <;> linarith
      · linarith
      · linarith
    rcases hm1 with rfl | hm5
    · simp; have : (k : ℤ)^2 = (p : ℤ) - 4 := by rw [← hm_val, hp_eq]; ring
      have : (k : ℤ)^2 > 10 := by linarith [hp_gtM]
      have h_k_odd : (k : ℤ) % 2 = 1 := by
        rw [← Nat.cast_mod]
        have : k % 2 = 1 := by
          rw [k, Nat.sub_mod (by linarith), Nat.mul_mod_right]
          exact hp_prime.mod_two_eq_one_iff_odd.mpr (by linarith [hp_gtM])
        rw [this]; rfl
      nlinarith
    · have : (n : ℤ) ≥ 1 := by linarith [hn_ge_N]
      have : (k : ℤ) ≥ 1 := by linarith
      linarith
  rw [Real.gt_iff_lt, ← Real.lt_sub_iff_add_lt', Real.sqrt_lt_iff]
  · constructor; exact_mod_cast (Nat.zero_le (2 * n))
    have : (p : ℝ) - 2 * n = (k : ℝ) := by rw [← Nat.cast_sub (by linarith)]; rfl
    rw [this]; exact_mod_cast h_k2_gt_2n
  · linarith
