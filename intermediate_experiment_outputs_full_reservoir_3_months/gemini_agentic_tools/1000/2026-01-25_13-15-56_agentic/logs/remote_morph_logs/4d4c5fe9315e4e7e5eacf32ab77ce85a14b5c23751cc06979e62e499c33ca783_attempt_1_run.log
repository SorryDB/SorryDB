import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p : ℕ | Nat.Prime p ∧ p ≡ 1 [MOD 4] ∧ p > 13}
  have hS : S.Infinite := by
    apply Set.Infinite.mono (fun p hp => hp.2.2)
    exact Nat.Infinite_setOf_prime_mod_four_eq_one.minus_finite {p | Nat.Prime p ∧ p ≡ 1 [MOD 4] ∧ p ≤ 13}
  by_contra h
  push_neg at h
  let n_set := {n | n ≥ N ∧ ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n)}
  have h_n_finite : n_set.Finite := by
    specialize h N
    have h_empty : n_set = ∅ := by
      ext n
      simp only [n_set, Set.mem_setOf_eq, Set.mem_empty_iff_false, iff_false, not_and, not_exists, not_le]
      intro hn_ge
      exact h n hn_ge
    rw [h_empty]
    exact Set.finite_empty
  let all_primes := {p | Nat.Prime p ∧ ∃ n ∈ n_set, p ∣ n ^ 2 + 1}
  have h_primes_finite : all_primes.Finite := by
    apply Set.Finite.biUnion h_n_finite
    intro n _
    exact Nat.finite_factors (n ^ 2 + 1).ne_zero
  have : ∃ p ∈ S, p ∉ all_primes := hS.exists_not_mem h_primes_finite
  rcases this with ⟨p, ⟨hp_prime, hp_mod, hp_gt13⟩, hp_not_in⟩
  obtain ⟨n0, hn0_sq, hn0_lt⟩ := Nat.sq_mod_inv_exists_diff_sq hp_prime hp_mod
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_prime_div : p ∣ n ^ 2 + 1 := by
    rcases hn0_sq with ⟨x, hx⟩
    have : n ^ 2 ≡ n0 ^ 2 [MOD p] := by
      dsimp [n]
      split_ifs
      · rfl
      · exact Nat.ModEq.sq (Nat.modEq_sub hp_prime.pos)
    rw [Nat.modEq_iff_dvd' (by positivity)] at this
    have : p ∣ n0 ^ 2 + 1 := by rw [hx]; exact Nat.dvd_refl _
    exact (Nat.dvd_add_right this).mp (by exact this)
  have hn_lt : n < p / 2 := by
    dsimp [n]
    split_ifs with h_if
    · exact Nat.lt_of_le_of_ne h_if (fun heq => by
        have : p ∣ (p/2)^2 + 1 := heq ▸ hn_prime_div
        have : p ≤ (p/2)^2 + 1 := Nat.le_of_dvd (by positivity) this
        linarith [hp_gt13])
    · have : p - n0 < p - p / 2 := Nat.sub_lt_sub_left (Nat.Prime.pos hp_prime) (lt_of_not_ge h_if)
      apply lt_of_lt_of_le this
      exact Nat.sub_le_self p (p / 2)
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := by
    have : 2 * n < p := by linarith [hn_lt, Nat.div_le_self p 2]
    exact Nat.sub_positive_of_lt this
  have hk_odd : k % 2 = 1 := by
    rw [Nat.sub_mod (by linarith), Nat.mul_mod_right]
    exact hp_prime.mod_two_eq_one_iff_odd.mpr (hp_gt13.trans_le' (by norm_num))
  have hp_div_k : p ∣ k ^ 2 + 4 := by
    have : k ^ 2 + 4 = (p - 2 * n) ^ 2 + 4 := rfl
    have : (p - 2 * n) ^ 2 + 4 = p ^ 2 - 4 * p * n + 4 * n ^ 2 + 4 := by
      rw [Nat.sub_sq (by linarith)]; ring
    rw [this]
    apply Nat.dvd_add
    · apply Nat.dvd_sub (by narith)
      · apply Nat.dvd_pow (Nat.dvd_refl p) (by norm_num)
      · apply Nat.dvd_mul_right
    · apply (Nat.dvd_mul_left p 4).mpr
      have : p ∣ n ^ 2 + 1 := hn_prime_div
      exact (Nat.dvd_mul_left p 4).mp (by simpa [mul_add] using Nat.mul_dvd_mul_left 4 this)
  let m := (k ^ 2 + 4) / p
  have hm_odd : m % 2 = 1 := by
    have : k ^ 2 + 4 = m * p := (Nat.div_eq_iff_mul_dvd hp_div_k).mp rfl
    have : (k ^ 2 + 4) % 2 = (m * p) % 2 := by rw [this]
    simpa [Nat.add_mod, Nat.pow_mod, hk_odd, hp_prime.mod_two_eq_one_iff_odd.mpr (hp_gt13.trans_le' (by norm_num))] using this
  have hk_sq_gt : k ^ 2 > p - k := by
    have : (m - 1) * k ^ 2 + m * k - 4 > 0 := by
      rcases hm_odd.exists_two_ns_plus_one with ⟨s, hs⟩
      cases s
      · simpa [hs] using (hk_pos.trans_le' (by linarith)).ne.symm
        linarith [hk_pos, hp_gt13]
      · linarith [hk_pos]
    have : m * k ^ 2 + m * k > k ^ 2 + 4 := by linarith
    have : k ^ 2 + k > (k ^ 2 + 4 : ℝ) / m := by rw [gt_iff_lt, div_lt_iff (by rcases hm_odd.exists_two_ns_plus_one with ⟨s, hs⟩; linarith)]; assumption
    have : (k : ℝ) ^ 2 + k > p := by rw [← (Nat.div_eq_iff_mul_dvd hp_div_k).mp rfl] at this; exact this
    linarith
  have h_p_val : (p : ℝ) > 2 * n + √(2 * n) := by
    have : (k : ℝ) > √(p - k) := by rw [Real.sqrt_lt_iff (by linarith [hk_pos])]; exact_mod_cast hk_sq_gt
    have : (p : ℝ) - 2 * n > √((p : ℝ) - (p - 2 * n)) := by exact_mod_cast this
    linarith [Real.sqrt_le_sqrt (by norm_num : (2 : ℝ) ≤ 2)]
  have hn_ge_N : n < N := by
    by_contra h_ge
    push_neg at h_ge
    exact hp_not_in ⟨hp_prime, ⟨n, ⟨h_ge, ⟨p, hp_prime, hn_prime_div, h_p_val⟩⟩, hn_prime_div⟩⟩
  have : ∃ (p_large : ℕ), p_large ∈ S ∧ ∀ n < N, ¬ p_large ∣ n ^ 2 + 1 := by
    let finite_primes := Set.biUnion (Set.Iio N) (fun n _ => Nat.primeFactors (n ^ 2 + 1))
    have h_fin : finite_primes.Finite := Set.Finite.biUnion (Set.finite_Iio N) (fun n _ => Nat.finite_factors (by linarith))
    exact hS.exists_not_mem h_fin
  rcases this with ⟨p_final, hp_final_S, hp_final_not_dvd⟩
  exact hp_final_not_dvd n hn_ge_N hn_prime_div
```
