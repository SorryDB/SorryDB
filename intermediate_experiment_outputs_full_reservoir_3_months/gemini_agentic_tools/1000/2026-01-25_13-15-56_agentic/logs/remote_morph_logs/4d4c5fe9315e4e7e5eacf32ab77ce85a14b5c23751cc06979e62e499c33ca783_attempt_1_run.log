import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 1) 14
  obtain ⟨p, hp_prime, hp_gtM, hp_mod4⟩ := Nat.exists_prime_gt_modEq_one M (by norm_num)
  have hp_mod4_real : p % 4 = 1 := hp_mod4
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have h_sq : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by linarith [hp_mod4_real])
  obtain ⟨x, hx⟩ := h_sq
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs
    · push_cast; rw [ZMod.natCast_zmod_val, hx]
    · push_cast; rw [ZMod.natCast_zmod_val, hx]; ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    have : ((n ^ 2 + 1 : ℕ) : ZMod p) = 0 := by push_cast; rw [hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  have h_2n_lt_p : 2 * n < p := by
    have h_p_odd : p % 2 = 1 := by
      rw [← Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4), hp_mod4_real]
      norm_num
    have h_n_le_half : n ≤ p / 2 := by dsimp [n]; split_ifs <;> linarith [x.val_lt]
    have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (n ^ 2 + 1).succ_pos hp_dvd
    have : n ^ 2 + 1 > N ^ 2 + 1 := by linarith [hp_gtM]
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) (by linarith)
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := Nat.sub_pos_of_lt h_2n_lt_p
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    have : (k : ZMod p) = - 2 * (n : ZMod p) := by
      rw [Nat.cast_sub h_2n_lt_p.le]; push_cast; simp [k]
    have : ((k ^ 2 + 4 : ℕ) : ZMod p) = 0 := by
      push_cast; rw [this]; ring; rw [hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = (k : ℤ) ^ 2 + 4 := by
    rw [← Nat.cast_mul, Nat.mul_div_cancel' hp_dvd_k, Nat.cast_add, Nat.cast_pow]; rfl
  have h_k_odd : k % 2 = 1 := by
    have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel h_2n_lt_p.le]
    rw [this, ← Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4), hp_mod4_real]
    norm_num
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [Nat.mul_div_cancel' hp_dvd_k]
    rw [Nat.mul_mod, hp_mod4_real] at this; simp at this
    revert h_k_odd this; generalize k % 4 = r; intros; interval_cases r <;> norm_num at *
  have h_k2_gt_2n : (k : ℤ) ^ 2 > 2 * n := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub h_2n_lt_p.le]; ring
    have hm1 : m = 1 ∨ m ≥ 5 := by
      have : m % 4 = 1 := hm_mod4
      have : m > 0 := Nat.pos_of_mul_pos_right (by linarith [hp_dvd_k, k]) hp_prime.pos
      rcases (Nat.le_or_gt 5 m) with h' | h' <;> [right; left] <;> (try exact h'); interval_cases m <;> (try linarith); rfl
    rcases hm1 with rfl | hm5
    · simp; have : (k : ℤ)^2 = (p : ℤ) - 4 := by rw [← hm_val]; simp; ring
      have : (k : ℤ)^2 > 10 := by linarith [hp_gtM]
      have : (k : ℤ) ≥ 5 := by
        have : k * k > 10 := by exact_mod_cast (by linarith : (k : ℤ)^2 > 10)
        revert this h_k_odd; rcases k with _|_|_|_|_|k <;> norm_num
      linarith
    · have : (k : ℤ) ^ 2 - 2 * n = 2 * (m - 1) * n + m * k - 4 := by rw [← hm_val, hp_eq]; ring
      have : (n : ℤ) ≥ 1 := by linarith [hn_ge_N]
      have : (k : ℤ) ≥ 1 := by linarith [hk_pos]
      have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
      linarith
  rw [Real.gt_iff_lt, ← Real.lt_sub_iff_add_lt', Real.sqrt_lt' (by exact_mod_cast hk_pos)]
  constructor
  · have : (p : ℝ) - 2 * n = (k : ℝ) := by rw [← Nat.cast_sub h_2n_lt_p.le]; rfl
    rw [this]; exact_mod_cast h_k2_gt_2n
  · linarith
