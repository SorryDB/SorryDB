  obtain ⟨x, hx⟩ := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp_mod4_val]; norm_num)
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_p_odd : p % 2 = 1 := by
    have : p % 2 = (p % 4) % 2 := (Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4)).symm
    rw [this, hp_mod4_val]; norm_num
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs with h
    · push_cast; rw [ZMod.natCast_val, hx]
    · push_cast; rw [Nat.cast_sub x.val_lt.le, ZMod.natCast_val, hx]; ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.natCast_eq_zero_iff p]
    push_cast; rw [hn_sq_mod_p]; simp
  have h_2n_lt_p : 2 * n < p := by
    have h_n_le_half : n ≤ p / 2 := by
      dsimp [n]; split_ifs with h
      · exact h
      · have : p = 2 * (p / 2) + 1 := Nat.div_add_mod p 2 |>.trans (by rw [h_p_odd]; rfl)
        linarith [x.val_lt]
    have : p = 2 * (p / 2) + 1 := Nat.div_add_mod p 2 |>.trans (by rw [h_p_odd]; rfl)
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by norm_num) hp_dvd
    have : N ^ 2 + 1 < p := by linarith [hp_gtM]
    have : N ^ 2 < n ^ 2 := by linarith
    exact (Nat.pow_lt_pow_iff_left (show 0 < 2 by norm_num)).mp this |>.le
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := by linarith
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    rw [← ZMod.natCast_eq_zero_iff p]
    have : (k : ZMod p) = - 2 * (n : ZMod p) := by
      rw [Nat.cast_sub h_2n_lt_p.le]; push_cast; simp [k]
    push_cast; rw [this]; ring_nf; rw [hn_sq_mod_p]; simp
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * (p : ℤ) = (k : ℤ) ^ 2 + 4 := by
    have : m * p = k ^ 2 + 4 := Nat.mul_div_cancel' hp_dvd_k
    exact_mod_cast this
  have h_k_odd : k % 2 = 1 := by
    have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel h_2n_lt_p.le]
    rw [this, h_p_odd]
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by
