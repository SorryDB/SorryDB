Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 1) 14
  have h_inf := Nat.Infinite_setOf_prime_modEq_one 4 (by norm_num)
  obtain ⟨p, hp_mem, hp_gtM⟩ := h_inf.exists_gt M
  have hp_prime : p.Prime := hp_mem.1
  have hp_mod4 : p % 4 = 1 := hp_mem.2
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have h_sq : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by
    rw [hp_mod4]; norm_num)
  obtain ⟨x, hx⟩ := h_sq
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_p_odd : p % 2 = 1 := by
    rw [← Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4), hp_mod4]
    norm_num
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs with h
    · push_cast; rw [ZMod.natCast_val, hx]
    · push_cast; rw [Nat.cast_sub (by linarith [x.val_lt]), ZMod.natCast_val, hx]
      ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.natCast_zmod_eq_zero_iff_dvd]
    push_cast; rw [hn_sq_mod_p]; simp
  have h_2n_lt_p : 2 * n < p := by
    have h_n_le_half : n ≤ p / 2 := by
      dsimp [n]; split_ifs with h
      · exact h
      · have : x.val < p := x.val_lt
        have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
        linarith
    have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by nlinarith) hp_dvd
    have : N ^ 2 + 1 < p := by linarith [hp_gtM]
    have : N < n := (Nat.pow_lt_pow_iff_left (by norm_num : 0 < 2)).mp (by linarith)
    exact this.le
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := by
    have : 2 * n ≤ p - 1 := by
      have h_n_le_half : n ≤ p / 2 := by dsimp [n]; split_ifs <;> linarith [x.val_lt]
      have : 2 * (p / 2) = p - 1 := by rw [← Nat.div_add_mod p 2, h_p_odd]; simp
      linarith
    linarith
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    have : (k : ZMod p) = - 2 * (n : ZMod p) := by
      rw [Nat.cast_sub (by linarith [h_2n_lt_p])]; push_cast; simp [k]
    rw [← ZMod.natCast_zmod_eq_zero_iff_dvd]
    push_cast; rw [this]; ring_nf; rw [hn_sq_mod_p]; simp
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = (k : ℤ) ^ 2 + 4 := by
    rw [← Nat.cast_mul, Nat.mul_div_cancel' hp_dvd_k]; push_cast; rfl
  have h_k_odd : k % 2 = 1 := by
    have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel (by linarith [h_2n_lt_p])]
    rw [this, h_p_odd]
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [Nat.mul_div_cancel' hp_dvd_k]
    rw [Nat.mul_mod, hp_mod4] at this; simp at this
    revert h_k_odd this; generalize k % 4 = r; intros; interval_cases r <;> norm_num at *
  have h_k2_gt_2n : (k : ℤ) ^ 2 > 2 * n := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub (by linarith)]; ring
    have hm1 : m = 1 ∨ m ≥ 5 := by
      have : m % 4 = 1 := hm_mod4
      have : m > 0 := Nat.pos_of_mul_pos_left (by linarith [hp_dvd_k, hk_pos])
      rcases (le_or_gt 5 m) with h' | h'
      · right; exact h'
      · left; interval_cases m <;> (try linarith); rfl
    rcases hm1 with rfl | hm5
    · simp at hm_val; have : (k : ℤ)^2 = (p : ℤ) - 4 := by linarith
      have : (k : ℤ)^2 > 10 := by linarith [hp_gtM]
      have : (k : ℤ) ≥ 5 := by
        have : k * k > 10 := by exact_mod_cast (by linarith : (k : ℤ)^2 > 10)
        revert this h_k_odd; rcases k with _|_|_|_|_|k <;> norm_num
      linarith
    · have : (k : ℤ) ^ 2 - 2 * n = 2 * (m - 1) * n + m * k - 4 := by rw [← hm_val, hp_eq]; ring
      have : (n : ℤ) ≥ 1 := by linarith [hn_ge_N]
      have : (k : ℤ) ≥ 1 := by linarith [hk_pos]
      have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
      linarith
  rw [gt_iff_lt, ← Real.lt_sub_iff_add_lt', Real.sqrt_lt_iff]
  constructor
  · exact_mod_cast (Nat.zero_le (2 * n))
  · constructor
    · have : (p : ℝ) - 2 * n = (k : ℝ) := by rw [← Nat.cast_sub (by linarith)]; rfl
      rw [this]; exact_mod_cast (by linarith [hk_pos] : 0 < k)
    · have : (p : ℝ) - 2 * n = (k : ℝ) := by rw [← Nat.cast_sub (by linarith)]; rfl
      rw [this, ← Real.cast_pow, ← Real.cast_mul]; exact_mod_cast h_k2_gt_2n
