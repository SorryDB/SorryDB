        have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
        have : (k : ℤ) ≥ 1 := by exact_mod_cast hk_pos
        nlinarith
      have : (m : ℤ) > 0 := by exact_mod_cast hm_pos
      nlinarith
  have h_p_real : (p : ℝ) > 2 * n + √(2 * n) := by
    rw [add_comm, ← Real.lt_sub_iff_add_lt]
    have : (p : ℝ) - 2 * n = (k : ℝ) := by
      rw [← Nat.cast_sub h_2n_lt_p.le, Nat.cast_mul, Nat.cast_of_nat]
    rw [this]
    apply (Real.sqrt_lt (by push_cast; linarith) (by push_cast; linarith)).mpr
