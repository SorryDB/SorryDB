import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max 14 (N ^ 2 + 1)
  obtain ⟨p, ⟨hp_prime, hp_mod4⟩, hp_gtM⟩ :=
    (Nat.infinite_setOf_prime_modEq_one 4 (by norm_num)).exists_gt M
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have hp4 : p % 4 = 1 := hp_mod4
  have : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp4]; norm_num)
  obtain ⟨x, hx⟩ := this
  let n_val := x.val
  let n := if n_val ≤ p / 2 then n_val else p - n_val
  have hn_sq : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs
    · push_cast; rw [ZMod.natCast_zmod_val, hx]
    · push_cast; rw [ZMod.natCast_zmod_val]; ring; rw [hx]; simp
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    have : ((n ^ 2 + 1 : ℕ) : ZMod p) = 0 := by push_cast; rw [hn_sq]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  have hn_lt_half : n < p / 2 := by
    dsimp [n]; split_ifs with h
    · refine lt_of_le_of_ne h ?_
      intro h_eq
      have : p = 2 * n_val := by
        rw [h_eq, Nat.mul_div_cancel' (Nat.even_iff.mpr (by rw [← h_eq]; apply Nat.even_mul_self.mpr; exact Nat.even_two))]
      have : p % 2 = 0 := by rw [this]; exact Nat.mul_mod_right 2 n_val
      have : p % 2 = 1 := (hp_prime.eq_two_or_odd.resolve_left (by linarith)).mod_two_eq_one
      linarith
    · have : n_val < p := x.val_lt
      have : p - n_val < p - p / 2 := Nat.sub_lt_sub_left this (Nat.lt_of_not_ge h)
      apply lt_of_lt_of_le this
      exact Nat.sub_le_self p (p / 2)
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (n ^ 2 + 1).succ_pos hp_dvd
    have : n ^ 2 ≥ p - 1 := Nat.le_sub_of_add_le this
    have : n ^ 2 ≥ N ^ 2 := by linarith [hp_gtM]
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) this
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hp_odd : p % 2 = 1 := (hp_prime.eq_two_or_odd.resolve_left (by linarith)).mod_two_eq_one
  have hk_pos : k ≥ 1 := by
    have : 2 * n < p := by
      calc 2 * n ≤ 2 * (p / 2) := Nat.mul_le_mul_left 2 hn_lt_half.le
        _ = p - 1 := Nat.mul_div_cancel' (Nat.even_iff.mpr (by rw [hp_odd]; norm_num))
        _ < p := Nat.sub_lt hp_prime.pos (by norm_num)
    exact Nat.sub_positive_of_lt this
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = k ^ 2 + 4 := by
    have hp_dvd_k : p ∣ k ^ 2 + 4 := by
      have : ((k ^ 2 + 4 : ℕ) : ZMod p) = 0 := by
        push_cast; have : (k : ZMod p) = (p : ZMod p) - (2 * n : ZMod p) := by push_cast; rfl
        rw [this]; simp; ring; rw [hn_sq]; simp
      exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
    have : m * p = k ^ 2 + 4 := Nat.mul_div_cancel' hp_dvd_k
    exact_mod_cast this
  have h_k_sq_gt_2n : (k : ℤ) ^ 2 > (2 * n : ℤ) := by
    have hm_pos : (m : ℤ) > 0 := by
      have : m * p > 0 := by linarith [hk_pos]
      exact_mod_cast Nat.pos_of_mul_pos_right this hp_prime.pos
    apply pos_of_mul_pos_left (a := (m : ℤ)) (by linarith)
    have : (m : ℤ) * ((k : ℤ) ^ 2 - 2 * n) = ((m : ℤ) - 1) * k ^ 2 + m * k - 4 := by
      rw [sub_mul, one_mul, hm_val]; simp [k]; ring
    rw [this]
    have : m % 4 = 1 ∨ m % 4 = 0 := by
      have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [← hm_val]; push_cast; rfl
      rw [Nat.mul_mod, hp4] at this; simp at this
      have : k % 4 = 0 ∨ k % 4 = 1 ∨ k % 4 = 2 ∨ k % 4 = 3 := by linarith [Nat.mod_lt k (by norm_num)]
      rcases this with h|h|h|h <;> { rw [Nat.pow_mod, h] at this; norm_num at this; (try left; assumption); (try right; assumption) }
    rcases this with hm1 | hm0
    · rcases (Nat.le_or_gt 5 m) with hm5 | hm1_4
      · calc ((m : ℤ) - 1) * k ^ 2 + m * k - 4 ≥ 4 * 1 ^ 2 + 5 * 1 - 4 := by
          apply add_le_add; apply mul_le_mul; linarith; exact_mod_cast (Nat.one_le_pow 2 k hk_pos); linarith; linarith
          linarith [hk_pos]
        _ > 0 := by norm_num
      · have : m = 1 := by
          have : m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 := by linarith [Nat.pos_of_mod_eq_one hm1]
          rcases this with rfl|rfl|rfl|rfl; rfl
          rw [Nat.mod_eq_of_lt (by norm_num)] at hm1; norm_num at hm1
          rw [Nat.mod_eq_of_lt (by norm_num)] at hm1; norm_num at hm1
          rw [Nat.mod_eq_of_lt (by norm_num)] at hm1; norm_num at hm1
        rw [this]; simp; rw [← hm_val, this, one_mul] at hp_gtM
        have : (k : ℤ) ^ 2 > 10 := by linarith
        have : (k : ℤ) > 3 := by
          have : k * k > 10 := by exact_mod_cast this
          revert this; rcases k with _|_|_|_|k <;> norm_num
        linarith
    · have : m ≥ 4 := Nat.pos_of_mod_eq_zero hm0
      calc ((m : ℤ) - 1) * k ^ 2 + m * k - 4 ≥ 3 * 1 ^ 2 + 4 * 1 - 4 := by
        apply add_le_add; apply mul_le_mul; linarith; exact_mod_cast (Nat.one_le_pow 2 k hk_pos); linarith; linarith
        linarith [hk_pos]
      _ > 0 := by norm_num
  rw [Real.gt_iff_lt, ← Real.lt_sub_iff_add_lt', Real.sqrt_lt_iff]
  · constructor; exact_mod_cast (Nat.zero_le (2 * n))
    have : (p : ℝ) - 2 * n = (k : ℝ) := by push_cast; rfl
    rw [this]; exact_mod_cast h_k_sq_gt_2n
  · linarith [hk_pos]

