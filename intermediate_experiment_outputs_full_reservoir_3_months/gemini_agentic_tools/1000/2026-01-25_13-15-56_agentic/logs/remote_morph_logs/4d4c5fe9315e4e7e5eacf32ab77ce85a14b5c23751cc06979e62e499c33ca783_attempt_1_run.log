import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 30) 100
  obtain ⟨p, hp_prime, hMp, hp_mod4⟩ := Nat.exists_prime_gt_modEq_one 4 M
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have hp_mod4_val : p % 4 = 1 := by
    unfold Nat.ModEq at hp_mod4
    exact hp_mod4
  obtain ⟨x_zmod, hx_zmod⟩ := ZMod.exists_sq_eq_neg_one_iff (p := p).mpr (Or.inr hp_mod4_val)
  let x := x_zmod.val
  let n := if x ≤ p / 2 then x else p - x
  have h_p_odd : p % 2 = 1 := by
    have := (Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4)).symm
    rwa [hp_mod4_val] at this
  have x_lt_p : x < p := ZMod.val_lt x_zmod
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs with h
    · push_cast; rw [ZMod.natCast_zmod_val, hx_zmod]
    · push_cast; rw [Nat.cast_sub x_lt_p.le, ZMod.natCast_zmod_val, hx_zmod]; ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.natCast_eq_zero_iff p]; push_cast; rw [hn_sq_mod_p]; simp
  have hn_pos : 0 < n := by
    refine Nat.pos_of_ne_zero (fun hn0 => ?_)
    rw [hn0, zero_pow (by norm_num), zero_add] at hp_dvd
    exact Nat.Prime.not_dvd_one hp_prime hp_dvd
  have hn_ge_N : n ≥ N := by
    have : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by linarith) hp_dvd
    have : N ^ 2 + 1 < p := by linarith
    have : N ^ 2 < n ^ 2 := by linarith
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) this
  use n, hn_ge_N, p, hp_prime, hp_dvd
  have h_2n_lt_p : 2 * n < p := by
    have h_p_val : p = 2 * (p / 2) + 1 := by rw [Nat.div_add_mod p 2, h_p_odd]
    dsimp [n]; split_ifs with h
    · linarith
    · linarith
  let k := p - 2 * n
  have hk_pos : 1 ≤ k := by linarith
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    rw [← ZMod.natCast_eq_zero_iff p]
    have : (k : ZMod p) = - 2 * (n : ZMod p) := by
      rw [Nat.cast_sub h_2n_lt_p.le]; push_cast; ring
    push_cast; rw [this, hn_sq_mod_p]; ring
  let m := (k ^ 2 + 4) / p
  have hm_p : m * p = k ^ 2 + 4 := Nat.mul_div_cancel' hp_dvd_k
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [hm_p]
    rw [Nat.mul_mod, hp_mod4_val] at this; simp at this
    have : k % 2 = 1 := by
      have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel h_2n_lt_p.le]
      rw [this, h_p_odd]
    have : k % 4 = 1 ∨ k % 4 = 3 := by
      have h2 : k % 4 < 4 := Nat.mod_lt k (by norm_num)
      have : (k % 4) % 2 = 1 := by rw [Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 4), this]
      revert h2 this; interval_cases r : k % 4 <;> norm_num
    rcases this with h | h <;> rw [h] at this <;> norm_num at this ⊢
  have h_k2_gt_2n : 2 * n < k ^ 2 := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub h_2n_lt_p.le]; ring
    have hm_val : (m : ℤ) * p = (k : ℤ) ^ 2 + 4 := by
      rw [← Nat.cast_mul, hm_p]; push_cast; rfl
    have hm1 : m = 1 ∨ m ≥ 5 := by
      have : m > 0 := Nat.pos_of_ne_zero (fun h => by rw [h, zero_mul] at hm_p; linarith)
      rcases le_or_gt 5 m with h' | h'
      · right; exact h'
      · left; interval_cases m <;> (simp [hm_mod4] at *)
    rcases hm1 with rfl | hm5
    · have : (k : ℤ) ^ 2 = (p : ℤ) - 4 := by linarith
      have : (k : ℤ) ^ 2 > 25 := by linarith [hMp]
      have : (k : ℤ) > 5 := by nlinarith
      linarith
    · have : (m : ℤ) * ((k : ℤ) ^ 2 - 2 * n) = (m - 1) * (k : ℤ) ^ 2 + (m : ℤ) * k - 4 := by
        rw [← hm_val, hp_eq]; ring
      have : (m - 1 : ℤ) * (k : ℤ) ^ 2 + (m : ℤ) * k - 4 > 0 := by
        have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
        have : (k : ℤ) ≥ 1 := by exact_mod_cast hk_pos
        nlinarith
      have : (m : ℤ) > 0 := by exact_mod_cast (Nat.pos_of_ne_zero (show m ≠ 0 by linarith))
      nlinarith
  have h_p_real : (p : ℝ) - 2 * n = (k : ℝ) := by
    rw [← Nat.cast_sub h_2n_lt_p.le]; push_cast; rfl
  rw [add_comm, ← Real.lt_sub_iff_add_lt, h_p_real]
  apply (Real.sqrt_lt (by push_cast; linarith) (by push_cast; linarith)).mpr
  push_cast; exact_mod_cast h_k2_gt_2n

