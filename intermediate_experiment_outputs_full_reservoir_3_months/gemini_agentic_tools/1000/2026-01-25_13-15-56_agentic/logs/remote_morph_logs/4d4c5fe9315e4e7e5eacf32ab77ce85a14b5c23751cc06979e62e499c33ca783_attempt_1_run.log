import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 1) 29
  obtain ⟨p, hp_prime, hp_gtM, hp_mod4⟩ := Nat.exists_prime_gt_modEq_one (k := 4) M (by norm_num)
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have hp_mod4_val : p % 4 = 1 := hp_mod4
  obtain ⟨x, hx⟩ := ZMod.exists_sq_eq_neg_one_iff (p := p).mpr (by rw [hp_mod4_val]; norm_num)
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_p_odd : p % 2 = 1 := by
    have : p % 2 = (p % 4) % 2 := (Nat.mod_mod_of_dvd p (by norm_num : 2 ∣ 4)).symm
    rw [this, hp_mod4_val]; norm_num
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs with h
    · push_cast; rw [ZMod.natCast_zmod_val x, hx]
    · push_cast; rw [Nat.cast_sub x.val_lt.le, ZMod.natCast_zmod_val x, hx]; ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.natCast_zmod_eq_zero_iff_dvd]
    push_cast; rw [hn_sq_mod_p]; simp
  have h_2n_lt_p : 2 * n < p := by
    have h_n_le_half : n ≤ p / 2 := by
      dsimp [n]; split_ifs with h <;> [exact h; skip]
      have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
      linarith [x.val_lt]
    have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by norm_num) hp_dvd
    have : N ^ 2 + 1 < p := by linarith [hp_gtM]
    have : N ^ 2 < n ^ 2 := by linarith
    exact (Nat.pow_lt_pow_iff_left (by norm_num : 0 < 2)).mp this |>.le
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := by linarith
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    rw [← ZMod.natCast_zmod_eq_zero_iff_dvd p]
    have : (k : ZMod p) = - 2 * (n : ZMod p) := by
      rw [Nat.cast_sub h_2n_lt_p.le]; push_cast; simp [k]
    push_cast; rw [this]; ring_nf; rw [hn_sq_mod_p]; simp
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = (k : ℤ) ^ 2 + 4 := by
    rw [← Nat.cast_mul, Nat.mul_div_cancel' hp_dvd_k]; push_cast; rfl
  have h_k_odd : k % 2 = 1 := by
    have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel h_2n_lt_p.le]
    rw [this, h_p_odd]
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [Nat.mul_div_cancel' hp_dvd_k]
    rw [Nat.mul_mod, hp_mod4_val] at this; simp at this
    have : Odd k := Nat.odd_iff.mpr h_k_odd
    rcases (Nat.odd_mod_four_iff.mp this) with rfl | rfl <;> norm_num at this ⊢
  have h_k2_gt_2n : 2 * n < k ^ 2 := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub h_2n_lt_p.le]; ring
    have hm1 : m = 1 ∨ m ≥ 5 := by
      have : (m : ℤ) > 0 := pos_of_mul_pos_right (by linarith [hm_val, hk_pos]) (by linarith [hp_prime.pos])
      have : m > 0 := by exact_mod_cast this
      rcases (le_or_gt 5 m) with h' | h' <;> [right; left] <;> (try exact h')
      interval_cases m; exact hm_mod4
    rcases hm1 with rfl | hm5
    · have : (k : ℤ) ^ 2 = (p : ℤ) - 4 := by linarith [hm_val]
      have : (k : ℤ) ^ 2 > 25 := by linarith [hp_gtM]
      have : (k : ℤ) > 5 := by
        have : (k : ℤ) * (k : ℤ) > 5 * 5 := by nlinarith
        nlinarith
      linarith [hp_eq]
    · have : (m : ℤ) * ((k : ℤ) ^ 2 - 2 * n) = (m - 1) * (k : ℤ) ^ 2 + (m : ℤ) * k - 4 := by
        rw [← hm_val, hp_eq]; ring
      have h_rhs_pos : (m - 1) * (k : ℤ) ^ 2 + (m : ℤ) * k - (4 : ℤ) > 0 := by
        have : (m : ℤ) ≥ 5 := by exact_mod_cast hm5
        have : (k : ℤ) ≥ 1 := by exact_mod_cast hk_pos
        nlinarith
      have : (k : ℤ) ^ 2 - 2 * (n : ℤ) > 0 := pos_of_mul_pos_left (by rw [this]; exact h_rhs_pos) (by linarith)
      exact_mod_cast this
  have : (p : ℝ) - 2 * n = (k : ℝ) := by rw [← Nat.cast_sub h_2n_lt_p.le]; rfl
  rw [← Real.lt_sub_iff_add_lt', this, Real.sqrt_lt' (by exact_mod_cast (hk_pos : 0 < k))]
  exact_mod_cast h_k2_gt_2n
