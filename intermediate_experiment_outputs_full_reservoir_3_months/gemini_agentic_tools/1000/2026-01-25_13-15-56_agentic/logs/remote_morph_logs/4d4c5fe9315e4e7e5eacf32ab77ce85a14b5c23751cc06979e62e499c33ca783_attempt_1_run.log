import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max (N ^ 2 + 1) 14
  have h_inf := Nat.infinite_setOf_prime_modEq_one 4 (by norm_num)
  obtain ⟨p, hp_mem, hp_gtM⟩ := h_inf.exists_gt M
  have hp_prime : p.Prime := hp_mem.1
  have hp_mod4 : p % 4 = 1 := hp_mem.2
  haveI : Fact p.Prime := ⟨hp_prime⟩
  have h_sq : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by linarith)
  obtain ⟨x, hx⟩ := h_sq
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have hn_sq_mod_p : (n : ZMod p) ^ 2 = -1 := by
    dsimp [n]; split_ifs
    · push_cast; rw [ZMod.natCast_zmod_val, hx]
    · push_cast; rw [ZMod.natCast_zmod_val, hx]; ring
  have hp_dvd : p ∣ n ^ 2 + 1 := by
    have : ((n ^ 2 + 1 : ℕ) : ZMod p) = 0 := by push_cast; rw [hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  have h_2n_lt_p : 2 * n < p := by
    have h_p_odd : p % 2 = 1 := (hp_prime.eq_two_or_odd.resolve_left (by linarith)).mod_two_eq_one
    have h_n_le_half : n ≤ p / 2 := by dsimp [n]; split_ifs <;> linarith [x.val_lt]
    have : p = 2 * (p / 2) + 1 := by rw [← h_p_odd, Nat.div_add_mod]
    linarith
  have hn_ge_N : n ≥ N := by
    have h_n2_p : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (n ^ 2 + 1).succ_pos hp_dvd
    have : n ^ 2 + 1 > N ^ 2 + 1 := by linarith [hp_gtM]
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) (by linarith)
  use n, hn_ge_N, p, hp_prime, hp_dvd
  let k := p - 2 * n
  have hk_pos : k ≥ 1 := Nat.sub_pos_of_lt h_2n_lt_p
  have hp_dvd_k : p ∣ k ^ 2 + 4 := by
    have : (k : ZMod p) ^ 2 + 4 = (- 2 * (n : ZMod p)) ^ 2 + 4 := by
      push_cast; rw [Nat.cast_sub h_2n_lt_p.le]; simp [k]
    have : ((k ^ 2 + 4 : ℕ) : ZMod p) = 0 := by
      push_cast; rw [this]; ring_nf; rw [hn_sq_mod_p]; simp
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ p).mp this
  let m := (k ^ 2 + 4) / p
  have hm_val : (m : ℤ) * p = (k : ℤ) ^ 2 + 4 := by
    rw [← Nat.cast_mul, Nat.mul_div_cancel' hp_dvd_k, Nat.cast_add, Nat.cast_pow]; rfl
  have h_k_odd : k % 2 = 1 := by
    have h_p_odd : p % 2 = 1 := (hp_prime.eq_two_or_odd.resolve_left (by linarith)).mod_two_eq_one
    have : (k + 2 * n) % 2 = p % 2 := by rw [Nat.sub_add_cancel h_2n_lt_p.le]
    rw [this, h_p_odd]; simp
  have hm_mod4 : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [Nat.mul_div_cancel' hp_dvd_k]
    rw [Nat.mul_mod, hp_mod4] at this; simp at this
    revert h_k_odd this; generalize k % 4 = r; intros; interval_cases r <;> norm_num at *
  have h_k2_gt_2n : (k : ℤ) ^ 2 > 2 * n := by
    have hp_eq : (p : ℤ) = 2 * n + k := by rw [Nat.cast_sub h_2n_lt_p.le]; ring
    have hm_pos : (m : ℤ) > 0 := by
      have : m * p > 0 := by linarith [hk_pos]
      exact_mod_cast Nat.pos_of_mul_pos_right this hp_prime.pos
    apply pos_of_mul_pos_left (a := (m : ℤ)) (by linarith)
    have : (m : ℤ) * ((k : ℤ) ^ 2 - 2 * n) = ((m : ℤ) - 1) * k ^ 2 + (m : ℤ) * k - 4 := by
      rw [sub_mul, one_mul, hm_val, hp_eq]; ring
    rw [this]
    have hm1 : m = 1 ∨ m ≥ 5 := by
