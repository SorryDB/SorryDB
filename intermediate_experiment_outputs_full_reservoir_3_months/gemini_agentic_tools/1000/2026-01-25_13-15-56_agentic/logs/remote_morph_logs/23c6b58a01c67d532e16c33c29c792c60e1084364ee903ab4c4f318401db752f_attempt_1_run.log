We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    obtain h_even | h_odd := Nat.even_or_odd n
    · -- n is even, use regular (n-1)-gon plus its center
      let m := n - 1
      let f : ℕ → EuclideanSpace ℝ (Fin 2) := fun i => (EuclideanSpace.equiv (Fin 2) ℝ).symm
        ![Real.cos (2 * Real.pi * (i : ℝ) / (m : ℝ)), Real.sin (2 * Real.pi * (i : ℝ) / (m : ℝ))]
      let s := insert (0 : EuclideanSpace ℝ (Fin 2)) ((Finset.range m).image f)
      use s; constructor
      · rw [hb₀]; sorry
      · have h_m : n = m + 1 := (Nat.succ_pred_eq_of_pos (by linarith)).symm
        rw [h_m, Finset.card_insert_of_not_mem, Finset.card_image_of_injOn]
        · exact Finset.card_range m
        · sorry
        · sorry
    · -- n is odd, use regular n-gon
      let f : ℕ → EuclideanSpace ℝ (Fin 2) := fun i => (EuclideanSpace.equiv (Fin 2) ℝ).symm
        ![Real.cos (2 * Real.pi * (i : ℝ) / (n : ℝ)), Real.sin (2 * Real.pi * (i : ℝ) / (n : ℝ))]
      let s := (Finset.range n).image f
      use s; constructor
      · rw [hb₀]; sorry
      · rw [Finset.card_image_of_injOn]; · exact Finset.card_range n; · sorry
  · apply Set.ext; intro n; constructor
    · rintro ⟨h3, s, hb, hcf, hsc⟩
      constructor; · exact h3
      rw [hb₀] at hb; rw [hb₁] at hcf
      -- A balanced centre-free set must have an odd number of points by counting the pairs each point balances.
      sorry
    · rintro ⟨h3, h_odd⟩
      constructor; · exact h3
      -- For odd n, a regular n-gon is both balanced and centre-free.
      let f : ℕ → EuclideanSpace ℝ (Fin 2) := fun i => (EuclideanSpace.equiv (Fin 2) ℝ).symm
        ![Real.cos (2 * Real.pi * (i : ℝ) / (n : ℝ)), Real.sin (2 * Real.pi * (i : ℝ) / (n : ℝ))]
      let s := (Finset.range n).image f
      use s; constructor
      · rw [hb₀]; sorry
      · constructor
        · rw [hb₁]; sorry
        · rw [Finset.card_image_of_injOn]; · exact Finset.card_range n; · sorry
