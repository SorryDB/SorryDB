import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$ (in $\mathcal{S}$), there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    obtain h_even | h_odd := Nat.even_or_odd n
    · sorry
    · let f (i : ℕ) : EuclideanSpace ℝ (Fin 2) := (EuclideanSpace.equiv (Fin 2) ℝ).symm ![Real.cos (2 * Real.pi * (i : ℝ) / (n : ℝ)), Real.sin (2 * Real.pi * (i : ℝ) / (n : ℝ))]
      use (Finset.range n).image f; constructor
      · rw [hb₀]; intro A hA B hB hAB; sorry
      · rw [Finset.card_image_of_injOn]; · exact Finset.card_range n; · sorry
  · apply Set.ext; intro n; constructor
    · rintro ⟨h3, s, hb, hcf, hsc⟩
      rw [hb₀] at hb; rw [hb₁] at hcf
      constructor; · exact h3
      by_contra h_even; rw [Nat.not_odd_iff_even, ← hsc] at h_even
      have h_double : s.card * (s.card - 1) / 2 ≤ s.card * ((s.card - 2) / 2) := by sorry
      sorry
    · rintro ⟨h3, h_odd⟩
      let f (i : ℕ) : EuclideanSpace ℝ (Fin 2) := (EuclideanSpace.equiv (Fin 2) ℝ).symm ![Real.cos (2 * Real.pi * (i : ℝ) / (n : ℝ)), Real.sin (2 * Real.pi * (i : ℝ) / (n : ℝ))]
      use (Finset.range n).image f; constructor
      · rw [hb₀]; intro A hA B hB hAB; sorry
      · constructor
        · rw [hb₁]; intro A hA B hB C hC hdiff; rintro ⟨P, hP, hdist⟩; sorry
        · rw [Finset.card_image_of_injOn]; · exact Finset.card_range n; · sorry

