import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = answer({n | 3 ≤ n ∧ Odd n}) := by
  constructor
  · intro n hn
    obtain h_odd | h_even := Nat.even_or_odd n
    · sorry -- Construction for odd n: Regular n-gon
    · sorry -- Construction for even n: rhombus for n=4, etc.
  · apply Set.ext; intro n; constructor
    · rintro ⟨h3, s, hb, hcf, hsc⟩
      constructor; · exact h3
      rw [hb₀] at hb; rw [hb₁] at hcf
      by_contra h_even_n
      have h_even : Even n := Nat.not_odd_iff_even.mp h_even_n
      classical
      let pairs := (s.product s).filter (λ p => p.1 ≠ p.2)
      have h_total : pairs.card ≤ ∑ P ∈ s, (pairs.filter (λ p => dist P p.1 = dist P p.2)).card := by
        apply Finset.card_le_card_biUnion
        intro p hp; simp at hp; obtain ⟨h1, h2, hneq⟩ := hp
        obtain ⟨C, hCs, hdist⟩ := hb p.1 h1 p.2 h2 hneq
        simp; use C, hCs; simp [h1, h2, hneq, hdist]
      have h_each : ∀ P ∈ s, (pairs.filter (λ p => dist P p.1 = dist P p.2)).card ≤ n - 2 := by
        intro P hPs
        let S_P r := (s.erase P).filter (λ A => dist P A = r)
        have h_cf : ∀ r, (S_P r).card ≤ 2 := by
          intro r; rw [Finset.card_le_two]; intro A hA B hB C hC
          simp [S_P] at hA hB hC; by_contra h_all; push_neg at h_all
          exact hcf A hA.1.1 B hB.1.1 C hC.1.1 h_all ⟨P, hPs, hA.2.trans hB.2.symm, hB.2.trans hC.2.symm⟩
        let R := (s.erase P).image (λ A => dist P A)
        have h_card_balanced : (pairs.filter (λ p => dist P p.1 = dist P p.2)).card = ∑ r ∈ R, (S_P r).card * ((S_P r).card - 1) := sorry
        have h_bound : ∑ r ∈ R, (S_P r).card * ((S_P r).card - 1) ≤ n - 2 := by
          -- Since |S_P r| ≤ 2, card * (card - 1) is 2 if card = 2, else 0.
          -- Sum is 2 * (number of r with card = 2).
          -- Points in such pairs are in s \ {P}, so their number 2k ≤ n - 1.
          -- Since n is even, n - 1 is odd, so 2k ≤ n - 2.
          sorry
        exact h_card_balanced.trans h_bound
      have h_final : n * (n - 1) ≤ n * (n - 2) := by
        have : pairs.card = n * (n - 1) := by
          rw [Finset.card_filter, Finset.card_product, hsc, hsc]
          have : (Finset.filter (λ p : EuclideanSpace ℝ (Fin 2) × EuclideanSpace ℝ (Fin 2) => p.1 = p.2) (s.product s)).card = s.card := sorry
          rw [Finset.card_filter_ne_self, this, hsc]; exact Nat.mul_sub_left_distrib n n 1
        rw [this] at h_total; apply h_total.trans
        rw [Finset.sum_const, hsc, smul_eq_mul]; intro P hP; exact h_each P hP
      have : n - 1 ≤ n - 2 := Nat.le_of_mul_le_mul_left h_final (by linarith)
      linarith
    · rintro ⟨h3, h_odd⟩
      constructor; · exact h3
      sorry -- For odd n, a regular n-gon is both balanced and center-free.
