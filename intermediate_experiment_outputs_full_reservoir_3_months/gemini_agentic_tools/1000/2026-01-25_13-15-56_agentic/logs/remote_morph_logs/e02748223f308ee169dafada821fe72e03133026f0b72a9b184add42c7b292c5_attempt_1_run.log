lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  rintro hφψ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ψ) + 1;
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, hΓ₂⟩ := h;
    have hΓ₁ : (Γ.conj ⋏ φ) ➝ (Γ.conj ⋏ ψ) ∈ T.theory := T.mem_of_provable $ by
      sorry;
    have : (Γ.conj ⋏ φ) ➝ ξ ∈ T.theory := T.imp_closed axiomI $ T.andIR hΓ₁ hΓ₂;

    have h_inv : ∀ i Γ, ↑Γ ⊆ construction T hT i → Γ.conj ➝ ξ ∉ T.theory := by
      intro i; induction i with
      | zero =>
        intro Γ hΓ hC; apply hT; apply T.mem_trans _ hC;
        apply T.mem_of_provable; apply Logic.iff_provable.mp; simp;
        intro γ hγ; have := hΓ hγ; simp [construction] at this; exact this;
      | succ i ih =>
        intro Γ hΓ hC; dsimp [construction] at hΓ; split at hΓ;
        . rename_i δ h_dec; split_ifs at hΓ with h_cond;
          . by_cases hδ : δ ∈ Γ;
            . apply h_cond (Γ.erase δ);
              . intro x hx; have := hΓ (Finset.mem_of_mem_erase hx); simp at this; tauto;
              . apply T.imp_closed (φ := Γ.conj) (T.mem_of_provable $ Logic.iff_provable.mp $ by grind) hC;
            . apply ih; intro x hx; have := hΓ hx; simp at this; tauto;
          . apply ih hΓ hC;
        . apply ih hΓ hC;
    obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
    apply h_inv (max i (encode ψ)) (insert φ Γ) (by
      intro x hx; simp at hx; rcases hx with (rfl | hx);
      . apply monotone_construction (le_max_left _ _) hi;
      . apply monotone_construction (le_max_right _ _) (hΓ hx)) (by
      apply T.imp_closed (φ := Γ.conj ⋏ φ) (T.mem_of_provable $ Logic.iff_provable.mp $ by grind) this);
