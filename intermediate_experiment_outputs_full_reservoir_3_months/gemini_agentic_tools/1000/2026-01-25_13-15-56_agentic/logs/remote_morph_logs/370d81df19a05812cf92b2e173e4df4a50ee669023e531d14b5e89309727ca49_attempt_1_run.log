import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let n := #A
  have m_pos : 0 < m := by linarith
  have m_ge_2 : 2 ≤ m := hm
  by_contra! h_mn
  have h_2n : 2 * n < m := by
    exact_mod_cast h_mn
  let f : (Fin m → Fin m) → (A → Fin (m * (m - 1) + 1)) := fun c a =>
    let val := ∑ k : Fin m, (c k : ℤ) * (if (a : ℤ) ∈ B k then 1 else 0)
    have h_nonneg : 0 ≤ val := Finset.sum_nonneg (fun k _ => mul_nonneg (by simp) (by split <;> linarith))
    have h_le : val ≤ m * (m - 1) := by
      calc val ≤ ∑ _k : Fin m, (m - 1 : ℤ) * 1 := Finset.sum_le_sum (fun k _ => mul_le_mul (by simp; omega) (by split <;> linarith) (by split <;> linarith) (by simp; omega))
           _ = m * (m - 1) := by simp; ring
    ⟨val.toNat, by
      rw [Int.toNat_lt h_nonneg]
      linarith⟩
  have h_card_dom : Fintype.card (Fin m → Fin m) = m ^ m := by simp
  have h_card_cod : Fintype.card (A → Fin (m * (m - 1) + 1)) = (m * (m - 1) + 1) ^ n := by simp
  have h_lt : (m * (m - 1) + 1) ^ n < m ^ m := by
    calc (m * (m - 1) + 1) ^ n < (m * m) ^ n := by
           apply pow_lt_pow_left _ (by linarith) (by linarith)
           calc m * (m - 1) + 1 = m * m - m + 1 := by ring
                _ < m * m := by linarith
         _ = m ^ (2 * n) := by rw [← pow_mul]; ring
         _ ≤ m ^ (m - 1) := Nat.pow_le_pow_of_le_right m_pos (by linarith)
         _ < m ^ m := Nat.pow_lt_pow_right (by linarith) (by linarith)
  obtain ⟨c1, c2, h_c_ne, h_f_eq⟩ := Fintype.exists_ne_of_card_lt_card f (by rw [h_card_dom, h_card_cod]; exact h_lt)
  let b : Fin m → ℤ := fun k => (c1 k : ℤ) - (c2 k : ℤ)
  have h_sum_b : ∑ k, b k * (m : ℤ) ^ (k.val + 1) = 0 := by
    calc ∑ k, b k * (m : ℤ) ^ (k.val + 1) = ∑ k, b k * ∑ a ∈ B k, a := by simp [hB]
         _ = ∑ k, ∑ a ∈ A, b k * (if (a : ℤ) ∈ B k then 1 else 0) * a := by
           apply Finset.sum_congr rfl; intro k _; rw [Finset.sum_subset (hBA k)]; swap; { intro a ha hna; simp [hna] }
           simp; apply Finset.sum_congr rfl; intro a ha; split <;> ring
         _ = ∑ a ∈ A, a * (∑ k, b k * (if a ∈ B k then 1 else 0)) := by ring_nf; exact Finset.sum_comm
         _ = 0 := Finset.sum_eq_zero (fun a ha => by
           let f1 := (f c1 a).val
           let f2 := (f c2 a).val
           have h_eq : f1 = f2 := by rw [h_f_eq]
           simp [f1, f2, f] at h_eq
           rw [← h_eq, ← Finset.sum_sub_distrib]
           simp [b]; ring)
  have h_sum_b_m : ∑ k, b k * (m : ℤ) ^ k.val = 0 := by
    rw [← Finset.mul_sum] at h_sum_b
    simp [pow_succ] at h_sum_b
    exact (Int.mul_eq_zero.mp h_sum_b).resolve_left (by linarith)
  let K := Finset.filter (fun k => b k ≠ 0) Finset.univ
  have h_K_ne : K.Nonempty := by
    obtain ⟨k, hk⟩ := Function.ne_iff.mp h_c_ne
    use k; simp [K, b, hk]
  let k0 := K.max' h_K_ne
  have h_b_k0 : |b k0| ≥ 1 := by simp [K]; exact Int.abs_pos.mpr (by simp [K] at h_K_ne; exact (Finset.mem_filter.mp (Finset.max'_mem K h_K_ne)).right)
  have h_tail : |∑ k in K.filter (· < k0), b k * (m : ℤ) ^ k.val| ≤ m ^ k0.val - 1 := by
    calc |∑ k in K.filter (· < k0), b k * (m : ℤ) ^ k.val|
           ≤ ∑ k in K.filter (· < k0), |b k| * (m : ℤ) ^ k.val := Finset.abs_sum_le_sum_abs _ _
         _ ≤ ∑ k in K.filter (· < k0), (m - 1 : ℤ) * (m : ℤ) ^ k.val := by
           apply Finset.sum_le_sum; intro k hk; apply mul_le_mul_of_nonneg_right (by simp [b]; omega) (pow_nonneg (by linarith) _)
         _ ≤ ∑ j in Finset.range k0.val, (m - 1 : ℤ) * (m : ℤ) ^ j := by
           apply Finset.sum_le_sum_of_subset_of_nonneg
           · intro k hk; simp at hk; rw [Finset.mem_range]; exact hk.right
           · intro j _ _; apply mul_nonneg (by linarith) (pow_nonneg (by linarith) _)
         _ = (m - 1) * ∑ j in Finset.range k0.val, (m : ℤ) ^ j := by rw [Finset.mul_sum]
         _ = (m - 1) * ((m ^ k0.val - 1) / (m - 1)) := by rw [geom_sum_range (m : ℤ) (by linarith)]
         _ = m ^ k0.val - 1 := by rw [Int.mul_ediv_cancel' (by linarith)]
  have h_sum_all : ∑ k, b k * (m : ℤ) ^ k.val = b k0 * m ^ k0.val + ∑ k in K.filter (· < k0), b k * m ^ k.val := by
    rw [← Finset.sum_filter_add_sum_filter_not Finset.univ (fun k => b k ≠ 0), Finset.sum_eq_zero]
    · simp [K]; rw [← Finset.add_sum_erase _ _ (Finset.max'_mem K h_K_ne), Finset.filter_true_of_mem]
      · apply Finset.sum_congr rfl; intro x hx; simp at hx; simp [hx.right]
      · intro x hx; simp at hx; linarith [Finset.le_max' K x hx.left]
    · intro x hx; simp at hx; exact hx
  rw [h_sum_all, add_eq_zero_iff_eq_neg] at h_sum_b_m
  apply_fun abs at h_sum_b_m
  rw [abs_mul, abs_pow] at h_sum_b_m
  linarith [h_b_k0, h_tail, h_sum_b_m]

