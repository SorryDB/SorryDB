    dsimp [S] at hS_eq
    simp_rw [pow_succ, ← Finset.mul_sum] at hS_eq
    have h_sum_pow : ∑ k : Fin m, (c1 k : ℤ) * (m : ℤ) ^ (k : ℕ) = ∑ k : Fin m, (c2 k : ℤ) * (m : ℤ) ^ (k : ℕ) :=
      (Int.mul_eq_mul_left_iff (by omega)).mp hS_eq
    have h_sum_pow_nat : ∑ k : Fin m, (c1 k : ℕ) * m ^ (k : ℕ) = ∑ k : Fin m, (c2 k : ℕ) * m ^ (k : ℕ) := by
      norm_cast at h_sum_pow
