import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let n := #A
  have m_pos : 0 < m := by linarith
  have m_gt_1 : 1 < m := hm
  by_contra! h_lt
  have h_2n_lt_m : 2 * n < m := by
    rw [lt_div_iff₀ (by norm_num : (0 : ℚ) < 2)] at h_lt
    norm_cast at h_lt
  have n_pos : 0 < n := by
    by_contra! hn
    have hA : A = ∅ := by rwa [Finset.card_eq_zero, nonpos_iff_eq_zero] at hn
    have hB0 : B ⟨0, m_pos⟩ = ∅ := by rw [hA] at hBA; exact Finset.subset_empty.mp (hBA _)
    have : (m : ℤ) ^ (0 + 1) = 0 := by rw [← hB ⟨0, m_pos⟩, hB0]; simp
    simp at this; linarith
  let f : (Fin m → Fin m) → (↥A → Fin (m * (m - 1) + 1)) := fun c a =>
    let v := ∑ k : Fin m, (c k : ℕ) * (if (a : ℤ) ∈ B k then 1 else 0)
    have h_v : v < m * (m - 1) + 1 := by
      calc v ≤ ∑ _k : Fin m, (m - 1) * 1 := Finset.sum_le_sum (fun k _ => Nat.mul_le_mul (Nat.le_pred_of_lt (c k).is_lt) (by split_ifs <;> omega))
           _ = m * (m - 1) := by simp; ring
           _ < m * (m - 1) + 1 := by linarith
    ⟨v, h_v⟩
  have h_card_dom : Fintype.card (Fin m → Fin m) = m ^ m := by simp
  have h_card_cod : Fintype.card (↥A → Fin (m * (m - 1) + 1)) = (m * (m - 1) + 1) ^ n := by simp
  have h_lt_card : Fintype.card (↥A → Fin (m * (m - 1) + 1)) < Fintype.card (Fin m → Fin m) := by
    rw [h_card_dom, h_card_cod]
    calc (m * (m - 1) + 1) ^ n < (m * m) ^ n := Nat.pow_lt_pow_left (by nlinarith) n_pos
         _ = m ^ (2 * n) := by rw [← pow_mul]
         _ ≤ m ^ (m - 1) := pow_le_pow_right m_pos (by linarith)
         _ < m ^ m := pow_lt_pow_right m_gt_1 (by linarith)
  obtain ⟨c1, c2, h_c_ne, h_f_eq⟩ := Fintype.exists_ne_of_card_lt_card f h_lt_card
  have h_v_eq : ∀ a : ↥A, ∑ k : Fin m, (c1 k : ℤ) * (if (a : ℤ) ∈ B k then 1 else 0) = ∑ k : Fin m, (c2 k : ℤ) * (if (a : ℤ) ∈ B k then 1 else 0) := by
    intro a
    apply_fun (fun x => (x a).val) at h_f_eq
    simp [f] at h_f_eq
    norm_cast at h_f_eq
  have h_sum_eq : ∑ k : Fin m, (c1 k : ℤ) * (m : ℤ) ^ ((k : ℕ) + 1) = ∑ k : Fin m, (c2 k : ℤ) * (m : ℤ) ^ ((k : ℕ) + 1) := by
    have h_S c := calc ∑ k : Fin m, (c k : ℤ) * (m : ℤ) ^ ((k : ℕ) + 1)
      _ = ∑ k, (c k : ℤ) * ∑ a ∈ B k, a := by simp [hB]
      _ = ∑ k, ∑ a ∈ A, (c k : ℤ) * (if a ∈ B k then 1 else 0) * a := by
        apply Finset.sum_congr rfl; intro k _; rw [Finset.sum_subset (hBA k)]
        · intro a ha hna; simp [hna]
        · intro a ha; simp; ring
      _ = ∑ a ∈ A, (a : ℤ) * ∑ k, (c k : ℤ) * (if a ∈ B k then 1 else 0) := by ring_nf; exact Finset.sum_comm
    rw [h_S c1, h_S c2]
    apply Finset.sum_congr rfl; intro a ha
    rw [h_v_eq ⟨a, ha⟩]
  simp_rw [pow_succ, ← Finset.mul_sum] at h_sum_eq
  have h_sum_eq_nat : ∑ k : Fin m, (c1 k : ℕ) * m ^ (k : ℕ) = ∑ k : Fin m, (c2 k : ℕ) * m ^ (k : ℕ) := by
    replace h_sum_eq := (Int.mul_eq_mul_left_iff (by linarith)).mp h_sum_eq
    norm_cast at h_sum_eq
  apply h_c_ne
  ext k
  let L1 := List.ofFn (fun k : Fin m => (c1 k).val)
  let L2 := List.ofFn (fun k : Fin m => (c2 k).val)
  have h_ofDigits : Nat.ofDigits m L1 = Nat.ofDigits m L2 := by
    rw [Nat.ofDigits_eq_sum_mapIdx, Nat.ofDigits_eq_sum_mapIdx]
    simp [L1, L2, List.mapIdx_ofFn, List.sum_ofFn, ← h_sum_eq_nat]
  have h_list_eq := Nat.ofDigits_inj_of_len_eq m_gt_1 (by simp [L1, L2]) (by simp [L1]) (by simp [L2]) h_ofDigits
  apply_fun (fun L => L.get ⟨k.val, by simp [L1, L2]⟩) at h_list_eq
  simpa [L1, L2] using h_list_eq

end IMO2021P6

