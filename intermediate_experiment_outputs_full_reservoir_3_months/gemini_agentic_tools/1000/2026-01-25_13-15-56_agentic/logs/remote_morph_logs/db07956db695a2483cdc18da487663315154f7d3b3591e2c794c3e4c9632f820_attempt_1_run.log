      let vm := (Finset.univ.image v).min' (Finset.univ_nonempty.image _)
      have h_vm i : vm ≤ v i := Finset.min'_le _ _ (Finset.mem_image.mpr ⟨i, Finset.mem_univ _, rfl⟩)
      have h_v_eq i : v i = vm := by
        induction vm using Nat.strong_induction_on with
        | h vm' ih =>
          contrapose! h_vm
          sorry
      rw [h_v_eq j, h_v_eq l]
    have h_mod : ∀ k j l, deck j % 2^k = deck l % 2^k := by
      intro k
      induction k with
