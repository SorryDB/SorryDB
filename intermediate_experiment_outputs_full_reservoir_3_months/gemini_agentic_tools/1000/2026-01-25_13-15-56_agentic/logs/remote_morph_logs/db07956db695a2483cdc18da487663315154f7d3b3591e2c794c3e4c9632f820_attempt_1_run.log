import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp [answer]
  constructor
  · exact fun h ↦ h.1
  · intro hn
    refine ⟨hn, fun deck hpos hGM ↦ ?_⟩
    intro i j
    have h_mod (k : ℕ) : ∀ i j, deck i % 2^k = deck j % 2^k := by
      induction k with
      | zero => simp
      | succ k ih =>
        intro i j
        let r := deck i % 2^k
        have h_r l : deck l % 2^k = r := ih l i
        let b l := deck l / 2^k
        have h_ab l : deck l = 2^k * b l + r := by rw [Nat.div_add_mod, h_r]
        have h_b_parity j l : b j % 2 = b l % 2 := by
          by_cases hjl : j = l; · rw [hjl]
          obtain ⟨S, hS, hG⟩ := hGM j l hjl
          have h_prod : (∏ i ∈ S, (deck i : ℚ)) = ((deck j + deck l : ℚ) / 2) ^ S.card := by
            apply (Rat.cast_inj (K := ℝ)).1; push_cast; rw [hG, Real.rpow_nat_cast]; rfl
          have h_int : ((deck j + deck l : ℚ) / 2).den = 1 := by
            have h_den := Rat.den_pow ((deck j + deck l : ℚ) / 2) S.card
            rw [← h_prod] at h_den; simp at h_den
            exact Nat.pow_eq_one_iff.1 h_den.symm |>.1 (by simp [hS.ne_empty])
          let m := ((deck j + deck l : ℚ) / 2).num.toNat
          have hm : (deck j + deck l : ℝ) / 2 = m := by
            have : (deck j + deck l : ℚ) / 2 = ↑m := by
              rw [← Rat.num_den ((deck j + deck l : ℚ) / 2), h_int]; simp; rfl
            rw [← Rat.cast_inj (K := ℝ), this]; push_cast; rfl
          have h_odd_m : (m : ℚ) ^ S.card = ∏ k ∈ S, (deck k : ℚ) := by
            apply (Rat.cast_inj (K := ℝ)).1; push_cast; rw [← hm, hG, Real.rpow_nat_cast]; rfl
          sorry
        rw [h_ab i, h_ab j, Nat.add_mod, Nat.add_mod, h_b_parity i j, Nat.mul_mod_mul_left]
        simp [pow_succ]
    let K := deck i + deck j + 1
    have hi : deck i < 2^K := Nat.lt_of_lt_of_le (Nat.lt_succ_self _) (Nat.pow_le_pow_of_le_right (by norm_num) (Nat.le_add_right _ _))
    have hj : deck j < 2^K := Nat.lt_of_lt_of_le (Nat.lt_succ_self _) (Nat.pow_le_pow_of_le_right (by norm_num) (Nat.le_add_left _ _))
    have := h_mod K i j
    rwa [Nat.mod_eq_of_lt hi, Nat.mod_eq_of_lt hj] at this

