    apply (Rat.cast_inj (α := ℝ)).1; push_cast
    rw [Rat.num_den, h_den]; simp; exact Int.toNat_of_nonneg h_num_pos
  have h_v2 : ∀ i j, padicValNat 2 (deck i) = padicValNat 2 (deck j) := by
    intro i j
    let v := fun i ↦ padicValNat 2 (deck i)
    let vmin := (Finset.univ.image v).min' (Finset.univ_nonempty.mpr (by linarith) |>.image _)
    have h_vmin k : vmin ≤ v k := Finset.min'_le _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ _))
    have h_vmin_eq : ∀ k, v k = vmin := by
