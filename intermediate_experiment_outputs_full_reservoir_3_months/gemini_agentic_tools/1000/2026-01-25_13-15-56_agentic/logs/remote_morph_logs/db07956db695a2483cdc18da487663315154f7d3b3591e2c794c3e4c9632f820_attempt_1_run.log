import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hGM ↦ ?_⟩⟩
  intro i j
  let a := deck
  have h_avg_int (j l : Fin n) (hjl : j ≠ l) : ∃ m : ℕ, (a j + a l : ℝ) / 2 = m := by
    obtain ⟨S, hS, hG⟩ := hGM j l hjl
    have h_prod : (∏ i ∈ S, (a i : ℚ)) = ((a j + a l : ℚ) / 2) ^ S.card := by
      apply (Rat.cast_inj (K := ℝ)).1
      push_cast
      rw [hG, ← Real.rpow_nat_cast, ← Real.rpow_mul]
      · simp [hS.ne_empty]
      · apply Finset.prod_nonneg; intro i _; simp [hpos]
    have h_den : ((a j + a l : ℚ) / 2).den = 1 := by
      have h_pden := Rat.den_pow ((a j + a l : ℚ) / 2) S.card
      rw [← h_prod] at h_pden; simp at h_pden
      exact Nat.pow_eq_one_iff.1 h_pden.symm |>.left (by simp [hS.ne_empty])
    use ((a j + a l : ℚ) / 2).num.toNat
    have : ((a j + a l : ℚ) / 2) = (((a j + a l : ℚ) / 2).num : ℚ) := by
      rw [← Rat.num_den ((a j + a l : ℚ) / 2), h_den]; simp
    rw [← Rat.cast_inj (K := ℝ), this]; push_cast; rfl
  have h_mod (k : ℕ) (j l : Fin n) : a j % 2^k = a l % 2^k := by
    induction k with
    | zero => simp
    | succ k ih =>
      let idx0 : Fin n := ⟨0, Nat.pos_of_gt hn⟩
      let r := a idx0 % 2^k
      have h_r i : a i % 2^k = r := ih i idx0
      let b i := a i / 2^k
      have h_ab i : a i = 2^k * b i + r := by rw [Nat.div_add_mod]
      have h_b_parity (j l : Fin n) : b j % 2 = b l % 2 := by
        by_cases hjl : j = l; · rw [hjl]
        obtain ⟨S, hS, hG⟩ := hGM j l hjl
        obtain ⟨m, hm⟩ := h_avg_int j l hjl
        sorry
      rw [h_ab j, h_ab l, Nat.add_mod, Nat.add_mod, h_b_parity j l]
      simp [pow_succ, mul_comm]
  let K := a i + a j + 1
  have hi : a i < 2^K := Nat.lt_of_lt_of_le (Nat.lt_succ_self _) (Nat.le_pow_self (by norm_num) _)
  have hj : a j < 2^K := Nat.lt_of_lt_of_le (Nat.lt_succ_self _) (Nat.le_pow_self (by norm_num) _)
  have := h_mod K i j
  rwa [Nat.mod_eq_of_lt hi, Nat.mod_eq_of_lt hj] at this

