    · exact hij
    have h_int : ∀ {j l : Fin n}, j ≠ l → ∃ m : ℕ, (deck j + deck l : ℝ) / 2 = m := by
      intro j l hjl
      obtain ⟨S, hS, hG⟩ := hGM hjl
      have h_GM_pow : ((deck j + deck l : ℝ) / 2) ^ S.card = ∏ i' ∈ S, (deck i' : ℝ) := by
        rw [hG, ← Real.rpow_nat_cast, ← Real.rpow_mul]
        · simp [hS.ne_empty]
        · apply Finset.prod_nonneg; intro i' _; simp [hpos]
      have h_GM_rat : ((deck j + deck l : ℚ) / 2) ^ S.card = ∏ i' ∈ S, (deck i' : ℚ) := by
        apply (Rat.cast_inj (K := ℝ)).1; push_cast; exact h_GM_pow
      have h_den : ((deck j + deck l : ℚ) / 2).den = 1 := by
        have h_pow_den := Rat.den_pow ((deck j + deck l : ℚ) / 2) S.card
        rw [h_GM_rat] at h_pow_den
        have h_prod_den : (∏ i' ∈ S, (deck i' : ℚ)).den = 1 := by
          rw [← Rat.coe_int_eq_mk, Rat.den_int_cast]
        rw [h_prod_den] at h_pow_den; simp at h_pow_den
        exact Nat.pow_eq_one_iff.1 h_pow_den.symm |>.1 (hS.ne_empty.bot_lt.ne.symm)
      use ((deck j + deck l : ℚ) / 2).toNat
      rw [← Rat.cast_inj (K := ℝ)]; push_cast
      conv_lhs => rw [← Rat.num_den ((deck j + deck l : ℚ) / 2), h_den]
      simp; rfl
    have h_mod (k : ℕ) : ∀ i j, deck i % 2^k = deck j % 2^k := by
      induction k with
