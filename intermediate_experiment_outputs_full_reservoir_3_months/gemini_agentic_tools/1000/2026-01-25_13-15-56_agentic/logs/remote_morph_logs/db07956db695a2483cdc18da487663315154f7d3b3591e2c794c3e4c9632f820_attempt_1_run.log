import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp [answer]
  constructor
  · intro h; exact h.1
  · intro hn
    refine ⟨hn, fun deck hpos hGM ↦ ?_⟩
    have h_int : ∀ j k, j ≠ k → ∃ m : ℕ, (deck j + deck k : ℝ) / 2 = m := by
      intro j k hjk
      obtain ⟨S, hS, hG⟩ := hGM hjk
      have h_q : ((deck j + deck k : ℚ) / 2) ^ #S = ∏ i ∈ S, (deck i : ℚ) := by
        apply (Rat.cast_inj (α := ℝ)).1; push_cast
        rw [hG, ← Real.rpow_natCast]; simp [hS.ne_empty]
      have h_den : ((deck j + deck k : ℚ) / 2).den = 1 := by
        have h_pd := Rat.den_pow ((deck j + deck k : ℚ) / 2) (#S)
        rw [h_q] at h_pd
        have : (∏ i ∈ S, (deck i : ℚ)).den = 1 := by
          rw [← Rat.cast_prod]; exact Rat.den_natCast _
        rw [this, Nat.pow_eq_one_iff] at h_pd; · exact h_pd.1; · simp [hS.ne_empty]
      use ((deck j + deck k : ℚ) / 2).num.toNat
      apply (Rat.cast_inj (α := ℝ)).1; push_cast
      rw [Rat.num_den, h_den]; simp
    have h_parity : ∀ i j, deck i % 2 = deck j % 2 := by
      intro i j
      by_cases hij : i = j; · rw [hij]
      obtain ⟨m, hm⟩ := h_int i j hij
      have : deck i + deck j = 2 * m := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; rw [← hm]; ring
      have h1 : (deck i + deck j) % 2 = 0 := by rw [this, Nat.mul_mod_right]
      if h_n : n = 2 then
        cases i using Fin.cases with | zero => cases j using Fin.cases with | zero => contradiction | succ j => rfl
        | succ i => cases j using Fin.cases with | zero => rfl | succ j => contradiction
      else
        haveI : Fact (2 < n) := ⟨lt_of_le_of_ne hn (Ne.symm h_n)⟩
        let k : Fin n := if i = 0 then (if j = 1 then 2 else 1) else 0
        have hik : i ≠ k := by split_ifs <;> (intro h; simp_all)
        have hjk : j ≠ k := by split_ifs <;> (intro h; simp_all)
        obtain ⟨m1, hm1⟩ := h_int i k hik
        obtain ⟨m2, hm2⟩ := h_int j k hjk
        have h2 : (deck i + deck k) % 2 = 0 := by
          have : deck i + deck k = 2 * m1 := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; rw [← hm1]; ring
          rw [this, Nat.mul_mod_right]
        have h3 : (deck j + deck k) % 2 = 0 := by
          have : deck j + deck k = 2 * m2 := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; rw [← hm2]; ring
          rw [this, Nat.mul_mod_right]
        rw [Nat.add_mod_eq_zero_iff] at h1 h2 h3; · rw [h1, h2]; · exact Nat.le_add_left _ _
    have h_mod_2k : ∀ k, ∀ i j, deck i % 2^k = deck j % 2^k := by
      intro k; induction k with
      | zero => intros; simp
      | succ k ih =>
        intros i j
        by_cases hij : i = j; · rw [hij]
        let c := deck 0 % 2^(k+1)
        have : ∀ l, deck l % 2^k = c % 2^k := fun l ↦ by rw [ih l 0, Nat.mod_mod]
        let a l := (deck l - deck l % 2^k) / 2^k
        have h_deck l : deck l = 2^k * a l + (c % 2^k) := by
          rw [Nat.mul_div_cancel' (Nat.dvd_sub_mod (deck l)), Nat.sub_add_cancel (Nat.mod_le _ _), this]
        obtain ⟨m, hm⟩ := h_int i j hij
        have : 2 * m = deck i + deck j := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; rw [← hm]; ring
        rw [h_deck i, h_deck j] at this
        obtain ⟨S, hS, hG⟩ := hGM hij
        have h_prod : (m : ℝ)^#S = ∏ l ∈ S, (deck l : ℝ) := by rw [← hm, hG, ← Real.rpow_natCast]; simp [hS.ne_empty]
        have h_prod_nat : m^#S = ∏ l ∈ S, deck l := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; exact h_prod
        have h_v2 : v2 (m^#S) = v2 (∏ l ∈ S, deck l) := by rw [h_prod_nat]
        have h_v2_all : ∀ l, v2 (deck l) = v2 (deck 0) := by
          intro l; induction (deck 0) using Nat.strong_induction_on with | h d' _ =>
          let v := v2 (deck 0)
          have : ∀ i, 2^v ∣ deck i := fun i ↦ by rw [← padicValNat_dvd_iff (hpos i).ne.symm]; rw [h_parity i 0]; exact Nat.pow_dvd_padicValNat _ _
          if hv : v = 0 then simp [hv]
          else skip
          sorry
        sorry
    intro i j
    let K := deck i + deck j + 1
    have hK := h_mod_2k K i j
    rwa [Nat.mod_eq_of_lt (Nat.lt_pow_self one_lt_two _), Nat.mod_eq_of_lt (Nat.lt_pow_self one_lt_two _)] at hK

