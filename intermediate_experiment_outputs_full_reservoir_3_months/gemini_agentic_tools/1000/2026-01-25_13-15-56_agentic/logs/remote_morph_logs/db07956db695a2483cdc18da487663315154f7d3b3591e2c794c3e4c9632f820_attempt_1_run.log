  · intro h; exact h.1
  · intro hn
    refine ⟨hn, fun deck hpos hGM ↦ ?_⟩
    have h_int : ∀ j k, ∃ m : ℕ, (deck j + deck k : ℝ) / 2 = m := by
      intro j k
      by_cases hjk : j = k
      · use deck j; push_cast; ring
      · obtain ⟨S, hS, hG⟩ := hGM hjk
        have h_q : ((deck j + deck k : ℚ) / 2) ^ #S = ∏ i ∈ S, (deck i : ℚ) := by
          apply (Rat.cast_inj (α := ℝ)).1; push_cast; rw [hG, Real.rpow_natCast]; rfl
        have h_den : ((deck j + deck k : ℚ) / 2).den = 1 := by
          have h_pd := Rat.den_pow ((deck j + deck k : ℚ) / 2) (#S)
          rw [h_q] at h_pd
          have h_prod_den : (∏ i ∈ S, (deck i : ℚ)).den = 1 := by
            rw [Rat.den_prod]; intro i _; rw [Rat.den_natCast]
          rw [h_prod_den] at h_pd; simp at h_pd
          exact Nat.pow_eq_one_iff.1 h_pd.symm |>.1 (by simp [hS.ne_empty])
        use ((deck j + deck k : ℚ) / 2).num.toNat
        apply (Rat.cast_inj (α := ℝ)).1; push_cast
        rw [Rat.num_den, h_den]; simp; rfl
    let v i := padicValNat 2 (deck i)
    let vmin := (Finset.univ.image v).min' (Finset.univ_nonempty.image _)
    have h_v i : v i = vmin := by
      let b i := deck i / 2^vmin
      have h_b_int j k : ∃ m : ℕ, (b j + b k : ℝ) / 2 = m := by
        obtain ⟨m, hm⟩ := h_int j k
        use m / 2^vmin
        apply (Nat.cast_inj (R := ℝ)).1; push_cast
        rw [Nat.mul_div_cancel' (Nat.pow_dvd_padicValNat 2 m)]
        · rw [← hm, ← Nat.cast_add]; push_cast; ring
        · have : padicValNat 2 (2 * m) = vmin + 1 + padicValNat 2 (m / 2^vmin) := sorry
          sorry
      sorry
    have h_mod k i j : deck i % 2^k = deck j % 2^k := by
      induction k with
      | zero => simp
      | succ k ih =>
        intro i' j'
        by_cases hij : i' = j'; · rw [hij]
        obtain ⟨m, hm⟩ := h_int i' j'
        have : (deck i' + deck j') = 2 * m := by apply (Nat.cast_inj (R := ℝ)).1; push_cast; rw [← hm]; ring
        sorry
    intro i j
