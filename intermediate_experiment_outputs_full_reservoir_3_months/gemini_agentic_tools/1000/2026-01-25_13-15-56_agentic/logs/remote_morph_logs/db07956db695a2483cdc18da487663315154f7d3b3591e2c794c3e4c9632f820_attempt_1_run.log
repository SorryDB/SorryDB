      obtain ⟨S, hS, hG⟩ := hGM hjk
      have h_pow : ((deck j + deck k : ℝ) / 2) ^ S.card = ∏ i ∈ S, (deck i : ℝ) := by
        rw [hG, ← Real.rpow_natCast, ← Real.rpow_mul]
        · simp [hS.ne_empty]
        · apply Finset.prod_nonneg; intro i _; simp [hpos]
      have h_rat : ((deck j + deck k : ℚ) / 2) ^ S.card = ∏ i ∈ S, (deck i : ℚ) := by
        apply (Rat.cast_inj).1; push_cast; exact h_pow
      have h_den : ((deck j + deck k : ℚ) / 2).den = 1 := by
        have h_pd := Rat.den_pow ((deck j + deck k : ℚ) / 2) S.card
        rw [h_rat] at h_pd
        have : (∏ i ∈ S, (deck i : ℚ)).den = 1 := by
          induction S using Finset.induction with
          | empty => simp
          | insert hS1 hS2 ih => rw [Finset.prod_insert hS2]; simp [ih]
        rw [this] at h_pd; simp at h_pd
        exact Nat.pow_eq_one_iff.1 h_pd.symm |>.1 (by simp [hS.ne_empty])
      have : ∃ m : ℕ, (deck j + deck k : ℚ) / 2 = m := by
        refine ⟨((deck j + deck k : ℚ) / 2).num.toNat, ?_⟩
        rw [Rat.num_den, h_den]; simp
      obtain ⟨m, hm⟩ := this
