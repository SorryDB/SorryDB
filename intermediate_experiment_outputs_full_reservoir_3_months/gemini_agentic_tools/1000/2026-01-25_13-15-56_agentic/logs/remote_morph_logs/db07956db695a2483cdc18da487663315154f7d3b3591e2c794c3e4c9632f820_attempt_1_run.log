        apply (Rat.cast_inj (α := ℚ)).1; push_cast; assumption
      rw [this, Nat.mul_mod_right]
    have h_v2 : ∀ j l, padicValNat 2 (deck j) = padicValNat 2 (deck l) := by
      intro j l
