import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hGM ↦ ?_⟩⟩
  intro i j
  have h_same_mod : ∀ k : ℕ, ∀ i j, deck i % 2^k = deck j % 2^k := by
    intro k; induction k with
    | zero => simp
    | succ k ih =>
      intro i j
      let r := deck 0 % 2^k
      have hf_mod : ∀ i, deck i % 2^k = r := fun i ↦ by rw [ih i 0]
      let f := fun i ↦ (deck i - r) / 2^k
      have hf : ∀ i, deck i = 2^k * f i + r := fun i ↦ by
        rw [Nat.div_add_mod (deck i - r) (2^k), Nat.sub_add_cancel (hf_mod i ▸ Nat.mod_le _ _), hf_mod]
      have h_f_parity : ∀ j k, f j % 2 = f k % 2 := by
        intro j k; by_cases hjk : j = k; · rw [hjk]
        obtain ⟨S, hS, hG⟩ := hGM j k hjk
        have h_avg : ((f j + f k : ℚ) + (2 * r : ℚ) / 2^k) / 2 = (∏ i ∈ S, (f i + (r : ℚ) / 2^k : ℚ)) ^ (1 / (#S : ℚ)) := by
          apply (Real.ext_rat_cast _ _).1; push_cast
          repeat rw [hf]; simp [hS.ne_empty] at hG ⊢; rw [hG, Real.rpow_rat_cast]
        have h_avg_pow : (((f j + f k : ℚ) + (2 * r : ℚ) / 2^k) / 2) ^ S.card = ∏ i ∈ S, (f i + (r : ℚ) / 2^k : ℚ) := by
          rw [h_avg, ← Rat.pow_mul]; simp [hS.ne_empty]
        sorry
      rw [hf i, hf j, Nat.add_mod, Nat.add_mod, h_f_parity i j]; simp [pow_succ, mul_comm]
  exact Nat.eq_of_forall_mod_pow_eq (by norm_num) h_same_mod

