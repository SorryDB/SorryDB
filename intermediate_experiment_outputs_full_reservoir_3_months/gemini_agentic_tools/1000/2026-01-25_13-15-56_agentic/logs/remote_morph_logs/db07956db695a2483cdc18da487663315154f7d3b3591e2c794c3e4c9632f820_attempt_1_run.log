import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hGM ↦ ?_⟩⟩
  intro i j
  by_contra h_deck
  have h_int (j k : Fin n) : ∃ m : ℕ, (deck j + deck k : ℝ) / 2 = m := by
    obtain ⟨S, hS, hGM_jk⟩ := hGM (by_contra fun h ↦ h_deck (by subst h; rfl))
    have : ((∏ i in S, deck i) : ℚ) ^ (1 / (S.card : ℚ)) = (deck j + deck k : ℚ) / 2 := by
      apply (pow_left_inj _ _ _).1
      · exact (Rational.pow_nat_pow _ _).symm
      · exact Rational.cast_nonneg.1 (by simp [hGM_jk])
      · exact Rational.cast_nonneg.1 (by simp [hGM_jk])
      · simp [hS.card_pos]
    obtain ⟨m, hm⟩ := (Rational.isInteger_pow_iff (by simp [hS.card_pos])).1 (by use deck j + deck k, 2; simp [this])
    exact ⟨m, by simp [hm, this]⟩
  have h_parity (j k : Fin n) : deck j % 2 = deck k % 2 := by
    obtain ⟨m, hm⟩ := h_int j k
    have : deck j + deck k = 2 * m := by
      apply (Finset.mul_left_inj' (two_ne_zero : (2 : ℝ) ≠ 0)).1
      rw [← hm]; field_simp
    rw [← Nat.add_mod_two_eq_zero_iff]
    simp [this]
  let d i := deck i / 2
  let r := deck 0 % 2
  have h_deck' : ∀ i, deck i = 2 * d i + r := fun i ↦ by rw [Nat.div_add_mod]
  sorry
