import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hGM ↦ ?_⟩⟩
  intro i j
  have h_int (l m : Fin n) (hlm : l ≠ m) : ∃ (z : ℕ), (deck l + deck m : ℝ) / 2 = z := by
    obtain ⟨S, hS, hG⟩ := hGM l m hlm
    have h_prod : (∏ i ∈ S, (deck i : ℚ)) = ((deck l + deck m : ℚ) / 2) ^ S.card := by
      apply (Rat.cast_inj (K := ℝ)).1
      push_cast
      rw [hG, ← Real.rpow_nat_cast, ← Real.rpow_mul]
      · simp [hS.ne_empty]
      · apply (∏ i ∈ S, _); simp [hpos]
    have h_rat : ((deck l + deck m : ℚ) / 2).den = 1 := by
      have := Rat.den_pow_nat ((deck l + deck m : ℚ) / 2) S.card
      rw [← h_prod] at this; simp at this; exact Nat.pow_eq_one_iff.1 this.symm |>.left (by simp [hS.ne_empty])
    refine ⟨((deck l + deck m : ℚ) / 2).num.toNat, ?_⟩
    lift ((deck l + deck m : ℚ) / 2) to ℕ using h_rat
    · simp [hpos]
    · simp
  have h_same_mod (k : ℕ) : ∀ i j, deck i % 2^k = deck j % 2^k := by
    induction k with
    | zero => simp
    | succ k ih =>
      intro i j
      let r := deck 0 % 2^k
      have h_mod l : deck l % 2^k = r := ih l 0
      let b l := deck l / 2^k
      have h_deck l : deck l = 2^k * b l + r := by rw [Nat.div_add_mod]
      have h_parity l m (hlm : l ≠ m) : b l % 2 = b m % 2 := by
        obtain ⟨S, hS, hG⟩ := hGM l m hlm
        obtain ⟨z, hz⟩ := h_int l m hlm
        have h_G_int : (deck l + deck m) / 2 = z := by
          apply (Nat.cast_inj (R := ℝ)).1; rw [hz]; push_cast; rfl
        if hk : k = 0 then
          simp [hk] at h_G_int ⊢; exact Nat.add_mod_two_eq_zero_iff.1 (by rw [← Nat.even_iff, ← Nat.two_dvd_iff, h_G_int]; exact dvd_mul_right 2 z)
        else
          have h_v2 : 2^k * (b l + b m) + 2*r = 2*z := by
            rw [← h_deck l, ← h_deck m, ← h_G_int]; field_simp
          have h_v2' : 2^(k-1) * (b l + b m) + r = z := by
            apply (Nat.mul_left_inj' (by norm_num)).1
            rw [← h_v2, Nat.left_distrib, Nat.mul_assoc]; congr 1; rw [← Nat.pow_succ, Nat.sub_add_cancel (Nat.one_le_of_lt (Nat.pos_of_ne_zero hk))]
          have h_even_S : (∏ i ∈ S, (deck i : ℚ)) = (z : ℚ) ^ S.card := by
            apply (Rat.cast_inj (K := ℝ)).1; push_cast; rw [hG, hz, ← Real.rpow_nat_cast, ← Real.rpow_mul]; simp [hS.ne_empty]; apply (∏ i ∈ S, _); simp [hpos]
          have h_z_mod : z % 2^k = r % 2^k := by
            have : (z : ℤ)^S.card ≡ r^S.card [ZMOD 2^k] := by
              rw [← Int.coe_nat_pow, ← h_even_S, ← Int.coe_nat_pow, Nat.prod_factors]
              apply Int.mod_eq_iff_lt.1; sorry -- Logic for modulo congruence
            sorry -- Final 2-adic steps for parity
          sorry
      have h_parity_all l m : b l % 2 = b m % 2 := by
        by_cases h : l = m; · rw [h]
        exact h_parity l m h
      rw [h_deck i, h_deck j, Nat.add_mod, Nat.add_mod, h_parity_all i j, mul_comm, Nat.mul_mod_left, Nat.mul_mod_left]; simp [pow_succ]
  exact Nat.eq_of_forall_mod_pow_eq h_same_mod
