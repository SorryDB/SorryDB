    by_contra hLT
    exact hmin (B, A) ⟨hB, hA, by rw [add_comm, mul_comm]; exact hABk⟩ (by dsimp [InvImage]; omega)
  have h_k_pos : 0 < k := by
    have h_pos : 0 < a^2 + b^2 := by positivity
    rw [hk] at h_pos; exact Nat.pos_of_ne_zero (fun h => by simp [h] at h_pos; omega)
  have h_sq : ∃ xn : ℕ, k = xn ^ 2 := by
    let x : ℤ := (k : ℤ) * B - A
    have h_int : (A:ℤ)^2 + B^2 = k * (A * B + 1) := by norm_cast; exact hABk
    have h_root : x^2 - (k * B) * x + B^2 - k = 0 := by
      calc x^2 - k * B * x + B^2 - k
        = (k * B - A)^2 - k * B * (k * B - A) + B^2 - k := rfl
        _ = (k * B)^2 - 2 * (k * B) * A + A^2 - (k * B)^2 + (k * B) * A + B^2 - k := by ring
        _ = (A^2 + B^2) - k * (A * B + 1) := by ring
        _ = 0 := by rw [h_int, sub_self]
    have h_x_alt : x * A = (B:ℤ)^2 - k := by linarith
    have h_x_nonneg : 0 ≤ x := by
      by_contra h_neg
      have h_root_alt : x^2 + B^2 = k * (x * B + 1) := by linarith
      have h_xB_neg : x * B + 1 ≤ 0 := by
        have : x ≤ -1 := by linarith
