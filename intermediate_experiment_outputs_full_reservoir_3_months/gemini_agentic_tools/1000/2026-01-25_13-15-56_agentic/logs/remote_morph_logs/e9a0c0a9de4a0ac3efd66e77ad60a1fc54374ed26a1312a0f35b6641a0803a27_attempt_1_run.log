import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  set k := (a ^ 2 + b ^ 2) / (a * b + 1) with hk
  have h_k : a ^ 2 + b ^ 2 = k * (a * b + 1) := Nat.div_mul_cancel h₁
  have : ∃ x : ℕ, x ^ 2 = k := by
    let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
    obtain ⟨⟨A₀, B₀⟩, hS₀, hmin₀⟩ := WellFounded.has_min wellFounded_lt (fun p => p.1 + p.2) ⟨(a, b), ⟨h₀.1, h₀.2, h_k⟩⟩
    let A := max A₀ B₀; let B := min A₀ B₀
    have hS : (A, B) ∈ S := ⟨by positivity, by positivity, by simpa [A, B, mul_comm, add_comm] using hS₀.2.2⟩
    have hBA : B ≤ A := Nat.min_le_max _ _
    let x : ℤ := k * B - A
    have hx_nat : ∃ xn : ℕ, x = xn := by
      refine ⟨x.toNat, ?_⟩; rw [Int.toNat_of_nonneg]; by_contra h_neg
      have hxk : x^2 + B^2 = (k : ℤ) * (x * B + 1) := by
        apply Int.add_left_cancel (a := A * x); rw [sub_add_cancel, ← hS.2.2]; ring
      have : x * B + 1 ≤ 0 := by nlinarith [hS.2.1, h_neg]
      nlinarith [hS.2.1, h_neg, (by rw [← h_k]; positivity : 0 < (k : ℤ))]
    obtain ⟨xn, rfl⟩ := hx_nat
    if hxn : xn = 0 then
      use B; apply Int.ofNat_inj.1; have : xn^2 - (k * B) * xn + B^2 - k = 0 := by
        apply Int.add_left_cancel (a := A * xn); rw [sub_add_cancel, ← hS.2.2]; ring
      simpa [hxn] using this
    else
      have hS' : (xn, B) ∈ S := ⟨Nat.pos_of_ne_zero hxn, hS.2.1, Int.ofNat_inj.1 (by push_cast; apply Int.add_left_cancel (a := A * xn); rw [sub_add_cancel, ← hS.2.2]; ring)⟩
      have : xn < A := by
        apply Int.ofNat_lt.1; have hxk : xn * A = B ^ 2 - k := by apply Int.add_left_cancel (a := A ^ 2); rw [sub_add_cancel, ← hS.2.2]; ring
        nlinarith [hxk, hBA, (by rw [← h_k]; positivity : 0 < (k : ℤ))]
      absurd (by dsimp [A, B] at *; omega : xn + B < A₀ + B₀) (hmin₀ (xn, B) hS')
  obtain ⟨x, hx⟩ := this
  use x; rw [← Nat.cast_pow, hx, hk]; push_cast; rw [Nat.cast_div h₁ (by positivity)]

