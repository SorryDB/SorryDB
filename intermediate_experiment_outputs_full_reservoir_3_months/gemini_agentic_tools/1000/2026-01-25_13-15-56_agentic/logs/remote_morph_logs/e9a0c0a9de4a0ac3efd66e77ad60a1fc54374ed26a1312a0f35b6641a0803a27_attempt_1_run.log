        have : (B : ℤ) ≥ 1 := by norm_cast; exact hS.2.1
        nlinarith
      nlinarith [h_k_pos, h_root_alt]
    obtain ⟨xn, hxn⟩ : ∃ xn : ℕ, x = (xn : ℤ) := ⟨x.toNat, by rw [Int.toNat_of_nonneg hx_nonneg]⟩
