theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  set k := (a ^ 2 + b ^ 2) / (a * b + 1) with hk_def
  have hk : a ^ 2 + b ^ 2 = k * (a * b + 1) := (Nat.div_mul_cancel h₁).symm
  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  let f := fun (p : ℕ × ℕ) => p.1 + p.2
  have hr : WellFounded (InvImage (· < ·) f) := InvImage.wf f wellFounded_lt
  obtain ⟨⟨A_pre, B_pre⟩, hS_pre, hmin_pre⟩ := hr.has_min S ⟨(a, b), h₀.1, h₀.2, hk⟩
  let A := max A_pre B_pre
  let B := min A_pre B_pre
  have hS : (A, B) ∈ S := by
    obtain ⟨h1, h2, h3⟩ := hS_pre
    refine ⟨by dsimp [A, B]; omega, by dsimp [B]; omega, ?_⟩
    dsimp [A, B]; cases le_total A_pre B_pre with
    | inl h => rwa [max_eq_right h, min_eq_left h, add_comm, mul_comm A_pre]
    | inr h => rwa [max_eq_left h, min_eq_right h]
  have hmin : ∀ p ∈ S, A + B ≤ p.1 + p.2 := by
    intro p hp; specialize hmin_pre p hp; dsimp [InvImage, f] at hmin_pre; dsimp [A, B]; omega
  have h_k_sq : ∃ xn : ℕ, k = xn ^ 2 := by
    by_contra h_not_sq
    let x : ℤ := (k : ℤ) * B - A
    have h_int : (A : ℤ) ^ 2 + (B : ℤ) ^ 2 = (k : ℤ) * (A * B + 1) := by norm_cast; exact hS.2.2
    have hx_root : x ^ 2 - (k : ℤ) * B * x + B ^ 2 - (k : ℤ) = 0 := by nlinarith [h_int]
    have hx_A : x * A = (B : ℤ) ^ 2 - (k : ℤ) := by nlinarith [h_int]
    have h_k_pos : 0 < k := by
      have h_num_pos : 0 < a ^ 2 + b ^ 2 := by nlinarith [h₀.1]
      rw [hk] at h_num_pos
      exact Nat.pos_of_mul_pos_left h_num_pos
    have hx_nonneg : 0 ≤ x := by
      by_contra h_neg
      have h_root_alt : x ^ 2 + (B : ℤ) ^ 2 = (k : ℤ) * (x * B + 1) := by nlinarith [hx_root]
      have : x * B + 1 ≤ 0 := by
        have : x ≤ -1 := by linarith
        have : (B : ℤ) ≥ 1 := by norm_cast; exact hS.2.1
        nlinarith
      nlinarith [h_k_pos]
    obtain ⟨xn, hxn⟩ : ∃ xn : ℕ, x = (xn : ℤ) := ⟨x.toNat, by rw [Int.toNat_of_nonneg hx_nonneg]⟩
    if hxn0 : xn = 0 then
      have hzk : k = B ^ 2 := by
        have : (k : ℤ) = (B : ℤ) ^ 2 := by nlinarith [hxn, hxn0, hx_A]
        norm_cast at this
      exact h_not_sq ⟨B, hzk⟩
    else
      have hxnS : (xn, B) ∈ S := by
        refine ⟨Nat.pos_of_ne_zero hxn0, hS.2.1, ?_⟩
        norm_cast; linarith [hxn, hx_root]
      have h_xn_lt_A : xn < A := by
        have h1 : (xn : ℤ) * A < (A : ℤ) * A := by
          rw [hxn, hx_A]
          have : (B : ℤ) ≤ (A : ℤ) := by norm_cast; apply min_le_max
          nlinarith [h_k_pos]
        norm_cast at h1
        exact (mul_lt_mul_right hS.1).1 h1
      specialize hmin (xn, B) hxnS; dsimp [f] at hmin; omega
  obtain ⟨xn, hxn_sq⟩ := h_k_sq
  use xn; rw [← Nat.cast_pow, ← hxn_sq, hk_def, Nat.cast_div h₁]
  · push_cast; rfl
  · positivity
