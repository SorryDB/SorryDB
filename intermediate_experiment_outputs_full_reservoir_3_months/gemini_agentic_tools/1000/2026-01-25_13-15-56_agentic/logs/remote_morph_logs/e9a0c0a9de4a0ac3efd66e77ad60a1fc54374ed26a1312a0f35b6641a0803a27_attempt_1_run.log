      nlinarith
    obtain ⟨xn, hxn⟩ : ∃ xn : ℕ, x = xn := ⟨x.toNat, by rw [Int.toNat_of_nonneg h_x_nonneg]⟩
    if hxn_zero : xn = 0 then
