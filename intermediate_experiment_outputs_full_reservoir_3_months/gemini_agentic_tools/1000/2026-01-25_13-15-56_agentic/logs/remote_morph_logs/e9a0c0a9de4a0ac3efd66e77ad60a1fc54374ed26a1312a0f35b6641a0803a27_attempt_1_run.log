    else if hAB : A = B then
      have hABk_int : (k : ℤ) * (A^2 + 1) = 2 * A^2 := by norm_cast at hABk; ring_nf at hABk; rwa [hAB] at hABk
      have h_div : (A^2 + 1 : ℤ) ∣ 2 := by
        have : (k:ℤ) * (A^2 + 1) - 2 * (A^2 + 1) = 2 * A^2 - 2 * (A^2 + 1) := by rw [hABk_int]
        ring_nf at this; rw [← sub_mul] at this; exact ⟨k - 2, this.symm⟩
      have : A = 1 := by have := Int.le_of_dvd (by norm_num) h_div; nlinarith [hA]
      use 1; rw [this] at hABk_int; norm_num at hABk_int; linarith
    else
