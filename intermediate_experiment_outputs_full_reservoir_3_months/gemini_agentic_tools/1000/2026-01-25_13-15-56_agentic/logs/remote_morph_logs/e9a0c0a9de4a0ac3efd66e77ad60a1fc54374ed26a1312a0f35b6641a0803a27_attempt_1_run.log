  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  let f := fun (p : ℕ × ℕ) => p.1 + p.2
  have hr : WellFounded (InvImage (· < ·) f) := InvImage.wf f wellFounded_lt
  obtain ⟨⟨A_pre, B_pre⟩, hS_pre, hmin_pre⟩ := hr.has_min S ⟨(a, b), h₀.1, h₀.2, hk⟩
