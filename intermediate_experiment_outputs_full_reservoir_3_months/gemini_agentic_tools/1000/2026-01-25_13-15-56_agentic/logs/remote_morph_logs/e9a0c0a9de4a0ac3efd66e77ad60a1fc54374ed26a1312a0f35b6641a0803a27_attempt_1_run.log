  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  obtain ⟨⟨A, B⟩, hSAB, hmin⟩ :=
    WellFounded.has_min (InvImage wellFounded_lt (fun p : ℕ × ℕ => p.1 + p.2)) S ⟨h₀.1, h₀.2, hk⟩
