        _ ≤ (b.val + (2 * acc).val) + 1 := Nat.add_le_add_right (Nat.mod_le _ _) _
        _ = (b.val + (ZMod.val (2 : ZMod p) * acc.val) % p) + 1 := by rw [ZMod.val_mul]
        _ ≤ b.val + ZMod.val (2 : ZMod p) * acc.val + 1 := Nat.add_le_add_right (Nat.add_le_add_left (Nat.mod_le _ _) _) _
        _ ≤ 1 + 2 * acc.val + 1 := by
          apply Nat.add_le_add_right
          apply Nat.add_le_add hb_val
          apply Nat.mul_le_mul_right
          exact Nat.mod_le 2 p
        _ = 2 * (acc.val + 1) := by ring
  have h_all : ∀ x ∈ args.toList, x = 0 ∨ x = 1 := by
    intro x hx
    rw [List.mem_iff_get] at hx
    rcases hx with ⟨i, rfl⟩
    simp [assert_bits, Vector.all_eq_true, beq_iff_eq] at h_bits
    exact h_bits ⟨i.val, by simpa using i.isLt⟩
