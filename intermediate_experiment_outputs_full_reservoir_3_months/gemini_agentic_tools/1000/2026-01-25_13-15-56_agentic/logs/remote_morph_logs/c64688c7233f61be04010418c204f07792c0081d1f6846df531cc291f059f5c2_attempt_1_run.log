lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = Exp.c (bits2num args)) := by
  intros w args e h_not_lt h
  rcases h with ⟨h_bits, rfl⟩
  simp [Exp.eval] at h_not_lt ⊢
  have h_f : ∀ (l : List (ZMod p)) (acc : ZMod p),
      (∀ x ∈ l, x = 0 ∨ x = 1) →
      (l.foldl (fun acc b => b + 2 * acc) acc).val < 2^l.length * (acc.val + 1) := by
    intro l; induction l with
    | nil => intro acc _; simp; apply Nat.lt_succ_self
    | cons b l ih =>
      intro acc hb
      simp
      specialize ih (b + 2 * acc) (fun x hx => hb x (List.mem_cons_of_mem _ hx))
      apply Nat.lt_of_lt_of_le ih
      rw [List.length_cons, Nat.pow_succ, Nat.mul_assoc, Nat.mul_comm 2]
      apply Nat.mul_le_mul_left
      have hb01 : b = 0 ∨ b = 1 := hb b (List.mem_cons_self b l)
      have hb_val : b.val ≤ 1 := by
        rcases hb01 with h0 | h1
        · rw [h0]; simp [ZMod.val_zero]
        · rw [h1]; simp [ZMod.val_one]
      calc (b + 2 * acc).val + 1
        _ ≤ (b.val + (2 * acc).val) + 1 := Nat.add_le_add_right (ZMod.val_add _ _) _
        _ ≤ b.val + 2 * acc.val + 1 := by
          apply Nat.add_le_add_right
          apply Nat.add_le_add_left
          apply Nat.le_trans (ZMod.val_mul _ _)
          apply Nat.le_trans (Nat.mod_le _ _)
          apply Nat.mul_le_mul_right
          apply Nat.mod_le
        _ ≤ 1 + 2 * acc.val + 1 := by
          apply Nat.add_le_add_right
          apply Nat.add_le_add_right
          exact hb_val
        _ = 2 * (acc.val + 1) := by ring
  have h_all : ∀ x ∈ args.toList, x = 0 ∨ x = 1 := by
    intro x hx
    rw [List.mem_iff_get] at hx
    rcases hx with ⟨i, rfl⟩
    simp [assert_bits, Vector.all_eq_true, beq_iff_eq] at h_bits
    exact h_bits i
  specialize h_f args.toList 0 h_all
  unfold bits2num Vector.foldl
  simp [args.2] at h_f
  exact h_not_lt h_f
```
