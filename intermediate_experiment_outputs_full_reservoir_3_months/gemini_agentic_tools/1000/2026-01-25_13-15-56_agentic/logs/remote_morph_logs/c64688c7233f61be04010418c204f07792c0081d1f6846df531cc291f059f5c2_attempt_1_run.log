lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = Exp.c (bits2num args)) := by
  intros w args e hne h
  rcases h with ⟨h_bits, rfl⟩
  simp [Exp.eval] at hne
  apply hne
  have hp : Nat.Prime p := Fact.out
  let f := fun (acc b : ZMod p) => b + 2 * acc
  have h_bits_l : ∀ x ∈ args.toList, x = 0 ∨ x = 1 := by
    intro x hx
    rw [List.mem_iff_get] at hx
    rcases hx with ⟨i, rfl⟩
    rw [assert_bits, Vector.all_eq_true] at h_bits
    specialize h_bits i
    simpa [beq_iff_eq] using h_bits
  have h_gen : ∀ l acc k, (∀ x ∈ l, x = 0 ∨ x = 1) → acc.val < 2^k → (List.foldl f acc l).val < 2^(l.length + k) := by
    intro l; induction l with
    | nil => intros; simp; assumption
    | cons b l ih =>
      intros acc k hb hacc
      simp only [List.foldl_cons, List.length_cons, Nat.add_succ]
      apply ih (b + 2 * acc) (k + 1)
      · intros x hx; apply hb; apply List.mem_cons_of_mem; exact hx
      · have hb01 : b = 0 ∨ b = 1 := hb b (List.mem_cons_self b l)
        have hb_val : b.val ≤ 1 := by
          rcases hb01 with rfl | rfl
          · simp [ZMod.val_zero]
          · rw [ZMod.val_one]; apply Nat.mod_eq_of_lt; exact hp.one_lt
        calc (b + 2 * acc).val
          _ = (b.val + (2 * acc).val) % p := ZMod.val_add ..
          _ ≤ b.val + (2 * acc).val := Nat.mod_le ..
          _ = b.val + (2 % p * acc.val) % p := by rw [ZMod.val_mul, ZMod.val_natCast]
          _ ≤ b.val + 2 * acc.val := by
            apply Nat.add_le_add_left
            apply Nat.le_trans (Nat.mod_le ..)
            apply Nat.mul_le_mul_right _ (Nat.mod_le 2 p)
          _ ≤ 1 + 2 * (2^k - 1) := Nat.add_le_add hb_val (Nat.mul_le_mul_left 2 (Nat.le_pred_of_lt (Nat.pow_pos (by decide)) hacc))
          _ = 2^(k+1) - 1 := by
              rw [Nat.mul_sub_left_distrib, Nat.mul_one, Nat.pow_succ, Nat.add_comm, Nat.add_sub_assoc]
              · rfl
              · exact Nat.one_le_pow _ _ (by decide)
          _ < 2^(k+1) := Nat.sub_lt (Nat.pow_pos (by decide)) (by decide)
  have h_val := h_gen args.toList 0 0 h_bits_l (by simp [ZMod.val_zero])
  simp [Nat.add_zero] at h_val
  have h_eq : bits2num args = args.toList.foldl f 0 := by
    unfold bits2num Vector.foldl
    try simp only [List.foldl_toArray', Array.foldl_toArray']
    congr
    try cases args; rfl
  rw [h_eq]
  simpa using h_val
