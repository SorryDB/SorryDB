lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = Exp.c (bits2num args)) := by
  intros w args e h_bound ⟨h_bits, h_e⟩
  simp [h_e, Exp.eval, bits2num, Vector.foldl] at h_bound
  apply h_bound
  let l := args.toList
  have hl : l.length = w := args.2
  have h_f : ∀ (l : List (ZMod p)) (acc : ZMod p),
    (∀ x ∈ l, x = 0 ∨ x = 1) → (l.foldl (fun acc b => b + 2 * acc) acc).val < 2^l.length * (acc.val + 1) := by
    intro l; induction l with
    | nil => intros; simp; exact Nat.lt_succ_self _
    | cons b l ih =>
      intros acc hb
      simp only [List.foldl_cons, List.length_cons, Nat.pow_succ']
      apply ih (b + 2 * acc) (fun x hx => hb x (List.mem_cons_of_mem _ hx))
      have h_b : b.val ≤ 1 := by
        rcases (by simpa [beq_iff_eq] using hb b (List.mem_cons_self _ _)) with h | h <;> simp [h]
      calc (b + 2 * acc).val + 1
        _ = (b.val + (2 * acc).val) % p + 1 := by rw [ZMod.val_add]
        _ ≤ (b.val + (2 * acc).val) + 1 := Nat.add_le_add_right (Nat.mod_le _ _) _
        _ = b.val + (2 * acc.val % p) + 1 := by rw [ZMod.val_mul, ZMod.val_nat_cast]
        _ ≤ b.val + 2 * acc.val + 1 := Nat.add_le_add_right (Nat.add_le_add_left (Nat.mod_le _ _) _) _
        _ ≤ 1 + 2 * acc.val + 1 := Nat.add_le_add_right (Nat.add_le_add_right h_b _) _
        _ = 2 * (acc.val + 1) := by ring
  have h_all : ∀ x ∈ l, x = 0 ∨ x = 1 := by
    intro x hx; simp [assert_bits, Vector.all_eq_true, beq_iff_eq] at h_bits
    exact h_bits x (by simpa [l] using hx)
  specialize h_f l 0 h_all
  simpa [hl] using h_f
