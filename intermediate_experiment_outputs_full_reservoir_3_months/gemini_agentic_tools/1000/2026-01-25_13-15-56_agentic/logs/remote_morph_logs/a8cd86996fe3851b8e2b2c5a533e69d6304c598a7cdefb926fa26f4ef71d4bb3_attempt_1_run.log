    rw [dist_eq_norm, ← sq_lt_sq, abs_of_nonneg (norm_nonneg _), abs_of_pos εpos]
    · dsimp [φ] at hN
      push_cast at hN
      rw [norm_add_sq_add_norm_sub_sq] at hN
      linarith
    · positivity
  obtain ⟨x, hx⟩ := cauchySeq_exists_tendsto g_cau
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg_conv n), hx⟩
