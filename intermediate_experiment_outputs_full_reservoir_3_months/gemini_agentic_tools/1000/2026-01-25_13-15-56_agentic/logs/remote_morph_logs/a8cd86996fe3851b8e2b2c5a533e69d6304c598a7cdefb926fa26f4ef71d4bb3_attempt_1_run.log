lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_conv, hg_cau_info⟩ := komlos_convex (fun x ↦ sq_nonneg ‖x‖)
    (⟨(max 0 M) ^ 2, fun n ↦ pow_le_pow_left (norm_nonneg _) ((hM n).trans (le_max_right 0 M)) 2⟩ :
      ∃ M_sq, ∀ n, ‖f n‖ ^ 2 ≤ M_sq)
  have g_cau : CauchySeq g := by
    refine cauchySeq_of_le_epsilon (fun ε εpos ↦ ?_)
    obtain ⟨N, hN⟩ := hg_cau_info (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, abs_norm]
    · simp only [NNReal.smul_def, norm_smul, NNReal.coe_inv, NNReal.coe_two, inv_pow, pow_two] at hN
      linarith [norm_add_sq_add_norm_sub_sq (g n) (g m)]
    · positivity
  obtain ⟨x, hx⟩ := g_cau.exists_tendsto
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg_conv n), hx⟩
```
