lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨g, hg_conv, hg_cau⟩ := komlos_convex (fun x ↦ ‖x‖^2) (fun x ↦ sq_nonneg _)
    (by obtain ⟨M, hM⟩ := h_bdd; exact ⟨M^2, fun n ↦ pow_le_pow_left (norm_nonneg _) (hM n) 2⟩)
  have g_cau : CauchySeq g := by
    refine cauchySeq_of_le_epsilon (fun ε hε ↦ ?_)
    obtain ⟨N, hN⟩ := hg_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, abs_norm, ← dist_sq_avg_of_sq_norm]
    · linarith
    · positivity
  obtain ⟨x, hx⟩ := g_cau.exists_tendsto
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    (convex_convexHull ℝ _).restrict_scalars (hg_conv n), hx⟩
```
