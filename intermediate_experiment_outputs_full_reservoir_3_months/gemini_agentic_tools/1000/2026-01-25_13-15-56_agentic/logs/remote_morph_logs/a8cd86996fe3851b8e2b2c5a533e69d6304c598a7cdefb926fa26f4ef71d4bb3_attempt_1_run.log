lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  rcases h_bdd with ⟨M, hM⟩
  rcases komlos_convex (fun x ↦ ‖x‖^2) (fun x ↦ sq_nonneg ‖x‖)
    ⟨max 0 M ^ 2, fun n ↦ pow_le_pow_left (norm_nonneg _) ((hM n).trans (le_max_right 0 M)) 2⟩
    with ⟨g, hg_conv, hg_cau_info⟩
  have h_cau : CauchySeq g := by
    refine cauchySeq_of_le_epsilon (fun ε hε ↦ ?_)
    rcases hg_cau_info (ε^2 / 4) (by positivity) with ⟨N, hN⟩
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, abs_norm]
    · simp only [NNReal.smul_def, norm_smul, NNReal.norm_eq, NNReal.coe_inv, NNReal.coe_two,
        inv_pow, pow_two] at hN
      linarith [norm_add_sq_add_norm_sub_sq (g n) (g m)]
    · positivity
  rcases h_cau.exists_tendsto with ⟨x, hx⟩
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    (fun _ hx _ hy _ _ ha hb hab ↦ (convex_convexHull ℝ _) hx hy ha hb hab) (hg_conv n), hx⟩

