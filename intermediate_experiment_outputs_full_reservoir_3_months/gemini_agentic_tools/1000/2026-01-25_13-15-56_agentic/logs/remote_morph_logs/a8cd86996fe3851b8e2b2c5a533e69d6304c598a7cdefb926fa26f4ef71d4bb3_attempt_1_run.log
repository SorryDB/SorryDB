    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  let φ : E → ℝ := fun x ↦ ‖x‖ ^ 2
  have hφ_nonneg : 0 ≤ φ := fun x ↦ sq_nonneg _
  have hφ_bdd : ∃ M', ∀ n, φ (f n) ≤ M' :=
    ⟨(max 0 M) ^ 2, fun n ↦ sq_le_sq.mpr (by
      rw [abs_of_nonneg (norm_nonneg _), abs_of_nonneg (le_max_right 0 M)]
      exact (hM n).trans (le_max_right 0 M))⟩
  obtain ⟨g, hg_conv, hg_cau_info⟩ := komlos_convex hφ_nonneg hφ_bdd
  have g_cau : CauchySeq g := by
    rw [Metric.cauchySeq_iff]
    intro ε εpos
