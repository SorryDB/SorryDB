```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  obtain ⟨U, hU, hU_bot⟩ := NoSmallSubgroups.exists_nhds_one_subgroup_eq_bot (G := Circle)
  obtain ⟨V, hVU, hV_open, h1V⟩ := mem_nhds_iff.mp hU
  have h_open : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ V} :=
    isOpen_induced_iff.mpr ⟨ContinuousMap.isOpen_setOf_mapsTo isCompact_univ hV_open, rfl⟩
  have h_eq : {f : PontryaginDual M | ∀ x, f x ∈ V} = {1} := by
    ext f
    simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
    constructor
    · intro hf
      ext x
      let S := Submonoid.mrange f.toMonoidHom
      let hS : IsCompact (S : Set Circle) := isCompact_range f.continuous
      let H := Submonoid.subgroupOfIsCompact S hS
      have hH : (H : Set Circle) ⊆ U := by
        rw [Submonoid.coe_subgroupOfIsCompact S hS]
        exact (Set.range_subset_iff.mpr hf).trans hVU
      have hfx : f x ∈ H := by
        rw [Submonoid.coe_subgroupOfIsCompact S hS]
        exact Set.mem_range_self x
      rw [hU_bot H hH] at hfx
      exact Subgroup.mem_bot.mp hfx
    · rintro rfl x
      exact h1V
  rwa [h_eq] at h_open

end PontryaginDual
```
