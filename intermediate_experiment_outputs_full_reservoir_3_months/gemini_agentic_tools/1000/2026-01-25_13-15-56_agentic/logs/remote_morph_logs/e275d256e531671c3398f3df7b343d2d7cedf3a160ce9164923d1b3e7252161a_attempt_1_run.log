        have : 1 / 2 < (x_ n) ^ 2 := by linarith
        rw [← Real.sq_sqrt (by linarith : (0 : ℝ) ≤ 2), one_div, Real.inv_pow, ← Real.sqrt_inv] at this
        exact Real.lt_of_pow_two_lt_pow_two (by positivity) (by linarith [hx_ n]) this
