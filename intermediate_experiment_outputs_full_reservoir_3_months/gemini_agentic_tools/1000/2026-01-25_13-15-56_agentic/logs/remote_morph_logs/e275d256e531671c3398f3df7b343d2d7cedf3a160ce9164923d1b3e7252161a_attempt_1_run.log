  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hW : IsOpen {f : PontryaginDual M | Set.MapsTo f Set.univ U} :=
    isOpen_induced_iff.mpr ⟨{f : ContinuousMap M Circle | Set.MapsTo f Set.univ U},
      ContinuousMap.isOpen_setOf_mapsTo isCompact_univ hU, by
        ext f
        simp only [Set.mem_setOf_eq, Set.MapsTo, Set.mem_univ, true_implies]⟩
  have h_eq : {f : PontryaginDual M | Set.MapsTo f Set.univ U} = {1} := by
    ext f
    simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
    constructor
    · intro hf
      ext x
      let S := f.mrange
      have hS_compact : IsCompact (S : Set Circle) := isCompact_univ.image f.continuous
      let hS_group : IsGroup S := Submonoid.isGroup_of_isCompact S hS_compact
      by_contra hx
      let z := f x
      have hzS : z ∈ S := ⟨x, rfl⟩
      have hS_U : (S : Set Circle) ⊆ U := fun w ⟨y, hy⟩ => hy ▸ hf (Set.mem_univ y)
      let x_ (n : ℕ) : ℝ := (z ^ (2 ^ n) : ℂ).re
      have hx_ (n : ℕ) : 0 < x_ n := by
        have : z ^ (2 ^ n) ∈ S := @pow_mem _ _ S.toSubmonoid hS_group.toGroup z hzS (2 ^ n)
        exact hS_U this
      have hl (n : ℕ) : x_ (n + 1) = 2 * (x_ n) ^ 2 - 1 := by
        rw [pow_succ, pow_mul, ← Circle.coe_pow]
        set w := z ^ (2 ^ n)
        have : (w : ℂ) ^ 2 = ((w : ℂ).re + Complex.I * (w : ℂ).im) ^ 2 := by rw [Complex.re_add_im]
        rw [this, sq, Complex.mul_re]
        simp only [Complex.add_re, Complex.mul_re, Complex.I_re, Complex.I_im, Complex.add_im,
          Complex.mul_im, zero_mul, one_mul, sub_self, add_zero, sub_zero]
        have : (w : ℂ).re ^ 2 + (w : ℂ).im ^ 2 = 1 := by
          rw [← Complex.normSq_apply, Circle.normSq_coe w]
        linarith
      have hx_le_one (n : ℕ) : x_ n ≤ 1 := by
        rw [← Circle.norm_coe (z ^ (2 ^ n))]; exact Complex.re_le_norm _
      have hx_ge (n : ℕ) : x_ n > 1 / Real.sqrt 2 := by
        have : 2 * (x_ n) ^ 2 - 1 > 0 := by rw [← hl]; exact hx_ (n + 1)
        rw [gt_iff_lt, sub_pos, ← mul_div_assoc, ← pow_two] at this
        exact Real.lt_sqrt_of_sq_lt (by linarith)
      have hx_dec (n : ℕ) : x_ (n + 1) ≤ x_ n := by
        rw [hl, sub_le_iff_le_add, ← sub_le_iff_le_add']
        have : 2 * (x_ n) ^ 2 - (x_ n) - 1 = (2 * x_ n + 1) * (x_ n - 1) := by ring
        rw [this]; exact mul_nonpos_of_nonneg_of_nonpos (by linarith [hx_ n]) (by linarith [hx_le_one n])
      let L := Filter.tendsto_atTop_isBounded_of_monotone hx_dec (fun n => (hx_ n).le)
      obtain ⟨l, hl_lim⟩ := L
      have hl_eq : l = 2 * l ^ 2 - 1 := by
        apply tendsto_nhds_unique (hl_lim.comp (tendsto_add_atTop_nat 1))
        simp_rw [hl]; exact ((tendsto_pow_atTop 2).const_mul _).tendsto_nhds.sub (tendsto_const_nhds) hl_lim
      have hl_val : l = 1 := by
        have : (2 * l + 1) * (l - 1) = 0 := by linarith
        cases' (mul_eq_zero.mp this) with h1 h2
        · linarith [ge_trans (le_of_tendsto hl_lim (Filter.eventually_of_forall hx_ge)) (by linarith : (1 : ℝ) / Real.sqrt 2 > -1/2)]
        · exact h2
      have : x_ 0 = 1 := by
        refine le_antisymm (hx_le_one 0) (le_of_tendsto hl_lim (Filter.eventually_of_forall hx_dec))
      have : (z : ℂ).re = 1 := this
      exact hx (Circle.coe_re_eq_one.mp this)
    · rintro rfl x -; exact zero_lt_one
  rwa [h_eq] at hW

end PontryaginDual
