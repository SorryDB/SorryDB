import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hW : IsOpen {f : PontryaginDual M | ∀ x, (f x : ℂ).re > 0} :=
    isOpen_induced_iff.mpr ⟨{f : ContinuousMap M Circle | ∀ x, (f x : ℂ).re > 0},
      ContinuousMap.isOpen_setOf_mapsTo isCompact_univ hU, rfl⟩
  have h_eq : {f : PontryaginDual M | ∀ x, (f x : ℂ).re > 0} = {1} := by
    apply Set.ext; intro f
    simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
    constructor
    · intro hf
      refine ContinuousMonoidHom.ext (fun x => ?_)
      let z := f x
      let x_ : ℕ → ℝ := fun n => ((z ^ 2 ^ n : Circle) : ℂ).re
      have hx_pos n : 0 < x_ n := by
        rw [← map_pow]; exact hf (x ^ 2 ^ n)
      have h_step n : x_ (n + 1) = 2 * (x_ n) ^ 2 - 1 := by
        dsimp [x_]; rw [pow_succ, pow_mul, pow_two]
        set w := z ^ 2 ^ n
        have h_sq : (w : ℂ).re ^ 2 + (w : ℂ).im ^ 2 = 1 := by
          rw [← Complex.normSq_apply, Complex.normSq_eq_abs, (show Complex.abs (w : ℂ) = 1 from w.2), one_pow]
        rw [Circle.val_mul, Complex.mul_re]
        linarith
      have h_le_one n : x_ n ≤ 1 := by
        rw [← (z ^ 2 ^ n).2]; exact Complex.re_le_norm _
      have h_antitone : Antitone x_ := antitone_nat_of_le_succ (fun n => by
        rw [h_step]
        have : 2 * x_ n ^ 2 - 1 - x_ n = (2 * x_ n + 1) * (x_ n - 1) := by ring
        linarith [hx_pos n, h_le_one n])
      obtain ⟨L, hL⟩ := tendsto_atTop_of_antitone_of_bounded h_antitone ⟨0, fun n => (hx_pos n).le⟩
      have L_eq : L = 1 := by
        have hL_eq : L = 2 * L ^ 2 - 1 := tendsto_nhds_unique (hL.comp (Filter.tendsto_add_atTop_nat 1))
          (by simp_rw [h_step]; exact ((hL.pow 2).const_mul 2).sub tendsto_const_nhds)
        have h_root : (2 * L + 1) * (L - 1) = 0 := by rw [← hL_eq]; ring
        have h_L_nonneg : L ≥ 0 := le_of_tendsto hL (Filter.eventually_of_forall (fun n => (hx_pos n).le))
        rcases mul_eq_zero.mp h_root with h | h <;> linarith
      have h_all_one n : x_ n = 1 := le_antisymm (h_le_one n) (le_of_tendsto hL (h_antitone.eventually_ge n))
      have h_re : (z : ℂ).re = 1 := h_all_one 0
      have h_im : (z : ℂ).im = 0 := by
        have : (z : ℂ).re ^ 2 + (z : ℂ).im ^ 2 = 1 := by
          rw [← Complex.normSq_apply, (show Complex.abs (z : ℂ) = 1 from z.2), one_pow]
        rw [h_re] at this; simpa using this
      exact Subtype.ext (Complex.ext h_re h_im)
    · rintro rfl x
      change (1 : ℂ).re > 0
      simp only [Complex.one_re, zero_lt_one]
  rwa [h_eq] at hW

end PontryaginDual
```
