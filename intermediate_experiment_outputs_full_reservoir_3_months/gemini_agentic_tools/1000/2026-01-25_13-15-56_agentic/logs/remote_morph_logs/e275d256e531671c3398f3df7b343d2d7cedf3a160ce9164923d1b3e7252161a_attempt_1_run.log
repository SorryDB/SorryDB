```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  obtain ⟨V, hV, hV_bot⟩ := TopologicalGroup.exists_nhds_one_subgroup_eq_bot (G := Circle)
  obtain ⟨U, hUV, hU, h1U⟩ := mem_nhds_iff.mp hV
  have h_open : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ U} :=
    continuous_induced_dom.isOpen_preimage _ (ContinuousMap.isOpen_gen_compact isCompact_univ hU)
  have h_eq : ({1} : Set (PontryaginDual M)) = {f | ∀ x, f x ∈ U} := by
    ext f
    simp only [Set.mem_singleton_iff, Set.mem_setOf_eq, Set.range_subset_iff]
    refine ⟨fun h x => h.symm ▸ h1U, fun hf => ?_⟩
    let H := f.toMonoidHom.mrange.toSubgroupOfIsCompact (isCompact_range f.toContinuousMap.continuous)
    have : H = ⊥ := hV_bot H ((Set.range_subset_iff.mpr hf).trans hUV)
    ext x
    simpa [this] using Set.mem_range_self x
  rwa [h_eq] at h_open

end PontryaginDual
```
