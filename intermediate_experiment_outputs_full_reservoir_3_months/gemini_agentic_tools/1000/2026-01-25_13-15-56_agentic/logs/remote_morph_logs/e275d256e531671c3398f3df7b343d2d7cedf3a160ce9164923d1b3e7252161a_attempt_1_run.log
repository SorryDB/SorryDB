```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  let U : Set Circle := {z | 0 < z.val.re}
  have hU : IsOpen U := (Complex.re_continuous.comp Circle.val_continuous).isOpen_preimage _ isOpen_Ioi
  have h1U : (1 : Circle) ∈ U := by simp [Circle.val_one, zero_lt_one]
  have h_open : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ U} :=
    continuous_induced_dom.isOpen_preimage _ (ContinuousMap.isOpen_gen_compact isCompact_univ hU)
  have h_eq : ({1} : Set (PontryaginDual M)) = {f | ∀ x, f x ∈ U} := by
    ext f
    simp only [Set.mem_singleton_iff, Set.mem_setOf_eq]
    constructor
    · rintro rfl x; exact h1U
    · intro hf
      ext x
      let S : Submonoid Circle := f.toMonoidHom.mrange
      let hS : IsCompact (S : Set Circle) := isCompact_range f.continuous
      let H : Subgroup Circle := S.toSubgroupOfIsCompact hS
      have hH : (H : Set Circle) ⊆ U := by
        rw [S.coe_toSubgroupOfIsCompact hS]
        rintro z ⟨y, rfl⟩; exact hf y
      have hH_bot : H = ⊥ := by
        contrapose! hH
        obtain ⟨z, hzH, hz1⟩ := Subgroup.ne_bot_iff.mp hH
        obtain ⟨n, hn⟩ := Circle.exists_pow_re_nonpos z hz1
        exact ⟨z ^ n, H.pow_mem hzH n, hn⟩
      have hfx : f x ∈ H := by
        rw [S.coe_toSubgroupOfIsCompact hS]
        exact ⟨x, rfl⟩
      rw [hH_bot] at hfx
      exact Subgroup.mem_bot.mp hfx
  rwa [h_eq] at h_open

end PontryaginDual
```
