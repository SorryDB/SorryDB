import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_iff_isOpen_singleton_one.mpr ?_
  let U : Set Circle := {z | 0 < (z : ℂ).re}
  have hU : IsOpen U := (Complex.continuous_re.comp continuous_subtype_val).isOpen_preimage _ isOpen_Ioi
  have hW : IsOpen {f : PontryaginDual M | Set.MapsTo f Set.univ U} :=
    isOpen_induced_iff.mpr ⟨{f : ContinuousMap M Circle | Set.MapsTo f Set.univ U},
      ContinuousMap.isOpen_setOf_mapsTo isCompact_univ hU, rfl⟩
  have h_eq : {f : PontryaginDual M | Set.MapsTo f Set.univ U} = {1} := by
    ext f
    simp only [Set.mem_setOf_eq, Set.mem_singleton_iff, Set.MapsTo, Set.mem_univ, true_implies]
    constructor
    · intro hf
      ext x
      let z := f x
      let x_ (n : ℕ) : ℝ := ((z ^ (2 ^ n) : Circle) : ℂ).re
      have hx_ (n : ℕ) : 0 < x_ n := by
        have : z ^ (2 ^ n) = f (x ^ (2 ^ n)) := (map_pow f x (2 ^ n)).symm
        rw [this]
        exact hf (x ^ (2 ^ n))
      have hl (n : ℕ) : x_ (n + 1) = 2 * (x_ n) ^ 2 - 1 := by
        dsimp [x_]
        rw [pow_succ, pow_mul, pow_two, ← Circle.val_mul, Complex.mul_re]
        have h_norm : (z ^ 2 ^ n : ℂ).re ^ 2 + (z ^ 2 ^ n : ℂ).im ^ 2 = 1 := by
          have h1 : Complex.abs (z ^ 2 ^ n : ℂ) = 1 := (z ^ 2 ^ n).2
          have h2 : Complex.normSq (z ^ 2 ^ n : ℂ) = Complex.abs (z ^ 2 ^ n : ℂ) ^ 2 := Complex.normSq_eq_abs _
          rw [← Complex.normSq_apply, h2, h1, one_pow]
        linarith
      have hx_ge (n : ℕ) : x_ n > 1 / Real.sqrt 2 := by
        have h1 := hx_ (n + 1)
        rw [hl n] at h1
        have h2 : 1 / 2 < (x_ n) ^ 2 := by linarith
        rw [← Real.sqrt_lt_sqrt_iff (by positivity), Real.sqrt_sq (hx_ n).le, Real.sqrt_div (by positivity), Real.sqrt_one] at h2
        exact h2
      have hx_dec (n : ℕ) : x_ (n + 1) ≤ x_ n := by
        rw [hl n]
        have : 2 * x_ n ^ 2 - 1 - x_ n = (2 * x_ n + 1) * (x_ n - 1) := by ring
        have h_le : x_ n ≤ 1 := by
          rw [← (show Complex.abs (z ^ 2 ^ n : ℂ) = 1 from (z ^ 2 ^ n).2)]
          exact Complex.re_le_norm _
        have : (2 * x_ n + 1) * (x_ n - 1) ≤ 0 :=
          mul_nonpos_of_nonneg_of_nonpos (by linarith [hx_ n]) (by linarith [h_le])
        linarith
      have h_conv : Filter.Tendsto x_ Filter.atTop (nhds 1) := by
        obtain ⟨L, hL⟩ := tendsto_atTop_of_antitone_of_bounded (antitone_nat_of_le_succ hx_dec) ⟨0, fun n => (hx_ n).le⟩
        have L_eq : L = 2 * L ^ 2 - 1 := by
          refine tendsto_nhds_unique (hL.comp (Filter.tendsto_add_atTop_nat 1)) ?_
          simp_rw [hl]; exact ((hL.pow 2).const_mul 2).sub tendsto_const_nhds
        have : (2 * L + 1) * (L - 1) = 0 := by linarith
        rcases mul_eq_zero.mp this with h | h
        · have : L ≥ 1 / Real.sqrt 2 := le_of_tendsto hL (Filter.eventually_of_forall hx_ge)
          exfalso; linarith [Real.sqrt_two_gt_one]
        · exact h
      have h_re0 : (z : ℂ).re = 1 := by
        refine le_antisymm (by rw [← (show Complex.abs (z : ℂ) = 1 from z.2)]; exact Complex.re_le_norm _) ?_
        exact le_of_tendsto h_conv (Filter.eventually_of_forall hx_dec)
      have h_im0 : (z : ℂ).im = 0 := by
        have : (z : ℂ).re ^ 2 + (z : ℂ).im ^ 2 = 1 := by
          rw [← Complex.normSq_apply, Complex.normSq_eq_abs, (show Complex.abs (z : ℂ) = 1 from z.2), one_pow]
        rw [h_re0] at this
        simp at this; exact this
      exact Subtype.ext (Complex.ext h_re0 h_im0)
    · rintro rfl x
      simp only [ContinuousMonoidHom.one_apply, Circle.val_one, Complex.one_re]
      exact zero_lt_one
  rwa [h_eq] at hW

end PontryaginDual
