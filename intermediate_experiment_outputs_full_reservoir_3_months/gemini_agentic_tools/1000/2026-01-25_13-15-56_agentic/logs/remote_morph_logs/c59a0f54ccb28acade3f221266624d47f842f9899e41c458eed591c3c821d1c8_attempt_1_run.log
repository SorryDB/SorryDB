          --(dies sind die Symbole in vwx)
          obtain ⟨u, v, w, x, y, h_split, h_vx, h_vwx, h_pump⟩ : ∃ u v w x y, ↑z = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ 2 ^ (↑cfg_CNF).V.card ∧ ∀ k, u * v ^ k * w * x ^ k * y ∈ ↑language :=
            (default_deriv_z₂.length.zero_le.elim (sorry))
          exact ⟨u, v, w, x, y, h_split, h_vx, h_vwx, h_pump⟩
