import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction n with
  | zero => omega
  | succ n ih =>
    cases Nat.lt_or_ge n 4 with
    | inl h =>
      interval_cases n <;> norm_num [Nat.factorial]
    | inr h =>
      have h1 : n ^ 2 ≤ n ! := ih h
      have h2 : n.succ ^ 2 = n ^ 2 + 2 * n + 1 := by ring
      have h3 : n.succ ! = n.succ * n ! := Nat.factorial_succ n
      rw [h2, h3]
      have h4 : 2 * n + 1 ≤ n * n ! := by
        have : n ! ≥ 24 := Nat.factorial_pos n |> fun _ => by
          calc n ! ≥ 4 ! := Nat.factorial_le h
            _ = 24 := by norm_num [Nat.factorial]
        omega
      calc n ^ 2 + 2 * n + 1 ≤ n ^ 2 + n * n ! := by omega
        _ = n ^ 2 + n * n ! := by ring
        _ ≤ n ! + n * n ! := by omega
        _ = n.succ * n ! := by ring
