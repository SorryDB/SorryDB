theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction n with
  | zero => omega
  | succ n ih =>
    cases Nat.lt_or_ge n 4 with
    | inl h =>
      interval_cases n <;> simp [Nat.factorial]
    | inr h =>
      have h1 : n ^ 2 ≤ n ! := ih h
      calc (n + 1) ^ 2 = n ^ 2 + 2 * n + 1 := by ring
        _ ≤ n ^ 2 + n ^ 2 := by nlinarith
        _ = 2 * n ^ 2 := by ring
        _ ≤ (n + 1) * n ^ 2 := by nlinarith
        _ ≤ (n + 1) * n ! := by nlinarith
        _ = (n + 1)! := by rw [Nat.factorial_succ, mul_comm]
```
