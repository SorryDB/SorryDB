theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction n with
  | zero => omega
  | succ n ih =>
    cases Nat.lt_or_ge n 4 with
    | inl h =>
      interval_cases n <;> simp [Nat.factorial]
    | inr h =>
      have ih' := ih h
      calc (n + 1) ^ 2 = n ^ 2 + 2 * n + 1 := by ring
        _ ≤ n ^ 2 + 2 * n + 1 := le_refl _
        _ ≤ n ! * (n + 1) := by
          have h1 : n ^ 2 ≤ n ! := ih'
          have h2 : 2 * n + 1 ≤ n * n ! := by
            have : n ! ≥ 24 := by
              have : n ! ≥ 4 ! := Nat.factorial_le h
              simp [Nat.factorial] at this
              exact this
            omega
          calc n ^ 2 + 2 * n + 1 ≤ n ! + n * n ! := by omega
            _ = n ! * (1 + n) := by ring
            _ = n ! * (n + 1) := by ring
        _ = (n + 1)! := by rw [Nat.factorial_succ, mul_comm]
