example (a b : ℝ) (ha : 0 < a) (hb : 0 < b) :
    ∫ x in a..b, 1 / x + 1 / x ^ 2 =
  log b + 1 / a - log a - 1 / b := by
  have : 0 ∉ [[a, b]] := by sorry
  rw [integral_add (by apply IntervalIntegrable.div_of_continuous; exact continuous_const; exact this)
      (by apply IntervalIntegrable.div_of_continuous; exact continuous_const; simpa using this)]
  rw [integral_one_div (ne_of_gt ha) (ne_of_gt hb)]
  have h1 : ∫ x in a..b, 1 / x ^ 2 = 1 / a - 1 / b := by
    have ha' : a ≠ 0 := ne_of_gt ha
    have hb' : b ≠ 0 := ne_of_gt hb
