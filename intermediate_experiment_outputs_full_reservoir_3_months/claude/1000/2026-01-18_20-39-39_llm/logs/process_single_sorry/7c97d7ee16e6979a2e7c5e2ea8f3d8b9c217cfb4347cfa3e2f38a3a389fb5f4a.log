lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext A
  ext x
  apply Iff.intro
  · intro hx
    obtain ⟨y, hy, hgy⟩ := hx
    obtain ⟨z, hz, hfz⟩ := hy
    rw [← hgy, ← hfz]
    have : g (f z) = z := congrFun h z
    rw [this]
    exact hz
  · intro hx
    use f x
    constructor
    · use x
    · exact congrFun h x
```
