      "\n      simp only [Coalg.toCofix]\n      rw [Cofix.dest_corec, Cofix.dest_corec]\n      have h := h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, Coalg.IsBisim] at h\n      rw [MvQPF.liftR_iff] at h ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, TypeVec.comp_assoc]\n        convert hf using 2\n        ext i x\n        cases i <;> simp [TypeVec.comp]\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, TypeVec.comp_assoc]\n        convert hg using 2\n        ext i x\n        cases i <;> simp [TypeVec.comp]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.RelLast, TypeVec.comp] at hfg ⊢\n          obtain ⟨s', t', hR', hs', ht'⟩ := hfg Fin2.fz j\n          cases hs'\n          cases ht'\n          exact ⟨s', t', hR', rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp]\n          exact hfg (Fin2.fs i) j",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map, ← TypeVec.appendFun_comp_id] at h_bisim\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, (TypeVec.id ::: fun x => Coalg.toCofix { a with s := x }) ⊚ f,\n              (TypeVec.id ::: fun x => Coalg.toCofix { b with s := x }) ⊚ g, ?_, ?_, ?_⟩\n      · simp only [MvFunctor.map_map, ← TypeVec.comp_assoc, hf]\n      · simp only [MvFunctor.map_map, ← TypeVec.comp_assoc, hg]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.RelLast, TypeVec.comp, TypeVec.appendFun] at hfg ⊢\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.RelLast, TypeVec.comp, TypeVec.appendFun] at hfg\n          obtain ⟨s', t', hR', hs', ht'⟩ := hfg\n          cases hs'\n          cases ht'\n          exact ⟨s', t', hR', rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id]\n          exact hfg (Fin2.fs i) j",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      have h := h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map, ← TypeVec.appendFun_comp_id] at h\n      rw [MvQPF.liftR_iff] at h ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [← MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hf]\n      · simp only [← MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hg]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.RelLast', TypeVec.comp, Function.comp_apply, TypeVec.appendFun]\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.RelLast', TypeVec.comp, Function.comp_apply, TypeVec.appendFun] at hfg\n          obtain ⟨s', t', hR', rfl, rfl⟩ := hfg\n          cases s' <;> cases t' <;> simp only at hR'\n          exact ⟨_, _, hR', rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp, Function.comp_apply, TypeVec.appendFun, TypeVec.id]\n          specialize hfg (Fin2.fs i) j\n          simp only [TypeVec.RelLast', TypeVec.comp, Function.comp_apply, TypeVec.appendFun, TypeVec.id] at hfg\n          exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, Coalg.IsBisim] at h_bisim\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hf]\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hg]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.IsLast, TypeVec.RelLast, TypeVec.comp, TypeVec.appendFun] at hfg ⊢\n          specialize hfg Fin2.fz j\n          cases f _ j <;> cases g _ j <;> simp_all only [Sum.inl.injEq, Sum.inr.injEq]\n          exact ⟨_, _, hfg, rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id]\n          exact hfg (Fin2.fs i) j",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map] at h_bisim\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, ?_, ?_, ?_, ?_, ?_⟩\n      · exact (TypeVec.id ::: (Coalg.toCofix ⟨a.dest', ·⟩)) ⊚ f\n      · exact (TypeVec.id ::: (Coalg.toCofix ⟨b.dest', ·⟩)) ⊚ g\n      · simp only [← hf, MvFunctor.map_map, ← TypeVec.appendFun_comp_id]\n        rfl\n      · simp only [← hg, MvFunctor.map_map, ← TypeVec.appendFun_comp_id]\n        rfl\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.comp, TypeVec.appendFun, Fin2.elim0] at hfg ⊢\n          refine ⟨f Fin2.fz j, g Fin2.fz j, ?_, rfl, rfl⟩\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.comp, TypeVec.appendFun, RelLast] at hfg\n          exact hfg\n        | fs i =>\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id] at hfg ⊢\n          specialize hfg (Fin2.fs i) j\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id, RelLast] at hfg\n          exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      have h := h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map, ← TypeVec.appendFun_comp_id] at h\n      rw [MvQPF.liftR_iff] at h ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, \n              (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [TypeVec.appendFun, TypeVec.comp] at hf ⊢\n        convert hf using 1\n        rw [← MvFunctor.map_map, ← MvFunctor.map_map]\n        congr 1\n        ext i x\n        cases i <;> rfl\n      · simp only [TypeVec.appendFun, TypeVec.comp] at hg ⊢\n        convert hg using 1\n        rw [← MvFunctor.map_map, ← MvFunctor.map_map]\n        congr 1\n        ext i x\n        cases i <;> rfl\n      · intro i x\n        cases i with\n        | fz => \n          simp only [TypeVec.comp, TypeVec.appendFun, Function.comp_apply]\n          specialize hfg Fin2.fz x\n          simp only [TypeVec.RelLast, Fin2.last, TypeVec.repeatEq] at hfg ⊢\n          exact ⟨f Fin2.fz x, g Fin2.fz x, hfg, rfl, rfl⟩\n        | fs j =>\n          simp only [TypeVec.comp, TypeVec.appendFun, Function.comp_apply]\n          specialize hfg (Fin2.fs j) x\n          simp only [TypeVec.RelLast] at hfg ⊢\n          exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, Coalg.IsBisim] at h_bisim\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, ?_, ?_, ?_, ?_, ?_⟩\n      · exact (TypeVec.id ::: fun s => Coalg.toCofix { a with s }) ⊚ f\n      · exact (TypeVec.id ::: fun t => Coalg.toCofix { b with s := t }) ⊚ g\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, TypeVec.comp]\n        convert hf using 2\n        funext i x\n        cases i <;> rfl\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, TypeVec.comp]\n        convert hg using 2\n        funext i x\n        cases i <;> rfl\n      · intro i j\n        specialize hfg i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.comp, Function.comp] at hfg ⊢\n          cases (f Fin2.fz j) with\n          | inl s' =>\n            cases (g Fin2.fz j) with\n            | inl t' => exact False.elim hfg\n            | inr t' => exact ⟨s', t', hfg, rfl, rfl⟩\n          | inr s' =>\n            cases (g Fin2.fz j) with\n            | inl t' => exact False.elim hfg\n            | inr t' => exact False.elim hfg\n        | fs i => exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map, ← TypeVec.appendFun_comp_id] at h_bisim\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [← hf, MvFunctor.map_map, TypeVec.comp_assoc]\n        congr 1\n        ext i x\n        cases i <;> rfl\n      · simp only [← hg, MvFunctor.map_map, TypeVec.comp_assoc]\n        congr 1\n        ext i x\n        cases i <;> rfl\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.IsLast, TypeVec.comp, Function.comp_apply, TypeVec.appendFun, Fin.cases_succ, Fin.cases_zero]\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.appendFun, Fin.cases_succ, Fin.cases_zero, RelLast] at hfg\n          obtain ⟨s', t', hR', hs', ht'⟩ := hfg\n          cases hs'\n          cases ht'\n          exact ⟨s', t', hR', rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp, Function.comp_apply, TypeVec.appendFun, Fin.cases_succ]\n          specialize hfg (Fin2.fs i) j\n          simp only [TypeVec.appendFun, Fin.cases_succ, RelLast] at hfg\n          exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      specialize h_bisim (.inl s) (.inr t) hR\n      rw [MvQPF.liftR_iff] at h_bisim ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_bisim\n      refine ⟨u, (TypeVec.id ::: Cofix.corec a.dest') ⊚ f, (TypeVec.id ::: Cofix.corec b.dest') ⊚ g, ?_, ?_, ?_⟩\n      · simp only [Coalg.union, ← hf, MvFunctor.map_map, ← TypeVec.appendFun_comp_id]\n        rfl\n      · simp only [Coalg.union, ← hg, MvFunctor.map_map, ← TypeVec.appendFun_comp_id]\n        rfl\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.IsRelLast'_def, TypeVec.IsRelLast'_val]\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.IsRelLast'_def, TypeVec.IsRelLast'_val, TypeVec.IsRelLast_val, TypeVec.comp, TypeVec.appendFun] at hfg ⊢\n          cases (f Fin2.fz j) with\n          | inl sl => exact ⟨sl, (g Fin2.fz j).getRight (by simp only [RelLast, TypeVec.RelLast', hfg]), hfg, rfl, rfl⟩\n          | inr sr => simp only [RelLast, TypeVec.RelLast'] at hfg\n        | fs i =>\n          specialize hfg i.fs j\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id] at hfg ⊢\n          exact hfg",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      have hbis := h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, Coalg.IsBisim] at hbis\n      rw [MvQPF.liftR_iff] at hbis ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := hbis\n      refine ⟨u, (TypeVec.id ::: (Cofix.corec a.dest')) ⊚ f, (TypeVec.id ::: (Cofix.corec b.dest')) ⊚ g, ?_, ?_, ?_⟩\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hf]\n      · simp only [MvFunctor.map_map, ← TypeVec.appendFun_comp_id, hg]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.IsRelLast] at hfg\n          specialize hfg j\n          simp only [TypeVec.IsRelLast, TypeVec.IsRelLast', TypeVec.comp, TypeVec.appendFun,\n            Fin2.elim0, TypeVec.id]\n          cases hfg.1 with\n          | inl hl => exact ⟨hl.1, hl.2, hfg.2, rfl, rfl⟩\n          | inr hr => exact ⟨hr.1, hr.2, hfg.2, rfl, rfl⟩\n        | fs i =>\n          simp only [TypeVec.comp, TypeVec.appendFun, TypeVec.id]\n          exact (hfg (Fin2.fs i) j).2",
      "\n      simp only [Coalg.toCofix, Cofix.dest_corec]\n      have h_lift := h_bisim (.inl s) (.inr t) hR\n      simp only [Coalg.union, MvFunctor.map_map, ← TypeVec.appendFun_comp_id] at h_lift\n      rw [MvQPF.liftR_iff] at h_lift ⊢\n      obtain ⟨u, f, g, hf, hg, hfg⟩ := h_lift\n      refine ⟨u, ?_, ?_, ?_, ?_, ?_⟩\n      · exact (TypeVec.id ::: fun s => Coalg.toCofix { a with s }) ⊚ f\n      · exact (TypeVec.id ::: fun t => Coalg.toCofix { b with s := t }) ⊚ g\n      · simp only [MvFunctor.map_map, ← TypeVec.comp_assoc, hf]\n      · simp only [MvFunctor.map_map, ← TypeVec.comp_assoc, hg]\n      · intro i j\n        cases i with\n        | fz =>\n          simp only [TypeVec.appendFun, TypeVec.comp] at hfg ⊢\n          specialize hfg Fin2.fz j\n          simp only [TypeVec.appendFun, TypeVec.comp] at hfg\n          cases (f Fin2.fz j) with\n          | inl s' =>\n            cases (g Fin2.fz j) with\n            | inl t' => exact False.elim (hfg)\n            | inr t' => exact ⟨s', t', hfg, rfl, rfl⟩\n          | inr s' => exact False.elim (hfg)\n        | fs i =>\n          simp only [TypeVec.appendFun, TypeVec.comp, TypeVec.id] at hfg ⊢\n          exact hfg (Fin2.fs i) j",
