lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have h1 : V(G, M') ⊆ V(G) := vertexSet_edgeSet_subset_vertexSet hM'.subset
    have h2 : V(G, M') ⊆ V(G, M) := h1.trans hsu
    have h3 : ∀ e ∈ M', ∃ f ∈ M, V(G, e) ∩ V(G, f) ≠ ∅ := by
      intro e he
      have hes : e ∈ E(G) := hM'.subset he
      obtain ⟨v, hv⟩ := vertexSet_edge_nonempty hes
      have hv' : v ∈ V(G, M) := h2 ⟨e, he, hv⟩
      obtain ⟨f, hf, hvf⟩ := hv'
      exact ⟨f, hf, Set.nonempty_iff_ne_empty.mp ⟨v, hv, hvf⟩⟩
    have h4 : ∀ e ∈ M', ∃! f, f ∈ M ∧ V(G, e) ∩ V(G, f) ≠ ∅ := by
      intro e he
      obtain ⟨f, hf, hne⟩ := h3 e he
      refine ⟨f, ⟨hf, hne⟩, ?_⟩
      intro g ⟨hg, hne'⟩
      by_contra hfg
      have : Disjoint V(G, f) V(G, g) := hM.disjoint hf hg hfg
      obtain ⟨v, hve, hvf⟩ := Set.nonempty_iff_ne_empty.mpr hne
      obtain ⟨w, hwe, hwg⟩ := Set.nonempty_iff_ne_empty.mpr hne'
      have hvg : v ∈ V(G, g) := by
        have hes : e ∈ E(G) := hM'.subset he
        have : Disjoint V(G, e) V(G, g) := hM'.disjoint he hg (by
          intro heq
          subst heq
          exact hne' (this.inter_eq ▸ rfl))
        by_contra hvng
        have : w = v := by
          have hsub : V(G, e) ⊆ V(G, M) := fun x hx => h2 ⟨e, he, hx⟩
          have hwM : w ∈ V(G, M) := hsub hwe
          obtain ⟨h, hh, hwh⟩ := hwM
          by_contra hwv
          have hfh : f ≠ h := by
            intro hfh
            subst hfh
            exact (hM.disjoint hf hg (by intro heq; subst heq; exact hne' (this.inter_eq ▸ rfl))).ne_of_mem hvf hwg hwv
          exact (hM.disjoint hf hh hfh).ne_of_mem hvf hwh (by intro heq; subst heq; exact hwv rfl)
        subst this
        exact hvng hwg
      exact this.ne_of_mem hvf hvg rfl
    choose g hg using h4
    have hinj : M'.InjOn (fun e => (g e).choose) := by
      intro e he f hf heq
      have hge := (g e).choose_spec he
      have hgf := (g f).choose_spec hf
      simp only at heq
      by_contra hne
      have disj : Disjoint V(G, e) V(G, f) := hM'.disjoint he hf hne
      have : V(G, e) ∩ V(G, (g e).choose) ≠ ∅ := hge.1.2
      have : V(G, f) ∩ V(G, (g f).choose) ≠ ∅ := hgf.1.2
      rw [← heq] at this
      obtain ⟨v, hve, hvge⟩ := Set.nonempty_iff_ne_empty.mpr hge.1.2
      obtain ⟨w, hwf, hwge⟩ := Set.nonempty_iff_ne_empty.mpr ‹V(G, f) ∩ V(G, (g e).choose) ≠ ∅›
      exact disj.ne_of_mem hve hwf (hM.disjoint hge.1.1 hge.1.1 (fun h => h ▸ disj.ne_of_mem hve hwf rfl) |>.symm.ne_of_mem hvge hwge)
    calc M'.encard = (M'.image (fun e => (g e).choose)).encard := (hinj.encard_image).symm
      _ ≤ M.encard := encard_le_encard (by intro x hx; obtain ⟨e, he, rfl⟩ := hx; exact ((g e).choose_spec he).1.1)
