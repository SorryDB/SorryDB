lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have h1 : V(G, M') ⊆ V(G, M) := by
      intro v hv
      obtain ⟨e, he, hve⟩ := hv
      have : v ∈ V(G) := Graph.inc_subset_vertexSet (hM'.subset he) hve
      exact hsu this
    have h2 : ∀ e ∈ M', ∃ f ∈ M, V(G, e) ∩ V(G, f) ≠ ∅ := by
      intro e he
      have hev : V(G, e) ⊆ V(G, M) := by
        intro v hv
        exact h1 ⟨e, he, hv⟩
      obtain ⟨v, hv⟩ := Graph.nonempty_inc (hM'.subset he)
      obtain ⟨f, hf, hvf⟩ := hev hv
      exact ⟨f, hf, Set.nonempty_iff_ne_empty.mp ⟨v, hv, hvf⟩⟩
    have h3 : ∀ e ∈ M', ∃! f, f ∈ M ∧ V(G, e) ∩ V(G, f) ≠ ∅ := by
      intro e he
      obtain ⟨f, hf, hne⟩ := h2 e he
      refine ⟨f, ⟨hf, hne⟩, ?_⟩
      intro g ⟨hg, hne'⟩
      by_contra hfg
      obtain ⟨v, hve, hvf⟩ := Set.nonempty_iff_ne_empty.mpr hne
      obtain ⟨w, hwe, hwg⟩ := Set.nonempty_iff_ne_empty.mpr hne'
      have : v = w := by
        by_contra hvw
        have hdisj := hM'.disjoint he he (fun h => hvw (by rw [h]))
        exact hdisj.ne_of_mem hve hwe hvw
      subst this
      exact (hM.disjoint hf hg hfg).ne_of_mem hvf hwg rfl
    calc M'.encard ≤ M.encard := by
      refine encard_le_of_injOn (fun e => (h3 e (by assumption)).choose) ?_ ?_
      · intro e he
        exact ((h3 e he).choose_spec).1.1
      · intro e he f hf hef
        have hce := ((h3 e he).choose_spec)
        have hcf := ((h3 f hf).choose_spec)
        by_contra hne
        have := hce.2 _ hcf.1
        rw [hef] at this
        exact hne (this rfl)
