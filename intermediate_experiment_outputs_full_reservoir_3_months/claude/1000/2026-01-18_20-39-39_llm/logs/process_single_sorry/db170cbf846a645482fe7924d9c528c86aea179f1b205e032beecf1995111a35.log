      have hv'' : v ∈ V(G, M) := h2 hv'
      obtain ⟨f, hf, hvf⟩ := hv''
      exact ⟨f, hf, Set.nonempty_iff_ne_empty.mp ⟨v, hv, hvf⟩⟩
    have h4 : ∀ e ∈ M', ∃! f, f ∈ M ∧ V(G, e) ∩ V(G, f) ≠ ∅ := by
      intro e he
      obtain ⟨f, hf, hne⟩ := h3 e he
      refine ⟨f, ⟨hf, hne⟩, ?_⟩
      intro g ⟨hg, hne'⟩
      by_contra hfg
      have : Disjoint V(G, f) V(G, g) := hM.disjoint hf hg hfg
      have hv : V(G, e) ∩ V(G, f) ≠ ∅ := hne
      have hv' : V(G, e) ∩ V(G, g) ≠ ∅ := hne'
      obtain ⟨v, hve, hvf⟩ := Set.nonempty_iff_ne_empty.mpr hv
      obtain ⟨w, hwe, hwg⟩ := Set.nonempty_iff_ne_empty.mpr hv'
      have hvw : v = w := by
        have hMv : v ∈ V(G, M) := ⟨f, hf, hvf⟩
        have hMw : w ∈ V(G, M) := ⟨g, hg, hwg⟩
        have hM'v : v ∈ V(G, M') := ⟨e, he, hve⟩
        have hM'w : w ∈ V(G, M') := ⟨e, he, hwe⟩
        by_contra hvwne
        have : Disjoint V(G, e) V(G, e) := hM'.disjoint he he (fun h => hvwne (by simp_all))
        simp at this
        exact this hve
      subst hvw
      exact this.ne_of_mem hvf hwg rfl
    choose φ hφ using h4
    have hinj : Function.Injective (fun e => if h : e ∈ M' then φ e h else Classical.arbitrary β) := by
      intro e₁ e₂ heq
      by_cases h1 : e₁ ∈ M' <;> by_cases h2 : e₂ ∈ M'
      · simp only [h1, h2, dif_pos] at heq
        have hφ1 := hφ e₁ h1
        have hφ2 := hφ e₂ h2
        by_contra hne
        have disj : Disjoint V(G, e₁) V(G, e₂) := hM'.disjoint h1 h2 hne
        rw [heq] at hφ1
        have ⟨v, hv1, hv2⟩ := Set.nonempty_iff_ne_empty.mpr hφ1.1.2
        have ⟨w, hw1, hw2⟩ := Set.nonempty_iff_ne_empty.mpr hφ2.1.2
        exact disj.ne_of_mem hv1 hw1 (by rw [← hv2, ← hw2])
      all_goals simp_all
    have hran : (fun e => if h : e ∈ M' then φ e h else Classical.arbitrary β) '' M' ⊆ M := by
      intro f hf
      obtain ⟨e, he, rfl⟩ := hf
      simp only [he, dif_pos]
