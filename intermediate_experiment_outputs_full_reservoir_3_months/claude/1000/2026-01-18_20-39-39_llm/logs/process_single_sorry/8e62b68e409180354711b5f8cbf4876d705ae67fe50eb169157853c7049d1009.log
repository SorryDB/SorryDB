```lean
/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  by_cases hs_empty : s = ∅
  · simp [hs_empty]
  · push_neg at hs_empty
    obtain ⟨x₀, hx₀⟩ := Set.nonempty_iff_ne_empty.mpr hs_empty
    -- For each point, the function is locally bounded
    have hlocal : ∀ x ∈ s, ∃ U ∈ 𝓝[s] x, IsBounded (f '' U) := by
      intro x _
      obtain ⟨l, hl⟩ := hf.left_limit x
      have hr := hf.right_continuous x
      have hbdd_right : ∃ V ∈ 𝓝[Set.Ici x] x, IsBounded (f '' V) := by
        have : Tendsto f (𝓝[Set.Ici x] x) (𝓝 (f x)) := by
          rw [← nhdsWithin_insert_of_ne_top (by simp : {x}ᶜ ≠ ⊤)]
          simp only [Set.Ioi_insert]
          exact hr.tendsto_nhdsWithin (Set.subset_insert x _)
        exact (Metric.tendsto_nhdsWithin_nhds.mp this 1 one_pos).imp fun δ ⟨hδ, hδf⟩ =>
          ⟨nhdsWithin_le_nhds (Metric.ball_mem_nhds x hδ), 
           Metric.isBounded_iff.mpr ⟨2, fun y ⟨y', hy'_mem, hy'_eq⟩ z ⟨z', hz'_mem, hz'_eq⟩ => by
             rw [← hy'_eq, ← hz'_eq]
             calc dist (f y') (f z') ≤ dist (f y') (f x) + dist (f x) (f z') := dist_triangle _ _ _
               _ < 1 + 1 := add_lt_add (hδf hy'_mem.2 hy'_mem.1) (hδf hz'_mem.2 hz'_mem.1)
               _ = 2 := one_add_one_eq_two⟩⟩
      obtain ⟨V, hV, hbV⟩ := hbdd_right
      have hbdd_left : ∃ W ∈ 𝓝[Set.Iio x] x, IsBounded (f '' W) := by
        have := Metric.tendsto_nhdsWithin_nhds.mp hl 1 one_pos
        obtain ⟨δ, hδ, hδf⟩ := this
        refine ⟨Metric.ball x δ ∩ Set.Iio x, inter_mem_nhdsWithin _ (Metric.ball_mem_nhds x hδ), ?_⟩
        refine Metric.isBounded_iff.mpr ⟨2, ?_⟩
        rintro _ ⟨y, ⟨hy1, hy2⟩, rfl⟩ _ ⟨z, ⟨hz1, hz2⟩, rfl⟩
        calc dist (f y) (f z) ≤ dist (f y) l + dist l (f z) := dist_triangle _ _ _
          _ < 1 + 1 := add_lt_add (hδf (Metric.mem_ball'.mp hy1) hy2) (hδf (Metric.mem_ball'.mp hz1) hz2)
          _ = 2 := one_add_one_eq_two
      obtain ⟨W, hW, hbW⟩ := hbdd_left
      refine ⟨(W ∪ V) ∩ s, ?_, (hbW.union hbV).subset (Set.image_mono Set.inter_subset_left)⟩
      rw [nhdsWithin]
      apply Filter.inter_mem_inf
      · have := nhdsWithin_le_nhds hW
        have := nhdsWithin_le_nhds hV
        have : W ∪ V ∈ 𝓝 x := by
          rw [← nhdsWithin_univ, ← Set.Iio_union_Ici]
          apply Filter.union_mem_sup (nhdsWithin_mono _ Set.Iio_subset_Iic_self hW)
          exact nhdsWithin_mono _ Set.Ici_subset_Ioi_self hV
        exact this
      · exact Filter.mem_principal_self s
    exact hs.isBounded_of_forall_mem hlocal
