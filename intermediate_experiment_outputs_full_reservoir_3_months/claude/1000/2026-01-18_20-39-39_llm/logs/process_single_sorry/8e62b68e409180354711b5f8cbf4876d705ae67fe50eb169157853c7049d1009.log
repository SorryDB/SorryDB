lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  apply hs.isBounded_of_forall_mem
  intro x _
  obtain ⟨l, hl⟩ := hf.left_limit x
  have hr := hf.right_continuous x
  obtain ⟨δ₁, hδ₁, h₁⟩ := Metric.tendsto_nhdsWithin_nhds.mp hl 1 one_pos
  obtain ⟨δ₂, hδ₂, h₂⟩ := Metric.tendsto_nhdsWithin_nhds.mp hr 1 one_pos
  refine ⟨Metric.ball x (min δ₁ δ₂) ∩ s, ?_, ?_⟩
  · exact inter_mem_nhdsWithin s (Metric.ball_mem_nhds x (lt_min hδ₁ hδ₂))
  · rw [Metric.isBounded_iff]
    refine ⟨4, fun a ⟨y, ⟨hy₁, _⟩, rfl⟩ b ⟨z, ⟨hz₁, _⟩, rfl⟩ => ?_⟩
    simp only [Metric.mem_ball] at hy₁ hz₁
    calc dist (f y) (f z) 
        ≤ dist (f y) (f x) + dist (f x) (f z) := dist_triangle _ _ _
      _ ≤ 2 + 2 := by
          apply add_le_add
          all_goals {
            rcases le_or_lt x _ with h | h
            · exact le_of_lt (h₂ (lt_of_lt_of_le (lt_min_iff.mp ·).2 (min_le_right _ _)) h)
            · have := h₁ (lt_of_lt_of_le (lt_min_iff.mp ·).2 (min_le_left _ _)) h
              calc dist (f _) (f x) ≤ dist (f _) l + dist l (f x) := dist_triangle _ _ _
                _ ≤ 1 + 1 := by sorry
                _ = 2 := one_add_one_eq_two }
      _ = 4 := by ring
