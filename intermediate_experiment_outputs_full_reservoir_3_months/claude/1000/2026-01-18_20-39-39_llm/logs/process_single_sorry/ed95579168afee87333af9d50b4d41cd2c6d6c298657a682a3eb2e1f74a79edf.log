    simp only [Subtype.mk.injEq, Prod.mk.injEq] at ht
    obtain ⟨⟨h1, h2⟩, h3⟩ := ht
    have hz : z = y := by linarith
    have hxy : x = y := by linarith
    simp only [S, Set.mem_setOf_eq] at hS
    obtain ⟨hS1, hxpos, hypos⟩ := hS
    have hy : y = 1 := by
      have eq1 : 4 * y * y + y ^ 2 = 4 * k + 1 := by rw [← hxy, ← hz]; exact hS1
      have eq2 : 5 * y ^ 2 = 4 * k + 1 := by nlinarith
      have hdiv : (5 : ℤ) ∣ 4 * k + 1 ∨ y = 1 ∨ y = -1 := by
        have : y ^ 2 = (4 * k + 1) / 5 ∨ 5 ∣ 4 * k + 1 := by sorry
        sorry
      interval_cases y <;> nlinarith
    simp only [Set.mem_singleton_iff, Subtype.mk.injEq]
    have hx : x = k := by nlinarith
    ext <;> simp_all
  · intro ht
    simp only [Set.mem_singleton_iff] at ht
    simp [ht]
