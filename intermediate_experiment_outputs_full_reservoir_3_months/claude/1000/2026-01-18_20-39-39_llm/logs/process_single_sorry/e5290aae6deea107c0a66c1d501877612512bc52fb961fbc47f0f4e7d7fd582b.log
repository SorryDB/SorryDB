      "\n    conv_rhs => unfold dropWhileSL\n    simp\n    by_cases hempty : lhs.isEmpty ∧ rhs.isEmpty\n    · simp [hempty, nil, fromSL, dropWhile]\n    · simp [hempty]\n      cases hhead : headSL ⟨lhs, rhs, ok⟩ with\n      | none =>\n        rw [headSL_none_iff_nilSL] at hhead\n        unfold nil at hhead; simp at hhead\n        simp [hhead.1, hhead.2] at hempty\n      | some hsl =>\n        simp\n        by_cases hp : p hsl\n        · simp [hp]\n          have hne : (⟨lhs, rhs, ok⟩ : SymList a) ≠ nil := by\n            intro hnil; rw [← headSL_none_iff_nilSL] at hnil\n            rw [hnil] at hhead; contradiction\n          have := ih (tailSL ⟨lhs, rhs, ok⟩) (length_tail_lt_length _ hne)\n          simp [Function.comp] at this\n          rw [← this]\n          cases lhs with\n          | nil =>\n            simp at hempty ok\n            have y :: [] := rhs\n            simp [headSL] at hhead; subst hhead\n            simp [fromSL, dropWhile, hp, tailSL, nil]\n          | cons x xs =>\n            simp [headSL] at hhead; subst hhead\n            simp [fromSL, dropWhile, hp, tailSL]\n            split <;> simp [fromSL, splitInTwoSL]\n        · simp [hp, fromSL]\n          cases lhs with\n          | nil =>\n            simp at hempty ok\n            have y :: [] := rhs\n            simp [headSL] at hhead; subst hhead\n            simp [fromSL, dropWhile, hp]\n          | cons x xs =>\n            simp [headSL] at hhead; subst hhead\n            simp [fromSL, dropWhile, hp]",
      "\n  unfold dropWhileSL\n  simp\n  split\n  · rename_i h\n    simp at h\n    have ⟨hl, hr⟩ := h\n    subst hl hr\n    simp [fromSL, nil, Chapter1.dropWhile]\n  · split\n    · rename_i h1 h2\n      simp at h1\n      push_neg at h1\n      unfold headSL at h2\n      split at h2 <;> simp at h2\n      rename_i heq\n      have ⟨hl, hr⟩ := heq\n      subst hl hr\n      simp at h1\n    · split\n      · rename_i h1 h2 hsl hp\n        have := length_tail_lt_length (SymList.mk lhs rhs ok) (by\n          simp only [ne_eq]\n          intro heq\n          rw [← headSL_none_iff_nilSL] at heq\n          rw [heq] at h2\n          simp at h2)\n        conv_lhs => rw [show fromSL (SymList.mk lhs rhs ok) = headSL! (SymList.mk lhs rhs ok) :: fromSL (tailSL (SymList.mk lhs rhs ok)) by\n          unfold headSL! fromSL tailSL\n          simp at h1\n          push_neg at h1\n          cases lhs with\n          | nil =>\n            simp at ok\n            cases rhs with\n            | nil => simp at h1\n            | cons y ys =>\n              simp at ok\n              subst ok\n              simp [nil]\n          | cons x xs =>\n            by_cases hxs : xs = []\n            · subst hxs\n              simp [splitInTwoSL]\n            · simp [hxs]]\n        unfold headSL at h2\n        split at h2 <;> try simp at h2\n        · rename_i heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp at h1\n        · rename_i y ys heq\n          simp at heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp at ok\n          subst ok\n          simp [headSL!, Chapter1.dropWhile, hp, h2]\n          rfl\n        · rename_i x xs ys heq\n          simp at heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp [headSL!, Chapter1.dropWhile, hp, h2]\n          rfl\n      · rename_i h1 h2 hsl hp\n        unfold headSL at h2\n        split at h2 <;> try simp at h2\n        · rename_i heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp at h1\n        · rename_i y ys heq\n          simp at heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp at ok\n          subst ok\n          simp [fromSL, Chapter1.dropWhile, hp, h2]\n        · rename_i x xs ys heq\n          simp at heq\n          have ⟨hl, hr⟩ := heq\n          subst hl hr\n          simp [fromSL, Chapter1.dropWhile, hp, h2]",
      "\n  induction lhs, rhs, ok using SymList.dropWhileSL.induct p with\n  | case1 h => simp [dropWhileSL, h, nil, fromSL, dropWhile]\n  | case2 h1 h2 => simp [dropWhileSL, h1, h2, nil, fromSL, dropWhile]\n  | case3 sl h1 h2 h3 ih =>\n    simp only [dropWhileSL, h1, ↓reduceIte, h2, h3]\n    simp [fromSL, headSL] at h2\n    split at h2 <;> simp at h2\n    simp [fromSL, dropWhile, h3, ih]\n  | case4 sl h1 h2 h3 => simp [dropWhileSL, h1, h2, h3, fromSL, dropWhile]",
      "\n  generalize hsl : (⟨lhs, rhs, ok⟩ : SymList a) = sl' at *\n  induction sl' using (measure_wf (fun s => lengthSL s)).wf.induction generalizing lhs rhs with\n  | _ sl' ih =>\n    conv_rhs => rw [dropWhileSL]\n    simp only\n    by_cases hemp : sl'.lhs.isEmpty ∧ sl'.rhs.isEmpty\n    · obtain ⟨hl, hr⟩ := hemp\n      simp only [hl, hr, and_self, ↓reduceIte, fromSL, nil]\n      simp [List.isEmpty_iff] at hl hr\n      simp [hl, hr, dropWhile]\n    · simp only [hemp, ↓reduceIte]\n      cases hhead : headSL sl' with\n      | none => simp [headSL_none_iff_nilSL] at hhead; simp [hhead, nil] at hemp\n      | some x =>\n        by_cases hp : p x <;> simp only [hp, ↓reduceIte]\n        · have hne : sl' ≠ nil := by intro h; rw [← headSL_none_iff_nilSL] at h; simp [h] at hhead\n          have := length_tail_lt_length sl' hne\n          rw [← ih (tailSL sl') this rfl]\n          have := congrArg fromSL (congrArg tailSL hsl.symm)\n          simp at this\n          conv_lhs => rw [← this]\n          clear this\n          have htail : fromSL (tailSL sl') = tail (fromSL sl') := by\n            have ⟨xs, ys, ok'⟩ := sl'\n            cases xs with\n            | nil => simp [fromSL, tailSL, nil] at *; simp at ok'; simp [ok']\n            | cons a as =>\n              by_cases has : as = []\n              · simp [has, tailSL, splitInTwoSL, fromSL]\n              · simp [tailSL, has, fromSL]\n          rw [htail]\n          have hfromhead : (fromSL sl').head? = some x := by\n            have := congrArg headSL hsl.symm\n            simp at this\n            rw [← this] at hhead\n            have : List.head? ∘ fromSL = @headSL a := by\n              funext s; have ⟨l, r, o⟩ := s; simp [Function.comp, headSL, fromSL]\n              split <;> (rename_i h; simp at h; have ⟨ha, hb⟩ := h; subst ha hb; simp)\n              simp at o; simp [o]\n            have := congrFun this ⟨lhs, rhs, ok⟩\n            simp [Function.comp] at this\n            rw [this, hhead]\n          cases hfsl : fromSL sl' with\n          | nil => simp at hfromhead\n          | cons y ys => simp at hfromhead; simp [hfromhead, dropWhile, hp]\n        · rfl",
      "\n  unfold dropWhileSL\n  simp\n  split\n  · rename_i h\n    simp at h\n    have ⟨hl, hr⟩ := h\n    simp [hl, hr, fromSL, nil, dropWhile]\n  · split\n    · rename_i h1 h2\n      simp at h1\n      push_neg at h1\n      simp [headSL] at h2\n      split at h2\n      · rename_i heq\n        simp at heq\n        have ⟨ha, hb⟩ := heq\n        subst ha hb\n        simp at h1\n      · contradiction\n      · contradiction\n    · rename_i h1 hsl\n      split\n      · rename_i hp\n        simp [fromSL, headSL] at hsl\n        split at hsl\n        · rename_i heq\n          simp at heq\n          have ⟨ha, hb⟩ := heq\n          subst ha hb\n          simp at h1\n        · rename_i heq\n          simp at heq ok\n          have ⟨ha, hb⟩ := heq\n          subst ha\n          have y :: [] := rhs\n          simp at hsl\n          subst hsl\n          simp [fromSL, dropWhile, hp, tailSL, nil, splitInTwoSL]\n        · rename_i x xs heq\n          simp at hsl\n          subst hsl\n          simp [fromSL, dropWhile, hp, tailSL]\n          by_cases hxs : xs = []\n          · subst hxs\n            simp [splitInTwoSL, fromSL]\n          · simp [hxs, fromSL]\n            rfl\n      · rename_i hp\n        simp [fromSL, headSL] at hsl\n        split at hsl\n        · rename_i heq\n          simp at heq\n          have ⟨ha, hb⟩ := heq\n          subst ha hb\n          simp at h1\n        · rename_i heq\n          simp at heq ok\n          have ⟨ha, hb⟩ := heq\n          subst ha\n          have y :: [] := rhs\n          simp at hsl\n          subst hsl\n          simp [fromSL, dropWhile, hp]\n        · rename_i x xs heq\n          simp at hsl\n          subst hsl\n          simp [fromSL, dropWhile, hp]",
      "\n  induction sl using (measure_wf (fun s => lengthSL s)).wf.recursion with\n  | _ sl ih =>\n    have ⟨lhs, rhs, ok⟩ := sl\n    unfold dropWhileSL\n    simp only\n    by_cases hempty : lhs.isEmpty ∧ rhs.isEmpty\n    · simp [hempty, nil, fromSL, dropWhile]\n      obtain ⟨hl, hr⟩ := hempty\n      simp [List.isEmpty_iff] at hl hr\n      simp [hl, hr]\n    · simp [hempty]\n      cases hhead : headSL ⟨lhs, rhs, ok⟩ with\n      | none =>\n        simp [nil, fromSL]\n        rw [headSL_none_iff_nilSL] at hhead\n        unfold nil at hhead\n        simp at hhead\n        obtain ⟨hl, hr⟩ := hhead\n        simp [hl, hr, dropWhile]\n      | some hsl =>\n        by_cases hp : p hsl\n        · simp [hp]\n          have hne : ⟨lhs, rhs, ok⟩ ≠ nil := by\n            intro heq\n            rw [← headSL_none_iff_nilSL] at heq\n            rw [heq] at hhead\n            contradiction\n          have hlt : lengthSL (tailSL ⟨lhs, rhs, ok⟩) < lengthSL ⟨lhs, rhs, ok⟩ :=\n            length_tail_lt_length ⟨lhs, rhs, ok⟩ hne\n          rw [← ih (tailSL ⟨lhs, rhs, ok⟩) hlt]\n          conv_lhs => rw [← tail (fromSL ⟨lhs, rhs, ok⟩)]\n          congr 1\n          · have : fromSL (tailSL ⟨lhs, rhs, ok⟩) = tail (fromSL ⟨lhs, rhs, ok⟩) := by\n              exact (fun as => rfl) ⟨lhs, rhs, ok⟩\n            rw [this]\n            simp only [headSL, fromSL] at hhead\n            split at hhead <;> simp at hhead\n            · rename_i h\n              simp at h\n              obtain ⟨hl, hr⟩ := h\n              simp [hl, hr]\n            · rename_i h\n              simp at h\n              obtain ⟨hl, hr⟩ := h\n              simp [fromSL, hl]\n              rw [dropWhile]\n              simp [← hhead, hp]\n            · simp [fromSL]\n              rw [dropWhile]\n              simp [← hhead, hp]\n          · rfl\n        · simp [hp, fromSL]\n          simp only [headSL, fromSL] at hhead\n          split at hhead <;> simp at hhead\n          · rename_i h; simp at h; obtain ⟨hl, hr⟩ := h; simp [hl, hr, dropWhile]\n          · rename_i h; simp at h; obtain ⟨hl, hr⟩ := h\n            simp [hl]\n            have : rhs = [hsl] := by simp at ok; exact ok\n            simp [this, dropWhile, ← hhead, hp]\n          · rename_i x xs\n            simp [dropWhile, ← hhead, hp]",
      "\n  unfold dropWhileSL\n  simp\n  split\n  · rename_i h\n    have ⟨hl, hr⟩ := h\n    simp at hl hr\n    subst hl hr\n    simp [fromSL, nil, dropWhile]\n  · rename_i hne\n    push_neg at hne\n    split\n    · rename_i hhead\n      simp [headSL] at hhead\n      split at hhead <;> simp at hhead\n    · rename_i x hhead\n      simp [headSL] at hhead\n      split at hhead\n      · simp at hhead\n      · rename_i heq\n        simp at heq hhead\n        have ⟨ha, hb⟩ := heq\n        subst ha hb\n        simp at ok\n        cases ok with\n        | inl h => simp [h] at hhead\n        | inr h =>\n          have y :: [] := rhs\n          simp at hhead\n          subst hhead\n          split\n          · rename_i hp\n            simp [fromSL, dropWhile, hp, tailSL, nil, splitInTwoSL]\n          · rename_i hp\n            simp [fromSL, dropWhile, hp]\n      · rename_i x' xs' heq\n        simp at hhead\n        subst hhead\n        split\n        · rename_i hp\n          simp [fromSL, dropWhile, hp]\n          have : lengthSL (tailSL ⟨x' :: xs', rhs, ok⟩) < lengthSL ⟨x' :: xs', rhs, ok⟩ := by\n            apply length_tail_lt_length\n            simp [nil]\n          conv_rhs => rw [← Function.comp_apply (f := fromSL) (g := dropWhileSL p)]\n          have := congrFun (congrArg (fromSL ∘ ·) rfl) (tailSL ⟨x' :: xs', rhs, ok⟩)\n          rw [← tailSL]\n          simp [tailSL]\n          by_cases hxs : xs' = []\n          · subst hxs\n            simp [splitInTwoSL, fromSL]\n            conv_lhs => rw [← Function.comp_apply (f := fromSL) (g := dropWhileSL p)]\n            congr 1\n            funext sl'\n            simp [Function.comp]\n          · simp [hxs, fromSL]\n            conv_lhs => rw [← Function.comp_apply (f := fromSL) (g := dropWhileSL p)]\n            congr 1\n            funext sl'\n            simp [Function.comp]\n        · rename_i hp\n          simp [fromSL, dropWhile, hp]\ntermination_by sl.lengthSL",
      "\n  generalize hs : SymList.mk lhs rhs ok = sl'\n  induction sl' using SymList.dropWhileSL.induct p generalizing lhs rhs ok with\n  | _ => simp_all [dropWhileSL, fromSL, nil, dropWhile, headSL, tailSL]",
      "\n          rw [ih]\n          congr 1\n          simp [fromSL] at hhead ⊢\n          cases lhs with\n          | nil =>\n            cases rhs with\n            | nil => simp at hempty\n            | cons y ys => simp at hhead ok; subst hhead; simp [dropWhile, hp, tailSL, nil]\n          | cons x xs =>\n            simp at hhead; subst hhead\n            simp [dropWhile, hp]\n            exact congrArg fromSL rfl |> fun _ => by\n              have : fromSL (tailSL ⟨x :: xs, rhs, ok⟩) = (fromSL ⟨x :: xs, rhs, ok⟩).tail := by\n                simp [fromSL, tailSL]\n                by_cases hxs : xs = [] <;> simp [hxs, splitInTwoSL]\n              rw [this, fromSL]; simp\n        · simp [hp]",
      "\n  induction lhs, rhs, ok using SymList.dropWhileSL.induct p with\n  | _ lhs rhs ok hempty => simp [hempty, dropWhileSL, fromSL, nil, dropWhile, List.isEmpty_iff.mp hempty.1, List.isEmpty_iff.mp hempty.2]\n  | _ lhs rhs ok hne hnone => simp [headSL_none_iff_nilSL, nil] at hnone; simp [hnone.1, hnone.2] at hne\n  | _ lhs rhs ok hne hsome hp ih => simp [dropWhileSL, hne, hsome, hp, ← ih]; sorry\n  | _ lhs rhs ok hne hsome hp => simp [dropWhileSL, hne, hsome, hp, fromSL]; sorry",
      "\n  generalize hsl : SymList.mk lhs rhs ok = sl'\n  have hlen : lengthSL sl' = lhs.length + rhs.length := by simp [← hsl, lengthSL]\n  clear ok hsl\n  induction sl' using SymList.dropWhileSL.induct p with\n  | case1 sl hempty =>\n    simp [SymList.dropWhileSL, hempty, SymList.nil, fromSL, dropWhile]\n  | case2 sl hne hnone =>\n    simp [SymList.dropWhileSL, hne, hnone, SymList.nil, fromSL]\n    rw [SymList.headSL_none_iff_nilSL] at hnone\n    simp [hnone, SymList.nil, fromSL, dropWhile]\n  | case3 sl hne hsome hsl hp ih =>\n    simp only [SymList.dropWhileSL, hne, hsome, hp, ↓reduceIte]\n    rw [← ih]\n    have heq : List.head? (fromSL sl) = some hsl := by\n      have := congrFun (by rfl : List.head? ∘ fromSL = @headSL a) sl\n      simp [Function.comp] at this\n      rw [this, hsome]\n    cases hfrom : fromSL sl with\n    | nil => simp [fromSL] at hfrom; rw [hfrom] at heq; simp at heq\n    | cons x xs =>\n      simp at heq\n      subst heq\n      simp [dropWhile, hp]\n      have := congrFun (by rfl : ∀ (as : SymList a), fromSL (tailSL as) = tail (fromSL as)) sl\n      simp [hfrom, List.tail] at this\n      exact this.symm\n  | case4 sl hne hsome hsl hnp =>\n    simp [SymList.dropWhileSL, hne, hsome, hnp]\n    have heq : List.head? (fromSL sl) = some hsl := by\n      have := congrFun (by rfl : List.head? ∘ fromSL = @headSL a) sl\n      simp [Function.comp] at this\n      rw [this, hsome]\n    cases hfrom : fromSL sl with\n    | nil => simp [fromSL] at hfrom; rw [hfrom] at heq; simp at heq\n    | cons x xs =>\n      simp at heq\n      subst heq\n      simp [dropWhile, hnp]",
