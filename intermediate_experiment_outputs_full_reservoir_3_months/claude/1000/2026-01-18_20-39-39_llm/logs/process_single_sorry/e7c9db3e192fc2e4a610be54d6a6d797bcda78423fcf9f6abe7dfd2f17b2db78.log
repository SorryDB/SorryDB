-- 2.
lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  set g : ↑(A \ {a}) → ↑(B \ {b}) := fun x =>
    ⟨f x.val, by
      constructor
      · rw [← h2]
        exact ⟨x.val, x.property.left, rfl⟩
      · intro hfx
        rw [Set.mem_singleton_iff] at hfx
        have : x.val = a := h1 x.property.left h3 hfx
        exact x.property.right this⟩
  apply Exists.intro g
  constructor
  · -- one_to_one g
    intro x1 x2 hg
    have : f x1.val = f x2.val := by
      have := congrArg Subtype.val hg
      exact this
    have heq : x1.val = x2.val := h1 x1.property.left x2.property.left this
    exact Subtype.ext heq
  · -- onto g
    intro ⟨y, hy⟩
    have hyB : y ∈ B := hy.left
    rw [← h2] at hyB
    obtain ⟨x, hxA, hfx⟩ := hyB
    have hxna : x ≠ a := by
      intro hxa
      rw [hxa, h4] at hfx
      exact hy.right hfx
    use ⟨x, hxA, hxna⟩
    apply Subtype.ext
    exact hfx
