lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  constructor
  · intro hv
    have hx : x ∈ 𝒪[K] := by
      rw [ValuativeRel.mem_integers_iff]
      simp [hv]
    have hx_ne : x ≠ 0 := by
      intro h
      simp [h] at hv
    have hx_inv : x⁻¹ ∈ 𝒪[K] := by
      rw [ValuativeRel.mem_integers_iff]
      simp [map_inv₀, hv]
    use ⟨⟨x, hx⟩, ⟨x⁻¹, hx_inv⟩, by simp [mul_inv_cancel₀ hx_ne], by simp [inv_mul_cancel₀ hx_ne]⟩
    rfl
  · rintro ⟨r, rfl⟩
    exact ValuativeRel.valuation_unit r
