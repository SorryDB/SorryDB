      ext
      simp [inv_mul_cancel₀ hx_ne]
    exact ⟨⟨x', x'_inv, h_mul, h_mul'⟩, rfl⟩
  · intro ⟨r, hr⟩
    simp [hr, ValuativeRel.valuation_isUnit]
