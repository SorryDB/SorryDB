lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  constructor
  · intro hx
    have hx_ne : x ≠ 0 := by
      intro h
      simp [h] at hx
    have hx_mem : x ∈ 𝒪[K] := by
      rw [ValuativeRel.mem_integerSubring]
      simp [hx]
    have hx_inv_mem : x⁻¹ ∈ 𝒪[K] := by
      rw [ValuativeRel.mem_integerSubring]
      simp [map_inv₀, hx]
    let x' : 𝒪[K] := ⟨x, hx_mem⟩
    let x'_inv : 𝒪[K] := ⟨x⁻¹, hx_inv_mem⟩
    have h_mul : x' * x'_inv = 1 := by
      ext
