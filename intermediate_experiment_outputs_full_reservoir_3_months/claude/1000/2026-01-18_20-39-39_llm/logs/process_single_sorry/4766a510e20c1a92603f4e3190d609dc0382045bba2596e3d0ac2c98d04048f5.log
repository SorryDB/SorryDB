    have hx_inv_mem : x⁻¹ ∈ 𝒪[K] := by
      rw [ValuationSubring.mem_toSubring, Valuation.mem_valuationSubring_iff]
      simp [hx]
    refine ⟨⟨⟨x, hx_mem⟩, ⟨x⁻¹, hx_inv_mem⟩, ?_, ?_⟩, rfl⟩
    · ext; simp [mul_inv_cancel₀ hx_ne]
    · ext; simp [inv_mul_cancel₀ hx_ne]
  · rintro ⟨r, rfl⟩
    have hr : (r : K) ≠ 0 := Units.ne_zero _
    have h1 : (valuation K) r ≤ 1 := r.val.prop
    have h2 : (valuation K) r⁻¹ ≤ 1 := r.inv.val.prop
    rw [show (r : K)⁻¹ = (r⁻¹ : 𝒪[K]ˣ) from rfl] at h2
    have h3 : (valuation K) r * (valuation K) (r⁻¹ : 𝒪[K]ˣ) = 1 := by
      rw [← Valuation.map_mul]
      simp [mul_inv_cancel₀ hr]
    by_contra h
    push_neg at h
    interval_cases (valuation K) r <;> simp_all
