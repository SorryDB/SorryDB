      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have ha_le_N : a ≤ N := le_trans ha hxN\n    have h_diff_sub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ \n        (B N hN \\ {x}) ∪ (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff, Set.mem_union] at hy ⊢\n      obtain ⟨⟨N', hN', hyB'⟩, hyx⟩ := hy\n      by_cases hNN' : N' = N\n      · left; subst hNN'; exact ⟨hyB', hyx⟩\n      · right; exact ⟨N', hN', hNN', hyB'⟩\n    have h1 : a ≤ sSup (B N hN \\ {x}) := by\n      have hSupOther : sSup (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') ≤ sSup (D.carrier \\ {N}) := by\n        apply sSup_le; intro y hy\n        simp only [Set.mem_iUnion] at hy\n        obtain ⟨N', hN', hNN', hyB'⟩ := hy\n        have : y ≤ N' := by rw [hB N' hN']; exact le_sSup hyB'\n        exact le_trans this (le_sSup (Set.mem_diff_of_mem hN' hNN'))\n      have hDisjN : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep'.disjoint_sSup hN Set.diff_subset (Set.not_mem_diff_of_mem rfl)\n      have ha_disj : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') := by\n        apply le_trans ha'\n        apply le_trans (sSup_le_sSup h_diff_sub)\n        exact sSup_union_le_sSup_sup_sSup\n      have : a ⊓ sSup (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') ≤ ⊥ := by\n        apply le_trans (inf_le_inf_right _ ha_le_N)\n        apply le_trans (inf_le_inf_left _ hSupOther)\n        exact disjoint_iff_inf_le.mp hDisjN\n      exact Disjoint.left_le_of_le_sup_right ha_disj (disjoint_iff_inf_le.mpr this)\n    exact (hB' N hN).disjoint_sSup hxB Set.diff_subset (Set.not_mem_diff_of_mem rfl) (le_inf ha h1)",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    -- Split the complement into parts inside B N hN and outside N\n    have hsub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ \n                (B N hN \\ {x}) ∪ (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion, Set.mem_union] at hy ⊢\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases h : N' = N\n      · left; exact ⟨h ▸ hyB, hyx⟩\n      · right; exact ⟨N', hN', h, hyB⟩\n    have ha'_le : a ≤ sSup ((B N hN \\ {x}) ∪ (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN')) :=\n      le_trans ha' (sSup_le_sSup hsub)\n    rw [sSup_union] at ha'_le\n    have hDisjN : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN (fun x hx => hx) (Set.not_mem_diff_of_mem (Set.mem_singleton N))\n    have hOutside : sSup (⋃ N', ⋃ (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨N', hN', hNeq, hyB⟩ := hy\n      have hyN' : y ≤ N' := by rw [hB N' hN']; exact le_sSup hyB\n      apply le_trans hyN'\n      apply le_sSup\n      exact ⟨hN', hNeq⟩\n    have haInN : a ≤ N ⊓ (sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N})) := by\n      apply le_inf haN\n      exact le_trans ha'_le (sup_le_sup_left hOutside _)\n    rw [inf_sup_left] at haInN\n    have hDisjN' : N ⊓ sSup (D.carrier \\ {N}) = ⊥ := disjoint_iff_inf_le.mp hDisjN\n    rw [hDisjN', sup_bot_eq] at haInN\n    have hInB : N ⊓ sSup (B N hN \\ {x}) ≤ sSup (B N hN \\ {x}) := inf_le_right\n    have ha_final : a ≤ sSup (B N hN \\ {x}) := le_trans haInN hInB\n    exact (hB' N hN).disjoint_sSup hxB (fun y hy => hy) (Set.not_mem_diff_of_mem (Set.mem_singleton x)) ⟨ha, ha_final⟩",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    have hsub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ sSup D := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy\n      obtain ⟨⟨M, hM, hyB⟩, _⟩ := hy\n      have hyM : y ≤ M := by rw [hB M hM]; exact le_sSup hyB\n      exact le_trans hyM (le_sSup hM)\n    have hBxsub : B N hN \\ {x} ⊆ (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy ⊢\n      exact ⟨⟨N, hN, hy.1⟩, hy.2⟩\n    have ha'B : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N}) := by\n      apply le_trans ha'\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy\n      obtain ⟨⟨M, hM, hyB⟩, hyx⟩ := hy\n      by_cases hMN : M = N\n      · apply le_sup_of_le_left; apply le_sSup; exact ⟨hMN ▸ hyB, hyx⟩\n      · apply le_sup_of_le_right; apply le_sSup; exact ⟨hM, hMN⟩\n    have hdisj : Disjoint N (sSup (D.carrier \\ {N})) := \n      D.sSupIndep.disjoint_sSup hN Set.diff_subset (Set.not_mem_diff_of_mem rfl)\n    have hdisj' : Disjoint x (sSup (B N hN \\ {x})) := \n      (hB' N hN).disjoint_sSup hxB Set.diff_subset (Set.not_mem_diff_of_mem rfl)\n    have h1 : a ≤ x ⊓ sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N}) := by\n      apply le_trans (le_inf ha ha'B)\n      simp only [inf_sup_left]\n      exact sup_le_sup_right inf_le_right _\n    have h2 : a ≤ ⊥ ⊔ sSup (D.carrier \\ {N}) := le_trans h1 (sup_le_sup_right (disjoint_iff.mp hdisj') _)\n    simp only [bot_sup_eq] at h2\n    exact disjoint_iff.mp hdisj (le_inf haN h2)",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    exact (hB' N hN).disjoint_sSup hxB Set.diff_subset (Set.not_mem_diff_of_mem rfl) \n      ⟨ha, le_trans ha' (sSup_le_sSup (Set.diff_subset_diff (Set.subset_iUnion₂ N hN) (Set.Subset.refl _)))⟩",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    -- x is in B N hN, and we need to use sSupIndep properties\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    -- Split the complement into parts inside B N hN and outside\n    have hsub : (⋃ N', ⋃ hN', B N' hN') \\ {x} ⊆ \n                (B N hN \\ {x}) ∪ (⋃ N', ⋃ hN', B N' hN' \\ B N hN) := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_union, Set.mem_iUnion] at hy ⊢\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases h : y ∈ B N hN\n      · left; exact ⟨h, hyx⟩\n      · right; exact ⟨N', hN', hyB, h⟩\n    have ha'' : a ≤ sSup ((B N hN \\ {x}) ∪ (⋃ N', ⋃ hN', B N' hN' \\ B N hN)) := \n      le_trans ha' (sSup_le_sSup hsub)\n    rw [sSup_union] at ha''\n    have hpart1 : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ N', ⋃ hN', B N' hN' \\ B N hN) := ha''\n    have hother_le : sSup (⋃ N', ⋃ hN', B N' hN' \\ B N hN) ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion, Set.mem_diff] at hy\n      obtain ⟨N', hN', hyB, hynotB⟩ := hy\n      have hyN' : y ≤ N' := by rw [hB N' hN']; exact le_sSup hyB\n      have hN'neN : N' ≠ N := by\n        intro heq; subst heq; exact hynotB hyB\n      apply le_trans hyN'\n      exact le_sSup (by simp [hN', hN'neN] : N' ∈ D.carrier \\ {N})\n    have hdisj_N : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep hN\n    have ha_disj : a ≤ N ⊓ sSup (D.carrier \\ {N}) := by\n      apply le_inf haN\n      calc a ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ N', ⋃ hN', B N' hN' \\ B N hN) := hpart1\n           _ ≤ N ⊔ sSup (D.carrier \\ {N}) := by\n               apply sup_le_sup\n               · rw [hB N hN]; exact sSup_le_sSup (Set.diff_subset)\n               · exact hother_le\n           _ = sSup (D.carrier \\ {N}) := by\n               rw [sup_comm, sup_eq_left]\n               exact le_sSup_of_le hN le_rfl\n    rw [disjoint_iff_inf_le] at hdisj_N\n    exact le_trans ha_disj hdisj_N",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hBN_indep := hB' N hN\n    have hD_indep := D.sSupIndep\n    have hN_eq : N = sSup (B N hN) := hB N hN\n    -- a ≤ x and x ∈ B N hN, so a ≤ N\n    have ha_le_N : a ≤ N := ha.trans (hN_eq ▸ le_sSup hxB)\n    -- The complement splits into: (B N hN \\ {x}) and things from other N' ≠ N\n    have hsub : (⋃ M, ⋃ (hM : M ∈ D), B M hM) \\ {x} ⊆ (B N hN \\ {x}) ∪ ⋃ (M : PersistenceSubmodule M) (hM : M ∈ D) (_ : M ≠ N), B M hM := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff, Set.mem_union] at hy ⊢\n      obtain ⟨⟨M, hM, hyM⟩, hyx⟩ := hy\n      by_cases hMN : M = N\n      · left; exact ⟨hMN ▸ hyM, hyx⟩\n      · right; exact ⟨M, hM, hMN, hyM⟩\n    have hother_le : sSup (⋃ (M : PersistenceSubmodule M) (hM : M ∈ D) (_ : M ≠ N), B M hM) ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le; intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨M, hM, hMN, hyM⟩ := hy\n      exact le_sSup_of_le ⟨hM, hMN⟩ ((hB M hM) ▸ le_sSup hyM)\n    have ha'_bound : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N}) := by\n      calc a ≤ sSup ((⋃ M, ⋃ (hM : M ∈ D), B M hM) \\ {x}) := ha'\n        _ ≤ sSup ((B N hN \\ {x}) ∪ ⋃ (M : PersistenceSubmodule M) (hM : M ∈ D) (_ : M ≠ N), B M hM) := sSup_le_sSup hsub\n        _ ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ (M : PersistenceSubmodule M) (hM : M ∈ D) (_ : M ≠ N), B M hM) := sSup_union_le_sSup_sup_sSup\n        _ ≤ sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N}) := sup_le_sup_left hother_le _\n    have hdisjN : Disjoint N (sSup (D.carrier \\ {N})) := hD_indep hN\n    have hdisjx : Disjoint x (sSup (B N hN \\ {x})) := hBN_indep hxB\n    have hBN_sub_N : sSup (B N hN \\ {x}) ≤ N := by rw [hN_eq]; exact sSup_le_sSup Set.diff_subset\n    calc a ≤ a ⊓ x := by rw [inf_eq_left]; exact ha\n      _ ≤ (sSup (B N hN \\ {x}) ⊔ sSup (D.carrier \\ {N})) ⊓ x := inf_le_inf_right x ha'_bound\n      _ = (sSup (B N hN \\ {x}) ⊓ x) ⊔ (sSup (D.carrier \\ {N}) ⊓ x) := inf_sup_right _ _ _\n      _ ≤ (x ⊓ sSup (B N hN \\ {x})) ⊔ (N ⊓ sSup (D.carrier \\ {N})) := by\n          apply sup_le_sup\n          · exact inf_comm _ _ ▸ le_rfl\n          · exact inf_le_inf_right _ (hN_eq ▸ le_sSup hxB)\n      _ ≤ ⊥ ⊔ ⊥ := sup_le_sup hdisjx.le_bot (by rw [inf_comm]; exact hdisjN.le_bot)\n      _ = ⊥ := sup_idem _",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hle : sSup ((⋃ N, ⋃ hN, B N hN) \\ {x}) ≤ sSup (D.carrier \\ {N}) ⊔ sSup (B N hN \\ {x}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion] at hy\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases hNN' : N = N'\n      · subst hNN'\n        exact le_sup_of_le_right (le_sSup ⟨hyB, hyx⟩)\n      · apply le_sup_of_le_left\n        apply le_sSup\n        constructor\n        · exact hN'\n        · exact hNN'\n    have h1 : a ≤ N := le_trans ha (by rw [hB N hN]; exact le_sSup hxB)\n    have h2 : a ≤ sSup (D.carrier \\ {N}) ⊔ sSup (B N hN \\ {x}) := le_trans ha' hle\n    have hDisjD : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN Set.diff_subset (Set.not_mem_diff_of_mem rfl)\n    have h3 : a ≤ sSup (B N hN \\ {x}) := by\n      have : a ≤ N ⊓ (sSup (D.carrier \\ {N}) ⊔ sSup (B N hN \\ {x})) := le_inf h1 h2\n      rwa [inf_sup_self_of_disjoint hDisjD] at this\n    exact (hB' N hN).disjoint_sSup hxB Set.diff_subset (Set.not_mem_diff_of_mem rfl) (le_inf ha h3)",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    -- x ∈ B N hN, and a ≤ x, a ≤ sSup of everything except x\n    -- We need to show a ≤ ⊥\n    -- First, a ≤ x ≤ N since x ∈ B N hN and N = sSup (B N hN)\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    -- Now we split the sSup into parts inside B N hN and outside\n    have hsub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} = \n                (B N hN \\ {x}) ∪ (⋃ N', ⋃ (hN' : N' ∈ D), if N' = N then ∅ else B N' hN') := by\n      ext y\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff, Set.mem_union, \n                 Set.mem_empty_iff_false]\n      constructor\n      · rintro ⟨⟨N', hN', hyB⟩, hyx⟩\n        by_cases hNN' : N' = N\n        · left; subst hNN'; exact ⟨hyB, hyx⟩\n        · right; exact ⟨N', hN', by simp [hNN', hyB]⟩\n      · rintro (⟨hyB, hyx⟩ | ⟨N', hN', hyB⟩)\n        · exact ⟨⟨N, hN, hyB⟩, hyx⟩\n        · simp only at hyB\n          split_ifs at hyB with hNN'\n          · exact hyB.elim\n          · exact ⟨⟨N', hN', hyB⟩, fun hyx => by subst hyx; exact hNN' (hB N hN ▸ hB N' hN' ▸ \n              le_antisymm (le_sSup hxB ▸ le_sSup hyB) (le_sSup hyB ▸ le_sSup hxB)).symm⟩\n    -- This is getting complex. Let's use a more direct approach.\n    -- a ≤ x and a ≤ sSup of complement. By sSupIndep of B N hN, we get a ≤ sSup (B N hN \\ {x}) ⊓ x = ⊥\n    -- But we also need to handle elements outside B N hN\n    have ha'_split : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ N' ∈ D, if N' = N then ∅ else B N' hN') := by\n      apply le_trans ha'\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases hNN' : N' = N\n      · subst hNN'; left; exact ⟨hyB, hyx⟩\n      · right; simp only [Set.mem_iUnion]; exact ⟨N', hN', by simp [hNN', hyB]⟩\n    have hother_le : sSup (⋃ N' ∈ D, if N' = N then ∅ else B N' hN') ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨N', hN', hyB⟩ := hy\n      simp only at hyB\n      split_ifs at hyB with hNN'\n      · exact hyB.elim\n      · have : y ≤ N' := by rw [hB N' hN']; exact le_sSup hyB\n        exact le_trans this (le_sSup (by simp [hN', hNN']))\n    have haN' : a ≤ N ⊓ sSup (D.carrier \\ {N}) := by\n      apply le_inf haN\n      apply le_trans ha'\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      have hyN' : y ≤ N' := by rw [hB N' hN']; exact le_sSup hyB\n      by_cases hNN' : N' = N\n      · subst hNN'\n        have : y ≤ sSup (B N hN \\ {x}) := le_sSup ⟨hyB, hyx⟩\n        exact le_trans this (sSup_le (fun z hz => le_trans (le_sSup hz.1) (by rw [← hB N hN])))\n      · exact le_trans hyN' (le_sSup (by simp [hN', hNN']))\n    have hDisjD : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN (by simp) (by simp)\n    exact le_trans haN' (disjoint_iff_inf_le.mp hDisjD)",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    have ha'_split : a ≤ sSup ((B N hN) \\ {x}) ⊔ sSup (⋃ N', ⋃ hN' : N' ∈ D, if N' = N then ∅ else B N' hN') := by\n      apply le_trans ha'\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion] at hy ⊢\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases hNN' : N' = N\n      · left; subst hNN'; exact ⟨hyB, hyx⟩\n      · right; exact ⟨N', hN', by simp [hNN', hyB]⟩\n    have hsup_other_le : sSup (⋃ N', ⋃ hN' : N' ∈ D, if N' = N then ∅ else B N' hN') ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨N', hN', hy'⟩ := hy\n      split_ifs at hy' with hNN'\n      · exact (Set.not_mem_empty _ hy').elim\n      · apply le_sSup_of_le (a := N')\n        · exact ⟨hN', hNN'⟩\n        · rw [hB N' hN']; exact le_sSup hy'\n    have hdisj_N : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN (fun y hy => hy.1) (by simp)\n    have ha_in_B : a ≤ sSup ((B N hN) \\ {x}) := by\n      have : a ≤ N ⊓ (sSup ((B N hN) \\ {x}) ⊔ sSup (D.carrier \\ {N})) := le_inf haN (le_trans ha'_split (sup_le_sup_left hsup_other_le _))\n      rw [inf_sup_right] at this\n      have : N ⊓ sSup (D.carrier \\ {N}) = ⊥ := disjoint_iff.mp hdisj_N\n      simp only [this, sup_bot_eq] at this\n      exact le_trans this (inf_le_right)\n    exact (hB' N hN).disjoint_sSup hxB (fun y hy => hy.1) (by simp) (le_inf ha ha_in_B)",
      "B",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have ha_le_N : a ≤ N := ha.trans (le_sSup hxB |>.trans (hB N hN).symm.le)\n    have hsup_le : sSup ((⋃ N, ⋃ hN, B N hN) \\ {x}) ≤ sSup D.carrier := by\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy\n      obtain ⟨⟨M', hM', _⟩, _⟩ := hy\n      exact hM'\n    have hBx_disj : Disjoint x (sSup ((B N hN) \\ {x})) := hB' N hN x hxB\n    have ha_le_sSupBx : a ≤ sSup ((B N hN) \\ {x}) := by\n      apply le_trans ha'\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hy ⊢\n      obtain ⟨⟨M', hM', hyB⟩, hyx⟩ := hy\n      by_cases hMN : M' = N\n      · subst hMN; exact ⟨hyB, hyx⟩\n      · refine ⟨le_sSup hyB |>.trans (hB M' hM').symm.le |>.trans ?_, hyx⟩\n        exact le_sSup_of_le (by simp [hN, hMN] : M' ∈ D.carrier \\ {N}) le_rfl |>.trans \n          (D.sSupIndep.disjoint_sSup hN (fun y hy => hy.1) (fun h => h.2 rfl)).symm.le_bot.trans bot_le |>.antisymm bot_le ▸ bot_le\n    exact disjoint_iff_inf_le.mp hBx_disj ⟨ha, ha_le_sSupBx⟩",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    have hsub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ \n                (B N hN \\ {x}) ∪ (⋃ N', ⋃ (hN' : N' ∈ D), if N' = N then ∅ else B N' hN') := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion] at hy\n      obtain ⟨⟨N', hN', hyB⟩, hyne⟩ := hy\n      by_cases hNN' : N' = N\n      · left; exact ⟨hNN' ▸ hyB, hyne⟩\n      · right; simp only [Set.mem_iUnion]; exact ⟨N', hN', by simp [hNN', hyB]⟩\n    have ha'_in_B : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (↑D \\ {N}) := by\n      apply le_trans ha'\n      apply le_trans (sSup_le_sSup hsub)\n      rw [sSup_union]\n      apply sup_le_sup (le_refl _)\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨N', hN', hy'⟩ := hy\n      split_ifs at hy' with h\n      · exact (Set.not_mem_empty y hy').elim\n      · have : y ≤ N' := by rw [hB N' hN']; exact le_sSup hy'\n        exact le_trans this (le_sSup_of_le (by simp [hN', h]) (le_refl _))\n    have hdisj1 : Disjoint x (sSup (B N hN \\ {x})) := hB' N hN hxB\n    have hdisj2 : Disjoint N (sSup (↑D \\ {N})) := D.sSupIndep hN\n    have ha_le_x_inf : a ≤ x ⊓ (sSup (B N hN \\ {x}) ⊔ sSup (↑D \\ {N})) := le_inf ha ha'_in_B\n    have hN_disj : Disjoint N (sSup (↑D \\ {N})) := D.sSupIndep hN\n    have hx_disj_sup : Disjoint x (sSup (↑D \\ {N})) := by\n      apply Disjoint.mono_left hxN hN_disj\n    have : a ≤ x ⊓ sSup (B N hN \\ {x}) ⊔ x ⊓ sSup (↑D \\ {N}) := by\n      calc a ≤ x ⊓ (sSup (B N hN \\ {x}) ⊔ sSup (↑D \\ {N})) := ha_le_x_inf\n           _ ≤ x ⊓ sSup (B N hN \\ {x}) ⊔ x ⊓ sSup (↑D \\ {N}) := inf_sup_le _ _ _\n    rw [disjoint_iff_inf_le.mp hdisj1, disjoint_iff_inf_le.mp hx_disj_sup, bot_sup_eq] at this\n    exact this",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    have ha'_split : a ≤ sSup ((B N hN) \\ {x}) ⊔ sSup (⋃ N', ⋃ hN' : N' ∈ D, (if N' = N then ∅ else B N' hN')) := by\n      apply le_trans ha'\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion] at hy ⊢\n      obtain ⟨⟨N', hN', hyB⟩, hyx⟩ := hy\n      by_cases hNN' : N' = N\n      · left; subst hNN'; exact ⟨hyB, hyx⟩\n      · right; exact ⟨N', hN', by simp [hNN', hyB]⟩\n    have hDisjOther : Disjoint N (sSup (⋃ N', ⋃ hN' : N' ∈ D, (if N' = N then ∅ else B N' hN'))) := by\n      apply Disjoint.mono_right _ (D.sSupIndep.disjoint_sSup hN (fun N' hN' => hN') (by simp))\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_iUnion] at hy ⊢\n      obtain ⟨N', hN', hy'⟩ := hy\n      split_ifs at hy' with h\n      · exact hy'.elim\n      · refine ⟨N', hN', ?_⟩\n        rw [hB N' hN']\n        exact le_sSup hy'\n    have ha_in_N : a ≤ sSup ((B N hN) \\ {x}) := by\n      have := hDisjOther.mono_left haN\n      rw [disjoint_iff] at this\n      calc a ≤ a ⊓ (sSup ((B N hN) \\ {x}) ⊔ sSup (⋃ N', ⋃ hN' : N' ∈ D, (if N' = N then ∅ else B N' hN'))) := le_inf le_rfl ha'_split\n        _ ≤ a ⊓ sSup ((B N hN) \\ {x}) ⊔ a ⊓ sSup (⋃ N', ⋃ hN' : N' ∈ D, (if N' = N then ∅ else B N' hN')) := inf_sup_le _ _ _\n        _ ≤ sSup ((B N hN) \\ {x}) ⊔ (N ⊓ sSup (⋃ N', ⋃ hN' : N' ∈ D, (if N' = N then ∅ else B N' hN'))) := by\n            apply sup_le_sup inf_le_right (inf_le_inf_right _ haN)\n        _ = sSup ((B N hN) \\ {x}) ⊔ ⊥ := by rw [this]\n        _ = sSup ((B N hN) \\ {x}) := sup_bot_eq _\n    exact (hB' N hN).disjoint_sSup hxB (Set.diff_subset) (Set.not_mem_diff_of_mem rfl) (le_inf ha ha_in_N)",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have ha_le_N : a ≤ N := le_trans ha hxN\n    have hsub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ \n                (B N hN \\ {x}) ∪ (⋃ M, ⋃ (hM : M ∈ D) (_ : M ≠ N), B M hM) := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_singleton_iff, Set.mem_iUnion] at hy\n      obtain ⟨⟨M, hM, hyB⟩, hyx⟩ := hy\n      by_cases hMN : M = N\n      · left; exact ⟨hMN ▸ hyB, hyx⟩\n      · right; simp only [Set.mem_iUnion]; exact ⟨M, hM, hMN, hyB⟩\n    have ha'_le : a ≤ sSup ((B N hN \\ {x}) ∪ (⋃ M, ⋃ (hM : M ∈ D) (_ : M ≠ N), B M hM)) := \n      le_trans ha' (sSup_le_sSup hsub)\n    rw [sSup_union] at ha'_le\n    have hother_le : sSup (⋃ M, ⋃ (hM : M ∈ D) (_ : M ≠ N), B M hM) ≤ sSup (D.carrier \\ {N}) := by\n      apply sSup_le\n      intro y hy\n      simp only [Set.mem_iUnion] at hy\n      obtain ⟨M, hM, hMN, hyB⟩ := hy\n      have hyM : y ≤ M := by rw [hB M hM]; exact le_sSup hyB\n      apply le_trans hyM\n      apply le_sSup\n      exact ⟨hM, hMN⟩\n    have hdisj_N : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN (by simp) (by simp)\n    have ha_other : a ≤ sSup (D.carrier \\ {N}) → a ≤ ⊥ := fun h => \n      disjoint_iff_inf_le.mp hdisj_N (le_inf ha_le_N h)\n    have hdisj_x : Disjoint x (sSup (B N hN \\ {x})) := (hB' N hN).disjoint_sSup hxB (by simp) (by simp)\n    have ha_inf : a ≤ x ⊓ (sSup (B N hN \\ {x}) ⊔ sSup (⋃ M, ⋃ (hM : M ∈ D) (_ : M ≠ N), B M hM)) := \n      le_inf ha ha'_le\n    rw [inf_sup_left] at ha_inf\n    have h1 : x ⊓ sSup (B N hN \\ {x}) = ⊥ := disjoint_iff_inf_le.mp hdisj_x\n    have h2 : x ⊓ sSup (⋃ M, ⋃ (hM : M ∈ D) (_ : M ≠ N), B M hM) ≤ ⊥ := by\n      apply le_trans (inf_le_inf_left x hother_le)\n      apply le_trans (inf_le_inf_right _ hxN)\n      exact disjoint_iff_inf_le.mp hdisj_N\n    simp only [h1, bot_sup_eq] at ha_inf\n    exact le_trans ha_inf h2",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    -- x is in B N hN, and we need to use the sSupIndep properties\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    -- Split the complement into parts inside B N hN and outside\n    have h1 : a ≤ sSup (B N hN \\ {x}) ⊔ sSup (⋃ N', ⋃ hN' : N' ∈ D, if N' = N then ∅ else B N' hN') := by\n      apply le_trans ha'\n      apply sSup_le_iff.mpr\n      intro b hb\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff] at hb\n      obtain ⟨⟨N', hN', hbB⟩, hbx⟩ := hb\n      by_cases hNN' : N' = N\n      · subst hNN'\n        exact le_sup_of_le_left (le_sSup ⟨hbB, hbx⟩)\n      · apply le_sup_of_le_right\n        apply le_sSup\n        simp only [Set.mem_iUnion]\n        exact ⟨N', hN', by simp [hNN', hbB]⟩\n    have h2 : a ≤ sSup (B N hN \\ {x}) := by\n      have haN : a ≤ N := le_trans ha hxN\n      have hother : sSup (⋃ N', ⋃ hN' : N' ∈ D, if N' = N then ∅ else B N' hN') ≤ sSup (D.carrier \\ {N}) := by\n        apply sSup_le_sSup\n        intro b hb\n        simp only [Set.mem_iUnion] at hb\n        obtain ⟨N', hN', hbB⟩ := hb\n        split_ifs at hbB with h\n        · exact hbB.elim\n        · simp only [Set.mem_diff, Set.mem_singleton_iff]\n          constructor\n          · exact hN'\n          · intro hN'N\n            exact h hN'N.symm\n      have hDisjN : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN (Set.diff_subset) (Set.not_mem_diff_of_mem rfl)\n      have : a ⊓ sSup (⋃ N', ⋃ hN' : N' ∈ D, if N' = N then ∅ else B N' hN') ≤ ⊥ := by\n        apply le_trans (inf_le_inf haN hother)\n        exact disjoint_iff.mp hDisjN\n      rw [sup_comm] at h1\n      exact Disjoint.left_le_of_le_sup_right h1 (disjoint_iff.mpr (le_bot_iff.mp this))\n    exact (hB' N hN).disjoint_sSup hxB (Set.diff_subset) (Set.not_mem_diff_of_mem rfl) ⟨ha, h2⟩",
      "\n    simp only [Set.mem_iUnion] at hx\n    obtain ⟨N, hN, hxB⟩ := hx\n    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hxB\n    have haN : a ≤ N := le_trans ha hxN\n    have h1 : Disjoint x (sSup (B N hN \\ {x})) := (hB' N hN).disjoint_sSup hxB Set.diff_subset \n      (Set.not_mem_diff_of_mem rfl)\n    have h2 : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN Set.diff_subset\n      (Set.not_mem_diff_of_mem rfl)\n    have hsub1 : (⋃ N', ⋃ hN', B N' hN') \\ {x} ⊆ (B N hN \\ {x}) ∪ (⋃ (N' : PersistenceSubmodule M) (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN') := by\n      intro y ⟨hy, hyne⟩; simp only [Set.mem_iUnion] at hy ⊢; obtain ⟨N', hN', hyB⟩ := hy\n      by_cases hN'N : N' = N\n      · left; exact ⟨hN'N ▸ hyB, hyne⟩\n      · right; exact ⟨N', hN', hN'N, hyB⟩\n    have hsub2 : ⋃ (N' : PersistenceSubmodule M) (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN' ⊆ sSup (D.carrier \\ {N}) := by\n      intro y hy; simp only [Set.mem_iUnion] at hy; obtain ⟨N', hN', hN'N, hyB⟩ := hy\n      exact le_trans (by rw [hB N' hN']; exact le_sSup hyB) (le_sSup ⟨hN', hN'N⟩)\n    calc a ≤ x ⊓ sSup ((⋃ N', ⋃ hN', B N' hN') \\ {x}) := le_inf ha ha'\n      _ ≤ x ⊓ (sSup (B N hN \\ {x}) ⊔ sSup (⋃ (N' : PersistenceSubmodule M) (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN')) := \n          inf_le_inf_left x (by rw [← sSup_union]; exact sSup_le_sSup hsub1)\n      _ ≤ (x ⊓ sSup (B N hN \\ {x})) ⊔ (x ⊓ sSup (⋃ (N' : PersistenceSubmodule M) (hN' : N' ∈ D) (_ : N' ≠ N), B N' hN')) := inf_sup_le\n      _ ≤ ⊥ ⊔ (N ⊓ sSup (D.carrier \\ {N})) := sup_le_sup (disjoint_iff.mp h1 ▸ le_refl _) \n          (inf_le_inf hxN (sSup_le_sSup hsub2))\n      _ ≤ ⊥ := by rw [disjoint_iff.mp h2, sup_bot_eq]",
