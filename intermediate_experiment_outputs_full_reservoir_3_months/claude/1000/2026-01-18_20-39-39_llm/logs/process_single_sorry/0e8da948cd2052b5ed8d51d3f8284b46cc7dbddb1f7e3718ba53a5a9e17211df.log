      "by\n  constructor\n  · intro ⟨R, hR⟩\n    obtain ⟨f, hf⟩ := fcnl_exists hR.left\n    obtain ⟨g, hg⟩ := fcnl_exists hR.right.left\n    use f, g\n    constructor\n    · funext v\n      have hv : v ∈ Ran R := hR.right.right.left v\n      obtain ⟨u, huv⟩ := hv\n      have hfu : f u = v := hf.right u v huv\n      have hgv : g v = u := hg.right v u (inv_pair huv)\n      simp [hfu, hgv]\n    · funext u\n      have hu : u ∈ Dom R := hR.right.right.right u\n      obtain ⟨v, huv⟩ := hu\n      have hfu : f u = v := hf.right u v huv\n      have hgv : g v = u := hg.right v u (inv_pair huv)\n      simp [hfu, hgv]\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · exact fcnl_graph f\n    constructor\n    · have h : inv (graph f) = graph g := by\n        apply Set.ext\n        intro ⟨v, u⟩\n        simp [inv, graph]\n        constructor\n        · intro hfu\n          have : g (f u) = g v := by rw [hfu]\n          simp [← hgf] at this\n          exact this.symm\n        · intro hgv\n          have : f (g v) = f u := by rw [hgv]\n          simp [← hfg] at this\n          exact this.symm\n      rw [h]\n      exact fcnl_graph g\n    constructor\n    · intro v\n      use g v\n      simp [graph]\n      have : (f ∘ g) v = id v := by rw [hfg]\n      simp at this\n      exact this\n    · intro u\n      use f u\n      simp [graph]",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_match hR\n    have hinvfcnl := fcnl_of_match (match_symm hR)\n    set f := fcnl_to_fcn hfcnl with hf_def\n    set g := fcnl_to_fcn hinvfcnl with hg_def\n    use f, g\n    constructor\n    · ext y\n      simp only [Function.comp_apply, id_eq]\n      have hy : y ∈ Ran R := hR.right.right.right y\n      obtain ⟨x, hxy⟩ := hy\n      have hgdef : g y = x := fcnl_to_fcn_spec hinvfcnl hxy\n      have hfdef : f x = y := fcnl_to_fcn_spec hfcnl hxy\n      rw [hgdef, hfdef]\n    · ext x\n      simp only [Function.comp_apply, id_eq]\n      have hx : x ∈ Dom R := hR.right.right.left x\n      obtain ⟨y, hxy⟩ := hx\n      have hfdef : f x = y := fcnl_to_fcn_spec hfcnl hxy\n      have hgdef : g y = x := fcnl_to_fcn_spec hinvfcnl hxy\n      rw [hfdef, hgdef]\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · intro x\n      use f x\n      rfl\n    constructor\n    · intro x y1 y2 hy1 hy2\n      simp only [graph, Set.mem_setOf_eq] at hy1 hy2\n      rw [← hy1, ← hy2]\n    constructor\n    · intro x\n      use f x\n      rfl\n    · intro y\n      use g y\n      have : f (g y) = y := by\n        have : (f ∘ g) y = id y := congrFun hfg y\n        simp at this\n        exact this\n      exact this",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_match hR\n    have hinv := match_symm hR\n    have hgcnl := fcnl_of_match hinv\n    set f := fcnl_to_fcn hfcnl with hfdef\n    set g := fcnl_to_fcn hgcnl with hgdef\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hgv : (v, g v) ∈ R.inv := fcnl_to_fcn_graph hgcnl v\n      have hfgv : (g v, f (g v)) ∈ R := fcnl_to_fcn_graph hfcnl (g v)\n      have hvinv : (v, g v) ∈ R.inv := hgv\n      have hvR : (g v, v) ∈ R := hvinv\n      exact hR.right.right.right (g v) (f (g v)) v hfgv hvR\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hfu : (u, f u) ∈ R := fcnl_to_fcn_graph hfcnl u\n      have hgfu : (f u, g (f u)) ∈ R.inv := fcnl_to_fcn_graph hgcnl (f u)\n      have hRinv : (g (f u), f u) ∈ R := hgfu\n      exact hR.right.right.left u (g (f u)) (f u) hfu hRinv\n  · intro ⟨f, g, hfg, hgf⟩\n    have hbij : one_one f ∧ onto f := by\n      constructor\n      · intro u1 u2 hfeq\n        have : g (f u1) = g (f u2) := by rw [hfeq]\n        simp only [← Function.comp_apply (f := g) (g := f)] at this\n        rw [hgf] at this\n        exact this\n      · intro v\n        use g v\n        have : f (g v) = v := by\n          have := congr_fun hfg v\n          simp only [Function.comp_apply, id_eq] at this\n          exact this\n        exact this\n    exact equinum_of_bij hbij",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl : fcnl_on R (Univ U) := hR.left\n    have hfcnl_inv : fcnl_on (invRel R) (Univ V) := hR.right\n    set f := fcnl_to_fcn R (Univ U) with hf_def\n    set g := fcnl_to_fcn (invRel R) (Univ V) with hg_def\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Univ V := by trivial\n      obtain ⟨u, hu⟩ := fcnl_exists hfcnl_inv hv\n      have hgu : g v = u := fcnl_to_fcn_def hfcnl_inv hv hu.left hu.right\n      rw [hgu]\n      have hu_univ : u ∈ Univ U := by trivial\n      have hRuv : R u v := hu.left\n      obtain ⟨v', hv'⟩ := fcnl_exists hfcnl hu_univ\n      have hfu : f u = v' := fcnl_to_fcn_def hfcnl hu_univ hv'.left hv'.right\n      have : v = v' := fcnl_unique hfcnl hu_univ hRuv hv'.left\n      rw [hfu, this]\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Univ U := by trivial\n      obtain ⟨v, hv⟩ := fcnl_exists hfcnl hu\n      have hfu : f u = v := fcnl_to_fcn_def hfcnl hu hv.left hv.right\n      rw [hfu]\n      have hv_univ : v ∈ Univ V := by trivial\n      have hinvRvu : invRel R v u := hv.left\n      obtain ⟨u', hu'⟩ := fcnl_exists hfcnl_inv hv_univ\n      have hgv : g v = u' := fcnl_to_fcn_def hfcnl_inv hv_univ hu'.left hu'.right\n      have : u = u' := fcnl_unique hfcnl_inv hv_univ hinvRvu hu'.left\n      rw [hgv, this]\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · intro u _\n      use f u\n      constructor\n      · rfl\n      · intro v2 hv2\n        exact hv2\n    · intro v _\n      use g v\n      constructor\n      · simp only [invRel, graph]\n        have : f (g v) = v := congr_fun hfg v\n        exact this\n      · intro u2 hu2\n        simp only [invRel, graph] at hu2\n        have : g (f u2) = u2 := congr_fun hgf u2\n        rw [← this, hu2]",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨f, hf⟩ := h\n    have hinv := Theorem_5_3_3 _ _ hf\n    obtain ⟨g, hg⟩ := hinv\n    use f, g\n    constructor\n    · ext v\n      exact hg.right.right v\n    · ext u\n      exact hg.right.left u\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use f\n    constructor\n    · -- one_to_one f\n      intro u1 u2 hfu\n      have : g (f u1) = g (f u2) := by rw [hfu]\n      simp only [← Function.comp_apply, hgf] at this\n      exact this\n    · -- onto f\n      intro v\n      use g v\n      have : (f ∘ g) v = id v := by rw [hfg]\n      simp at this\n      exact this",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hinv := fcnl_inv_fcnl hR.left hR.right\n    set f := fcnl_to_fcn hR.left\n    set g := fcnl_to_fcn hinv\n    use f, g\n    constructor\n    · funext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Ran R := by\n        rw [hR.right.right]\n        trivial\n      obtain ⟨u, huv⟩ := hv\n      have hu : u ∈ Dom R := by\n        exact Dom_def R u v huv\n      have hfcnl := hR.left\n      have hfcnl_inv := hinv\n      have hgu : g v = u := by\n        apply fcnl_to_fcn_spec hfcnl_inv\n        exact huv\n      have hfu : f u = v := by\n        apply fcnl_to_fcn_spec hfcnl\n        exact huv\n      rw [hgu, hfu]\n    · funext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Dom R := by\n        rw [hR.left.right]\n        trivial\n      obtain ⟨v, huv⟩ := hu\n      have hv : v ∈ Ran R := Ran_def R u v huv\n      have hfu : f u = v := fcnl_to_fcn_spec hR.left huv\n      have hgv : g v = u := fcnl_to_fcn_spec hinv huv\n      rw [hfu, hgv]\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · constructor\n      · intro x y1 y2 hy1 hy2\n        simp only [graph, Set.mem_setOf_eq] at hy1 hy2\n        rw [← hy1, ← hy2]\n      · ext u\n        simp only [Dom, graph, Set.mem_setOf_eq, Set.mem_univ, iff_true]\n        use f u\n    · constructor\n      · intro y x1 x2 hx1 hx2\n        simp only [graph, Set.mem_setOf_eq] at hx1 hx2\n        have : g (f x1) = g (f x2) := by rw [hx1, hx2]\n        simp only [Function.comp_apply, id_eq] at hgf\n        have h1 : (g ∘ f) x1 = x1 := by\n          have := congr_fun hgf x1\n          exact this\n        have h2 : (g ∘ f) x2 = x2 := by\n          have := congr_fun hgf x2\n          exact this\n        simp only [Function.comp_apply] at h1 h2\n        rw [← h1, ← h2, this]\n      · ext v\n        simp only [Ran, graph, Set.mem_setOf_eq, Set.mem_univ, iff_true]\n        use g v\n        have : (f ∘ g) v = v := congr_fun hfg v\n        simp only [Function.comp_apply] at this\n        exact this",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_equinum hR\n    have hinv := inv_equinum hR\n    have hfcnl_inv := fcnl_of_equinum hinv\n    set f := fcnl_onto_fun hfcnl with hf_def\n    set g := fcnl_onto_fun hfcnl_inv with hg_def\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hRan : Ran R = Univ V := hR.right.right.left\n      have hv : v ∈ Univ V := trivial\n      rw [← hRan] at hv\n      obtain ⟨u, huv⟩ := hv\n      have hgu : g v = u := by\n        apply fcnl_onto_fun_unique hfcnl_inv\n        exact huv\n      have hfu : f u = v := by\n        apply fcnl_onto_fun_unique hfcnl\n        exact huv\n      rw [hgu, hfu]\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hDom : Dom R = Univ U := hR.right.right.right\n      have hu : u ∈ Univ U := trivial\n      rw [← hDom] at hu\n      obtain ⟨v, huv⟩ := hu\n      have hfu : f u = v := by\n        apply fcnl_onto_fun_unique hfcnl\n        exact huv\n      have hgv : g v = u := by\n        apply fcnl_onto_fun_unique hfcnl_inv\n        exact huv\n      rw [hfu, hgv]\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · -- fcnl (graph f)\n      exact fcnl_graph f\n    constructor\n    · -- fcnl (inv (graph f))\n      rw [fcnl_iff_inv_fcnl_of_fcnl]\n      · exact fcnl_graph f\n      · intro v1 v2 u hv1 hv2\n        have : g (f u) = g (f u) := rfl\n        rw [← hv1, ← hv2] at this\n        have hgf1 : (g ∘ f) u = u := by rw [hgf]; rfl\n        simp only [Function.comp_apply] at hgf1\n        rw [hv1] at hgf1\n        have hgf2 : g v2 = u := by\n          have : (g ∘ f) u = u := by rw [hgf]; rfl\n          simp only [Function.comp_apply] at this\n          rw [hv2] at this\n          exact this\n        rw [← hgf1, ← hgf2]\n    constructor\n    · -- Ran (graph f) = Univ V\n      ext v\n      simp only [Ran, mem_setOf_eq, graph, Univ]\n      constructor\n      · intro _; trivial\n      · intro _\n        use g v\n        have : (f ∘ g) v = v := by rw [hfg]; rfl\n        simp only [Function.comp_apply] at this\n        exact this\n    · -- Dom (graph f) = Univ U\n      ext u\n      simp only [Dom, mem_setOf_eq, graph, Univ]\n      constructor\n      · intro _; trivial\n      · intro _; use f u",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, h1, h2, h3⟩ := h\n    have hex : ∀ (x : U), ∃ (y : V), R x y := by\n      intro x\n      obtain ⟨y, hy⟩ := h2 x\n      exact ⟨y, hy.left⟩\n    set f := fun x => Classical.choose (hex x) with hf_def\n    have hf : ∀ x, R x (f x) := fun x => Classical.choose_spec (hex x)\n    have hex' : ∀ (y : V), ∃ (x : U), R x y := by\n      intro y\n      obtain ⟨x, hx⟩ := h3 y\n      exact ⟨x, hx.left⟩\n    set g := fun y => Classical.choose (hex' y) with hg_def\n    have hg : ∀ y, R (g y) y := fun y => Classical.choose_spec (hex' y)\n    use f, g\n    constructor\n    · funext y\n      have hr1 : R (g y) (f (g y)) := hf (g y)\n      have hr2 : R (g y) y := hg y\n      exact h1 hr1 hr2\n    · funext x\n      have hr1 : R x (f x) := hf x\n      have hr2 : R (g (f x)) (f x) := hg (f x)\n      have : ∀ y, R x y → R (g y) y → g y = x := by\n        intro y hxy hgy\n        have := h1 hxy hgy\n        have h1' : ∀ {x1 x2 : U} {y : V}, R x1 y → R x2 y → x1 = x2 := by\n          intro x1 x2 y' h1' h2'\n          obtain ⟨_, hu⟩ := h3 y'\n          exact hu h1' ▸ hu h2'\n        exact h1' hgy hxy\n      exact (this (f x) hr1 hr2).symm\n  · intro ⟨f, g, hfg, hgf⟩\n    use fun x y => f x = y\n    constructor\n    · intro x1 x2 y h1 h2\n      have : g (f x1) = g (f x2) := by rw [h1, h2]\n      simp only [congr_fun hgf] at this\n      exact this\n    · intro x\n      exact ⟨f x, rfl, fun y hy => hy⟩\n    · intro y\n      use g y\n      constructor\n      · exact congr_fun hfg y\n      · intro x hx\n        rw [← hx]\n        exact congr_fun hgf x",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_one_one_on_Rel hR.left hR.right.left\n    have hgcnl := fcnl_of_one_one_on_Rel (inv_one_one_on hR.right.left) (inv_one_one_on hR.left)\n    set f := fcnl_to_fcn hfcnl with hfdef\n    set g := fcnl_to_fcn hgcnl with hgdef\n    use f, g\n    constructor\n    · funext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Dom (inv R) := by\n        rw [dom_inv, hR.right.right.right]\n        trivial\n      have hgv := fcnl_to_fcn_def hgcnl hv\n      have hgvR : (g v, v) ∈ R := by\n        have : (v, g v) ∈ inv R := hgv\n        exact this\n      have hgvDom : g v ∈ Dom R := by\n        exists v\n      have hfgv := fcnl_to_fcn_def hfcnl hgvDom\n      exact hR.right.left (g v) v (f (g v)) hgvR hfgv\n    · funext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Dom R := by\n        rw [hR.right.right.left]\n        trivial\n      have hfu := fcnl_to_fcn_def hfcnl hu\n      have hfuDom : f u ∈ Dom (inv R) := by\n        rw [dom_inv, hR.right.right.right]\n        trivial\n      have hgfu := fcnl_to_fcn_def hgcnl hfuDom\n      have hgfuR : (g (f u), f u) ∈ R := hgfu\n      exact hR.left u (g (f u)) (f u) hfu hgfuR\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · intro x₁ x₂ y h1 h2\n      simp only [graph, Set.mem_setOf_eq] at h1 h2\n      have : g y = g (f x₁) := by rw [h1]\n      rw [congr_fun hgf x₁] at this\n      have : g y = g (f x₂) := by rw [h2]\n      rw [congr_fun hgf x₂] at this\n      rw [← congr_fun hgf x₁, ← congr_fun hgf x₂, h1, h2]\n    constructor\n    · intro x y₁ y₂ h1 h2\n      simp only [graph, Set.mem_setOf_eq] at h1 h2\n      rw [← h1, ← h2]\n    constructor\n    · ext u\n      simp only [Dom, graph, Set.mem_setOf_eq, Univ]\n      constructor\n      · intro _; trivial\n      · intro _; use f u\n    · ext v\n      simp only [Ran, graph, Set.mem_setOf_eq, Univ]\n      constructor\n      · intro _; trivial\n      · intro _\n        use g v\n        exact congr_fun hfg v",
      "by\n  constructor\n  · intro h1\n    obtain ⟨f, hf⟩ := h1\n    obtain ⟨g, hg⟩ := one_one_onto_inv hf\n    use f, g\n    constructor\n    · funext y\n      exact hg.right.right y\n    · funext x\n      exact hg.right.left x\n  · intro ⟨f, g, hfg, hgf⟩\n    apply Exists.intro f\n    constructor\n    · intro x1 x2 hx\n      have : g (f x1) = g (f x2) := by rw [hx]\n      simp only [congr_fun hgf] at this\n      exact this\n    · intro y\n      use g y\n      exact congr_fun hfg y",
      "by\n  constructor\n  · intro ⟨f, hf⟩\n    obtain ⟨g, hfg, hgf⟩ := bij_iff_has_inverse.mp hf\n    exact ⟨f, g, funext hfg, funext hgf⟩\n  · intro ⟨f, g, hfg, hgf⟩\n    use f\n    apply bij_iff_has_inverse.mpr\n    use g\n    constructor\n    · intro y\n      have : (f ∘ g) y = id y := congrFun hfg y\n      exact this\n    · intro x\n      have : (g ∘ f) x = id x := congrFun hgf x\n      exact this",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hinv := fcnl_inv hR.1 hR.2.1\n    have hfcnl := fcnl_of_match hR.1 hR.2.1 hR.2.2\n    have hfcnlinv := fcnl_of_match hinv.1 hinv.2.1 hinv.2.2\n    set f := fcnl_to_fcn hfcnl with hfdef\n    set g := fcnl_to_fcn hfcnlinv with hgdef\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hgv := fcnl_to_fcn_prop hfcnlinv v\n      have hfgv := fcnl_to_fcn_prop hfcnl (g v)\n      have : (g v, v) ∈ R := hgv\n      have : (g v, f (g v)) ∈ R := hfgv\n      exact fcnl_unique hR.2.1 this hgv\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hfu := fcnl_to_fcn_prop hfcnl u\n      have hgfu := fcnl_to_fcn_prop hfcnlinv (f u)\n      have : (u, f u) ∈ R := hfu\n      have : (g (f u), f u) ∈ R := hgfu\n      exact fcnl_unique hR.1 this hfu\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · exact fcnl_graph f\n    constructor\n    · intro v\n      use g v\n      simp only [graph, Set.mem_setOf_eq]\n      have : (f ∘ g) v = v := congrFun hfg v\n      simp only [Function.comp_apply] at this\n      exact this.symm\n    · intro u₁ u₂ v h1 h2\n      simp only [graph, Set.mem_setOf_eq] at h1 h2\n      have : (g ∘ f) u₁ = u₁ := congrFun hgf u₁\n      have : (g ∘ f) u₂ = u₂ := congrFun hgf u₂\n      simp only [Function.comp_apply] at *\n      rw [← h1, ← h2] at this\n      calc u₁ = g (f u₁) := (congrFun hgf u₁).symm\n        _ = g (f u₂) := by rw [h1, h2]\n        _ = u₂ := congrFun hgf u₂",
      "by\n  constructor\n  · -- Forward direction: U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    have hinv := fcnl_inv_onto_of_equinum hR\n    have hfcnl := fcnl_of_equinum hR\n    set f := fcnl_on_to_fcn (Univ U) R hfcnl.1 with hf_def\n    set g := fcnl_on_to_fcn (Univ V) (inv R) hinv.1 with hg_def\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Univ V := elt_Univ v\n      have hgv := fcnl_on_to_fcn_graph hv hinv.1\n      have hu : g v ∈ Univ U := elt_Univ (g v)\n      have hfgv := fcnl_on_to_fcn_graph hu hfcnl.1\n      have : (g v, v) ∈ inv R := hgv\n      rw [inv_def] at this\n      exact hR.right_unique hfgv this\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Univ U := elt_Univ u\n      have hfu := fcnl_on_to_fcn_graph hu hfcnl.1\n      have hv : f u ∈ Univ V := elt_Univ (f u)\n      have hgfu := fcnl_on_to_fcn_graph hv hinv.1\n      rw [inv_def] at hgfu\n      exact hR.left_unique hgfu hfu\n  · -- Backward direction: ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · -- one-to-one\n      intro x1 x2 y hxy1 hxy2\n      simp only [graph, Set.mem_setOf_eq] at hxy1 hxy2\n      rw [← hxy1, ← hxy2]\n      have : g (f x1) = g (f x2) := by rw [hxy1, hxy2]\n      have h1 : (g ∘ f) x1 = x1 := congr_fun hgf x1\n      have h2 : (g ∘ f) x2 = x2 := congr_fun hgf x2\n      simp only [Function.comp_apply] at h1 h2\n      rw [← h1, ← h2, this]\n    constructor\n    · -- onto\n      intro y hy\n      use g y\n      simp only [graph, Set.mem_setOf_eq]\n      have : (f ∘ g) y = y := congr_fun hfg y\n      simp only [Function.comp_apply] at this\n      exact this\n    constructor\n    · -- fcnl on domain\n      intro x hx\n      use f x\n      constructor\n      · simp only [graph, Set.mem_setOf_eq]\n      · intro y hy\n        simp only [graph, Set.mem_setOf_eq] at hy\n        exact hy.symm\n    · -- fcnl on range\n      intro y hy\n      use g y\n      constructor\n      · simp only [graph, Set.mem_setOf_eq]\n        have : (f ∘ g) y = y := congr_fun hfg y\n        simp only [Function.comp_apply] at this\n        exact this\n      · intro x hx\n        simp only [graph, Set.mem_setOf_eq] at hx\n        have h1 : (g ∘ f) x = x := congr_fun hgf x\n        simp only [Function.comp_apply] at h1\n        rw [← h1, hx]",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_equinum hR\n    have hinv := inv_equinum hR\n    have hfcnl_inv := fcnl_of_equinum hinv\n    set f := fcnl_to_fcn hfcnl\n    set g := fcnl_to_fcn hfcnl_inv\n    use f, g\n    constructor\n    · funext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Ran R := (equinum_def.mp hR).2.1.2 v\n      obtain ⟨u, huv⟩ := hv\n      have hgu : g v = u := by\n        apply fcnl_to_fcn_unique hfcnl_inv\n        exact huv\n      have hfu : f u = v := by\n        apply fcnl_to_fcn_unique hfcnl\n        exact huv\n      rw [hgu, hfu]\n    · funext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Dom R := (equinum_def.mp hR).2.1.1 u\n      obtain ⟨v, huv⟩ := hu\n      have hfu : f u = v := by\n        apply fcnl_to_fcn_unique hfcnl\n        exact huv\n      have hgv : g v = u := by\n        apply fcnl_to_fcn_unique hfcnl_inv\n        exact huv\n      rw [hfu, hgv]\n  · intro ⟨f, g, hfg, hgf⟩\n    have hbij : one_one f ∧ onto f := by\n      constructor\n      · intro u1 u2 hfu\n        have : g (f u1) = g (f u2) := by rw [hfu]\n        simp only [← Function.comp_apply, hgf, id_eq] at this\n        exact this\n      · intro v\n        use g v\n        simp only [← Function.comp_apply, hfg, id_eq]\n    exact ⟨graph f, bij_to_equinum hbij⟩",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro ⟨R, hR⟩\n    obtain ⟨f, hf⟩ := fcnl_exists_iff_eq.mp hR.rel_within_for.right\n    obtain ⟨g, hg⟩ := fcnl_exists_iff_eq.mp hR.inv.rel_within_for.right\n    use f, g\n    constructor\n    · ext y\n      have hy := hR.right y\n      obtain ⟨x, hxy⟩ := hy\n      have hfx : f x = y := by\n        have : (x, f x) ∈ R := hf x\n        exact hR.left x (f x) y this hxy\n      have hgy : g y = x := by\n        have : (g y, y) ∈ R := by\n          have := hg y\n          simp [Rel.inv] at this\n          exact this\n        exact hR.inv.left y x (g y) hxy this\n      simp [hgy, hfx]\n    · ext x\n      have hx := hR.left x\n      obtain ⟨y, hxy⟩ := hx\n      have hgy : g y = x := by\n        have : (g y, y) ∈ R := by\n          have := hg y\n          simp [Rel.inv] at this\n          exact this\n        exact hR.inv.left y x (g y) hxy this\n      have hfx : f x = y := by\n        have : (x, f x) ∈ R := hf x\n        exact hR.left x (f x) y this hxy\n      simp [hfx, hgy]\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · intro x y₁ y₂ hy₁ hy₂\n      simp [graph] at hy₁ hy₂\n      rw [hy₁, hy₂]\n    · intro y x₁ x₂ hx₁ hx₂\n      simp [graph] at hx₁ hx₂\n      have h1 : g (f x₁) = g y := by rw [hx₁]\n      have h2 : g (f x₂) = g y := by rw [hx₂]\n      have hgf1 : g (f x₁) = x₁ := by\n        have := congrFun hgf x₁\n        simp at this\n        exact this\n      have hgf2 : g (f x₂) = x₂ := by\n        have := congrFun hgf x₂\n        simp at this\n        exact this\n      rw [hgf1] at h1\n      rw [hgf2] at h2\n      rw [h1, h2]\n    · intro x\n      use f x\n      simp [graph]\n    · intro y\n      use g y\n      simp [graph]\n      have := congrFun hfg y\n      simp at this\n      exact this",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨f, hf⟩ := h\n    have hinv := bij_iff_has_inverse.mp hf\n    obtain ⟨g, hfg, hgf⟩ := hinv\n    exact ⟨f, g, hfg, hgf⟩\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro h\n    obtain ⟨f, g, hfg, hgf⟩ := h\n    use f\n    exact bij_iff_has_inverse.mpr ⟨g, hfg, hgf⟩",
      "by\n  constructor\n  · intro ⟨R, hR⟩\n    obtain ⟨f, hf⟩ := fcnl_exists hR.left\n    obtain ⟨g, hg⟩ := fcnl_exists hR.right.left\n    use f, g\n    have hfg : ∀ v, f (g v) = v := by\n      intro v\n      have hgv := hg.left v\n      have hfgv := hf.left (g v)\n      have huniq := unique_match_R hR.left (g v)\n      have : (g v, v) ∈ R := hgv\n      have : (g v, f (g v)) ∈ R := hfgv\n      exact huniq v (f (g v)) hgv hfgv\n    have hgf : ∀ u, g (f u) = u := by\n      intro u\n      have hfu := hf.left u\n      have hgfu := hg.left (f u)\n      have huniq := unique_match_L hR.right.left (f u)\n      have : (u, f u) ∈ R := hfu\n      have : (g (f u), f u) ∈ R := hgfu\n      exact huniq u (g (f u)) hfu hgfu\n    constructor\n    · funext v\n      exact hfg v\n    · funext u\n      exact hgf u\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · exact fcnl_graph f\n    constructor\n    · intro v\n      use g v, f (g v)\n      constructor\n      · rfl\n      · have : (f ∘ g) v = id v := congrFun hfg v\n        simp at this\n        exact this\n    · intro u\n      use f u\n      intro v1 v2 ⟨hv1a, hv1b⟩ ⟨hv2a, hv2b⟩\n      rw [← hv1a, ← hv2a]",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_match hR\n    have hinv := match_inv hR\n    have hfcnl_inv := fcnl_of_match hinv\n    set f := fcnl_to_fcn hfcnl with hf_def\n    set g := fcnl_to_fcn hfcnl_inv with hg_def\n    use f, g\n    constructor\n    · ext v\n      have hgv := fcnl_to_fcn_def hfcnl_inv v\n      have hfgv := fcnl_to_fcn_def hfcnl (g v)\n      simp only [Function.comp_apply, id_eq]\n      have : (g v, v) ∈ inv R := hgv\n      simp only [inv_def] at this\n      exact unique_of_fcnl hfcnl hfgv this\n    · ext u\n      have hfu := fcnl_to_fcn_def hfcnl u\n      have hgfu := fcnl_to_fcn_def hfcnl_inv (f u)\n      simp only [Function.comp_apply, id_eq]\n      have : (f u, u) ∈ inv R := by\n        simp only [inv_def]\n        exact hfu\n      exact unique_of_fcnl hfcnl_inv hgfu this\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    define\n    constructor\n    · -- fcnl_on (graph f) (Univ U)\n      define\n      constructor\n      · intro u _\n        use f u\n        rfl\n      · intro u _ v1 v2 hv1 hv2\n        simp only [graph_def] at hv1 hv2\n        rw [← hv1, ← hv2]\n    · -- fcnl_on (inv (graph f)) (Univ V)\n      define\n      constructor\n      · intro v _\n        use g v\n        simp only [inv_def, graph_def]\n        have : (f ∘ g) v = id v := congrFun hfg v\n        simp only [Function.comp_apply, id_eq] at this\n        exact this\n      · intro v _ u1 u2 hu1 hu2\n        simp only [inv_def, graph_def] at hu1 hu2\n        have h1 : (g ∘ f) u1 = id u1 := congrFun hgf u1\n        have h2 : (g ∘ f) u2 = id u2 := congrFun hgf u2\n        simp only [Function.comp_apply, id_eq] at h1 h2\n        rw [← h1, ← h2, hu1, hu2]",
      "by\n  constructor\n  · intro h\n    obtain ⟨R, hR⟩ := h\n    have hfcnl := fcnl_of_match hR\n    have hinv := match_inv hR\n    have hfcnl_inv := fcnl_of_match hinv\n    set f := fcnl_to_fcn hfcnl with hf_def\n    set g := fcnl_to_fcn hfcnl_inv with hg_def\n    use f, g\n    constructor\n    · funext y\n      simp only [Function.comp_apply, id_eq]\n      have hy : y ∈ Dom (inv R) := by\n        rw [hR.right.right.left]\n        trivial\n      have hgy := fcnl_to_fcn_def hfcnl_inv hy\n      have hgy' : (y, g y) ∈ inv R := hgy\n      have hgy'' : (g y, y) ∈ R := by\n        rw [inv_def] at hgy'\n        exact hgy'\n      have hgx : g y ∈ Dom R := by\n        rw [hR.right.left]\n        trivial\n      have hfgy := fcnl_to_fcn_def hfcnl hgx\n      have huniq := hR.left (g y) y (f (g y)) hgy'' hfgy\n      exact huniq.symm\n    · funext x\n      simp only [Function.comp_apply, id_eq]\n      have hx : x ∈ Dom R := by\n        rw [hR.right.left]\n        trivial\n      have hfx := fcnl_to_fcn_def hfcnl hx\n      have hfx' : (x, f x) ∈ R := hfx\n      have hfx_inv : (f x, x) ∈ inv R := by\n        rw [inv_def]\n        exact hfx'\n      have hfx_dom : f x ∈ Dom (inv R) := by\n        rw [hR.right.right.left]\n        trivial\n      have hgfx := fcnl_to_fcn_def hfcnl_inv hfx_dom\n      have huniq := hinv.left (f x) x (g (f x)) hfx_inv hgfx\n      exact huniq.symm\n  · intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · intro x y1 y2 hy1 hy2\n      simp only [graph, Set.mem_setOf_eq] at hy1 hy2\n      rw [← hy1, ← hy2]\n    constructor\n    · intro y x1 x2 hx1 hx2\n      simp only [graph, Set.mem_setOf_eq] at hx1 hx2\n      have h1 : g (f x1) = g (f x2) := by rw [hx1, hx2]\n      have h2 : (g ∘ f) x1 = (g ∘ f) x2 := h1\n      rw [hgf] at h2\n      exact h2\n    constructor\n    · ext x\n      constructor\n      · intro hx\n        trivial\n      · intro _\n        use f x\n        simp only [graph, Set.mem_setOf_eq]\n    · ext y\n      constructor\n      · intro hy\n        trivial\n      · intro _\n        use g y\n        simp only [graph, Set.mem_setOf_eq]\n        have : (f ∘ g) y = y := by rw [hfg]; rfl\n        exact this",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    set f := fun u => (hR.fcnl_on_univ.right u trivial).choose\n    set g := fun v => (hR.fcnl_on_univ.left v trivial).choose\n    use f, g\n    constructor\n    · ext v\n      simp only [Function.comp_apply, id_eq]\n      have hv : v ∈ Univ V := trivial\n      have hg := (hR.fcnl_on_univ.left v hv).choose_spec\n      have hf := (hR.fcnl_on_univ.right (g v) trivial).choose_spec\n      have := hR.fcnl_on_univ.right v hv\n      obtain ⟨u, hu⟩ := this\n      have : f (g v) = v := by\n        apply hR.fcnl_on_univ.right v hv |>.unique\n        exact hf.right\n        exact hg.right\n      exact this\n    · ext u\n      simp only [Function.comp_apply, id_eq]\n      have hu : u ∈ Univ U := trivial\n      have hf := (hR.fcnl_on_univ.right u hu).choose_spec\n      have hg := (hR.fcnl_on_univ.left (f u) trivial).choose_spec\n      apply hR.fcnl_on_univ.left (f u) trivial |>.unique\n      exact hg.right\n      exact hf.right\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    have hbij : one_to_one f ∧ onto f := by\n      constructor\n      · intro u1 u2 hfeq\n        have : g (f u1) = g (f u2) := by rw [hfeq]\n        simp only [← Function.comp_apply, hgf, id_eq] at this\n        exact this\n      · intro v\n        use g v\n        have : f (g v) = v := by simp only [← Function.comp_apply, hfg, id_eq]\n        exact this\n    exact ⟨graph f, bij_graph_iff_bij.mpr hbij⟩",
      "by\n  constructor\n  · -- U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id\n    intro h\n    obtain ⟨R, hR⟩ := h\n    set f := fun u => (hR.fcnl_on_univ.has_fval u).choose with hf_def\n    have hf : ∀ u, R u (f u) := fun u => (hR.fcnl_on_univ.has_fval u).choose_spec\n    set g := fun v => (hR.inv_fcnl_on_univ.has_fval v).choose with hg_def\n    have hg : ∀ v, R (g v) v := fun v => (hR.inv_fcnl_on_univ.has_fval v).choose_spec\n    use f, g\n    constructor\n    · ext v\n      have h1 : R (g v) v := hg v\n      have h2 : R (g v) (f (g v)) := hf (g v)\n      exact hR.fcnl_on_univ.unique trivial h2 h1\n    · ext u\n      have h1 : R u (f u) := hf u\n      have h2 : R (g (f u)) (f u) := hg (f u)\n      exact hR.inv_fcnl_on_univ.unique trivial h2 h1\n  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V\n    intro ⟨f, g, hfg, hgf⟩\n    use graph f\n    constructor\n    · -- fcnl_on (graph f) (Univ U)\n      define\n      intro u _\n      use f u\n      define\n      rfl\n    · -- inv_fcnl_on (graph f) (Univ V)\n      define\n      intro v _\n      use g v\n      define\n      have : f (g v) = v := congr_fun hfg v\n      exact this",
