      have hgu : g v = u := fcnl_to_fun_spec hinvfcnl huv
      simp [hfu, hgu]
    · ext u
      have hu : u ∈ Dom R := (equinum_def U V).mp ⟨R, hR⟩ |>.2.2.1 u
      obtain ⟨v, huv⟩ := hu
      have hfu : f u = v := fcnl_to_fun_spec hfcnl huv
      have hgv : g v = u := fcnl_to_fun_spec hinvfcnl huv
      simp [hfu, hgv]
  · -- ∃ f g, f ∘ g = id ∧ g ∘ f = id → U ∼ V
    intro ⟨f, g, hfg, hgf⟩
    have hbij : one_one f ∧ onto f := by
      constructor
