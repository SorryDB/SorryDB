    obtain ⟨R, hR⟩ := h
    have hfcnl := fcnl_of_bij hR
    have hinvfcnl := inv_fcnl_of_bij hR
    set f := fcnl_to_fcn hfcnl with hfdef
    set g := fcnl_to_fcn hinvfcnl with hgdef
    use f, g
    constructor
    · ext v
      simp only [Function.comp_apply, id_eq]
      have hgv : (v, g v) ∈ inv R := fcnl_to_fcn_graph hinvfcnl v
      have hRgv : (g v, v) ∈ R := hgv
      have hfgv : (g v, f (g v)) ∈ R := fcnl_to_fcn_graph hfcnl (g v)
      exact unique_of_graph_fcnl hfcnl.left hRgv hfgv
    · ext u
      simp only [Function.comp_apply, id_eq]
      have hfu : (u, f u) ∈ R := fcnl_to_fcn_graph hfcnl u
      have hginvfu : (f u, g (f u)) ∈ inv R := fcnl_to_fcn_graph hinvfcnl (f u)
      have hRgfu : (g (f u), f u) ∈ R := hginvfu
