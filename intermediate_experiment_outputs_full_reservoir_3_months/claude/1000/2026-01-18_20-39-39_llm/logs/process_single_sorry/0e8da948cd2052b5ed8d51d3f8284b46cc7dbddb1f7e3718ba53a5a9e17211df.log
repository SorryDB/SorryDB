    have hfcnl := fcnl_of_equinum_left hR
    have hinvfcnl := fcnl_of_equinum_right hR
    set f := fcnl_to_fun hfcnl with hf_def
    set g := fcnl_to_fun hinvfcnl with hg_def
    use f, g
    constructor
    · ext v
      have hv : v ∈ Ran R := (equinum_def U V).mp ⟨R, hR⟩ |>.2.2.2 v
