      "\n  rw [G]\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo\n  have h2_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h2 h2\n  have h2_cubed : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 3) := by\n    rw [pow_succ, pow_two]; exact MDifferentiable.mul (MDifferentiable.mul h2 h2) h2\n  have h4_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₄ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h4 h4\n  have h_term1 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2) := by\n    exact MDifferentiable.const_mul h2_sq 2\n  have h_term2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₂ * H₄) := by\n    exact MDifferentiable.mul (MDifferentiable.const_mul h2 5) h4\n  have h_term3 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₄ ^ 2) := by\n    exact MDifferentiable.const_mul h4_sq 5\n  have h_paren : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := by\n    exact MDifferentiable.add (MDifferentiable.add h_term1 h_term2) h_term3\n  exact MDifferentiable.mul h2_cubed h_paren",
      "\n  rw [G]\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo'\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo'\n  have h2_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h2 h2\n  have h4_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₄ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h4 h4\n  have h2_cubed : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 3) := by\n    rw [pow_succ, pow_two]; exact MDifferentiable.mul (MDifferentiable.mul h2 h2) h2\n  have term1 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2) := MDifferentiable.const_smul h2_sq 2\n  have term2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₂ * H₄) := by\n    exact MDifferentiable.mul (MDifferentiable.const_smul h2 5) h4\n  have term3 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₄ ^ 2) := MDifferentiable.const_smul h4_sq 5\n  have inner : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := by\n    exact MDifferentiable.add (MDifferentiable.add term1 term2) term3\n  exact MDifferentiable.mul h2_cubed inner",
      "\n  unfold G\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo\n  have h2_3 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 3) := by\n    rw [pow_succ, pow_two]\n    exact MDifferentiable.mul (MDifferentiable.mul h2 h2) h2\n  have h2_2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 2) := by\n    rw [pow_two]\n    exact MDifferentiable.mul h2 h2\n  have h4_2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₄ ^ 2) := by\n    rw [pow_two]\n    exact MDifferentiable.mul h4 h4\n  have h_inner : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := by\n    apply MDifferentiable.add\n    apply MDifferentiable.add\n    · exact MDifferentiable.mul (mdifferentiable_const) h2_2\n    · exact MDifferentiable.mul (MDifferentiable.mul (mdifferentiable_const) h2) h4\n    · exact MDifferentiable.mul (mdifferentiable_const) h4_2\n  exact MDifferentiable.mul h2_3 h_inner",
      "\n  rw [G]\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo'\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo'\n  have h2_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h2 h2\n  have h4_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₄ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul h4 h4\n  have h2_cubed : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 3) := by\n    rw [pow_succ, pow_two]; exact MDifferentiable.mul (MDifferentiable.mul h2 h2) h2\n  have term1 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2) := MDifferentiable.const_smul h2_sq 2\n  have term2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₂ * H₄) := by\n    exact MDifferentiable.mul (MDifferentiable.const_smul h2 5) h4\n  have term3 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₄ ^ 2) := MDifferentiable.const_smul h4_sq 5\n  have inner : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := by\n    exact MDifferentiable.add (MDifferentiable.add term1 term2) term3\n  exact MDifferentiable.mul h2_cubed inner",
      "\n  rw [G]\n  have hH₂ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo\n  have hH₄ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo\n  have hH₂_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul hH₂ hH₂\n  have hH₂_cubed : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ ^ 3) := by\n    rw [pow_succ, pow_two]; exact MDifferentiable.mul hH₂ (MDifferentiable.mul hH₂ hH₂)\n  have hH₄_sq : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₄ ^ 2) := by\n    rw [pow_two]; exact MDifferentiable.mul hH₄ hH₄\n  have h1 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2) := MDifferentiable.const_smul hH₂_sq 2\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ * H₄) := MDifferentiable.mul hH₂ hH₄\n  have h3 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₂ * H₄) := MDifferentiable.const_smul h2 5\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₄ ^ 2) := MDifferentiable.const_smul hH₄_sq 5\n  have h5 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄) := MDifferentiable.add h1 h3\n  have h6 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := MDifferentiable.add h5 h4\n  exact MDifferentiable.mul hH₂_cubed h6",
      "\n  rw [G]\n  have h2 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := H₂_holo\n  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := H₄_holo\n  apply MDifferentiable.mul\n  · apply MDifferentiable.mul\n    apply MDifferentiable.mul\n    exact h2\n    exact h2\n    exact h2\n  · apply MDifferentiable.add\n    apply MDifferentiable.add\n    · apply MDifferentiable.mul\n      exact mdifferentiable_const\n      apply MDifferentiable.mul h2 h2\n    · apply MDifferentiable.mul\n      apply MDifferentiable.mul\n      exact mdifferentiable_const\n      exact h2\n      exact h4\n    · apply MDifferentiable.mul\n      apply MDifferentiable.mul\n      exact mdifferentiable_const\n      exact h4\n      exact h4",
