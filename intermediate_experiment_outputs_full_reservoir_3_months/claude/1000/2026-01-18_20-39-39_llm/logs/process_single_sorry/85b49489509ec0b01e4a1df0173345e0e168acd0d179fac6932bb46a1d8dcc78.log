theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ)∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  constructor
  · rw [div_le_iff]
    · simp only [← Nat.cast_pow, ← Nat.cast_factorial]
      have h : (n.choose k) * k.factorial ≤ n ^ k := Nat.choose_mul_factorial_le_pow n k
      exact_mod_cast h
    · exact_mod_cast Nat.factorial_pos k
  · by_cases hk : k = 0
    · simp [hk]
    · apply div_le_div_of_nonneg_left
      · exact pow_nonneg (Nat.cast_nonneg n) k
      · exact pow_pos two_pos (k - 1)
      · have hk' : 1 ≤ k := Nat.one_le_iff_ne_zero.mpr hk
        have : 2 ^ (k - 1) ≤ k.factorial := Nat.two_pow_sub_one_le_factorial hk'
        exact_mod_cast this
