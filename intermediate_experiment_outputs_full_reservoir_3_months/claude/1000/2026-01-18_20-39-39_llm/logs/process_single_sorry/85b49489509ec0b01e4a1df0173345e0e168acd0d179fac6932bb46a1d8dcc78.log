theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ)∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  constructor
  · rw [div_le_iff (by positivity : (0 : ℚ) < k.factorial)]
    push_cast
    exact_mod_cast Nat.choose_mul_factorial_mul_factorial (Nat.choose_le_pow_div k n).le
  · cases k with
    | zero => simp
    | succ k =>
      apply div_le_div_of_nonneg_left (by positivity)
      · positivity
      · push_cast
        have : (2 : ℚ) ^ k ≤ (k + 1).factorial := by
          induction k with
          | zero => simp
          | succ k ih =>
            rw [pow_succ, Nat.factorial_succ, Nat.cast_mul, Nat.cast_add, Nat.cast_one]
            calc 2 * 2 ^ k ≤ 2 * ↑(k + 1).factorial := by linarith
              _ ≤ (↑k + 1 + 1) * ↑(k + 1).factorial := by nlinarith
        simp only [Nat.succ_sub_succ_eq_sub, Nat.sub_zero]
        exact this
