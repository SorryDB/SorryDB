theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ)∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  constructor
  · by_cases hk : k ≤ n
    · have hfac : (k.factorial : ℚ) ≠ 0 := by positivity
      rw [le_div_iff (by positivity : (k.factorial : ℚ) > 0)]
      push_cast
      rw [mul_comm]
      exact_mod_cast Nat.factorial_mul_choose_le_pow n k
    · simp only [not_le] at hk
      rw [Nat.choose_eq_zero_of_lt hk]
      simp [div_nonneg (by positivity : (n : ℚ) ^ k ≥ 0) (by positivity : (k.factorial : ℚ) ≥ 0)]
  · by_cases hk : k = 0
    · simp [hk]
    · have hfac : (k.factorial : ℚ) > 0 := by positivity
      have hpow : (2 : ℚ) ^ (k - 1) > 0 := by positivity
      rw [div_le_div_iff hfac hpow]
      have h : 2 ^ (k - 1) ≤ k.factorial := Nat.two_pow_sub_one_le_factorial hk
      calc (n : ℚ) ^ k * 2 ^ (k - 1) ≤ (n : ℚ) ^ k * k.factorial := by
            apply mul_le_mul_of_nonneg_left
            · exact_mod_cast h
            · positivity
           _ = (n : ℚ) ^ k * k.factorial := rfl
