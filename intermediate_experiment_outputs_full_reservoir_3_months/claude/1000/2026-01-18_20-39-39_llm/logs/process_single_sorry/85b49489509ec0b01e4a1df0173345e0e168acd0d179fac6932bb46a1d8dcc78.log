      have : 2 ^ k ≤ (k + 1).factorial := by
        induction k with
        | zero => simp
        | succ k ih =>
          calc 2 ^ (k + 1) = 2 * 2 ^ k := by ring
            _ ≤ 2 * (k + 1).factorial := by omega
            _ ≤ (k + 2) * (k + 1).factorial := by omega
            _ = (k + 2).factorial := by rw [Nat.factorial_succ]
      simp only [Nat.succ_sub_succ_eq_sub, tsub_zero]
      exact_mod_cast this
