  have h_entry : (fun ω => wignerMatrixMap n ω i j) = (fun ω => ω ⟨(i, j), le_of_lt h⟩) := by
    ext ω
    simp only [wignerMatrixMap, wignerMatrixMap', Matrix.of_apply, wignerMatrixEntryFunction]
    simp [h_ne, h]
  rw [h_entry, WignerMeasure]
  have h_proj : Measure.map (fun ω => ω ⟨(i, j), le_of_lt h⟩) (Measure.pi (wignerMeasureDist μ ν n)) 
              = wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩ := by
    exact Measure.map_eval_pi (wignerMeasureDist μ ν n) ⟨(i, j), le_of_lt h⟩
