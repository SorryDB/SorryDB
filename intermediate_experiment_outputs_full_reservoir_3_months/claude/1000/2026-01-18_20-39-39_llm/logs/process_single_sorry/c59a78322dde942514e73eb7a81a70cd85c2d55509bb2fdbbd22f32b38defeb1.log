  (supportSet p).card ≤ (edgeSet p).card +1 := by
  induction p with
  | nil =>
    simp only [supportSet, support, edgeSet, edges, darts, List.map_nil]
    simp only [List.toFinset_cons, List.toFinset_nil, Finset.insert_empty, List.toFinset_nil]
    simp
  | cons h p' ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.map_cons, dartEdge]
    simp only [List.toFinset_cons]
    calc Finset.card (insert u (List.toFinset (support p')))
        ≤ Finset.card (List.toFinset (support p')) + 1 := Finset.card_insert_le u _
      _ ≤ Finset.card (List.toFinset (List.map dartEdge (darts p'))) + 1 + 1 := by omega_nat; exact ih
      _ ≤ Finset.card (insert (dartEdge (u, _)) (List.toFinset (List.map dartEdge (darts p')))) + 1 := by
          have : Finset.card (List.toFinset (List.map dartEdge (darts p'))) + 1 ≤ 
                 Finset.card (insert (dartEdge (u, _)) (List.toFinset (List.map dartEdge (darts p')))) := by
            simp only [Finset.card_insert_le]
            omega
          omega
  | loop p' ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.map_cons, dartEdge]
    simp only [List.toFinset_cons]
    have h1 : Finset.card (insert u (List.toFinset (support p'))) ≤ Finset.card (List.toFinset (support p')) + 1 := 
      Finset.card_insert_le u _
    have h2 : Finset.card (List.toFinset (support p')) ≤ Finset.card (List.toFinset (List.map dartEdge (darts p'))) + 1 := ih
    have h3 : Finset.card (List.toFinset (List.map dartEdge (darts p'))) ≤ 
              Finset.card (insert (Sym2.mk (u, u)) (List.toFinset (List.map dartEdge (darts p')))) := 
