    open Bluebird
    open Lark
    open Starling

    -- a sage bird exists in the forest
    theorem sagebird_existence :
        ∃ θ, ∀ x, x ◁ (θ ◁ x) = θ ◁ x := by
      use B ◁ M ◁ L
      intro x
      calc (B ◁ M ◁ L) ◁ x = M ◁ (L ◁ x) := by rw [B.call]
        _ = (L ◁ x) ◁ (L ◁ x) := by rw [M.call]
