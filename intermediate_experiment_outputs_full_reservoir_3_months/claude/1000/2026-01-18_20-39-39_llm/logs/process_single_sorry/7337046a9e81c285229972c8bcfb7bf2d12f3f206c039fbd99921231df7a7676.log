  · exact refinement_le B hB hB' hB''
  · intro h_eq
    obtain ⟨N, hN, hBN⟩ := H
    have h_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by
      rw [← h_eq]
    simp only [refinement] at h_carrier
    have hN_subset : B N hN ⊆ D.carrier := by
