      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_carrier : (D : Set (PersistenceSubmodule M)) = (refinement B hB hB' hB'' : Set (PersistenceSubmodule M)) := by\n      rw [h_eq]\n    have hN_mem : N ∈ (refinement B hB hB' hB'' : Set (PersistenceSubmodule M)) := h_carrier ▸ hN\n    simp only [refinement, Set.mem_iUnion] at hN_mem\n    obtain ⟨N', hN', hN_in_B⟩ := hN_mem\n    have hB_sub : B N hN ⊆ (refinement B hB hB' hB'' : Set (PersistenceSubmodule M)) := by\n      intro x hx\n      simp only [refinement, Set.mem_iUnion]\n      exact ⟨N, hN, hx⟩\n    have hB_sub_D : B N hN ⊆ D := by\n      rw [h_carrier]\n      exact hB_sub\n    have hN_eq : N = sSup (B N hN) := hB N hN\n    by_cases h_single : B N hN = {N}\n    · exact hBN h_single\n    · push_neg at h_single\n      rcases Set.eq_singleton_or_nontrivial (s := B N hN) (a := N) with h | h\n      · by_contra\n        have : N ∈ B N hN := by\n          rw [hN_eq]\n          have hne : (B N hN).Nonempty := by\n            by_contra hemp\n            push_neg at hemp\n            simp only [Set.not_nonempty_iff_eq_empty] at hemp\n            rw [hemp] at hN_eq\n            simp at hN_eq\n            exact D.not_bot_mem (hN_eq ▸ hN)\n          obtain ⟨x, hx⟩ := hne\n          exact le_sSup hx\n        exact h_single (h this)\n      · obtain ⟨x, hx, y, hy, hxy⟩ := h\n        have hx_in_D : x ∈ D := hB_sub_D hx\n        have hy_in_D : y ∈ D := hB_sub_D hy\n        have hx_le_N : x ≤ N := by rw [hN_eq]; exact le_sSup hx\n        have hy_le_N : y ≤ N := by rw [hN_eq]; exact le_sSup hy\n        have hx_disj : Disjoint x (sSup (D.carrier \\ {x})) := D.sSupIndep hx_in_D\n        have hN_in_diff : N ∈ D.carrier \\ {x} ∨ N = x := by\n          by_cases hNx : N = x\n          · right; exact hNx\n          · left; exact ⟨hN, hNx⟩\n        cases hN_in_diff with\n        | inl hN_diff =>\n          have hN_le : N ≤ sSup (D.carrier \\ {x}) := le_sSup hN_diff\n          have hx_le_diff : x ≤ sSup (D.carrier \\ {x}) := le_trans hx_le_N hN_le\n          have hx_bot : x = ⊥ := Disjoint.eq_bot_of_le hx_disj hx_le_diff\n          exact hB'' N hN (hx_bot ▸ hx)\n        | inr hNx =>\n          subst hNx\n          have hy_in_diff : y ∈ D.carrier \\ {x} := ⟨hy_in_D, hxy.symm⟩\n          have hy_le_diff : y ≤ sSup (D.carrier \\ {x}) := le_sSup hy_in_diff\n          have hx_le_y : x ≤ y := le_trans hx_le_N hy_le_N\n          have hx_le_diff' : x ≤ sSup (D.carrier \\ {x}) := le_trans hx_le_y hy_le_diff\n          have hx_bot : x = ⊥ := Disjoint.eq_bot_of_le hx_disj hx_le_diff'\n          exact hB'' N hN (hx_bot ▸ hx)",
