/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  obtain ⟨N, hN, hBN⟩ := H
  have h_mem : N ∈ refinement B hB hB' hB'' := by
    rw [← h_eq]
    exact hN
  simp only [refinement, Set.mem_iUnion] at h_mem
  obtain ⟨N', hN', hN_in_B⟩ := h_mem
  by_cases hNN' : N = N'
  · subst hNN'
    have hBN_singleton : B N hN = {N} := by
      apply Set.eq_singleton_iff_unique_mem.mpr
      constructor
      · exact hN_in_B
      · intro x hx
        have hx_le : x ≤ N := by
          rw [hB N hN]
          exact le_sSup hx
        have hN_le : N ≤ x := by
          have : N ≤ sSup (B N hN) := by rw [← hB N hN]
          exact le_sSup_of_le hN_in_B le_rfl
        sorry
    exact hBN hBN_singleton
  · have hN_le_N' : N ≤ N' := by
      rw [hB N' hN']
      exact le_sSup hN_in_B
    have hN'_le_N : N' ≤ N := by
      have h_N'_mem : N' ∈ refinement B hB hB' hB'' := by
        simp only [refinement, Set.mem_iUnion]
        refine ⟨N', hN', ?_⟩
        rw [← hB N' hN']
      rw [h_eq] at h_N'_mem
      sorry
    exact hNN' (le_antisymm hN_le_N' hN'_le_N)
```
