      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ (le_refl D)\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have hC_in : C ⊆ B N hN := by\n      intro c hc\n      simp only [refinement, Set.mem_iUnion] at hC_sub\n      obtain ⟨N', hN', hc'⟩ := hC_sub hc\n      have hc_le_N : c ≤ N := by\n        rw [hC_eq]\n        exact le_sSup hc\n      have hc_le_N' : c ≤ N' := by\n        rw [hB N' hN']\n        exact le_sSup hc'\n      by_cases hNN' : N = N'\n      · subst hNN'\n        exact hc'\n      · have h_disj : Disjoint N N' := D.sSupIndep.pairwise_disjoint hN hN' hNN'\n        have h_c_bot : c = ⊥ := by\n          apply le_bot_iff.mp\n          calc c ≤ N ⊓ N' := le_inf hc_le_N hc_le_N'\n            _ = ⊥ := disjoint_iff.mp h_disj\n        have hc_mem : c ∈ refinement B hB hB' hB'' := hC_sub hc\n        simp only [refinement, Set.mem_iUnion] at hc_mem\n        obtain ⟨N'', hN'', hc''⟩ := hc_mem\n        exact absurd (h_c_bot ▸ hc'') (hB'' N'' hN'')\n    have hC_eq' : sSup C = sSup (B N hN) := by\n      rw [← hB N hN, ← hC_eq]\n    have hC_eq_B : C = B N hN := by\n      apply le_antisymm hC_in\n      intro b hb\n      by_contra hb_not_in\n      have h_disj : Disjoint b (sSup C) := (hB' N hN).disjoint_sSup hb hC_in hb_not_in\n      have h_le : b ≤ sSup C := by\n        rw [hC_eq']\n        exact le_sSup hb\n      have h_b_bot : b = ⊥ := Disjoint.eq_bot_of_le h_disj h_le\n      exact absurd (h_b_bot ▸ hb) (hB'' N hN)\n    rw [hC_eq, hC_eq_B, hB N hN] at hBN\n    exact hBN rfl",
      "by\n  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')\n  intro h_eq\n  obtain ⟨N, hN, hBN⟩ := H\n  apply hBN\n  sorry",
      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ (le_refl D)\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have hN_eq : N = sSup (B N hN) := hB N hN\n    have hC_eq' : N = sSup C := hC_eq\n    have hB_sub : B N hN ⊆ refinement B hB hB' hB'' := by\n      intro x hx\n      simp only [refinement, Set.mem_iUnion]\n      exact ⟨N, hN, hx⟩\n    -- If B N hN ≠ {N}, then either B N hN has more than one element or is empty\n    by_cases h_empty : B N hN = ∅\n    · rw [h_empty, sSup_empty] at hN_eq\n      exact D.not_bot_mem (hN_eq ▸ hN)\n    · push_neg at h_empty\n      obtain ⟨x, hx⟩ := Set.nonempty_iff_ne_empty.mpr h_empty\n      have hx_ne_N : x ≠ N ∨ ∃ y ∈ B N hN, y ≠ x := by\n        by_contra h_neg\n        push_neg at h_neg\n        have : B N hN = {N} := by\n          ext z\n          constructor\n          · intro hz\n            simp only [Set.mem_singleton_iff]\n            rw [← h_neg.1]\n            exact h_neg.2 z hz\n          · intro hz\n            simp only [Set.mem_singleton_iff] at hz\n            rw [hz, h_neg.1]\n            exact hx\n        exact hBN this\n      cases hx_ne_N with\n      | inl hx_ne =>\n        have hx_le_N : x ≤ N := by rw [hN_eq]; exact le_sSup hx\n        have hx_in_ref : x ∈ refinement B hB hB' hB'' := hB_sub hx\n        have hx_in_D : x ∈ D := by\n          have := SetLike.coe_injective (congrArg SetLike.coe h_eq)\n          simp only [refinement] at this\n          rw [← this]\n          exact hx_in_ref\n        have hN_le_x : N ≤ x := by\n          have := D.sSupIndep.disjoint_sSup hN (s := D \\ {N}) (Set.diff_subset) (by simp)\n          by_contra h_neg\n          push_neg at h_neg\n          sorry\n        exact hx_ne (le_antisymm hx_le_N hN_le_x)\n      | inr ⟨y, hy, hy_ne⟩ =>\n        sorry",
      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_mem : N ∈ D := hN\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ (le_refl D)\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref h_mem\n    have hC_sub' : C ⊆ B N hN := by\n      intro c hc\n      have hc_mem : c ∈ (refinement B hB hB' hB'').carrier := hC_sub hc\n      simp only [refinement, Set.mem_iUnion] at hc_mem\n      obtain ⟨N', hN', hc_in_B⟩ := hc_mem\n      by_cases h : N' = N\n      · subst h; exact hc_in_B\n      · have h_disj : Disjoint N' N := D.sSupIndep.pairwise_disjoint hN' hN h\n        have hc_le_N' : c ≤ N' := by rw [hB N' hN']; exact le_sSup hc_in_B\n        have hc_le_N : c ≤ N := by rw [hC_eq]; exact le_sSup hc\n        have hc_bot : c = ⊥ := by\n          have : c ≤ N' ⊓ N := le_inf hc_le_N' hc_le_N\n          rw [h_disj.eq_bot] at this\n          exact le_bot_iff.mp this\n        exfalso\n        exact hB'' N hN (hc_bot ▸ hc_in_B)\n    have hN_eq : N = sSup C := hC_eq\n    have hN_eq' : N = sSup (B N hN) := hB N hN\n    have h_C_eq_B : sSup C = sSup (B N hN) := by rw [← hN_eq, ← hN_eq']\n    by_cases hC_eq_B : C = B N hN\n    · rw [hC_eq_B] at hC_eq\n      have : B N hN = {N} := by\n        ext x\n        constructor\n        · intro hx\n          have hx_le : x ≤ N := by rw [hB N hN]; exact le_sSup hx\n          have hx_le' : x ≤ sSup (B N hN) := le_sSup hx\n          rw [← hB N hN] at hx_le'\n          have hx_in_D : x ∈ (refinement B hB hB' hB'').carrier := by\n            simp only [refinement, Set.mem_iUnion]\n            exact ⟨N, hN, hx⟩\n          have hx_in_D' : x ∈ D := by\n            rw [h_eq]\n            exact hx_in_D\n          by_cases hx_eq : x = N\n          · simp [hx_eq]\n          · have h_disj : Disjoint x N := D.sSupIndep.pairwise_disjoint hx_in_D' hN hx_eq\n            have : x ≤ x ⊓ N := le_inf le_rfl hx_le\n            rw [h_disj.eq_bot] at this\n            exfalso\n            exact hB'' N hN (le_bot_iff.mp this ▸ hx)\n        · intro hx\n          simp only [Set.mem_singleton_iff] at hx\n          subst hx\n          rw [hB N hN]\n          have hne : (B N hN).Nonempty := by\n            by_contra h_empty\n            push_neg at h_empty\n            have : B N hN = ∅ := Set.not_nonempty_iff_eq_empty.mp h_empty\n            rw [this] at hN_eq'\n            simp at hN_eq'\n            exact D.not_bot_mem (hN_eq' ▸ hN)\n          obtain ⟨b, hb⟩ := hne\n          have hb_le : b ≤ sSup (B N hN) := le_sSup hb\n          exact ⟨b, hb, le_rfl⟩\n      exact hBN this\n    · have hC_ne : C.Nonempty := by\n        by_contra h_empty\n        push_neg at h_empty\n        have : C = ∅ := Set.not_nonempty_iff_eq_empty.mp h_empty\n        rw [this] at hC_eq\n        simp at hC_eq\n        exact D.not_bot_mem (hC_eq ▸ hN)\n      have hB_ne : (B N hN).Nonempty := by\n        by_contra h_empty\n        push_neg at h_empty\n        have : B N hN = ∅ := Set.not_nonempty_iff_eq_empty.mp h_empty\n        rw [this] at hN_eq'\n        simp at hN_eq'\n        exact D.not_bot_mem (hN_eq' ▸ hN)\n      have : C ⊂ B N hN ∨ C = B N hN := Set.ssubset_or_eq_of_subset hC_sub'\n      cases this with\n      | inl h_ss =>\n        have h_exists : ∃ b ∈ B N hN, b ∉ C := Set.exists_of_ssubset h_ss\n        obtain ⟨b, hb, hb_not⟩ := h_exists\n        have h_disj : Disjoint b (sSup C) := hB' N hN b hb (fun x hx => hb_not hx)\n        have hb_le : b ≤ sSup (B N hN) := le_sSup hb\n        rw [← h_C_eq_B] at hb_le\n        have : b ≤ b ⊓ sSup C := le_inf le_rfl hb_le\n        rw [h_disj.eq_bot] at this\n        exact hB'' N hN (le_bot_iff.mp this ▸ hb)\n      | inr h_eq' => exact hC_eq_B h_eq'",
