/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  obtain ⟨N, hN, hBN⟩ := H
  have h_mem : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN
  simp only [refinement, Set.mem_iUnion] at h_mem
  obtain ⟨N', hN', hN_in_B⟩ := h_mem
  by_cases hNN' : N = N'
  · subst hNN'
    have h_singleton : B N hN = {N} := by
      ext x
      constructor
      · intro hx
        have hx_le : x ≤ N := by rw [hB N hN]; exact le_sSup hx
        have hN_le : N ≤ x := by
          have : N ≤ sSup (B N hN) := by rw [← hB N hN]
          exact le_sSup_of_le hN_in_B le_rfl
        simp only [Set.mem_singleton_iff]
        exact le_antisymm hx_le hN_le
      · intro hx
        simp only [Set.mem_singleton_iff] at hx
        exact hx ▸ hN_in_B
    exact hBN h_singleton
  · have h_disj : Disjoint N N' := D.sSupIndep.pairwise_disjoint hN hN' hNN'
    have hN_le_N' : N ≤ N' := by rw [hB N' hN']; exact le_sSup hN_in_B
    have hN_bot : N = ⊥ := Disjoint.eq_bot_of_le h_disj hN_le_N'
    exact D.not_bot_mem (hN_bot ▸ hN)
