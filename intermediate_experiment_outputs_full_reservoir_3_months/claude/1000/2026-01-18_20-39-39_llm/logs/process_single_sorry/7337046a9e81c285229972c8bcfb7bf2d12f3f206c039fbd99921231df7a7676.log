      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ (le_refl D)\n    rcases h_ref hN with ⟨C, hC_sub, hC_eq⟩\n    have hC_singleton : C = {N} := by\n      have hC_sub' : C ⊆ B N hN := by\n        intro c hc\n        simp only [refinement, Set.mem_iUnion] at hC_sub\n        rcases hC_sub hc with ⟨N', hN', hc_in_B⟩\n        have hc_le_N' : c ≤ N' := by\n          rw [hB N' hN']\n          exact le_sSup hc_in_B\n        have hc_le_N : c ≤ N := by\n          rw [hC_eq]\n          exact le_sSup hc\n        by_cases hN_eq : N = N'\n        · exact hN_eq ▸ hc_in_B\n        · have hDisj : Disjoint N N' := D.sSupIndep.pairwiseDisjoint hN hN' hN_eq\n          have hc_bot : c = ⊥ := by\n            apply le_bot_iff.mp\n            calc c ≤ N ⊓ N' := le_inf hc_le_N hc_le_N'\n              _ = ⊥ := hDisj.eq_bot\n          exfalso\n          apply hB'' N' hN'\n          rw [← hc_bot]\n          exact hc_in_B\n      rw [hB N hN] at hC_eq\n      have hsSup_eq : sSup C = sSup (B N hN) := hC_eq\n      ext x\n      constructor\n      · intro hx\n        have hx_le : x ≤ sSup C := le_sSup hx\n        have hx_le' : x ≤ sSup (B N hN) := hsSup_eq ▸ hx_le\n        rw [← hB N hN] at hx_le'\n        have hx_disj : Disjoint x (sSup (B N hN \\ {x})) := (hB' N hN).disjoint_sSup (hC_sub' hx) (Set.diff_subset) (Set.not_mem_diff_of_mem rfl)\n        simp only [Set.mem_singleton_iff]\n        by_contra hx_ne\n        have hsSup_diff : sSup (B N hN \\ {x}) = sSup (B N hN) := by\n          apply le_antisymm\n          · exact sSup_le_sSup Set.diff_subset\n          · apply sSup_le\n            intro b hb\n            by_cases hbx : b = x\n            · rw [hbx]\n              rw [hB N hN] at hx_le'\n              calc x ≤ sSup C := le_sSup hx\n                _ = sSup (B N hN) := hsSup_eq\n                _ = sSup (B N hN \\ {x}) ⊔ x := by\n                  rw [sup_comm]\n                  apply le_antisymm\n                  · apply sup_le\n                    · exact le_sSup (hC_sub' hx)\n                    · exact sSup_le_sSup Set.diff_subset\n                  · apply sSup_le\n                    intro y hy\n                    by_cases hyx : y = x\n                    · exact hyx ▸ le_sup_left\n                    · exact le_sup_of_le_right (le_sSup ⟨hy, hyx⟩)\n              sorry\n            · exact le_sSup ⟨hb, hbx⟩\n        rw [hsSup_diff, ← hB N hN] at hx_disj\n        have hx_bot : x = ⊥ := Disjoint.eq_bot_of_le hx_disj hx_le'\n        apply hB'' N hN\n        rw [← hx_bot]\n        exact hC_sub' hx\n      · intro hx\n        simp only [Set.mem_singleton_iff] at hx\n        rw [hx, ← hB N hN, ← hC_eq]\n        by_contra hN_notin\n        have hsSup_le : sSup C ≤ sSup (B N hN \\ {N}) := by\n          apply sSup_le\n          intro c hc\n          exact le_sSup ⟨hC_sub' hc, fun h => hN_notin (h ▸ hc)⟩\n        have hsSup_lt : sSup (B N hN \\ {N}) < N := by\n          apply lt_of_le_of_ne\n          · rw [hB N hN]\n            exact sSup_le_sSup Set.diff_subset\n          · intro heq\n            have hN_in : N ∈ B N hN \\ {N} := by\n              rw [← heq, hB N hN]\n              sorry\n            exact hN_in.2 rfl\n        have : sSup C < N := lt_of_le_of_lt hsSup_le hsSup_lt\n        rw [hC_eq] at this\n        exact lt_irrefl _ this\n    exact hBN hC_singleton",
      "by\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_eq\n  obtain ⟨N, hN, hBN⟩ := H\n  have h_mem : N ∈ refinement B hB hB' hB'' := by\n    rw [← h_eq]\n    exact hN\n  simp only [refinement, Set.mem_iUnion] at h_mem\n  obtain ⟨N', hN', hN_in_B⟩ := h_mem\n  have hN_le_N' : N ≤ N' := by\n    rw [hB N' hN']\n    exact le_sSup hN_in_B\n  have hN'_le_N : N' ≤ sSup D := le_sSup hN'\n  rw [D.sSup_eq_top] at hN'_le_N\n  have h_disj : N = N' ∨ Disjoint N N' := by\n    by_cases h : N = N'\n    · left; exact h\n    · right\n      exact D.sSupIndep.pairwiseDisjoint hN hN' h\n  rcases h_disj with rfl | h_disj\n  · have : B N hN = {N} := by\n      apply Set.eq_singleton_iff_unique_mem.mpr\n      constructor\n      · exact hN_in_B\n      · intro x hx\n        have hx_le : x ≤ N := by\n          rw [hB N hN]\n          exact le_sSup hx\n        have hN_le_x : N ≤ x := by\n          rw [hB N hN]\n          exact le_sSup hN_in_B\n        sorry\n    exact hBN this\n  · have : N ≤ N' := hN_le_N'\n    have : N = ⊥ := Disjoint.eq_bot_of_le h_disj this\n    exact D.not_bot_mem (this ▸ hN)",
      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ le_refl D\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have h_C_sub_B : C ⊆ B N hN := by\n      intro c hc\n      simp only [refinement, Set.mem_iUnion] at hC_sub\n      obtain ⟨N', hN', hc'⟩ := hC_sub hc\n      have h_c_le_N : c ≤ N := by\n        rw [hC_eq]\n        exact le_sSup hc\n      have h_c_le_N' : c ≤ N' := by\n        rw [hB N' hN']\n        exact le_sSup hc'\n      by_cases h : N = N'\n      · subst h; exact hc'\n      · have h_disj : Disjoint N N' := D.sSupIndep.pairwise_disjoint hN hN' h\n        have h_c_bot : c = ⊥ := by\n          apply le_bot_iff.mp\n          calc c ≤ N ⊓ N' := le_inf h_c_le_N h_c_le_N'\n            _ = ⊥ := h_disj.eq_bot\n        exfalso\n        have : c ∈ (refinement B hB hB' hB'') := hC_sub hc\n        rw [h_c_bot] at this\n        exact (refinement B hB hB' hB'').not_bot_mem this\n    have h_N_eq_sSup_C : N = sSup C := hC_eq\n    have h_N_eq_sSup_B : N = sSup (B N hN) := hB N hN\n    have h_sSup_eq : sSup C = sSup (B N hN) := by rw [← h_N_eq_sSup_C, h_N_eq_sSup_B]\n    have h_C_eq_B : C = B N hN := by\n      by_contra h_ne\n      have h_strict : C ⊂ B N hN := ⟨h_C_sub_B, fun h => h_ne (le_antisymm h_C_sub_B h)⟩\n      obtain ⟨x, hx_in_B, hx_not_in_C⟩ := Set.exists_of_ssubset h_strict\n      have h_x_le_N : x ≤ N := by\n        rw [hB N hN]\n        exact le_sSup hx_in_B\n      have h_disj : Disjoint x (sSup C) := (hB' N hN).disjoint_sSup hx_in_B h_C_sub_B hx_not_in_C\n      have h_x_bot : x = ⊥ := by\n        apply le_bot_iff.mp\n        calc x ≤ x ⊓ sSup C := le_inf le_rfl (by rw [h_sSup_eq, ← hB N hN]; exact h_x_le_N)\n          _ = ⊥ := h_disj.eq_bot\n      exact hB'' N hN (h_x_bot ▸ hx_in_B)\n    have h_B_singleton : B N hN = {N} := by\n      ext y\n      constructor\n      · intro hy\n        rw [← h_C_eq_B] at hy\n        have h_y_le : y ≤ sSup C := le_sSup hy\n        rw [← hC_eq] at h_y_le\n        have h_y_in_ref : y ∈ (refinement B hB hB' hB'') := hC_sub hy\n        obtain ⟨A, hA⟩ := RefinementMapSurj' D (refinement B hB hB' hB'') (refinement_le B hB hB' hB'') ⟨y, h_y_in_ref⟩\n        simp only at hA\n        have h_A_eq_N : A.val = N := by\n          by_contra h_ne\n          have h_disj : Disjoint N A.val := D.sSupIndep.pairwise_disjoint hN A.prop h_ne\n          have h_y_bot : y = ⊥ := le_bot_iff.mp (calc y ≤ N ⊓ A.val := le_inf h_y_le hA\n            _ = ⊥ := h_disj.eq_bot)\n          exact (refinement B hB hB' hB'').not_bot_mem (h_y_bot ▸ h_y_in_ref)\n        have h_y_le_N : y ≤ N := h_A_eq_N ▸ hA\n        have h_sSup_C_le_y : sSup C ≤ y := by\n          apply sSup_le\n          intro c hc\n          have hc_in_ref : c ∈ (refinement B hB hB' hB'') := hC_sub hc\n          obtain ⟨A', hA'⟩ := RefinementMapSurj' D (refinement B hB hB' hB'') (refinement_le B hB hB' hB'') ⟨c, hc_in_ref⟩\n          simp only at hA'\n          have h_c_le_N : c ≤ N := by\n            rw [hC_eq]; exact le_sSup hc\n          have h_A'_eq_N : A'.val = N := by\n            by_contra h_ne\n            have h_disj : Disjoint N A'.val := D.sSupIndep.pairwise_disjoint hN A'.prop h_ne\n            have h_c_bot : c = ⊥ := le_bot_iff.mp (calc c ≤ N ⊓ A'.val := le_inf h_c_le_N hA'\n              _ = ⊥ := h_disj.eq_bot)\n            exact (refinement B hB hB' hB'').not_bot_mem (h_c_bot ▸ hc_in_ref)\n          rw [← h_C_eq_B] at hy hc\n          have h_disj_cy : Disjoint c y ∨ c = y := by\n            by_cases h : c = y\n            · right; exact h\n            · left; exact (hB' N hN).pairwise_disjoint (h_C_eq_B ▸ hc) (h_C_eq_B ▸ hy) h\n          rcases h_disj_cy with h_disj | h_eq\n          · have h_c_bot : c = ⊥ := by\n              apply le_bot_iff.mp\n              have h_c_le_y : c ≤ y := by\n                calc c ≤ sSup C := le_sSup hc\n                  _ ≤ y := by rw [← hC_eq]; exact h_y_le_N.trans (hC_eq ▸ le_sSup h