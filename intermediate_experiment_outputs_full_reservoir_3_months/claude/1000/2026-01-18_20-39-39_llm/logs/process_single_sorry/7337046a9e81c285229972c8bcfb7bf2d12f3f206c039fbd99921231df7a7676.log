      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ le_refl D\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have hC_sub' : C ⊆ B N hN := by\n      intro c hc\n      have hc_mem : c ∈ ⋃ N, ⋃ hN, B N hN := hC_sub hc\n      simp only [Set.mem_iUnion] at hc_mem\n      obtain ⟨N', hN', hc_in_B⟩ := hc_mem\n      by_cases h : N = N'\n      · subst h; exact hc_in_B\n      · have h_le : c ≤ N' := by rw [hB N' hN']; exact le_sSup hc_in_B\n        have h_le' : c ≤ N := by rw [hC_eq]; exact le_sSup hc\n        have h_disj : Disjoint N N' := by\n          have := D.sSupIndep.pairwise_disjoint\n          exact this hN hN' h\n        have : c ≤ N ⊓ N' := le_inf h_le' h_le\n        rw [h_disj.eq_bot] at this\n        have : c = ⊥ := le_bot_iff.mp this\n        have hc_mem_ref : c ∈ refinement B hB hB' hB'' := hC_sub hc\n        rw [this] at hc_mem_ref\n        exact absurd hc_mem_ref (refinement B hB hB' hB'').not_bot_mem\n    have hN_eq : N = sSup C := hC_eq\n    have hN_eq' : N = sSup (B N hN) := hB N hN\n    rw [hN_eq'] at hN_eq\n    have h_singleton : C = {N} ∨ C ⊆ B N hN ∧ sSup (B N hN) = sSup C := by\n      right\n      exact ⟨hC_sub', hN_eq.symm⟩\n    sorry",
      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ le_refl _\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have : C ⊆ B N hN := by\n      intro c hc\n      have hc_mem : c ∈ ⋃ N, ⋃ hN, B N hN := hC_sub hc\n      simp only [Set.mem_iUnion] at hc_mem\n      obtain ⟨N', hN', hc_in_BN'⟩ := hc_mem\n      by_cases h : N = N'\n      · subst h; exact hc_in_BN'\n      · have hc_le_N : c ≤ N := by\n          rw [hC_eq]; exact le_sSup hc\n        have hc_le_N' : c ≤ N' := by\n          rw [hB N' hN']; exact le_sSup hc_in_BN'\n        have h_disj : Disjoint N N' := D.sSupIndep.pairwise_disjoint hN hN' h\n        have hc_bot : c ≤ ⊥ := by\n          calc c ≤ N ⊓ N' := le_inf hc_le_N hc_le_N'\n            _ = ⊥ := h_disj.eq_bot\n        have : c = ⊥ := le_bot_iff.mp hc_bot\n        exfalso\n        exact hB'' N' hN' (this ▸ hc_in_BN')\n    have hC_eq' : sSup C = sSup (B N hN) := by rw [← hC_eq, ← hB N hN]\n    have : C = B N hN ∨ C ⊂ B N hN := eq_or_ssubset_of_subset this\n    cases this with\n    | inl h_eq =>\n      rw [← h_eq, ← hC_eq] at hBN\n      exact hBN rfl\n    | inr h_ssubset =>\n      have h_strict : sSup C < sSup (B N hN) ∨ sSup C = sSup (B N hN) := by\n        right; exact hC_eq'\n      sorry",
