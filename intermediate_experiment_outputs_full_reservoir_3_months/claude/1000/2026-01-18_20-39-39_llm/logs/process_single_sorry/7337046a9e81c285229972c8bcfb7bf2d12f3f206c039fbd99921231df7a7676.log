      "by\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_eq\n  obtain ⟨N, hN, hBN⟩ := H\n  have h_mem : N ∈ refinement B hB hB' hB'' := by\n    rw [← h_eq]\n    exact hN\n  simp only [refinement, Set.mem_iUnion] at h_mem\n  obtain ⟨N', hN', hN_in_B⟩ := h_mem\n  by_cases hNN' : N = N'\n  · subst hNN'\n    have hBN_singleton : B N hN = {N} := by\n      apply Set.eq_singleton_iff_unique_mem.mpr\n      constructor\n      · exact hN_in_B\n      · intro x hx\n        have hx_le : x ≤ N := by\n          rw [hB N hN]\n          exact le_sSup hx\n        have hN_le : N ≤ x := by\n          have : N ≤ sSup (B N hN) := by rw [← hB N hN]\n          exact le_sSup_of_le hN_in_B le_rfl\n        sorry\n    exact hBN hBN_singleton\n  · have hN_le_N' : N ≤ N' := by\n      rw [hB N' hN']\n      exact le_sSup hN_in_B\n    have hN'_le_N : N' ≤ N := by\n      have h_N'_mem : N' ∈ refinement B hB hB' hB'' := by\n        simp only [refinement, Set.mem_iUnion]\n        refine ⟨N', hN', ?_⟩\n        rw [← hB N' hN']\n      rw [h_eq] at h_N'_mem\n      sorry\n    exact hNN' (le_antisymm hN_le_N' hN'_le_N)",
      "by\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, hBN⟩ := H\n    have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_eq ▸ (le_refl D)\n    obtain ⟨C, hC_sub, hC_eq⟩ := h_ref hN\n    have hN_eq : N = sSup (B N hN) := hB N hN\n    have hC_sub' : C ⊆ B N hN := by\n      intro c hc\n      have hc_mem : c ∈ (refinement B hB hB' hB'').carrier := hC_sub hc\n      simp only [refinement, Set.mem_iUnion] at hc_mem\n      obtain ⟨N', hN', hc_in_BN'⟩ := hc_mem\n      by_cases h : N' = N\n      · subst h; exact hc_in_BN'\n      · have hc_le_N' : c ≤ N' := by rw [hB N' hN']; exact le_sSup hc_in_BN'\n        have hc_le_N : c ≤ N := by rw [hC_eq]; exact le_sSup hc\n        have h_disj : Disjoint N N' := D.sSupIndep.pairwiseDisjoint hN hN' h\n        have hc_bot : c = ⊥ := by\n          apply le_bot_iff.mp\n          calc c ≤ N ⊓ N' := le_inf hc_le_N hc_le_N'\n               _ = ⊥ := h_disj.eq_bot\n        exfalso\n        apply hB'' N hN\n        rw [← hc_bot]\n        exact hc_in_BN'\n    have hC_eq' : sSup C = sSup (B N hN) := by rw [← hC_eq, ← hN_eq]\n    have hC_eq_BN : C = B N hN := by\n      by_contra h_ne\n      have h_strict : C ⊂ B N hN := Set.ssubset_of_subset_of_ne hC_sub' h_ne\n      obtain ⟨x, hx_in_B, hx_not_in_C⟩ := Set.exists_of_ssubset h_strict\n      have hx_le : x ≤ sSup C := by rw [hC_eq']; exact le_sSup hx_in_B\n      have h_disj : Disjoint x (sSup C) := (hB' N hN).disjoint_sSup hx_in_B hC_sub' hx_not_in_C\n      have hx_bot : x = ⊥ := by\n        apply le_bot_iff.mp\n        calc x ≤ x ⊓ sSup C := le_inf le_rfl hx_le\n             _ = ⊥ := h_disj.eq_bot\n      exact hB'' N hN (hx_bot ▸ hx_in_B)\n    have hBN_singleton : B N hN = {N} := by\n      rw [← hC_eq_BN]\n      ext y\n      simp only [Set.mem_singleton_iff]\n      constructor\n      · intro hy\n        have hy_le : y ≤ N := by rw [hC_eq]; exact le_sSup hy\n        have hN_le_y : N ≤ y := by\n          rw [hC_eq]\n          apply sSup_le\n          intro z hz\n          have hz_le_y : z ≤ y := by\n            by_contra h_not_le\n            have h_disj : Disjoint z (sSup (C \\ {z})) := \n              (hB' N hN).disjoint_sSup (hC_eq_BN ▸ hz) (by rw [hC_eq_BN]; exact Set.diff_subset) \n                (Set.not_mem_diff_of_mem rfl)\n            sorry\n          sorry\n        exact le_antisymm hy_le hN_le_y\n      · intro hy\n        subst hy\n        have : sSup C = N := by rw [hC_eq]\n        sorry\n    exact hBN hBN_singleton",
