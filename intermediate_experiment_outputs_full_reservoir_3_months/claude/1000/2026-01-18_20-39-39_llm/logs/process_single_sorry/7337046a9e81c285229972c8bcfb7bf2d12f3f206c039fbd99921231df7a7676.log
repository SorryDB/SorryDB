    · push_neg at h_empty
      obtain ⟨x, hx⟩ := Set.nonempty_iff_ne_empty.mpr h_empty
      have hx_in_D : x ∈ D.carrier := hN_subset hx
      have hx_le_N : x ≤ N := by
