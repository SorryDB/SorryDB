      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        let offset := (List.take idx (l.set idx l1).map List.length).sum
        have h_len : offset + idx1 < (l.set idx l1).flatten.length := by
          simp only [List.length_flatten]
