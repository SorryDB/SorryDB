2. For the backward direction: If `X` is uniformly integrable, we need to show `ClassD X 𝓕 P`.

Looking at the existing proof for `Submartingale.classD_iff_uniformIntegrable`, I can adapt a similar approach using the norm process.

```lean
lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  let S := {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤}
  let G (T : S) : (Ω → E) := stoppedValue X T.1
  refine ⟨fun hp => ?_, fun hq => ?_⟩
  · let constT (t : ι) : S := ⟨fun ω : Ω => t, ⟨isStoppingTime_const 𝓕 t, by simp⟩⟩
    have eq : X = G ∘ constT := by ext; simp [constT, G, stoppedValue]
    simpa [eq] using hp.2.comp constT
  · have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
    refine ⟨h_prog, ?_⟩
    have hY_ui : UniformIntegrable (fun t => fun ω => ‖X t ω‖) 1 P := hq.norm
    have hY_sub : Submartingale (fun t ω => ‖X t ω‖) 𝓕 P := hX1.submartingale_convex_comp
      (convexOn_norm convex_univ) continuous_norm (fun t => (hX1.integrable t).norm)
    have hY_cont : ∀ ω, RightContinuous (fun t => ‖X t ω‖) := fun ω t => (hX2 ω t).norm
    have hY_nonneg : 0 ≤ fun t ω => ‖X t ω‖ := fun t ω => norm_nonneg _
    have hY_classD := (hY_sub.classD_iff_uniformIntegrable hY_cont hY_nonneg).mpr hY_ui
    rw [uniformIntegrable_iff_norm h_prog.aestronglyMeasurable]
    exact hY_classD.2
