/- This is the last exercise from the lecture. -/
example (a b : ℝ) (ha : 0 < a) (hb : 0 < b) :
    ∫ x in a..b, 1 / x + 1 / x ^ 2 =
  log b + 1 / a - log a - 1 / b := by
  have : 0 ∉ [[a, b]] := by
    simp only [uIcc, mem_Icc, not_and_or, not_le]
    by_cases hab : a ≤ b
    · simp [min_eq_left hab, max_eq_right hab]
