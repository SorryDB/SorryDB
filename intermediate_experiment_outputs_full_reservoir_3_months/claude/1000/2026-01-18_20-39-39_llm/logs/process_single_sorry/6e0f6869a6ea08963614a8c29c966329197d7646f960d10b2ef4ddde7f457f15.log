def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext
  constructor
  · intro h
    subst h
    unfold beq beq.go
    induction (w - 1) with
    | zero => simp
    | succ n ih => simp [ih]
  · intro h
    apply BitVec.eq_of_getLsbD_eq
    intro i
    unfold beq at h
    have hi : i.val ≤ w - 1 ∨ i.val > w - 1 := Nat.le_or_lt i.val (w - 1)
    cases hi with
    | inl hle =>
      have : w - 1 - (w - 1 - i.val) = i.val := by omega
      induction (w - 1) with
      | zero =>
        simp [beq.go] at h
        have : i.val = 0 := by omega
        simp_all
      | succ n ih =>
        simp only [beq.go, Bool.and_eq_true, beq_iff_eq] at h
        by_cases hcase : i.val = w - 1 - (n + 1)
        · rw [← hcase]
          exact h.1
        · apply ih h.2
          omega
    | inr hgt =>
      have : i.val ≥ w := by omega
      have hi' : i.val < w := i.isLt
      omega
```
