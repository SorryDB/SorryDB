      rw [← InternalTangentSpace.lof_comp_apply p (contDiff_of_mem_isPlot (IsFineDiffeology.isPlot_iff.mp p.2.1)) p.2.2]
      congr 1
      · ext t
        simp only [Function.comp_apply, add_zero]
        rw [p.2.2]
    | H_plus u v hu hv =>
      obtain ⟨a, ha⟩ := hu
      obtain ⟨b, hb⟩ := hv
      exact ⟨a + b, by simp [map_add, ha, hb]⟩
