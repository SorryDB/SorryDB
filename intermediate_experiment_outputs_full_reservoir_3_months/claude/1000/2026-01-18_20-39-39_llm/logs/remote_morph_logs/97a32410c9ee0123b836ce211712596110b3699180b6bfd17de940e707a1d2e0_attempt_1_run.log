```lean
lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h := cfc_toLinearFunctional_bound ha x y
  unfold cfc_toComplexMeasure
  apply ComplexRMK.rieszMeasure_variation_le_norm
  calc ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y)
      (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖
