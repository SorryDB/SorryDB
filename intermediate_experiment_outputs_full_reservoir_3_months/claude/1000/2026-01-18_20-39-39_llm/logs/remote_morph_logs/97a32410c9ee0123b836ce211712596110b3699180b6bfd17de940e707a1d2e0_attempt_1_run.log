      apply ContinuousLinearMap.opNorm_comp_le
    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * 1 := by
      apply mul_le_mul_of_nonneg_left _ (norm_nonneg _)
      exact ContinuousLinearEquiv.norm_symm_toContinuousLinearMap_le _
    _ ≤ ‖x‖ * ‖y‖ := by rw [mul_one]; exact cfc_toLinearFunctional_bound ha x y
