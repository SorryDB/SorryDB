lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk']
  rw [← Tensorial.smulLinearMap_apply]
  congr 1
  conv_lhs =>
    enter [2, μ, 2, ν]
    rw [SpaceTime.distDeriv_smul_eq]
  conv_rhs =>
    rw [Finset.sum_comm]
    enter [2, ν, 2, μ]
    rw [Tensorial.smul_prod, smul_smul]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl (fun μ _ => ?_)
  apply Finset.sum_congr rfl (fun ν _ => ?_)
  simp only [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
