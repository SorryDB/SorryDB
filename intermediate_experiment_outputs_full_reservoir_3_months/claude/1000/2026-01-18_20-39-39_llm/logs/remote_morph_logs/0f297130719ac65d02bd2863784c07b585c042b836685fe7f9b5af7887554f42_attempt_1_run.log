  apply Finset.sum_congr rfl (fun κ _ => ?_)
  rw [sum_tmul, Finset.smul_sum]
  apply Finset.sum_congr rfl (fun ρ _ => ?_)
  rw [smul_tmul, tmul_smul, smul_smul, smul_smul]
  ring_nf
