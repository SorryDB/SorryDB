lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk']
  conv_rhs => rw [Tensorial.smul_sum, Tensorial.smul_sum]
  congr 1
  funext μ
  congr 1
  funext ν
  rw [Tensorial.smul_prod, smul_smul]
  congr 1
  · rw [SpaceTime.distDeriv_equivariant]
    simp only [ContinuousLinearMap.coe_smul', Pi.smul_apply]
    rfl
  · rw [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
    rfl
```
