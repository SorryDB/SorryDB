      factorial_factorization_eq_div hprime hp']
    have hsum_nonneg : (P.initial.a.map (·.factorization p)).sum ≥ 0 := Nat.zero_le _
    have hdiv_le : P.n / p ≤ (P.initial.a.map (·.factorization p)).sum + P.M := by
      have hle := sum_valuation_le_M_mul_interval_count P hp'
      have hcount := count_multiples_le (P.n - P.n / P.M) P.n p hprime.pos
      have hbound := count_bound_aux P.n P.M p hprime.pos
      rw [Nat.sub_sub_self (div_le_self _ _)] at hcount
      nlinarith
    omega
  · simp only [Factorization.balance, Factorization.sum,
      Nat.factorization_eq_zero_of_not_prime _ hprime, Nat.cast_zero, sub_zero]
    have : (P.initial.a.map (·.factorization p)).sum = 0 := sum_eq_zero fun x hx ↦ by
      simp only [Multiset.mem_map] at hx
      obtain ⟨m, _, rfl⟩ := hx
      exact Nat.factorization_eq_zero_of_not_prime m hprime
    simp [this]
