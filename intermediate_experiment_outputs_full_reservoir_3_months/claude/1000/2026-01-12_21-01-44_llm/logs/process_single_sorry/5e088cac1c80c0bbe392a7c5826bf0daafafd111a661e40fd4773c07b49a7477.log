set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  have : (∑ k ∈ Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 2 ^ (3 * k)) % 5 = 2 % 5 := by
    have h1 : (9 : ℤ) ^ (2 * n + 1) = ∑ k ∈ Finset.range (2 * n + 2), (2 * n + 1).choose k * 8 ^ k := by
      simp [Commute.add_pow (by ring : (1 : ℤ) * 8 = 8 * 1)]
      norm_num
    omega
  omega
