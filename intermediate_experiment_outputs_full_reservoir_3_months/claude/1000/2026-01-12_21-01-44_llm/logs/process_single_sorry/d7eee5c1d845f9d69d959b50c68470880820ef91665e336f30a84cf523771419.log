    [Algebra K L] [ValuativeExtension K L]
    [IsGaloisGroup G K L] : ShortComplex (Rep ℤ G) where
  X₁ := Rep.ofAlgebraAutOnUnits' G 𝒪[K] 𝒪[L]
  X₂ := Rep.ofAlgebraAutOnUnits' G K L
