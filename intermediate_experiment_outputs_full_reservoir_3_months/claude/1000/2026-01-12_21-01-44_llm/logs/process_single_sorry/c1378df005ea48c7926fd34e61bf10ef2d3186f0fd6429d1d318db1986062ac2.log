open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    by_cases h : Nonempty ι
    · have he : ∀ i, ∃ c d : ℝ, c > 0 ∧ d > 0 ∧ 
        ∀ x : E i, (c • ‖x‖^2 ≤ re (inner x x)) ∧ (re (inner x x) ≤ d • ‖x‖^2) := 
        fun i => inner_top_equiv_norm (𝕜:=𝕜) (E:=E i)
      choose c d hc hd hcd using he
      let cmin := Finset.univ.inf' Finset.univ_nonempty c
      let dmax := Finset.univ.sup' Finset.univ_nonempty d
      refine ⟨cmin / Fintype.card ι, dmax * Fintype.card ι, ?_, ?_, ?_⟩
      · apply div_pos
        · apply Finset.lt_inf'_iff.mpr; intro i _; exact hc i
        · exact Nat.cast_pos.mpr Fintype.card_pos
      · apply mul_pos
        · apply Finset.sup'_lt_iff.mpr; intro i _; exact hd i
        · exact Nat.cast_pos.mpr Fintype.card_pos
      · intro x
        constructor
        · sorry
