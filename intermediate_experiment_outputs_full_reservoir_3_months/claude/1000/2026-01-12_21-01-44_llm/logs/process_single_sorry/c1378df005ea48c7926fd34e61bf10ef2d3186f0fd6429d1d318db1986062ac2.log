    · refine ⟨1, 1, one_pos, one_pos, ?_⟩
      intro x
      have : IsEmpty ι := not_nonempty_iff.mp h
      simp [Finset.sum_eq_zero_iff, Finset.mem_univ, forall_true_left]
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
