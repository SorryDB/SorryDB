axiom hTpq0 : (T p → Type) = (T q → Type) -- (provable from hpq)
axiom tp : T p
axiom tq : T q
axiom htpq : tp = Eq.mpr hTpq tq

universe u v

theorem test {A : Type u} {U V : A → Type v}
  (hAUBV : ((a : A) → U a) = ((a : A) → V a))
  : U = V := by
  funext a
  exact congrArg (fun f => f a) (congrArg (fun T => (a : A) → T a) (funext fun a => rfl)) ▸ congrArg (fun f => f a) hAUBV
```

