theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hu : u = 39 := by
    have : u ∈ S := h₁.1
    have : 14 * u % 100 = 46 := (h₀ u).1 this |>.2
    have : 14 * 39 % 100 = 46 := by norm_num
    have : 39 ∈ S := (h₀ 39).2 ⟨by norm_num, by norm_num⟩
    have : ∀ n ∈ S, 39 ≤ n := by
      intro n hn
      have : 14 * n % 100 = 46 := (h₀ n).1 hn |>.2
      interval_cases n <;> norm_num at this
    have := h₁.2 this
    omega
  have hv : v = 89 := by
    have : v ∈ S \ {u} := h₂.1
    have : 14 * v % 100 = 46 := (h₀ v).1 this.1 |>.2
    have : 89 ∈ S \ {u} := by
      constructor
      · exact (h₀ 89).2 ⟨by norm_num, by norm_num⟩
      · simp [hu]; norm_num
    have : ∀ n ∈ S \ {u}, 89 ≤ n := by
      intro n hn
      have : 14 * n % 100 = 46 := (h₀ n).1 hn.1 |>.2
      have : n ≠ u := hn.2
      rw [hu] at this
      interval_cases n <;> norm_num at this
    have := h₂.2 this
    omega
  rw [hu, hv]
  norm_num
