  obtain ⟨l, hl⟩ := hf (by positivity : 0 < ε / 3)
  refine ⟨min l (ε / 3), by positivity, fun x y hxy => ?_⟩
  obtain ⟨t, ⟨-, -⟩, ht⟩ := hl (x - y)
  calc Complex.dist (f x) (f y)
