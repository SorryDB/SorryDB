    _ = ‖(f x - f ((x - y) + t)) + (f ((x - y) + t) - f (y + t)) + (f (y + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f ((x - y) + t)‖ + ‖f ((x - y) + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := by
