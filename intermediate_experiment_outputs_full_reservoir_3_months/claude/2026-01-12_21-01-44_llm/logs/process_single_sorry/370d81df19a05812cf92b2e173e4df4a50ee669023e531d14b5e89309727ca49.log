namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  by_contra h
  push_neg at h
  have hA : A.card < m / 2 := by exact_mod_cast h
  have hm_pos : 0 < m := by omega
  have : m / 2 ≤ m - 1 := by omega
  have : A.card ≤ m - 1 := by omega
  sorry
