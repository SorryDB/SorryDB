    let u := U8x32_as_Nat mp

    if (Z - Y) % p = 0 then
      u % p = 0
    else
      u * (Z - Y) % p = (Z + Y) % p := by

    progress as ⟨mp, h_ret, h_prop⟩
    exact ⟨mp, h_ret, h_prop⟩
