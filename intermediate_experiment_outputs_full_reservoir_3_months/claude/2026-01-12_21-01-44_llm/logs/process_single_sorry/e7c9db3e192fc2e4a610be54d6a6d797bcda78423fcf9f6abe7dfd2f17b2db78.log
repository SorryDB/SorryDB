lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  define at h1
  define at h2
  apply Exists.intro (fun x : A \ {a} => ⟨f x.val, by
    have hxA : x.val ∈ A := x.property.left
    have hxna : x.val ∉ {a} := x.property.right
    have hfxB : f x.val ∈ B := by rw [←h2]; exact ⟨x.val, hxA, rfl⟩
    apply And.intro hfxB
    define; intro hfxa
    define at hxna; apply hxna; rw [←hfxa, ←h4]
    exact h1 hxA h3⟩)
  apply Exists.intro (fun y : B \ {b} => ⟨Classical.choose (by
    rw [←h2] at y; exact y.property.left), by
    have hy : y.val ∈ B := y.property.left
    have hyb : y.val ≠ b := by define at y; exact y.property.right
    rw [←h2] at hy
    obtain ⟨u, huA, hfu⟩ := hy
    have := Classical.choose_spec (by exact hy)
    apply And.intro
    · apply And.intro this.left
      define; intro hua; define at hua
      apply hyb; rw [←hfu, ←h4, hua]
      exact h1 this.left h3
    · rw [←hfu]; exact this.right⟩)
  apply And.intro <;> funext x <;> simp <;> apply Subtype.eq <;> simp
  · have := Classical.choose_spec (by rw [←h2]; exact x.property.left)
    exact this.right
  · have hxA : x.val ∈ A := x.property.left
    have hfx := Classical.choose_spec (by rw [←h2]; exact ⟨x.val, hxA, rfl⟩)
    exact h1 hfx.left hxA hfx.right
