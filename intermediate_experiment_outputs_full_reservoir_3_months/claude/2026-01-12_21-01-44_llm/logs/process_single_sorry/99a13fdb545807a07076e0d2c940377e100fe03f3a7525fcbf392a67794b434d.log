      exact ((stronglyMeasurable_stoppedValue (hD.progMeasurable) T.2.1).mono
        (Filtration.le' 𝓕 _)).aestronglyMeasurable
    · intro hU
      have : ClassD Y 𝓕 P := by
        rw [hY_sub.classD_iff_uniformIntegrable hY_cont hY_nonneg]
        exact hU
      refine ⟨hX1.adapted.progMeasurable_of_rightContinuous hX2, ?_⟩
