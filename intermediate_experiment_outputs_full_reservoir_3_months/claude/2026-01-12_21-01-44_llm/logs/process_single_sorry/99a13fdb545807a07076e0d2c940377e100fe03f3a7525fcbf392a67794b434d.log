    have hY_cont : ∀ ω, RightContinuous (Y · ω) := fun ω t ↦ (hX2 ω t).norm
    have hY_nonneg : 0 ≤ Y := fun t ω ↦ norm_nonneg _
    constructor
    · intro hD
      rw [← hY_sub.classD_iff_uniformIntegrable hY_cont hY_nonneg]
      refine ⟨hY_sub.adapted.progMeasurable_of_rightContinuous hY_cont, ?_⟩
      refine uniformIntegrable_of_uniformIntegrable_norm ?_ hD.2
