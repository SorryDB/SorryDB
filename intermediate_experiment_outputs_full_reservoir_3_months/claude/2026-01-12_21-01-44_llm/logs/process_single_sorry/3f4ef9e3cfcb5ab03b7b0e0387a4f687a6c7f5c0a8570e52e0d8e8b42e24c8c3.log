  by_contra h
  rw [not_nonempty_iff_eq_empty] at h
  have : trivialInvo k ^ 2 = 1 := by
    change trivialInvo k ∘ trivialInvo k = id
    funext ⟨⟨⟨x, y, z⟩, hS⟩, hT⟩
    simp [trivialInvo]
