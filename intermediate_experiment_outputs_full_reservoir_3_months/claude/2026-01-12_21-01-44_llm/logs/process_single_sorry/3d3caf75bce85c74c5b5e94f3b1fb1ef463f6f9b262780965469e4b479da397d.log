    · have : biasedEnergyDiff net x i < 0 := 
        biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net x i h_neq hlf
      linarith
  · intro h
    unfold biasedEnergyDiff
    rw [h]
```
