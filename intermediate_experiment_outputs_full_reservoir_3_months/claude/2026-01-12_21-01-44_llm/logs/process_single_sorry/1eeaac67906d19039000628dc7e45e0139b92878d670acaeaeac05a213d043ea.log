rewrite [show y^3 - x^3 = (y - x) * (x ^ 2 + x * y + y ^ 2) by ring_nf]
rewrite [show |(y - x) * (x ^ 2 + x * y + y ^ 2)| = |y - x| * |x ^ 2 + x * y + y ^ 2| by apply abs_mul]
have hy' : |y| ≤ |x| + 1 := by calc |y| = |y - x + x| := by ring_nf
    _ ≤ |y - x| + |x| := by apply abs_add
    _ < δ + |x| := by linarith
    _ ≤ 1 + |x| := by linarith
    _ = |x| + 1 := by ring
