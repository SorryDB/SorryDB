    (h1 h2 : Hom c d) (h : h1 ≠ h2) :
    NatTrans_Hom_c_?_Hom_?_c c d h1 ≠ NatTrans_Hom_c_?_Hom_?_c c d h2 := by
  intro heq
  have : (NatTrans_Hom_c_?_Hom_?_c c d h1).arrow d = (NatTrans_Hom_c_?_Hom_?_c c d h2).arrow d := by
    rw [heq]
  simp only [NatTrans_Hom_c_?_Hom_?_c] at this
  have : h1 ≫ id d = h2 ≫ id d := by
    have := congr_fun this (id d)
    exact this
  rw [id_right, id_right] at this
  exact h this
```
