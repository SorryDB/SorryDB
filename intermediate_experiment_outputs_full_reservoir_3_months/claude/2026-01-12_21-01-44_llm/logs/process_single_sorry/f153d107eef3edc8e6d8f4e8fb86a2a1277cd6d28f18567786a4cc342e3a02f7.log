theorem well_typed_well_typed' {ε} {e : ExprLow Ident Typ} :
  e.well_formed ε →
  e.well_typed ε →
  e.well_typed' ε := by
  induction e with
  | base inst typ =>
    intro hwf hwt; dsimp [well_typed', build_module_interface', well_typed'', well_formed] at *
    split at hwf
    rename_i _ _ heq; rw [heq]; constructor; simp [Option.map]; rfl
    contradiction
  | connect c e ih =>
    intro hwf hwt
    dsimp [well_typed', build_module_interface', well_typed''] at *
    obtain ⟨hwt1, mi, T, hbuild, hf1, hf2⟩ := hwt
    obtain ⟨mi', hbuild', hwt'⟩ := ih (well_formed_connect.mp hwf) hwt1
    rw [hbuild']
    constructor
    intro x T' hfind
    obtain ⟨mi'', hbuild''⟩ := build_module_interface_build_module_interface'' hbuild
    rw [hbuild''] at hbuild; cases hbuild
    apply hwt'
    apply Batteries.AssocList.find?_eraseAll
    assumption
  | product e1 e2 he1 he2 =>
    intro hwf hwt
    dsimp [well_typed', build_module_interface', well_typed'', well_formed] at *
    simp at hwf; dsimp [well_typed] at hwt
    specialize he1 hwf.1 hwt.1
    specialize he2 hwf.2 hwt.2
    obtain ⟨mi1, hb1, hwt1⟩ := he1
    obtain ⟨mi2, hb2, hwt2⟩ := he2
    rw [hb1, hb2]
    dsimp; constructor
