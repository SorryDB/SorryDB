import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro y
  push_neg at h₁
  obtain ⟨x₀, hx₀⟩ := h₁
  by_cases hg : g y = 0
  · simp [hg]
  have key := h₀ x₀ y
  rw [key]
  have hfx₀ : f x₀ ≠ 0 := hx₀
  have : 2 * f x₀ * g y = f (x₀ + y) + f (x₀ - y) := key.symm
  have bound : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by
    calc |f (x₀ + y) + f (x₀ - y)| 
        ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _
      _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)
      _ = 2 := by norm_num
  rw [← this] at bound
  have : |2 * f x₀ * g y| ≤ 2 := bound
  rw [abs_mul, abs_mul] at this
  simp only [abs_two] at this
  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hfx₀
  have : 2 * |f x₀| * |g y| ≤ 2 := this
  linarith [h₂ x₀, mul_pos (by norm_num : (0:ℝ) < 2) hfx₀_pos]
```
