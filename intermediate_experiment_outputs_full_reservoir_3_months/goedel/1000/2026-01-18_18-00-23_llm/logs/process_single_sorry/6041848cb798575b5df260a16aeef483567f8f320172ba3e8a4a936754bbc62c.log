theorem bayesTheorem (hB : ℙ B ≠ 0) : ℙ(A|B) = ℙ A * ℙ(B|A) / ℙ B := by
  by_cases h : ℙ A = 0
  · -- Case: ℙ A = 0
    have h₁ : ℙ (A ∩ B) = 0 := by
      calc
        ℙ (A ∩ B) ≤ ℙ A := by
          apply measure_mono
          exact intersect_subset_left
        _ = 0 := by rw [h]
    have h₂ : ℙ(A|B) = 0 := by
      rw [condProb]
      have h₃ : (0 : ENNReal) < ℙ B := by
        exact lt_of_le_of_ne (by
          -- Prove that 0 ≤ ℙ B
          apply zero_le
          ) (by
          -- Prove that ℙ B ≠ 0
          intro h₄
          apply hB
          simp_all [ENNReal.ext_iff]
          <;> norm_num at * <;> simp_all
          )
      rw [h₁]
      simp [div_eq_mul_inv]
      <;> simp_all [ENNReal.mul_zero, ENNReal.zero_mul]
      <;> field_simp [h₃.ne'] <;> simp_all [ENNReal.ext_iff]
      <;> norm_num
      <;> linarith
    have h₃ : ℙ A * ℙ(B|A) / ℙ B = 0 := by
      calc
        ℙ A * ℙ(B|A) / ℙ B = 0 * ℙ(B|A) / ℙ B := by rw [h]
        _ = 0 / ℙ B := by simp [zero_mul]
        _ = 0 := by
          have h₄ : (0 : ENNReal) < ℙ B := by
            exact lt_of_le_of_ne (by apply zero_le) (by intro h₄; apply hB; simp_all [ENNReal.ext_iff] <;> norm_num at * <;> simp_all)
          simp [div_eq_mul_inv]
          <;> simp_all [ENNReal.ext_iff]
          <;> norm_num
          <;> linarith
    rw [h₂, h₃]
  · -- Case: ℙ A ≠ 0
    have h₁ : 0 < ℙ A := by
      have h₁ : 0 ≤ ℙ A := by apply zero_le
      have h₂ : ℙ A ≠ 0 := h
      exact lt_of_le_of_ne h₁ (by intro h₃; apply h₂; simp_all [ENNReal.ext_iff])
    have h₂ : 0 < ℙ B := by
      have h₂ : 0 ≤ ℙ B := by apply zero_le
      have h₃ : ℙ B ≠ 0 := hB
      exact lt_of_le_of_ne h₂ (by intro h₄; apply h₃; simp_all [ENNReal.ext_iff])
    have h₃ : ℙ(A|B) = ℙ (A ∩ B) / ℙ B := by
      rw [condProb]
    have h₄ : ℙ A * ℙ(B|A) / ℙ B = (ℙ A * (ℙ (B ∩ A) / ℙ A)) / ℙ B := by
      have h₄₁ : ℙ(B|A) = ℙ (B ∩ A) / ℙ A := by
        rw [condProb]
        <;>
        (try simp_all [inter_comm]) <;>
        (try ring_nf) <;>
        (try field_simp [h, ENNReal.ext_iff, instFunLikeApply]) <;>
        (try norm_num) <;>
        (try linarith)
        <;>
        simp_all [inter_comm]
        <;>
        ring_nf
        <;>
        field_simp [h, ENNReal.ext_iff, instFunLikeApply]
        <;>
        norm_num
        <;>
        linarith
      rw [h₄₁]
      <;>
      simp_all [mul_assoc]
      <;>
      ring_nf
      <;>
      field_simp [h, ENNReal.ext_iff, instFunLikeApply]
      <;>
      norm_num
      <;>
      linarith
    have h₅ : (ℙ A * (ℙ (B ∩ A) / ℙ A)) / ℙ B = (ℙ (B ∩ A)) / ℙ B := by
      have h₅₁ : ℙ A * (ℙ (B ∩ A) / ℙ A) = ℙ (B ∩ A) := by
        calc
