      ring_nf
      <;>
      simp_all [measure_inter_comm]
      <;>
      linarith
    calc
      ℙ (A | B) = ℙ (A ∩ B) / ℙ B := rfl
      _ = (ℙ A * (ℙ (A ∩ B) / ℙ A)) / ℙ B := by
        field_simp [h]
        <;>
        ring_nf
        <;>
        simp_all [measure_inter_comm]
        <;>
        linarith
