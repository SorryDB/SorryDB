theorem bayesTheorem (hB : ℙ B ≠ 0) : ℙ(A|B) = ℙ A * ℙ(B|A) / ℙ B := by
  by_cases h : ℙ A = 0
  · -- Case: ℙ A = 0
    have h₁ : ℙ(A | B) = 0 := by
      -- Since ℙ A = 0, the probability of A given B is 0
      have h₂ : ℙ (A ∩ B) = 0 := by
        calc
          ℙ (A ∩ B) ≤ ℙ A := by
            -- The probability of the intersection is less than or equal to the probability of A
            apply measure_mono
            · -- A ∩ B is a subset of A
              exact Set.inter_subset_left
            · -- A and B are measurable (this is a standard assumption in measure theory)
              exact MeasurableSet.inter (by
                -- A is measurable (this is a standard assumption in measure theory)
                infer_instance) (by
                -- B is measurable (this is a standard assumption in measure theory)
                infer_instance)
          _ = 0 := by rw [h]
      -- Using the above result, we can conclude that ℙ(A | B) = 0
      calc
        ℙ (A | B) = ℙ (A ∩ B) / ℙ B := rfl
        _ = 0 / ℙ B := by rw [h₂]
        _ = 0 := by simp
        _ = 0 := by rfl
    have h₂ : ℙ A * ℙ (B | A) / ℙ B = 0 := by
      -- Since ℙ A = 0, the product ℙ A * ℙ(B | A) is 0, and the division by ℙ B (which is not 0) remains 0
      calc
        ℙ A * ℙ (B | A) / ℙ B = 0 * ℙ (B | A) / ℙ B := by rw [h]
        _ = 0 / ℙ B := by simp
        _ = 0 := by simp [hB]
    -- Combining both results, we get ℙ(A | B) = ℙ A * ℙ(B | A) / ℙ B
    rw [h₁, h₂]
  · -- Case: ℙ A ≠ 0
    -- When ℙ A ≠ 0 and ℙ B ≠ 0, we can directly apply the definition of conditional probability and algebraic manipulation
    have h₁ : ℙ (A | B) = ℙ (A ∩ B) / ℙ B := rfl
    have h₂ : ℙ (B | A) = ℙ (A ∩ B) / ℙ A := by
