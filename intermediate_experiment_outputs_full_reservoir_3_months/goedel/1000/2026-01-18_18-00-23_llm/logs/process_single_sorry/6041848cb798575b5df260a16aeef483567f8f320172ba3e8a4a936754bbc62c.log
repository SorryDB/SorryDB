theorem bayesTheorem (hB : ℙ B ≠ 0) : ℙ(A|B) = ℙ A * ℙ(B|A) / ℙ B := by
  by_cases h : ℙ A = 0
  · -- Case: ℙ A = 0
    have h₁ : ℙ (A ∩ B) = 0 := by
      calc
        ℙ (A ∩ B) ≤ ℙ A := by
          apply measure_mono
          · -- Prove A ∩ B ⊆ A
            intro x hx
            exact hx.1
          · -- A is measurable by default
            exact MeasurableSet.inter (measurableSet_self) (measurableSet_self)
        _ = 0 := by rw [h]
    have h₂ : ℙ(A|B) = 0 := by
      rw [condProb]
      have h₃ : ℙ (A ∩ B) = 0 := h₁
      rw [h₃]
      simp [hB]
    have h₃ : ℙ A * ℙ(B|A) / ℙ B = 0 := by
      calc
        ℙ A * ℙ(B|A) / ℙ B = 0 * ℙ(B|A) / ℙ B := by rw [h]
        _ = 0 := by simp [hB]
        _ = 0 := by simp
    rw [h₂, h₃]
  · -- Case: ℙ A ≠ 0
    have h₁ : ℙ (A ∩ B) = ℙ A * (ℙ (B | A)) := by
      have h₂ : ℙ (B | A) = ℙ (A ∩ B) / ℙ A := by
        rw [condProb]
        <;> field_simp [h, MeasurableSet.inter (measurableSet_self) (measurableSet_self)]
        <;>
          simp_all [div_eq_mul_inv]
        <;>
          ring_nf
        <;>
          norm_num
        <;>
          simp_all [div_eq_mul_inv]
        <;>
          field_simp [h]
        <;>
          ring_nf
        <;>
          norm_num
        <;>
          linarith
      calc
        ℙ (A ∩ B) = ℙ (A ∩ B) := rfl
        _ = ℙ A * (ℙ (A ∩ B) / ℙ A) := by
          field_simp [h]
          <;>
            ring_nf
          <;>
            simp_all [div_eq_mul_inv]
          <;>
            norm_num
          <;>
            linarith
        _ = ℙ A * ℙ (B | A) := by
          rw [h₂]
          <;>
            ring_nf
          <;>
            simp_all [div_eq_mul_inv]
          <;>
            norm_num
          <;>
            linarith
    calc
      ℙ(A | B) = ℙ (A ∩ B) / ℙ B := by rw [condProb]
      _ = (ℙ A * (ℙ (B | A))) / ℙ B := by rw [h₁]
      _ = ℙ A * ℙ (B | A) / ℙ B := by
        ring_nf
        <;> simp_all [div_eq_mul_inv]
        <;> norm_num
        <;> linarith
