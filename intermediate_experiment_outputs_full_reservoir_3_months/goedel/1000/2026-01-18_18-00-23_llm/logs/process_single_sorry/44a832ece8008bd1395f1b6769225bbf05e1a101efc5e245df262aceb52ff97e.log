        intro i
        exact le_trans ha (direct.1 (le_iInf (fun j => I j) i))
      ext i
      have h₁ : a ∈ I i := h i
      have h₂ : Quotient.mk (I i) a = 0 := by
        rw [Quotient.eq_zero_iff_mem]
        exact h₁
      simpa using h₂)
