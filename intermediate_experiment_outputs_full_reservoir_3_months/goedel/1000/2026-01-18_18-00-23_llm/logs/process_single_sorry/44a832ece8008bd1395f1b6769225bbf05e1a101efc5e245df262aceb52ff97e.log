def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    -- If x is in I and y is in I, then x + y is in I.
    -- Similarly, if x is in J and y is in J, then x + y is in J.
    -- Therefore, x + y is in the intersection of I and J.
    have hx' : x ∈ I := by exact hx.1
    have hy' : y ∈ I := by exact hy.1
    have hx'' : x ∈ J := by exact hx.2
    have hy'' : y ∈ J := by exact hy.2
    exact ⟨I.add_mem hx' hy', J.add_mem hx'' hy''⟩
  zero_mem' := by
    -- The zero element is in both I and J, so it is in their intersection.
    exact ⟨I.zero_mem, J.zero_mem⟩
  smul_mem' := by
    intro r x hx
    -- If x is in I and J, then r * x is in I and J because I and J are ideals.
    have hx' : x ∈ I := by exact hx.1
    have hx'' : x ∈ J := by exact hx.2
    exact ⟨I.smul_mem r hx', J.smul_mem r hx''⟩

