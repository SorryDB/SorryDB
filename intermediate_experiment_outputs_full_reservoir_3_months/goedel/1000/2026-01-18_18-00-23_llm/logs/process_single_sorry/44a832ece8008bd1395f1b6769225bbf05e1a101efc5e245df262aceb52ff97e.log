def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    have hx' : x ∈ I := hx.1
    have hy' : y ∈ I := hy.1
    have hx'' : x ∈ J := hx.2
    have hy'' : y ∈ J := hy.2
    have hsumI : x + y ∈ I := I.add_mem hx' hy'
    have hsumJ : x + y ∈ J := J.add_mem hx'' hy''
    exact ⟨hsumI, hsumJ⟩
