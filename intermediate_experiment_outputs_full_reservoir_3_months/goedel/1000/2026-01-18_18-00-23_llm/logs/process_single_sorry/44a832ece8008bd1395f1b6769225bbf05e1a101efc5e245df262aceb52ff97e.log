def chineseMap  : (R ⧸ ⨅ i, I i) →+* Π i, R ⧸ I i :=
  Quotient.lift (⨅ i, I i) (Pi.ringHom fun i : ι ↦ Quotient.mk (I i))
    (by
      intro a ha
      ext i
      -- Since `a` is in the intersection of all ideals `I i`, it is in each `I i`.
      have h : a ∈ I i := by
        apply Ideal.mem_of_le (Ideal.inter_le_left _ _)
        exact ha
      -- Therefore, `Quotient.mk (I i) a` is zero in each quotient `R ⧸ I i`.
      simp [Quotient.mk_eq_zero, h]
    )
