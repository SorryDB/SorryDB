    intro r x hx
    have hx' : x ∈ I := hx.1
    have hx'' : x ∈ J := hx.2
    have hsmulI : r • x ∈ I := I.smul_mem r hx'
    have hsmulJ : r • x ∈ J := J.smul_mem r hx''
    exact ⟨hsmulI, hsmulJ⟩

