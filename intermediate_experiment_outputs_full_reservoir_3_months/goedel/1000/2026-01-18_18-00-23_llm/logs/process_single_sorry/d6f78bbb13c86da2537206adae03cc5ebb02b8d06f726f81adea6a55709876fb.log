theorem Matroid.IsGood.isRegular {M : Matroid α} (hM : M.IsGood) : M.IsRegular := by
  induction hM with
  | graphic hM => exact hM.isRegular
  | cographic hM =>
    have h₀ : M.IsRegular := hM.isRegular
    exact h₀
  | isomorphicR10 {e} hM =>
    have h₀ : M.IsRegular := by
      have h₁ : M.mapEquiv e = matroidR10.toMatroid := hM
      have h₂ : (M.mapEquiv e).IsRegular := by
        -- The R10 matroid is regular, and the image of a regular matroid under an equivalence is regular.
        apply matroidR10.toMatroid.isRegular
      -- The image of M under the equivalence e is regular, so M itself is regular.
      have h₃ : M.IsRegular := by
        have h₄ : (M.mapEquiv e).IsRegular := h₂
        have h₅ : M.IsRegular := by
          -- Use the fact that the equivalence preserves the regularity of the matroid.
          have h₆ : (M.mapEquiv e).IsRegular := h₄
          have h₇ : M.IsRegular := by
            -- Since the equivalence is an isomorphism, the regularity is preserved.
            simpa [h₁] using h₆
          exact h₇
        exact h₅
      exact h₃
    exact h₀
  | is1sum _ hM _ hMₗ hMᵣ =>
    -- For 1-sum, the regularity is preserved because the rank is finite.
    have h₀ : M.IsRegular := hM.isRegular
    exact h₀
  | is2sum _ hM _ hMₗ hMᵣ =>
    -- For 2-sum, the regularity is preserved because the rank is finite.
    have h₀ : M.IsRegular := hM.isRegular
    exact h₀
  | is3sum _ hM _ hMₗ hMᵣ =>
    -- For 3-sum, the regularity is preserved because the rank is finite.
    have h₀ : M.IsRegular := hM.isRegular
    exact h₀
