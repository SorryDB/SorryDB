theorem Matroid.IsGood.isRegular {M : Matroid α} (hM : M.IsGood) : M.IsRegular := by
  induction hM with
  | graphic hM => exact hM.isRegular
  | cographic hM => exact hM.toDual.isRegular.dual
  | isomorphicR10 _ _ hM => by
      have h₁ : matroidR10.toMatroid.IsRegular := by
        -- Prove that R10 is regular (this is a known fact)
        exact inferInstance
      -- Since M is isomorphic to R10, it is also regular
      have h₂ : M.IsRegular := by
        -- Use the fact that the matroid is isomorphic to R10 and R10 is regular
        have h₃ : M.mapEquiv _ = matroidR10.toMatroid := hM
        have h₄ : M.IsRegular := by
          -- Use the property of isomorphism to transfer the regularity
          have h₅ : M.IsRegular := by
            -- Use the fact that the mapEquiv preserves the matroid structure
            have h₆ : M.mapEquiv _ = matroidR10.toMatroid := hM
            -- Since R10 is regular, M is also regular
            simpa [h₆] using h₁
          exact h₅
        exact h₄
      exact h₂
  | is1sum hMMM hM hMₗ hMᵣ => by
    have h₁ : M.IsRegular := by
      -- Use the fact that the 1-sum of regular matroids is regular
      have h₂ : M.IsRegular := by
        -- Use the property of 1-sum to transfer the regularity
        exact M.IsSum1of.isRegular hMMM hMₗ.isRegular hMᵣ.isRegular hM
      exact h₂
    exact h₁
  | is2sum hMMM hM hMₗ hMᵣ => by
    have h₁ : M.IsRegular := by
      -- Use the fact that the 2-sum of regular matroids is regular
      have h₂ : M.IsRegular := by
        -- Use the property of 2-sum to transfer the regularity
        exact M.IsSum2of.isRegular hMMM hMₗ.isRegular hMᵣ.isRegular hM
      exact h₂
    exact h₁
  | is3sum hMMM hM hMₗ hMᵣ => by
    have h₁ : M.IsRegular := by
      -- Use the fact that the 3-sum of regular matroids is regular
      have h₂ : M.IsRegular := by
        -- Use the property of 3-sum to transfer the regularity
        exact M.IsSum3of.isRegular hMMM hMₗ.isRegular hMᵣ.isRegular hM
      exact h₂
    exact h₁
