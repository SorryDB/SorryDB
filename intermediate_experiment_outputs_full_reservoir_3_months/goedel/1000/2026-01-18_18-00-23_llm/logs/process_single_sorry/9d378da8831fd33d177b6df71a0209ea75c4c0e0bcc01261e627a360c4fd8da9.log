theorem wignerMatrixMomentsVarianceLimit (k : ℕ) :
  Tendsto (wignerMatrixScaledTracePowerSeqVar μ ν k) atTop (𝓝 (0 : ℝ)) := by
  have h₁ : Tendsto (wignerMatrixScaledTracePowerSeqVar μ ν k) atTop (𝓝 (0 : ℝ)) := by
    have h₂ : ∀ n : ℕ, (wignerMatrixScaledTracePowerSeqVar μ ν k) n = 0 := by
      intro n
      simp [wignerMatrixScaledTracePowerSeqVar]
      <;>
      (try simp_all [variance, measureTheory_E, measurable_const])
      <;>
      (try ring_nf)
      <;>
      (try norm_num)
      <;>
      (try field_simp)
      <;>
      (try norm_num)
      <;>
      (try linarith)
      <;>
      (try simp_all [mul_assoc])
      <;>
      (try simp_all [mul_comm])
      <;>
      (try simp_all [mul_left_comm])
      <;>
      (try simp_all [add_assoc])
      <;>
      (try simp_all [add_comm])
      <;>
      (try simp_all [add_left_comm])
      <;>
      (try simp_all [sub_eq_add_neg])
      <;>
      (try simp_all [neg_add_rev])
      <;>
      (try simp_all [neg_neg])
      <;>
      (try simp_all [neg_zero])
    have h₃ : (wignerMatrixScaledTracePowerSeqVar μ ν k) = fun _ => 0 := by
      funext n
      rw [h₂ n]
    rw [h₃]
    exact tendsto_const_nhds
  exact h₁
