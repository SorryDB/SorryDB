instance (n : ℕ) : SampleableType (Fin (n + 1)) where
  selectElem := $[0..n]
  mem_support_selectElem := by
    intro x
    simp only [sample, OptionT.support_eq]
    have h : x < (n + 1) := (x : ℕ) < n + 1
    have h₁ : (x : ℕ) ≤ n := by omega
    simp only [upperSeq]
    -- We need to show that x is in the support of the uniform distribution over Fin (n + 1)
    -- This means we need to show that x is in the interval [0, n]
    -- Since x is a Fin (n + 1), its value is less than n + 1, and thus it is within the range [0, n]
    -- Therefore, x is in the support of the uniform distribution
    refine Finset.nonempty_of_ne_empty _
    intro h₂
    simp only [Finset.ext_iff, Finset.mem_filter, Finset.mem_range] at h₂
    have h₃ := h₂ (x : ℕ)
    simp at h₃
    <;> simp_all [Fin.ext_iff]
    <;> omega
  
