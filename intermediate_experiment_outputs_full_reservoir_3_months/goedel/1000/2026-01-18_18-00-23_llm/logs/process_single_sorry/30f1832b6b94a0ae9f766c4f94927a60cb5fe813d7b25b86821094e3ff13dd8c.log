```lean
theorem sampleable_fin (n : ℕ) :
  SampleableType (Fin (n + 1)) where
  selectElem : ProbComp (Fin (n + 1)) := $[0..n]
  mem_support_selectElem (x : Fin (n + 1)) : x ∈ support selectElem := by
    have h₁ : x.val < n + 1 := Fin.is_lt x
    have h₂ : x.val ∈ Finset.Iio (n + 1) := Finset.mem_Iio.mpr h₁
    simp [selectElem, List.bind, List.map, List.range]
    <;> aesop

  probOutput_selectElem_eq := by
    intro x y
    simp [probOutput_eq_subtype]
    <;>
    (try cases x <;> cases y <;> simp_all [Fin.ext_iff, Fin.val_mk])
    <;>
    (try
      {
        simp [selectElem, List.bind, List.map, List.range]
        <;>
        simp_all [Option.get?, Finset.card_range, Nat.cast_add, Nat.cast_one, Nat.cast_zero]
        <;>
        norm_num
        <;>
        aesop
      })
    <;>
    (try
      {
        simp_all [Fin.ext_iff, Fin.val_mk]
        <;>
        norm_num
        <;>
        aesop
      })
    <;>
    (try
      {
        cases x <;> cases y <;> simp_all [Fin.ext_iff, Fin.val_mk]
        <;>
        norm_num
        <;>
        aesop
      })

  probFailure_selectElem : [⊥ | $[0..n]] = 0 := by
    simp [OptionT.isFailure_iff]
    <;>
    (try cases n <;> simp_all [List.bind, List.map, List.range])
    <;>
    (try
      {
        simp_all [Option.get?, Finset.card_range, Nat.cast_add, Nat.cast_one, Nat.cast_zero]
        <;>
        norm_num
        <;>
        aesop
      })
    <;>
    (try
      {
        cases n <;> simp_all [List.bind, List.map, List.range]
        <;>
        simp_all [Option.get?, Finset.card_range, Nat.cast_add, Nat.cast_one, Nat.cast_zero]
        <;>
        norm_num
        <;>
        aesop
      })
    <;>
    (try
      {
        cases n <;> simp_all [List.bind, List.map, List.range]
        <;>
        simp_all [Option.get?, Finset.card_range, Nat.cast_add, Nat.cast_one, Nat.cast_zero]
        <;>
        norm_num
        <;>
        aesop
      })
