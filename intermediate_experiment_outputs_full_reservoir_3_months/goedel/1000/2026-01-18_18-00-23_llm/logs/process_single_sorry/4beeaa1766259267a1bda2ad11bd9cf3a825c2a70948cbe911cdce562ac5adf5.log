    map_mul' := by
      have h₁ : ∀ (x y : R ⧸ ker f), kerLift f (x * y) = kerLift f x * kerLift f y := by
        intro x y
        -- Use the property of the quotient ring to simplify the expression
        have h₂ : ∀ (x' y' : R), kerLift f (Ideal.Quotient.mk (ker f) x' * Ideal.Quotient.mk (ker f) y') = kerLift f (Ideal.Quotient.mk (ker f) x') * kerLift f (Ideal.Quotient.mk (ker f) y') := by
