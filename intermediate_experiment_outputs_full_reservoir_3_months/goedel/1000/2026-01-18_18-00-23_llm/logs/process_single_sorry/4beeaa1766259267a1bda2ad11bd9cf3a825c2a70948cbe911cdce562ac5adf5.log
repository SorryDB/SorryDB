  Ideal.Quotient.lift (ker f) f fun x hx ↦ by
    simp_all [mem_ker]
    <;>
    aesop

theorem kerLift_mk (f : R →+* S) (x : R) : kerLift f (Ideal.Quotient.mk (ker f) x) = f x := by
  apply Ideal.Quotient.lift_mk

theorem kerLift_injective' (f : R →+* S) (x : R ⧸ ker f) (hx : kerLift f x = 0) : x = 0 := by
  rcases Ideal.Quotient.mk_surjective x with ⟨x', hx'⟩
  rw [← hx']
  rw [← hx'] at hx
  have h₁ : kerLift f (Ideal.Quotient.mk (ker f) x') = f x' := kerLift_mk f x'
  rw [h₁] at hx
  have h₂ : f x' = 0 := hx
  have h₃ : x' ∈ ker f := by
    rw [Ideal.mem_ker]
    simpa using h₂
  have h₄ : Ideal.Quotient.mk (ker f) x' = 0 := by
    rw [Ideal.Quotient.eq_zero_iff]
    exact h₃
  rw [h₄]

theorem kerLift_injective (f : R →+* S) : Injective (kerLift f) := by
  rw [injective_iff_map_eq_zero]
  exact kerLift_injective' f

