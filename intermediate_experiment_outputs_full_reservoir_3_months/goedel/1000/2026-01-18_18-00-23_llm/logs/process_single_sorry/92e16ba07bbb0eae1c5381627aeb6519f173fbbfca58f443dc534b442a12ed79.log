```lean
instance (G : Type*) [Group G] (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [Field L] [ValuativeRel L] [TopologicalSpace L] [IsNonarchimedeanLocalField L]
    [Algebra K L] [ValuativeExtension K L] [MulSemiringAction G L] [IsGaloisGroup G K L] :
    IsGaloisGroup G 𝒪[K] 𝒪[L] where
  faithful := by
    -- Use the fact that the Galois group is faithful on the base field K
    have h_faithful : Function.Injective (algebraMap K L) := (inferInstance : AlgebraMapInjective K L).injective
    -- Use the fact that the Galois group is faithful on the ring of integers to deduce faithfulness on K
    exact (IsGaloisGroup.faithful_of_injective (fun g h => by
      simp_all [IsGaloisGroup, MulSemiringAction.toRingEquiv, Equiv.ext_iff]
      <;>
      aesop))
  
  commutes := inferInstance
  
  isInvariant := by
    -- Use the fact that the Galois group is invariant on the ring of integers to deduce invariance on K
    have h_inv : ∀ (g : G) (r : 𝒪[K]), g • r = r := by
      intro g r
      have h₁ : g • (r : 𝒪[K]) = (r : 𝒪[K]) := by
        simp_all [IsGaloisGroup, MulSemiringAction.toRingEquiv, Equiv.ext_iff]
        <;>
        aesop
      exact h₁
    -- Use the above result to conclude that the Galois group is invariant on K
    exact ⟨fun g r => by simpa using h_inv g r, fun g r => by simpa using h_inv g r⟩
```
