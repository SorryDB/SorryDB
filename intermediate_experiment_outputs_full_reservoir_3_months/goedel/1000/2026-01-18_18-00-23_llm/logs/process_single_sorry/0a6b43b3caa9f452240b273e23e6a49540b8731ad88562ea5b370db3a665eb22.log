def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    rw [show (fun x => g (f x)) ∘ (fun x => f.symm (g.symm x)) = (fun x => x) by
      funext x
      have h1 : g.symm (g (f (f.symm (g.symm x)))) = f (f.symm (g.symm x)) := by
        apply g.symm_apply_apply
      have h2 : f (f.symm (g.symm x)) = g.symm x := by
        apply f.apply_symm_apply
      calc
        g (f (f.symm (g.symm x))) = g (g.symm x) := by rw [h2]
        _ = x := by apply g.apply_symm_apply
    ]
    <;> simp
  right_inv := by
    intro x
    rw [show (fun x => f.symm (g.symm x)) ∘ (fun x => g (f x)) = (fun x => x) by
      funext x
      have h1 : f.symm (g.symm (g (f x))) = f.symm (f x) := by
        apply f.symm.congr_arg
        <;> apply g.symm_apply_apply
      have h2 : f.symm (f x) = x := by
        apply RingEquiv.symm_apply_apply
      calc
        f.symm (g.symm (g (f x))) = f.symm (f x) := by rw [h1]
        _ = x := by rw [h2]
    ]
    <;> simp
``` 

