def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Function.LeftInverse]
    <;> simp_all [RingEquiv.symm_apply_apply]
    <;> aesop
  
  right_inv := by
