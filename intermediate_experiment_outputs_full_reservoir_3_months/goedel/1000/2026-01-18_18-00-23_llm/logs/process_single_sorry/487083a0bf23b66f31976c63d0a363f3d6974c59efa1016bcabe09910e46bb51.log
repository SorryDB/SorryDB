```lean
structure Expression (p : ℕ) where
  | const : (ZMod p) → Expression p
  | var : String → Expression p
  | add : (Expression p) → (Expression p) → Expression p
  | mul : (Expression p) → (Expression p) → Expression p

namespace Expression
  def eval {p : ℕ} (e : Expression p) (env : String → ZMod p) : ZMod p :=
    match e with
      | .const n => n
      | .var x => env x
      | .add e1 e2 => e1.eval env + e2.eval env
      | .mul e1 e2 => e1.eval env * e2.eval env
end

