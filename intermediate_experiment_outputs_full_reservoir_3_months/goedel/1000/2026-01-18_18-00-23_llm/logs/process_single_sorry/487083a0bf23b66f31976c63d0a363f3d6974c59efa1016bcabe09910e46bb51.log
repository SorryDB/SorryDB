theorem ofExpression_correct (p : ℕ) (e : Expression p) (ae : AffineExpression p) :
  some ae = AffineExpression.ofExpression? e
  → ae.eval = e.eval := by
  intro h
  have h₁ : AffineExpression.eval p ae = e.eval := by
    have h₂ : some ae = AffineExpression.ofExpression? e := h
    have h₃ : semanticallyMatch (p := p) ae e := by
      rw [semanticallyMatch]
      -- Prove that the affine expression and the expression are semantically equivalent
      -- by checking that their evaluations are the same in any environment
      have h₄ : ∀ (env : String → ZMod p), AffineExpression.eval p ae env = e.eval env := by
        intro env
        -- Use the fact that the affine expression was constructed from the original expression
        -- to ensure that they evaluate to the same value in any environment
        have h₅ : some ae = AffineExpression.ofExpression? e := h₂
        have h₆ : AffineExpression.eval p ae env = e.eval env := by
          -- Use the property of the construction to ensure the evaluations match
          rcases e with (_ | _ | _ | _ | _ | _ | _) <;>
          (try simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]) <;>
          (try contradiction) <;>
          (try {
            simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]
            <;>
            aesop
          }) <;>
          (try {
            cases p <;> simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]
            <;> aesop
          })
          <;>
          (try {
            cases p <;> simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]
            <;> norm_num at * <;> aesop
          })
          <;>
          (try {
            cases p <;> simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]
            <;>
            aesop
          })
          <;>
          (try {
            aesop
          })
          <;>
          (try {
            simp_all [AffineExpression.ofExpression?, Expression.eval, AffineExpression.eval, ZMod.nat_cast_self]
            <;>
            norm_num at * <;>
            aesop
          })
        exact h₆
      exact h₄
    -- Use the semantic equivalence to conclude that the evaluations are the same
    have h₄ : AffineExpression.eval p ae = e.eval := by
      -- Use the fact that the affine expression and the expression are semantically equivalent
      -- to deduce that their evaluations are the same in the empty environment
      have h₅ : semanticallyMatch (p := p) ae e := h₃
      have h₆ : AffineExpression.eval p ae = e.eval := by
        -- Use the empty environment to compare the evaluations
        have h₇ : AffineExpression.eval p ae (fun _ => 0) = e.eval (fun _ => 0) := by
          apply h₅
        -- Since the expressions are semantically equivalent, their evaluations in the empty environment are the same
        -- This implies that their offsets are the same, because the empty environment sets all variables to 0
        -- and the affine part contributes nothing to the evaluation
        simp [AffineExpression.eval, Expression.eval] at h₇ ⊢
        <;>
        (try simp_all [AffineExpression.eval, Expression.eval]) <;>
        (try aesop) <;>
        (try {
          cases p <;> simp_all [AffineExpression.eval, Expression.eval, ZMod.nat_cast_self] <;>
          norm_num at * <;>
          aesop
