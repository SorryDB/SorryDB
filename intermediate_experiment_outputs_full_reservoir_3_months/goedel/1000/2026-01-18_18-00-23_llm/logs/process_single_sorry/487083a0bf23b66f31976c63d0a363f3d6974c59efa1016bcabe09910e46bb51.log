  some ae = AffineExpression.ofExpression? e
  → ae.eval = e.eval := by
  intro h
  have h_main : ae.eval = e.eval := by
    have h₁ : ae = (AffineExpression.ofExpression? e).getD (by
      have h₂ : some ae = AffineExpression.ofExpression? e := h
      have h₃ : AffineExpression.ofExpression? e ≠ none := by
        intro h₄
        rw [h₄] at h₂
        simp at h₂
      cases' AffineExpression.ofExpression? e with v hv
      simp_all [Option.getD]
      <;> aesop) := by
      have h₂ : some ae = AffineExpression.ofExpression? e := h
      cases' AffineExpression.ofExpression? e with v hv
      simp_all [Option.getD]
      <;> aesop
    rw [h₁]
    -- Now we need to prove that for any expression e, (ofExpression? e).getD _ .eval = e.eval
    -- We will do this by induction on e
    have h₂ : ∀ (e : Expression p), (AffineExpression.ofExpression? e).getD (by
      -- This proof is just to provide a dummy value for the getD, which will not actually be used
      have h₃ : some ( { offset := 0, affine := ∅ } : AffineExpression p) = some ( { offset := 0, affine := ∅ } : AffineExpression p) := rfl
      simp_all [Option.getD]
      <;> aesop) .eval = e.eval := by
