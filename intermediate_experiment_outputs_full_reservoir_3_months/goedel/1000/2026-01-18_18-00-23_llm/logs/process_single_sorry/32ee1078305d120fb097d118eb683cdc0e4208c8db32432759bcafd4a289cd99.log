    have h₄ : y = x := by
      simp_all [Subtype.ext_iff]
    have h₅ : x ∈ X2 := by
      rw [h₄] at hy
      exact hy
    exact h₅
  exact h₁

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  refine' fun X1 X2 h => _
