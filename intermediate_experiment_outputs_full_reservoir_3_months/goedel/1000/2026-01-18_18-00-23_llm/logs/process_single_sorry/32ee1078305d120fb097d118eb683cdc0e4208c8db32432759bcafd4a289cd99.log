lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: if U ∼ V, then there exist functions f and g satisfying the conditions.
    intro h
    rcases h with ⟨e⟩
    refine' ⟨e, e.symm, _⟩
    constructor <;>
    (try simp_all [Equiv.symm_apply_apply, Equiv.apply_symm_apply, Function.comp_apply]) <;>
    (try ext <;> simp_all [Equiv.symm_apply_apply, Equiv.apply_symm_apply, Function.comp_apply]) <;>
    (try aesop)
  · -- Prove the backward direction: if there exist functions f and g satisfying the conditions, then U ∼ V.
    rintro ⟨f, g, h₁, h₂⟩
    refine' ⟨Equiv.ofBijective f ⟨_, _⟩⟩
    · -- Prove that f is injective.
      have h₃ : Function.Injective f := by
        intro a b h
        have h₄ := congr_arg g h
        simp [h₂] at h₄
        exact h₄
      exact h₃
    · -- Prove that f is surjective.
      have h₃ : Function.Surjective f := by
        intro b
        have h₄ : g b = g b := rfl
        have h₅ : f (g b) = b := by
          have h₆ := congr_arg (fun x => x b) h₁
          simp at h₆
          exact h₆
        exact ⟨g b, h₅⟩
      exact h₃

lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext s
  have h₁ : (image g) (image f s) = s := by
    apply Set.Subset.antisymm
    · -- Prove the forward inclusion: (image g) (image f s) ⊆ s
      intro x hx
