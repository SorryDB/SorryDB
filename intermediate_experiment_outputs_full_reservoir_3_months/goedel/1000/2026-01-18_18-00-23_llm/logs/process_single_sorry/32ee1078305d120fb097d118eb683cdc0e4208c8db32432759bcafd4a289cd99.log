lemma ctble_set_of_ctble_type {U : Type}
    (h : ctble U) (A : Set U) : ctble A := by
  -- We use the fact that any subset of a countable set is countable.
  have h₁ : ctble (↑A : Set U) := by
    apply Set.countable.mono (Set.subset_univ A)
    -- Since U is countable, the universal set in U is countable.
    exact by simpa using h
  -- The result follows directly from the countability of the subset.
  exact h₁
```
