      obtain ⟨y, hy₁, hy₂⟩ := hx
      obtain ⟨z, hz₁, hz₂⟩ := hy₁
      have h₂ := congr_fun h z
      simp [Function.comp_apply] at h₂
      have h₃ : g (f z) = z := by simp_all
      simp_all
      <;> aesop
    · -- Prove the reverse inclusion: s ⊆ (image g) (image f s)
      intro x hx
      simp only [Set.mem_image, Set.mem_image] at hx ⊢
      have h₂ : f x ∈ Set.univ := by simp
      have h₃ : g (f x) = x := by
        have h₄ := congr_fun h x
        simp [Function.comp_apply] at h₄
        simp_all
      refine' ⟨f x, by simp, _⟩
      simp_all
      <;> aesop
  simp [h₁]

