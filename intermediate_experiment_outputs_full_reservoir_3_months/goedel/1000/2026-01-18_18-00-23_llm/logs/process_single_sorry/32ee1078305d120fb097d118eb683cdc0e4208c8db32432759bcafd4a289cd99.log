      rw [Equiv.symm_apply_apply]
    have h2 : hf.symm ∘ f = id := by
      funext x
      rw [Function.comp_apply]
      rw [Equiv.apply_symm_apply]
    exact ⟨h1, h2⟩
  · -- Prove the reverse direction: if there exist f and g as described, then U ∼ V.
    rintro ⟨f, g, h1, h2⟩
    refine' ⟨f, _⟩
    have h3 : Function.Bijective f := by
