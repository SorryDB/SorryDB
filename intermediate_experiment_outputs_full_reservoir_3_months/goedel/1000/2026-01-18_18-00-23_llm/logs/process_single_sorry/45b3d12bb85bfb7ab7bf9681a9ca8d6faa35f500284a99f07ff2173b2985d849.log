```lean
lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : x.val ∈ val_image A X1 := by
    -- Prove that x.val is in val_image A X1
    have h₂ : x ∈ X1 := hx
    refine' ⟨x, h₂, _⟩
    <;> simp
  have h₂ : x.val ∈ val_image A X2 := by
    -- Use the fact that val_image A X1 = val_image A X2
    rw [h] at h₁
    exact h₁
  -- Obtain the element y in X2 such that y.val = x.val
  obtain ⟨y, hy, hy'⟩ := h₂
  -- Since y.val = x.val and x, y are in A, we can use the property of coercion to show x = y
  have h₃ : (y : U) = x.val := by
    rw [hy'] <;> simp [Set.mem_setOf_eq]
  -- Since x and y are in A and (y : U) = x.val, we have x = y in A
  have h₄ : x = y := by
    cases x <;> cases y <;> simp_all [Subtype.ext_iff]
    <;> aesop
  -- Therefore, x is in X2
  exact hy.trans h₄
