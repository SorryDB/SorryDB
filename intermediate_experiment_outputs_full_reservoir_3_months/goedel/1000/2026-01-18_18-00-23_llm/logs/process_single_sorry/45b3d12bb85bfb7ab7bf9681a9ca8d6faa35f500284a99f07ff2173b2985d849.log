lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  simp only [Set.mem_setOf_eq, val_image] at h ⊢
  have h₁ := h
  simp only [Set.mem_setOf_eq, Set.mem_setOf_eq] at h₁
  -- We need to show that x is in X2 given that x is in X1.
  -- Since x is in X1, we have x.val ∈ val_image A X1.
  -- But val_image A X1 = val_image A X2, so x.val ∈ val_image A X2.
  -- Therefore, there exists some y in X2 such that y.val = x.val.
  -- But since x and y are in A, and their values are equal, x = y (because the coercion from A to U is injective).
  -- Hence, x is in X2.
  have h₂ : x.val ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp
  have h₃ : x.val ∈ val_image A X2 := by
    rw [h] at h₂
    exact h₂
  obtain ⟨y, hy, hy'⟩ := h₃
  have h₄ : (y : U) = x.val := by simp_all
  have h₅ : y = x := by
    have h₅₁ : (y : U) = (x : U) := by simp_all [Set.mem_setOf_eq]
    exact Subtype.ext h₅₁
  rw [h₅] at hy
  exact hy
