### Formal Proof

```lean
lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 :=
  by
  intro x hx
  have h₁ : (x : A).val ∈ val_image A X1 := by
    -- Show that the value of x is in the val_image of X1
    exact ⟨x, hx, rfl⟩
  have h₂ : (x : A).val ∈ val_image A X2 := by
    -- Since the val_images are equal, the value of x is also in the val_image of X2
    rw [h] at h₁
    exact h₁
  -- Now we have that the value of x is in the val_image of X2, so there exists an element in X2 with the same value
  rcases h₂ with ⟨y, hy, hy'⟩
  -- Since y and x are in A and have the same value, they are equal as elements of A
  have h₃ : (y : A) = x := by
    apply Subtype.ext
    <;> simp_all [Subtype.val_eq_val]
  -- Since y is in X2 and y = x, x is in X2
  rw [h₃] at hy
  exact hy
