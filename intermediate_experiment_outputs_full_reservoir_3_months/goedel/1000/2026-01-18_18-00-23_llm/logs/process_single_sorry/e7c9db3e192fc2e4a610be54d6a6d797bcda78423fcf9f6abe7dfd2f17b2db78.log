    -- Construct a bijection between A \ {a} and B \ {b}
    have h6 : B = image f A := by rw [h2]
    have h7 : ∀ (x : U), x ∈ A → f x ∈ B := by
      intro x hx
      rw [h6]
      exact image_mem _ hx
    -- Define a function from A \ {a} to B \ {b}
    have h8 : ∀ (x : U), x ∈ A \ {a} → f x ∈ B \ {b} := by
      intro x hx
      have h9 : x ∈ A := by exact hx.1
      have h10 : x ≠ a := by
        intro h11
        simp_all [Set.mem_singleton_iff]
