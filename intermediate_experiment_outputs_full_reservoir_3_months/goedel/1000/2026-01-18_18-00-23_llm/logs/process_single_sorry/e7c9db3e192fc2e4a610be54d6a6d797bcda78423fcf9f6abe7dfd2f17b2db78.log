      "by\n  have h5 : ↑(A \\ {a}) ∼ ↑(B \\ {b}) := by\n    -- Define the restriction of `f` to `A \\ {a}`\n    have h6 : ∀ (x : U), x ∈ A → x ≠ a → f x ∈ B := by\n      intro x hx hx'\n      have h7 : f x ∈ image f A := by\n        exact mem_image_of_mem f hx\n      rw [h2] at h7\n      exact h7\n    -- Use the restriction to show that `A \\ {a}` and `B \\ {b}` are equinumerous\n    have h7 : {x : U | x ∈ A ∧ x ≠ a} ∼ {y : V | y ∈ B ∧ y ≠ b} := by\n      let g : U → V := fun x => f x\n      have h8 : one_to_oneOn g ({x : U | x ∈ A ∧ x ≠ a} : Set U) := by\n        intro x hx y hy hxy\n        have h9 : x ∈ A := hx.1\n        have h10 : x ≠ a := hx.2\n        have h11 : y ∈ A := hy.1\n        have h12 : y ≠ a := hy.2\n        have h13 : g x = g y := hxy\n        have h14 : f x = f y := by simpa [g] using h13\n        have h15 : x = y := by\n          apply h1\n          <;> simp_all [h9, h11]\n          <;> aesop\n        exact h15\n      have h9 : image g ({x : U | x ∈ A ∧ x ≠ a} : Set U) = {y : V | y ∈ B ∧ y ≠ b} := by\n        apply Set.ext\n        intro y\n        simp only [Set.mem_image, Set.mem_setOf_eq, image]\n        constructor\n        · -- Prove the forward direction: if y is in the image of g, then y is in {y : V | y ∈ B ∧ y ≠ b}\n          rintro ⟨x, hx, rfl⟩\n          have h10 : x ∈ A := hx.1\n          have h11 : x ≠ a := hx.2\n          have h12 : f x ∈ B := by\n            have h13 : f x ∈ image f A := by\n              exact mem_image_of_mem f h10\n            rw [h2] at h13\n            exact h13\n          have h13 : f x ≠ b := by\n            intro h14\n            have h15 : f x = b := h14\n            have h16 : f a = b := h4\n            have h17 : f x = f a := by rw [h15, h16]\n            have h18 : x = a := by\n              apply h1\n              <;> simp_all [h10, h3]\n              <;> aesop\n            contradiction\n          exact ⟨h12, h13⟩\n        · -- Prove the reverse direction: if y is in {y : V | y ∈ B ∧ y ≠ b}, then y is