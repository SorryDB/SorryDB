          <;> simp_all [Set.mem_singleton_iff]
          <;> aesop
        simp_all [Set.mem_singleton_iff]
      exact ⟨h11, h12⟩
    -- Show that the function is injective
    have h9 : one_to_one (fun x : ↑(A \ {a}) => f x.val) := by
      intro x y h10
      have h11 : x.val ∈ A \ {a} := by exact x.prop
      have h12 : y.val ∈ A \ {a} := by exact y.prop
      have h13 : f x.val = f y.val := by simpa using h10
      have h14 : x.val ∈ A := by exact h11.1
      have h15 : y.val ∈ A := by exact h12.1
      have h16 : x.val ≠ a := by
        intro h17
        simp_all [Set.mem_singleton_iff]
      have h17 : y.val ≠ a := by
