theorem remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  have h5 : B = Set.image f A := by
    rw [h2]
  have h6 : Set.image f (A \ {a}) = B \ {b} := by
    apply Set.ext
    intro x
    simp only [Set.mem_image, Set.mem_diff, Set.mem_singleton_iff, h5]
    constructor
    · -- Prove the forward direction: if x is in the image of A \ {a}, then x is in B \ {b}
      rintro ⟨y, hy, rfl⟩
      have hy' : y ∈ A := hy.1
      have hy'' : y ≠ a := hy.2
      have h7 : f y ∈ Set.image f A := by
        exact Set.mem_image_of_mem f hy'
      have h8 : f y ≠ b := by
        intro h9
        have h10 : f y = b := h9
        have h11 : f y = f a := by
          rw [h4] at *
          <;> simp_all
        have h12 : y = a := by
          apply h1
          <;> simp_all
          <;> aesop
        contradiction
      simp_all
      <;> aesop
    · -- Prove the reverse direction: if x is in B \ {b}, then x is in the image of A \ {a}
      rintro h
      have h7 : x ∈ Set.image f A := by
        simp_all
        <;> aesop
      obtain ⟨y, hy, rfl⟩ := h7
      have h8 : y ∈ A := hy
      by_cases h9 : y = a
      · -- Case y = a
        exfalso
        simp_all
        <;> aesop
      · -- Case y ≠ a
        refine' ⟨y, ⟨h8, h9⟩, _⟩
        simp_all
        <;> aesop
  -- Use the fact that the images are equal to show the sets are equinumerous
  have h7 : (A \ {a}) ∼ (B \ {b}) := by
    have h8 : Set.image f (A \ {a}) = B \ {b} := h6
    have h9 : one_one_on f (A \ {a}) := by
      intro x hx y hy hxy
      have h10 : x ∈ A := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
        aesop
      have h11 : y ∈ A := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hy
        aesop
      have h12 : x ≠ a := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
        aesop
      have h13 : y ≠ a := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hy
        aesop
      have h14 : f x = f y := hxy
      have h15 : x = y := by
        apply h1
        <;> simp_all
        <;> aesop
      exact h15
    -- Use the bijection to show equinumerosity
    have h10 : (A \ {a}) ∼ Set.image f (A \ {a}) := by
      apply Set.equivSetImage
      exact h9
    have h11 : Set.image f (A \ {a}) = B \ {b} := h6
    rw [h11] at h10
    exact h10
  -- Convert the set equinumerosity to type equinumerosity
  exact h7
