          })
        }) <;>
        (try {
          aesop
        })
      })
      <;>
      (try {
        aesop
      })
    -- Use the fact that the image of the restricted function is the desired set and the function is injective to establish a bijection
    have h21 : (A \ ({a} : Set U)) ∼ (image f (A \ ({a} : Set U))) := by
      apply SetEquiv.of_injective
      · intro x
        exact ⟨f x, Set.mem_image_of_mem _ (by
          simp_all [Set.mem_diff]
          <;>
          tauto
          )⟩
      · intro x y h
        simp_all [Set.mem_image]
        <;>
        (try aesop)
        <;>
        (try {
          have h22 := h10
          simp_all [one_one_on]
          <;>
          aesop
        })
        <;>
        (try {
          aesop
        })
    have h22 : (image f (A \ ({a} : Set U))) ∼ (B \ ({b} : Set V)) := by
      apply SetEquiv.ofEq
      <;> simp_all
      <;>
      (try {
        aesop
      })
      <;>
      (try {
        simp_all [Set.ext_iff]
        <;>
        tauto
      })
    -- Combine the equivalences to get the final result
    calc
      (A \ ({a} : Set U)) ∼ (image f (A \ ({a} : Set U))) := h21
      _ ∼ (B \ ({b} : Set V)) := h22
  
  exact h9
