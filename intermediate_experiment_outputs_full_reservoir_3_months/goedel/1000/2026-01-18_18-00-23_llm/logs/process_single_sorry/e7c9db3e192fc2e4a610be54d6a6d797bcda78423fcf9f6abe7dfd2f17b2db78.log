      "by\n  have h5 : ↑(A \\ {a}) ∼ ↑(B \\ {b}) := by\n    -- Construct a bijection between A \\ {a} and B \\ {b}\n    have h6 : B = image f A := by rw [h2]\n    have h7 : ∀ (x : U), x ∈ A → f x ∈ B := by\n      intro x hx\n      rw [h6]\n      exact image_mem _ hx\n    -- Define a function from A \\ {a} to B \\ {b}\n    have h8 : ∀ (x : U), x ∈ A \\ {a} → f x ∈ B \\ {b} := by\n      intro x hx\n      have h9 : x ∈ A := by exact hx.1\n      have h10 : x ≠ a := by\n        intro h11\n        simp_all [Set.mem_singleton_iff]\n      have h11 : f x ∈ B := h7 x h9\n      have h12 : f x ≠ b := by\n        intro h13\n        have h14 : f a = f x := by simp_all\n        have h15 : a = x := by\n          apply h1\n          <;> simp_all [Set.mem_singleton_iff]\n          <;> aesop\n        simp_all [Set.mem_singleton_iff]\n      exact ⟨h11, h12⟩\n    -- Show that the function is injective\n    have h9 : one_to_one (fun x : ↑(A \\ {a}) => f x.val) := by\n      intro x y h10\n      have h11 : x.val ∈ A \\ {a} := by exact x.prop\n      have h12 : y.val ∈ A \\ {a} := by exact y.prop\n      have h13 : f x.val = f y.val := by simpa using h10\n      have h14 : x.val ∈ A := by exact h11.1\n      have h15 : y.val ∈ A := by exact h12.1\n      have h16 : x.val ≠ a := by\n        intro h17\n        simp_all [Set.mem_singleton_iff]\n      have h17 : y.val ≠ a := by\n        intro h18\n        simp_all [Set.mem_singleton_iff]\n      have h18 : x.val = y.val := by\n        have h19 : f x.val = f y.val := h13\n        have h20 : x.val ∈ A := h14\n        have h21 : y.val ∈ A := h15\n        have h22 : x.val = y.val := by\n          by_cases h23 : x.val = y.val\n          · exact h23\n          · exfalso\n            have h24 : f x.val ≠ f y.val := by\n              have h25 : x.val ≠ y.val := h23\n              have h26 : x.val ∈ A := h14\n              have h27 : y.val ∈ A := h15\n              have h28 : ¬(f x.val = f y.val) := by\n                intro h29\n                have h30 : x.val = y.val := by\n                  apply h1\n                  <;> simp_all [Set.mem_singleton_iff]\n                  <;> aesop\n                contradiction\n              exact h28\n            contradiction\n        exact h22\n      exact Subtype.ext h18\n    -- Show that the function is surjective\n    have h10 : ∀ (y : ↑(B \\ {b})), ∃ (x : ↑(A \\ {a})), f x.val = y.val := by\n      intro y\n      have h11 : y.val ∈ B \\ {b} := by exact y.prop\n      have h12 : y.val ∈ B := by exact h11.1\n      have h13 : y.val ≠ b := by exact h11.2\n      have h14 : y.val ∈ image f A := by\n        rw [h6] at *\n        exact h12\n      obtain ⟨x, hx, hx'⟩ := h14\n      have h15 : x ∈ A := by exact hx\n      have h16 : f x = y.val := by\n        simp_all\n      have h17 : x ≠ a := by\n        intro h18\n        simp_all [Set.mem_singleton_iff]\n        <;> aesop\n      have h18 : x ∈ A \\ {a} := by\n        exact ⟨h15, h17⟩\n      refine' ⟨⟨x, h18⟩, _⟩\n      simp_all\n    -- Conclude that the function is a bijection\n    have h11 : ↑(A \\ {a}) ∼ ↑(B \\ {b}) := by\n      apply Equiv.ofInjective (fun x : ↑(A \\ {a}) => ⟨f x.val, by\n        have h12 : x.val ∈ A \\ {a} := x.prop\n        have h13 : f x.val ∈ B \\ {b} := h8 x.val h12\n        exact h13⟩)\n      intro x y h12\n      simp_all [Equiv.ext_iff]\n      <;> aesop\n    exact h11\n  exact h5",
      "by\n  have h5 : B \\ {b} = image f (A \\ {a}) := by\n    apply Set.ext\n    intro y\n    have h6 : y ∈ B \\ {b} ↔ y ∈ B ∧ y ≠ b := by simp [Set.mem_diff]\n    have h7 : y ∈ image f (A \\ {a}) ↔ ∃ (x : U), x ∈ A \\ {a} ∧ f x = y := by\n      simp [Set.mem_image]\n    rw [h6, h7]\n    constructor\n    · -- Prove the forward direction: if y ∈ B \\ {b}, then y ∈ image f (A \\ {a})\n      intro h8\n      have h9 : y ∈ B := h8.1\n      have h10 : y ≠ b := h8.2\n      have h11 : y ∈ image f A := by\n        rw [h2] at *\n        exact h9\n      rcases h11 with ⟨x, hx, hy⟩\n      have h12 : x ∈ A := hx\n      by_cases h13 : x = a\n      · -- If x = a, then y = f a = b, which contradicts y ≠ b\n        have h14 : y = b := by\n          rw [h13] at hy\n          rw [h4] at hy\n          exact hy\n        contradiction\n      · -- If x ≠ a, then x ∈ A \\ {a} and f x = y\n        have h15 : x ∈ A \\ {a} := by\n          exact ⟨h12, by\n            intro h16\n            apply h13\n            simp_all [Set.mem_singleton_iff]\n            ⟩\n        exact ⟨x, h15, hy⟩\n    · -- Prove the reverse direction: if y ∈ image f (A \\ {a}), then y ∈ B \\ {b}\n      intro h8\n      rcases h8 with ⟨x, hx, hy⟩\n      have h9 : x ∈ A \\ {a} := hx\n      have h10 : x ∈ A := h9.1\n      have h11 : x ≠ a := by\n        intro h12\n        have h13 : x ∈ ({a} : Set U) := by simp [h12]\n        have h14 : x ∉ ({a} : Set U) := by\n          simp_all [Set.mem_singleton_iff]\n        contradiction\n      have h12 : y = f x := by rw [hy]\n      have h13 : y ∈ image f A := by\n        refine' ⟨x, h10, _⟩\n        <;> simp_all\n      have h14 : y ∈ B := by\n        rw [h2] at *\n        exact h13\n      have h15 : y ≠ b := by\n        by_contra h16\n        have h17 : y = b := by tauto\n        have h18 : f x = b := by\n          linarith\n        have h19 : f x = f a := by\n          rw [h4]\n          <;> linarith\n        have h20 : x = a := by\n          apply h1\n          <;> simp_all [Set