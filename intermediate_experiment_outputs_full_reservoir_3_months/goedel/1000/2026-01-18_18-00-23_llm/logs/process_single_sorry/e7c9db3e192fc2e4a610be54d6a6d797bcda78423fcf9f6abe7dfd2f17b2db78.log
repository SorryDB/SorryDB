          have h14 : f x ∈ image f (A \ {a}) := Set.mem_image_of_mem f h13
          simp_all
          <;> aesop
    -- Use the bijection to show the equinumerosity
    have h9 : (↑(A \ {a}) : Set U) ∼ ↑(B \ {b}) := by
      have h10 : image f (A \ {a}) = B \ {b} := h8
      have h11 : one_one_on f (A \ {a}) := h7
      have h12 : (A \ {a} : Set U) ∼ image f (A \ {a} : Set U) := by
        apply Set.Equinumerous.image_of_injective
        <;> simp_all [one_one_on]
        <;>
        (try aesop)
