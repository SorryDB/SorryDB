      "by\n  have h5 : b ∈ B := by\n    have h5₁ : f a ∈ image f A := by\n      apply image_mem\n      <;> simp_all\n    rw [h2] at h5₁\n    exact h5₁\n  have h6 : a ∈ {a} := by simp\n  have h7 : a ∈ A := h3\n  have h8 : (B \\ {b} : Set V) = (B \\ {b} : Set V) := rfl\n  have h9 : (A \\ {a} : Set U) = (A \\ {a} : Set U) := rfl\n  -- Define the function from A \\ {a} to B \\ {b}\n  have h10 : ∀ (x : U), x ∈ A \\ {a} → f x ∈ B \\ {b} := by\n    intro x hx\n    have h10₁ : x ∈ A := by\n      simp only [Set.mem_diff] at hx ⊢\n      exact hx.1\n    have h10₂ : f x ∈ B := by\n      have h10₃ : f x ∈ image f A := by\n        apply image_mem\n        <;> simp_all\n      rw [h2] at h10₃\n      exact h10₃\n    have h10₃ : x ≠ a := by\n      simp only [Set.mem_diff] at hx ⊢\n      intro h10₄\n      simp_all\n    have h10₄ : f x ≠ b := by\n      intro h10₅\n      have h10₆ : f x = b := h10₅\n      have h10₇ : f x = f a := by rw [h4] at * <;> simp_all\n      have h10₈ : x = a := by\n        apply h1\n        <;> simp_all\n        <;> aesop\n      contradiction\n    simp only [Set.mem_diff] at hx ⊢\n    exact ⟨h10₂, h10₄⟩\n  -- Construct the bijection\n  have h11 : ∃ (g : (A \\ {a}) → (B \\ {b})), Function.Bijective g := by\n    have h11₁ : ∀ (x : U), x ∈ A \\ {a} → f x ∈ B \\ {b} := h10\n    have h11₂ : one_one_on f A := h1\n    -- Define the function g from A \\ {a} to B \\ {b}\n    classical\n    let g : (A \\ {a}) → (B \\ {b}) := fun x => ⟨f x.val, (h11₁ x.val x.prop)⟩\n    -- Prove that g is injective\n    have h11₃ : Function.Injective g := by\n      intro x y hxy\n      have h11₄ : g x = g y := hxy\n      have h11₅ : f x.val = f y.val := by\n        simp only [g] at h11₄\n        simp_all [Subtype.ext_iff]\n      have h11₆ : x.val = y.val := by\n        have h11₇ : x.val ∈ A := by\n          simp only [Set.mem_diff] at x.prop ⊢\n          exact x.prop.1\n        have h11₈ : y.val ∈ A := by\n          simp only [Set.mem_diff] at y.prop ⊢\n          exact y.prop.1\n        have h11₉ : x.val ∈ A ∧ y.val ∈ A := ⟨h11₇, h11₈⟩\n        have h11₁₀ : f x.val = f y.val := h11₅\n        have h11₁₁ : x.val = y.val := by\n          apply h1\n          <;> simp_all\n          <;> aesop\n        exact h11₁₁\n      exact Subtype.ext h11₆\n    -- Prove that g is surjective\n    have h11₄ : Function.Surjective g := by\n      intro z\n      have h11₅ : z.val ∈ B \\ {b} := z.prop\n      have h11₆ : z.val ∈ B := by\n        simp only [Set.mem_diff] at h11₅\n        exact h11₅.1\n      have h11₇ : z.val ≠ b := by\n        simp only [Set.mem_diff] at h11₅\n        exact h11₅.2\n      have h11₈ : z.val ∈ image f A := by\n        rw [h2] at *\n        exact h11₆\n      obtain ⟨x, hx, rfl⟩ := h11₈\n      have h11₉ : x ∈ A := hx\n      by_cases h11₁₀ : x = a\n      · exfalso\n        have h11₁₁ : f x = b := by\n          rw [h11₁₀]\n          simp_all\n        have h11₁₂ : f x = z.val := by\n          simp_all\n        have h11₁₃ : z.val = b := by\n          simp_all\n        contradiction\n      · -- x ≠ a, so x ∈ A \\ {a}\n        have h11₁₁ : x ∈ A \\ {a} := by\n          simp only [Set.mem_diff]\n          exact ⟨h11₉, h11₁₀⟩\n        refine' ⟨⟨x, h11₁₁⟩, _⟩\n        simp only [g]\n        <;> simp_all [Subtype.ext_iff]\n        <;> aesop\n    -- Combine injective and surjective to get bijective\n    exact ⟨g, ⟨h11₃, h11₄⟩⟩\n  -- Use the bijection to conclude the proof\n  obtain ⟨g, hg⟩ := h11\n  refine' ⟨_, _⟩\n  · exact hg.1\n  · exact hg.2",
