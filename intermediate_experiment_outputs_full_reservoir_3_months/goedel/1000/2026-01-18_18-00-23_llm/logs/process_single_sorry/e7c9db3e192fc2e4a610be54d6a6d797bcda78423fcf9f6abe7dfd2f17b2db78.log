        · -- Prove the backward direction: if y ∈ B \ {b}, then y ∈ image f (A \ {a})
          intro hy
          have h12 : y ∈ B := hy.1
          have h13 : y ≠ b := hy.2
          have h14 : y ∈ image f A := by
