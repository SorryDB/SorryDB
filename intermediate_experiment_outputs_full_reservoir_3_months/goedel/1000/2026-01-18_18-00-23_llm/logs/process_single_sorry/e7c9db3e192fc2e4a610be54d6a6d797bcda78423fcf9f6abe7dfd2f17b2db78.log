      "by\n  have h5 : B \\ {b} = B \\ {b} := rfl\n  have h6 : A \\ {a} = A \\ {a} := rfl\n  -- Define the restricted function from A \\ {a} to B \\ {b}\n  have h7 : ∃ (g : (A \\ {a}) → (B \\ {b})), Function.Bijective g := by\n    use fun x : A \\ {a} => ⟨f x.val, by\n      -- Prove that f(x) ∈ B \\ {b}\n      have h8 : f x.val ∈ B := by\n        have h9 : image f A = B := h2\n        have h10 : f x.val ∈ image f A := by\n          apply mem_image_of_mem\n          exact x.prop\n        rw [h9] at h10\n        exact h10\n      have h11 : f x.val ≠ b := by\n        intro h12\n        have h13 : x.val = a := by\n          have h14 : x.val ∈ A := x.prop\n          have h15 : a ∈ A := h3\n          have h16 : f x.val = f a := by rw [h12, h4]\n          have h17 : one_one_on f A := h1\n          have h18 : x.val ∈ A := x.prop\n          have h19 : a ∈ A := h3\n          have h20 : f x.val = f a := h16\n          exact h17 h18 h19 h20\n        have h21 : x.val ≠ a := by\n          simp_all [Set.mem_singleton_iff]\n          <;> aesop\n        contradiction\n      exact ⟨h8, h11⟩⟩\n    -- Prove that the function is bijective\n    constructor\n    · -- Injectivity\n      intro x y h22\n      have h23 : f x.val = f y.val := by\n        simp_all [Subtype.ext_iff]\n      have h24 : x.val ∈ A := x.prop\n      have h25 : y.val ∈ A := y.prop\n      have h26 : one_one_on f A := h1\n      have h27 : x.val = y.val := h26 h24 h25 h23\n      exact Subtype.ext h27\n    · -- Surjectivity\n      intro y\n      have h28 : y.val ∈ B := y.prop.1\n      have h29 : y.val ≠ b := y.prop.2\n      have h30 : image f A = B := h2\n      have h31 : y.val ∈ image f A := by\n        rw [h30] at *\n        exact h28\n      obtain ⟨x, hx1, hx2⟩ := h31\n      have h32 : x ∈ A := hx1\n      have h33 : f x = y.val := hx2\n      have h34 : x ≠ a := by\n        intro h35\n        have h36 : f x = f a := by rw [h35]\n        have h37 : f x = y.val := hx2\n        have h38 : f a = b := h4\n        have h39 : y