    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  have h5 : ∃ (g : (A \ {a}) → (B \ {b})), Function.Bijective g := by
    use fun x =>
      ⟨f x.val, by
        have h6 : f x.val ∈ B := by
          have h7 : f x.val ∈ image f A := by
            apply mem_image_of_mem
            exact x.property
          rw [h2] at h7
          exact h7
        have h8 : f x.val ≠ b := by
          intro h9
          have h10 : f x.val = b := h9
          have h11 : x.val ∈ A := x.property
          have h12 : x.val ≠ a := by
            intro h13
            simp_all [Set.mem_singleton_iff]
          have h13 : f x.val = f a := by
            simp_all [h4]
          have h14 : one_one_on f A := h1
          have h15 : x.val ∈ A := x.property
          have h16 : a ∈ A := h3
          have h17 : x.val ≠ a := h12
          have h18 := h14 h15 h16 h13
          contradiction
        simp_all [Set.mem_singleton_iff]
        ⟩
    constructor
    · -- Prove injectivity
      intro x y hxy
      have h6 : f x.val = f y.val := by
        simp_all [Subtype.ext_iff]
      have h7 : x.val ∈ A := x.property
      have h8 : y.val ∈ A := y.property
      have h9 : x.val ≠ a := by
        intro h10
        simp_all [Set.mem_singleton_iff]
      have h10 : y.val ≠ a := by
        intro h11
        simp_all [Set.mem_singleton_iff]
      have h11 : x.val = y.val := by
        have h12 : one_one_on f A := h1
        have h13 : x.val ∈ A := x.property
        have h14 : y.val ∈ A := y.property
        have h15 := h12 h13 h14 h6
        exact h15
      simp_all [Subtype.ext_iff]
    · -- Prove surjectivity
      intro y
      have h6 : y.val ∈ B := y.property
      have h7 : y.val ∈ image f A := by
        rw [h2] at *
        exact h6
      obtain ⟨x, hx, hx'⟩ := h7
      have h8 : x ∈ A := hx
      have h9 : f x = y.val := hx'
      by_cases h10 : x = a
      · -- Case x = a
        exfalso
        have h11 : f x = b := by simp_all [h4]
        have h12 : y.val = b := by simp_all
        simp_all [Set.mem_singleton_iff]
        <;> aesop
      · -- Case x ≠ a
        have h11 : x ∈ A \ {a} := by
          refine' ⟨h8, _⟩
          intro h12
          apply h10
          simp_all [Set.mem_singleton_iff]
        have h12 : f x ∈ B := by
          have h13 : f x ∈ image f A := by
            apply mem_image_of_mem
            exact h8
          rw [h2] at h13
          exact h13
        have h13 : f x ≠ b := by
          intro h14
          have h15 : f x = b := h14
          have h16 : x ∈ A := h8
          have h17 : x ≠ a := h10
          have h18 : f x = f a := by simp_all [h4]
          have h19 : one_one_on f A := h1
          have h20 : x ∈ A := h8
          have h21 : a ∈ A := h3
          have h22 : x ≠ a := h17
          have h23 := h19 h20 h21 h18
          contradiction
        refine' ⟨⟨x, h11⟩, _⟩
        simp_all [Subtype.ext_iff]
        <;> aesop
  -- Use the existence of a bijection to prove equinumerosity
  obtain ⟨g, hg⟩ := h5
  have h6 : (A \ {a}) ∼ (B \ {b}) := by
    exact Equiv.ofBijective g hg
  exact h6
