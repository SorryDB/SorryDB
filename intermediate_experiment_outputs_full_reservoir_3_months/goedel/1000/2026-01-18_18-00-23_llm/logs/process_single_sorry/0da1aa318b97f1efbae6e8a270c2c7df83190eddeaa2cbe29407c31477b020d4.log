      intro i
      have h₃ := congr_fun h i
      simp [chineseMap_mk'] at h₃ ⊢
      <;>
      (try simp_all [Ideal.Quotient.ext_iff]) <;>
      (try ring_nf at * <;> aesop)
      <;>
      (try exact h₃)
    -- Use the fact that the map is injective if the underlying function is injective
    have h₃ : x = y := by
      ext i
      exact h₂ i
    exact h₃
  exact h₁
