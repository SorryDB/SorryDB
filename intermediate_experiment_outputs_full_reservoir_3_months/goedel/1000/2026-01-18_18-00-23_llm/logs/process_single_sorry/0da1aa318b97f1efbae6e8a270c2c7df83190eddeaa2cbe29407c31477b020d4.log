lemma chineseMap_injective : Injective (chineseMap I) := by
  intro x y h
  have h₁ : (chineseMap I x) = (chineseMap I y) := h
  have h₂ : ∀ (i : ι), (Quotient.mk (I i)) (chineseMap.I_sends_to (by simp) x) = (Quotient.mk (I i)) (chineseMap.I_sends_to (by simp) y) := by
    intro i
    have h₃ := congr_fun h₁ i
    simp [chineseMap_mk] at h₃ ⊢
    <;> simpa [Quotient.mk.injEq] using h₃
  have h₃ : x = y := by
    have h₄ : x = y := by
      apply Quotient.eq
      have h₅ : (⨅ i, I i).mk (x : R) = (⨅ i, I i).mk (y : R) := by
        -- We need to show that the images of x and y in the quotient are equal.
        -- This follows from the fact that for every i, x - y is in I i.
        have h₆ : ∀ i, (x : R) - (y : R) ∈ I i := by
          intro i
          have h₇ := h₂ i
          -- Use the fact that the images of x and y in R / I i are equal.
          simp [Quotient.eq] at h₇ ⊢
          <;> simp_all [I]
          <;> aesop
        -- Since x - y is in every I i, it is in the intersection of all I i.
        have h₈ : (x : R) - (y : R) ∈ ⨅ i, I i := by
          intro i
          exact h₆ i
        -- Therefore, x and y are in the same equivalence class in R / ⨅ i, I i.
        simpa [Quotient.eq] using h₈
      simpa using h₅
    exact h₄
  exact h₃
