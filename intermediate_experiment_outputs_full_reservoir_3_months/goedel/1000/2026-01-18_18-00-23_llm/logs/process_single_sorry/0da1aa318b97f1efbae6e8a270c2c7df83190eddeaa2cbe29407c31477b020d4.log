lemma chineseMap_injective : Injective (chineseMap I) := by
  intro x y h
  have h₁ : chineseMap I x = chineseMap I y := h
  have h₂ : x = y := by
    -- Use the fact that the chineseMap is injective to conclude that x = y
    by_cases h₃ : x = y
    · exact h₃
    · exfalso
      -- If x ≠ y, then there exists an ideal I_i such that their images in R/I_i are different
      have h₄ : ∃ (i : ι), (x : Π i, R ⧸ I i) i ≠ (y : Π i, R ⧸ I i) i := by
        by_contra h₄
        push_neg at h₄
        -- If for all i, the images of x and y in R/I_i are the same, then x = y
        have h₅ : (x : Π i, R ⧸ I i) = (y : Π i, R ⧸ I i) := by
          funext i
          have h₅₁ := h₄ i
          tauto
        have h₆ : (x : Π i, R ⧸ I i) = (y : Π i, R ⧸ I i) := h₅
        have h₇ : x = y := by
          -- Use the fact that the chineseMap is injective to conclude that x = y
          have h₇₁ : (x : Π i, R ⧸ I i) = (y : Π i, R ⧸ I i) := h₆
          have h₇₂ : ChineseMap I x = ChineseMap I y := by
            simp_all [ChineseMap]
          -- Use the injectivity of ChineseMap to conclude that x = y
          simp_all [ChineseMap]
          <;>
          (try contradiction) <;>
          (try tauto)
        contradiction
      -- Obtain the ideal I_i such that the images of x and y in R/I_i are different
      obtain ⟨i, hi⟩ := h₄
      -- Use the fact that the images are different to derive a contradiction
      have h₅ : (x : Π i, R ⧸ I i) i ≠ (y : Π i, R ⧸ I i) i := hi
      simp_all [ChineseMap]
      <;>
      (try contradiction) <;>
      (try tauto)
  exact h₂
