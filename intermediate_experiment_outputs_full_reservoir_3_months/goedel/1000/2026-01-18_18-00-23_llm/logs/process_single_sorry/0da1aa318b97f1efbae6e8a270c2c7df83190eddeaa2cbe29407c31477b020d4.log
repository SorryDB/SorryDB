      "\n  rw [Function.Injective]\n  intro x y h\n  have h₁ : x = y := by\n    -- Use the fact that the map is injective if the kernel is trivial\n    have h₂ : chineseMap I x = chineseMap I y := h\n    -- Since the map is injective, we can deduce x = y\n    have h₃ : x = y := by\n      -- Use the surjectivity of the quotient map to find representatives\n      have h₄ : ∃ (a : R), (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) = x := by\n        -- The quotient map is surjective\n        have h₅ : Function.Surjective (Quotient.mk (⨅ i, I i)) :=\n          Ideal.Quotient.mk_surjective\n        -- Therefore, there exists an a such that the quotient of a is x\n        exact h₅ x\n      have h₅ : ∃ (b : R), (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) = y := by\n        -- Similarly for y\n        have h₆ : Function.Surjective (Quotient.mk (⨅ i, I i)) :=\n          Ideal.Quotient.mk_surjective\n        exact h₆ y\n      -- Obtain the representatives\n      obtain ⟨a, ha⟩ := h₄\n      obtain ⟨b, hb⟩ := h₅\n      -- Use the injectivity of the Chinese map to show that the representatives are equal\n      have h₆ : chineseMap I (Quotient.mk (⨅ i, I i) a) = chineseMap I (Quotient.mk (⨅ i, I i) b) := by\n        rw [ha, hb] at *\n        exact h₂\n      -- Simplify the equation using the definition of the Chinese map\n      have h₇ : (fun i : ι => Quotient.mk (I i) a) = (fun i : ι => Quotient.mk (I i) b) := by\n        have h₈ : chineseMap I (Quotient.mk (⨅ i, I i) a) = chineseMap I (Quotient.mk (⨅ i, I i) b) := h₆\n        have h₉ : chineseMap I (Quotient.mk (⨅ i, I i) a) = (fun i : ι => Quotient.mk (I i) a) := by\n          simp [chineseMap_mk]\n        have h₁₀ : chineseMap I (Quotient.mk (⨅ i, I i) b) = (fun i : ι => Quotient.mk (I i) b) := by\n          simp [chineseMap_mk]\n        rw [h₉] at h₈\n        rw [h₁₀] at h₈\n        exact h₈\n      -- Since the functions are equal, their values at each i are equal\n      have h₈ : ∀ (i : ι), Quotient.mk (I i) a = Quotient.mk (I i) b := by\n        intro i\n        have h₉ := congr_fun h₇ i\n        exact h₉\n      -- This implies that a - b is in each ideal I i\n      have h₉ : ∀ (i : ι), a - b ∈ I i := by\n        intro i\n        have h₁₀ : Quotient.mk (I i) a = Quotient.mk (I i) b := h₈ i\n        have h₁₁ : Quotient.mk (I i) (a - b) = 0 := by\n          calc\n            Quotient.mk (I i) (a - b) = Quotient.mk (I i) a - Quotient.mk (I i) b := by\n              simp [Quotient.mk_sub]\n            _ = 0 := by rw [h₁₀]; simp\n        have h₁₂ : a - b ∈ I i := by\n          simpa [Quotient.eq_zero_iff_mem] using h₁₁\n        exact h₁₂\n      -- Therefore, a - b is in the intersection of all I i\n      have h₁₀ : a - b ∈ ⨅ i, I i := by\n        -- Use the fact that the intersection is the set of elements in every I i\n        exact Ideal.mem_iInf.mpr h₉\n      -- This implies that the quotients of a and b are equal in R ⧸ ⨅ i, I i\n      have h₁₁ : (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) = (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) := by\n        have h₁₂ : a - b ∈ ⨅ i, I i := h₁₀\n        have h₁₃ : (Quotient.mk (⨅ i, I i) (a - b) : R ⧸ ⨅ i, I i) = 0 := by\n          simp [Quotient.eq_zero_iff_mem, h₁₂]\n        have h₁₄ : (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) - (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) = 0 := by\n          calc\n            (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) - (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) =\n                (Quotient.mk (⨅ i, I i) (a - b) : R ⧸ ⨅ i, I i) := by\n              simp [Quotient.mk_sub]\n            _ = 0 := h₁₃\n        have h₁₅ : (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) = (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) := by\n          rw [sub_eq_zero] at h₁₄\n          exact h₁₄\n        exact h₁₅\n      -- Since the quotients are equal, x = y\n      have h₁₂ : x = y := by\n        calc\n          x = (Quotient.mk (⨅ i, I i) a : R ⧸ ⨅ i, I i) := by rw [ha]\n          _ = (Quotient.mk (⨅ i, I i) b : R ⧸ ⨅ i, I i) := h₁₁\n          _ = y := by rw [hb]\n      exact h₁₂\n    exact h₃\n  exact h₁",
