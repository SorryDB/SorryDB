def chineseMap  : (R ⧸ ⨅ i, I i) →+* Π i, R ⧸ I i :=
  Quotient.lift (⨅ i, I i) (Pi.ringHom fun i : ι ↦ Quotient.mk (I i))
    (by
      -- Prove that the intersection of all ideals is contained in the kernel of the product map
      apply le_of_forall_le'
      intro a ha i
      -- For each ideal I i, if a is in the intersection, then a is in I i
      have h : a ∈ I i := by
        -- Since a is in the intersection of all ideals, it is in each I i
        exact le_trans (iInf_le _ _) ha
      -- a is mapped to 0 in each quotient R / I i
      simp_all [Ideal.mem_ker, Pi.ringHom_apply, Quotient.mk_eq_zero]
      <;>
      aesop
    )

