lemma chineseMap_injective : Injective (chineseMap I) := by
  have h : chineseMap I = Ideal.Quotient.lift _ _ (by
    -- Show that the kernel of the product map is contained in the intersection of the ideals
    intro a ha
    simp only [Ideal.mem_inf] at ha ⊢
    have h : ∀ i : ι, a ∈ I i := by
      intro i
      have h₁ : a ∈ (Pi.ringHom fun i : ι => Quotient.mk (I i)).ker := ha
      simp [RingHom.mem_ker] at h₁
      have h₂ : (Pi.ringHom fun i : ι => Quotient.mk (I i)) a = 0 := h₁
      have h₃ : ((Pi.ringHom fun i : ι => Quotient.mk (I i)) a) i = 0 := by
        simp [h₂]
      have h₄ : (Quotient.mk (I i) a : R ⧸ I i) = 0 := by
        simp_all [Pi.ringHom_apply]
      have h₅ : a ∈ I i := by
        simpa [Quotient.mk_eq_zero] using h₄
      exact h₅
    exact h
  ) := rfl
  rw [h]
  -- Use the injectivity of the lift
  apply Ideal.Quotient.injective_of_isInj _
  <;> simp_all [RingHom.isInj]
  <;>
  (try decide) <;>
  (try
    {
      -- Show that the product map is injective if the intersection of the ideals is zero
      intro x y hxy
      have h := congr_arg (fun p => p 0) hxy
      simp_all [Pi.ringHom_apply, RingHom.map_zero]
      <;>
      (try simp_all [Quotient.mk_eq_zero]) <;>
      (try aesop)
    })
  <;>
  (try
    {
      -- Show that the kernel of the product map is contained in the intersection of the ideals
      intro x hx
      simp_all [RingHom.ker, Set.mem_setOf_eq]
      <;>
      (try
        {
          have h₁ := hx
          simp_all [Pi.ringHom_apply, RingHom.map_zero]
          <;>
          (try simp_all [Quotient.mk_eq_zero]) <;>
          (try aesop)
        })
      <;>
      (try aesop)
    })
