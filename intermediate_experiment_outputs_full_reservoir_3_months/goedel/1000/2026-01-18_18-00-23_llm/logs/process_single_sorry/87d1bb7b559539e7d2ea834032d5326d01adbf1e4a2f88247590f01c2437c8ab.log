  have h₂ : (-r + -e) * (-r + -e) = e ^ 2 + 2 * (e * r) + r ^ 2 := by
    calc
      (-r + -e) * (-r + -e) = (-r) * (-r) + (-r) * (-e) + (-e) * (-r) + (-e) * (-e) := by
        ring_nf
