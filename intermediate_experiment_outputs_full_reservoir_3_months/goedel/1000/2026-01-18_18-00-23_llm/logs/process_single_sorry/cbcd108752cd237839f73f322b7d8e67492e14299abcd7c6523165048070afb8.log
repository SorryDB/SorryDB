```lean
theorem knights_knaves_puzzle :
  (B ∈ Knight ↔ (A ∈ Knight ↔ Knight.card = 1)) →
  (C ∈ Knight ↔ B ∈ Knave) →
  (C ∈ Knave ↔ B ∈ Knight) →
  B ∈ Knave ∧ C ∈ Knight := by
  intro stB stC stCn
  have BKnave : B ∈ Knave := by
    by_contra h
    -- Assume B is a knight
    have hBK : B ∈ Knight := by simpa [not_mem_Knave] using h
    -- Since C is a knight iff B is a knave, C is a knave
    have hCv : C ∈ Knave := (stCn.mpr hBK)
    -- Since C is a knave, B must be a knight (from the third statement)
    have hBC : B ∈ Knight := by simpa [hCv] using stCn.mp hCv
    -- B cannot be both a knight and a knave
    simp_all [not_mem_Knave]
    <;> try contradiction
    <;> try aesop
  
  have CKnight : C ∈ Knight := by
    have hC : C ∈ Knight := by
      -- Use the fact that C is a knight if and only if B is a knave
      have h1 : (C ∈ Knight ↔ B ∈ Knave) := stC
      -- Since B is a knave, we can deduce that C is a knight
      have h2 : B ∈ Knave := BKnave
      have h3 : C ∈ Knight := (h1.mpr h2)
      exact h3
    exact h
  exact ⟨BKnave, CKnight⟩
```
