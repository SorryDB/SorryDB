def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by simp [RingHom.map_one]
  map_mul' := by
    intro x y
    simp [RingHom.map_mul, map_mul]
  map_zero' := by simp [map_zero]
  map_add' := by
    intro x y
    simp [map_add]

