      _ = f.symm (g.symm (g (f x))) := rfl
      _ = f.symm (f x) := by
        -- Simplify g.symm (g (f x)) to f x since g.symm is a right inverse of g
        have h : g.symm (g (f x)) = f x := by
          apply Eq.symm
          apply Eq.symm
          apply g.symm_apply_apply
        rw [h]
      _ = x := by
        -- Simplify f.symm (f x) to x since f.symm is a left inverse of f
        have h : f.symm (f x) = x := by
          apply Eq.symm
          apply Eq.symm
          apply f.symm_apply_apply
        rw [h]
  right_inv := by
    -- Unfold the definition of the composition and use the properties of right inverse and ring homomorphism
    intro x
    calc
      toFun (invFun x) = toFun (f.symm (g.symm x)) := rfl
      _ = g (f (f.symm (g.symm x))) := rfl
      _ = g (g.symm x) := by
        -- Simplify f (f.symm (g.symm x)) to g.symm x since f is a left inverse of f.symm
        have h : f (f.symm (g.symm x)) = g.symm x := by
          apply Eq.symm
          apply Eq.symm
          apply f.apply_symm_apply
        rw [h]
