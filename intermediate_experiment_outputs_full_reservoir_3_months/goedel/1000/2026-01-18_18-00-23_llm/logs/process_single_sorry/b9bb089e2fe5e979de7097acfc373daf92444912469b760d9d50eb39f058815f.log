structure RingEquiv (R S : Type*) [Ring R] [Ring S] 
  extends RingHom R S, Equiv R S where
  toRingHom : toFun = toFun
  toEquiv : toFun = toFun

@[to_additive]
instance [Ring R] [Ring S] : MulEquiv R S ↔ R ≃+* S :=
  ⟨fun e => MulEquiv.toRingEquiv _ _, fun e => by
    exact inferInstance⟩

@[to_additive]
def RingEquiv.comp {R S T : Type*} [Ring R] [Ring S] [Ring T]
    (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T :=
  {
    toFun := fun x : R ↦ g (f x)
    invFun := fun x : T ↦ f.symm (g.symm x)
    map_mul' := by
      intro x y
      simp [RingHom.map_mul, mul_assoc]
      <;> simp_all [RingEquiv.toFun_eq]
      <;> simp_all [RingHom.map_mul]
      <;> ring_nf
      <;> simp_all [RingEquiv.toFun_eq]
    map_one' := by
      have h : (g : S →+* T) 1 = 1 := by simp [RingHom.map_one]
      simp [h, f.map_one]
    addCommGroupHomClass := by
      exact inferInstance
    bijective := by
      apply And.intro
      · -- Prove injectivity
        intro x y h
        have h₁ : g (f x) = g (f y) := h
        have h₂ : f x = f y := by
          apply g.injective
          exact h₁
        have h₃ : x = y := by
          apply f.injective
          exact h₂
        exact h₃
      · -- Prove surjectivity
        intro z
        have h₁ : ∃ y : S, g y = z := by
          -- Since g is surjective, there exists a y such that g(y) = z
          have h₂ : Function.Surjective (g : S →+* T) := (g.equiv.surjective)
          obtain ⟨y, hy⟩ := h₂ z
          exact ⟨y, by simpa [RingHom.map_mul] using hy⟩
        obtain ⟨y, hy⟩ := h₁
        have h₂ : ∃ x : R, f x = y := by
          -- Since f is surjective, there exists an x such that f(x) = y
          have h₃ : Function.Surjective (f : R →+* S) := (f.equiv.surjective)
          obtain ⟨x, hx⟩ := h₃ y
          exact ⟨x, by simpa [RingHom.map_mul] using hx⟩
        obtain ⟨x, hx⟩ := h₂
        use x
        <;> simp_all [RingHom.map_mul]
        <;> simp_all [hy]
        <;> ring_nf at *
        <;> simp_all [hx]
  }
