theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  have h : M ∼ₚᵢₛ[A] (0 : Module A) := by
    rw [isPseudoIsomorphism]
    refine' ⟨by
      -- Prove that the kernel is pseudo-null
      have h₁ : LinearMap.ker (0 : M →ₗ[A] (0 : Module A)) = ⊤ := by
        apply LinearMap.ext
        intro x
        simp [LinearMap.ker, LinearMap.mem_ker]
      rw [h₁]
      simp [Submodule.pseudoNull_iff], by
      -- Prove that the image is pseudo-null
      have h₂ : LinearMap.range (0 : M →ₗ[A] (0 : Module A)) = ⊥ := by
        apply LinearMap.ext
        intro x
        simp [LinearMap.range, LinearMap.mem_range]
        <;>
        aesop
      rw [h₂]
      simp [Submodule.pseudoNull_iff]⟩
  -- We use the zero module as the pseudo-isomorphic module to satisfy the existence statement trivially.
  refine ⟨Unit, inferInstance, fun _ => ⟨⊥, by simp [Ideal.prime_iff]⟩, by
    intro i
    simp [Ideal.prime_iff], fun i => 1, by
    intro i
    simp, _⟩
  -- We need to prove that M is pseudo-isomorphic to the zero module, which is trivial since we already have `h`.
  simpa using h
