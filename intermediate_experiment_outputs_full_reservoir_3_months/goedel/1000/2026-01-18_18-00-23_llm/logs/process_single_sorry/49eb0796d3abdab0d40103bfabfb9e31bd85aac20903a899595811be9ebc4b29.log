theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  by_cases h : Nonempty M
  · -- Case: M is nonempty
    haveI : Nonempty M := h
    -- We provide a trivial solution where ι is empty, which can't be the case.
    refine' ⟨Empty, inferInstance, Empty.elim, _⟩
    <;> simp_all [PseudoIsomorphism]
    <;> aesop
  · -- Case: M is empty
    have h₁ : M = PEmpty := by
      exact Subsingleton.elim
    -- Since M is empty, we can take ι as empty and the result is trivial
    refine' ⟨Empty, inferInstance, Empty.elim, _⟩
    <;> simp_all [PseudoIsomorphism]
    <;> aesop
