theorem main2 (n x y : ℕ) : 
  n > 0 → 
  (x < y) → 
  (x < n * x + y) := by
  intro hn hxy
  have h₁ : x < n * x + y := by
    have h₂ : 0 < n := by linarith
    have h₃ : 0 ≤ x := by linarith
    have h₄ : 0 ≤ y := by linarith
    have h₅ : x < n * x + y := by
      nlinarith
    exact h₅
  exact h₁
```

