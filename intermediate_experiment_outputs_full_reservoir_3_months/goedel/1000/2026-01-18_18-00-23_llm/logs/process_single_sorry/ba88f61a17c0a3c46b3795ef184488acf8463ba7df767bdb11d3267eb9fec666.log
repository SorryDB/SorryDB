theorem Theorem_8_1_5_3 : 
  U ∼ V ↔ S ∼ T ↔ Set U ∼ Set V ↔ Set S ∼ Set T := by
  have h₁ : U ∼ V ↔ S ∼ T := by
    apply Iff.intro
    · intro uv
      -- Assume U ∼ V, then S ∼ T
      exact h_suv (equate.trans uv)
    · intro st
      -- Assume S ∼ T, then U ∼ V
      exact h_suv.symm.trans st
  have h₂ : Set U ∼ Set V ↔ Set S ∼ Set T := by
    apply Iff.intro
    · intro uv
      -- Assume Set U ∼ Set V, then Set S ∼ Set T
      exact h_set (equate.trans uv)
    · intro st
      -- Assume Set S ∼ Set T, then Set U ∼ Set V
      exact h_set.symm.trans st
  -- Combine the two equivalences to get the final result
  constructor <;> simp_all [h₁, h₂] <;> tauto
