theorem Exercise_8_1_17 {U V : Type} {A B : Set U}
    (h1 : B ⊆ A) (h2 : ctble A) : ctble B := by
  have h3 : B ∼ A ∩ B := by
    refine' { toFun := fun x => x, invFun := fun x => x, left_inv := _, right_inv := _ }
    · -- Prove that the composition of invFun and toFun is the identity on B
      intro x
      simp
    · -- Prove that the composition of toFun and invFun is the identity on A ∩ B
      intro x
      simp [Set.mem_inter_iff]
      <;> aesop
  have h4 : ctble (A ∩ B) := by
    -- A ∩ B is a subset of A, and A is countable, so A ∩ B is countable
    have h5 : A ∩ B ⊆ A := by
      intro x hx
      exact hx.1
    have h6 : ctble A := h2
    have h7 : ctble (A ∩ B) := h6.mono h5
    exact h7
  have h8 : ctble B := by
    -- Since B is in bijection with A ∩ B, and A ∩ B is countable, B is countable
    have h9 : B ∼ A ∩ B := h3.symm
    have h10 : ctble (A ∩ B) := h4
    exact h10.ofEquiv h9
  exact h8

``` 

