    -- The Wigner measure is a product of measures, each of which is a probability measure.
    exact instIsProbabilityMeasure
  -- The measure is mapped to matrices by `wignerMatrixMap`.
  have h₂ : IsProbabilityMeasure (Measure.map (wignerMatrixMap n) (WignerMeasure μ ν n)) := by
    apply h₁.map
  exact h₂

