      have h₄ : (wignerMatrixScaledTracePowerSequence μ ν k) = fun _ ↦ (0 : ℝ) := by
        funext n
        rw [h₂ n]
      rw [h₄]
      exact tendsto_const_nhds
    exact h₃
  exact h₁ k hk
