theorem wignerMatrixMomentOddExpectation (n : ℕ) (k : ℕ) (hk : Odd k) :
  Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (nhds 0) := by
  have h₁ : Odd k := hk
  have h₂ : (k : ℕ) % 2 = 1 := by
    cases' h₁ with m hm
    omega
  have h₃ : (1 : ℝ) / (n : ℝ) = 0 := by
    cases n with
    | zero =>
      norm_num
    | succ n => 
      field_simp [Nat.cast_add_one_ne_zero]
      <;> ring_nf
      <;> norm_num
      <;> simp_all [Nat.cast_add_one_ne_zero]
      <;> field_simp [Nat.cast_add_one_ne_zero]
      <;> ring_nf
      <;> norm_num
      <;> linarith
  simp_all [wignerMatrixScaledTracePowerSequence, wignerMatrixTracePower]
  <;> norm_num
  <;> aesop
```
