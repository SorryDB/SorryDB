theorem wignerMatrixMomentOddExpectation (n : ℕ) (k : ℕ) (hk : Odd k) :
  Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (nhds 0) := by
  have h₁ : ∀ (k : ℕ), Odd k → Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (nhds 0) := by
    intro k hk
    have h₂ : ∀ (n : ℕ), wignerMatrixScaledTracePowerSequence μ ν k n = 0 := by
      intro n
      simp [wignerMatrixScaledTracePowerSequence, wignerMatrixTracePowerSequence, wignerMatrixTracePower, wignerMatrixMapScaled]
      <;> ring_nf
      <;> simp_all [Matrix.trace_pow]
      <;> field_simp
