                    exact Equiv.isEmpty_iff.mpr (by simp_all [Set.Countable])
                  simp_all [Equiv.isEmpty_iff]
                  <;> aesop
              -- Use the fact that any countable set is equivalent to ℕ
              exact Set.countableEquivNat (Set.range f)
            exact h₁₂
