    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  have h₁ : ctble U → ∃ (f : U → ℕ), Function.Injective f := by
    intro h
    have h₂ : Nonempty (U ≃ ℕ) := by
      rw [ctble] at h
      exact h
    cases' h₂ with e
    refine' ⟨e.toFun, _⟩
    intro x y h
    apply e.injective
    exact h
  have h₂ : (∃ (f : U → ℕ), Function.Injective f) → ctble U := by
    intro h
    have h₃ : Nonempty (U ≃ ℕ) := by
      cases' h with f hf
      have h₄ : U ≃ Set.range f := by
        refine' ⟨fun x => ⟨f x, Set.mem_range_self x⟩, fun x => x.1, _, _⟩ <;> simp_all [Function.Injective]
        <;> aesop
      have h₅ : Set.range f ≃ ℕ := by
        have h₆ : Set.range f ≃ ℕ := by
          have h₇ : Set.range f ≃ Set.range f := by simp [Equiv.refl]
          have h₈ : Function.Injective f := hf
          have h₉ : Set.range f ≃ ℕ := by
            -- Use the fact that the range of f is countable because it is a subset of ℕ
            have h₁₀ : Set.range f ⊆ Set.univ := by simp
            have h₁₁ : Set.Countable (Set.range f) := Set.countable_range _
            have h₁₂ : Set.range f ≃ ℕ := by
              -- Use the fact that any countable set is equivalent to ℕ
              have h₁₃ : Set.Nonempty (Set.range f) := by
                -- Show that the range is nonempty
                by_cases h₁₄ : Nonempty U
                · cases' h₁₄ with x
                  exact ⟨f x, Set.mem_range_self x⟩
                · exfalso
                  -- If U is empty, then f cannot be injective unless U is empty
