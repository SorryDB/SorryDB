lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  simp [fnz, Int.ofNat_eq_coe, Int.emod_eq_of_lt]
  <;>
  ring_nf
  <;>
  norm_num
  <;>
  omega
  
lemma fnz_fzn : fnz ∘ fzn = id := by
  ext x
  simp [functions.funext_iff, fnz, fzn]
  <;>
  cases x <;>
  simp_all [Int.emod_eq_of_lt]
  <;>
  ring_nf at *
  <;>
  norm_cast at *
  <;>
  omega
  
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  have h₁ : tri (k + 1) = (k + 1) * (k + 2) / 2 := by
    simp [tri]
    <;>
    ring_nf
    <;>
    norm_num
    <;>
    omega
  
  have h₂ : tri k = k * (k + 1) / 2 := by
    simp [tri]
    <;>
    ring_nf
    <;>
    norm_num
    <;>
    omega
  
  rw [h₁]
  rw [h₂]
  have h₃ : (k + 1) * (k + 2) / 2 = (k * (k + 1) / 2 + k + 1) := by
    have h₄ : (k + 1) * (k + 2) = k * (k + 1) + 2 * (k + 1) := by
      ring
    have h₅ : (k + 1) * (k + 2) / 2 = (k * (k + 1) + 2 * (k + 1)) / 2 := by
      rw [h₄]
    have h₆ : (k * (k + 1) + 2 * (k + 1)) / 2 = (k * (k + 1) / 2 + k + 1) := by
      have h₇ : (k * (k + 1)) % 2 = 0 := by
        have h₈ : k * (k + 1) % 2 = 0 := by
          have : k % 2 = 0 ∨ k % 2 = 1 := by omega
          rcases this with (h₉ | h₉) <;>
          simp [h₉, Nat.mul_mod, Nat.add_mod, Nat.mod_mod]
          <;>
          ring_nf at * <;>
          omega
        exact h₈
      have h₈ : (k * (k + 1) + 2 * (k + 1)) / 2 = (k * (k + 1) / 2 + (2 * (k + 1)) / 2) := by
        have h₉ : (k * (k + 1) + 2 * (k + 1)) / 2 = (k * (k + 1) / 2 + (2 * (k + 1)) / 2) := by
          have h₁₀ : k * (k + 1) % 2 = 0 := h₇
