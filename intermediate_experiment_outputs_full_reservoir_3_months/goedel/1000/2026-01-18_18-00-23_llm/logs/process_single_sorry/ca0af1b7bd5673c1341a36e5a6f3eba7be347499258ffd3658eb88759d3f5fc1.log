    -- Use the fact that B is a subset of A and A is countable to show that B is countable
    have : ctble (↥B) := by
      -- Since B is a subset of A, we can use the countability of A to deduce the countability of B
      apply Set.countable_coe_iff.mpr
      -- The set B itself is countable if its coercion to a type is countable
      simpa [Set.countable_def] using h2.mono (by exact Set.subset_univ B)
    exact this
  -- Since the subtype ↥B is countable, the set B is also countable
  exact Set.countable_coe_iff.mp h3
