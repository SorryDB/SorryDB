        refine' h₄.trans _
        exact h₅
      exact h₁₀
    -- Use the fact that U ≃ ℕ to conclude that U is countable
    rw [ctble]
    exact h₃
  -- Combine the two directions to get the final result
  constructor
  · intro h
    exact h₁ h
  · intro h
    exact h₂ h
