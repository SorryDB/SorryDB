theorem Exercise_8_1_17 {U : Type} (U V : Type) (A : Set U) (f : A → V) (v : V) :
    func_restrict (func_extend f v) A = f := by
  funext ⟨x, hx⟩
  rw [show (fun p : A => (fun y : U => if y = p.val then f p else v) p.val) = fun p : A => f p by
    funext p
    simp]
  <;> simp [hx]
  <;> aesop
```

```lean
theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · intro h
    obtain ⟨f, hf⟩ := h
    exact ⟨f, by simpa [Function.Injective] using hf⟩
  · rintro ⟨f, hf⟩
    exact ⟨f, by simpa [Function.Injective] using hf⟩
```

```lean
theorem ctble_set_of_ctble_type {U : Type}
    (h : ctble U) (A : Set U) : ctble A := by
  have h' : ctble (↥A) := by
    -- Use the fact that A is a subset of U and U is countable to show that A is countable
    have : ctble (↥A) := by
      -- Since A is a subset of U, we can use the countability of U to deduce the countability of A
      apply Set.countable_coe_iff.mpr
      -- The set A itself is countable if its coercion to a type is countable
      simpa [Set.countable_def] using h.mono (by exact Set.subset_univ A)
    exact this
  -- Since the subtype ↥A is countable, the set A is also countable
  exact Set.countable_coe_iff.mp h'
```

