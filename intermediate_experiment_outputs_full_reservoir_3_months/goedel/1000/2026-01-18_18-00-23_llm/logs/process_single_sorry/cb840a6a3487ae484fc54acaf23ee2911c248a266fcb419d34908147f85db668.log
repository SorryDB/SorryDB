      "by\n  have h₁ : range (val_image A) ⊆ 𝒫 A := by\n    intro S hS\n    rcases hS with ⟨X, rfl⟩\n    apply Set.subset_iff.mpr\n    intro y hy\n    -- We need to show that for any y in the image of X, y is in A.\n    -- This follows from the definition of val_image.\n    rcases hy with ⟨⟨x, hx⟩, rfl⟩\n    exact hx\n  have h₂ : 𝒫 A ⊆ range (val_image A) := by\n    intro S hS\n    -- For any subset S of A, we need to find a set X in A such that val_image A X = S.\n    -- We can simply take X = S, since S is already a subset of A.\n    refine' ⟨S, _⟩\n    -- We need to show that val_image A S = S.\n    -- This is true because for any y in S, y is in A and there exists x ∈ S such that x = y.\n    ext y\n    simp only [Set.mem_setOf_eq, val_image, Set.mem_range, Set.mem_setOf_eq]\n    <;>\n    (try simp_all [Set.mem_setOf_eq]) <;>\n    (try {\n      aesop\n    }) <;>\n    (try {\n      constructor <;> intro h <;>\n      (try {\n        aesop\n      }) <;>\n      (try {\n        simp_all [Set.mem_setOf_eq]\n        <;>\n        aesop\n      })\n    })\n    <;>\n    aesop\n  -- Combining the two subset relations gives us the equality.\n  exact Set.Subset.antisymm h₁ h₂",
