      "by\n  ext S\n  simp only [Set.mem_range, Set.mem_powerset_iff]\n  constructor\n  · -- Prove that if S is in the range of val_image A, then S ⊆ A\n    rintro ⟨X, rfl⟩\n    intro y hy\n    -- For any y in val_image A X, there exists x in X such that x.val = y\n    simp only [val_image, Set.mem_setOf_eq] at hy\n    obtain ⟨x, hx, rfl⟩ := hy\n    -- Since x is in X and X is a subset of A, y is in A\n    exact x.property\n  · -- Prove that if S ⊆ A, then S is in the range of val_image A\n    intro hS\n    -- Construct a subset X of A such that val_image A X = S\n    refine' ⟨S, _⟩\n    ext y\n    simp only [val_image, Set.mem_setOf_eq, Subtype.mem_val]\n    <;>\n    constructor <;>\n    (try { intro hy <;> aesop }) <;>\n    (try {\n      intro hy\n      obtain ⟨x, hx, rfl⟩ := hy\n      aesop\n    }) <;>\n    (try {\n      aesop\n    })",
      "by\n  ext S\n  simp only [Set.mem_range, exists_prop]\n  constructor\n  · -- Prove that if S is in the range of val_image A, then S is a subset of A.\n    rintro ⟨X, rfl⟩\n    -- For any X : Set A, val_image A X is a subset of A.\n    -- This is because every element of val_image A X is an element of A.\n    have h : val_image A X ⊆ A := by\n      intro x hx\n      -- If x is in val_image A X, then there exists some y in X such that y.val = x.\n      rcases hx with ⟨y, hy, rfl⟩\n      -- Since y is in X and X is a subset of A (because X : Set A), y.val is in A.\n      exact hy.prop\n    -- Therefore, val_image A X is in 𝒫 A.\n    exact h\n  · -- Prove that if S is a subset of A, then there exists some X : Set A such that val_image A X = S.\n    intro hS\n    -- S is a subset of A.\n    -- We can take X to be the set of all elements y : A such that y.val is in S.\n    -- But actually, we can use Subtype S directly.\n    refine' ⟨S, _⟩\n    -- We need to show that val_image A (S : Set A) = S.\n    -- For any x, x is in val_image A (S : Set A) iff there exists some y : S such that y.val = x.\n    -- But y : S means y.val is in S by definition.\n    -- So x is in S iff there exists y : S with y.val = x, since S is a subset of A.\n    ext x\n    simp only [Set.mem_setOf_eq, val_image, Set.mem_range]\n    constructor\n    · -- Prove the forward direction: if x is in val_image A S, then x is in S.\n      intro hx\n      -- If x is in val_image A S, then there exists some y in S such that y.val = x.\n      -- But y in S means y.val is in S, so x = y.val is in S.\n      rcases hx with ⟨y, hy, rfl⟩\n      exact hy\n    · -- Prove the reverse direction: if x is in S, then x is in val_image A S.\n      intro hx\n      -- If x is in S, then (x : A) is in S (View S as a subtype).\n      -- And (x : A).val = x.\n      refine' ⟨⟨x, hx⟩, by exact ⟨x, hx⟩, _⟩\n      <;> simp",
      "by\n  have h₁ : range (val_image A) ⊆ 𝒫 A := by\n    intro S hS\n    rw [Set.mem_range] at hS\n    rcases hS with ⟨X, rfl⟩\n    -- We need to show that val_image A X is a subset of A\n    have h₂ : val_image A X ⊆ A := by\n      intro y hy\n      -- For any y in val_image A X, there exists x in X such that x.val = y\n      -- Since x is in X and X is a subset of A, y must be in A\n      rcases hy with ⟨x, hx, rfl⟩\n      have h₃ : (x : U) ∈ A := by\n        exact x.prop\n      exact h₃\n    -- Therefore, val_image A X is a subset of A, so it is in 𝒫 A\n    exact h₂\n  have h₂ : 𝒫 A ⊆ range (val_image A) := by\n    intro S hS\n    -- For any subset S of A, we need to find a set X such that val_image A X = S\n    have h₃ : S ∈ 𝒫 A := hS\n    have h₄ : S ⊆ A := h₃\n    -- We can take X to be the set of elements of A that are in S\n    -- Specifically, X = {x : A | (x : U) ∈ S}\n    -- Then val_image A X = S\n    have h₅ : ∃ (X : Set A), val_image A X = S := by\n      use {x : A | (x : U) ∈ S}\n      apply Set.ext\n      intro y\n      simp only [Set.mem_setOf_eq, val_image, Set.mem_setOf_eq]\n      constructor\n      · -- Prove the forward direction: if y is in val_image A X, then y is in S\n        intro h\n        rcases h with ⟨x, hx, rfl⟩\n        have h₆ : (x : U) ∈ S := hx\n        exact h₆\n      · -- Prove the reverse direction: if y is in S, then y is in val_image A X\n        intro h\n        have h₆ : y ∈ A := h₄ h\n        have h₇ : (⟨y, h₆⟩ : A) ∈ {x : A | (x : U) ∈ S} := by\n          simp [h]\n        refine' ⟨⟨y, h₆⟩, h₇, _⟩\n        simp\n        <;> aesop\n    -- Therefore, S is in the range of val_image A\n    rcases h₅ with ⟨X, hX⟩\n    have h₆ : S ∈ range (val_image A) := by\n      refine' ⟨X, _⟩\n      rw [hX]\n    exact h₆\n  -- Since both inclusions hold, the range of val_image A is equal to 𝒫 A\n  exact Set.Subset.antisymm h₁ h₂",
