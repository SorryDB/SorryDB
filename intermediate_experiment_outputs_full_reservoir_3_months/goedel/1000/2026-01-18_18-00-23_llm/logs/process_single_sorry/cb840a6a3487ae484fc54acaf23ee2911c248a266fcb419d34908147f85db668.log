      "by\n  have h₁ : range (val_image A) ⊆ 𝒫 A := by\n    intro S hS\n    obtain ⟨X, rfl⟩ := hS\n    have h₂ : val_image A X ⊆ A := by\n      intro y hy\n      obtain ⟨x, hx, rfl⟩ := hy\n      exact x.prop\n    exact h₂\n  have h₂ : 𝒫 A ⊆ range (val_image A) := by\n    intro S hS\n    have h₃ : S ∈ 𝒫 A := hS\n    have h₄ : S ⊆ A := by simpa [Set.mem_powerSet] using h₃\n    have h₅ : ∃ (X : Set (↥A)), val_image A X = S := by\n      use {x : ↥A | (x : U) ∈ S}\n      apply Set.ext\n      intro y\n      simp only [val_image, Set.mem_setOf_eq, Set.mem_setOf_eq]\n      constructor\n      · intro hy\n        obtain ⟨x, hx, rfl⟩ := hy\n        have h₆ : (x : U) ∈ S := by simpa using hx\n        exact h₆\n      · intro hy\n        have h₆ : y ∈ S := hy\n        have h₇ : y ∈ A := h₄ h₆\n        refine' ⟨⟨y, h₇⟩, _, rfl⟩\n        simpa using h₆\n    obtain ⟨X, hX⟩ := h₅\n    refine' ⟨X, _⟩\n    simp [hX]\n  exact Set.Subset.antisymm h₁ h₂",
      "sorry\n\ntheorem range_val_image {U : Type} (A : Set U) :\n    range (val_image A) = 𝒫 A := by\n  apply Set.Subset.antisymm\n  · -- Prove that range (val_image A) ⊆ 𝒫 A\n    intro S hS\n    rcases hS with ⟨X, rfl⟩\n    -- We need to show that val_image A X is a subset of A.\n    have h : val_image A X ⊆ A := by\n      intro y hy\n      -- For any y in val_image A X, there exists x in X such that x.val = y.\n      rcases hy with ⟨x, hx, rfl⟩\n      -- Since x is in X, and X is a set of elements of A, x.val is in A.\n      exact x.2\n    -- Since val_image A X is a subset of A, it is in 𝒫 A.\n    exact h\n  · -- Prove that 𝒫 A ⊆ range (val_image A)\n    intro S hS\n    -- For any S in 𝒫 A, we need to find X such that val_image A X = S.\n    have h : S ∈ 𝒫 A := hS\n    have h₁ : S ⊆ A := h\n    -- Define X as the subtype of elements of S.\n    let X : Set {x : U // x ∈ A} := {x : {x : U // x ∈ A} | x.val ∈ S}\n    -- Show that val_image A X = S.\n    have h₂ : val_image A X = S := by\n      ext y\n      simp only [val_image, Set.mem_setOf_eq, X]\n      constructor\n      · -- Prove the forward direction: if y is in val_image A X, then y is in S.\n        intro hy\n        rcases hy with ⟨⟨x, hx⟩, hx', rfl⟩\n        -- Since ⟨x, hx⟩ is in X, x.val is in S.\n        exact hx'\n      · -- Prove the reverse direction: if y is in S, then y is in val_image A X.\n        intro hy\n        -- Since y is in S and S is a subset of A, we can find an element in X whose value is y.\n        have h₃ : y ∈ A := h₁ hy\n        refine' ⟨⟨y, h₃⟩, _, rfl⟩\n        -- Show that ⟨y, h₃⟩ is in X.\n        simp [hy]\n    -- Therefore, S is in the range of val_image A.\n    exact ⟨X, by simp [h₂]⟩",
