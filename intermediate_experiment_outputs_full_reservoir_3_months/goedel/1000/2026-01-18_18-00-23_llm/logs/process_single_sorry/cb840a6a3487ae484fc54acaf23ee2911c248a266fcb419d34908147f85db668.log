theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: if U ∼ V, then there exist f and g such that f ∘ g = id and g ∘ f = id.
    intro h
    have h₁ : Nonempty (U ≃ V) := by
      -- Since U ∼ V, there exists an equivalence between U and V.
      exact h
    -- Obtain the equivalence from the nonempty type.
    cases' h₁ with e
    -- Use the equivalence to construct the functions f and g.
    refine' ⟨e.toFun, e.invFun, _, _⟩ <;>
      (try simp_all [Equiv.ext_iff, Function.comp_apply]) <;>
      (try aesop) <;>
      (try {
        funext x
        simp [Equiv.apply_inv_apply]
      }) <;>
      (try {
        funext x
        simp [Equiv.inv_apply_apply]
      })
  · -- Prove the reverse direction: if there exist f and g such that f ∘ g = id and g ∘ f = id, then U ∼ V.
    rintro ⟨f, g, h₁, h₂⟩
    -- Construct the equivalence using the functions f and g.
    have h₃ : U ≃ V := {
      toFun := f
      invFun := g
      left_inv := by
        -- Prove that g ∘ f = id implies left inverse.
        funext x
        have h₄ := congr_fun h₂ x
        simp [Function.comp_apply] at h₄ ⊢
        <;> simp_all
      right_inv := by
        -- Prove that f ∘ g = id implies right inverse.
        funext x
        have h₄ := congr_fun h₁ x
        simp [Function.comp_apply] at h₄ ⊢
        <;> simp_all
    }
    -- Use the equivalence to conclude U ∼ V.
    exact ⟨h₃⟩
