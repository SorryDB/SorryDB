def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  have h₁ : range (val_image A) ⊆ 𝒫 A := by
    intro S hS
    obtain ⟨X, rfl⟩ := hS
    have h₂ : val_image A X ⊆ A := by
      intro y hy
      obtain ⟨x, hx, rfl⟩ := hy
      exact x.prop
    exact h₂
  have h₂ : 𝒫 A ⊆ range (val_image A) := by
    intro S hS
    have h₃ : S ∈ 𝒫 A := hS
    have h₄ : S ⊆ A := by simpa [Set.mem_powerSet] using h₃
    have h₅ : ∃ (X : Set (↥A)), val_image A X = S := by
      use {x : ↥A | (x : U) ∈ S}
      apply Set.ext
      intro y
      simp only [val_image, Set.mem_setOf_eq, Set.mem_setOf_eq]
      constructor
      · intro hy
        obtain ⟨x, hx, rfl⟩ := hy
        have h₆ : (x : U) ∈ S := by simpa using hx
        exact h₆
      · intro hy
        have h₆ : y ∈ S := hy
        have h₇ : y ∈ A := h₄ h₆
        refine' ⟨⟨y, h₇⟩, _, rfl⟩
        simpa using h₆
    obtain ⟨X, hX⟩ := h₅
    refine' ⟨X, _⟩
    simp [hX]
  exact Set.Subset.antisymm h₁ h₂
