      "\n    have hвВБ : tвВБ.size < 2 ^ tвВБ.height := ihl\n    have hвВВ : tвВВ.size < 2 ^ tвВВ.height := ihr\n    have hвВГ : 1 + tвВБ.size + tвВВ.size < 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n      have hвВД : 2 ^ (1 + max tвВБ.height tвВВ.height) = 2 * 2 ^ (max tвВБ.height tвВВ.height) := by\n        rw [pow_add]\n        <;> simp [pow_one]\n        <;> ring\n      rw [hвВД]\n      have hвВЕ : max tвВБ.height tвВВ.height = max tвВБ.height tвВВ.height := rfl\n      have hвВЖ : tвВБ.size < 2 ^ tвВБ.height := ihl\n      have hвВЗ : tвВВ.size < 2 ^ tвВВ.height := ihr\n      have hвВИ : tвВБ.height вЙ§ max tвВБ.height tвВВ.height := by\n        apply le_max_left\n      have hвВЙ : tвВВ.height вЙ§ max tвВБ.height tвВВ.height := by\n        apply le_max_right\n      have hвВБвВА : (2 : вДХ) ^ tвВБ.height вЙ§ 2 ^ (max tвВБ.height tвВВ.height) := by\n        apply pow_le_pow_right (by norm_num)\n        exact hвВИ\n      have hвВБвВБ : (2 : вДХ) ^ tвВВ.height вЙ§ 2 ^ (max tвВБ.height tвВВ.height) := by\n        apply pow_le_pow_right (by norm_num)\n        exact hвВЙ\n      have hвВБвВВ : 1 + tвВБ.size + tвВВ.size < 2 * 2 ^ (max tвВБ.height tвВВ.height) := by\n        have hвВБвВГ : 1 + tвВБ.size + tвВВ.size < 1 + 2 ^ tвВБ.height + 2 ^ tвВВ.height := by\n          have hвВБвВД : tвВБ.size < 2 ^ tвВБ.height := ihl\n          have hвВБвВЕ : tвВВ.size < 2 ^ tвВВ.height := ihr\n          omega\n        have hвВБвВЖ : 1 + 2 ^ tвВБ.height + 2 ^ tвВВ.height вЙ§ 2 * 2 ^ (max tвВБ.height tвВВ.height) := by\n          cases' le_total tвВБ.height tвВВ.height with h h <;>\n            simp_all [max_eq_right, max_eq_left] <;>\n            (try { contradiction }) <;>\n            (try {\n              have hвВБвВЗ : (2 : вДХ) ^ tвВБ.height вЙ§ 2 ^ tвВВ.height := by\n                apply pow_le_pow_right (by norm_num)\n                <;> linarith\n              nlinarith [pow_pos (by norm_num : (0 : вДХ) < 2) tвВВ.height]\n            }) <;>\n            (try {\n              