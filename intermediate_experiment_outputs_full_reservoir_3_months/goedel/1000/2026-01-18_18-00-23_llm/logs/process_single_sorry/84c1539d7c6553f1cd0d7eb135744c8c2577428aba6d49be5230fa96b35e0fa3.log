      "\n    have hвВБ : tвВБ.size < 2 ^ tвВБ.height := ihl\n    have hвВВ : tвВВ.size < 2 ^ tвВВ.height := ihr\n    have hвВГ : tвВБ.size < 2 ^ tвВБ.height := ihl\n    have hвВД : tвВВ.size < 2 ^ tвВВ.height := ihr\n    -- We use the fact that for any natural numbers a and b, a < 2^a and b < 2^b to bound the size of the tree.\n    have hвВЕ : 1 + tвВБ.size + tвВВ.size < 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n      have hвВЕвВБ : tвВБ.size < 2 ^ tвВБ.height := ihl\n      have hвВЕвВВ : tвВВ.size < 2 ^ tвВВ.height := ihr\n      have hвВЕвВГ : tвВБ.size + tвВВ.size < 2 ^ tвВБ.height + 2 ^ tвВВ.height := by\n        linarith\n      have hвВЕвВД : max tвВБ.height tвВВ.height вЙ• tвВБ.height := by\n        apply le_max_left\n      have hвВЕвВЕ : max tвВБ.height tвВВ.height вЙ• tвВВ.height := by\n        apply le_max_right\n      have hвВЕвВЖ : 2 ^ tвВБ.height + 2 ^ tвВВ.height вЙ§ 2 ^ (max tвВБ.height tвВВ.height) + 2 ^ (max tвВБ.height tвВВ.height) := by\n        have hвВЕвВЖвВБ : 2 ^ tвВБ.height вЙ§ 2 ^ (max tвВБ.height tвВВ.height) := by\n          apply pow_le_pow_right (by norm_num)\n          exact hвВЕвВД\n        have hвВЕвВЖвВВ : 2 ^ tвВВ.height вЙ§ 2 ^ (max tвВБ.height tвВВ.height) := by\n          apply pow_le_pow_right (by norm_num)\n          exact hвВЕвВЕ\n        linarith\n      have hвВЕвВЗ : 2 ^ (max tвВБ.height tвВВ.height) + 2 ^ (max tвВБ.height tвВВ.height) = 2 * 2 ^ (max tвВБ.height tвВВ.height) := by\n        ring\n      have hвВЕвВИ : 2 * 2 ^ (max tвВБ.height tвВВ.height) = 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n        ring_nf\n        <;> simp [pow_succ, mul_comm]\n        <;> ring\n      have hвВЕвВЙ : 2 ^ tвВБ.height + 2 ^ tвВВ.height вЙ§ 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n        linarith\n      have hвВЕвВБвВА : 1 + tвВБ.size + tвВВ.size < 1 + (2 ^ tвВБ.height + 2 ^ tвВВ.height) := by\n        linarith\n      have hвВЕвВБвВБ : 1 + (2 ^ tвВБ.height + 2 ^ tвВВ.height) вЙ§ 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n      