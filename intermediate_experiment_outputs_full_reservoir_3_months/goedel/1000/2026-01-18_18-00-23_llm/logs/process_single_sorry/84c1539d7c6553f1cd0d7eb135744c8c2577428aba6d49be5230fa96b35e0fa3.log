      "\n    cases' le_total tвВБ.height tвВВ.height with h h <;> simp [h, max_eq_right, max_eq_left] at * <;>\n      (try { omega }) <;>\n      (try {\n        have hвВБ : tвВБ.size < 2 ^ tвВБ.height := ihl\n        have hвВВ : tвВВ.size < 2 ^ tвВВ.height := ihr\n        have hвВГ : tвВБ.size < 2 ^ (1 + tвВВ.height) := by\n          calc\n            tвВБ.size < 2 ^ tвВБ.height := ihl\n            _ вЙ§ 2 ^ tвВВ.height := by apply pow_le_pow_right (by norm_num) (by linarith)\n            _ < 2 ^ (1 + tвВВ.height) := by\n              apply pow_lt_pow_right (by norm_num)\n              linarith\n        have hвВД : tвВВ.size < 2 ^ (1 + tвВВ.height) := by\n          calc\n            tвВВ.size < 2 ^ tвВВ.height := ihr\n            _ < 2 ^ (1 + tвВВ.height) := by\n              apply pow_lt_pow_right (by norm_num)\n              linarith\n        nlinarith [pow_pos (by norm_num : (0 : вДХ) < 2) tвВВ.height]\n      }) <;>\n      (try {\n        have hвВБ : tвВБ.size < 2 ^ tвВБ.height := ihl\n        have hвВВ : tвВВ.size < 2 ^ tвВВ.height := ihr\n        have hвВГ : tвВВ.size < 2 ^ (1 + tвВБ.height) := by\n          calc\n            tвВВ.size < 2 ^ tвВВ.height := ihr\n            _ вЙ§ 2 ^ tвВБ.height := by apply pow_le_pow_right (by norm_num) (by linarith)\n            _ < 2 ^ (1 + tвВБ.height) := by\n              apply pow_lt_pow_right (by norm_num)\n              linarith\n        have hвВД : tвВБ.size < 2 ^ (1 + tвВБ.height) := by\n          calc\n            tвВБ.size < 2 ^ tвВБ.height := ihl\n            _ < 2 ^ (1 + tвВБ.height) := by\n              apply pow_lt_pow_right (by norm_num)\n              linarith\n        nlinarith [pow_pos (by norm_num : (0 : вДХ) < 2) tвВБ.height]\n      })",
