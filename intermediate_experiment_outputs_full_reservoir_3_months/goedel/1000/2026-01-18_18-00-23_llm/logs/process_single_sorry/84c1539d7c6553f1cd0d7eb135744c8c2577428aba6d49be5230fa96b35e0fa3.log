      "\n    have hвВБ : 1 + tвВБ.size + tвВВ.size < 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n      have hвВВ : tвВБ.size < 2 ^ tвВБ.height := ihl\n      have hвВГ : tвВВ.size < 2 ^ tвВВ.height := ihr\n      have hвВД : max tвВБ.height tвВВ.height = tвВБ.height вИ® max tвВБ.height tвВВ.height = tвВВ.height := by\n        cases' le_total tвВБ.height tвВВ.height with h h <;> simp [h, max_eq_right, max_eq_left]\n      cases' hвВД with hвВД hвВД\n      ¬Ј -- Case: max tвВБ.height tвВВ.height = tвВБ.height\n        have hвВЕ : tвВВ.height вЙ§ tвВБ.height := by\n          simp_all [max_eq_left]\n        have hвВЖ : 2 ^ tвВВ.height вЙ§ 2 ^ tвВБ.height := by\n          apply pow_le_pow_right (by norm_num)\n          exact hвВЕ\n        calc\n          1 + tвВБ.size + tвВВ.size < 1 + (2 ^ tвВБ.height) + (2 ^ tвВВ.height) := by\n            linarith\n          _ вЙ§ 1 + (2 ^ tвВБ.height) + (2 ^ tвВБ.height) := by\n            linarith\n          _ = 1 + 2 * 2 ^ tвВБ.height := by ring\n          _ = 1 + 2 ^ (tвВБ.height + 1) := by\n            have hвВЗ : 2 * 2 ^ tвВБ.height = 2 ^ (tвВБ.height + 1) := by\n              ring_nf\n              <;> simp [pow_succ]\n              <;> ring_nf\n            linarith\n          _ вЙ§ 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n            have hвВИ : 1 + tвВБ.height = 1 + max tвВБ.height tвВВ.height := by\n              simp_all [max_eq_left]\n              <;> linarith\n            have hвВЙ : 2 ^ (tвВБ.height + 1) = 2 ^ (1 + tвВБ.height) := by ring_nf\n            have hвВБвВА : 2 ^ (1 + tвВБ.height) вЙ§ 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n              apply pow_le_pow_right (by norm_num)\n              simp_all [max_eq_left]\n              <;> linarith\n            have hвВБвВБ : 1 + 2 ^ (tвВБ.height + 1) вЙ§ 2 ^ (1 + max tвВБ.height tвВВ.height) := by\n              calc\n                1 + 2 ^ (tвВБ.height + 1) вЙ§ 2 ^ (tвВБ.height + 1) + 2 ^ (tвВБ.height + 1) := by\n                  have hвВБвВВ : 1 вЙ§ 2 ^ (tвВ