```lean
namespace BST1

def flatcat : (t : Tree a) вЖТ (xs: List a) вЖТ List a
| .null, xs => xs
| .node l x r, xs => flatcat l (x :: flatcat r xs)

def Tree.flattenвВБ (t : Tree a) : List a :=
 flatcat t []

theorem flatten_eq_helper_accum (t : Tree a) (xs: List a)
  : t.flatten ++ xs = flatcat t xs := by
  induction t generalizing xs with
  | null => rfl
  | node l x r ihl ihr =>
    rw [flatcat, вЖРihr]
    rw [вЖРihl (x :: (r.flatten ++ xs))]
    rw [List.append_cons]
    rw [вЖР List.append_assoc]
    rw [Tree.flatten]

example (t: Tree a) : t.flatten = t.flattenвВБ := by
  induction t with
  | null => exact rfl
  | node l x r ihl ihr =>
    rw [Tree.flattenвВБ]
    simp [вЖР flatten_eq_helper_accum]

end BST1

