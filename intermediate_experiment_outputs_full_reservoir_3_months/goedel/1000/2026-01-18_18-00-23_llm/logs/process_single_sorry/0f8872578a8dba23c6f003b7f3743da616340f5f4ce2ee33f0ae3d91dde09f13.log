/-!
# Filters
-/



section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  obtain ⟨t, ht, ht'⟩ := hs
  refine' ⟨t, ht, _⟩
  simp_all [Filter.map_le_iff]
  <;> aesop


/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : F.map (t ∘ s) ≤ G.map t := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        exact Filter.map_mono hs
  calc
    F.map (t ∘ s) ≤ G.map t := h1
    _ ≤ H := ht
    _ = H := le_refl H

  
example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the fact that the composition of functions that tend to certain limits also tends to the composition of those limits.
    have h₁ : Tendsto (g ∘ f) (𝓝 0) atTop := by
      -- Use the composition of the limits to show that the composition of the functions tends to the composition of the limits.
      apply Tendsto_comp
      · -- Show that f tends to π along the neighborhood filter of 0.
        exact hf
      · -- Show that g tends to infinity along the neighborhood filter of π.
        exact hg
    exact h₁
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    -- Use the fact that the composition of functions that tend to certain limits also tends to the composition of those limits.
    have h₁ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
      -- Use the composition of the limits to show that the composition of the functions tends to the composition of the limits.
      apply Tendsto_comp
      · -- Show that a tends to -1 along the filter atTop.
        exact ha
      · -- Show that φ tends to i along the neighborhood filter of -1.
        exact hφ
    exact h₁
  exact h

