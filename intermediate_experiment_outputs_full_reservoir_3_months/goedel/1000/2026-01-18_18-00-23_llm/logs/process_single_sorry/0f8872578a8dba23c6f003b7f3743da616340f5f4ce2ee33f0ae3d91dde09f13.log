/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  simp_all [Tendsto]
  <;>
    (try compositionality)
  <;>
    (try
      exact Filter.map_mono (by tauto))
  <;>
    (try
      exact le_trans (Filter.map_map s t) (by tauto))
  <;>
    (try simp_all [map_le_map_iff])
  <;>
    (try tauto)
  <;>
    (try
      dsimp_all [Tendsto]
      <;>
      tauto)

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h1 : Tendsto (g ∘ f) (𝓝 0) atTop := by
    have h2 : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h3 : Tendsto g (𝓝 Real.pi) atTop := hg
    have h4 : Tendsto (g ∘ f) (𝓝 0) atTop := by
      simp_all [Tendsto]
      <;>
      (try compositionality)
      <;>
      (try
        exact Filter.map_mono (by tauto))
      <;>
      (try
        exact le_trans (Filter.map_map f g) (by tauto))
      <;>
      (try simp_all [map_le_map_iff])
      <;>
      (try tauto)
    exact h4
  exact h1

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h1 : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    have h2 : Tendsto a atTop (𝓝 (-1 : ℝ)) := ha
    have h3 : Tendsto φ (𝓝 (-1 : ℝ)) (𝓝 (Complex.I)) := hφ
    have h4 : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
      simp_all [Tendsto]
      <;>
      (try compositionality)
      <;>
      (try
        exact Filter.map_mono (by tauto))
      <;>
      (try
        exact le_trans (Filter.map_map a φ) (by tauto))
      <;>
      (try simp_all [map_le_map_iff])
      <;>
      (try tauto)
    exact h4
  exact h1

