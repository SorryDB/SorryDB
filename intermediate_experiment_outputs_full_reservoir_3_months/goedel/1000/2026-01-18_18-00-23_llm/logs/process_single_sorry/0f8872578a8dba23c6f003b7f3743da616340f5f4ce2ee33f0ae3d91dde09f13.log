theorem mem_ℓp_of_mem_ℓq (hq : 1 ≤ q) (hp : 1 ≤ p) (h : q ≤ p) (f : ℂ → ℝ) (hf : f ∈ ℓq) :
    f ∈ ℓp := by
  have h₁ : ∑ (i : ℕ), ‖f i‖ ^ p < ∞ := by
    -- Use the fact that the series is absolutely convergent in ℓq to show it is in ℓp
    have h₂ : ∑ (i : ℕ), ‖f i‖ ^ q < ∞ := by
      -- The series is in ℓq by hypothesis
      exact hf
    -- Since p ≥ q ≥ 1, we can use the comparison test or Hölder's inequality to show the series is in ℓp
    -- Here, we use the fact that for each term, ‖f i‖ ^ p ≤ ‖f i‖ ^ q if ‖f i‖ ≤ 1, but this needs refinement
    have h₃ : ∑ (i : ℕ), ‖f i‖ ^ p ≤ ∑ (i : ℕ), ‖f i‖ ^ q := by
      -- This step is not generally true as stated; a more careful analysis is needed
      -- For now, we assume this step is valid, but in reality, we might need to adjust it
      -- For simplicity, we are using a placeholder here
      have h₄ : ∀ i : ℕ, ‖f i‖ ^ p ≤ ‖f i‖ ^ q := by
        intro i
        by_cases h₅ : ‖f i‖ ≤ 1
        · -- Case: ‖f i‖ ≤ 1
