        simp_all
      -- Use the fact that the measure of each F n is 0
      have h₂ : ∀ n : ℕ, (if (3.14 : ℝ) ∈ (F n : Set ℝ) then (1 : ℝ≥0∞) else 0) = 0 := by
        intro n
        simp [h₁ n]
      have h₃ : (if (3.14 : ℝ) ∈ (⋃ n : ℕ, (F n : Set ℝ)) then (1 : ℝ≥0∞) else 0) = 0 := by
        simp [h]
      simp_all [h₂, h₃]
      <;>
      (try { linarith }) <;>
      (try { aesop })
    })

def μL : Measure ℝ := by volume_tac

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h₀ : μD {x : ℝ | x < 0} = 0 := by
    by_cases h : (3.14 : ℝ) ∈ ({x : ℝ | x < 0} : Set ℝ)
    · exfalso
      norm_num at h ⊢
      <;> linarith [Real.pi_gt_three]
    · simp_all [μD]
      <;> aesop
  have h₁ : μD (∅ : Set ℝ) = 0 := by simp [μD]
  -- Since the measure of both sets is zero, they are equal almost everywhere.
  exact by
    have h₂ : μD {x : ℝ | x < 0} = μD (∅ : Set ℝ) := by rw [h₀, h₁]
    filter_upwards [self_mem_ae_restrict] with x hx using by
      simp_all [μD]
      <;>
      (try { aesop }) <;>
      (try { norm_num at * }) <;>
      (try { linarith [Real.pi_gt_three] })

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    exact h1.trans h2
  exact h3

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    exact h1.trans h2
  exact h3

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    exact h1.trans h2
  exact h3

end Lp

/-!
## ℓp-spaces
-/



section ℓp

open Memℓp ENNReal

variable (p : ℝ≥0∞)
variable (ι : Type*) (E : ι → Type*) [(i : ι) → NormedAddCommGroup (E i)]
variable (v : Π (i : ι), E i)

#check PreLp (α := ι) E
#check Memℓp v p
#check lp E p

def ONE : PreLp (fun n : ℕ ↦ ℝ) := (fun _ : ℕ ↦ 1)

def GEO : PreLp (fun n : ℕ ↦ ℝ) := (fun n : ℕ ↦ (1 / n))

example : Memℓp ONE ∞ := by
  dsimp only [ONE]
  simp [memℓp_def]
  <;>
  simp_all [norm_num]
  <;>
  norm_num
  <;>
  apply ENNReal.ofReal_le_ofReal.mpr
  <;>
  simp_all [norm_num]
  <;>
  norm_num
  <;>
  apply ENNReal.ofReal_le_ofReal.mpr
  <;>
  simp_all [norm_num]
  <;>
  norm_num

lemma GEO_mem_ℓ2 : Memℓp GEO 2 := by
  dsimp only [GEO]
  simp [memℓp_def, ENNReal.ofReal_eq_zero]
  <;>
  norm_num
  <;>
  simp_all [summable_nat_add_iff]
  <;>
  norm_num
  <;>
  apply Summable.of_nonneg_of_le (fun n => by positivity) (fun n => by
    cases n with
    | zero => simp
    | succ n =>
      simp_all [Nat.cast_add_one_ne_zero]
      <;>
      norm_num
      <;>
      apply le_of_sub_nonneg
      <;>
      field_simp
      <;>
      ring_nf
      <;>
      positivity)
  <;>
  summable_nat_pow_inv

def GEO' : lp (fun _ : ℕ ↦ ℝ) 2 := ⟨GEO, GEO_mem_ℓ2⟩

