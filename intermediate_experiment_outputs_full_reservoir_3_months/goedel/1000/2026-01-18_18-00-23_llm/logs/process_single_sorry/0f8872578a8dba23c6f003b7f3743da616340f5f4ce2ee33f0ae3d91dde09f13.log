example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x | p x ∧ q x} ∈ 𝓝 x := by
    have h1 : {x | p x} ∈ 𝓝 x := hT
    have h2 : {x | q x} ∈ 𝓝 x := hS
    have h3 : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by ext <;> simp [and_comm]
    rw [h3]
    exact Filter.inter_mem h1 h2
  have h2 : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h1 : {x | p' x} ∈ 𝓝 x := hT'
    have h2 : {x | q' x} ∈ 𝓝 x := hS'
    have h3 : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by ext <;> simp [and_comm]
    rw [h3]
    exact Filter.inter_mem h1 h2
  have h3 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext x
    simp [or_iff_not_imp_left, not_and, not_or]
    <;> tauto
  rw [h3]
  exact Filter.union_mem h1 h2

