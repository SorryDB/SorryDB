example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x | p x} ∈ 𝓝 x := hT
  have h₂ : {x | q x} ∈ 𝓝 x := hS
  have h₃ : {x | p' x} ∈ 𝓝 x := hT'
  have h₄ : {x | q' x} ∈ 𝓝 x := hS'
  -- We use the fact that the intersection of two sets in the neighborhood filter is also in the neighborhood filter.
  -- Since {x | p x} and {x | q x} are in 𝓝 x, their intersection is in 𝓝 x.
  -- Similarly, {x | p' x} and {x | q' x} are in 𝓝 x, so their intersection is in 𝓝 x.
  -- The union of these two intersections is in 𝓝 x.
  filter_upwards [h₁, h₂, h₃, h₄] with y hy₁ hy₂ hy₃ hy₄
  -- For each y in the intersection of all four sets, we need to show that either (p y ∧ q y) or (p' y ∧ q' y) holds.
  -- Since y is in {x | p x} and {x | q x}, p y and q y hold. So (p y ∧ q y) is true.
  -- Alternatively, since y is in {x | p' x} and {x | q' x}, p' y and q' y hold. So (p' y ∧ q' y) is true.
  by
    by_cases h₅ : p y <;> by_cases h₆ : p' y <;> by_cases h₇ : q y <;> by_cases h₈ : q' y <;>
