structure FormalCircuit (R : Type*) (I : Type*) (O : Type*) [DecidableEq R] [AddCommMonoid R] [Zero R]
  where
  main : I → (O)
  localLength : ℕ
  localLength_eq : localLength = localLength
  output : ℕ → O
  output_eq : ∀ (i : ℕ), output i = main (default : I) i
  subcircuitsConsistent : (main (default : I) (0 : ℕ) : O) = 0
  Assumptions : I → Prop
  Spec : I → O → Prop
  soundness : ∀ (input : I), Assumptions input → Spec input (main input)

def BinSubInput (n : ℕ) := ProvableVector (fields n) 2

@[reducible]
def IsZero (v : F p) : Bool := (v.val = 0)

@[reducible]
def IsBool (v : F p) : Bool := (v.val < 2)

def toFp (b : Bool) : F p := if b then 1 else 0

def bitsOf (v : F p) : List Bool := by sorry

def fieldFromBits (bits : Vector Bool n) : F p := by sorry

def fieldToBits (v : F p) : Vector Bool n := by sorry

def main (n : ℕ) [NeZero n] (inp : BinSubInput n (Expression (F p))) := by sorry

def circuit (n : ℕ) [hn : NeZero n] [NonEmptyProvableType (fields n)] (hnout : 2^(n+1) < p) :
    FormalCircuit (F p) (BinSubInput n) (fields n) where
  main input := main n input
  localLength _ := n
  localLength_eq := by sorry
  output _ i := varFromOffset (fields n) i
  output_eq := by sorry
  subcircuitsConsistent := by sorry
  Assumptions input := ∀ j i (hj : j < 2) (hi : i < n), IsBool input[j][i]
  Spec input output := (∀ j i (hj : j < 2) (hi : i < n), IsBool input[j][i]) ∧ (∀ i (hi : i < n), IsBool output[i]) ∧ ∃ aux : F p, IsBool aux ∧ fieldFromBits input[0] + (2^n : F p) - fieldFromBits input[1] = fieldFromBits output + aux * (2^n : F p)
  soundness := by
    intro input h_assumptions
    have h₁ : ∀ j i (hj : j < 2) (hi : i < n), IsBool input[j][i] := h_assumptions
    have h₂ : (∀ j i (hj : j < 2) (hi : i < n), IsBool input[j][i]) := h₁
    have h₃ : (∀ i (hi : i < n), IsBool (main n input)[i]) := by sorry
    have h₄ : ∃ aux : F p, IsBool aux ∧ fieldFromBits input[0] + (2^n : F p) - fieldFromBits input[1] = fieldFromBits (main n input) + aux * (2^n : F p) := by sorry
    exact ⟨h₂, h₃, h₄⟩
