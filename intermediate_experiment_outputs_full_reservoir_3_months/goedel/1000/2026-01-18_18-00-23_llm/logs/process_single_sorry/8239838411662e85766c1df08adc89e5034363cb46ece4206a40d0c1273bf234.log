def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx ↦ by
    have h : f x = 0 := by
      -- Since x is in the kernel of f, f(x) = 0 by definition of the kernel.
