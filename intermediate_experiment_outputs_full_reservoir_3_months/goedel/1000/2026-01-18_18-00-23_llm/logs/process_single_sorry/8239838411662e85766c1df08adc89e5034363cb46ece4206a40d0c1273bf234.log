      _ = g (g.symm x) := by
        simp [RingEquiv.apply_symm_apply]
      _ = x := by
        simp [RingEquiv.apply_symm_apply]
  map_add' := by
    intro x y
    simp [RingEquiv.map_add, RingHom.map_add]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul, RingHom.map_mul]

end homomorphisms

