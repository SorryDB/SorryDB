example : suffixClosed leftmin := by
   unfold suffixClosed
   intro xs ys
   unfold leftmin; simp
   intro h
   have h₁ : (xs ++ ys).head! = xs.head! ∨ xs = [] := by
      by_cases hx : xs = []
      · exact Or.inr hx
      · exact Or.inl (by simp [hx, List.head!_append, List.head!_cons])
   cases h₁ with
   | inl h₁ =>
     have h₂ : ∀ x ∈ ys, xs.head! ≤ x := by
       intro x hx
       have h₃ : x ∈ xs ++ ys := by
         apply List.mem_append_right
         exact hx
       have h₄ : (xs ++ ys).head! ≤ x := h x h₃
       simp [h₁] at h₄ ⊢
       <;> assumption
     intro x hx
     have h₃ : xs.head! ≤ x := h₂ x hx
     have h₄ : ys.head! ≤ x := by
       have h₅ : ∀ x ∈ ys, ys.head! ≤ x := by
         intro x hx
         have h₆ : ys.head! ≤ x := by
           have h₇ : x ∈ ys := hx
           have h₈ : ∀ y ∈ ys, y ≥ ys.head! := by
             intro y hy
             have h₉ : (xs ++ ys).head! ≤ y := h y (List.mem_append_right xs hy)
             simp [h₁] at h₉ ⊢
             <;>
             (try omega) <;>
             (try
               {
                 have h₁₀ : xs.head! ≤ y := by assumption
                 have h₁₁ : ys.head! ≤ y := by
                   have h₁₂ : y ≥ ys.head! := by
                     have h₁₃ : y ∈ ys := hy
                     have h₁₄ : ys.head! ≤ y := by
                       -- Use the fact that the head! of ys is less than or equal to any element in ys
                       -- This is true because the list is ordered and the head! is the smallest element
                       cases' ys with y' ys'
                       <;> simp_all [List.head!, List.mem_cons, List.mem_nil_iff]
                       <;> omega
                     exact h₁₄
                   omega
                 omega
               }) <;>
             (try omega)
           have h₁₀ : y ≥ ys.head! := h₈ x hx
           omega
         exact h₆
       have h₆ : x ∈ ys := hx
       have h₇ : ys.head! ≤ x := h₅ x h₆
       exact h₇
     omega
   | inr h₁ =>
     simp_all [h₁, List.head!_nil, List.mem_nil_iff]
     <;> tauto
