  have h₁ : n % 17 = 5 := by
    have h₂ : (5 * n) % 17 = 8 := h₀
    have h₃ : (5 * (n % 17)) % 17 = 8 := by
      have h₄ : (5 * n) % 17 = (5 * (n % 17)) % 17 := by
        simp [Nat.mul_mod, Nat.add_mod]
        <;> omega
      rw [h₄] at h₂
      exact h₂
    -- We now check all possible values of n % 17 to find the one that satisfies (5 * (n % 17)) % 17 = 8
    have h₄ : n % 17 = 5 := by
      have : n % 17 < 17 := Nat.mod_lt n (by decide)
      interval_cases n % 17 <;> norm_num at h₃ ⊢ <;> omega
    exact h₄
  exact h₁
