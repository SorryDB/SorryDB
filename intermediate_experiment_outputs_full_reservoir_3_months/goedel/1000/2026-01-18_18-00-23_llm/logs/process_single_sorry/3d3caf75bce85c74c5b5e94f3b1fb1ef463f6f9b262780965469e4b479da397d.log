    -- Use the lemma to show that the energy difference is negative if the state changes and the local field is non-zero
    have h₉ : biasedEnergyDiff net x i < 0 := biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero h₂ h₃
    linarith
  · -- Prove the backward direction: if biasedUpdateState net x i = x, then biasedEnergyDiff net x i = 0
    intro h
