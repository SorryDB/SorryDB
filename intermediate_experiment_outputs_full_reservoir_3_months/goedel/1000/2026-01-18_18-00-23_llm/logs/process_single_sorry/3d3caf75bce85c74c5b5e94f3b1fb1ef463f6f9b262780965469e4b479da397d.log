lemma biasedEnergy_fixed_point_iff_no_change :
  biasedEnergyDiff net x i = 0 ↔ biasedUpdateState net x i = x := by
  have h₁ : biasedEnergyDiff net x i = 0 ↔ biasedUpdateState net x i = x := by
    constructor
    · -- Prove the forward direction: if biasedEnergyDiff net x i = 0, then biasedUpdateState net x i = x
      intro h
      have h₂ : biasedEnergyDiff net x i = 0 := h
      have h₃ : biasedUpdateState net x i = x := by
        by_contra h₄
        -- If the state changes, then the energy difference is negative
        have h₅ : biasedUpdateState net x i ≠ x := h₄
        have h₆ : biasedLocalField net x i ≠ 0 := by
          by_contra h₇
          have h₈ : biasedLocalField net x i = 0 := by simpa using h₇
          have h₉ : biasedUpdateState net x i = x := by
            have h₁₀ : biasedUpdateState net x i = Function.update x i (if 0 < biasedLocalField net x i then SpinState.up else if biasedLocalField net x i < 0 then SpinState.down else x i) := rfl
            rw [h₁₀]
            simp_all [biasedLocalField, Function.update_same]
            <;>
            (try { contradiction }) <;>
            (try { aesop }) <;>
            (try {
              split_ifs at * <;>
              simp_all [Fin.ext_iff, Ne.symm] <;>
              norm_num <;>
              linarith
            })
          contradiction
        have h₇ : biasedEnergyDiff net x i < 0 := biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero h₅ h₆
        linarith
      exact h₃
    · -- Prove the reverse direction: if biasedUpdateState net x i = x, then biasedEnergyDiff net x i = 0
      intro h
      have h₂ : biasedUpdateState net x i = x := h
      have h₃ : biasedEnergyDiff net x i = 0 := by
        have h₄ : biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
          apply biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField
        rw [h₄]
        have h₅ : (biasedUpdateState net x i i : ℝ) = (x i : ℝ) := by
          have h₆ : biasedUpdateState net x i = x := h₂
          rw [h₆]
          <;> simp [Function.update_same]
        have h₆ : (biasedUpdateState net x i i : ℝ) - (x i : ℝ) = 0 := by linarith
        have h₇ : -((biasedUpdateState net x i i : ℝ) - (x i : ℝ)) * biasedLocalField net x i = 0 := by
          rw [h₆]
          ring
        exact_mod_cast h₇
      exact h₃
  exact h₁
