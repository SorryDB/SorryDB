lemma biasedEnergy_fixed_point_iff_no_change :
  biasedEnergyDiff net x i = 0 ↔ biasedUpdateState net x i = x := by
  constructor
  · -- Prove the forward direction: if biasedEnergyDiff net x i = 0, then biasedUpdateState net x i = x
    intro h
    by_contra h₁
    -- Assume the update changes the state
    have h₂ : biasedUpdateState net x i ≠ x := h₁
    -- If the update changes the state, then the biasedLocalField is not zero
    have h₃ : biasedLocalField net x i ≠ 0 := by
      by_contra h₄
      have h₅ : biasedLocalField net x i = 0 := by simpa using h₄
      have h₆ : biasedUpdateState net x i = x := by
        -- If the biasedLocalField is zero, then the state doesn't change
        have h₇ : (if 0 < biasedLocalField net x i then SpinState.up else if biasedLocalField net x i < 0 then SpinState.down else x i) = x i := by
          simp [h₅]
        have h₈ : biasedUpdateState net x i = Function.update x i (if 0 < biasedLocalField net x i then SpinState.up else if biasedLocalField net x i < 0 then SpinState.down else x i) := rfl
        rw [h₈]
        simp [h₇]
        <;>
        (try cases x i <;> simp_all [Fin.val_zero, Fin.val_succ, Function.update_same, Function.update_noteq]) <;>
        (try aesop)
