lemma lemma1 {m n : ℕ} (hmn : m ≤ n) (hm : all_colorings_are_good m) :
    all_colorings_are_good n := by
  have h_main : 3 ≤ n := by
    have h3m : 3 ≤ m := hm.1
    have hmn' : m ≤ n := hmn
    linarith
  
  have h_colorings : ∀ color : Set.Icc 1 n → Fin 2, coloring_is_good color := by
    intro color
    have hm' : ∀ (color : Set.Icc 1 m → Fin 2), coloring_is_good color := hm.2
    -- Define a coloring for m points based on the coloring for n points
    let c' : Set.Icc 1 m → Fin 2 :=
      fun x ↦ color ⟨x.val, by
        rw [Set.mem_Icc]
        exact ⟨x.prop.1, x.prop.2.trans hmn⟩⟩
    -- Obtain the same-colored triple for the m-point coloring
    obtain ⟨i, j, hij1, k, hc1, hc2⟩ := hm' c'
    -- Use the triple to construct a triple for the n-point coloring
    refine' ⟨i, j, hij1, k, _, _⟩
    · -- Prove that the coloring is the same for i and j
      simpa [c'] using hc1
    · -- Prove that the coloring is the same for i and k
      simpa [c'] using hc2
  exact ⟨h_main, h_colorings⟩
```
