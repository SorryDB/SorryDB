instance : DecidableEq (Fin 2) := inferInstance

@[simp]
lemma Fin.val_zero : (0 : Fin 2) = 0 := rfl

@[simp]
lemma Fin.val_one : (1 : Fin 2) = 1 := rfl

@[simp]
def coloring_of_eight {n : ℕ} : Set.Icc 1 n → Fin 2
| ⟨1, _⟩ => 0
