theorem colorings {n : ℕ} :
    ∃ f : Set.Icc 1 n → Fin 2, ¬coloring_is_good f := by
  have h₁ : n = 0 ∨ 0 < n := by omega
  cases h₁ with
  | inl h₁ =>
    subst_vars
    -- If n = 0, use a trivial coloring
    have h₂ : ∃ f : Set.Icc 1 0 → Fin 2, ¬coloring_is_good f := by
      use fun x => 0
      -- No points, so no good coloring exists
      intro h
      cases h with
      | intro i j => by
        cases i
        <;> cases j
    simpa using h₂
  | inr h₁ =>
    -- If n > 0, we can ignore and use coloring_of_eight
    have h₂ : ∃ f : Set.Icc 1 n → Fin 2, ¬coloring_is_good f := by
      use fun x => 0
      -- Use a constant coloring where all points are the same color
      intro h
      cases h with
      | intro i j => by
        cases i
        <;> cases j
        <;> simp_all [coloring_is_good]
        <;>
          (try omega) <;>
          (try
            {
              aesop
            })
    simpa using h₂
```
