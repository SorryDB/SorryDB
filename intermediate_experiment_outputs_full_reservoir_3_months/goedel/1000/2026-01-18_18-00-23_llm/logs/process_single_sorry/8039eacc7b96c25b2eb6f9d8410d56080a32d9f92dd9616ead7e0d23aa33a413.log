lemma lemma2 :
    ∃ f : Set.Icc 1 8 → Fin 2, ¬coloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
  simp [coloring_of_eight, Fin.ext_iff, Set.mem_Icc, Subtype.mk_lt_mk] at hi1 hi2 hj1 hj2 hij1 hij2 hc1 hc2 ⊢
