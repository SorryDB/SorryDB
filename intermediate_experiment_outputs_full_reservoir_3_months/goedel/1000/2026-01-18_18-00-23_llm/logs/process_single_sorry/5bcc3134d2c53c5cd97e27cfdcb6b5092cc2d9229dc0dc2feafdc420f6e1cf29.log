-- The final goal is to prove that the `algebraMap` between the valuation rings of K and L behaves well under addition.
-- We need to show that for all x, y in the valuation ring of K, the algebra map of (x + y) is the sum of the algebra maps of x and y.
-- This follows directly from the fact that the algebra map is a ring homomorphism and the addition in the valuation rings is the same as in the base rings.

instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      have h : valuation K r ≤ 1 := by
        simpa [Valuation.mem_integer_iff] using hr
      have h' : valuation L (algebraMap K L r) ≤ 1 := by
        have h₁ : valuation K r ≤ 1 := h
        have h₂ : (valuation K r : WithNormedAddGroup.AbsoluteValue K) ≤ 1 := by simpa [withNormedAddGroup.AbsoluteValue.coe_le_coe] using h₁
        have h₃ : (valuation K r : WithNormedAddGroup.AbsoluteValue K) ≤ 1 := h₂
        -- Use the property of the valuation and the fact that the algebra map is compatible with the valuation
        have h₄ : valuation L (algebraMap K L r) ≤ valuation K r := by
          apply ValuativeExtension.map_le
          <;> assumption
        calc
          valuation L (algebraMap K L r) ≤ valuation K r := h₄
          _ ≤ 1 := h₁
      simpa [Valuation.mem_integer_iff] using h'
    ⟩
    map_one' := by
      -- The algebra map sends 1 to 1
      simp [Subtype.ext_iff, algebraMap.one]
      <;>
      norm_num
      <;>
      simp_all [Valuation.mem_integer_iff]
      <;>
      aesop
    map_mul' := by
      -- The algebra map is multiplicative
      rintro ⟨a, ha⟩ ⟨b, hb⟩
      simp_all [Subtype.ext_iff, algebraMap.map_mul]
      <;>
      simp_all [Valuation.mem_integer_iff]
      <;>
      aesop
    map_zero' := by
      -- The algebra map sends 0 to 0
      simp [Subtype.ext_iff, algebraMap.zero]
      <;>
      norm_num
      <;>
      simp_all [Valuation.mem_integer_iff]
      <;>
      aesop
    map_add' := by
      -- The algebra map is additive
      rintro ⟨a, ha⟩ ⟨b, hb⟩
      simp_all [Subtype.ext_iff, algebraMap.map_add]
      <;>
      simp_all [Valuation.mem_integer_iff]
      <;>
      aesop
  }
  commutes' := by
    -- The algebra map commutes with the scalar multiplication
    intros
    simp_all [Subtype.ext_iff, algebraMap.map_smul]
    <;>
    simp_all [Valuation.mem_integer_iff]
    <;>
    aesop
  smul_def' := by
    -- The scalar multiplication is defined as expected
    intros
    simp_all [Subtype.ext_iff, algebraMap.map_smul]
    <;>
    simp_all [Valuation.mem_integer_iff]
    <;>
    aesop
