        have h₂ : valuation K r.1 ≤ 0 := by
          -- Since r ∈ 𝒪[K], valuation K r.1 ≤ 0.
          have h₃ : r.1 ∈ (valuation K).integer := r.prop
          rw [Set.mem_setOf_eq] at h₃
