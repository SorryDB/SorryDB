theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · intro h
    have h1 : Nonempty (U ≃ V) := ⟨h⟩
    obtain ⟨e⟩ := h1
    refine' ⟨e, e.symm, _, _⟩
    · ext x
      simp [Equiv.apply_symm_apply]
    · ext x
      simp [Equiv.symm_apply_apply]
  · rintro ⟨f, g, h1, h2⟩
    exact ⟨Equiv.ofBijective f ⟨fun a b h => by
      have h3 := congr_fun h2 a
      have h4 := congr_fun h2 b
      simp at h3 h4
      simp_all, fun b => ⟨g b, by
      have h3 := congr_fun h1 b
      simp at h3
      simp_all⟩⟩⟩
