theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  apply Iff.intro
  · -- (⇒) U ∼ V implies existence of inverses
    intro h
    -- Since U ∼ V, there exists a bijection f : U → V
    rcases h with ⟨f, hf⟩
    -- The bijection f has an inverse function g : V → U
    have h₁ : ∃ (g : V → U), Function.LeftInverse g f ∧ Function.RightInverse g f := by
      exact ⟨f.symm, by
        -- Show that f.symm is a left inverse of f
        have h₂ : Function.LeftInverse f.symm f := by
          intro u
          simp [Equiv.apply_symm_apply]
        exact h₂, by
        -- Show that f.symm is a right inverse of f
        have h₂ : Function.RightInverse f.symm f := by
          intro v
          simp [Equiv.symm_apply_apply]
        exact h₂⟩
    -- Obtain the inverse function g
    rcases h₁ with ⟨g, hg_left, hg_right⟩
    -- Verify that f ∘ g = id and g ∘ f = id
    refine' ⟨f, g, _, _⟩
    · -- Prove f ∘ g = id
      funext v
      have h₂ : f (g v) = v := by
        apply hg_right
      simpa using h₂
    · -- Prove g ∘ f = id
      funext u
      have h₂ : g (f u) = u := by
        apply hg_left
      simpa using h₂
  · -- (⇐) Existence of inverses implies U ∼ V
    intro h
    -- Obtain the functions f and g with the given properties
    rcases h with ⟨f, g, hf, hg⟩
    -- Show that f is bijective
    have h₁ : Function.Bijective f := by
      constructor
      · -- Injectivity of f
        intro a b h₂
        have h₃ : g (f a) = g (f b) := by rw [h₂]
        have h₄ : g (f a) = a := by
          have h₅ : (g ∘ f) a = a := by
            rw [hg]
            <;> simp
          exact h₅
        have h₅ : g (f b) = b := by
          have h₆ : (g ∘ f) b = b := by
            rw [hg]
            <;> simp
          exact h₆
        rw [h₄, h₅] at h₃
        exact h₃
      · -- Surjectivity of f
        intro v
        have h₂ : f (g v) = v := by
          have h₃ : (f ∘ g) v = v := by
            rw [hf]
            <;> simp
          exact h₃
        exact ⟨g v, h₂⟩
    -- Construct the equivalence using the bijective function f
    refine' ⟨f, _⟩
    exact h₁
