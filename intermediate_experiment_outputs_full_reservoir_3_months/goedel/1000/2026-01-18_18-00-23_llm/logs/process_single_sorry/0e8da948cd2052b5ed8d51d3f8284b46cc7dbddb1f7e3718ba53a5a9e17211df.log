      have h₃ : g (f b) = b := by
        have h₄ : (g ∘ f) b = b := by
          have h₅ : (g ∘ f) b = b := by
            rw [hgf]
            <;> simp
          exact h₅
        simpa using h₄
      rw [h₂] at h₁
      rw [h₃] at h₁
      exact h₁
    -- Show that f is surjective
    have hf_surj : Function.Surjective f := by
      intro v
      use g v
      have h₁ : (f ∘ g) v = v := by
        have h₂ : (f ∘ g) v = v := by
          rw [hfg]
          <;> simp
        exact h₂
