theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Forward direction: If U ∼ V, then there exist f and g such that f ∘ g = id and g ∘ f = id
    intro h
    -- Since U ∼ V, there exists a bijection f : U → V
    have h₁ : Nonempty (U ≃ V) := h
    -- Extract the bijection f
    obtain ⟨f⟩ := h₁
    -- Define g as the inverse of f
    use f, f.symm
    -- Prove that f ∘ g = id and g ∘ f = id
    constructor
    · -- Prove f ∘ g = id
      ext x
      simp [Equiv.symm_apply_apply]
    · -- Prove g ∘ f = id
      ext x
      simp [Equiv.apply_symm_apply]
  · -- Backward direction: If there exist f and g such that f ∘ g = id and g ∘ f = id, then U ∼ V
    intro h
    -- Extract f and g from the hypothesis
    obtain ⟨f, g, h₁, h₂⟩ := h
    -- Show that f is a bijection with inverse g
    have h₃ : U ≃ V :=
      {
        toFun := f
        invFun := g
        left_inv := by
          -- Prove that g ∘ f = id
          funext x
          have h₄ : (g ∘ f) x = x := by
            have h₅ : (g ∘ f) x = x := by
              have h₆ : (g ∘ f) = id := h₂
              rw [h₆]
              <;> simp
            exact h₅
          exact h₄
        right_inv := by
          -- Prove that f ∘ g = id
          funext x
          have h₄ : (f ∘ g) x = x := by
            have h₅ : (f ∘ g) x = x := by
              have h₆ : (f ∘ g) = id := h₁
              rw [h₆]
              <;> simp
            exact h₅
          exact h₄
      }
    -- Conclude that U ∼ V
    exact ⟨h₃⟩
