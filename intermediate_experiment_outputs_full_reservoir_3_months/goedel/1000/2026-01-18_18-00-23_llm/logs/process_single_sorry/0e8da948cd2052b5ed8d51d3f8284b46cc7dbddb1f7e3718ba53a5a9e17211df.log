lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: if U ∼ V, then there exist f and g with f ∘ g = id and g ∘ f = id
    intro h
    have h₁ : Nonempty (U ≃ V) := h
    -- Extract the equivalence from the nonempty type
    obtain ⟨e⟩ := h₁
    -- Use the forward and backward functions of the equivalence
    refine' ⟨e, e.symm, _⟩
    -- Prove that e ∘ e.symm = id and e.symm ∘ e = id
    constructor <;>
    (try simp [e.symm_apply_apply, e.apply_symm_apply]) <;>
    (try ext x <;> simp [e.symm_apply_apply, e.apply_symm_apply]) <;>
    (try aesop)
  · -- Prove the reverse direction: if there exist f and g with f ∘ g = id and g ∘ f = id, then U ∼ V
    rintro ⟨f, g, hfg, hgf⟩
    -- Construct the equivalence using f and g
    refine' ⟨f, g, funext hfg, funext hgf⟩
