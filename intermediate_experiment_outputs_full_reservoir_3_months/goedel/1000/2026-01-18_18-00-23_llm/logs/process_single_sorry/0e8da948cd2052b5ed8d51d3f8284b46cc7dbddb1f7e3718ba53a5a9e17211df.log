lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: U ∼ V implies the existence of f and g
    intro h
    have h₁ : Nonempty (U ≃ V) := by
      exact h
    cases' h₁ with f
    refine' ⟨f, f.symm, _, _⟩
    · -- Prove f ∘ f.symm = id
      funext x
      simp [Equiv.apply_symm_apply]
    · -- Prove f.symm ∘ f = id
      funext x
      simp [Equiv.symm_apply_apply]
  · -- Prove the reverse direction: the existence of f and g implies U ∼ V
    rintro ⟨f, g, hfg, hgf⟩
    -- Construct an equivalence using the given functions f and g
    have h₁ : U ≃ V := {
      toFun := f
      invFun := g
      left_inv := by
        funext x
        have h₂ := congr_fun hgf x
        simp at h₂ ⊢
        <;> simpa using h₂
      right_inv := by
        funext x
        have h₂ := congr_fun hfg x
        simp at h₂ ⊢
        <;> simpa using h₂
    }
    exact ⟨h₁⟩
