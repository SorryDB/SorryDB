theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h₁ : denum {n : Int | even n} := by
    have h₂ : {n : Int | even n} = Set.range (fun (n : Int) => 2 * n) := by
      apply Set.Subset.antisymm
      · -- Prove that {n : Int | even n} ⊆ Set.range (fun (n : Int) => 2 * n)
        intro x hx
        rw [Set.mem_setOf_eq] at hx
        rw [Set.mem_range]
        -- Since x is even, there exists an integer k such that x = 2 * k
        have h₃ : ∃ (k : Int), x = 2 * k := by
          rw [Int.even_iff] at hx
          exact ⟨x / 2, by
            have h₄ : x % 2 = 0 := hx
            have h₅ : x = 2 * (x / 2) := by
              have h₆ := Int.emod_add_ediv x 2
              omega
            exact h₅
          ⟩
        obtain ⟨k, hk⟩ := h₃
        exact ⟨k, by simp [hk]⟩
      · -- Prove that Set.range (fun (n : Int) => 2 * n) ⊆ {n : Int | even n}
        intro x hx
        rw [Set.mem_range] at hx
        rw [Set.mem_setOf_eq]
        -- If x is in the range of the function, then x = 2 * k for some integer k, hence x is even
        obtain ⟨k, rfl⟩ := hx
        rw [Int.even_iff]
        simp [Int.mul_emod]
    rw [h₂]
    -- The set {n : Int | even n} is the range of the function (fun (n : Int) => 2 * n)
    -- Since the integers are denumerable, the range of this function is also denumerable
    exact denumerable_range_of_injective (fun a b h => by
      simp_all [mul_left_inj]
      <;> omega)
  exact h₁
