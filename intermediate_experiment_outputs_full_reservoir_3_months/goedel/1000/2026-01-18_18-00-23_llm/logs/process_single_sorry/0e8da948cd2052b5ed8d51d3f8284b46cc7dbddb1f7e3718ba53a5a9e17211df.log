lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  have h_forward : U ∼ V → (∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id) := by
    intro h
    obtain ⟨e⟩ := h
    refine' ⟨e, e.symm, _, _⟩
    · -- Prove that e ∘ e.symm = id
      ext x
      simp [e.symm_apply_apply]
    · -- Prove that e.symm ∘ e = id
      ext x
      simp [e.apply_symm_apply]
  
  have h_backward : (∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id) → U ∼ V := by
    intro h
    obtain ⟨f, g, h₁, h₂⟩ := h
    -- We use the fact that f and g are inverses to construct an equivalence.
    have h₃ : Function.Bijective f := by
      -- Prove that f is bijective.
      constructor
      · -- Prove that f is injective.
        intro a b h₄
        have h₅ : g (f a) = g (f b) := by rw [h₄]
        have h₆ : g (f a) = a := by
          have h₇ : g ∘ f = id := h₂
          have h₈ : (g ∘ f) a = a := by
            rw [h₇]
            <;> simp
          simpa [Function.comp_apply] using h₈
        have h₉ : g (f b) = b := by
          have h₁₀ : g ∘ f = id := h₂
          have h₁₁ : (g ∘ f) b = b := by
            rw [h₁₀]
            <;> simp
          simpa [Function.comp_apply] using h₁₁
        rw [h₆] at h₅
        rw [h₉] at h₅
        exact h₅
      · -- Prove that f is surjective.
        intro b
        have h₅ : f (g b) = b := by
          have h₆ : f ∘ g = id := h₁
          have h₇ : (f ∘ g) b = b := by
            rw [h₆]
            <;> simp
          simpa [Function.comp_apply] using h₇
        exact ⟨g b, h₅⟩
    -- Use the bijectivity of f to construct an equivalence.
    have h₄ : U ≃ V := Equiv.ofBijective f h₃
    exact ⟨h₄⟩
  
  have h_final : U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
    constructor
    · -- Prove the forward direction: U ∼ V → ∃ f g, f ∘ g = id ∧ g ∘ f = id
      intro h
      exact h_forward h
    · -- Prove the backward direction: (∃ f g, f ∘ g = id ∧ g ∘ f = id) → U ∼ V
      intro h
      exact h_backward h
  
  exact h_final
