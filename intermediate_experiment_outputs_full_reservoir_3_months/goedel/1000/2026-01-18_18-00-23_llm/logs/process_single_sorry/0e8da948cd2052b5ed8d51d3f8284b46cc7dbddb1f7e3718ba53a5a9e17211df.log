  have h_forward : U ∼ V → (∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id) := by sorry
  have h_backward : (∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id) → U ∼ V := by sorry
  exact ⟨h_forward, h_backward⟩
