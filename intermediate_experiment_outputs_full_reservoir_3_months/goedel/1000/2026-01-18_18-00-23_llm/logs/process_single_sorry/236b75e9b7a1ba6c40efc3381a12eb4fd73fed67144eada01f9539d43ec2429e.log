    intro c x hx
    have h1 : x ∈ I := hx.1
    have h2 : x ∈ J := hx.2
    have h3 : c • x ∈ I := I.smul_mem c h1
    have h4 : c • x ∈ J := J.smul_mem c h2
    exact ⟨h3, h4⟩
