  simp

variable {T : Type*} [CommRing T]

def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    rw [← map_one f]
    simp [RingHom.map_one]
  map_mul' := by
    intro x y
    rw [← map_mul f x y]
    simp [RingHom.map_mul]
  map_zero' := by
    rw [← map_zero f]
    simp [RingHom.map_zero]
  map_add' := by
    intro x y
    rw [← map_add f x y]
    simp [RingHom.map_add]

def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Equiv.apply_symm_apply]
  right_inv := by
    intro x
    simp [Equiv.apply_symm_apply]
  map_add' := by
    intro x y
    simp [RingHom.map_add]
  map_mul' := by
    intro x y
    simp [RingHom.map_mul]

end homomorphisms

variable {R} [CommRing R]

example (I : Ideal R) (x y : R) (hx : x ∈ I) : y * x + x * y - 0 ∈ I := by
  have h1 : y * x + x * y ∈ I := by
    have h2 : y * x ∈ I := by
      -- Since I is an ideal, it is closed under multiplication by any element of the ring.
      -- Specifically, for any r ∈ R and a ∈ I, r * a ∈ I.
      -- Here, y ∈ R and x ∈ I, so y * x ∈ I.
      apply Ideal.mul_mem_right
      exact hx
    have h3 : x * y ∈ I := by
      -- Similarly, x ∈ I and y ∈ R, so x * y ∈ I.
      -- However, we need to adjust for the fact that the ideal is two-sided.
      -- In a commutative ring, left and right ideals coincide, so we can use either.
      -- Here, we use the fact that x ∈ I implies x * y ∈ I because I is closed under multiplication by any element of the ring.
      have h4 : x * y = y * x := by ring
      rw [h4]
      apply Ideal.mul_mem_right
      exact hx
    -- Since I is closed under addition, y * x + x * y ∈ I.
    apply Ideal.add_mem
    · exact h2
    · exact h3
  -- Since I is closed under subtraction, y * x + x * y - 0 ∈ I.
  have h5 : y * x + x * y - 0 ∈ I := by
    have h6 : y * x + x * y - 0 = y * x + x * y := by simp
    rw [h6]
    exact h1
  exact h5

example {S} [CommRing S] (f : R →+* S) (x : R) : x ∈ ker f ↔ f x = 0 := by
  rw [mem_ker]

def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
