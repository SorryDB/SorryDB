lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  have h1 : valuation L (e x) = valuation L x := by
    have h2 : valuation L ∘ (e : L → L) = valuation L := by
      ext x
      rw [← (e.symm	ev := (e : L ≃+* L) : L → L)]
      <;> simp [e.symm_apply_apply, e.map_mul, e.map_one]
      <;> rfl
    simp [h2]
  exact h1

