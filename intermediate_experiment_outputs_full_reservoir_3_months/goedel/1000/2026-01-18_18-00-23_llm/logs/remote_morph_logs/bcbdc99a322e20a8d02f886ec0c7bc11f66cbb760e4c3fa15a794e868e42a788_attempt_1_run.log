theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  simp_all [maxStrength_precond, maxStrength_postcond]
  <;>
  (try norm_num) <;>
  (try
    {
      cases nums with
      | nil => contradiction
      | cons a as =>
        simp_all [List.sublists, List.foldr, List.map, List.filter, List.foldl]
        <;>
        norm_num <;>
        aesop
    }
  ) <;>
  (try
    {
      norm_num at *
      <;>
      aesop
    }
  )
  <;>
  (try
    {
      aesop
    }
  )
