lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝕱 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have h₁ : UniformIntegrable (fun i ↦ stoppedValue (hX.toMartingale) (τ i)) 1 μ :=
    (hX.toMartingale).uniformIntegrable_stoppedValue τ hτ n (by
      intro i ω
      exact hτ_le i ω)
  have h₂ : (fun i ↦ stoppedValue (hX.toMartingale) (τ i)) = (fun i ↦ stoppedValue X (τ i)) := by
    funext i
    simp [Submartingale.toMartingale]
    <;>
    (try congr_arg _) <;>
    (try simp_all [hX.toMartingale]) <;>
    (try aesop)
  rw [h₂] at h₁
  exact h₁
