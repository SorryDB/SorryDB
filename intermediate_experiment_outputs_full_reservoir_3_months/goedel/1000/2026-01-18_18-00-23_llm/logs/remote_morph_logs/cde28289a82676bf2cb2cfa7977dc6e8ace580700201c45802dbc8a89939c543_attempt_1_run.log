```lean
lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ}
    (h₁ : Submartingale X 𝓕 μ) : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have h₂ : UniformIntegrable (fun i : ℕ ↦ (X n : Ω → ℝ)) 1 μ := by
    have h₃ : UniformIntegrable (fun (_ : Unit) => (X n : Ω → ℝ)) 1 μ := by
      exact uniformIntegrable_subsingleton (f := fun _ : Unit => (X n : Ω → ℝ)) (le_rfl) (by simp)
        (fun _ => memLp_one_iff_integrable.2 (h₁.integrable n))
    simpa using h₃.comp (fun i : ℕ => ())

  have h₃ : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
    have h₄ : ∀ i : ℕ, IsStoppingTime 𝓕 (τ i) := fun i => hτ i
    have h₅ : ∀ i : ℕ, ∀ ω : Ω, τ i ω ≤ (n : WithTop ι) := fun i ω => hτ_le i ω
    have h₆ : ∀ i : ℕ, stoppedValue X (τ i) =ᵐ[μ] (fun ω : Ω => (X n : ℝ) ω) := by
      intro i
      have h₇ : stoppedValue X (τ i) =ᵐ[μ] (fun ω : Ω => (X n : ℝ) ω) := by
        apply Filter.ae_of_subset (measurableSet_ae) (h₁.ae_eq_condExp_of_isStoppingTime (hτ i) (hτ_le i))
        intro ω
        simp_all [h₅ i ω]
        <;>
        (try simp_all) <;>
        (try aesop) <;>
        (try norm_num) <;>
        (try linarith)
      exact h₇
    have h₇ : UniformIntegrable (fun i : ℕ => (fun ω : Ω => (X n : ℝ) ω : Ω → ℝ)) 1 μ := by
      simpa using h₂
    have h₈ : UniformIntegrable (fun i : ℕ ↦ stoppedValue X (τ i)) 1 μ := by
      refine' h₇.congr_ae _
      filter_upwards [h₆ 0] with ω hω
      simp_all
      <;>
      (try simp_all) <;>
      (try aesop) <;>
      (try norm_num) <;>
      (try linarith)
    simpa using h₈
  exact h₃
``` 

