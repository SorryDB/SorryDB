theorem Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓰 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ ↑n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have hY : ∀ (i : ℕ), stoppedValue X (τ i) =ᵐ[μ] μ[X n | (hτ i).measurableSpace] := by
    intro i
    have h₁ : ∀ (ω : Ω), τ i ω ≤ n := by intro ω; exact hτ_le i ω
    have h₂ : IsStoppingTime 𝓕 (τ i) := hτ i
    have h₃ : stoppedValue X (τ i) =ᵐ[μ] μ[X n | (hτ i).measurableSpace] := by
      apply hX.ae_eq_condExp_of_isStoppingTime
      <;> simp_all [h₂]
      <;> try norm_num
      <;> intros <;> simp_all [h₁]
      <;> try norm_num
      <;> try linarith
    exact h₃
  have hZ : UniformIntegrable (fun (i : ℕ) ↦ μ[X n | (hτ i).measurableSpace]) 1 μ := by
    have h₁ : ∀ (i : ℕ), (μ[X n | (hτ i).measurableSpace] : Ω → ℝ) = μ[X n | (hτ i).measurableSpace] := by simp
    have h₂ : UniformIntegrable (fun (i : ℕ) ↦ (μ[X n | (hτ i).measurableSpace] : Ω → ℝ)) 1 μ := by
      have h₃ : UniformIntegrable (fun (i : ℕ) ↦ (X n : Ω → ℝ)) 1 μ := by
        have h₄ : UniformIntegrable (fun (_ : ℕ) ↦ (X n : Ω → ℝ)) 1 μ := by
          simpa using uniformIntegrable_const (by norm_num : (1 : ℝ≥0∞) ≤ 1)
            (memLp_one_iff_integrable.2 (hX.integrable n))
        exact h₄
      have h₄ : (∀ (i : ℕ), (μ[X n | (hτ i).measurableSpace] : Ω → ℝ) = μ[X n | (hτ i).measurableSpace]) := by simp
      have h₅ : UniformIntegrable (fun (i : ℕ) ↦ μ[X n | (hτ i).measurableSpace] : ℕ → Ω → ℝ) 1 μ := by
        have h₆ : UniformIntegrable (fun (i : ℕ) ↦ μ[X n | (hτ i).measurableSpace] : ℕ → Ω → ℝ) 1 μ := by
          refine (h₃.condExp' (fun i ↦ (hτ i).measurableSpace_le))
            |>.comp (fun i ↦ (i : ℕ))
          <;> simp_all
          <;> try norm_num
          <;> try linarith
        exact h₆
      exact h₅
    simpa using h₂
  have hW : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
    have h₁ : (fun i ↦ stoppedValue X (τ i)) =ᵐ[μ] (fun i ↦ μ[X n | (hτ i).measurableSpace]) := by
      filter_upwards [hY 0] with ω h₂
      simp_all
      <;> try norm_num
      <;> try linarith
    have h₂ : UniformIntegrable (fun i ↦ μ[X n | (hτ i).measurableSpace]) 1 μ := hZ
    exact h₂.of_ae_eq h₁
  exact hW
