```lean
lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {F : Filtration ι mΩ}
    [SigmaFiniteFiltration μ F]
    (hX : Submartingale X F μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime F (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ ↑n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  (hX.boundedAt n).uniformIntegrable_of_subset_measurable (by
    exact Ici_subset_Ici.mpr (by
      have h : ∀ i, (μ[X n | F ↑n] : ℝ) = μ[X n | F ↑n] := by simp
      exact le_refl (n : WithBot ι)))
```
