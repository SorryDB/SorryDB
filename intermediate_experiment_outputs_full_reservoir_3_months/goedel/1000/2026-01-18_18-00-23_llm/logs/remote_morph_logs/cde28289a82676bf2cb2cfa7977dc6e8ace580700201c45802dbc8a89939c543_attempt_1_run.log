lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ ↑n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  let Y : ι → Ω → ℝ := fun _ ↦ fun ω => 0
  have h_main : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
    have h₁ : UniformIntegrable (fun _ : Unit => (X n : Ω → ℝ)) 1 μ := by
      refine' uniformIntegrable_const _ _ _
      have h₂ : Integrable (X n) μ := by
        apply hX.integrable
      exact memLp_one_iff_integrable.mpr (by simpa using h₂)
    have h₂ : UniformIntegrable (fun i : ℕ ↦ (X n : Ω → ℝ)) 1 μ := by
      simpa using h₁.comp (fun _ => ((), ()))
    have h₃ : ∀ (i : ℕ), stoppedValue X (τ i) =ᵐ[μ] μ[X n | (hτ i).measurableSpace] := by
      intro i
      have h₄ : ∀ ω, τ i ω ≤ ↑n := by
        intro ω
        exact hτ_le i ω
      have h₅ : stoppedValue X (τ i) =ᵐ[μ] μ[X n | (hτ i).measurableSpace] := by
        exact (hX.ae_eq_condExp_of_isStoppingTime (hτ i) (hτ_le i)).symm
      exact h₅
    have h₄ : UniformIntegrable (fun i : ℕ ↦ μ[X n | (hτ i).measurableSpace]) 1 μ := by
      have h₅ : UniformIntegrable (fun _ : Unit => (X n : Ω → ℝ)) 1 μ := by
        simpa using h₁
      have h₆ : UniformIntegrable (fun i : ℕ ↦ μ[X n | (hτ i).measurableSpace]) 1 μ := by
        have h₇ : UniformIntegrable (fun i : ℕ ↦ μ[X n | (hτ i).measurableSpace]) 1 μ :=
          h₅.condExp' (fun i => (hτ i).measurableSpace_le)
        exact h₇
      exact h₆
    have h₅ : UniformIntegrable (fun i : ℕ ↦ stoppedValue X (τ i)) 1 μ := by
