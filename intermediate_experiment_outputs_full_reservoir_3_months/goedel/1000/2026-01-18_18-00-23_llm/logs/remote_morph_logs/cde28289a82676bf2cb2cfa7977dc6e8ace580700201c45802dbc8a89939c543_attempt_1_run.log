lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {imgs : ι → Ω → ℝ} {mΩ : MeasurableSpace Ω} {μ : Measure Ω} {ι : Type*} {mι : LinearOrder ι} [Countable ι] {φ : ι → ι} {s : Set ι} (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i)) {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) : UniformIntegrable (fun i => stoppedValue X (τ i)) 1 μ := by
  have h₁ : UniformIntegrable (fun i => stoppedValue X (τ i)) 1 μ := by
    classical
    -- Since we have a submartingale, we can use the fact that the stopped values form a submartingale with respect to the product space
    have h₂ : ∀ i, Iterable (τ i) := by
      intro i
      -- Prove that τ i is iterable
      exact by
        -- Since τ i is a stopping time, it is measurable and thus can be iterated
        have h₃ : IsStoppingTime 𝓕 (τ i) := hτ i
        -- Use the fact that stopping times are measurable to prove iterability
        exact (h₃.measurable).iterable
    -- Use the fact that the stopped values form a submartingale with respect to the product space to prove uniform integrability
    exact by
      -- Use the properties of the submartingale and the stopping times to prove uniform integrability
      have h₃ : ∀ i, IsStoppable (τ i) := by
        intro i
        -- Since τ i is a stopping time, it is stoppable
        have h₄ : IsStoppingTime 𝓕 (τ i) := hτ i
        -- Use the fact that stopping times are stoppable
        exact hold'
          fun ω => by
            -- Show that the stopping time is measurable
            have h₅ : Measurable (τ i) := h₄.measurable
            -- Since τ i is measurable, it is stoppable
            exact ⟨⟨h₄, Set.mem_univ _⟩, by simp_all⟩
      -- Use the properties of the submartingale and the stopping times to prove uniform integrability
      refine' UniformIntegrable.of_bound _
      -- Use the bound to prove uniform integrability
      <;>
      (try simp_all [hf, hf, yielding, ParallelMap.iterable_iff, ParallelMap.get, Fintype.card_fin]) <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try ring_nf) <;>
      (try aesop) <;>
      (try simp_all [hf, hf, yielding, ParallelMap.iterable_iff, ParallelMap.get, Fintype.card_fin]) <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try ring_nf) <;>
      (try aesop)
  -- The final result
  exact h₁
