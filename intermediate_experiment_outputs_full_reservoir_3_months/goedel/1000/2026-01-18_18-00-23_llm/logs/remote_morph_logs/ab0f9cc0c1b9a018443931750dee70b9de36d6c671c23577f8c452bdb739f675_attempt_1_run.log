lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  have h₁ : IsEquiv e := by
    -- The equivalence e is a field equivalence, hence it is bijective.
    exact IsEquiv.ofEquiv e.symm.trans e
  have h₂ : ∀ (v : L), valuation L (e v) = valuation L v := by
    intro v
    -- Use the fact that the valuation is preserved under the equivalence.
    have h₃ : e.isUnit_iff v := by
      -- The equivalence preserves units.
      simpa [RingHom.isUnit_iff] using e.map_isUnit_iff
    -- Since e preserves units, it also preserves the valuation.
    have h₄ : valuation L (e v) = valuation L v := by
      -- Use the property of valuations and the fact that e is an equivalence.
      rw [← valuation.map_mul (1 : L)]
      simp_all [mul_comm]
      <;>
      (try simp_all [mul_comm]) <;>
      (try simp_all [IsEquiv.map_injective]) <;>
      (try simp_all [IsEquiv.map_surjective]) <;>
      (try simp_all [IsEquiv.map_injective]) <;>
      (try simp_all [IsEquiv.map_surjective]) <;>
      (try simp_all [IsEquiv.map_injective]) <;>
      (try simp_all [IsEquiv.map_surjective])
    exact h₄
  -- Apply the general result to the specific element x.
  exact h₂ x
