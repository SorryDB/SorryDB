lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  have hM : iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
    have h₁ : IsBinomialRandom G p P := hG
    -- Extract the property of being Bernoulli on edges from the binomial random graph assumption
