          <;>
          (try aesop)
          <;>
          (try simp_all [MeasurableSpace.countable])
          <;>
          (try aesop)
        })
    rw [h₅] at h₄
    exact h₄
  have h₃ : iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
    have h₄ : IsBernoulliOn (fun ←(x) (x : Ω) ↦ edgeSet (G x)) diagSetᶜ p P := by
