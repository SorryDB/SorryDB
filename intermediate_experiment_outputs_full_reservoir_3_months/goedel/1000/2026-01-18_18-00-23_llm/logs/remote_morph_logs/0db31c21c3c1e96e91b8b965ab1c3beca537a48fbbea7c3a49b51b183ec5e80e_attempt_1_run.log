lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  have h₁ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
    have h₂ : IsBinomialRandom G p P := hG
    have h₃ : HasLaw G (G(V, p)) P := h₂
    -- Use the fact that G is a binomial random graph to show independence
    have h₄ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
      -- Extract the independence property from the binomial random graph
      have h₅ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P :=
        (isBernoulliOn_edgeSet_binomialRandom P).iIndepFun (by
          simp_all [HasLaw, MeasureTheory.ae_map])
      exact h₅
    exact h₄
  exact h₁
```
