  have h₄ : (ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq (e.mul_by_cofactor) (Identitycurve25519_dalekedwardsEdwardsPoint.id) : Result Bool (Unit)) = by_cases (fun _ => true) (ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint(ct_eq (e.mul_by_cofactor) (Identitycurve25519_dalekedwardsEdwardsPoint.id))) := by
    rfl
  have h₅ : (e.is_small_order : Result Bool (Unit)) = by_cases (fun _ => true) e.is_small_order := by
