    rfl
  have h₂ : mul_by_cofactor e = by_cases (fun _ => true) e.mul_by_cofactor := by
    rfl
  have h₃ : (Identitycurve25519_dalekedwardsEdwardsPoint.id : Result Unit (Unit)) = ok () := by
