  have h₄ : ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq (mul_by_cofactor e).val identity = ok (if (mul_by_cofactor e).val = identity then Choice.one else Choice.zero) := by
    simp [ct_eq]
    <;> aesop
  refine' ⟨if (mul_by_cofactor e).val = identity then true else false, (mul_by_cofactor e).val, identity, if (mul_by_cofactor e).val = identity then Choice.one else Choice.zero, _, _, _, _, _⟩ <;>
