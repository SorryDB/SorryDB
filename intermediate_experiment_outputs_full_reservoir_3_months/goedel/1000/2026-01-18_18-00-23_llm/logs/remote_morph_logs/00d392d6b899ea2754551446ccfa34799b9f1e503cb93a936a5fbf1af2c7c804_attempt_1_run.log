variable (n k : ℕ∞)

noncomputable def lineDerivWithOrderCLM (v : E) :
    𝓓'^{n}(Ω, F) →L[ℝ] 𝓓'^{k}(Ω, F) :=
  (-1 : ℝ) • TestFunction.lineDerivWithOrderCLM k n v |>.precomp F

@[simp]
lemma lineDerivWithOrderCLM_apply {v : E} {T : 𝓓'^{n}(Ω, F)} {φ : 𝓓^{k}(Ω, ℝ)} :
    lineDerivWithOrderCLM v T φ = T (- TestFunction.lineDerivWithOrderCLM k n v φ) := by
  simp [lineDerivWithOrderCLM, ContinuousLinearMap.neg_apply, ContinuousLinearMap.smul_apply]
  <;>
  simp_all [ContinuousLinearMap.comp_apply, ContinuousLinearMap.neg_apply, ContinuousLinearMap.smul_apply]
  <;>
  ring_nf
  <;>
  simp_all [TestFunction.kthDeriv_eq_zero_of_lt, ENNReal.ofReal_simp]
  <;>
  norm_num
  <;>
  linarith

variable (n : ℕ∞)

noncomputable def lineDerivCLM (v : E) :
    𝓓'(Ω, F) →L[ℝ] 𝓓'(Ω, F) :=
  (-1 : ℝ) • TestFunction.lineDerivCLM v |>.precomp F

@[simp]
lemma lineDerivCLM_apply {v : E} {T : 𝓓'(Ω, F)} {φ : 𝓓(Ω, ℝ)} :
    lineDerivCLM v T φ = T (- TestFunction.lineDerivCLM v φ) := by
  simp [lineDerivCLM, ContinuousLinearMap.neg_apply, ContinuousLinearMap.smul_apply]
  <;>
  simp_all [ContinuousLinearMap.comp_apply, ContinuousLinearMap.neg_apply, ContinuousLinearMap.smul_apply]
