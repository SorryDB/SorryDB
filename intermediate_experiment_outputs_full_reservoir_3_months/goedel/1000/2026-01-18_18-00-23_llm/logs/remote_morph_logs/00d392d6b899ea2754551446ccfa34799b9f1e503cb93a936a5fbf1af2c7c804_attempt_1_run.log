theorem fderiv_add {T U : 𝓓'(Ω, F)} :
  fderiv (T + U) = fun v ↦ fderiv T v + fderiv U v := by
  ext v
  -- Use the linearity of the derivative to show that the derivative of the sum is the sum of the derivatives.
  have h₁ : fderiv (T + U) v = fderiv T v + fderiv U v := by
    -- Use the fact that the derivative of the sum is the sum of the derivatives.
    have h₂ : (T + U) = T + U := rfl
    have h₃ : fderiv (T + U) v = fderiv T v + fderiv U v := by
      -- Use the linearity of the derivative to show that the derivative of the sum is the sum of the derivatives.
      have h₄ : fderiv (T + U) v = (T + U : 𝓓'(Ω, F)) ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ)) := rfl
      have h₅ : fderiv T v = (T : 𝓓'(Ω, F)) ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ)) := rfl
      have h₆ : fderiv U v = (U : 𝓓'(Ω, F)) ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ)) := rfl
      calc
        fderiv (T + U) v = (T + U : 𝓓'(Ω, F)) ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ)) := by rw [h₄]
        _ = (T ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ)) + U ∘L (lineDerivCLM v : 𝓓(Ω, ℝ) →L[ℝ] 𝓓(Ω, ℝ))) := by
          -- Use the linearity of the derivative to show that the derivative of the sum is the sum of the derivatives.
          simp [ContinuousLinearMap.add_apply, Pi.add_apply]
          <;>
          congr <;>
          simp_all [ContinuousLinearMap.add_apply, Pi.add_apply]
          <;>
          aesop
        _ = fderiv T v + fderiv U v := by
          -- Use the linearity of the derivative to show that the derivative of the sum is the sum of the derivatives.
          simp [h₅, h₆]
          <;>
          congr <;>
          simp_all [ContinuousLinearMap.add_apply, Pi.add_apply]
          <;>
          aesop
    exact h₃
  -- Use the linearity of the derivative to show that the derivative of the sum is the sum of the derivatives.
  simp_all [h₁]
  <;>
  aesop
