/[Finset.sum_eq_single I h]
theorem Finset.sum_eq_single {α : Type*} {G : Type*} [AddCommMonoid G]
  (I : α) (s : Finset α) (h : ∀ (j : α), j ∈ s → j ≠ I → j ∉ s) : ∑ j in s, f j = f I := by
  have h₁ : s ⊆ {I} := by
    intro j hj
    have h₂ : j = I := by
      by_contra h₃
      have h₄ := h j hj h₃
      simp_all
    simp_all
  have h₂ : s = ∅ ∨ s = {I} := by
    classical
    have h₃ : s ⊆ {I} := h₁
    have h₄ : s = ∅ ∨ s = {I} := by
      by_cases h₅ : s = ∅
      · exact Or.inl h₅
      · have h₆ : s.Nonempty := Finset.nonempty_iff_ne_empty.mpr h₅
        have h₇ : ∃ a, a ∈ s := h₆
        have h₈ : ∀ (a : α), a ∈ s → a = I := by
          intro a ha
          have h₉ : a ∈ s := ha
          have h₁₀ : a = I := by
            by_contra h₁₁
            have h₁₂ := h a ha h₁₁
            simp_all
          exact h₁₀
        have h₉ : s = {I} := by
          apply Finset.eq_singleton_iff_unique_mem.mpr
          constructor
          · obtain ⟨a, ha⟩ := h₇
            have h₁₀ : a = I := h₈ a ha
            have h₁₁ : I ∈ s := by
              rw [h₁₀] at ha
              exact ha
            exact h₁₁
          · intro a ha
            have h₁₀ : a = I := h₈ a ha
            rw [h₁₀]
            <;> simp_all
        exact Or.inr h₉
    exact h₄
  cases h₂ with
  | inl h₂ =>
    simp [h₂]
    <;> simp_all [Finset.sum_empty]
  | inr h₂ =>
    simp [h₂]
    <;> simp_all [Finset.sum_singleton]

end

