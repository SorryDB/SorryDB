    have h₃ : (lamb : ℂ) ≠ 1 := by
      intro h₃
      apply h_lamb
      simpa [Complex.ext_iff] using h₃
    have h₄ : ‖a‖ < 1 := by
      have h₅ : ‖lamb‖ = 1 := by
        have h₅₁ : ‖lamb‖ = 1 := by
          have h₅₂ := h₂.isUnit
          simp_all [Complex.norm_eq_abs, Complex.abs_def, Complex.normSq]
          <;> ring_nf at *
          <;> norm_num at *
          <;>
          (try
            {
              simp_all [Complex.ext_iff, pow_two]
              <;> ring_nf at *
              <;> nlinarith [sq_nonneg (a : ℝ), sq_nonneg (b : ℝ)]
            })
          <;>
          (try
            {
              field_simp [Complex.ext_iff, pow_two] at *
              <;> ring_nf at *
              <;> nlinarith [sq_nonneg (a : ℝ), sq_nonneg (b : ℝ)]
            })
          <;>
