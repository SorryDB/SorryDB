theorem h_lamb_gt_q_sub_one (q n : ℕ) (lamb : ℂ):
  lamb ∈ (primitiveRoots n ℂ) → ‖(X - (C lamb)).eval (q : ℂ)‖ > (q - 1) := by
  let a := lamb.re
  let b := lamb.im
  intro h
  have h_lamb: lamb ≠ 1 := by
    have h₁ : lamb ∈ primitiveRoots n ℂ := h
    have h₂ : IsPrimitiveRoot (ζ := lamb) (n := n) := by
      rw [primitiveRoots] at h₁
      simpa [Set.mem_def] using h₁
    have h₃ : n ≠ 0 := by
      by_contra hn
      simp_all [IsPrimitiveRoot, Int.natAbs_eq_zero]
      <;> aesop
    have h₄ : lamb ≠ 1 := by
      intro h₄
      have h₅ := h₂.ne_one
      simpa [h₄] using h₅
    exact h₄
  
