              <;> ring_nf at *
              <;> nlinarith [sq_nonneg (a : ℝ), sq_nonneg (b : ℝ)]
            })
        exact h₅₁
      have h₆ : Complex.abs lamb = 1 := by
        simp_all [Complex.norm_eq_abs]
      have h₇ : Complex.abs (lamb : ℂ) ^ 2 = 1 := by
        have h₇₁ : Complex.abs (lamb : ℂ) = 1 := by
          simp_all [Complex.norm_eq_abs]
        have h₇₂ : Complex.abs (lamb : ℂ) ^ 2 = 1 := by
          rw [h₇₁]
          <;> norm_num
        exact h₇₂
      have h₈ : a * a + b * b = 1 := by
        have h₈₁ : Complex.abs (lamb : ℂ) ^ 2 = 1 := by
