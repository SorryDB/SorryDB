```lean
def ReesDecomposition (m n : ℕ) : ℕ → ℕ → ℕ := fun i j => (if i = j then m / 2 else 0)

theorem main (m n : ℕ) : ∑ i : Fin m, ∑ j : Fin n, ReesDecomposition m n i j = m * n / 2 := by
  have h₁ : ∑ i : Fin m, ∑ j : Fin n, ReesDecomposition m n i j = ∑ i : Fin m, ∑ j : Fin n, (if i = j then m / 2 else 0) := rfl
  rw [h₁]
  -- We will compute the sum by considering the cases where i and j are equal or not.
  have h₂ : ∑ i : Fin m, ∑ j : Fin n, (if i = j then m / 2 else 0) = (m / 2) * (if m = n then 1 else 0) + 0 * (if m ≠ n then 1 else 0) := by
    -- Case analysis on whether m equals n
    by_cases h : m = n
