theorem exercise_42917  (V : Type*)  (Ω : Type*) [MeasurableSpace Ω]  (G : Ω → SimpleGraph V) 
  (P : Measure Ω) (p : ℝ) : 
  AEMeasurable (fun ω => (G ω)ᶜ) P := by
  have h₀ : Measurable (fun (s : Ω) => (G s)ᶜ) := by
    apply Measurable.comp (measurable_comap (simpleGraphInclusion.2))
    exact measurable_simpleGraphInclusion
  filter_upwards [aemeasurable_of_measurable h₀] with ω
  <;> simp_all
  <;> aesop
```
