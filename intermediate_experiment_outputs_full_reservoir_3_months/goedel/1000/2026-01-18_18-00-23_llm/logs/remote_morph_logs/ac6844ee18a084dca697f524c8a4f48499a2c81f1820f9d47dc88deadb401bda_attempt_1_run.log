theorem lean_workbook_plus_5195 (a b c : ℕ) :
    a < b + c + 2 →
    (a < 2 * b ∧ a < 2 * c) ∨
    (a ≥ 2 * b ∧ a < 2 * c + 1) ∨
    (a < 2 * b + 1 ∧ a ≥ 2 * c) := by
  intro h
  have h₁ : (a < 2 * b ∧ a < 2 * c) ∨ (a ≥ 2 * b ∧ a < 2 * c + 1) ∨ (a < 2 * b + 1 ∧ a ≥ 2 * c) := by
    by_cases h₂ : a ≥ 2 * b
    · -- Case: a ≥ 2 * b
      by_cases h₃ : a < 2 * c + 1
      · -- Subcase: a < 2 * c + 1
        exact Or.inr (Or.inl ⟨h₂, h₃⟩)
      · -- Subcase: a ≥ 2 * c + 1
        have h₄ : a ≥ 2 * c + 1 := by omega
        have h₅ : a < 2 * b + 1 := by
          omega
        have h₆ : a ≥ 2 * c := by
          omega
        exact Or.inr (Or.inr ⟨h₅, h₆⟩)
    · -- Case: a < 2 * b
      by_cases h₃ : a < 2 * c
      · -- Subcase: a < 2 * c
        exact Or.inl ⟨by omega, h₃⟩
      · -- Subcase: a ≥ 2 * c
        have h₄ : a ≥ 2 * c := by omega
        have h₅ : a < 2 * b + 1 := by
          omega
        exact Or.inr (Or.inr ⟨h₅, h₄⟩)
  exact h₁
