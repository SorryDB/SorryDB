  have h₁ : (x + y : ℕ) ^ 2 = x ^ 2 + 2 * x * y + y ^ 2 := by
    -- Use the theorem `pow_two` to expand (x + y)^2
    have h₂ : (x + y : ℕ) ^ 2 = (x + y) * (x + y) := by
      rw [pow_two]
    rw [h₂]
    -- Expand (x + y) * (x + y) using the distributive property
    have h₃ : (x + y) * (x + y) = x * (x + y) + y * (x + y) := by
      ring_nf
      <;> simp [mul_add, add_mul]
      <;> ring_nf
      <;> omega
    rw [h₃]
    have h₄ : x * (x + y) + y * (x + y) = x * x + x * y + (y * x + y * y) := by
      ring_nf
      <;> simp [mul_add, add_mul]
      <;> ring_nf
      <;> omega
    rw [h₄]
    -- Combine terms and use commutativity of multiplication
    have h₅ : x * x + x * y + (y * x + y * y) = x ^ 2 + 2 * x * y + y ^ 2 := by
      ring_nf
      <;> simp [mul_add, add_mul]
      <;> ring_nf
      <;> omega
    rw [h₅]
  exact h₁
