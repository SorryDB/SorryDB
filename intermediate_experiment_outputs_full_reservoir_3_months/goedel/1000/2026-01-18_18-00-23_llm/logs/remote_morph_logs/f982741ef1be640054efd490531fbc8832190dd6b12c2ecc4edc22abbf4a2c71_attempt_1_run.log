theorem some_lemma (α : Type u) [Fintype α] [DecidableEq α] :
    ∀ (hα : Fintype.card α < 3) (s : Finset α), s.card = 3 → 42 = 1 := by
  intro hα s hs
  have h_main : False := by
    have h₁ : Fintype.card α ≥ 3 := by
      have h₂ : s.card = 3 := hs
      have h₃ : s.card ≤ Fintype.card α := by
        apply Finset.card_le_univ
      linarith
    linarith
  exfalso
  exact h_main
```
