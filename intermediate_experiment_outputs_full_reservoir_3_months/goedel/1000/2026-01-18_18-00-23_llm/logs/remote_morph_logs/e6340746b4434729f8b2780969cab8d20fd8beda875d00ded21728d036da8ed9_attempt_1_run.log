```lean
instance piLeft {k M ι : Type*} [Ring k] [AddCommGroup M] [Module k M]
    [LE ι] (M_ : ι → Submodule k M) [IsFilterComplete M_] (α : Type*) :
    IsFilterComplete fun i ↦ Submodule.pi Set.univ fun x => M_ i :=
  letI := ‹IsFilterComplete M_›
  {
    filtered := by
      refine' ⟨_, ⟨0, _⟩⟩
      · -- Prove that the family of submodules is decreasing
        intro i j h
        ext <;> simp_all [Submodule.mem_pi]
        <;> aesop
      · -- Find an index such that the submodule is zero
        simp_all [Submodule.mem_pi, Submodule.zero_mem]
        <;> aesop
    -- Prove the completeness condition for the family of submodules
    complete := by
      intro N hN
      have h₁ : ∀ x, N ≤ Submodule.pi Set.univ fun x => M_ x := by
        intro x
        apply hN
      -- Use the completeness of the original family to find an index
      have h₂ : ∃ i, N ≤ M_ i := by
        classical
        have h₃ : ∀ i, N ≤ M_ i := by
          intro i
          have h₄ := h₁ i
          have h₅ : N ≤ Submodule.pi Set.univ fun x => M_ i := by
            intro x y hy
            have h₆ := h₄ x hy
            have h₇ := h₄ y (by simpa using hy)
            simp_all [Submodule.mem_pi]
            <;> aesop
          have h₆ : Submodule.pi Set.univ fun x => M_ i ≤ M_ i := by
            intro x hx
            simp_all [Submodule.mem_pi]
