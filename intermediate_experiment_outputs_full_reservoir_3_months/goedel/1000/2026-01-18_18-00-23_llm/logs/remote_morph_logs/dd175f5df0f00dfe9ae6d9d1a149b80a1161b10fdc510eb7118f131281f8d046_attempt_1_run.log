theorem IsBinomialRandom.compl (hG : IsBinomialRandom G p P) :
    IsBinomialRandom (fun ω ↦ (G ω)ᶜ) (σ p) P where
  map_eq := by
    have h₁ : map (fun ω => (G ω)ᶜ) P = map (fromEdgeSet ∘ (·ᶜ) ∘ edgeSet) P := by
      congr with ω
      <;> simp [SimpleGraph.coe_compl]
      <;>
      simp_all [SimpleGraph.fromEdgeSet, Set.compl]
      <;>
      aesop
    rw [h₁]
    have h₂ : map (fromEdgeSet ∘ (·ᶜ) ∘ edgeSet) P = (G(V, σ p) : Measure (SimpleGraph V)) := by
      have h₃ : map (fromEdgeSet ∘ (·ᶜ) ∘ edgeSet) P = map (fromEdgeSet ∘ (·ᶜ)) (map edgeSet P) := by
        simp [map_map]
        <;>
        aesop
      rw [h₃]
      have h₄ : map edgeSet P = Ber(diagSetᶜ, p) := by
        have h₅ : HasLaw G (G(V, p)) P := hG
        have h₆ : HasLaw (edgeSet ∘ G) (Ber(diagSetᶜ, p)) P := by
          have h₇ : HasLaw (edgeSet ∘ G) (map edgeSet (G(V, p))) P := h₅.comp _
          have h₈ : map edgeSet (G(V, p)) = Ber(diagSetᶜ, p) := by
            rw [binomialRandom]
            <;> simp [measurableEmbedding_edgeSet.map_comap]
          rw [h₈] at h₇
          exact h₇
        have h₉ : Law (edgeSet ∘ G) = Ber(diagSetᶜ, p) := by
          apply HasLaw.law
          exact h₆
        have h₁₀ : Law (edgeSet ∘ G) = map edgeSet P := by
          simp [Law, Function.comp]
        rw [h₁₀] at h₉
        exact h₉
      rw [h₄]
      have h₅ : map (fromEdgeSet ∘ (·ᶜ)) (Ber(diagSetᶜ, p)) = (G(V, σ p) : Measure (SimpleGraph V)) := by
        calc
          map (fromEdgeSet ∘ (·ᶜ)) (Ber(diagSetᶜ, p)) = map fromEdgeSet (map (·ᶜ) (Ber(diagSetᶜ, p))) := by
            simp [map_map]
            <;>
            aesop
          _ = map fromEdgeSet (Ber(diagSetᶜ, σ p)) := by
            have h₆ : map (·ᶜ) (Ber(diagSetᶜ, p)) = Ber(diagSetᶜ, σ p) := by
              -- Use the fact that complementing a set in Bernoulli distribution flips the probability
              have h₇ : (·ᶜ) '' diagSetᶜ = diagSetᶜ := by
                -- The complement of the diagonal set is the off-diagonal set, and its complement is the diagonal set again
                ext ⟨x, y⟩
                simp [diagSet, Set.mem_compl_iff, Set.mem_singleton_iff]
                <;>
                by_cases h : x = y <;>
                simp_all
              have h₈ : map (·ᶜ) (Ber(diagSetᶜ, p)) = Ber(diagSetᶜ, σ p) := by
                -- Use the Bernoulli measure property to show the complement is another Bernoulli measure
                calc
                  map (·ᶜ) (Ber(diagSetᶜ, p)) = flet (q := p); map (·ᶜ) (Ber(diagSetᶜ, q)) := rfl
                  _ = flet (q := p); Ber(diagSetᶜ, σ q) := by
                    dsimp
                    rw [map_bernoulliOn_compl]
                    <;>
                    aesop
                  _ = Ber(diagSetᶜ, σ p) := rfl
              exact h₈
            rw [h₆]
          _ = (G(V, σ p) : Measure (SimpleGraph V)) := by
            rw [binomialRandom]
            <;> simp [measurableEmbedding_edgeSet.map_comap]
      rw [h₅]
    rw [h₂]
    <;>
    simp [IsBinomialRandom, HasLaw]
    <;>
    aesop
