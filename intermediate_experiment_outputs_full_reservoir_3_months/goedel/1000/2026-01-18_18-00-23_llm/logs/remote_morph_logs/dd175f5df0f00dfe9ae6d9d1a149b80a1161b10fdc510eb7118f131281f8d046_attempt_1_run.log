    IsBinomialRandom (fun ω ↦ (G ω)ᶜ) (σ p) P where
  map_eq := by
    have h₁ : (Measure.map (fun ω ↦ (G ω)ᶜ) P) = (Measure.map (fun ω ↦ (G ω)ᶜ) P) := rfl
    have h₂ : binomialRandom V (σ p) = binomialRandom V (σ p) := rfl
    have h₃ : IsBinomialRandom (fun ω ↦ (G ω)ᶜ) (σ p) P := by
      have h₄ : HasLaw (fun ω ↦ (G ω)ᶜ) (binomialRandom V (σ p)) P := by
        have h₅ : HasLaw G (binomialRandom V p) P := hG
        have h₆ : (binomialRandom V (σ p)) = (binomialRandom V p).map (fun G ↦ Gᶜ) := by
          -- Prove that the binomial distribution with σ p is the map of the binomial distribution with p under complement
          apply Measure.ext
          intro S
          simp [binomialRandom, measurableEmbedding_edgeSet.comap_apply, map_map]
          <;>
          simp_all [Set.image_comp]
          <;>
          congr 1 <;>
          simp_all [Set.image_comp]
          <;>
          apply Set.ext <;>
          simp (config := { contextual := true }) [SimpleGraph.edgeSet_compl, not_mem_empty,
            not_not, not_exists, not_forall] <;>
          tauto
        calc
          HasLaw (fun ω ↦ (G ω)ᶜ) (binomialRandom V (σ p)) P :=
              h₅.map (fun G ↦ Gᶜ)
          _ = HasLaw (fun ω ↦ (G ω)ᶜ) ((binomialRandom V p).map (fun G ↦ Gᶜ)) P := by
              rw [h₆]
          _ := by
              simpa using h₅.map (fun G ↦ Gᶜ)
      exact h₄
    have h₇ : (Measure.map (fun ω ↦ (G ω)ᶜ) P) = binomialRandom V (σ p) := by
      -- Use the fact that the map of the binomial distribution with p under complement is the binomial distribution with σ p
      have h₈ : HasLaw (fun ω ↦ (G ω)ᶜ) (binomialRandom V (σ p)) P := h₃
      have h₉ : (Measure.map (fun ω ↦ (G ω)ᶜ) P) = binomialRandom V (σ p) := by
        simpa [HasLaw] using h₈
      exact h₉
    -- Combine the results to prove the statement
    calc
      (Measure.map (fun ω ↦ (G ω)ᶜ) P) = binomialRandom V (σ p) := by rw [h₇]
      _ = binomialRandom V (σ p) := rfl
