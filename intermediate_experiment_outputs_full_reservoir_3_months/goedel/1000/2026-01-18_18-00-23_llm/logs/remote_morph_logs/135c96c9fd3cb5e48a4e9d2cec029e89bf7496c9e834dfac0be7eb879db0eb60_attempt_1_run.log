  funDeriv ℝ (fun x : ℝ => x ^ 3) g := by
  use fun x : ℝ => 3 * x ^ 2
  intro x ε εpos
  let δ : ℝ := min 1 (ε / (3 * |x| + 1))
  have δpos : 0 < δ := by
    have h₁ : 0 < ε / (3 * |x| + 1) := by
      apply div_pos εpos
      positivity
    have h₂ : 0 < min 1 (ε / (3 * |x| + 1)) := by
      exact lt_min (by norm_num) h₁
    simpa [δ] using h₂
  have δ_le_one : δ ≤ 1 := by
    exact min_le_left _ _
  have δ_le_two : δ ≤ ε / (3 * |x| + 1) := by
    exact min_le_right _ _
  use δ, δpos
  intro h hne hh
  have h₁ : ((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2 = (h - 0) * (3 * x + h) := by
    have h₂ : h ≠ 0 := hne
