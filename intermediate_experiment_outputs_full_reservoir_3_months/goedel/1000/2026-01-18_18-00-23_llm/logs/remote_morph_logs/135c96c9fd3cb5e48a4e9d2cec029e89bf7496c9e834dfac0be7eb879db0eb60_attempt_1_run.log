Statement : ∃ g : ℝ → ℝ,
  FunDeriv (fun x ↦ x ^ 3) g := by
use (fun x ↦ 3 * x ^ 2)
intro x ε hε
let δ : ℝ := min 1 (ε / (3 * |x| + 1))
have δ_le1 : δ ≤ 1 := by
  exact min_le_left _ _
have δ_le2 : δ ≤ ε / (3 * |x| + 1) := by
  exact min_le_right _ _
have δpos : 0 < δ := by
  have h₁ : (0 : ℝ) < 1 := by norm_num
  have h₂ : (0 : ℝ) < ε / (3 * |x| + 1) := by
    apply div_pos hε
    positivity
  -- Since both 1 and ε / (3 * |x| + 1) are positive, their minimum is also positive.
  have h₃ : 0 < min 1 (ε / (3 * |x| + 1)) := by
    exact lt_min h₁ h₂
  exact h₃
use δ, δpos
intro h hne hh
rewrite [show ((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2 = (h - 0) * (3 * x + h) by
  have h₁ : h ≠ 0 := hne
  field_simp [h₁, sub_ne_zero]
  <;> ring_nf
  <;> field_simp [h₁]
  <;> ring_nf
  ]
rewrite [show |(h - 0) * (3 * x + h)| = |h - 0| * |3 * x + h| by apply abs_mul]
have h1 : |3 * x + h| ≤ 3 * |x| + 1 := by
  calc
    |3 * x + h| ≤ |3 * x| + |h| := by apply abs_add
    _ = 3 * |x| + |h| := by simp [abs_mul, abs_of_pos (show (0 : ℝ) < 3 by norm_num)]
    _ ≤ 3 * |x| + 1 := by
      have h₂ : |h| < δ := by
        simpa [abs_of_nonneg (le_of_lt (by
          by_contra h₃
          have h₄ : h ≤ 0 := by linarith
          have h₅ : h ≠ 0 := hne
          have h₆ : h < 0 := lt_of_le_of_ne h₄ (Ne.symm h₅)
          simp_all [abs_of_neg, abs_of_nonneg, le_of_lt]
          <;> linarith
        ))] using hh
      have h₃ : δ ≤ 1 := δ_le1
      have h₄ : |h| < 1 := by linarith
      have h₅ : |h| ≤ 1 := by linarith [abs_nonneg h]
      linarith
have h₂ : |h - 0| < δ := by simpa [abs_of_nonneg (le_of_lt (by
  by_contra h₃
  have h₄ : h ≤ 0 := by linarith
  have h₅ : h ≠ 0 := hne
  have h₆ : h < 0 := lt_of_le_of_ne h₄ (Ne.symm h₅)
  simp_all [abs_of_neg, abs_of_nonneg, le_of_lt]
  <;> linarith
))] using hh
calc
  |h - 0| * |3 * x + h| < δ * (3 * |x| + 1) := by
