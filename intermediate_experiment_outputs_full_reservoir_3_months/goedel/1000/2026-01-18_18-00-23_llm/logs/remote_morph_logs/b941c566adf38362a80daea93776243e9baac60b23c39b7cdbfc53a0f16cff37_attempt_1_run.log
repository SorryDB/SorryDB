#print NumberField

#synth (Algebra ℚ K)

section

/- Assume `CharZero K` if you want to work with a possible infinite extension of `ℚ`, and *not*
`Algebra ℚ K`.  -/

variable (L : Type*) [Field L] [Algebra ℚ L] [FiniteDimensional ℚ L]

example : NumberField L := by
  have h₁ : NumberField L :=
    by
      -- Since L is a finite-dimensional algebra over ℚ and a field, it is a number field.
      have h₂ : IsScalarTower ℚ L L := by infer_instance
      -- The key property to check is that L is isomorphic to its own algebra over ℚ.
      have h₃ : Algebra.IsIntegral ℚ L := by
        -- Since L is finite-dimensional over ℚ, it is integral over ℚ.
        infer_instance
      -- Now we can use the fact that L is a field and integral over ℚ to conclude it's a number field.
      infer_instance
    exact h₁
``` 

