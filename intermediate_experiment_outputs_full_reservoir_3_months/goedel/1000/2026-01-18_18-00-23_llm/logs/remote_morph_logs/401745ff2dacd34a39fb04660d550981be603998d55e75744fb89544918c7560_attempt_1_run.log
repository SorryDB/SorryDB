theorem Φ₃'_contDiffOn : ContDiffOn ℝ ∞ (Φ₃' r) ℍ₀ := by
  have h₀ : ContDiffOn ℝ ∞ (Φ₃' r) ℍ₀ := by
    have h₁ : ContDiffOn ℝ ∞ (fun z : ℂ => (z - 1 : ℂ) ^ 2) ℍ₀ := by
      -- Prove that (z - 1)^2 is smooth on ℂ
      have h₂ : ContDiffOn ℝ ∞ (fun z : ℂ => (z - 1 : ℂ)) ℍ₀ := by
        -- Prove that (z - 1) is smooth on ℂ
        apply contDiffOn_id.sub
        exact contDiffOn_const
      -- Prove that (z - 1)^2 is smooth on ℂ
      apply ContDiffOn.pow h₂ 2
    -- Prove that the exponential function is smooth on ℂ
    have h₃ : ContDiffOn ℝ ∞ (fun z : ℂ => Complex.exp (r * z)) ℍ₀ := by
      have h₄ : ContDiffOn ℝ ∞ (fun z : ℂ => (r : ℂ) * z) ℍ₀ := by
        -- Prove that (r * z) is smooth on ℂ
        apply contDiffOn_const.mul
        exact contDiffOn_id
      -- Prove that exp(r * z) is smooth on ℂ
      apply contDiffOn_exp.comp h₄ (isOpen_upperHalfPlaneSet) (Set.mapsTo_univ _ _)
    -- Prove that φ₀'' is smooth on ℂ
    have h₅ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z) ℍ₀ := by
      -- φ₀'' is constant, hence smooth
      apply contDiffOn_const
    -- Prove that the product of the functions is smooth on ℂ
    have h₆ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z * (z - 1 : ℂ) ^ 2 * Complex.exp (r * z)) ℍ₀ := by
      apply ContDiffOn.mul
      · apply ContDiffOn.mul h₅ h₁
      · exact h₃
    -- Prove that Φ₃' r is smooth on ℂ
    have h₇ : (fun z : ℂ => φ₀'' z * (z - 1 : ℂ) ^ 2 * Complex.exp (r * z)) = Φ₃' r := by
      funext z
      rfl
    rw [h₇] at h₆
    exact h₆
  exact h₀
