```lean
def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    -- Prove that the composition maps 1 to 1
    simp [RingHom.map_one]
    <;>
    simp_all [RingHom.map_one]
  
  map_mul' := by
    -- Prove that the composition is multiplicative
    intro x y
    have h : g (f (x * y)) = g (f x * f y) := by
      -- Since f is a ring homomorphism, f(x * y) = f(x) * f(y)
      apply congr_arg g
      have h₁ : f (x * y) = f x * f y := by
        -- f is multiplicative
        apply f.map_mul
      rw [h₁]
    -- Since g is a ring homomorphism, g(f(x) * f(y)) = g(f(x)) * g(f(y))
    have h₂ : g (f x * f y) = g (f x) * g (f y) := by
      apply g.map_mul
    -- Combine the two steps to get the final result
    calc
      g (f (x * y)) = g (f x * f y) := h
      _ = g (f x) * g (f y) := h₂
  
  map_add' := by
    -- Prove that the composition is additive
    intro x y
    have h : g (f (x + y)) = g (f x + f y) := by
      -- Since f is a ring homomorphism, f(x + y) = f(x) + f(y)
      apply congr_arg g
      have h₁ : f (x + y) = f x + f y := by
        -- f is additive
        apply f.map_add
      rw [h₁]
    -- Since g is a ring homomorphism, g(f(x) + f(y)) = g(f(x)) + g(f(y))
    have h₂ : g (f x + f y) = g (f x) + g (f y) := by
      apply g.map_add
    -- Combine the two steps to get the final result
    calc
      g (f (x + y)) = g (f x + f y) := h
      _ = g (f x) + g (f y) := h₂
  
  map_zero' := by
    -- Prove that the composition maps 0 to 0
    simp [RingHom.map_zero]
