def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [RingHom.map_one]
  map_mul' := by
    intro x y
    have h : g (f (x * y)) = g (f x * f y) := by
      congr 1
      apply f.map_mul
    rw [h]
    apply g.map_mul
```
