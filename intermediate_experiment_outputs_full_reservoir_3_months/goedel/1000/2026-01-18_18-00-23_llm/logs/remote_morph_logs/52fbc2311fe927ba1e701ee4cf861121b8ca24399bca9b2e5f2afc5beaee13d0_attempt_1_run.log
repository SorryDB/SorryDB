lemma indepFun_rewardByCount_of_ne {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ rewardByCount b s ω) 𝔓 := by
  have h : (fun ω s ↦ rewardByCount a s ω) ⟂ᵢ[𝔓] (fun ω s ↦ rewardByCount b s ω) := by
    -- Use the fact that the rewards for different arms are independent
    -- due to the Markov property and the independence of the rewards in the stream measure.
    apply IndepFun.comp (ind : _)
    · -- Show that the functions are measurable
      part intro
      all_goals
        measure_theory.fun_ae_stronglyMeasurable
        <;>
        (try simp_all [IndepFun.comp])
        <;>
        (try fun_prop)
        <;>
        (try simp_all [.rewardByCount, pullCount, pullIndices, MeasureCount, stepsUntil])
        <;>
        (try aesop)
        <;>
        (try fun_prop)
        <;>
        (try simp_all [IndepFun.comp])
    · -- Use the independence of the rewards for different arms
      exact iIndepFun_comp_infi
  exact h
