class Solution {
    constructor(private initialRopes: Set<AbstractRope>) {
    }

    hasInitialRope(rope: AbstractRope): boolean {
        return this.initialRopes.has(rope);
    }
    getCollisionTime(ropes: List<AbstractRope> | null = null): number | null {
        if (ropes == null) {
            ropes = initialRopes;
        }
        if (ropes.length < 2) {
            return 0;
        }
        let maxRope: AbstractRope = ropes[0];
        let secondMaxRope: AbstractRope = ropes[1];
        let maxPair = [maxRope, secondMaxRope];
        ropes.filter(r => r != maxRope && r != secondMaxRope).forEach(r => {
            if (r > secondMaxRope) {
                maxPair = [maxRope, r];
                secondMaxRope = r;
            }
        })
        let maxSpeed = maxPair[0].speed + maxPair[1].speed;
        let sum: number = 0;
        let maxLen = 0;
        ropes.forEach(r => {
            if (r != maxPair[0] && r != maxPair[1]) {
                sum += r.length;
                maxLen += r.length;
            }
        })
        if (maxPair[0].length + maxPair[1].length < sum) {
            return null;
        }
        let collisionTime = (maxPair[0].length + maxPair[1].length - (sum - (maxPair[0].length + maxPair[1].length))) / 2 / maxSpeed;
        if (collisionTime < 0) {
            return 0;
        }
        return collisionTime;
    }
    validPair<NewType extends AbstractRope>(rope1: NewType, rope2: NewType): [NewType, NewType] | null {
        if (rope1 in this.initialRopes && rope2 in this.initialRopes && rope1 != rope2) {
            return [rope1, rope2];
        }
        return null;
    }
}
