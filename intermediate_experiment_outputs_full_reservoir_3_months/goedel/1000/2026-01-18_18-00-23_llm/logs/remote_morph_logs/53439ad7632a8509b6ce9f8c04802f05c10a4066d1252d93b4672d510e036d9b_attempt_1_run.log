    -- Use the fact that r • f is interval integrable to show that f is interval integrable.
    have h₂ : IntervalIntegrable (fun x : ℝ => (1 : R) • f x) μ a b := by
      have h₃ : IntervalIntegrable (r • f) μ a b := h
      have h₄ : IntervalIntegrable (fun x : ℝ => r⁻¹ • (r • f x)) μ a b := by
        refine' (h₃.smul_right r⁻¹ _
          (isBoundedSMulClass "ℝ" (by simpa using inferInstance) _
            (max a b - min a b)))
        <;>
        (try simp_all) <;>
        (try norm_num) <;>
        (try linarith) <;>
