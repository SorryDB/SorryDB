theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor <;> intro h
  · -- Forward direction: If f is interval integrable, then r • f is interval integrable.
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Since r • f is a scalar multiple of f, and multiplication by a constant preserves integrability,
      -- we use the fact that boundedness and linearity of the integral can be extended to scalar multiples.
      exact h.const_smul r
    exact h₁
  · -- Backward direction: If r • f is interval integrable, then f is interval integrable.
    have h₁ : IntervalIntegrable f μ a b := by
      -- Similarly, if we assume r ≠ 0, then we can invert the scalar multiple to recover f.
      -- However, if r = 0, then r • f = 0, and the fact that 0 is integrable is trivial.
      -- In this case, we can observe that the case when r = 0 is already covered by the first direction,
      -- but we need to treat it separately.
      by_cases hr : r = 0
      · -- Case r = 0: We have r • f = 0, which is always integrable.
        have h₂ : (r : R) • f = fun x => 0 := by
          ext x
          simp [hr]
          <;>
          (try simp_all [SMulZeroClass]) <;>
          (try aesop)
        rw [h₂] at h
        exact h.zero
      · -- Case r ≠ 0: We use the fact that we can divide by r.
        have h₂ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
          -- Since r • f is integrable, then r⁻¹ • (r • f) = f is also integrable because multiplication
          -- by r⁻¹ is bounded and the integral is linear.
          exact h.const_smul r⁻¹
        have h₃ : (r⁻¹ : R) • (r • f) = f := by
          -- This step is algebraically true, but we need to ensure that the scalar multiplication works as expected.
          ext x
          have : (r⁻¹ : R) • (r • f x) = f x := by
            calc
              (r⁻¹ : R) • (r • f x) = ((r⁻¹ : R) • r) • f x := by
                simp [smul_smul]
              _ = (1 : R) • f x := by
                have h₄ : (r⁻¹ : R) • r = (1 : R) := by
                  simp [hr]
                rw [h₄]
              _ = f x := by simp
          exact this
        rw [h₃] at h₂
        exact h₂
    exact h₁
