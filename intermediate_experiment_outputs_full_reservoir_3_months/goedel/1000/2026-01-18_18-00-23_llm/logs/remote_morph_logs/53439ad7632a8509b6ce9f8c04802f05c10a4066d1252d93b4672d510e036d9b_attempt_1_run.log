    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro hf
    -- Since `r • f` is a bounded linear transformation of `f`, we can use the fact that bounded
    -- linear transformations preserve interval integrability.
    have h₂ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that `r • f` is a bounded linear transformation of `f`.
      have h₃ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that the set of interval integrable functions is closed under bounded linear transformations.
