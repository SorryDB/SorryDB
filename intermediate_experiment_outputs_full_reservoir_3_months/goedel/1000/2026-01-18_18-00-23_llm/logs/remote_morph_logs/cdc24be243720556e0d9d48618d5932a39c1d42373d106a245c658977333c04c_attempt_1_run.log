    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (cx*cx + cy*cy) 
    apply Exists.intro (dx*dx + dy*dy)
