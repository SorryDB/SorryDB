          have h₈ : 0 ≤ dy := by linarith
          have h₉ : 0 ≤ cx * ‖x‖ ^ 2 := by positivity
          have h₁₀ : 0 ≤ cy * ‖y‖ ^ 2 := by positivity
          have h₁₁ : 0 ≤ dx * ‖x‖ ^ 2 := by positivity
          have h₁₂ : 0 ≤ dy * ‖y‖ ^ 2 := by positivity
          have h₁₃ : re ⟪x, x⟫_𝕜 ≤ dx * ‖x‖ ^ 2 := by
            simpa using (_hx x).2
          have h₁₄ : re ⟪y, y⟫_𝕜 ≤ dy * ‖y‖ ^ 2 := by
            simpa using (_hy y).2
          nlinarith [hx x, hy y]
        exact h₄
  conj_symm := by
    intro ⟨x₁, y₁⟩ ⟨x₂, y₂⟩
