        have h₄ : (cx * cx + cy * cy) • (‖(x, y)‖ ^ 2 : ℝ) ≤ re ⟪(x, y), (x, y)⟫_𝕜 := by
          simp [Prod.norm_def, inner_add_left, inner_add_right, inner_smul_left, inner_smul_right,
