theorem parts₁_length (xs : List α) : (parts₁ xs).length = 2^(xs.length - 1) := by
  have h : ∀ (xs : List α), (parts₁ xs).length = 2^(xs.length - 1) := by
    intro xs
    induction xs with
    | nil => simp [parts₁]
    | cons x xs ih =>
      cases xs with
      | nil =>
        simp [parts₁]
      | cons y xs =>
        simp_all [parts₁, List.cons_append, List.append_assoc, pow_succ, mul_add, mul_one]
        <;>
        (try omega) <;>
        (try ring_nf at * <;> simp_all [pow_succ, mul_add, mul_one]) <;>
        (try norm_num) <;>
        (try omega) <;>
        (try
          {
            cases xs with
            | nil => simp_all [parts₁, pow_succ]
            | cons z xs =>
              simp_all [parts₁, List.cons_append, List.append_assoc, pow_succ, mul_add, mul_one]
              <;>
              (try omega) <;>
              (try ring_nf at * <;> simp_all [pow_succ, mul_add, mul_one]) <;>
              (try norm_num) <;>
              (try omega)
          }
        )
  exact h xs
