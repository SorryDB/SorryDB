def inGame (people : ℕ → ℕ)
    : ∀ (n : ℕ) → n ≥ 2 →
      (people n) = 0 →
      ¬(∃ (q : ℕ → ℕ),
        (∀ (i : ℕ), q i < 100 ∧ q i ≠ 99) ∧
        (q n) = (people n) + 1) ∧
      ¬(∃ (q : ℕ → ℕ),
        (∀ (i : ℕ), q i < 100 ∧ q i ≠ 99) ∧
        (q n) = (people n) + 1) ∧
      ¬(∃ (q : ℕ → ℕ),
        (∀ (i : ℕ), q i < 100 ∧ q i ≠ 99) ∧
        (q n) = (people n) + 1)
  := by
  intro n hn h0
  have h₁ : ¬(∃ (q : ℕ → ℕ),
