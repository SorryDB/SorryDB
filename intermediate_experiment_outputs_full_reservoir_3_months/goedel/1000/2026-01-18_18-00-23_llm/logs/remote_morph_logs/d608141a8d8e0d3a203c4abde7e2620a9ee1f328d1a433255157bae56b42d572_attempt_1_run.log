            have h₄ : IdentDistrib (fun ω ↦ X i ω) (X₂ i) (μ) (μ.prod μ) := by
              simp [X₂, identDistrib_product_right, h₂]
            -- Use the transitivity of IdentDistrib to show X₁ i and X₂ i are identically distributed
            calc
