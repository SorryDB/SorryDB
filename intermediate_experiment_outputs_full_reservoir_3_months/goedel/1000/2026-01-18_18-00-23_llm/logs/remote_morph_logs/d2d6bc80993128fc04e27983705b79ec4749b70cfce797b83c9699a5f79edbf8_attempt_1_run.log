lemma IsBinomialRandom.sup (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊔ H ω) (σ <| σ p * σ q) P where
  map_eq := by
    have h₁ : IsBinomialRandom (fun ω => (G ω)ᶜ) (σ p) P := hG.compl
    have h₂ : IsBinomialRandom (fun ω => (H ω)ᶜ) (σ q) P := hY.compl
    -- Use the properties of complements and infimum to derive the required result
    have h₃ : IsBinomialRandom (fun ω => (G ω)ᶜ ⊓ (H ω)ᶜ) (σ p * σ q) P := h₁.inf h₂
    have h₄ : IsBinomialRandom (fun ω => ((G ω)ᶜ ⊓ (H ω)ᶜ)ᶜ) (σ (σ p * σ q)) P := h₃.compl
    -- Simplify the expression to match the required form
    have h₅ : (fun ω => ((G ω)ᶜ ⊓ (H ω)ᶜ)ᶜ) = (fun ω => G ω ⊔ H ω) := by
      funext ω
      ext v
      simp [SimpleGraph.mem_sup]
      <;>
      tauto
    -- Conclude the proof by equating the distributions
    rw [h₅] at h₄
    have h₆ : σ (σ p * σ q) = σ p * σ q := by
      simp [unitInterval.symm]
      <;>
      ring_nf
      <;>
      norm_num
    simp_all [h₆]
    <;>
    aesop
  aemeasurable := by
    simp_all [IsBinomialRandom]
    <;>
    aesop
