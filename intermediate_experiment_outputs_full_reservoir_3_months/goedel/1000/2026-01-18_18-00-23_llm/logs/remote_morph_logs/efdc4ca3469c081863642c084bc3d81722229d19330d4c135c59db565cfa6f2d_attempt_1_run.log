      have h4 : MeasurableEmbedding (edgeSet : SimpleGraph V → Set (Sym2 V)) :=
        inferInstance
      -- Since edgeSet is a measurable embedding, the distribution of e₁ ∈ G ω)edgeSet is the same as the distribution of e₁ ∈ edgeSet (G ω)
      have h5 : IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₁ ∈ (G ω).edgeSet) P P := rfl
      have h6 : IsBinomialRandom G p P := hG
      -- Use the fact that the edges are independent and identically distributed to show that the distributions of e₁ and e₂ are the same
      have h7 : IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
        classical
        have h8 : ∃ (f : Ω → Bool), (fun ω ↦ e₁ ∈ (G ω).edgeSet) = f ∧ (fun ω ↦ e₂ ∈ (G ω).edgeSet) = f := by
          use fun ω => e₁ ∈ (G ω).edgeSet
