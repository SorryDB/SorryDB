theorem measurableEmbedding_symm {α β : Type*} [TopologicalSpace α] [TopologicalSpace β]
 [T2Space α] [T2Space β] {e : α → β} (h : MeasurableEmbedding e) :
  MeasurableEmbedding e.symm :=
  (measurableEmbedding_image_iff (measurableEmbedding_injective h)).mpr h.symm_symm

theorem measurableEmbedding_comap {α β : Type*} [MeasurableSpace α] [MeasurableSpace β] {e : α → β} 
  [T2Space α] [T2Space β] (h : MeasurableEmbedding e) :
  MeasurableSpace.comap e (inferInstance : MeasurableSpace β) = inferInstance := by
  rw [← h.symm.measurableEmbedding_symm.comap_eq]
  <;> simp [h.isometry]
  <;> aesop

