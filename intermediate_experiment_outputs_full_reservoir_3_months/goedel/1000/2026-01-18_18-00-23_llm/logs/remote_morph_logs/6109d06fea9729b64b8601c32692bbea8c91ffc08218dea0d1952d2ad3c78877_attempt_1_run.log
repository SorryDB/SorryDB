instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have : ∃ (a : α) (b : β), a ∈ support ($ᵗ α) ∧ b ∈ support ($ᵗ β) := by
      -- Since `α` and `β` are SampleableType, their supports are nonempty.
      have h₁ : ∃ (a : α), a ∈ support ($ᵗ α) := by
        -- Use the fact that `SampleableType.mem_support_selectElem` ensures each element is in the support.
        have h₂ : (default : α) ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem (default : α)
        exact ⟨default, h₂⟩
      have h₃ : ∃ (b : β), b ∈ support ($ᵗ β) := by
        have h₄ : (default : β) ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem (default : β)
        exact ⟨default, h₄⟩
      obtain ⟨a, ha⟩ := h₁
      obtain ⟨b, hb⟩ := h₃
      exact ⟨a, b, ha, hb⟩
    obtain ⟨a, b, ha, hb⟩ := this
    -- Use the fact that the product of supports is in the support of the product.
    have h₅ : (a, b) ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      -- Use the fact that the support of the product is the product of the supports.
      simp [support_seq_map, support_bind, ha, hb]
      <;>
      (try aesop) <;>
      (try simp_all [support_seq_map, support_bind]) <;>
      (try aesop)
    -- Since `x : α × β`, we can write `x = (a, b)` for some `a : α` and `b : β`.
    -- We need to show that `x ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β))`.
