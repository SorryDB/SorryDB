    have h₆ : x ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      -- Use the fact that the support of the product is the product of the supports.
      simp [support_seq_map, support_bind, ha, hb] at h₅ ⊢
      <;>
      (try aesop) <;>
      (try simp_all [support_seq_map, support_bind]) <;>
      (try aesop)
    -- Conclude the proof.
    exact h₆
  
  probOutput_selectElem_eq := by
    intro x y
    simp [probOutput_seq_map_eq_mul, probOutput_selectElem_eq]
    <;>
    (try aesop) <;>
    (try simp_all [probOutput_seq_map_eq_mul, probOutput_selectElem_eq]) <;>
