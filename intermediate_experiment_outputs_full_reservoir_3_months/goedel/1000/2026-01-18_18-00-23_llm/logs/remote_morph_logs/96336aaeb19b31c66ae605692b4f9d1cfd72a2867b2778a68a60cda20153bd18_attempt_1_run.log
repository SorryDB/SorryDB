```lean
theorem infinity_of_primes₁ (S : Finset ℕ) (h : ∀ q ∈ S, Nat.Prime q):
  ∃ (p : ℕ), Nat.Prime p ∧ p ∉ S := by
  have h_main : ∃ (p : ℕ), Nat.Prime p ∧ p ∉ S := by
    let n := 1 + ∏ q ∈ S, q
    have h₁ : n ≠ 1 := by
      have h₂ : ∏ q ∈ S, q ≥ 0 := by positivity
      have h₃ : 1 + ∏ q ∈ S, q > 1 := by
        have h₄ : ∏ q ∈ S, q ≥ 0 := by positivity
        have h₅ : 1 + ∏ q ∈ S, q > 1 := by
          by_contra h₆
          have h₇ : 1 + ∏ q ∈ S, q ≤ 1 := by linarith
          have h₈ : ∏ q ∈ S, q = 0 := by omega
          have h₉ : S = ∅ := by
            by_contra h₁₀
            have h₁₁ : ∏ q ∈ S, q > 0 := Finset.prod_pos fun q hq => (h q hq).pos
            omega
          simp_all [h₉]
        exact h₅
      omega
    -- p is the smallest prime factor of n
    let p := n.minFac
