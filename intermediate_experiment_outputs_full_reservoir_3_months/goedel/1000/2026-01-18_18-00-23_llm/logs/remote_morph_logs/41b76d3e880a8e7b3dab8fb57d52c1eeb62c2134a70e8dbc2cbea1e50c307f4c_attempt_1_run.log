theorem RelInt.liftFinf_in' {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
  (∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j) →
  rule ∈ (RelInt.liftFinf n f) := by
  intro ⟨i, j, Hij⟩
  rw [Hij]
  unfold liftFinf
  simp only [RelInt, List.get_eq_getElem, List.mem_flatten, List.mem_map]
  -- We need to show that there exists a sublist in the map of f over fin_range n such that the j-th element of f i is in that sublist.
  -- Since i is in fin_range n and we can choose a = i, we have f i in the map, and (f i)[j] is trivially in f i.
  refine' ⟨f i, ⟨i, _⟩, _⟩
  <;> simp_all [Fin.forall_fin_succ]
  <;> try decide
  <;> try omega
