```lean
theorem coerceLang_mem_imp_word_of_type :
  ∀ word : Word α, ∀ G : Grammar Prod,
  word ∈ coerceLang α G.Z G.GeneratedLanguage →
  ∃ word₂ : Word G.Z, word₂ ∈ G.GeneratedLanguage ∧ coerceWord α G.Z word₂ = word := by
  intro word G h
  have h₁ : ∃ (w : Word G.Z), w ∈ G.GeneratedLanguage ∧ coerceWord α G.Z w = word := by
    have h₂ : word ∈ coerceLang α G.Z G.GeneratedLanguage := h
    -- By definition of coerceLang, there exists a word w in G.GeneratedLanguage such that coerceWord w = word
    simp only [coerceLang, exists_prop] at h₂
    -- Extract the witness from the existential quantifier
    obtain ⟨w, hw₁, hw₂⟩ := h₂
    refine' ⟨w, hw₁, _⟩
    -- Coerce the word w to Word α and check that it equals word
    <;> simp_all [coerceWord]
    <;> aesop
  
  have h₂ : ∃ word₂ : Word G.Z, word₂ ∈ G.GeneratedLanguage ∧ coerceWord α G.Z word₂ = word := by
    obtain ⟨w, hw₁, hw₂⟩ := h₁
    exact ⟨w, hw₁, hw₂⟩
  
  exact h₂
