theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable
      intro h
      -- Use the fact that scalar multiplication preserves integrability under boundedness conditions
      have h₁ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
        -- Use the property of interval integrability under bounded linear operators
        have h₂ : Continuous (fun x : E => r • x) := by
          -- Prove that scalar multiplication by r is continuous
          continuity
        -- Use the fact that continuous linear operators preserve integrability
        exact h.comp_smul r
      exact h₁
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable
      intro h
      -- Use the fact that scalar multiplication preserves integrability under boundedness conditions
      have h₁ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := h
      -- Use the property of interval integrability under bounded linear operators
      by_cases hr : r = 0
      · -- If r = 0, then r • f = 0, and we can directly conclude that f is interval integrable
        have h₂ : (fun x : ℝ => r • f x) = fun x : ℝ => (0 : E) := by
          funext x
          simp [hr]
        have h₃ : IntervalIntegrable (fun x : ℝ => (0 : E)) μ a b := by
          -- The zero function is interval integrable
          exact intervalIntegrable_zero
        have h₄ : IntervalIntegrable f μ a b := by
          -- Since r • f = 0, we can use the fact that 0 is interval integrable to conclude
          simpa [h₂] using h₃
        exact h₄
      · -- If r ≠ 0, we can use the boundedness of the inverse operation to preserve integrability
        have h₂ : Continuous (fun x : E => r⁻¹ • x) := by
          -- Prove that scalar multiplication by r⁻¹ is continuous
          continuity
        -- Use the fact that continuous linear operators preserve integrability
        have h₃ : IntervalIntegrable (fun x : ℝ => r⁻¹ • (r • f x)) μ a b := h₁.comp_smul r⁻¹
        -- Simplify the expression to show that f is interval integrable
        have h₄ : (fun x : ℝ => r⁻¹ • (r • f x)) = f := by
          funext x
          simp [smul_smul, hr]
          <;> field_simp [hr]
          <;> simp_all
        have h₅ : IntervalIntegrable f μ a b := by
          simpa [h₄] using h₃
        exact h₅
  exact h_main
