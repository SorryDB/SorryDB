theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable
    intro h
    -- Use the fact that bounded SMul preserves integrability
    have h₁ : IntervalIntegrable (fun x => r • f x) μ a b := by
      -- Use the boundedness of the smul to show integrability
      have h₂ : IntervalIntegrable (fun x => r • f x) μ a b := by
        -- Use the fact that r • f is the smul of an integrable function
        have h₃ : IntervalIntegrable f μ a b := h
        -- Use the boundedness of the smul to show integrability
        have h₄ : IntervalIntegrable (fun x => r • f x) μ a b :=
          h₃.smul r
        exact h₄
      exact h₂
    exact h₁
  · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable
    intro h
    -- Since r is non-zero, we can divide by r to recover f
    have h₁ : IntervalIntegrable f μ a b := by
      -- Use the fact that r • f is interval integrable and r is non-zero
      by_cases hr : r = 0
      · -- If r = 0, then r • f = 0, and the interval integrability of 0 implies f is zero almost everywhere
        have h₂ : (r : R) = 0 := hr
        have h₃ : IntervalIntegrable (fun x => (r : R) • f x) μ a b := h
        have h₄ : (fun x => (r : R) • f x) = fun x => (0 : R) := by
          funext x
          simp [h₂]
        rw [h₄] at h₃
        have h₅ : IntervalIntegrable (fun x => (0 : R)) μ a b := h₃
        have h₆ : IntervalIntegrable (fun x => (0 : R)) μ a b := h₅
        -- Since r = 0, we can deduce that f is zero almost everywhere, hence interval integrable
        have h₇ : IntervalIntegrable (fun x => f x) μ a b := by
          -- Here we use the fact that f is zero almost everywhere, but we don't have that directly
          -- Instead, we use the fact that the zero function is interval integrable and the properties of smul
          simp_all [intervalIntegrable_zero]
          <;>
          try
            simp_all [intervalIntegrable_zero]
          <;>
          try
            simp_all [intervalIntegrable_zero]
        exact h₇
      · -- If r ≠ 0, we can divide by r to recover f
        have h₂ : (r : R) ≠ 0 := hr
        have h₃ : IntervalIntegrable (fun x => (r : R) • f x) μ a b := h
        have h₄ : IntervalIntegrable (fun x => f x) μ a b := by
          -- Use the fact that r ≠ 0 to divide by r and recover f
          have h₅ : IntervalIntegrable (fun x => (r : R)⁻¹ • ((r : R) • f x)) μ a b := by
            -- Use the fact that r⁻¹ is a bounded smul
            have h₆ : IntervalIntegrable (fun x => (r : R) • f x) μ a b := h₃
            have h₇ : IntervalIntegrable (fun x => (r : R)⁻¹ • ((r : R) • f x)) μ a b := by
              -- Use the boundedness of the smul to show integrability
              have h₈ : IntervalIntegrable (fun x => (r : R) • f x) μ a b := h₆
              have h₉ : IntervalIntegrable (fun x => (r : R)⁻¹ • ((r : R) • f x)) μ a b :=
                h₈.smul (r⁻¹ : R)
              exact h₉
            exact h₇
          -- Simplify the expression (r⁻¹ • (r • f)) to f
          have h₈ : (fun x => (r : R)⁻¹ • ((r : R) • f x)) = (fun x => f x) := by
            funext x
            have h₉ : (r : R)⁻¹ • ((r : R) • f x) = f x := by
              rw [← smul_smul]
              simp [h₂]
              <;>
              simp_all [h₂]
            rw [h₉]
          rw [h₈] at h₅
          exact h₅
        exact h₄
    exact h₁

