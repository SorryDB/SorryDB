lemma of_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∈ construction_omega T hT) :
  (χ ➝ φ ∈ T.theory) ∨ (∀ Γ : Finset _, ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) := by
  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  induction i with
  | zero =>
    left
    simpa [construction] using hi
  | succ i ih =>
    dsimp [construction] at hi
    have h₁ : φ ∈ (if ∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT i → Γ.conj ⋏ (decode' i ∣ φ) ➝ ξ ∉ T.theory then insert (decode' i ∣ φ) (construction T hT i) else construction T hT i) := by
      simpa [match_1, Option.some] using hi
    split_ifs at h₁ with h₂
    · -- Case: the set is extended by insert (decode' i ∣ φ)
      have h₃ : φ = (decode' i ∣ φ) ∨ φ ∈ construction T hT i := by
        simp_all [Set.mem_insert_iff]
      cases h₃ with
      | inl h₃ =>
        subst_vars
        simp_all [Function.comp]
      | inr h₃ =>
        apply ih
        <;> simp_all [subset_construction_succ, subset_construction_add]
        <;> omega
    · -- Case: the set is not extended
      apply Or.inr
      intro Γ hΓ
      have h₃ : (encode φ) ≥ i + 1 := by
        have h₄ : φ ∈ construction T hT (i + 1) := hi
        have h₅ : ¬∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT i → Γ.conj ⋏ (decode' i ∣ φ) ➝ ξ ∉ T.theory := by tauto
        have h₆ : i + 1 ≤ encode φ := by
          by_contra h₆
          have h₇ : encode φ < i + 1 := by omega
          have h₈ : encode φ ≤ i := by omega
          have h₉ : φ ∈ construction T hT (encode φ) := by
            have h₁₀ : φ ∈ construction T hT (i + 1) := hi
            have h₁₁ : construction T hT (encode φ) ⊇ construction T hT (i + 1) := by
              apply subset_construction_add
            exact h₁₁ h₁₀
          have h₁₀ : φ ∈ construction T hT (i + 1) := hi
          have h₁₁ : encode φ ≤ i := by omega
          simp_all [subset_construction_add]
          <;> omega
        omega
      -- Continue with the proof for the case where the set is not extended
      have h₄ : ∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory := by
        intro Γ hΓ
        have h₅ : (encode φ) ≥ i + 1 := h₃
        have h₆ : ¬∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT i → Γ.conj ⋏ (decode' i ∣ φ) ➝ ξ ∉ T.theory := by tauto
        -- Use the fact that the set is not extended to conclude the proof
        simp_all [subset_construction_add]
        <;>
          (try omega) <;>
          (try tauto) <;>
          (try
            {
              exfalso
              simp_all [subset_construction_add]
              <;>
                omega
            }) <;>
          (try
            {
              simp_all [subset_construction_add]
              <;>
                omega
            })
      exact h₄ Γ hΓ
