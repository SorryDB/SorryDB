open scoped FintypeCat

@[default_instance]
instance : Fintype (Finset ℕ) where
  fintype := by
    classical
    exact Fintype.ofFinset (Finset.Iic (Finset.card (Finset.Iic 0)))

def radiating_type (s : Finset ℕ) : Type u := s

def radiating_instance (s : Finset ℕ) [Fintype s] : True := ⟨⟩

def radiating_fintype (s : Finset ℕ) : Fintype (radiating_type s) :=
  inferInstance

@[default_instance]
instance (s : Finset ℕ) : Fintype (radiating_type s) := by
  infer_instance

def radiating_type_is_decreasing {s t : Finset ℕ} (h : s ⊆ t) : radiating_type s → radiating_type t := by
  intro x
  exact ⟨x.1, by aesop⟩

def radiating_scores (s : Finset ℕ) : ℕ := s.card

def radiating_subscore {s t : Finset ℕ} (h : s ⊆ t) : radiating_scores s ≤ radiating_scores t := by
  have h₁ : s.card ≤ t.card := Finset.card_le_of_subset h
  exact h₁

def radiating_map {s t : Finset ℕ} (h : s ⊆ t) : radiating_type s → radiating_type t := by
  intro x
  exact ⟨x.1, by aesop⟩

def radiating_system_of_measurements : ∀ (s : Finset ℕ), Nonempty (radiating_type s) := by
  intro s
  have h : s ∈ Finset.univ := Finset.mem_univ s
  have h₁ : Nonempty (radiating_type s) := by
    by_cases h₂ : s = ∅
    · subst h₂
      exact ⟨⟨0, by simp⟩⟩
    · have h₃ : s.Nonempty := Finset.nonempty_iff_ne_empty.mpr h₂
      obtain ⟨x, hx⟩ := h₃
      exact ⟨⟨x, by aesop⟩⟩
  exact h₁

def radiating_norms (s : Finset ℕ) : ℝ := (s.card : ℝ)

def radiating_subnorm {s t : Finset ℕ} (h : s ⊆ t) : radiating_norms s ≤ radiating_norms t := by
  have h₁ : (s.card : ℝ) ≤ (t.card : ℝ) := by
    exact_mod_cast Finset.card_le_of_subset h
  exact h₁

