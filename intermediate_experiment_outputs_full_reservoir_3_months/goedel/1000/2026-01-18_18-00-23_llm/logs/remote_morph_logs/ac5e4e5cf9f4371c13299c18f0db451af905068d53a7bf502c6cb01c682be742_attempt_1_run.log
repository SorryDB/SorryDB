def map_seq (α β : Type*) [Inhabited α] [Inhabited β] (f : α → β) :
    NecessitySequence α → NecessitySequence β :=
  fun x ↦ ⟨fun n ↦ f (x.nth n), _⟩
  <;> simp

def map (Si T : FintypeCat) (c : ℤ) (f : Si → T) :
    (set Si c) → (set T c) :=
  fun a ↦
    { support := Multiset.map (fun (i : Si) ↦ f i) a.support,
      toFun := fun (j : T) ↦
        if h : j ∈ Multiset.image (fun (i : Si) ↦ f i) a.support then
          a.toFun (Classical.choose h)
        else
          0,
      mem_support := by
        intro j hj
        simp only [Finset.mem_filter, Finset.mem_univ, true_and_iff] at hj
        simp_all [NecessitySequence.map, Inhabited] }
  <;> simp_all [set]
  <;> aesop

def has_sum_image (α β : Type*) [Inhabited α] [Inhabited β] (f : α → β) (a : NecessitySequence α) :
    ∑' (i : α), a i = ∑' (i : α), (NecessitySequence.map f a) i := by sorry

def sum_map {α β : Type*} [Inhabited α] [Inhabited β] (f : α → β) (a : NecessitySequence α) :
    ∑' (i : α), a i = ∑' (i : α), (NecessitySequence.map f a) i := by sorry

  <;> aesop
