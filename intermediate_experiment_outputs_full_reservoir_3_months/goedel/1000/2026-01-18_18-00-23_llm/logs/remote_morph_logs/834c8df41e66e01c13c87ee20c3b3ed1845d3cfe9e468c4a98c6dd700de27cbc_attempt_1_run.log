| .one, Hist, X => -- case k(x)=1
    if X ∈ Hist ∨ isExitIn X C
      then [ ] -- then x is a leaf
      else [ QNode .two X (Qchildren C .two (X :: Hist) X) ]
| .two, Hist, X => -- case k(x)=2
