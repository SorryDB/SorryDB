    calc
      ( 𝕜.image (fun s ↦ (s.1, s.2)).card ) ≤ 𝕜.card := by
        apply Finset.card_image_le
      _ ≤ d * 𝕜.card := by
        have h₃ : 𝕜.card ≤ d * 𝕜.card := by
          have h₄ : d ≥ 1 := by
            -- Since the family is non-trivial, there exists at least one set in 𝕜
