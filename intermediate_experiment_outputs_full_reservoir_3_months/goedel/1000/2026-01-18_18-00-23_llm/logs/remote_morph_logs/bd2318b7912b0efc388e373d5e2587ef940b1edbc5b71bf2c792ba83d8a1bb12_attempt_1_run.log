theorem trace(xs : List Nat) : Nat :=xs.foldl (λ acc x, acc + x)0
theorem trace_nil : trace []=0 :=rfl
theorem trace_cons (x xs) : trace (x :: xs) = x + trace xs := by
 simp [trace, List.foldl]
theorem trace_append (xs ys : List Nat) : trace (xs ++ ys) = trace xs + trace ys := by
 induction xs with
 | nil => simp [trace_nil]
 | cons x xs ih =>
  simp_all [trace_cons, List.append_assoc]
  <;> ring__nf at *
  <;> omega
