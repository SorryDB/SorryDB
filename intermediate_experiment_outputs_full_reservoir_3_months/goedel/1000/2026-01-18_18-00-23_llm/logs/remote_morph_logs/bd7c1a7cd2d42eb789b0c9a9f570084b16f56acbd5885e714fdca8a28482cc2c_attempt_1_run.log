def M : Type := ℝ³

def N : Type := ℝ²

structure Pose where
  inner : Euc(3) →L[ℝ] Euc(2)
  outer : Euc(3) →L[ℝ] Euc(2)

  innerParams : Euc(3)
  outerParams : Euc(2)

protected def M (p : Pose) : Euc(2) →L[ℝ] Euc(2) :=
  ContinuousLinearMap.mat (p.inner.toMatrix ![(1 : ℝ), 0, 0] : Matrix (Fin 2) (Fin 3) ℝ)

protected def N (p : Pose) : Euc(2) →L[ℝ] Euc(2) :=
  ContinuousLinearMap.mat (p.outer.toMatrix ![(1 : ℝ), 0, 0] : Matrix (Fin 2) (Fin 3) ℝ)

protected def M₁ (p : Pose) : Euc(3) →L[ℝ] Euc(3) := 1

protected def M₁θ (p : Pose) : Euc(3) →L[ℝ] Euc(3) := 1

protected def M₁φ (p : Pose) : Euc(3) →L[ℝ] Euc(3) := 1

