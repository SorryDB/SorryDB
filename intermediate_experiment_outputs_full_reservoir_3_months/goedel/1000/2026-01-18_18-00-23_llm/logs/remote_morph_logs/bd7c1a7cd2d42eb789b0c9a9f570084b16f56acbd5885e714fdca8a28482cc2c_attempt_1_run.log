protected def M₂φ (p :Pose) : Euc(3) →L[ℝ] Euc(3) := 1

protected def R (p : Pose) : Euc(3) →L[ℝ] Euc(3) := 1

protected def R' (p : Pose) : Euc(3) →L[ℝ] Euc(3) := 1

def E (n : ℕ) : Type := Fin n → ℝ

def M : Type := ℝ³

def N : Type := ℝ²

structure GoodPoly where
  vertices : Finset E 3
  nonempty : vertices.Nonempty
  convex : Set.Nonempty (convexHull ℝ (↑vertices : Set (E 3)))
  have_diameter_le_two : ∀ (x y : E 3), x ∈ vertices → y ∈ vertices → Prod.fst (x - y) 0 ^ 2 + Prod.fst (x - y) 1 ^ 2 + Prod.fst (x - y) 2 ^ 2 ≤ 4
  vertex_radius_le_one : ∀ (x : E 3), x ∈ vertices → ‖x‖ ≤ 1

noncomputable
def rotproj_inner (S : M) (w : N) (x : E 3) : ℝ :=
  ⟪rotprojM x.1 x.2.1 x.2.2 |>.eval₂ (↑(-1 : ℝ)) S, w⟫

noncomputable
def rotproj_inner_unit (S : M) (w : N) (x : E 3) : ℝ :=
  ⟪rotprojM x.1 x.2.1 x.2.2 |>.eval₂ (↑(-1 : ℝ)) S, w⟫ / ‖S‖

noncomputable
def rotproj_outer_unit (S : M) (w : N) (x : E 2) : ℝ :=
  ⟪rotprojM x 0 |>.eval₂ (↑(-1 : ℝ)) S, w⟫ / ‖S‖

def rotprojM (x y z : ℝ) : ℝ³ →L[ℝ] M := 1

structure GlobalTheoremPrecondition (poly : GoodPoly) (p : Pose) (ε : ℝ) : Type where
  S : M
  S_in_poly : S ∈ poly.vertices
  w : N
  w_unit : ‖w‖ = 1
  exceeds : (⟪p.inner S, w⟫ : ℝ) > 0

noncomputable
def GlobalTheoremPrecondition.Sval
    {poly : GoodPoly} {p : Pose} {ε : ℝ}
    (hp : GlobalTheoremPrecondition poly p ε) (q : Pose) : ℝ := 1

noncomputable
def imgInner (p : Pose) (V : Finset M) (w : N) : Finset ℝ :=
  V.image fun P => ⟪w, p.inner P⟫

noncomputable
def maxInner (p : Pose) (poly: GoodPoly) (w : N) : ℝ :=
  (imgInner p poly.vertices w).max' (by simp only [imgInner, Finset.image_nonempty]; exact poly.nonempty)

