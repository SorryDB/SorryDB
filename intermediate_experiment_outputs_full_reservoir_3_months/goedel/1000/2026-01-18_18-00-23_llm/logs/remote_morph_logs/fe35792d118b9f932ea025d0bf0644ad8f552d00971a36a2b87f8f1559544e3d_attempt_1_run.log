      -- We use the fact that each agent needs at least n-1 calls to become an expert
      -- and that there are n agents, but we need to account for overlaps and the structure of the calls
      -- Here, we use a simpler approach: if the sequence is too short, it cannot possibly spread all secrets
      -- We use the fact that 2n - 4 is the minimal number of calls required for all agents to become experts
      have h₅ : σ.length < 2 * n - 4 := h₂
      have h₆ : 2 * n - 4 > 0 := by
        have h₇ : n ≥ 5 := by omega
        have h₈ : 2 * n ≥ 10 := by omega
