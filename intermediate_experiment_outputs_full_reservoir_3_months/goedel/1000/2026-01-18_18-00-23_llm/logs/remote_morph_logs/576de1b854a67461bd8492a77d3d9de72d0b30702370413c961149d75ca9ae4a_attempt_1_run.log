theorem equivalent_CNF_Grammar :
  ∀ α nt nt₂,
  ∀ cfg : {cfg : ContextFreeGrammar α nt | ε ∉ cfg.GeneratedLanguage},
  ∃ cfg₂ : { cfg₂ : ContextFreeGrammar α nt₂ // isInChomskyNormalForm cfg₂},
    coerceLang α (↑cfg).Z (↑cfg).GeneratedLanguage
    =
    coerceLang α (↑cfg₂).Z (↑cfg₂).GeneratedLanguage := by
  intro α nt nt₂
  introcfg : { cfg : ContextFreeGrammar α nt | ε ∉ cfg.GeneratedLanguage }
  have h_generate_CNF := generate_equivalent_CNF (⟨(↑cfg : ContextFreeGrammar α nt), by simpa using cfg.2⟩)
  refine' ⟨h_generate_CNF, _⟩
  have h_eq := generate_equivalent_CNF_is_eq α nt nt₂
  <;> simp_all [coerceLang]
  <;> aesop
```
