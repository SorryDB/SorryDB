    have h₂ : (∫ x : EuclideanSpace ℝ (Fin (d + 1)), x * (↑m / volume.real (Metric.closedBall (0 : EuclideanSpace ℝ (Fin (d + 1))) ↑R) * ∫ x in Metric.closedBall (0 : EuclideanSpace ℝ (Fin (d + 1))) ↑R, (1 : ℝ) ∂volume) ∂volume) = (↑m / volume.real (Metric.closedBall (0 : EuclideanSpace ℝ (Fin (d + 1))) ↑R) * ∫ x in Metric.closedBall (0 : EuclideanSpace ℝ (Fin (d + 1))) ↑R, (1 : ℝ) ∂volume) * (∫ x : EuclideanSpace ℝ (Fin (d + 1)), x ∂volume) := by
