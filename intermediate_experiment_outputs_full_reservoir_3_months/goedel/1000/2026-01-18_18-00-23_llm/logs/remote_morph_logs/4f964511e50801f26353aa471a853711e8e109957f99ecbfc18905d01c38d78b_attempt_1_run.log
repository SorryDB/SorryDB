lemma solidSphere_centerOfMass {d : ℕ} (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere d.succ m R).centerOfMass = 0 := by
  have h₁ : (solidSphere d.succ m R).centerOfMass = 0 := by
    simp only [centerOfMass, solidSphere, div_eq_mul_inv, mul_assoc]
    have h₂ : ( @volume (Space d.succ) measureSpaceOfInnerProductSpace).real
      (Metric.closedBall (0 : Space d.succ) R) ≠ 0 := by
      refine (measureReal_ne_zero_iff ?_).mpr ?_
      · rw [EuclideanSpace.volume_closedBall]
        simp
        exact not_eq_of_beq_eq_false rfl
      · rw [EuclideanSpace.volume_closedBall]
        simp only [ENNReal.ofReal_coe_nnreal, Nat.succ_eq_add_one, Fintype.card_fin, Nat.cast_add,
          Nat.cast_one, ne_eq, mul_eq_zero, Nat.add_eq_zero, one_ne_zero, and_false,
          not_false_eq_true, pow_eq_zero_iff, ENNReal.coe_eq_zero, ENNReal.ofReal_eq_zero, not_or,
          not_le]
        apply And.intro
        · exact hr
        · positivity
    -- Simplify the integral to show that it evaluates to zero
    have h₃ : (∫ x : Space d.succ in Metric.closedBall (0 : Space d.succ) R,
      (x : Space d.succ) ∂volume) = 0 := by
      -- Use the fact that the integral of an odd function over a symmetric region is zero
      simp [integral_zero]
      <;>
      simp_all [MeasureTheory.integral_comp_sub_left]
      <;>
      simp_all [MeasureTheory.integral_comp_sub_left]
      <;>
      norm_num
      <;>
      aesop
    -- Use the simplified integral to show that the center of mass is zero
    field_simp [h₂] at h₃ ⊢
    <;> simp_all [h₃]
    <;>
    aesop
  exact h₁
