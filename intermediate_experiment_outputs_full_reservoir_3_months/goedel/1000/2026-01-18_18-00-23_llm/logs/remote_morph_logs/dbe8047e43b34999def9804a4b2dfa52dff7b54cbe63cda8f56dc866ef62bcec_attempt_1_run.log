```lean
#check MeasureTheory.Measure.pi.isProbabilityMeasure

def WignerMeasure (n : ‚Ąē) : Measure (WignerSpace n) :=
  Measure.pi (fun (p : Index n) => if p.val.1 = p.val.2 then őĹ else őľ)

instance instIsProbabilityMeasure (n : ‚Ąē) : IsProbabilityMeasure (WignerMeasure őľ őĹ n) := by
  rw [WignerMeasure]
  -- We need to prove that the product measure of the measures `őĹ` and `őľ` is a probability measure.
  -- Since `őľ` and `őĹ` are probability measures, and the product of probability measures is a probability measure,
  -- we can use the fact that all factors are probability measures to get that the product is as well.
  refine' (MeasureTheory.Measure.pi_isProbabilityMeasure _)
  intro i
  -- For each index `i`, we need to check whether the corresponding measure is a probability measure.
  -- If `i.val.1 = i.val.2`, then the measure is `őĹ`, which is a probability measure by assumption.
  -- If `i.val.1 ‚Č† i.val.2`, then the measure is `őľ`, which is also a probability measure by assumption.
  by_cases h : (i : Index n).val.1 = (i : Index n).val.2
  ¬∑ -- Case: i.val.1 = i.val.2
    simp [h]
    <;> exact inferInstance
  ¬∑ -- Case: i.val.1 ‚Č† i.val.2
    simp [h]
    <;> exact inferInstance
