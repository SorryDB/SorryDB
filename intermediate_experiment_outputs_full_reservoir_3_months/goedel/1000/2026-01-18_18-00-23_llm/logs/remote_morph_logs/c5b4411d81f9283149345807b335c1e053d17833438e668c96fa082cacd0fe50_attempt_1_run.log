theorem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (j.rev + i) := by
  have h₀ : False := by
    -- Since S is a finite set of odd primes, it must be nonempty if we can find an element in it.
    by_cases h : S = ∅
    · -- If S is empty, then p₁ and p₂ are bijections from Fin 0 to ∅, which is impossible.
      subst h
      have h₁ := p₁.symm
      simp [Equiv.symm_apply_apply] at h₁
      <;> exfalso
      <;> simp_all [Finset.card_eq_zero]
      <;> contradiction
    · -- If S is not empty, then we can find an element in S.
      have h₂ : S.Nonempty := Finset.nonempty_iff_ne_empty.mpr h
      -- Extract an element from S and use it to derive a contradiction.
      obtain ⟨p, hp⟩ := h₂
      have h₃ := hS p hp
      have h₄ : p.Prime := h₃.2
      have h₅ : Odd p := h₃.1
      -- Use the fact that p is an odd prime to show that it leads to a contradiction.
      have h₆ := hp₁ ⟨0, by
        have h₇ : 0 < #S := by
          have h₈ : 0 < S.card := Finset.card_pos.mpr h₂
          simp_all [Nat.cast_pos]
          <;> omega
        omega⟩
