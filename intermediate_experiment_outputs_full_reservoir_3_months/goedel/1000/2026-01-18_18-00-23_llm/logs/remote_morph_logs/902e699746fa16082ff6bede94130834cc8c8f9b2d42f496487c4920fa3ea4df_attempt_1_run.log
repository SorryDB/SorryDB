namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · -- Prove the first part: ∃ m, p = 4 * m + 1 → num_solutions = 2
    use 0
    intro h₁
    exfalso
    have h₂ : p = 1 := by
      omega
    have h₃ : p.Prime := h.1
    have h₄ : p ≥ 2 := Nat.Prime.two_le h₃
    omega
  · constructor
    · -- Prove the second part: p = 2 → num_solutions = 1
      intro hp
      -- For p = 2, we need to show that there is exactly one solution to s^2 = -1 in ZMod 2
      have h₁ : p = 2 := hp
      have h₂ : p.Prime := h.1
      have h₃ : {s : ZMod p | s ^ 2 = -1} = {1} := by
        subst_vars
        -- In ZMod 2, the elements are 0 and 1
        -- Check each element to see if it satisfies s^2 = -1
        decide
      -- The cardinality of {1} is 1
      simp_all [h₃]
      <;> rfl
    · -- Prove the third part: ∃ m, p = 4 * m + 1 → num_solutions = 0
      use p
      intro h₁
      -- If p = 4 * p + 1, then p would have to be negative, which is impossible since p is a prime number
      have h₂ : p = 4 * p + 1 := by omega
      have h₃ : p ≥ 2 := Nat.Prime.two_le h.1
      omega
