### Solution

```lean
  · use 0
    intro h₁
    exfalso
    -- If p = 4*0 + 1 = 1, but p is a prime, so p cannot be 1.
    have h₂ : p = 1 := by
      omega
    have h₃ : p.Prime := Fact.out (p := p.Prime)
    have h₄ : ¬ p.Prime := by
      rw [h₂]
      decide
    exact h₄ h₃
```
