```lean
def makeDonut (minRadius : ℝ) (maxRadius : ℝ) (points : ℕ) (angleFactor : ℝ) 
  (lineLength : ℝ) : List (List (ℝ × ℝ)) := 
    let pointsOnCircumference : List (ℝ × ℝ) := 
      List.range points |>.map (fun i => 
        let angle : ℝ := 2 * Real.pi * (i : ℝ) / points * angleFactor
        let x : ℝ := maxRadius * Real.cos angle
        let y : ℝ := maxRadius * Real.sin angle
        (x, y)
      )
    let innerCircle : List (ℝ × ℝ) := 
      List.range points |>.map (fun i => 
        let angle : ℝ := 2 * Real.pi * (i : ℝ) / points * angleFactor
        let x : ℝ := minRadius * Real.cos angle
        let y : ℝ := minRadius * Real.sin angle
        (x, y)
      )
    let donut : List (List (ℝ × ℝ)) := 
      innerCircle.zip pointsOnCircumference |>.map (fun (inner, outer) => 
        [(0, 0), inner, outer, (0, 0)]
      )
    donut
```

The `makeDonut` function now correctly defines a donut shape with an inner and outer circle, connected by lines from the origin. The `donut` list contains lists of points representing the lines from the origin to the inner circle, then to the outer circle, and back to the origin. This ensures the donut is properly represented as a list of connected line segments.
