  have h₂ : ∃ (a b : Finset ℕ), a ⊆ S ∧ b ⊆ S ∧ Disjoint a b ∧ 0 < a.card ∧ 0 < b.card ∧ ∑ x ∈ a, x = ∑ x ∈ b, x := by
