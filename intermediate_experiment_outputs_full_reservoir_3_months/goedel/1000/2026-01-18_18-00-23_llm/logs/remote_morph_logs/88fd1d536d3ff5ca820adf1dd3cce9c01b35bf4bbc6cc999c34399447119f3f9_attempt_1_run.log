lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := by
      -- The integral of f against the complex measure is equal to the linear functional evaluated at f.
      simp [ComplexMeasure.integral, cfc_toComplexMeasure, ComplexRieszMeasure.integral_eq_apply]
      <;>
      simp_all [ContinuousLinearMap.apply_smul]
      <;>
      try simp_all [LinearMap.smul_apply]
      <;>
      try ring_nf
      <;>
      try simp_all [norm_smul, Complex.norm_eq_abs]
      <;>
      try simp_all [Complex.norm_eq_abs]
      <;>
      try simp_all [Complex.abs_abs]
      <;>
      try simp_all [ContinuousLinearMap.norm_eq]
    rw [h₂]
    -- Use the fact that the norm of the linear functional is bounded by the product of the norms of x and y.
    have h₃ : ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
      calc
        ‖(cfc_toLinearFunctional ha x y) f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := rfl
        _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
          -- Use the fact that the norm of a continuous linear map is bounded by its operator norm.
          calc
            ‖(cfc_toLinearFunctional ha x y) f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := rfl
            _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
              -- Use the property of continuous linear maps.
              apply ContinuousLinearMap.le_opNorm
    -- Combine the inequalities to get the final result.
    linarith
  -- Combine with the bound on the norm of the linear functional.
  have h₂ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
    apply cfc_toLinearFunctional_bound
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₁
    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by
      gcongr
      <;>
      simp_all [norm_nonneg]
    _ = ‖x‖ * ‖y‖ * ‖f‖ := by
      ring
      <;>
      simp_all [mul_assoc]
      <;>
      simp_all [norm_nonneg]
