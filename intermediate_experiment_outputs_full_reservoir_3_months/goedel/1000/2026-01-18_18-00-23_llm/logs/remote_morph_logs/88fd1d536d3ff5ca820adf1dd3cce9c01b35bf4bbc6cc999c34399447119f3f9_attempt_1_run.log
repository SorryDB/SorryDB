lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := by
      simp [cfc_toComplexMeasure, ComplexMeasure.integral,
        ZeroAtInftyContinuousMap.integral_eq_cofiniteIntegral]
      <;>
      simp_all [ComplexLinearMap.coe_injective,
        ContinuousLinearMap.coe_injective, Function.funext_iff]
      <;>
      congr 1 <;>
      ext f <;>
      simp [cfc_toLinearFunctional_apply]
    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by
      apply norm_image_le
    _ ≤ (‖x‖ * ‖y‖) * ‖(f : C((spectrum ℂ a), ℂ))‖ := by
      gcongr
      <;>
      (try norm_num) <;>
      (try simp_all [cfc_toLinearFunctional_bound]) <;>
      (try assumption) <;>
      (try linarith)
    _ = ‖x‖ * ‖y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by ring
