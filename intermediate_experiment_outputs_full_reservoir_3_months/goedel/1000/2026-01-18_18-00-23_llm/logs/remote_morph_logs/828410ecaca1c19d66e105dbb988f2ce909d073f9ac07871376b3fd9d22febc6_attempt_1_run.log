    have z₀ : MeromorphicOn (fun x ↦ f (circleMap 0 r x) - circleMap 0 1 a) (uIcc 0 (2 * Real.pi)) := by
      have h₁ : MeromorphicOn (fun x : ℂ => f (circleMap 0 r ↑x) - circleMap 0 1 (a : ℝ)) ⊤ := by
        -- Show that the function is meromorphic on the whole space ⊤
        apply MeromorphicOn.sub
        · -- f ∘ circleMap 0 r is meromorphic on ⊤
          apply h.comp
          · -- circleMap 0 r is holomorphic on ⊤
            exact (CircleMap.holomorphicOn _ _).1
          · -- Since ⊤ is the whole space, no issue with the domain
            trivial
        · -- circleMap 0 1 is constant and thus meromorphic on ⊤
          exact meromorphicOn_const
      -- Restrict the meromorphic function to the interval [0, 2π]
      have h₂ : MeromorphicOn (fun x ↦ f (circleMap 0 r x) - circleMap 0 1 a) (uIcc 0 (2 * Real.pi)) := by
        apply h₁.mono
        -- Any subset of ⊤ is trivially a subset
        simp [Set.subset_univ]
      exact h₂
