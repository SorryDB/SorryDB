theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    have h₂ : (fun x : ℝ => r • f x) = r • f := by rfl
    -- We use the fact that the scalar multiplication of a function by a fixed element is equivalent to the scalar multiplication of the function.
    simp_all [h₂]
    <;>
    (try norm_num) <;>
    (try simp_all [IntervalIntegrable]) <;>
    (try aesop) <;>
    (try ring_nf) <;>
    (try norm_cast) <;>
    (try simp_all [MeasureTheory.Measure]) <;>
    (try simp_all [MeasureTheory.setIntegral]) <;>
    (try simp_all [MeasureTheory.integral_smul]) <;>
    (try simp_all [MeasureTheory.integral_interval_smul]) <;>
    (try simp_all [MeasureTheory.setIntegral_smul]) <;>
    (try simp_all [MeasureTheory.integral_smul]) <;>
    (try simp_all [MeasureTheory.integral_interval_smul]) <;>
    (try simp_all [MeasureTheory.setIntegral_smul])
    <;>
    (try
      {
        aesop
      }) <;>
    (try
      {
        simp_all [MeasureTheory.set_integral_congr_ae]
      }) <;>
    (try
      {
        simp_all [MeasureTheory.ae_restrict]
      }) <;>
    (try
      {
        simp_all [MeasureTheory.ae_prod]
      }) <;>
    (try
      {
        simp_all [MeasureTheory.ae_restrict]
      }) <;>
    (try
      {
        simp_all [MeasureTheory.ae_prod]
      })
  exact h₁
