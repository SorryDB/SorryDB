```lean
namespace ValueDistribution

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℂ E]

theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
    intro hf
    have h1 : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that the scalar multiplication of an interval integrable function is interval integrable.
      have h2 : IntervalIntegrable (fun x => r • f x) μ a b := by
        -- Apply the scalar multiplication rule for interval integrability.
        apply hf.smul
      -- Simplify the expression to match the required form.
      simpa [smul_smul] using h2
    exact h1
  · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
    intro hf
    have h1 : IntervalIntegrable f μ a b := by
      -- Use the fact that the scalar multiplication of an interval integrable function is interval integrable.
      have h2 : IntervalIntegrable (fun x => (1 : R) • f x) μ a b := by
        -- Apply the scalar multiplication rule for interval integrability.
        have h3 : IntervalIntegrable (fun x => (1 : R) • f x) μ a b := by
          simpa [one_smul] using hf
        exact h3
      -- Simplify the expression to match the required form.
      have h4 : IntervalIntegrable f μ a b := by
        simpa [one_smul] using h2
      exact h4
    exact h1
