theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that the integral of `r • f` is `r` times the integral of `f`, and `r` is a scalar.
    have h₂ : IntervalIntegrable f μ a b := h
    have h₃ : IntervalIntegrable (r • f) μ a b := by
      -- Use the property of interval integrability under scalar multiplication.
      have h₄ : r • f = fun x => r • f x := rfl
      rw [h₄]
      -- Use the fact that if `f` is interval integrable, then `r • f` is also interval integrable.
      apply IntervalIntegrable.smul_of_bounded
      <;> norm_num
      <;>
      (try simp_all [intervalIntegrable_iff_norm_integrable]) <;>
      (try norm_num) <;>
      (try linarith)
      <;>
      (try
        {
          simp_all [intervalIntegrable_iff_norm_integrable]
          <;>
          norm_num
          <;>
          linarith
        })
      <;>
      (try
        {
          simp_all [intervalIntegrable_iff_norm_integrable]
          <;>
          norm_num
          <;>
          linarith
        })
    exact h₃
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    -- Similarly, if `r • f` is interval integrable, then `f` is also interval integrable.
    intro h
    have h₃ : IntervalIntegrable (r • f) μ a b := h
    have h₄ : IntervalIntegrable f μ a b := by
      by_cases hr : r = 0
      · -- If `r = 0`, then `r • f = 0`, which is trivially integrable.
        have h₅ : r • f = fun _ => 0 := by
          funext x
          rw [hr]
          simp
        rw [h₅] at h₃
        -- Use the fact that the zero function is interval integrable.
        have h₆ : IntervalIntegrable (fun _ : ℝ => (0 : E)) μ a b := by
          -- The zero function is always interval integrable.
          exact intervalIntegral.intervalIntegrable_zero
        -- Since `r • f = 0`, we have `IntervalIntegrable f μ a b` by assumption.
        have h₇ : IntervalIntegrable f μ a b := by
          simp_all [intervalIntegrable_iff_norm_integrable]
          <;>
          norm_num
          <;>
          linarith
        exact h₇
      · -- If `r ≠ 0`, we can use the inverse of `r` to recover `f`.
        have h₅ : r ≠ 0 := hr
        -- Use the fact that scalar multiplication is invertible.
        have h₆ : IntervalIntegrable f μ a b := by
          have h₇ : IntervalIntegrable (fun x => (r⁻¹ : R) • (r • f) x) μ a b := by
            -- Use the fact that if `r • f` is interval integrable, then `(r⁻¹) • (r • f)` is also interval integrable.
            apply IntervalIntegrable.smul_of_bounded
            <;> norm_num
            <;>
            (try simp_all [intervalIntegrable_iff_norm_integrable]) <;>
            (try norm_num) <;>
            (try linarith)
            <;>
            (try
              {
                simp_all [intervalIntegrable_iff_norm_integrable]
                <;>
                norm_num
                <;>
                linarith
              })
            <;>
            (try
              {
                simp_all [intervalIntegrable_iff_norm_integrable]
                <;>
                norm_num
                <;>
                linarith
              })
          -- Simplify `(r⁻¹) • (r • f)` to `f`.
          have h₈ : (fun x => (r⁻¹ : R) • (r • f) x) = f := by
            funext x
            simp [smul_smul, h₅]
          rw [h₈] at h₇
          exact h₇
        exact h₆
    exact h₄
  exact ⟨h₁, h₂⟩
