theorem preservesLimitsOfEquivalence {C D : Type} [SmallCategory C] [SmallCategory D]
    (F : C ⥤ D) (G : D ⥤ C) [IsLeftAdjoint F] [IsRightAdjoint G] :
    HasLimits D → HasLimits C → PreservesLimits F := by
  have h : ∀ {J : Type} [SmallCategory J], HasJLimits J D → HasJLimits J C → HasJLimits J C := by
    intro J _ hJ hJ'
    exact hJ'
  have h₁ : ∀ {J : Type} [SmallCategory J], HasJLimits J D → HasJLimits J C := by
    intro J _ hJD
    have h₂ : HasJLimits J C := hJ'.down J _ hJD
    exact h₂
  intro hD
  have hC : HasLimits C := by
    have hC₂ : HasLimits C := by
      exact hD.trans _
      -- Here, we use the fact that the equivalence preserves limits
      <;> simp_all [HasLimits]
    exact hC₂
  have hC' : HasLimits D := hD
  have hF : PreservesLimits F := by
    have hF₁ : ∀ {J : Type} [SmallCategory J], HasJLimits J D → HasJLimits J C := h₁
    have hF₂ : ∀ {J : Type} [SmallCategory J], HasJLimits J D → HasJLimits J C := by
      intro J _ hJD
      have h₃ : HasJLimits J C := h₁ _ _ hJD
      exact h₃
    -- Use the fact that F is left adjoint to G to show that F preserves limits
    have hF₃ : ∀ {J : Type} [SmallCategory J], HasJLimits J D → HasJLimits J C := by
      intro J _ hJD
      have h₃ : HasJLimits J C := h₁ _ _ hJD
      exact h₃
    -- Since F is left adjoint to G and G is right adjoint, F preserves limits
    exact fun J _ => by
      have h₄ : HasJLimits J D := hD(_)
      have h₅ : HasJLimits J C := hF₃ _ _ h₄
      have h₆ : PreservesJLimits F J := by
        -- Use the fact that F is left adjoint to G to show that F preserves limits
        have h₇ : IsLeftAdjoint F := by infer_instance
        have h₈ : IsRightAdjoint G := by infer_instance
        have h₉ : PreservesJLimits G J := by
          -- Use the fact that G is right adjoint to show that G preserves limits
          have h₁₀ : IsRightAdjoint G := by infer_instance
          exact RightAdjointPreservesLimits _
        have h₁₀ : PreservesJLimits F J := by
          -- Use the fact that F is left adjoint to show that F preserves limits
          have h₁₁ : IsLeftAdjoint F := by infer_instance
          have h₁₂ : IsRightAdjoint G := by infer_instance
          exact LeftAdjointPreservesLimits _
        exact h₁₀
      exact h₆.preserves
  exact hF
