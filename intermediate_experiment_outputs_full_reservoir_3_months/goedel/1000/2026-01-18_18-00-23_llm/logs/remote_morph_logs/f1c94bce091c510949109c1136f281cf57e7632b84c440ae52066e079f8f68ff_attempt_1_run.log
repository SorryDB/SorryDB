def seqFunctor (S : LightProfinite.{0}) : ℕ+ ⥤ LightProfinite where
  obj c := profiniteComponent S c
  map f := by
    cases' f with n m h
    exact ⟨fun _ => h⟩
  map_id := by
    intro n
    ext
    <;> simp [Nat.succ_eq_add_one]
  map_comp := by
    intro n m l f g
    simp [Function.funext_iff, Finset.sum_congr]
    <;>
    (try simp_all [Function.comp_apply])
    <;>
    (try aesop)
    <;>
    (try simp_all [Finset.sum_congr])
    <;>
