### Lean 4 Proof

```lean
lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  have h₀ : (ValuativeRel.valuation K) x = 1 ↔ x ∈ 𝒪[K]ˣ := by
    have h₁ : (ValuativeRel.valuation K) x = 1 ↔ x ∈ (Units.mk 𝒪[K] (RingHom.id 𝒪[K])).val := by
      simp [Units.ext_iff, ValuativeRel.mem_units_iff_val_eq_one]
    have h₂ : (Units.mk 𝒪[K] (RingHom.id 𝒪[K])).val = (𝒪[K]ˣ : Set K) := by
      ext x
      simp [Units.ext_iff]
      <;>
      simp_all [Units.mk_coe, Set.mem_setOf_eq]
      <;>
      aesop
    rw [h₁, h₂]
    <;>
    simp_all [Set.mem_setOf_eq]
  
  have h₁ : x ∈ 𝒪[K]ˣ ↔ ∃ r : 𝒪[K]ˣ, x = r := by
    constructor
    · intro hx
      refine' ⟨⟨x, hx⟩, _⟩
      simp [Units.ext_iff]
    · rintro ⟨r, rfl⟩
      exact r.prop
  
  rw [h₀]
  rw [h₁]
  <;>
  aesop
```
