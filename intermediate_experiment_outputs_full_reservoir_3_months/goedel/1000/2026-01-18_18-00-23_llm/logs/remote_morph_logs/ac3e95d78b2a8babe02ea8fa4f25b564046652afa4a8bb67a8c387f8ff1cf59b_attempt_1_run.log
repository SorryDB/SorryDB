  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · -- Prove the forward direction: if w ∈ l, then coerceWord w ∈ coerceLang l
    intro h
    refine' ⟨w, _⟩
    constructor
    · -- Show that w ∈ l
      exact h
    · -- Show that coerceWord w = coerceWord w (trivially true)
      rfl
  · -- Prove the backward direction: if coerceWord w ∈ coerceLang l, then w ∈ l
    intro h
    -- Extract the word w' from the coerceLang l membership condition
    rcases h with ⟨w', hw', hcoerce⟩
    -- Since coerceWord is injective (as it's a map of a word to itself), we have w = w'
    have h₁ : w = w' := by
      -- Prove that w and w' are equal by comparing their underlying lists
      apply Word.ext
      -- Use the fact that the coercion is injective
      <;> simp_all [coerceWord, Word.map_eq_of_forall]
      <;> aesop
    -- Substitute w' with w in the membership condition
    subst_vars
    -- Conclude that w ∈ l
    exact hw'
