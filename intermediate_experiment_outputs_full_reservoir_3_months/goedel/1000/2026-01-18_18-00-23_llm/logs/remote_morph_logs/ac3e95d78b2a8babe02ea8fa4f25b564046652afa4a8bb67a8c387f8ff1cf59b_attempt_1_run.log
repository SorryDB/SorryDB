theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  simp only [coerceLang, coerceWord, exists_prop]
  <;>
  constructor <;>
  intro h <;>
  (try { exact ⟨w, h, rfl⟩ }) <;>
  (try { obtain ⟨w', hw', hw⟩ := h <;> refine' hw' }) <;>
  (try { simp_all [Word.map] <;> aesop })
