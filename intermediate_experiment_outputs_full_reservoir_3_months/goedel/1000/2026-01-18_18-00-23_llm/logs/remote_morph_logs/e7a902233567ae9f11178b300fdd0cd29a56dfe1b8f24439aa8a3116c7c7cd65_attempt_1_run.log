```lean
theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G → cl ≈ (dedup cr) := by
  intro cl cr G hG hG'
  have h₁ : cl ≈ (dedup cr) := by
    have h₂ : cl ≈ (dedup cr) := by
      classical
      -- Use the fact that the circuits are equal if they have the same evaluation
      apply eq_of_subsingleton
    exact h₂
