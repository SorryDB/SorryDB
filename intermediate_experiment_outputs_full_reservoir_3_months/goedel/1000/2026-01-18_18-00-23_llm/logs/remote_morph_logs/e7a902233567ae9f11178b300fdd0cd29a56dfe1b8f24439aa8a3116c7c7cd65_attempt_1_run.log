theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G →
      cl ≈ (dedup cr) := by
  have h₀ : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
    wf G cl cr →
      List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G → cl ≈ (dedup cr) := by
    intro cl cr G hG hG'
    have h₁ := hG
    have h₂ := hG'
    simp_all [Circuit.ext_iff]
    <;>
    (try contradiction) <;>
    (try simp_all [Circuit.ext_iff]) <;>
    (try aesop)
    <;>
    (try
      {
        exfalso
        simp_all [Circuit.ext_iff]
        <;>
        (try contradiction) <;>
        (try aesop)
      })
    <;>
    (try
      {
        exfalso
        simp_all [Circuit.ext_iff]
        <;>
        (try contradiction) <;>
        (try aesop)
      })
  exact h₀
