theorem φ₀''_holo : Holo(φ₀'') := by
  have h₁ : DifferentiableOn ℂ φ₀'' ℍ₀ := by
    have h₂ : φ₀'' = (fun z : ℂ => (z + Complex.I) / (z - Complex.I)) ∘ (fun z : ℂ => z) := by
      funext z
      rfl
    rw [h₂]
    -- Use the fact that the composition of holomorphic functions is holomorphic
    have h₃ : DifferentiableOn ℂ (fun z : ℂ => (z : ℂ)) ℂ := by
      exact differentiableOn_id
    have h₄ : DifferentiableOn ℂ (fun z : ℂ => (z + Complex.I) / (z - Complex.I)) ℍ₀ := by
      -- Prove that (z + i)/(z - i) is holomorphic on the upper half-plane
      apply DifferentiableOn.div
      · -- The numerator (z + i) is holomorphic
        apply DifferentiableOn.add
        · exact differentiableOn_id
        · exact differentiableOn_const _
      · -- The denominator (z - i) is holomorphic
        apply DifferentiableOn.sub
        · exact differentiableOn_id
        · exact differentiableOn_const _
      · -- The denominator is never zero on the upper half-plane
        intro z hz
        have h₅ : z.im > 0 := by
          simp only [upperHalfPlaneSet, Set.mem_setOf_eq] at hz
          exact hz
        have h₆ : (z - Complex.I : ℂ) ≠ 0 := by
          intro h
          have h₇ : z.re - 0 = 0 := by
            simp [Complex.ext_iff, Complex.I_mul_I] at h
            <;> linarith
          have h₈ : z.im - 1 = 0 := by
            simp [Complex.ext_iff, Complex.I_mul_I] at h
            <;> linarith
          have h₉ : z.im = 1 := by linarith
          have h₁₀ : z.re = 0 := by linarith
          have h₁₁ : z = Complex.I := by
            apply Complex.ext <;> simp_all [Complex.ext_iff, Complex.I_mul_I] <;> linarith
          simp [h₁₁] at hz
          <;> simp_all [upperHalfPlaneSet, Set.mem_setOf_eq]
          <;> linarith
        exact h₆
    -- The composition is holomorphic
    have h₅ : DifferentiableOn ℂ (fun z : ℂ => (z : ℂ)) ℂ := by
      exact differentiableOn_id
    have h₆ : DifferentiableOn ℂ (fun z : ℂ => (z + Complex.I) / (z - Complex.I)) ℍ₀ := h₄
    have h₇ : DifferentiableOn ℂ (fun z : ℂ => (z : ℂ)) ℍ₀ := by
      apply DifferentiableOn.mono h₅
      exact Set.subset_univ _
    -- Use the fact that the composition of holomorphic functions is holomorphic
    apply DifferentiableOn.comp h₆ h₇
  exact h₁
