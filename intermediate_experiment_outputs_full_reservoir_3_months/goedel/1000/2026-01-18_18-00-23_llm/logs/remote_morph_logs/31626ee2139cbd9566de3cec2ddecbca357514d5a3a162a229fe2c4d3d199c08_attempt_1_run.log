theorem list_insertIdx_length {l1 l2 : List α} {idx : Nat} {hidx : idx <= l1.length}
    {l1 : List α} {elt : α} :
    (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2 := by
  induction l1 generalizing idx hidx with
  | nil =>
    have : idx = 0 := by
      have h₁ : idx ≤ 0 := by simpa using hidx
      have h₂ : 0 ≤ idx := by exact Nat.zero_le _
      omega
    subst idx
    simp
  | cons hd tl HR =>
    simp_all [List.insertIdx]
