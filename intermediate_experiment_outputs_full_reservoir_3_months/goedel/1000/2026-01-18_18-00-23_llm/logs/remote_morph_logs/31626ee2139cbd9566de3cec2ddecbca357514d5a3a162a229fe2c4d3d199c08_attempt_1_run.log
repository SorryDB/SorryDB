```lean
theorem list_insert_idx {l1 l2 : List α} {idx : Nat} (hidx : idx ≤ l1.length) :
  (l1 ++ l2).insertIdx idx elt = l1.insertIdx idx elt ++ l2 := by
  have h : ∀ {n m : Nat} {l1 : List α} (l2 : List α), n ≤ l1.length → (l1 ++ l2).insertIdx n elt = l1.insertIdx n elt ++ l2 := by
    intro n m l1 l2 h
    induction l1 using List.strong_induction_on with
    | h l1 ih =>
      match l1 with
      | [] =>
        have h₁ : n = 0 := by
          have h₂ : 0 ≤ List.length [] := by simp
          have h₃ : n ≤ List.length [] := by simpa using h
          simp at h₂ h₃ ⊢
          <;> omega
        simp_all [h₁, List.insertIdx_nil]
        <;> simp_all [List.insertIdx_nil]
        <;> cases m <;> simp_all [List.insertIdx_nil]
        <;> simp_all [List.insertIdx_nil]
      | (x :: xs) =>
        have h₁ : n ≤ x :: xs |>.length := by simpa using h
        have h₂ : n ≤ x :: xs |>.length := by simpa using h
        cases n with
        | zero =>
          simp [List.insertIdx_cons, List.length_contra]
          <;> simp_all [List.insertIdx_cons]
          <;> cases m <;> simp_all [List.insertIdx_cons]
          <;> simp_all [List.insertIdx_cons]
        | succ n =>
          have h₃ : n.succ ≤ x :: xs |>.length := h₂
          have h₄ : n ≤ xs.length := by
            simp [List.length_contra] at h₃ ⊢
            <;> omega
          have ih₁ := ih xs (by omega) l2 h₄
          simp [List.insertIdx_cons, List.length_contra, ih₁] at *
          <;> simp_all [List.insertIdx_cons, List.append_assoc]
          <;> cases m <;> simp_all [List.insertIdx_cons, List.append_assoc]
          <;> simp_all [List.insertIdx_cons, List.append_assoc]
          <;> try omega
  have h₁ := h (l2 := l2) (h := hidx)
  exact h₁
```

