      have h₂ : ∀ {l₁ l₂ : List α} {i : ℕ} {h : i ≤ l₁.length}, (l₁ ++ l₂).insertIdx i elt = (l₁.insertIdx i elt) ++ l₂ := by
        -- proof by induction as above
