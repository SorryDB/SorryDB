theorem list_insertIdx_length {l1 l2 : List α} {idx : Nat} {hidx : idx <= l1.length}
    {l1 : List α} {elt : α} :
    (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2 := by
  have h_main : ∀ (l1 l2 : List α) (idx : Nat), (l1 ++ l2).insertIdx idx elt = l1.insertIdx idx elt ++ l2 := by sorry
  have h_final : (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2 := by sorry
  sorry
