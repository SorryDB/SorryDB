```lean
theorem list_insertIdx_length {l1 l2 : List α} {idx : Nat} {hidx : idx <= l1.length}
    {l1 : List α} {elt : α} :
    (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2
    := by
  induction l1 generalizing idx hidx with
  | nil =>
    -- from the fact idx <= l1.length = [].length
    have : idx = 0 := by
      have h₁ : idx ≤ 0 := by simpa using hidx
      omega
    subst idx
    simp
  | cons hd tl HR =>
    simp_all [List.insertIdx, List.append_assoc, List.length_cons]
    <;>
    (try omega) <;>
    (try simp_all [List.insertIdx, List.append_assoc, List.length_cons]) <;>
    (try ring_nf at *) <;>
    (try omega)
    <;>
    (try
      {
        have h5 : (tl ++ l2).insertIdx (idx - 1) elt = tl.insertIdx (idx - 1) elt ++ l2 := by
          apply HR
          <;> omega
        simp_all [List.insertIdx, List.append_assoc, List.length_cons]
        <;> ring_nf at *
        <;> omega
      })
    <;>
    (try
      {
        have h5 : (tl ++ l2).insertIdx (idx - 1) elt = tl.insertIdx (idx - 1) elt ++ l2 := by
          apply HR
          <;> omega
        simp_all [List.insertIdx, List.append_assoc, List.length_cons]
        <;> ring_nf at *
        <;> omega
      })
  <;>
  simp_all [List.insertIdx, List.append_assoc, List.length_cons]
  <;>
  ring_nf at *
  <;>
  omega
``` 

