```lean
theorem RelInt.liftFinf_in {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
  -- TODO: This is probably an equivalence too
  rule ∈ (RelInt.liftFinf n f)
  → ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
  intro h
  have h₁ : rule ∈ (RelInt.liftFinf n f) := h
  simp only [RelInt.liftFinf, List.mem_flatten, List.mem_map, Fin.forall_fin_succ] at h₁
  -- Use the fact that rule is in the flattened list of lists to find the original index
  obtain ⟨i, hi, j, hj⟩ := h₁
  refine' ⟨i, ⟨_, hi⟩, _⟩ <;> simp_all [List.get]
  <;> aesop
```
