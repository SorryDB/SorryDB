              <;>
              (try omega) <;>
              (try aesop)
            })
          <;>
          (try
            {
              simp_all [List.get?]
              <;>
              (try omega) <;>
              (try aesop)
            })
        exact h₉
      exact h₇
    have h₅ : l1 = l2 := by
      have h₆ : l1.length = l2.length := by
        rw [h₁, h₂]
      have h₇ : ∀ (i : ℕ), i < l1.length → l1.get? i = l2.get? i := by
        intro i hi
        have h₈ : i < n := by
          rw [h₁] at hi
