  (∀ (idx : Fin n), v1[↑idx] = v2[↑idx]) → v1 = v2 := by
  intro h
  obtain ⟨⟨l1⟩, sz1⟩ := v1
  obtain ⟨⟨l2⟩, sz2⟩ := v2
  congr
  dsimp at h
  dsimp [Array.size] at sz1 sz2
  have h₁ : l1.length = n := by
    have h₁₁ : l1.length = n := by
      simp_all [Vector.length]
    exact h₁₁
  
  have h₂ : l2.length = n := by
    have h₂₁ : l2.length = n := by
      simp_all [Vector.length]
    exact h₂₁
  
  have h₃ : l1 = l2 := by
    have h₄ : ∀ (i : ℕ), i < n → l1.get? i = l2.get? i := by
      intro i hi
      have h₅ : i < l1.length := by
        rw [h₁]
        <;> assumption
      have h₆ : i < l2.length := by
        rw [h₂]
        <;> assumption
      have h₇ : l1.get? i = l2.get? i := by
        have h₈ : (⟨i, by omega⟩ : Fin n) = (⟨i, by omega⟩ : Fin n) := rfl
        have h₉ : l1.get? i = l2.get? i := by
          have h₁₀ := h (⟨i, by omega⟩ : Fin n)
          simp [Vector.get] at h₁₀ ⊢
          <;>
          (try simp_all [List.get?]) <;>
          (try omega) <;>
          (try aesop) <;>
          (try
