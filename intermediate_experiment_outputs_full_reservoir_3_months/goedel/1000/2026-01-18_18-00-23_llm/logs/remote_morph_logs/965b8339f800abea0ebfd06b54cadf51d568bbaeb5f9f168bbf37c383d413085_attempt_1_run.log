      (∀ (idx : Fin n), v1[↑idx] = v2[↑idx]) → v1 = v2 := by
        intros h
        obtain ⟨⟨l1⟩, sz1⟩ := v1
        obtain ⟨⟨l2⟩, sz2⟩ := v2
        congr
        dsimp at h
