        | nil =>
          induction l2 with
          | nil => rfl
          | cons hd2 tl2 HR2 => rw [←sz1] at sz2; contradiction
        | cons hd1 tl1 HR1 =>
          induction l2 with
          | nil => rw [←sz1] at sz2; contradiction
          | cons hd2 tl2 HR2 =>
            congr
            · apply h ⟨0, by simpa [←sz2] using (by
                simp_all [Nat.succ_le_iff]
                <;> omega)⟩
            · apply @HR1 (n - 1)
              · intros idx
                obtain ⟨idxv, idxh⟩ := idx
