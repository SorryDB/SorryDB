      (∀ (N : PersistenceSubmodule M) (hN : N ∈ D), N = sSup (B N hN)) ∧
      (∀ (N : PersistenceSubmodule M) (hN : N ∈ D), sSupIndep (B N hN)) ∧
      (∀ (N : PersistenceSubmodule M) (hN : N ∈ D), ⊥ ∉ B N hN) ∧
      (∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) := by
