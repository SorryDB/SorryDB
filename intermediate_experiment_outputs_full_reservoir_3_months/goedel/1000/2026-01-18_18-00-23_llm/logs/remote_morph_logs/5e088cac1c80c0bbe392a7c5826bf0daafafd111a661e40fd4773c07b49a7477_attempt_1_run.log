theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  have h₁ : ∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 2 ^ (3 * k) % 5 = 0 := by
    omega
  have h₂ : ∀ n : ℕ, (∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 2 ^ (3 * k)) % 5 ≠ 0 := by
    intro n
    have h₃ : (∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 2 ^ (3 * k)) % 5 ≠ 0 := by
      induction n with
      | zero =>
        norm_num [Finset.sum_range_succ]
      | succ n ih =>
        simp_all [Finset.sum_range_succ, Nat.choose_succ_succ, pow_add, pow_mul, Nat.mul_mod,
          Nat.pow_mod, Nat.add_mod, Nat.mod_mod]
        <;> ring_nf at *
        <;> norm_num at *
        <;>
        (try omega) <;>
        (try
          {
            have h₄ : n < 4 ∨ n ≥ 4 := by omega
            cases h₄ with
            | inl h₄ =>
              interval_cases n <;> norm_num [Finset.sum_range_succ, Nat.choose_succ_succ, pow_add, pow_mul, Nat.mul_mod, Nat.pow_mod, Nat.add_mod, Nat.mod_mod] at * <;>
                omega
            | inr h₄ =>
              omega
          }) <;>
        (try
          {
            omega
          })
        <;>
        (try
          {
            contradiction
          })
    exact h₃
  have h₃ := h₂ n
  omega
