theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  haveI : denum {n : Int | even n} := by
    -- The set of even integers is the image of the integers under the map `n ↦ 2 * n`,
    -- which is an injective function. Since the integers are denumerable,
    -- the set of even integers is also denumerable.
    let f : Int ≃ {n : Int | even n} := ⟨fun n => ⟨2 * n, by
      simp [Int.even_mul, Int.even_iff]
      <;> omega⟩, fun ⟨n, hn⟩ => by
      have h : n % 2 = 0 := by
        simp [Int.even_iff] at hn ⊢
        <;> omega
      have h₁ : ∃ k : Int, n = 2 * k := by
        use n / 2
        have h₂ : n % 2 = 0 := h
        have h₃ : n = 2 * (n / 2) := by
          omega
        linarith
      rcases h₁ with ⟨k, rfl⟩
      use k
      <;> simp [Int.even_mul, Int.even_iff] <;> ring_nf <;> simp_all
      <;> omega, by
      intro n m
      simp [Int.even_mul, Int.even_iff]
      <;> ring_nf at *
      <;> simp_all
      <;> omega, by
      intro ⟨n, hn⟩
      simp [Int.even_mul, Int.even_iff]
      <;> ring_nf at *
      <;> simp_all
      <;> omega⟩
    exact Equiv.denum f
  exact inferInstance
