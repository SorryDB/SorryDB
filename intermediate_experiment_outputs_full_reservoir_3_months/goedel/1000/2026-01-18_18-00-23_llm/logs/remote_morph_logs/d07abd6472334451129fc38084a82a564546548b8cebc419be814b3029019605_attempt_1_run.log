theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : denumerable {n : Int | even n} := by
    have h₁ : {n : Int | even n} = Set.range (fun (k : Int) => 2 * k) := by
      apply Set.Subset.antisymm
      · intro x hx
        have h₂ : even x := hx
        have h₃ : ∃ k : Int, x = 2 * k := by
          rw [Int.even_iff] at h₂
          use x / 2
          have h₄ : x % 2 = 0 := by omega
          have h₅ : x = 2 * (x / 2) := by
            have h₆ := Int.emod_add_ediv x 2
            omega
          exact h₅
        obtain ⟨k, rfl⟩ := h₃
        exact ⟨k, by simp⟩
      · intro x hx
        obtain ⟨k, rfl⟩ := hx
        have h₂ : even (2 * k : Int) := by
          rw [Int.even_iff]
          <;> simp [Int.mul_emod]
        exact h₂
    rw [h₁]
    -- Use the fact that the range of the function is denumerable
    exact Set.denumerable_range _
  exact h
