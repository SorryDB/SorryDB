theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : {n : Int | even n} ≃ ℕ := by
    -- Define a bijection between the set of even integers and the natural numbers
    -- Even integers can be written as 2k, so we can map k to 2k and vice versa
    -- Here, we use the fact that the even integers are countably infinite
    -- and can be put into a bijection with the natural numbers
    let f : ℕ → {n : Int | even n} := fun n => ⟨2 * n, by
      -- Prove that 2 * n is even
      simp [Int.even_iff]
      <;> ring_nf
      <;> norm_num
      <;> omega⟩
    let g : {n : Int | even n} → ℕ := fun ⟨n, hn⟩ =>
      -- Extract the natural number k such that n = 2k
      Int.natAbs (n / 2)
    refine' ⟨f, g, _, _, _⟩
    · -- Prove that f is injective
      intro a b h
      simp_all [f]
      <;> ring_nf at *
      <;> norm_cast at *
      <;> omega
    · -- Prove that g is injective
      intro a b h
      simp_all [g]
      <;>
      (try cases' a with a ha <;> cases' b with b hb <;> simp_all [Int.even_iff, Int.emod_eq_of_lt]) <;>
      (try omega) <;>
      (try {
        have h₁ : a / 2 = b / 2 := by
          omega
        have h₂ : a % 2 = 0 := by
          omega
        have h₃ : b % 2 = 0 := by
          omega
        omega
      })
      <;>
      (try {
        have h₁ : a / 2 = b / 2 := by
          omega
        have h₂ : a % 2 = 0 := by
          omega
        have h₃ : b % 2 = 0 := by
          omega
        omega
      })
    · -- Prove that f and g are inverses of each other
      intro a
      simp_all [f, g]
      <;>
      (try cases' a with a ha <;> simp_all [Int.even_iff, Int.emod_eq_of_lt]) <;>
      (try omega) <;>
      (try {
        have h₁ : (2 * a : Int) / 2 = a := by
          omega
        omega
      })
      <;>
      (try {
        have h₁ : (2 * a : Int) / 2 = a := by
          omega
        omega
      })
  -- Since {n : Int | even n} is in bijection with ℕ, it is countable
  exact denum_of_equiv h (by infer_instance)
