theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : denum {n : Int | even n} := by
    -- We use the fact that the set of even integers is countable and in bijection with the integers
    have h₁ : {n : Int | even n} ≃ Int := by
      -- Define the bijection between even integers and integers
      -- f : {n : Int | even n} → Int, f(n) = n / 2
      -- f⁻¹ : Int → {n : Int | even n}, f⁻¹(k) = 2k
      refine' ⟨fun n => ⟨n.val / 2, _⟩, fun n => ⟨2 * n, _⟩, _, _⟩
      · -- Prove that n / 2 is an integer when n is even
        have h₂ := n.prop
        simp [Int.even_iff, Int.emod_eq_of_lt] at h₂ ⊢
        <;> omega
      · -- Prove that 2 * n is even
        simp [Int.even_iff]
      · -- Prove that the functions are inverses
        intro n
        simp [Int.even_iff]
        <;> ring_nf
        <;> norm_num
        <;> omega
      · -- Prove that the functions are inverses
        intro n
        simp [Int.even_iff]
        <;> ring_nf
        <;> norm_num
        <;> omega
    -- Since the set of even integers is in bijection with the integers, and the integers are countable, the set of even integers is countable
    have h₂ : denum {n : Int | even n} := by
      -- Use the bijection to transfer the countability
      exact h₁.symm.denum_of_denum (by
        -- Prove that the integers are countable
        exact denum_of_countable inferInstance
        )
    exact h₂
  exact h
