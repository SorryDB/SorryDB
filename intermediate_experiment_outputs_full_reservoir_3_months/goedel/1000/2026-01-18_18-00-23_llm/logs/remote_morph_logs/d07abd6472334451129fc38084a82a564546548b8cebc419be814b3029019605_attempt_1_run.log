            <;> simp [Int.mul_ediv_cancel_left]
            <;> norm_num
            <;> ring_nf
            <;> omega
        -- Combine the bijection and its inverse to show the equivalence
        exact
          Equiv.ofBijective (fun (x : { n : Int | even n }) => (⟨(x : Int) / 2, by trivial⟩ : Set.univ)) h₄
      exact h₃
    -- Since the set of even integers is in bijection with the set of all integers,
