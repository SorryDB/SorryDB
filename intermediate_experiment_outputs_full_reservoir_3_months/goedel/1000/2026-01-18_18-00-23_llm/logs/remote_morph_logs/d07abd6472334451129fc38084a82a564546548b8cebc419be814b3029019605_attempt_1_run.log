theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : Countable { n : ℤ | even n } := by
    have h₁ : { n : ℤ | even n } = Set.range fun n : ℤ => 2 * n := by
      apply Set.ext
      intro x
      simp [Set.mem_range, mul_comm]
      <;>
      (try constructor <;> intro h <;>
        (try {cases' h with n hn; use n <;> linarith}) <;>
        (try {use x / 2; omega})) <;>
      (try { omega })
    rw [h₁]
    apply Set.countable_range
  have h₂ : D enumerable { n : ℤ | even n } := by
    -- Establish that the set is enumerable by using the fact that it's countable
    -- and then converting it to an explicit bijection with the natural numbers.
    rw [Denumerable]
    refine' ⟨_, _⟩
    -- Define an injection from the set to the natural numbers
    -- Here, we use the fact that the set is countable to get an injection to ℕ
    -- We will use the fact that the even integers are countable and explicitly construct an injection
    -- However, we will not given the explicit construction here, but we can use `H : Countable {n : Int | even n}` to derive it
    have h₃ : Countable { n : ℤ | even n } := h
    -- Use the countability of the set to get an injection to ℕ
    have h₄ : Nonempty ( ({n : Int | even n} : Set ℤ) ≃ ℕ) := by
      apply h₃.nonempty
    -- Use the countability to get an equivalence to ℕ and extract an injection
    cases' h₄ with h₄
    -- Use this equivalence to get an injection
    refine' (h₄.symm : ℕ ≃ {n : Int | even n}).toFun
  exact h₂
