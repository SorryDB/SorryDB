            have h₈ : (a : Int) = (b : Int) := by
              have h₉ : (a : Int) = 2 * ((a : Int) / 2) := by
                have h₁₀ := Int.emod_add_ediv (a : Int) 2
                omega
              have h₁₀ : (b : Int) = 2 * ((b : Int) / 2) := by
                have h₁₁ := Int.emod_add_ediv (b : Int) 2
                omega
              linarith
            exact Subtype.ext h₈
          · -- Surjectivity
            intro y
            -- For any integer y, there exists an even integer 2y such that (2y)/2 = y
            use ⟨2 * y, by
              -- Prove that 2 * y is even
