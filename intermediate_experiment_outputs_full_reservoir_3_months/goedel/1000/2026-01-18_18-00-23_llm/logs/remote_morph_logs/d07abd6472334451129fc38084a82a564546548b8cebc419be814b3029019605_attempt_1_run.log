        -- Prove that the bijection is well-defined and that the inverse is correct
        have h₄ : Function.Bijective (fun (x : { n : Int | even n }) => (x : Int) / 2) := by
          constructor
          · -- Injectivity
            intro a b hab
            -- If a/2 = b/2, then a = b
