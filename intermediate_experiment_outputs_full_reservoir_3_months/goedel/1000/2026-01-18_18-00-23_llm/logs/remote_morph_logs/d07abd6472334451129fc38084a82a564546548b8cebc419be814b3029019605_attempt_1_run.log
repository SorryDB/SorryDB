theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : {n : Int | even n} ≃ Set.range (fun n : ℤ => 2 * n) := by
    apply Set.ext
    intro x
    simp only [Set.mem_setOf_eq, Set.mem_range]
    constructor
    · -- Prove the forward direction: if x is even, then x is in the range of (fun n : ℤ => 2 * n)
      intro hx
      rw [even_iff_two_dvd] at hx
      obtain ⟨k, hk⟩ := hx
      use k
      <;> linarith
    · -- Prove the backward direction: if x is in the range of (fun n : ℤ => 2 * n), then x is even
      intro hx
      obtain ⟨k, hk⟩ := hx
      rw [even_iff_two_dvd]
      use k
      <;> linarith
  -- Now, we need to show that the set {n : Int | even n} is denumerable.
  -- Since it is equivalent to the range of (fun n : ℤ => 2 * n), which is denumerable,
  -- we can conclude that {n : Int | even n} is denumerable.
  have h₁ : Denumerable {n : Int | even n} := by
    rw [h]
    -- The range of (fun n : ℤ => 2 * n) is denumerable because it is the image of a denumerable set under a function.
    exact Denumerable.ofEmbedding (Set.rangeEmbedding (fun n : ℤ => 2 * n))
  exact h₁
