theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : Denumerable {n : Int | even n} := by
    have h₁ : Denumerable (Set.Icc 0 1 : Set Bool) := by
      exact Denumerable.ofFinite
    -- We need to show that the set of even integers is denumerable.
    -- We can construct a bijection between the even integers and the natural numbers.
    -- Here, we instead use the fact that the even integers are in bijection with the integers,
    -- and the integers are denumerable.
    have h₂ : Denumerable {n : Int | even n} := by
      -- Define a function from the even integers to the integers.
      have h₃ : {n : Int | even n} ≃ Int := by
        -- We use the fact that the even integers are in bijection with the integers.
        -- Specifically, we can map each even integer n to n / 2.
        -- This is a bijection because every integer can be written as 2k for some integer k.
        -- The inverse map is k ↦ 2k.
        refine' ⟨fun n => n.val / 2, fun n => 2 * n, _, _⟩
        · -- Prove that the composition of the two functions is the identity.
          intro n
          have h₄ : (n : Int) % 2 = 0 := by
            have h₅ : n ∈ {n : Int | even n} := n.prop
            have h₆ : even (n : Int) := h₅
            rw [Int.even_iff] at h₆
            omega
          have h₅ : (n : Int) / 2 * 2 = (n : Int) := by
            have h₆ : (n : Int) % 2 = 0 := h₄
            have h₇ : (n : Int) / 2 * 2 = (n : Int) := by
              have h₈ : (n : Int) = 2 * ((n : Int) / 2) := by
                omega
              linarith
            exact h₇
          simp_all [Int.even_iff]
          <;> ring_nf at * <;> omega
        · -- Prove that the composition of the two functions is the identity.
          intro n
          have h₄ : (2 * n : Int) % 2 = 0 := by
            omega
          simp_all [Int.even_iff]
          <;> ring_nf at * <;> omega
      -- Since the even integers are in bijection with the integers, and the integers are denumerable,
      -- the even integers are denumerable.
      exact h₃.denumerable
    exact h₂
  -- Since we have shown that the set of even integers is denumerable, we can conclude the proof.
  exact h
