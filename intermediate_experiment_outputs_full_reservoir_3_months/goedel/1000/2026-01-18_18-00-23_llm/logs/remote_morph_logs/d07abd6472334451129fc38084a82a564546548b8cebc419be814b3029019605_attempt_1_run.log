theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h₁ : Denumerable {n : ℤ | Even n} := by
    let f : ℕ → {n : ℤ | Even n} := fun n => ⟨2 * n, by
      simp [Int.even_iff, Int.emod_eq_of_lt]
      <;> omega⟩
    let g : {n : ℤ | Even n} → ℕ := fun ⟨n, hn⟩ => (n.natAbs / 2)
    have h₂ : Function.Surjective f := by
      intro ⟨n, hn⟩
      have h₃ : ∃ (k : ℕ), (2 : ℤ) * k = n := by
        have h₄ : Even n := hn
        have h₅ : (n : ℤ) % 2 = 0 := by
          rw [Int.even_iff] at h₄
          omega
        have h₆ : ∃ (k : ℤ), (2 : ℤ) * k = n := by
          use n / 2
          have h₇ : (n : ℤ) % 2 = 0 := h₅
          have h₈ : (n : ℤ) = 2 * (n / 2) := by
            omega
          linarith
        obtain ⟨k, hk⟩ := h₆
        have h₉ : (k : ℤ) ≥ 0 ∨ (k : ℤ) < 0 := by
          by_cases h : (k : ℤ) ≥ 0
          · exact Or.inl h
          · exact Or.inr (by linarith)
        cases h₉ with
        | inl h₉ =>
          have h₁₀ : (k : ℕ) = k.toNat := by simp [Int.toNat_of_nonneg h₉]
          use k.toNat
          <;> simp_all [Int.toNat_of_nonneg h₉]
          <;> ring_nf at *
          <;> omega
        | inr h₉ =>
          have h₁₀ : (k : ℕ) = (-k).toNat := by
            simp [Int.toNat_of_nonneg (by linarith : (0 : ℤ) ≤ -k)]
            <;> ring_nf at *
            <;> omega
          use (-k).toNat
          <;> simp_all [Int.toNat_of_nonneg (by linarith : (0 : ℤ) ≤ -k)]
          <;> ring_nf at *
          <;> omega
      obtain ⟨k, hk⟩ := h₃
      use k
      <;> simp_all [Set.mem_setOf_eq]
      <;> ring_nf at *
      <;> omega
    have h₃ : Function.Injective f := by
      intro a b h
      simp_all [Set.mem_setOf_eq]
      <;> ring_nf at *
      <;> omega
    have h₄ : Denumerable {n : ℤ | Even n} := by
      apply Denumerable.ofSurjective f h₂
    exact h₄
  exact h₁
