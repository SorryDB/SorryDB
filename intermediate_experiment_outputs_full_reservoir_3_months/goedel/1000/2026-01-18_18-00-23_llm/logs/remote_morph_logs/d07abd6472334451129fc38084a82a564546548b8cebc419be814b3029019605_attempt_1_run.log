theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : {n : ℤ | even n} ≃ Set.range (fun k : ℤ => 2 * k) := by
    apply Set.ext
    intro n
    simp only [Set.mem_setOf_eq, Set.mem_range]
    constructor
    · intro h
      rw [even_iff_two_dvd] at h
      obtain ⟨k, rfl⟩ := h
      refine' ⟨k, _⟩
      <;> simp [mul_comm]
    · intro h
      rcases h with ⟨k, rfl⟩
      simp [even_iff_two_dvd, dvd_mul_right]
  have h₁ : denum {n : ℤ | even n} := by
    rw [h]
    exact denum_range (fun k : ℤ => 2 * k)
  exact h₁
