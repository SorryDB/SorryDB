  have h : {n : Int | even n} = Set.range (fun k : ℤ => 2 * k) := by
    apply Set.Subset.antisymm
    · -- Prove that {n : ℤ | even n} ⊆ Set.range (fun k : ℤ => 2 * k)
      intro n hn
      rw [Set.mem_setOf_eq] at hn
      -- Since n is even, there exists an integer k such that n = 2 * k
      have h₁ : ∃ k : ℤ, n = 2 * k := by
        rw [even_iff_two_dvd] at hn
        obtain ⟨k, hk⟩ := hn
        exact ⟨k, by linarith⟩
      obtain ⟨k, hk⟩ := h₁
      -- Therefore, n is in the range of the function (fun k : ℤ => 2 * k)
      rw [Set.mem_range]
      refine' ⟨k, _⟩
      linarith
    · -- Prove that Set.range (fun k : ℤ => 2 * k) ⊆ {n : ℤ | even n}
      intro n hn
      rw [Set.mem_range] at hn
      obtain ⟨k, rfl⟩ := hn
      -- For any n = 2 * k, n is even
      rw [Set.mem_setOf_eq]
      simp [even_iff_two_dvd, Int.dvd_iff_emod_eq_zero]
      <;> ring_nf
      <;> simp [Int.mul_emod]
      <;> norm_num
  -- Since Set.range (fun k : ℤ => 2 * k) is denumerable, {n : ℤ | even n} is denumerable
  rw [h]
  -- The range of an injective function from ℤ to ℤ is denumerable
  have h₁ : Denumerable (Set.range (fun k : ℤ => 2 * k)) := by
    apply Denumerable.of_injective (fun k : ℤ => (2 * k : Set.range (fun k : ℤ => 2 * k)))
    intro k₁ k₂ h₂
    simp [Set.mem_range] at h₂
    obtain ⟨_, h₃⟩ := h₂
    -- The function (fun k : ℤ => 2 * k) is injective
    simp_all [mul_left_inj]
    <;> linarith
  exact h₁
