    have h₂ : Holo(φ₀'') := by sorry
    have h₃ : ContDiffOn ℂ ∞ (φ₀'' : ℂ → ℂ) ℍ₀ := h₂.contDiffOn isOpen_upperHalfPlaneSet
    exact h₃.ofComplex (by
      -- Show that the space of smooth complex functions is contained in the space of smooth real functions
      apply ContDiffOn.submodule
      exact contDiffOn.eval _ _ )
