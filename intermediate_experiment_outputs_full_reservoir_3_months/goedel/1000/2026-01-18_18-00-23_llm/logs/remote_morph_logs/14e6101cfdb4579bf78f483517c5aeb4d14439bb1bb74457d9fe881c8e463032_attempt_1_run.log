      have h₅ : ContDiffOn ℝ ⊤ (fun z : ℂ => (z : ℂ) : ℂ → ℂ) ℍ₀ := contDiffOn_id
      have h₆ : (fun z : ℂ => (z : ℂ)) = (fun z : ℂ => (z : ℂ)) := rfl
      have h₇ : ∀ z ∈ ℍ₀, (z : ℂ) ≠ 0 := by
        intro z hz
        have h₈ : z.im > 0 := hz
        have h₉ : z.re = z.re := rfl
        have h₁₀ : z.im = z.im := rfl
