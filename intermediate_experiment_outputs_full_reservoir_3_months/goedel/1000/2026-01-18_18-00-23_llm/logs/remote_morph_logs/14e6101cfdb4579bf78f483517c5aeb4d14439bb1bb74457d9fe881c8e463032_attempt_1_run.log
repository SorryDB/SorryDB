theorem Φ₅'_contDiffOn : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by
  have h₁ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z * (Complex.exp (-(r : ℂ) * z) : ℂ)) ℍ₀ := by
    -- Prove that the function is smooth using the fact that it is a product of smooth functions
    have h₂ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z : ℂ → ℂ) ℍ₀ := by sorry
    have h₃ : ContDiffOn ℝ ∞ (fun z : ℂ => (Complex.exp (-(r : ℂ) * z) : ℂ)) ℍ₀ := by sorry
    -- Use the fact that the product of two smooth functions is smooth
    have h₄ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z * (Complex.exp (-(r : ℂ) * z) : ℂ)) ℍ₀ :=
      h₂.mul h₃
    exact h₄
  -- Show that the function is smooth on the upper half plane
  have h₂ : ContDiffOn ℝ ∞ (fun z : ℂ => (z : ℂ) ^ 2 : ℂ → ℂ) ℍ₀ := by sorry
  -- Use the fact that the product of two smooth functions is smooth
  have h₃ : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by
    have h₄ : (Φ₅' r : ℂ → ℂ) = (fun z : ℂ => φ₀'' z * (Complex.exp (-(r : ℂ) * z) : ℂ)) * (fun z : ℂ => (z : ℂ) ^ 2 : ℂ → ℂ) := by sorry
    rw [h₄]
    -- Use the fact that the product of two smooth functions is smooth
    have h₅ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z * (Complex.exp (-(r : ℂ) * z) : ℂ)) ℍ₀ := h₁
    have h₆ : ContDiffOn ℝ ∞ (fun z : ℂ => (z : ℂ) ^ 2 : ℂ → ℂ) ℍ₀ := h₂
    exact h₅.mul h₆
  exact h₃
```

### Explanation of the Proof
1. **Split into Factors**: The function `Φ₅' r` is expressed as a product of two functions: `φ₀'' z * exp(-r * z)` and `z²`. 
2. **Smoothness of Each Factor**: 
   - The first factor is smooth because it is a product of the smooth functions `φ₀''` and `exp(-r * z)`.
   - The second factor is smooth because it is a polynomial in `z`.
3. **Product of Smooth Functions**: The product of two smooth functions is smooth.
4. **Conclusion**: Since both factors are smooth on the upper half-plane, their product is also smooth there.

