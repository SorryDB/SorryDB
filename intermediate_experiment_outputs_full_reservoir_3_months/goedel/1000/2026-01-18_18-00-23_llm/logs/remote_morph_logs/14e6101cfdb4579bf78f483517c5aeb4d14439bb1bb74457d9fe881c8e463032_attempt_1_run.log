theorem Φ₅'_contDiffOn : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by
  have h₁ : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by
    have h₂ : Holo(Φ₅' r) := Φ₅'_holo
    -- Use the fact that a holomorphic function is smooth to get the required result
    have h₃ : ContDiffOn ℂ ∞ (Φ₅' r) ℍ₀ := h₂.contDiffOn isOpen_upperHalfPlaneSet
    -- Convert the complex smoothness to real smoothness
    have h₄ : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by
      -- Use the fact that complex smoothness implies real smoothness
      convert h₃.ofReal using 1
      <;> simp [Complex.ext_iff]
      <;> norm_cast
      <;> simp_all [Complex.ext_iff]
      <;> ring_nf
      <;> simp_all [Complex.ext_iff]
    exact h₄
  exact h₁
