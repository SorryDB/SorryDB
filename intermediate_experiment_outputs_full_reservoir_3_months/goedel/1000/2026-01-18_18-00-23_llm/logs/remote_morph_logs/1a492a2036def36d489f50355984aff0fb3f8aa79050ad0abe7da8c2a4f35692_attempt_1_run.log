theorem align_swap {α : Type} {n : ℕ} {a : Fin n → α} : a = (a ∘ Fin.swap 0 1 ∘ Fin.swap 0 1) := by
  have h : a = (a ∘ Fin.swap 0 1 ∘ Fin.swap 0 1) := by
    funext i
    -- We need to show that for every index i, a i = (a ∘ Fin.swap 0 1 ∘ Fin.swap 0 1) i.
    -- This means we need to show that applying the swaps twice returns the original value.
    -- We handle the cases where i is 0, 1, or neither separately.
    fin_cases i <;> simp [Function.comp_apply, Fin.swap_apply_of_ne_of_ne] <;>
      (try decide) <;>
      (try {
        -- If n is 0, the Fin type is empty, and the statement is vacuously true.
        -- If n is 1, the Fin type has only one element, and the swaps do nothing.
        -- If n is 2, we can directly check the swaps.
        -- For n ≥ 3, we need to ensure that the swaps do not affect other elements.
        cases n <;> simp_all [Fin.ext_iff]
        <;>
          (try { contradiction }) <;>
          (try { omega }) <;>
          (try { aesop })
      }) <;>
      (try {
        -- We use the fact that swapping twice returns the original value.
        cases n <;> simp_all [Fin.ext_iff]
        <;>
          (try { contradiction }) <;>
          (try { omega }) <;>
          (try { aesop })
      })
  exact h
