open Finset Set

World "L22Pset"
Level 2
Title "Continuity Exercise"
Introduction "
# Level 2: Continuity Exercise

Prove that `x ↦ x ^ 3` is continuous.

"

/-- Prove this
-/
Statement : FunCont (fun x ↦ x ^ 3) := by
intro x ε hε
let δ : ℝ := min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
have δle1 : δ ≤ 1 := by
  dsimp only [δ]
  exact min_le_left _ _
have δle2 : δ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
  dsimp only [δ]
  exact min_le_right _ _
have δpos : 0 < δ := by
  have h₁ : 0 < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
    have h₂ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by positivity
    have h₃ : 0 < ε := by linarith
    exact div_pos h₃ h₂
  have h₂ : 0 < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := by
    exact lt_min (by norm_num) h₁
  simpa [δ] using h₂
have h₃ : ∀ (y : ℝ), |y - x| < δ → |y ^ 3 - x ^ 3| < ε := by
  intro y hy
  have h₄ : |y - x| < δ := hy
  have h₅ : |y - x| < 1 := by
    calc
      |y - x| < δ := h₄
      _ ≤ 1 := δle1
  have h₆ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
    calc
      |y - x| < δ := h₄
      _ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := δle2
  have h₇ : |y| ≤ |x| + 1 := by
    calc
      |y| = |y - x + x| := by ring_nf
      _ ≤ |y - x| + |x| := abs_add (y - x) x
      _ < 1 + |x| := by linarith
      _ = |x| + 1 := by ring
  have h₈ : |y ^ 3 - x ^ 3| < ε := by
    have h₉ : y ^ 3 - x ^ 3 = (y - x) * (y ^ 2 + y * x + x ^ 2) := by ring
    rw [h₉]
    have h₁₀ : |(y - x) * (y ^ 2 + y * x + x ^ 2)| = |y - x| * |y ^ 2 + y * x + x ^ 2| := by
      rw [abs_mul]
    rw [h₁₀]
    have h₁₁ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := h₆
    have h₁₂ : |y ^ 2 + y * x + x ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
      have h₁₃ : |y| ≤ |x| + 1 := h₇
      have h₁₄ : |y ^ 2 + y * x + x ^ 2| ≤ |y| ^ 2 + |y| * |x| + |x| ^ 2 := by
        calc
          |y ^ 2 + y * x + x ^ 2| ≤ |y ^ 2| + |y * x| + |x ^ 2| := by
            calc
              |y ^ 2 + y * x + x ^ 2| ≤ |y ^ 2 + y * x| + |x ^ 2| := abs_add (y ^ 2 + y * x) (x ^ 2)
              _ ≤ (|y ^ 2| + |y * x|) + |x ^ 2| := by
                have h₁₅ : |y ^ 2 + y * x| ≤ |y ^ 2| + |y * x| := abs_add (y ^ 2) (y * x)
                linarith
              _ = |y ^ 2| + |y * x| + |x ^ 2| := by ring
          _ = |y| ^ 2 + |y| * |x| + |x| ^ 2 := by
            simp [abs_mul, abs_pow]
            <;> ring_nf
            <;> simp [abs_mul, abs_pow]
            <;> ring_nf
      have h₁₅ : |y| ^ 2 + |y| * |x| + |x| ^ 2 ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
        have h₁₆ : |y| ≤ |x| + 1 := h₇
        have h₁₇ : 0 ≤ |x| := abs_nonneg x
        have h₁₈ : 0 ≤ |y| := abs_nonneg y
        nlinarith [sq_nonneg (|y| - |x| - 1), sq_nonneg (|y| - 1)]
      linarith
    have h₁₃ : |y - x| * |y ^ 2 + y * x + x ^ 2| < (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by
      have h₁₄ : 0 ≤ |y ^ 2 + y * x + x ^ 2| := abs_nonneg _
      have h₁₅ : 0 ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by positivity
      have h₁₆ : 0 ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by positivity
      have h₁₇ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := h₆
      nlinarith
    have h₁₄ : (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) = ε := by
      have h₁₅ : 3 * |x| ^ 2 + 3 * |x| + 1 ≠ 0 := by positivity
      field_simp [h₁₅]
      <;> ring
      <;> linarith
    linarith
  exact h₈
  <;> norm_num
exact ⟨δ, δpos, h₃⟩
