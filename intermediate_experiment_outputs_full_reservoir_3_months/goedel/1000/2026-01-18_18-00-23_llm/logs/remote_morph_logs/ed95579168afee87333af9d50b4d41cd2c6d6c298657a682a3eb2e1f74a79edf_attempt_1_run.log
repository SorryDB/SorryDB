lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · -- Existence of m such that if p = 4m + 1, then num_solutions = 2
    use 1
    intro hp
    have h₁ : p = 5 := by
      have h₂ : p = 4 * 1 + 1 := by omega
      omega
    simp_all [h₁]
    <;>
    (try decide) <;>
    (try
      {
        rfl
      }) <;>
    (try
      {
        norm_num [Finset.card_eq_zero]
        <;>
        simp_all [ZMod.nat_cast_self]
        <;>
        decide
      })
  · constructor
    · -- If p = 2, then num_solutions = 1
      intro hp
      have h₁ : p = 2 := hp
      simp_all [h₁]
      <;>
      (try decide) <;>
      (try
        {
          rfl
        }) <;>
      (try
        {
          norm_num [Finset.card_eq_zero]
          <;>
          simp_all [ZMod.nat_cast_self]
          <;>
          decide
        })
    · -- Existence of m such that if p = 4m + 1, then num_solutions = 0
      use 0
      intro hp
      have h₁ : p = 1 := by
        have h₂ : p = 4 * 0 + 1 := by omega
        omega
      have h₂ : p ≠ 1 := by
        have h₃ : p.Prime := Fact.out
        have h₄ : ¬ p = 1 := by
          intro h₄
          rw [h₄] at h₃
          norm_num at h₃
        exact h₄
      exfalso
      apply h₂
      linarith
