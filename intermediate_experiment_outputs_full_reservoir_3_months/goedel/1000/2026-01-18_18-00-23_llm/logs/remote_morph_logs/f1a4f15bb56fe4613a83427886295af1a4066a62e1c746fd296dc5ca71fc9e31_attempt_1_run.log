### Solution

```lean
theorem to_montgomery_spec (e : EdwardsPoint) :
    ∃ mp,
    to_montgomery e = ok mp ∧

    let Y := Field51_as_Nat e.Y
    let Z := Field51_as_Nat e.Z
    let u := U8x32_as_Nat mp

    if (Z - Y) % p = 0 then
      u % p = 0
    else
      u * (Z - Y) % p = (Z + Y) % p := by
  refine' ⟨0, _⟩
  simp [to_montgomery]
  <;> norm_num [Field51_as_Nat, U8x32_as_Nat]
  <;> split_ifs <;> try norm_num [Nat.add_mod, Nat.mul_mod, Nat.mod_mod]
  <;> try omega
  <;> try ring_nf
  <;> try norm_num [Nat.add_assoc]
```
