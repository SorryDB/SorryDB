theorem to_montgomery_spec (e : EdwardsPoint) :
    ∃ mp,
    to_montgomery e = ok mp ∧

    let Y := Field51_as_Nat e.Y
    let Z := Field51_as_Nat e.Z
    let u := U8x32_as_Nat mp

    if (Z - Y) % p = 0 then
      u % p = 0
    else
      u * (Z - Y) % p = (Z + Y) % p := by
  use defaultMontgomeryPoint
  simp_all [to_montgomery]
  <;>
  (try decide) <;>
  (try
    {
      split_ifs <;>
      simp_all [Field51_as_Nat, U8x32_as_Nat, Nat.mod_eq_of_lt] <;>
      norm_num <;>
      rfl
    }) <;>
  (try
    {
      simp_all [Field51_as_Nat, U8x32_as_Nat, Nat.mod_eq_of_lt] <;>
      norm_num <;>
      rfl
    }) <;>
  (try
    {
      exfalso <;>
      simp_all [Field51_as_Nat, U8x32_as_Nat, Nat.mod_eq_of_lt] <;>
      norm_num <;>
      contradiction
    })
