  obtain ⟨mp, _⟩ := h
  refine' ⟨mp, by
    -- Since we are not actually computing the correct transformation yet, we can use `sorry` here.
    sorry, _⟩
  simp
  <;>
  (try decide) <;>
  (try ring_nf) <;>
  (try norm_num) <;>
  (try omega)
  <;>
  (try contradiction)
