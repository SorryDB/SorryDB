theorem const_add_le_add_const {G : Type*} [CancellativeCommMonoidWithZero G] [OrderedSemiring G] {a b : G} (ha : 0 ≤ a) (hb : 0 ≤ b) : ∀ {n : ℕ}, a + n • b ≤ n • b + a := by
  intro n
  induction n with
  | zero => simp
