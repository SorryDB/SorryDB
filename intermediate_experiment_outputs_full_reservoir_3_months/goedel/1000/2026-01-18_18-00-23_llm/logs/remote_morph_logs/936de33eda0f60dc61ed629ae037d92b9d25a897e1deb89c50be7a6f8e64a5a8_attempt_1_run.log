    have h₃ := hA 0
    have h₄ : ∃! ab ∈ A ×ˢ (f.eval '' {n : ℤ | 0 < n}), (0 : ℤ) = ab.1 + ab.2 := h₃
    rcases h₄ with ⟨⟨a, b⟩, ⟨ha, hb⟩, h₁⟩
    rcases hb with ⟨n, hn, rfl⟩
