theorem ContextFreeDerivation.exhaustive_imp_child_exhaustive
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition) :
  ∀ u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }),
  ∀ step : ContextFreeDerivationStep G u,
  ∀ derivation : ContextFreeDerivation G u' v,
  ∀ sound : _,
  cfd = ContextFreeDerivation.step step derivation sound →
  derivation.exhaustiveCondition := by
    intro u' step derivation sound h₁
    have h₂ : cfd = ContextFreeDerivation.step step derivation sound := h₁
    have h₃ : derivation.exhaustiveCondition := by
      have h₄ : cfd = ContextFreeDerivation.step step derivation sound := h₂
      have h₅ : cfd.exhaustiveCondition := h_exhaustive
      have h₆ : (ContextFreeDerivation.step step derivation sound).exhaustiveCondition := by
        rw [exhaustiveCondition]
        intro a
        have h₇ := h₅ a
        simp_all [exhaustiveCondition]
        <;>
          (try cases' cfd with cfd) <;>
          (try cases' derivation with derivation) <;>
          (try simp_all [step, sound]) <;>
          (try tauto) <;>
          (try simp_all [step, sound, exhaustiveCondition]) <;>
          (try tauto)
      simpa [h₄] using h₆
    exact h₃

```
