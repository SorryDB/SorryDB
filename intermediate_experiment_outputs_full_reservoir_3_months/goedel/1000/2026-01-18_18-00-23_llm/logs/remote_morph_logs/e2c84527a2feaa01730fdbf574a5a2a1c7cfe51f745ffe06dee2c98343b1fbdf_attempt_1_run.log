```lean
have ha' : a (n + 1) = a n := by
  have h₁ : (a n + b n) / 2 - a n = (b n - a n) / 2 := by ring
  have h₂ : (a n + b n) / 2 - a n ≥ 0 := by
    have h₃ : a n ≤ b n := by
      have h₄ : a n ≤ b n := (ab n).property.2.2.1
      exact h₄
    linarith
  have h₃ : (n : ℕ) = n := rfl
  have h₄ : a (n + 1) = a n := by
    simp [a, b] at *
    -- When the midpoint is not an upper bound, the new interval is [a_n, a_n]
    have h₅ : (ab (n + 1)).val = (a n, (a n + b n) / 2) := by
      -- Use the fact that there is no element in S ≥ midpoint to deduce the new interval
      simp_all [ab, Nat.recAux]
      <;>
      (try { contradiction }) <;>
      (try {
        simp_all [midS]
        <;>
        (try { linarith })
        <;>
        (try {
          norm_num at *
          <;>
          linarith
        })
      }) <;>
      (try {
        aesop
      }) <;>
      (try {
        exfalso
        -- Use the properties of the set and the midpoint to derive a contradiction
        -- if the midpoint is not an upper bound.
        have h₆ := midS
        push_neg at h₆
        have h₇ := h₆ (a n) (a_prop n)
        linarith
      })
    simp_all [h₅]
    <;>
    (try {
      ring_nf at *
      <;>
      linarith
    })
  exact h₄
