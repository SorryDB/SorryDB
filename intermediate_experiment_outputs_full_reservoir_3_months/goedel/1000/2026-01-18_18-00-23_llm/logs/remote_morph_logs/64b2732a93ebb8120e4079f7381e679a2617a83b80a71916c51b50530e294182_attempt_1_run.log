theorem diagonalHasLaw (n : ℕ) (i : Fin n) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
  have h₁ : HasLaw (fun ω : WignerSpace n => (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, Matrix.of_apply, WignerMeasure]
    <;>
    simp_all [MeasureTheory.hasLaw_pi_iff, Index, Fin.ext_iff, wignerMeasureDist]
    <;>
    (try aesop)
    <;>
    (try simp_all [Fin.ext_iff])
    <;>
    (try cases n <;> simp_all [Fin.ext_iff, Nat.cast_zero, Nat.cast_add, Nat.cast_one])
    <;>
    (try
      {
        aesop
      })
  exact h₁
