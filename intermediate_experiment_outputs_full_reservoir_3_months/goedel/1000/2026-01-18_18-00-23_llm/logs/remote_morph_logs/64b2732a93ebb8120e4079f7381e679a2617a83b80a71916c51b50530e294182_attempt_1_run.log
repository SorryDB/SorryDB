lemma diagonal_has_law (n : ℕ) (i : Fin n) :
    HasLaw (fun ω => wignerMatrixMap n ω i i) ν (WignerMeasure μ ν n) := by
  have h₁ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, i), le_refl i⟩ : Index n)) ν (WignerMeasure μ ν n) := by
    -- Use the definition of WignerMeasure and the fact that the diagonal entries have distribution ν
    have h₂ : (WignerMeasure μ ν n) = Measure.pi (fun (p : Index n) => if p.val.1 = p.val.2 then ν else μ) := rfl
    rw [h₂]
    -- Use the property of the product measure to get the measure for each coordinate
    have h₃ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, i), le_refl i⟩ : Index n)) (if (⟨(i, i), le_refl i⟩ : Index n).val.1 = (⟨(i, i), le_refl i⟩ : Index n).val.2 then ν else μ) (Measure.pi _ ) := by
      apply MeasureTheory.hasLaw_pi_of_injOn measurable_fst (by
        -- Show that the function is injective on the product space
        intro ω₁ ω₂ h
        simp_all [Index.ext_iff]
        <;>
        (try decide) <;>
        (try simp_all [Fin.ext_iff]) <;>
        (try aesop)
      )
    -- Simplify the condition in the if statement
    have h₄ : (if (⟨(i, i), le_refl i⟩ : Index n).val.1 = (⟨(i, i), le_refl i⟩ : Index n).val.2 then ν else μ) = ν := by
      simp [Index.ext_iff]
      <;>
      aesop
    rw [h₄] at h₃
    exact h₃
  -- Relate the diagonal entry to the coordinate in WignerSpace
  have h₂ : (fun ω => wignerMatrixMap n ω i i) = (fun ω => ω (⟨(i, i), le_refl i⟩ : Index n)) := by
    funext ω
    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]
    <;>
    aesop
  rw [h₂]
