```lean
lemma diagonalHasLaw (n : ℕ) (i : Fin n) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
  have h₁ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i i) = (fun ω : WignerSpace n => ω ⟨(i, i), by simpa using le_refl i⟩) := by
    funext ω
    rw [wignerMatrixMap]
    rw [wignerMatrixMap']
    simp [wignerMatrixEntryFunction]
    <;>
    simp_all [Fin.ext_iff, Fin.val_mk]
    <;>
    norm_num
    <;>
    aesop
  rw [h₁]
  have h₂ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, i), by simpa using le_refl i⟩) ν (WignerMeasure μ ν n) := by
    apply HasLaw.congr (Measure.pi_hasLaw (wignerMeasureDist μ ν n))
    <;> simp [wignerMeasureDist]
    <;> aesop
  exact h₂
```

