theorem diagonalHasLaw (n : ℕ) (i : Fin n) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
  have h : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by
    -- Extract the probability measure for the element ⟨(i, i), _⟩ in Index n
    have h₁ : (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) = ν := by
      simp [wignerMeasureDist]
      <;>
      aesop
    -- Use the fact that the coordinate projections are independent with the given measures
    -- and each coordinate is either μ or ν depending on whether it is diagonal or not
    -- to get the desired probability measure for ω ⟨(i, i), _⟩
    have h₂ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (WignerMeasure μ ν n) := by
      apply Measure.FreeProduct.hasLaw
      <;>
      simp_all [wignerMeasureDist, WignerMeasure]
      <;>
      aesop
    -- Substitute the extracted measure ν into the result
    rw [h₁] at h₂
    exact h₂
  -- Show that the i-th diagonal entry of the matrix is equal to ω ⟨(i, i), _⟩
  have h₂ : (fun ω : WignerSpace n ↦ (wignerMatrixMap n ω) i i) = (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) := by
    funext ω
    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]
    <;>
    simp_all [Fin.ext_iff, Fin.val_mk]
    <;>
    aesop
  -- Use the fact that the two functions are equal to conclude the proof
  have h₃ : HasLaw (fun ω : WignerSpace n ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
    rw [h₂] at *
    exact h
  exact h₃
