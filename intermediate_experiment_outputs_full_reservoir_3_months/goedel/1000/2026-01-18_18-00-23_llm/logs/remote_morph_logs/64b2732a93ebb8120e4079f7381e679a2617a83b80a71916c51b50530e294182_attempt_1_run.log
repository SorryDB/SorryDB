lemma diagonalHasLaw (n : ℕ) (i : Fin n) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i i) = (fun ω ↦ (wignerMatrixEntryFunction ω) i i) := by
    funext ω
    <;> simp [wignerMatrixMap, wignerMatrixMap']
    <;> rfl
  rw [h₁]
  have h₂ : (fun ω ↦ (wignerMatrixEntryFunction ω) i i) = (fun ω ↦ ω ⟨(i, i), le_refl i⟩) := by
    funext ω
    simp [wignerMatrixEntryFunction]
    <;> split_ifs <;> simp_all (config := {decide := true})
    <;> try { contradiction }
    <;> try { linarith }
  rw [h₂]
  -- The projection map is measurable, and we can use the product measure to find the law
  have h₃ : HasLaw (fun ω ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by
    classical
    have h₄ : i = i := rfl
    -- The law of the projection is given by the corresponding measure in the product
    have h₅ : (WignerMeasure μ ν n) = Measure.pi (wignerMeasureDist μ ν n) := rfl
    rw [h₅]
    -- Use the property of the product measure to get the law of the projection
    have h₆ : (Measure.pi (wignerMeasureDist μ ν n)).prod = ⊤ := by
      simp [Measure.pi]
    -- The projection is measurable and the law is given by the corresponding measure
    have h₇ : HasLaw (fun ω : Index n → ℝ => ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (Measure.pi (wignerMeasureDist μ ν n)) := by
      apply hasLaw_pi
      <;> simp [h₄]
    -- Simplify the expression to match the required form
    have h₈ : wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩ = ν := by
      dsimp [wignerMeasureDist]
      <;> simp [le_refl]
      <;> aesop
    rw [h₈] at h₇
    exact h₇
  exact h₃
