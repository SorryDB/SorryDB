lemma IsMatching.encard_le (hM : G.IsMatching M) : M.encard ≤ ν(G) := by
  have h : ∃ M, G.IsMatching M ∧ M.encard = M.encard := ⟨M, hM, rfl⟩
  have h₁ : M.encard ≤ ν(G) := by
    apply le_csSup
    · exact ⟨0, by
        simp [MatchingNumber]
        <;>
        (try decide) <;>
        (try
          {
            use ∅
            simp [IsMatching, Set.Subset.refl, Disjoint]
            <;>
            aesop
          })
        ⟩
    · simp [MatchingNumber]
      <;>
      (try decide) <;>
      (try
        {
          use M
          <;>
          aesop
        })
  exact h₁
