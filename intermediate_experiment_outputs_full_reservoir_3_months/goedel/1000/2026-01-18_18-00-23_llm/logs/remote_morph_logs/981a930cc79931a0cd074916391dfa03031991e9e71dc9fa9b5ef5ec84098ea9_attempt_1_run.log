theorem Set.pairwise_le_image_of_le (s : Set α) (t : Set β) {f : α → β} 
    {g : β → β} {h : α → β} (hf : Monotone f) (hg : Monotone g) 
    (hh : ∀ a ∈ s, f a ≤ g (h a)) (a₁ : α) (a₂ : α) (ha₁ : a₁ ∈ s) (ha₂ : a₂ ∈ s) : 
