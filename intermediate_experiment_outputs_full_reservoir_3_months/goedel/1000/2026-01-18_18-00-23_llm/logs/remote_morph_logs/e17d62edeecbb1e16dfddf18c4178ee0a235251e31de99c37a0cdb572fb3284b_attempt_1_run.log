  have h₁ : (F.map s).map t ≤ H := by
    -- Since G.map t ≤ H and F.map s ≤ G, we have (F.map s).map t ≤ G.map t ≤ H.
    have h₂ : (F.map s).map t ≤ G.map t := by
      -- (F.map s).map t = F.map (t ∘ s) and G.map t is G.map t.
      -- Since F.map s ≤ G, we have (F.map s).map t ≤ G.map t.
      exact Filter.map_mono hs
    -- Now we use the fact that G.map t ≤ H.
