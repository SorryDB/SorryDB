section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact h.map f
  <;> simp_all [Filter.map_le]
  <;> aesop

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : (F.map s).map t ≤ H := by
    have h2 : F.map s ≤ G := hs
    have h3 : (F.map s).map t ≤ G.map t := h2.map t
    have h4 : G.map t ≤ H := ht
    exact le_trans h3 h4
  have h5 : F.map (t ∘ s) = (F.map s).map t := by
    ext S
    simp [Filter.mem_map, Function.comp]
    <;> aesop
  rw [h5]
  exact h1

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h1 : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h1

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h1 : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h1

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : ({x | p x ∧ q x} : Set α) ∈ 𝓝 x := by
    have h2 : ({x | p x} : Set α) ∈ 𝓝 x := hT
    have h3 : ({x | q x} : Set α) ∈ 𝓝 x := hS
    have h4 : ({x | p x ∧ q x} : Set α) ∈ 𝓝 x := by
      apply mem_nhds_iff.mpr
      obtain ⟨s, hs, hs'⟩ := mem_nhds_iff.mp h2
      obtain ⟨t, ht, ht'⟩ := mem_nhds_iff.mp h3
      refine' ⟨s ∩ t, ⟨_, _⟩, _⟩
      · exact IsOpen.inter hs ht
      · aesop
      · intro y hy
        aesop
    exact h4
  have h5 : ({x | p' x ∧ q' x} : Set α) ∈ 𝓝 x := by
    have h6 : ({x | p' x} : Set α) ∈ 𝓝 x := hT'
    have h7 : ({x | q' x} : Set α) ∈ 𝓝 x := hS'
    have h8 : ({x | p' x ∧ q' x} : Set α) ∈ 𝓝 x := by
      apply mem_nhds_iff.mpr
      obtain ⟨s, hs, hs'⟩ := mem_nhds_iff.mp h6
      obtain ⟨t, ht, ht'⟩ := mem_nhds_iff.mp h7
      refine' ⟨s ∩ t, ⟨_, _⟩, _⟩
      · exact IsOpen.inter hs ht
      · aesop
      · intro y hy
        aesop
    exact h8
  have h9 : ({x | p x ∧ q x ∨ p' x ∧ q' x} : Set α) ∈ 𝓝 x := by
    apply mem_nhds_iff.mpr
    obtain ⟨s, hs, hs'⟩ := mem_nhds_iff.mp h1
    obtain ⟨t, ht, ht'⟩ := mem_nhds_iff.mp h5
    refine' ⟨s ∪ t, ⟨_, _⟩, _⟩
    · exact IsOpen.union hs ht
    · aesop
    · intro y hy
      by_cases h10 : y ∈ s <;> by_cases h11 : y ∈ t <;> simp_all [Set.mem_union]
      <;> (try { aesop }) <;> (try { tauto })
  exact h9


end Filter

