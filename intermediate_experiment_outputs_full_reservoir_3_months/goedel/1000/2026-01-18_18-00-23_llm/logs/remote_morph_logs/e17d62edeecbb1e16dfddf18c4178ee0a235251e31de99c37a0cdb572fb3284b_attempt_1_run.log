    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Use the composition property of Tendsto to combine the given limits
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Apply the composition rule for Tendsto
    exact Tendsto_comp hf hg
  -- The result follows directly from the composition property
  exact h

