    ext <;>
    simp [Set.image] <;>
    congr <;>
    ext <;>
    simp [Function.comp]
    <;>
    aesop
  -- Therefore, F.map (t ∘ s) ≤ H.
  have h₃ : F.map (t ∘ s) ≤ H := by
    rw [h₂]
    exact h₁
  -- And this means Tendsto (t ∘ s) F H.
  exact h₃

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
