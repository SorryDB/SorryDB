  have h₁ : s ∈ G.map f := by
    -- Since F ≤ G, we can use the property of the map function to show that s is in the image of G under f.
    have h₂ : s ∈ F.map f := hs
    have h₃ : F.map f ≤ G.map f := by
      -- The map function preserves the order of filters.
      exact Filter.map_mono h
    -- Therefore, s is in the image of G under f.
    exact h₃ h₂
