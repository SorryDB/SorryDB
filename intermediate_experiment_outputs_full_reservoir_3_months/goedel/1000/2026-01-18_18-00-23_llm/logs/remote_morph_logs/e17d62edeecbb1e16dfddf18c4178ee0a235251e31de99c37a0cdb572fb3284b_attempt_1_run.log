```lean
noncomputable section

namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  have h₁ : F.map f ≤ G.map f := by
    -- Use the property of the `map` function on filters to preserve the order
    exact Filter.map_mono h
  exact h₁

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h₁ : F.map (t ∘ s) ≤ H := by
    -- Use the fact that the composition of functions maps the filter F to H
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        -- Show that mapping with the composition is the same as mapping with s and then t
        rw [← Filter.map_comp]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Use the fact that G.map t ≤ H
        exact ht
  -- Conclude that Tendsto (t ∘ s) F H
  exact h₁

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h₁ : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the composition of tendsto to show the result
    exact Tendsto_comp hf hg
  exact h₁

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h₁ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    -- Use the composition of tendsto to show the result
    exact Tendsto_comp ha hφ
  exact h₁

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of neighborhoods is a neighborhood
    have h₂ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      apply Filter.inter_mem
      · exact hT
      · exact hS
    have h₃ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      apply Filter.inter_mem
      · exact hT'
      · exact hS'
    -- Use the fact that the union of neighborhoods is a neighborhood
    have h₄ : ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) ∈ 𝓝 x := by
      apply Filter.union_mem
      · exact h₂
      · exact h₃
    -- Show that the set is contained in the union of the intersections
    have h₅ : ({x : α | p x ∧ q x} : Set α) = {x : α | p x} ∩ {x : α | q x} := by
      ext x
      simp [and_comm]
      <;> aesop
    have h₆ : ({x : α | p' x ∧ q' x} : Set α) = {x : α | p' x} ∩ {x : α | q' x} := by
      ext x
      simp [and_comm]
      <;> aesop
    have h₇ : ({x : α | p x ∧ q x ∨ p' x ∧ q' x} : Set α) = ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) := by
      ext x
      simp only [h₅, h₆]
      <;>
      (try simp_all [Set.mem_union, Set.mem_inter_iff]) <;>
      (try tauto) <;>
      (try aesop) <;>
      (try
        {
          by_cases h : p x <;> by_cases h' : q x <;> by_cases h'' : p' x <;> by_cases h''' : q' x <;> simp_all [h, h', h'', h''']
          <;> tauto
        })
    rw [h₇]
    exact h₄
  exact h₁

end Filter

