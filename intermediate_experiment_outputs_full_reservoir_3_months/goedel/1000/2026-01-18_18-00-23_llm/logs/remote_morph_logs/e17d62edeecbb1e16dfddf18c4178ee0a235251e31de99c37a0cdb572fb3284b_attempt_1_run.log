/-
# Filters
-/

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  exact h (By simpa [Filter.map] using hs)
   /-
   We need to show that F.map f ≤ G.map f given F ≤ G. Let's recall the definition of map for filters: for a filter F and a function f, F.map f is the filter generated by the sets { f(x) | x ∈ s } for each s ∈ F. To show F.map f ≤ G.map f, we need to show that every set in F.map f is in G.map f. 

   Given F ≤ G, for any set s ∈ F, we know s ∈ G as well. Now, for any set t ∈ F.map f, there exists a set s ∈ F such that t = { f(x) | x ∈ s }. Since s ∈ F and F ≤ G, we have s ∈ G. Therefore, t = { f(x) | x ∈ s } is also in G.map f. This shows that F.map f ≤ G.map f.

   In Lean, we can use the fact that h : F ≤ G to directly show that for any t ∈ F.map f, t ∈ G.map f, because h will allow us to transfer the membership from F to G.

   The `mono` lemma is thus proved using the `h` hypothesis and the properties of the filter map operation. The actual Lean proof will use `h` to lift the membership from F to G and then apply the definition of the filter map to conclude that F.map f ≤ G.map f.
   -/
  

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h₁ : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = F.map s |>.map t := by
        ext
        simp [Filter.map, Function.comp]
        <;>
        simp_all [Set.image]
        <;>
        congr 1 <;> ext <;> simp [Function.comp]
        <;>
        aesop
      _ ≤ G.map t := by
        -- Since `F.map s ≤ G`, we can use the monotonicity of the `map` operation with respect to `t`.
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since `G.map t ≤ H`, we can directly conclude the proof.
        exact ht
  -- Now we need to convert `h₁ : F.map (t ∘ s) ≤ H` into `Tendsto (t ∘ s) F H`.
  exact h₁
  /-
  The proof leverages the fact that the composition of functions can be broken down into two separate mappings, each of which respects the filter structure. Specifically, we use the fact that the map of a composition is the composition of the maps, and then use the monotonicity of the map operation to transfer the inequalities. 
  -/
  

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    have h1 : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h2 : Tendsto g (𝓝 Real.pi) atTop := hg
    have h3 : Tendsto (g ∘ f) (𝓝 0) atTop := by
      -- Use the composition of tendsto to show that (g ∘ f) tends to atTop along (𝓝 0)
      have h4 : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp h1 h2
      exact h4
    exact h3
  exact h
  
example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    have h1 : Tendsto a atTop (𝓝 (-1)) := ha
    have h2 : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
    have h3 : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp h1 h2
    exact h3
  exact h
   /-
   Given the two tendsto statements, we can directly use the composition property of tendsto to get the desired result.
   -/
  

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
    exact Inter_mem hT hS
  have h₂ : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
    exact Inter_mem hT' hS'
  have h₃ : ({x | p x} ∩ {x | q x}) ∪ ({x | p' x} ∩ {x | q' x}) ∈ 𝓝 x := by
    exact Union_mem h₁ h₂
  have h₄ : ({x | p x} ∩ {x | q x}) ∪ ({x | p' x} ∩ {x | q' x}) ⊆ {x | p x ∧ q x ∨ p' x ∧ q' x} := by
    intro x hx
    simp only [Set.mem_union, Set.mem_inter_iff, Set.mem_setOf_eq] at hx ⊢
    tauto
  exact mem_of_superset h₃ h₄
  
  /-
  We use the fact that the union and intersection of neighborhoods are neighborhoods to show that the set {x | p x ∧ q x ∨ p' x ∧ q' x} is a neighborhood of x. Specifically, we use the fact that the intersection of two neighborhoods is a neighborhood and the union of two neighborhoods is a neighborhood.
  -/
  
end Filter

