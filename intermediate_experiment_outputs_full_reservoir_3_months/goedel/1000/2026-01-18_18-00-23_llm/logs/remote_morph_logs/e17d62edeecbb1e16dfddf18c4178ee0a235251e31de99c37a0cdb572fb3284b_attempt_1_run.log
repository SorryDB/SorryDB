namespace ItaLean

/-!
# Filters
-/


section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact Filter.map_mono h

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h : (F.map s).map t ≤ H := by
    calc
      (F.map s).map t ≤ G.map t := by
        -- Use the fact that `F.map s ≤ G` to get `F.map s.map t ≤ G.map t`
        exact Filter.map_mono hs
      _ ≤ H := ht
  -- Simplify the composition of maps
  have h₁ : (F.map (t ∘ s)) = (F.map s).map t := by
    simp [Function.comp, Filter.map_map]
  -- Use the fact that `(t ∘ s).map F ≤ H`
  calc
    F.map (t ∘ s) = (F.map s).map t := by rw [h₁]
    _ ≤ H := h

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : ({x | p x} ∩ {x | q x}) ∈ 𝓝 x := by
    exact mem_nhds_inter hT hS
  have h2 : ({x | p' x} ∩ {x | q' x}) ∈ 𝓝 x := by
    exact mem_nhds_inter hT' hS'
  -- Use the fact that the union of two neighborhoods is a neighborhood
  have h3 : ({x | p x ∧ q x ∨ p' x ∧ q' x} : Set α) = ({x | p x} ∩ {x | q x}) ∪ ({x | p' x} ∩ {x | q' x}) := by
    ext x
    simp [and_assoc]
    <;> tauto
  rw [h3]
  exact nhds_union h1 h2

end Filter

