example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x : α | p x ∧ q x} ∈ 𝓝 x := by
    have h2 : {x : α | p x} ∈ 𝓝 x := hT
    have h3 : {x : α | q x} ∈ 𝓝 x := hS
    have h4 : {x : α | p x ∧ q x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood
      have h5 : {x : α | p x ∧ q x} = {x : α | p x} ∩ {x : α | q x} := by
        ext x
        simp [and_imp]
        <;> tauto
      rw [h5]
      -- The intersection of two neighborhoods is a neighborhood
      exact Filter.inter_mem h2 h3
    exact h4
  have h6 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    have h7 : {x : α | p' x} ∈ 𝓝 x := hT'
    have h8 : {x : α | q' x} ∈ 𝓝 x := hS'
    have h9 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood
      have h10 : {x : α | p' x ∧ q' x} = {x : α | p' x} ∩ {x : α | q' x} := by
        ext x
        simp [and_imp]
        <;> tauto
      rw [h10]
      -- The intersection of two neighborhoods is a neighborhood
      exact Filter.inter_mem h7 h8
    exact h9
  have h11 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    -- The union of two neighborhoods is a neighborhood
    have h12 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} = {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} := by
      ext x
      simp [or_imp]
      <;> tauto
    rw [h12]
