lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h_main : Tendsto (t ∘ s) F H := by
    calc
      (F.map (t ∘ s)) = F.map (fun x => t (s x)) := rfl
      _ = (F.map s).map t := by rw [Filter.map_map]
      _ ≤ G.map t := by
        -- Use the fact that Tendsto s F G (F.map s ≤ G) implies (F.map s).map t ≤ G.map t
        exact Filter.map_mono hs t
