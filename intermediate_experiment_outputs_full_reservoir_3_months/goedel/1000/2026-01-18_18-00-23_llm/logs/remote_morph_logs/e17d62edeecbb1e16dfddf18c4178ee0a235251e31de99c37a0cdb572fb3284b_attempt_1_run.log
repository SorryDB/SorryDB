`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₁ : {x : α | p x} ∈ 𝓝 x := hT
    have h₂ : {x : α | p' x} ∈ 𝓝 x := hT'
    have h₃ : {x : α | q x} ∈ 𝓝 x := hS
    have h₄ : {x : α | q' x} ∈ 𝓝 x := hS'
    -- Use the fact that the intersection of two neighborhoods is a neighborhood
    have h₅ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := h₁.inter h₃
    have h₆ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := h₂.inter h₄
    -- Use the fact that the union of two neighborhoods is a neighborhood
    have h₇ : ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) ∈ 𝓝 x := h₅.union h₆
    -- Show that the set is contained in the union of the intersections
    have h₈ : ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) ⊆ {x : α | p x ∧ q x ∨ p' x ∧ q' x} := by
      intro x hx
      simp only [Set.mem_union, Set.mem_inter_iff] at hx
      simp only [Set.mem_setOf_eq]
      cases hx with
      | inl hx =>
        exact Or.inl ⟨hx.1, hx.2⟩
      | inr hx =>
        exact Or.inr ⟨hx.1, hx.2⟩
    -- Use the fact that the set is contained in a neighborhood to conclude it is a neighborhood
    have h₉ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := h₇.mono h₈
    exact h₉
  exact h

end Filter

