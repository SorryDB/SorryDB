/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun S => if π ∈ S then 1 else 0
  empty := by
    simp [OuterMeasure.empty]
    <;>
    simp_all [Set.not_mem_empty]
    <;>
    norm_num
  mono {S T} hST := by
    by_cases h : π ∈ S <;> by_cases h' : π ∈ T <;> simp_all [h, h', le_of_lt]
    <;>
    (try { contradiction }) <;>
    (try { linarith }) <;>
    (try { simp_all [hST] }) <;>
    (try { aesop })
  iUnion_nat := by
    by_cases h : π ∈ (⋃ n : ℕ, Set.univ) <;> simp_all [h]
    <;>
    (try { aesop }) <;>
    (try { simp_all [Set.subset_def] }) <;>
    (try { norm_num }) <;>
    (try { linarith })

def μL : Measure ℝ := by
  exact volume

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h₁ : μD {x : ℝ | x < 0} = 0 := by
    by_cases h : π < 0 <;> simp_all [μD, Set.mem_setOf_eq]
    <;>
    (try { linarith [Real.pi_pos, Real.pi_gt_three] }) <;>
    (try { norm_num }) <;>
    (try { linarith })
  have h₂ : μD (∅ : Set ℝ) = 0 := by
    simp [μD]
  have h₃ : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    rw [MeasureTheory.ae_iff]
    <;>
    simp_all [μD]
    <;>
    (try { aesop }) <;>
    (try { norm_num }) <;>
    (try { linarith [Real.pi_pos, Real.pi_gt_three] }) <;>
    (try { aesop })
  exact h₃

