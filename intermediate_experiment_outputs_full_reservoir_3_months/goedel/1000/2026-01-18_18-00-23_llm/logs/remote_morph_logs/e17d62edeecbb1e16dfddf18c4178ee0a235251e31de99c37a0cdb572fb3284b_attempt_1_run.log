section Lp

open MeasureTheory ENNReal Set

def μD : OuterMeasure ℝ where
  measureOf := by
    intro S
    by_cases h : 0 ∈ S
    · exact 1
    · exact 0
  empty := by
    simp [measureOf]
    <;>
    norm_num
  mono {S T} hST := by
    by_cases h₀ : 0 ∈ T
    · -- Case: 0 ∈ T
      by_cases h₁ : 0 ∈ S
      · -- Case: 0 ∈ S
        simp [measureOf]
      · -- Case: 0 ∉ S
        simp [measureOf] at hST ⊢
        <;>
        (try contradiction) <;>
        (try simp_all [Set.subset_def]) <;>
        (try norm_num at *) <;>
        (try aesop)
    · -- Case: 0 ∉ T
      simp [measureOf] at hST ⊢
      <;>
      (try contradiction) <;>
      (try simp_all [Set.subset_def]) <;>
      (try norm_num at *) <;>
      (try aesop)
  iUnion_nat := by
    intro s
    by_cases h : 0 ∈ ⋃ (n : ℕ), s n
    · -- Case: 0 ∈ ⋃ (n : ℕ), s n
      have h₁ : ∃ (n : ℕ), 0 ∈ s n := by
        simp only [Set.mem_iUnion] at h
        exact h
      -- We need to show that the sum of measures is at least 1
      have h₂ : ∑' (n : ℕ), measureOf (s n) ≥ 1 := by
        obtain ⟨n, hn⟩ := h₁
        have h₃ : measureOf (s n) = 1 := by
          simp [measureOf, hn]
        calc
          ∑' (n : ℕ), measureOf (s n) ≥ measureOf (s n) := by
            exact le_tsum (by
              intro i
              uparam_cases <;> simp [measureOf] <;> norm_num) n (by simp_all [tsum_eq_zero_of_not_summable])
          _ = 1 := by rw [h₃]
          _ ≥ 1 := by norm_num
      -- Since the sum is at least 1, we have the desired inequality
      simp_all [measureOf]
      <;>
      norm_num at * <;>
      linarith
    · -- Case: 0 ∉ ⋃ (n : ℕ), s n
      simp_all [measureOf]
      <;>
      (try
        {
          -- We need to show that the sum of measures is 0
          have h₁ : ∀ n : ℕ, measureOf (s n) = 0 := by
            intro n
            have h₂ : 0 ∉ s n := by
              intro h₃
              have h₄ : 0 ∈ ⋃ (n : ℕ), s n := by
                exact Set.mem_iUnion.mpr ⟨n, h₃⟩
              contradiction
            simp [measureOf, h₂]
          calc
            ∑' (n : ℕ), measureOf (s n) = ∑' (n : ℕ), (0 : ℝ≥0) := by
              congr with n
              rw [h₁ n]
            _ = 0 := by simp [tsum_zero]
            _ ≥ 0 := by norm_num
        })
      <;>
      norm_num

def μL : Measure ℝ := MeasureTheory.volume

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    have h₁ : μD {x : ℝ | x < 0} = 0 := by
      simp [measureOf, ne_eq]
      <;>
      norm_num
      <;>
      (try {
        intro h
        linarith
      })
    have h₂ : μD (∅ : Set ℝ) = 0 := by
      simp [measureOf]
      <;>
      norm_num
    have h₃ : μD ({x : ℝ | x < 0} \ (∅ : Set ℝ)) = 0 := by
      simp_all [measureOf, Set.diff_eq_empty]
      <;>
      norm_num
      <;>
      (try {
        intro h
        linarith
      })
    have h₄ : μD ((∅ : Set ℝ) \ ({x : ℝ | x < 0})) = 0 := by
      simp_all [measureOf, Set.diff_eq_empty]
      <;>
      norm_num
    -- Use the fact that the symmetric difference has measure zero
    exact by
      simp_all [MeasureTheory.ae_iff, MeasureTheory.Measure.ae_iff, OuterMeasure.to_measure]
      <;>
      (try {
        norm_num at *
        <;>
        aesop
      })
      <;>
      (try {
        simp_all [measureOf]
        <;>
        norm_num at *
        <;>
        aesop
      })
  exact h

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    have h4 : f =ᵐ[μL] g := h1
    have h5 : g =ᵐ[μL] h := h2
    -- Use the transitivity of equality almost everywhere
    have h6 : f =ᵐ[μL] h := by
      filter_upwards [h4, h5] with x hx1 hx2
      <;> simp_all [hx1, hx2]
      <;> aesop
    exact h6
  exact h3
