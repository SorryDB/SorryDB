/-!
# Filters
-/



section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have : F.map f ≤ G.map f := by
    apply Filter.map_mono h
  have : s ∈ F.map f → s ∈ G.map f := by
    intro hf
    exact this hf
  have : s ∈ F.map f := hs
  have : s ∈ G.map f := this ‹s ∈ F.map f›
  exact this

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : F.map (t ∘ s) ≤ G.map t := by
    have h2 : F.map (t ∘ s) = (F.map s).map t := by
      simp [Filter.map_map]
      <;>
      congr 1 <;>
      funext <;>
      simp [Function.comp_apply]
    rw [h2]
    have h3 : F.map s ≤ G := hs
    have h4 : (F.map s).map t ≤ G.map t := Filter.map_mono h3
    exact h4
  have h5 : G.map t ≤ H := ht
  have h6 : F.map (t ∘ s) ≤ H := le_trans h1 h5
  exact h6

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x : α | p x ∧ q x} ∈ 𝓝 x := by
    have h2 : {x : α | p x} ∈ 𝓝 x := hT
    have h3 : {x : α | q x} ∈ 𝓝 x := hS
    have h4 : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      apply mem_nhds_inter h2 h3
    have h5 : {x : α | p x ∧ q x} = {x : α | p x} ∩ {x : α | q x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h5] at *
    exact h4
  have h2 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    have h3 : {x : α | p' x} ∈ 𝓝 x := hT'
    have h4 : {x : α | q' x} ∈ 𝓝 x := hS'
    have h5 : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      apply mem_nhds_inter h3 h4
    have h6 : {x : α | p' x ∧ q' x} = {x : α | p' x} ∩ {x : α | q' x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h6] at *
    exact h5
  have h3 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h4 : {x : α | p x ∧ q x} ∈ 𝓝 x := h1
    have h5 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := h2
    have h6 : {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
      apply mem_nhds_union h4 h5
    have h7 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} = {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} := by
      ext x
      simp [or_comm]
      <;> aesop
    rw [h7] at *
    exact h6
  exact h3

end Filter

