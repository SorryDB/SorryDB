variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact h.map f

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : F.map (t ∘ s) = (F.map s).map t := by
    simp [Function.comp]
    <;>
    ext x <;>
    simp [Filter.mem_map] <;>
    tauto
  -- Use the fact that the composition of filters is associative
  have h2 : (F.map s).map t ≤ H := by
    -- Use the given Tendsto properties to prove the inequality
    calc
      (F.map s).map t = (F.map s).map t := rfl
      _ ≤ G.map t := by
        -- Since F.map s ≤ G, we can use the monotonicity of the map operation
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since G.map t ≤ H, we can use the given Tendsto property
        exact ht
  -- Combine the results to get the final inequality
  calc
    F.map (t ∘ s) = (F.map s).map t := by rw [h1]
    _ ≤ H := h2

