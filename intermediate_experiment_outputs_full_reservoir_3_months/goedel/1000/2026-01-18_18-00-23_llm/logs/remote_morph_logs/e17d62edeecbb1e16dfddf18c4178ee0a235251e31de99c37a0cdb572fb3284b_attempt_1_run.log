namespace ItaLean

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have h' : F.map f ≤ G.map f := Filter.map_mono h
  exact h' hs

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Prove that the composition of two functions preserves the order of filters
  have h1 : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        simp [Filter.map_map]
        <;> ext <;> simp [Function.comp_apply]
        <;> aesop
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G
        have h2 : F.map s ≤ G := hs
        exact Filter.map_mono h2
      _ ≤ H := ht
  -- Use the definition of Tendsto to conclude the proof
  exact h1

