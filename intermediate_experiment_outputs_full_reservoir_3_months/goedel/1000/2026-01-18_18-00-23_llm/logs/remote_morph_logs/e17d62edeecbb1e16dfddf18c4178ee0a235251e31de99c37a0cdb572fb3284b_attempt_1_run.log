namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  apply Filter.map_le_map f h

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : Filter.map s F ≤ G := hs
  have h2 : Filter.map t G ≤ H := ht
  have h3 : Filter.map (t ∘ s) F ≤ Filter.map t G := Filter.map_comp_le t s F
  calc
    Filter.map (t ∘ s) F ≤ Filter.map t G := h3
    _ ≤ H := h2

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1 : ℝ)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
