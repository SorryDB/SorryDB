open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    refine fun s => if (Real.pi : ℝ) ∈ s then 1 else 0
  empty := by
    simp [μD]
    <;> norm_num
  mono {S T} hST := by
    by_cases h : (Real.pi : ℝ) ∈ S <;> by_cases h' : (Real.pi : ℝ) ∈ T <;> simp_all [μD]
    <;> norm_num <;> try { contradiction }
    <;> try { linarith }
  iUnion_nat := by
    by_cases h : (Real.pi : ℝ) ∈ (⋃ n : ℕ, {x : ℝ | x ∈ (Set.univ : Set ℝ)}) <;> simp_all [μD]
    <;> norm_num <;> try { exfalso; contradiction }
    <;> try {
      -- We need to show that if π is in the union, then the measure of the union is 1
      -- This is trivially true because the union is the entire space
      simp_all [Set.mem_iUnion]
      <;>
      (try { contradiction }) <;>
      (try { linarith })
    }

def μL : Measure ℝ := by volume_tac

def LebesgueFilter := ae μL
def DiracFilter := ae μD
