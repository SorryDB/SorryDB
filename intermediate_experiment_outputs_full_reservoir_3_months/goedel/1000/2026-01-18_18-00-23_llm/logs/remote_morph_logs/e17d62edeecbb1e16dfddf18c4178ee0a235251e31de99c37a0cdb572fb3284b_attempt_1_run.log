        <;> simp_all [Set.Subset]
      · simp_all [μD]
        <;> norm_num
  iUnion_nat := by
    intro s
    by_cases h : π ∈ ⋃ (n : ℕ), s n
    · simp_all [μD]
      <;>
      (try {
        have h₁ : ∃ (n : ℕ), π ∈ s n := by
          classical
