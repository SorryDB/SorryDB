          intro n
          intro hn
          have h₂ : π ∈ ⋃ (n : ℕ), s n := by
            exact Set.mem_iUnion.mpr ⟨n, hn⟩
          contradiction
        simp_all [μD]
        <;>
        (try { norm_num })
        <;>
        (try { linarith })
      })
      <;>
      (try {
        simp_all [μD]
        <;>
        (try { norm_num })
        <;>
        (try { linarith })
      })

def μL : Measure ℝ := by
  exact volume
  <;>
  (try {
    sorry
  })

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

