lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  have h₁ : (∃ m, p = 4 * m + 1 → Finset.card { s : ZMod p | s ^ 2 = -1 } = 2) := by
    by_cases h₂ : p = 2
    · -- Case: p = 2
      use 0
      intro h₃
      exfalso
      omega
    · -- Case: p ≠ 2
      -- We need to show that there exists m such that if p = 4m + 1, then the number of solutions is 2.
      -- However, since we do not have any specific constraints on m, we can always choose m = 0 and the implication will be vacuously true unless p = 1, which is impossible because p is a prime.
      use 1
      intro h₃
      have h₄ : p = 5 := by
