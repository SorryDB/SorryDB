namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  intro num_solutions
  have h₁ : (∃ m, p = 4 * m + 1 → num_solutions = 2) := by
    refine' ⟨0, _⟩
    intro h₂
    have h₃ : p = 1 := by omega
    have h₄ : p.Prime := h.out
    have h₅ : ¬p.Prime := by
      rw [h₃]
      norm_num [Nat.Prime]
    exact absurd h₄ h₅
  have h₂ : (p = 2 → num_solutions = 1) := by
    intro h₃
    have h₄ : p.Prime := h.out
    have h₅ : p = 2 := h₃
    subst_vars
    -- In ZMod 2, the equation s^2 = -1 becomes s^2 = 1.
    -- The solutions are s = 1 and s = 0, but 0^2 = 0 ≠ 1 and 1^2 = 1 = -1 (since -1 ≡ 1 mod 2).
    -- Therefore, there is exactly one solution: 1.
    simp [num_solutions, ZMod.nat_cast_self]
    <;>
    decide
  have h₃ : (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
    refine' ⟨0, _⟩
    intro h₄
    have h₅ : p = 1 := by omega
    have h₆ : p.Prime := h.out
    have h₇ : ¬p.Prime := by
      rw [h₅]
      norm_num [Nat.Prime]
    exact absurd h₆ h₇
  exact ⟨h₁, h₂, h₃⟩
