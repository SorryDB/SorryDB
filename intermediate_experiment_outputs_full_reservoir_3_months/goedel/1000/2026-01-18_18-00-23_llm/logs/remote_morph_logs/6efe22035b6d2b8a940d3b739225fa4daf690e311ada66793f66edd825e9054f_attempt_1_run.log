namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  intro num_solutions
  constructor
  · -- Case left: ∃ m, p = 4 * m + 1 → num_solutions = 2
    refine' ⟨0, _⟩
    intro h₁
    simp_all [num_solutions]
    <;>
    (try contradiction) <;>
    (try decide) <;>
    (try omega)
  · constructor
    · -- Case p = 2 → num_solutions = 1
      intro h₂
      simp_all [num_solutions]
      <;>
      (try contradiction) <;>
      (try decide) <;>
      (try omega)
    · -- Case right: ∃ m, p = 4 * m + 1 → num_solutions = 0
      refine' ⟨0, _⟩
      intro h₃
      simp_all [num_solutions]
      <;>
      (try contradiction) <;>
      (try decide) <;>
      (try omega)
