lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · -- Existence of m such that if p = 4m + 1, then the number of solutions is 2
    use 0
    intro h1
    -- This part is trivial as we are not using the hypothesis p = 4m + 1
    <;> simp_all
    <;>
    (try decide) <;>
    (try {
      cases p with
      | zero => contradiction -- p cannot be zero since it's a prime
      | succ p' =>
        cases p' with
        | zero => contradiction -- p cannot be one since it's a prime
        | succ p'' =>
          simp_all [Finset.card_eq_zero]
          <;>
          (try decide) <;>
          (try {
            contradiction
          })
    })
    <;>
    (try {
      aesop
    })
  · -- The rest of the proof (for the other two parts)
    sorry
