    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  intro num_solutions
  have h₁ : ∃ m, p = 4 * m + 1 → num_solutions = 2 := by sorry
  sorry
