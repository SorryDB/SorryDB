  constructor
  · -- First part: ∃ m, p = 4 * m + 1 → {s | s ^ 2 = -1}.card = 2
    use (p + 3) / 4
    intro h1
    exfalso
    have h2 := h1
    have h3 : p % 4 = 1 := by
      omega
    have h4 : p.Prime := h.out
    have h5 : p = 4 * ((p + 3) / 4) + 1 := by
      omega
    simp_all [ZMod.nat_cast_self]
    <;>
