      _ = g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
        rw [intervalIntegral.integral_const]; simp

  have bound1 : |g' 0| ≤ ε * ∑ i, |nth_partial i f x|  := by
    have h₁ : g' 0 = ∑ i, (y i - x i) * (nth_partial i f x) := by sorry
    have h₂ : ∀ (i : Fin n), |(y i - x i) * (nth_partial i f x)| ≤ ε * |nth_partial i f x| := by sorry
    have h₃ : |g' 0| ≤ ε * ∑ i : Fin n, |nth_partial i f x| := by sorry
    sorry
  sorry
