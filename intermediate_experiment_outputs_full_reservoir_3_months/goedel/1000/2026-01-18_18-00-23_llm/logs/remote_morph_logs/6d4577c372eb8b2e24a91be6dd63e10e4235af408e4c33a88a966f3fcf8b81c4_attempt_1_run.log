theorem bounded_partials_control_difference {n : ℕ} (f : E n → ℝ)
    (fc : ContDiff ℝ 2 f) (x y : E n)
    (ε : ℝ) (hε : ε > 0) (hdiff : (i : Fin n) → |x i - y i| ≤ ε)
    (mpb : mixed_partials_bounded f x) :
    |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
  let g₀ := interpolator x y
  let g := interpolated x y f

  let g' := interpolated_deriv x y f
  let g'' := interpolated_deriv2 x y f

  have f_diff : Differentiable ℝ f := fc.differentiable (by norm_num)
  have g₀_diff : Differentiable ℝ g₀ := Differentiable.interpolator x y
  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by
    have h : Differentiable ℝ (fun t : ℝ => ∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
      -- Prove that each term in the sum is differentiable and the sum is differentiable
      have h₁ : ∀ (i : Fin n), Differentiable ℝ (fun t : ℝ => (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
        intro i
        -- Each term is differentiable because it's a composition of differentiable functions
        have h₂ : Differentiable ℝ (fun t : ℝ => (1 - t) • x + t • y : ℝ → E n) := by
          -- This function is differentiable because it's linear in t
          apply Differentiable.add
          · apply Differentiable.smul
            · -- Differentiation is distributive over scalar multiplication
              apply Differentiable.const_smul
              apply Differentiable.sub
              · -- Differentiation is linear
                apply differentiable_const
              · -- t is differentiable
                apply Differentiable.id
            · -- x is a constant, hence differentiable
              apply differentiable_const
          · apply Differentiable.smul
            · -- t is differentiable
              apply Differentiable.id
            · -- y is a constant, hence differentiable
              apply differentiable_const
        -- The partial derivative of f is differentiable because f is C²
        have h₃ : Differentiable ℝ (nth_partial i f : E n → ℝ) := by
          have h₄ : ContDiff ℝ 1 (nth_partial i f : E n → ℝ) := by
            -- The first partial derivative of a C² function is C¹
            have h₅ : ContDiff ℝ 2 f := fc
            exact h₅.nth_partial (!2 0)
          exact h₄.differentiable (by norm_num)
        -- The composition of differentiable functions is differentiable
        have h₄ : Differentiable ℝ (fun t : ℝ => nth_partial i f ((1 - t) • x + t • y)) := by
          apply Differentiable.comp (h₃) h₂
        -- The product of differentiable functions is differentiable
        have h₅ : Differentiable ℝ (fun t : ℝ => (y i - x i : ℝ)) := by
          apply differentiable_const
        exact Differentiable.mul h₅ h₄
      -- The sum of differentiable functions is differentiable
      exact Differentiable.sum fun i _ => h₁ i
    -- The function g' is exactly the sum we just proved to be differentiable
    have h₁ : g' = (fun t : ℝ => ∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
      rfl
    rw [h₁]
    exact h
  have g'_cont : Continuous g' := by
    have h : Continuous (fun t : ℝ => ∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
      -- Prove that the sum is continuous
      have h₁ : ∀ (i : Fin n), Continuous (fun t : ℝ => (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
        intro i
        -- Each term in the sum is continuous
        have h₂ : Continuous (fun t : ℝ => (1 - t) • x + t • y : ℝ → E n) := by
          -- This function is continuous because it's linear in t
          continuity
        -- The partial derivative of f is continuous because f is C²
        have h₃ : Continuous (nth_partial i f : E n → ℝ) := by
          have h₄ : ContDiff ℝ 1 (nth_partial i f : E n → ℝ) := by
            -- The first partial derivative of a C² function is C¹
            have h₅ : ContDiff ℝ 2 f := fc
            exact h₅.nth_partial (!2 0)
          exact h₄.continuous
        -- The composition of continuous functions is continuous
        have h₄ : Continuous (fun t : ℝ => nth_partial i f ((1 - t) • x + t • y)) :=
          h₃.comp h₂
        -- The product of continuous functions is continuous
        have h₅ : Continuous (fun t : ℝ => (y i - x i : ℝ)) := by
          continuity
        exact Continuous.mul h₅ h₄
      -- The sum of continuous functions is continuous
      exact Continuous.sum fun i _ => h₁ i
    -- The function g' is exactly the sum we just proved to be continuous
    have h₁ : g' = (fun t : ℝ => ∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
      rfl
    rw [h₁]
    exact h
  have g''_cont : Continuous g'' := by
    sorry

  have deriv_g_eq_g' : deriv g = g' := by
    unfold g g'; exact deriv_interpolated x y f
  have deriv_g'_eq_g'' : deriv g' = g'' := by
    unfold g' g''; exact deriv_interpolated2 x y f

  have int_g'_eq_sub (t : ℝ) : (∫ (s : ℝ) in 0..t, g' s) = g t - g 0 := by
    exact intervalIntegral.integral_deriv_eq_sub' g deriv_g_eq_g' (by fun_prop) (by fun_prop)

  have int_g''_eq_sub (t : ℝ) : (∫ (s : ℝ) in 0..t, g'' s) = g' t - g' 0 := by
    exact intervalIntegral.integral_deriv_eq_sub' g' deriv_g'_eq_g'' (by fun_prop) (by fun_prop)

  -- "and observe that"
  have hobs := by calc g 1 - g 0
      _ = ∫ (t : ℝ) in 0..1, g' t := by rw [int_g'_eq_sub]
      _ = ∫ (t : ℝ) in 0..1, g' 0 + ∫ (s : ℝ) in 0..t, g'' s := by
        conv => arg 2; arg 1; intro t; rw [int_g''_eq_sub]; simp
      _ = (∫ (t : ℝ) in 0..1, g' 0) + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
        rw [intervalIntegral.integral_add]
        · exact intervalIntegrable_const
        · conv => arg 1; intro t; rw [int_g''_eq_sub t]
          exact Continuous.intervalIntegrable (by fun_prop) 0 1
      _ = g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
        rw [intervalIntegral.integral_const]; simp

  --- "the chain rule imples that..."
  have bound1 : |g' 0| ≤ ε * ∑ i, |nth_partial i f x|  := by
    have h₁ : g' 0 = ∑ i : Fin n, (y i - x i) * nth_partial i f x := by
      simp [g', nth_partial]
      <;>
      simp_all [interpolator]
      <;>
      field_simp [add_smul, sub_smul, smul_sub]
      <;>
      ring_nf
      <;>
      simp_all [Equiv.smul_apply]
      <;>
      norm_num
      <;>
      linarith
    rw [h₁]
    calc
      |∑ i : Fin n, (y i - x i) * nth_partial i f x| ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by
        apply Finset.abs_sum_le_sum_abs
      _ = ∑ i : Fin n, |(y i - x i)| * |nth_partial i f x| := by
        apply Finset.sum_congr rfl
        intro i _
        rw [abs_mul]
      _ ≤ ∑ i : Fin n, ε * |nth_partial i f x| := by
        apply Finset.sum_le_sum
        intro i _
        have h₂ : |(y i - x i : ℝ)| ≤ ε := by
          simpa [hdiff] using hdiff i
        have h₃ : 0 ≤ |nth_partial i f x| := abs_nonneg _
        nlinarith
      _ = ε * ∑ i : Fin n, |nth_partial i f x| := by
        simp [Finset.mul_sum]
        <;>
        ring_nf
        <;>
        field_simp
        <;>
        ring_nf
