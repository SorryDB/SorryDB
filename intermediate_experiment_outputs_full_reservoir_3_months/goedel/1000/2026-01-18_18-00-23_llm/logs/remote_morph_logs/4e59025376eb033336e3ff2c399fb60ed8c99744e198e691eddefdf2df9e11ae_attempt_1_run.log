    constructor <;> simp_all [Set.setOf_subset_iff]
    <;> (try tauto)
    <;> (try
      {
        intros
        use this
        <;> simp_all
      })
    <;> (try
      {
        intros
        use this
        <;> simp_all
      })
  have h₂ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
    apply Iff.intro
    · intro h
      -- Prove that if S is tight, then its closure is compact.
      have h₃ : IsCompact (closure S) := by
        -- Use the fact that a tight set in the space of probability measures is sequentially compact.
        -- This is a version of Prokhorov's theorem.
        have h₄ : IsTightMeasureSet S := h
        have h₅ : IsCompact (closure S) := by
          -- Use the fact that a tight set is sequentially compact and the space is complete and second countable.
          have h₆ : IsPrecompact (closure S) := by
            -- Use the fact that S is tight to show that its closure is precompact.
            have h₇ : IsTightMeasureSet S := h₄
            -- Apply the relevant lemma to show precompactness.
            have h₈ : IsPrecompact (closure S) := by
              -- Use the fact that S is tight to show that its closure is precompact.
              apply Metric.isPrecompact_iff_isCompact_closure.mpr
              -- Use the fact that S is tight to show that the set of measures is tight.
              -- This is a direct application of Prokhorov's theorem.
              simpa [h₁] using Prokhorov.isTightTelescope.mpr (by simpa [h₁] using h₇)
            exact h₈
          -- Use the fact that the closure is precompact to show it is compact.
          have h₉ : IsCompact (closure S) := by
            -- Use the fact that the space is complete and the set is precompact.
            exact isPrecompact_iff_isCompact_closure.mp h₆
          exact h₉
        exact h₅
      exact h₃
    · intro h
      -- Prove that if the closure of S is compact, then S is tight.
      have h₃ : IsTightMeasureSet S := by
        -- Use the fact that a compact set is tight.
        have h₄ : IsCompact (closure S) := h
        -- Use the fact that a compact set is tight.
        have h₅ : IsTightMeasureSet S := by
          -- Use the fact that the closure is compact to show that S is tight.
