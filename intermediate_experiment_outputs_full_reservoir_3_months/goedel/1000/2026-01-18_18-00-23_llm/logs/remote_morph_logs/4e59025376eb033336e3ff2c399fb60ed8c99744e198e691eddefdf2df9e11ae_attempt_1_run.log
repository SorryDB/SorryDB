theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTightMeasureSet S := by
    constructor
    · intro h
      -- If the set of measures induced by S is tight, then S itself is tight.
      have h₂ : IsTightMeasureSet S := by
        -- Use the fact that the tightness of the induced set implies the tightness of S.
        have h₃ : ∀ μ ∈ S, IsTight (μ : Measure E) := by
          intro μ hμ
          -- Since the set {μ : S} is tight, each measure in it is tight.
          have h₄ : IsTight (μ : Measure E) := by
            have h₅ : (μ : Measure E) ∈ {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
              exact ⟨μ, hμ, rfl⟩
            have h₆ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := h
            exact h₆.h_tight h₅
          exact h₄
        -- The set S is tight because each of its elements is tight.
        exact ⟨h₃⟩
      exact h₂
    · intro h
      -- If S is tight, then the set of measures induced by S is tight.
      have h₂ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
        -- Use the fact that the tightness of S implies the tightness of the induced set.
        have h₃ : ∀ μ ∈ {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}, IsTight μ := by
          intro μ hμ
          -- Extract the corresponding element of S.
          rcases hμ with ⟨μ', hμ', rfl⟩
          -- Since S is tight, each element of S is tight.
          have h₄ : IsTight (μ' : Measure E) := h.tight hμ'
          exact h₄
        -- The set of measures induced by S is tight because each of its elements is tight.
        exact ⟨h₃⟩
      exact h₂
  rw [h₁]
  -- Now we need to prove that S is tight if and only if the closure of S is compact.
  have h₂ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
    -- Use the fact that in a complete separable metric space, a set of probability measures is tight if and only if its closure is compact.
    have h₃ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
      -- Use the theorem that characterizes tight sets of probability measures in terms of compactness of their closure.
      apply (Iff.intro (fun h => by
        -- If S is tight, then its closure is compact.
        have h₄ : IsTightMeasureSet S := h
        have h₅ : IsCompact (closure S) := by
          -- Use the theorem that states that a tight set of probability measures has a compact closure.
          apply ProbabilityMeasures.isCompact_closure_iff_tight.mp
          -- Show that S is tight.
          exact h₄
        exact h₅
      ) (fun h => by
        -- If the closure of S is compact, then S is tight.
        have h₄ : IsCompact (closure S) := h
        have h₅ : IsTightMeasureSet S := by
          -- Use the theorem that states that if the closure of a set of probability measures is compact, then the set is tight.
          apply ProbabilityMeasures.isCompact_closure_iff_tight.mpr
          -- Show that the closure of S is compact.
          exact h₄
        exact h₅
      ))
    -- The above theorem directly gives us the required equivalence.
    exact h₃
  -- Combine the two equivalences to get the final result.
  rw [h₂]
  <;> simp_all
