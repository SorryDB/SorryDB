              -- Use the fact that the closure is compact to show that S is tight.
              have h₉ : IsTightMeasureSet S := by
                -- Use the fact that the closure is compact to show that S is tight.
                simpa [h₁] using Prokhorov.isTightTelescope.mpr (by
                  -- Use the fact that the closure is compact to show that the set of measures is tight.
                  have h₁₀ : IsCompact (closure S) := h₄
                  -- Use the fact that the closure is compact to show that the set of measures is tight.
                  simpa [h₁] using h₁₀.isTight)
