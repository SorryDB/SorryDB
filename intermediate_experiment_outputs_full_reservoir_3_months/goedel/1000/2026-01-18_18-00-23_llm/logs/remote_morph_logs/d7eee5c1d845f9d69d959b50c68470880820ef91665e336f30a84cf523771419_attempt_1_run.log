    have h₀ : (v L).toIntLinearMap ∘ (ker_v L).toIntLinearMap = 0 := by
      ext (x : Additive 𝒪[L]ˣ)
      -- Since v L is zero on 𝒪[L]ˣ, the composition is zero.
      simp [LinearMap.zero_apply]
      <;> simp_all [LinearMap.comp_apply, LinearMap.zero_apply]
      <;> aesop
    simp_all [LinearMap.comp_apply, LinearMap.zero_apply]
    <;> aesop
``` 

