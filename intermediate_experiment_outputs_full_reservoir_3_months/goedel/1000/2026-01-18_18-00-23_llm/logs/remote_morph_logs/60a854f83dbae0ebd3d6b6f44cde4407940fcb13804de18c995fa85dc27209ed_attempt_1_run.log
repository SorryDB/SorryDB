  intro n hn σ h
  have h₁ : σ.length ≥ 2*n - 4 := by
    by_contra h₂
    have h₃ : σ.length < 2*n - 4 := by
      omega
    have h₄ : n ≥ 5 := by
      omega
    -- Use the fact that for n ≥ 5, the minimal number of calls required is 2*n - 4
    have h₅ : σ.length ≥ 2*n - 4 := by
      -- Here we would normally use the fact that the minimal number of calls is 2*n - 4
      -- but since we are in a contradiction, we can directly derive a contradiction from the assumptions
      have h₅₁ : 2*n - 4 ≤ σ.length := by
