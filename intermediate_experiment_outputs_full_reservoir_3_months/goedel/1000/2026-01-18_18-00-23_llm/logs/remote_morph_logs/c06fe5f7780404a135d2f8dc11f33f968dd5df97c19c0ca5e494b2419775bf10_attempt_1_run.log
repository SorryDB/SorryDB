namespace EnchantedForest

  namespace Kestrel

    /-!
      A bird `K` is a *kestrel* if for any bird `x`,
      the bird `K ‚óĀ x` is fixated on `x`.

      https://en.wikipedia.org/wiki/Kestrel
    -/

    -- the definition of a kestrel
    axiom K : Bird
    axiom K.call : ‚ąÄ (x y : Bird), (K ‚óĀ x) ‚óĀ y = x

  end Kestrel

  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ‚óĀ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ‚ąÄ x, (K ‚óĀ x) is fixated on x := by
      intro x
      intro y
      have h := K.call x y
      simp [response] at h ‚äĘ
      <;> simpa using h

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h := K.call K x
      have h‚āĀ : K ‚óĀ K = K := kestrel_egocentric
      simp [response] at h h‚āĀ ‚äĘ
      <;> simp_all [response]
      <;> try { contradiction }
      <;> try { linarith }

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ‚óĀ x = K ‚óĀ y) :
        (x = y) := by
      have h‚āĀ : (K ‚óĀ x) ‚óĀ K = x := K.call x K
      have h‚āā : (K ‚óĀ y) ‚óĀ K = y := K.call y K
      calc
        x = (K ‚óĀ x) ‚óĀ K := by rw [h‚āĀ]
        _ = (K ‚óĀ y) ‚óĀ K := by rw [kestrel_application]
        _ = y := by rw [h‚āā]

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ‚óĀ x`,
    -- then `K` is fond of `x`.
    theorem kestrel_fondness
        (x : Bird)
        (fond_Kx : K is fond of (K ‚óĀ x)) :
        K is fond of x := by
      have h‚āĀ : (K ‚óĀ (K ‚óĀ x)) = (K ‚óĀ x) := fond_Kx
      have h‚āā : (K ‚óĀ (K ‚óĀ x)) ‚óĀ x = (K ‚óĀ x) := by
        calc
          (K ‚óĀ (K ‚óĀ x)) ‚óĀ x = (K ‚óĀ x) := by
            have h‚āÉ := K.call (K ‚óĀ x) x
            simpa [response] using h‚āÉ
          _ = (K ‚óĀ x) := by rfl
      have h‚āÉ : (K ‚óĀ (K ‚óĀ x)) ‚óĀ x = (K ‚óĀ x) := h‚āā
      have h‚āĄ : K ‚óĀ x = x := by
        have h‚āÖ := K.call x x
        have h‚āÜ := K.call (K ‚óĀ x) x
        simp [response] at h‚āÖ h‚āÜ ‚äĘ
        <;> simp_all [response]
        <;> try { aesop }
      simp [response] at h‚āĀ ‚äĘ
      <;> simp_all [response]
      <;> try { aesop }
