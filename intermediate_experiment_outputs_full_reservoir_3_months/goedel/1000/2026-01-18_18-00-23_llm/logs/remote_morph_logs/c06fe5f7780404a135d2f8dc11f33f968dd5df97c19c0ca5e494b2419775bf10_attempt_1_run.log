```lean
  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ‚óĀ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ‚ąÄ x, (K ‚óĀ x) is fixated on x := by
      intro x
      intro y
      have h := K.call x y
      calc
        (K ‚óĀ x) ‚óĀ y = x := by simpa using h
        _ = x := by rfl

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h‚āĀ : K ‚óĀ K = K := by simpa using kestrel_egocentric
      have h‚āā := K.call K x
      have h‚āÉ := K.call x K
      have h‚āĄ := K.call x x
      have h‚āÖ := K.call K K
      have h‚āÜ := K.call x (K ‚óĀ x)
      calc
        K ‚óĀ x = (K ‚óĀ K) ‚óĀ x := by
          simp [h‚āĀ]
        _ = K := by
          have h‚āá := K.call K x
          simpa using h‚āá
        _ = K := by rfl

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ‚óĀ x = K ‚óĀ y) :
        (x = y) := by
      have h‚āĀ := K.call x (K ‚óĀ x)
      have h‚āā := K.call y (K ‚óĀ x)
      have h‚āÉ := K.call x (K ‚óĀ y)
      have h‚āĄ := K.call y (K ‚óĀ y)
      calc
        x = (K ‚óĀ x) ‚óĀ (K ‚óĀ x) := by simpa using K.call x (K ‚óĀ x)
        _ = (K ‚óĀ y) ‚óĀ (K ‚óĀ x) := by rw [kestrel_application]
        _ = y := by simpa using K.call y (K ‚óĀ x)

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ‚óĀ x`,
    -- then `K` is fond of `x`.
    theorem kestrel_fondness
        (x : Bird)
        (fond_Kx : K is fond of (K ‚óĀ x)) :
        K is fond of x := by
      have h‚āĀ : K ‚óĀ (K ‚óĀ x) = K ‚óĀ x := by simpa using fond_Kx
      have h‚āā : K ‚óĀ x = x := by
        have h‚āÉ := K.call x (K ‚óĀ x)
        have h‚āĄ := K.call (K ‚óĀ x) x
        have h‚āÖ := K.call x x
        have h‚āÜ := K.call (K ‚óĀ x) (K ‚óĀ x)
