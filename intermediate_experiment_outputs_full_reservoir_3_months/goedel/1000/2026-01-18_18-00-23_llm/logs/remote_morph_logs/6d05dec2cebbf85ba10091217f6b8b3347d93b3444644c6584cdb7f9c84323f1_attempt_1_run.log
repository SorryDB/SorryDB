theorem sum_powers : ∀ (n : ℕ) (a : ℝ), a ≠ 0 → (n : ℕ) ≥ 1 → ∑ i in Finset.Icc 1 n, a ^ i = a * (1 - a ^ n) / (1 - a) := by
  intro n a ha hn
  have h_sum : ∑ i in Finset.Icc 1 n, a ^ i = a * (1 - a ^ n) / (1 - a) := by
    have h₁ : ∑ i in Finset.Icc 1 n, a ^ i = ∑ i in Finset.range n, a ^ (i + 1) := by
      apply Finset.sum_bij' (fun (i : ℕ) _ => i - 1) (fun (i : ℕ) _ => i + 1)
      <;> simp_all [Finset.mem_Icc, Finset.mem_range, Nat.lt_succ_iff]
      <;> omega
    rw [h₁]
    have h₂ : ∑ i in Finset.range n, a ^ (i + 1) = a * ∑ i in Finset.range n, a ^ i := by
      calc
        ∑ i in Finset.range n, a ^ (i + 1) = ∑ i in Finset.range n, (a * a ^ i) := by
          apply Finset.sum_congr rfl
          intro i _
          rw [pow_succ]
          <;> ring
        _ = a * ∑ i in Finset.range n, a ^ i := by
          rw [Finset.mul_sum]
    rw [h₂]
    have h₃ : ∑ i in Finset.range n, a ^ i = (1 - a ^ n) / (1 - a) := by
      have h₄ : ∑ i in Finset.range n, a ^ i = (1 - a ^ n) / (1 - a) := by
        -- Use the formula for the sum of a geometric series
        have h₅ : ∑ i in Finset.range n, a ^ i = (∑ i in Finset.range n, a ^ i) := rfl
        rw [h₅]
        -- Handle the case when a = 1 separately
        by_cases h₆ : a = 1
        · -- If a = 1, the sum is n
          subst h₆
          simp [Finset.sum_const, Finset.card_range]
          <;>
          (try { contradiction }) <;>
          (try { linarith }) <;>
          (try { ring }) <;>
          (try { field_simp })
        · -- If a ≠ 1, use the geometric series formula
          have h₇ : 1 - a ≠ 0 := by
            intro h₈
            apply h₆
            linarith
          -- Use the geometric series sum formula
          have h₈ : ∑ i in Finset.range n, a ^ i = (1 - a ^ n) / (1 - a) := by
            calc
              ∑ i in Finset.range n, a ^ i = ∑ i in Finset.range n, a ^ i := rfl
              _ = (1 - a ^ n) / (1 - a) := by
                -- Use the geometric series sum formula
                rw [geom_sum_eq] <;>
                (try { simp_all }) <;>
                (try { linarith }) <;>
                (try { field_simp [h₇] }) <;>
                (try { ring_nf }) <;>
                (try { norm_num }) <;>
                (try { linarith })
          exact h₈
      exact h₄
    rw [h₃]
    have h₄ : a * ((1 - a ^ n) / (1 - a)) = a * (1 - a ^ n) / (1 - a) := by
      ring
    rw [h₄]
  exact h_sum
