  have h₁ : ∃ (p : Prop), (¬p → |- ¬p) ∧ (L ⊢ p) := by
    refine' ⟨⊥, _⟩
    constructor
    · intro h₂
      -- Prove ¬p → |- ¬p where p = ⊥
      -- ¬p = ¬⊥ = ⊤, so ⊤ → |- ⊤ is always true
      trivial
    · -- Prove L ⊢ p where p = ⊥
      -- Since ⊥ ≤ L, L must be ⊥ because ⊥ is the least element
      have h₃ : L = ⊥ := by
        -- Use the fact that ⊥ is the least element to deduce L = ⊥
        have h₄ : L ≤ ⊥ := by
          -- Since ⊥ ≤ L and L ≤ ⊥ (from ⊥ ≤ L and ⊥ being the least element), L = ⊥
          exact bot_le.mp h
        exact le_antisymm h₄ (by simp_all [le_bot])
      -- Substitute L = ⊥ into the goal L ⊢ ⊥
