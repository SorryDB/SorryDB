/-- The base of the natural logarithm. -/
noncomputable def e := exp 1

theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have h₁ : (n : ℝ) ≥ 2 := by
    exact_mod_cast (by linarith)
  have h₂ : ∀ (k : ℕ), (k : ℝ) ≥ 1 → (k : ℝ) < 2 → k.factorial > e * (k / e) ^ k := by
    intro k hk₁ hk₂
    rcases k with (_ | _ | k) <;> norm_num [Nat.factorial_succ, Nat.cast_add, Nat.cast_one, e] at hk₁ hk₂ ⊢ <;>
      (try contradiction) <;>
      (try nlinarith [Real.exp_pos 1, Real.add_one_lt_exp (by norm_num : (1 : ℝ) ≠ 0)]) <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try field_simp) <;>
      (try norm_num) <;>
      (try linarith [Real.exp_pos 1, Real.add_one_lt_exp (by norm_num : (1 : ℝ) ≠ 0)])
  have h₃ : ∀ (k : ℕ), (k : ℝ) ≥ 2 → k.factorial > e * (k / e) ^ k := by
    intro k hk
    rcases k with (_ | _ | _ | k) <;> norm_num [Nat.factorial_succ, Nat.cast_add, Nat.cast_one, e] at hk ⊢ <;>
      (try contradiction) <;>
      (try nlinarith [Real.exp_pos 1, Real.add_one_lt_exp (by norm_num : (1 : ℝ) ≠ 0)]) <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try field_simp) <;>
      (try norm_num) <;>
      (try linarith [Real.exp_pos 1, Real.add_one_lt_exp (by norm_num : (1 : ℝ) ≠ 0)])
  have h₄ : (n : ℝ) ≥ 2 := by
    exact_mod_cast (by linarith)
  have h₅ : n.factorial > e * (n / e) ^ n := by
    have h₆ : (n : ℝ) ≥ 2 := by
      exact_mod_cast (by linarith)
    have h₇ : n.factorial > e * (n / e) ^ n := by
      have h₈ : (n : ℕ) ≥ 2 := by
        exact_mod_cast (by linarith)
      have h₉ : ∀ (k : ℕ), (k : ℕ) ≥ 2 → k.factorial > e * (k / e) ^ k := by
        intro k hk
        have h₁₀ : (k : ℝ) ≥ 2 := by
          exact_mod_cast hk
        have h₁₁ : k.factorial > e * (k / e) ^ k := by
          exact h₃ k h₁₀
        exact h₁₁
      exact h₉ n (by omega)
    exact h₇
  exact h₅
```
