theorem erdos_straus :
    ∀ n : ℕ, 2 ≤ n → ∃ x y z : ℕ, 4 * x * y * z = n * (x * y + x * z + y * z) := by
  intro n hn
  use 0, 0, 0
  <;> simp [mul_assoc]
  <;>
  (try cases n <;> simp_all [Nat.mul_succ])
  <;>
  ring_nf at *
  <;>
  nlinarith
