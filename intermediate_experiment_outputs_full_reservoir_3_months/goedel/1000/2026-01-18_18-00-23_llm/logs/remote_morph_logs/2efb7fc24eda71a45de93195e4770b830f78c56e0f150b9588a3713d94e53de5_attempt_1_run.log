theorem erdos_straus :
    ∀ n : ℕ, 2 ≤ n → ∃ x y z : ℕ, 4 * x * y * z = n * (x * y + x * z + y * z) := by
  intro n hn
  refine' ⟨1, n, n, _⟩
  simp [mul_add, add_mul, mul_comm, mul_left_comm, mul_assoc, Nat.mul_sub_left_distrib]
  <;> ring_nf at *
  <;> nlinarith
