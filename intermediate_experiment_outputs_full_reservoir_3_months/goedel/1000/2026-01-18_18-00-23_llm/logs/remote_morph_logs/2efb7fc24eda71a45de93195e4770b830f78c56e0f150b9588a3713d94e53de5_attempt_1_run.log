            (try nlinarith) <;>
            (try
              {
                ring_nf at *
                <;> omega
              })
          <;>
            (try
              {
                simp_all [Nat.mul_succ, Nat.add_assoc]
                <;> ring_nf at *
                <;> omega
              })
    linarith
  exact h₁
