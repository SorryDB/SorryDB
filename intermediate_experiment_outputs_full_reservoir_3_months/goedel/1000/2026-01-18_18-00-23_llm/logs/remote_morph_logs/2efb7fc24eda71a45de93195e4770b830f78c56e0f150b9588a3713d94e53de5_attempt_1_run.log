```lean
theorem erdos_straus :
    ∀ n : ℕ, 2 ≤ n → ∃ x y z : ℕ, 4 * x * y * z = n * (x * y + x * z + y * z) :=
  by
  intro n hn
  have h : ∃ x y z : ℕ, 4 * x * y * z = n * (x * y + x * z + y * z) := by
    by_cases h₂ : n % 2 = 0
    · -- Case: n is even
      use 1, 1, (n / 2)
      have h₃ : n = 2 * (n / 2) := by
        have h₄ : n % 2 = 0 := h₂
        have h₅ : 2 * (n / 2) = n := by
          have h₆ : n % 2 = 0 := h₂
          omega
        linarith
      simp [h₃, mul_assoc]
      <;> ring_nf at *
      <;> omega
    · -- Case: n is odd
      use 1, 1, (n - 1) / 2
      have h₃ : n % 2 = 1 := by
        have h₄ : n % 2 ≠ 0 := h₂
        have h₅ : n % 2 = 1 := by
          have : n % 2 = 0 ∨ n % 2 = 1 := by omega
          cases this with
          | inl h₆ => contradiction
          | inr h₆ => exact h₆
        exact h₅
      have h₄ : n ≥ 2 := hn
      have h₅ : (n - 1) % 2 = 0 := by
        omega
      have h₆ : 2 * ((n - 1) / 2) = n - 1 := by
        have h₇ : (n - 1) % 2 = 0 := h₅
        have h₈ : 2 * ((n - 1) / 2) = n - 1 := by
          have h₉ : (n - 1) % 2 = 0 := h₅
          omega
        exact h₈
      have h₇ : n = 2 * ((n - 1) / 2) + 1 := by
        have h₈ : 2 * ((n - 1) / 2) = n - 1 := h₆
        omega
      simp [h₇, mul_assoc]
      <;> ring_nf at *
      <;> omega
  exact h
