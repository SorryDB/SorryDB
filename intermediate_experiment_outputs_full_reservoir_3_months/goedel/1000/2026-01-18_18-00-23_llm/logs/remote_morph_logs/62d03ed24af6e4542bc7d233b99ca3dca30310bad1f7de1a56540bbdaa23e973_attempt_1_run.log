  intro h
  have h₁ : ∫ a : ℝ, (1 : ℝ) = ∫ a : ℝ, (1 : ℝ) := rfl
  have h₂ : ∫ a : ℝ, (1 : ℝ) ≠ (0 : ℝ) := by
    -- The integral of the constant function 1 over ℝ is not zero.
    have h₃ : ∫ a : ℝ, (1 : ℝ) = ENNReal.ofReal (volume.univ : ℝ≥0∞) := by
      simp [intervalIntegral.integral_const, Real.volume_Ioi]
      <;> norm_num
      <;> simp_all [MeasureTheory.integral_const]
      <;> field_simp
      <;> ring_nf
      <;> norm_num
      <;> simp_all [MeasureTheory.integral_const]
      <;> linarith
    have h₄ : volume.univ = ∞ := by
      -- The measure of the entire real line is infinity.
      simp [Real.volume_Ioi, ENNReal.ofReal_eq_top]
      <;> norm_num
      <;> simp_all [MeasureTheory.integral_const]
      <;> linarith
    have h₅ : ENNReal.ofReal (volume.univ : ℝ≥0∞) = ∞ := by
      rw [h₄]
      <;> simp [ENNReal.ofReal_eq_top]
      <;> norm_num
      <;> simp_all [MeasureTheory.integral_const]
      <;> linarith
    have h₆ : (∫ a : ℝ, (1 : ℝ)) = ∞ := by
      rw [h₃]
      <;> rw [h₅]
      <;> simp [ENNReal.ofReal_eq_top]
      <;> norm_num
      <;> simp_all [MeasureTheory.integral_const]
      <;> linarith
    have h₇ : (∫ a : ℝ, (1 : ℝ)) ≠ (0 : ℝ) := by
      intro h₈
      rw [h₆] at h₈
      norm_num at h₈ ⊢
      <;> simp_all [ENNReal.ofReal_eq_top]
      <;> linarith
    exact h₇
  -- The integral of 1 over ℝ is not zero, but it should be if it were integrable.
  have h₃ : (∫ a : ℝ, (1 : ℝ)) = 0 := by
    have h₄ : Integrable (fun _ : ℝ => (1 : ℝ)) := h
    simp [h₄.integral_eq_zero_of_ae_stronglyMeasurable]
