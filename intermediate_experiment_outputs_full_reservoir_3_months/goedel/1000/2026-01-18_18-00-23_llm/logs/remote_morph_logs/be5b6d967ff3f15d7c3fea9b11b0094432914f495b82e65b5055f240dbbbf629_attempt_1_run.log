lemma IsBinomialRandom.sup (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊔ H ω) (σ <| σ p * σ q) P where
  map_eq := by sorry
  aemeasurable := by
    have hG' : AEMeasurable G P := hG.hasLaw.m.1
    have hH' : AEMeasurable H P := hY.hasLaw.m.1
    have h : AEMeasurable (fun ω ↦ G ω ⊔ H ω) P := by
      apply AEMeasurable.prod
      · exact hG'
