lemma IsBinomialRandom.sup (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊔ H ω) (σ <| σ p * σ q) P where
  map_eq := by sorry
  aemeasurable := by
    have : AEMeasurable (fun ω ↦ G ω ⊔ H ω) P := by
      -- Since G and H are binomial random graphs, their union is a function of them.
      -- In particular, the union is measurable because G and H are measurable.
      have hGP : AEMeasurable G P := hG.aemeasurable
      have hHP : AEMeasurable H P := hY.aemeasurable
      have hG' : Measurable G := hG.aemeasurable.measurable
      have hH' : Measurable H := hY.aemeasurable.measurable
      -- The union of two simple graphs is measurable because it is a pointwise operation on the adjacency relation.
      have : Measurable (fun ω ↦ G ω ⊔ H ω) := by
        -- The supremum of two simple graphs is given by the pointwise supremum of their adjacency relations.
        have : Measurable (fun ω ↦ G ω ⊔ H ω) := by
          -- The supremum of two simple graph is the pointwise supremum of their adjacency relations.
          simp [sup_apply]
          <;> measurable
        exact this
      -- Therefore, the function is a.e. measurable.
      exact this.aemeasurable
    exact this
