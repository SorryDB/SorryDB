theorem group_cat_functors_differences (F G : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    F = G := by
  have h₁ : F.F () = G.F () := by
    simp [Monooid.one]
  have h₂ : F.homF = G.homF := by
    funext f
    -- Since there is only one function from Unit to Unit, both functors map it to the same monoid homomorphism.
    simp [Monooid.one]
    <;> aesop
  ext <;> simp_all
  <;> aesop
```
