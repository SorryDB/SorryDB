theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  classical
  refine' ⟨fun x => F.F x, _, _⟩
  · -- Prove that F.F is monotone
    intro a b hab
    have h : F.F a ≤ F.F b := by
      have h₁ : F F.id = F.id := by
        have h₂ := F.map_id
        simp at h₂ ⊢
        <;> simp_all [F.map_id]
      have h₂ : F F.id = F.id := by
        have h₃ := F.map_id
        simp at h₃ ⊢
        <;> simp_all [F.map_id]
      -- Use the fact that F preserves the order
      have h₃ : F (⟨hab, by simp_all [Preorder.le_trans]⟩ : Hom a b) = ⟨(F.F a : β) ≤ (F.F b : β), by simp_all [Preorder.le_trans]⟩ := by
        have h₄ := F.map_comp
        simp_all [F.map_id]
        <;>
          simp_all [Preorder.le_trans]
      -- Extract the order from the morphism
      simp_all [Hom]
      <;>
        simp_all [PLift.out]
      <;>
        simp_all [Preorder.le_trans]
      <;>
        aesop
    exact h
  · -- Prove that F.F x = f x for all x
    intro x
    rfl

example : ∃ α β: Type*, ∃ C: Category α, ∃ D: Category β,
    ∃ F : Functor α β, ∃ X Y: α, ∃ f: C.Hom X Y, ¬ IsIso f ∧ IsIso (F.homF f) := by
  classical
  -- Define a simple category with two objects and a non-isomorphic morphism
  let α : Type* := Bool
  let C : Category α := ⟨fun X Y => Unit, ⟨⟩, ⟨⟩, fun _ => ⟨⟩, fun _ => ⟨⟩, fun _ _ _ => ⟨⟩⟩
  let β : Type* := Unit
  let D : Category β := ⟨fun X Y => Unit, ⟨⟩, ⟨⟩, fun _ => ⟨⟩, fun _ => ⟨⟩, fun _ _ _ => ⟨⟩⟩
  -- Define a constant functor
  let F : Functor α β := {
    F := fun _ => ()
    homF := fun {X} {Y} _ => ⟨⟩
    map_id := by simp
    map_comp := by simp
  }
  -- Choose X = true and Y = false in α
  have h₁ : ∃ (X Y : α) (f : C.Hom X Y), ¬ IsIso f ∧ IsIso (F.homF f) := by
    use true, false, ⟨⟩
    constructor
    · -- Prove that the morphism is not an isomorphism in C
      intro h
      -- Since there is only one morphism, and it's not invertible
      trivial
    · -- Prove that the image under F is an isomorphism in D
      exact ⟨⟨⟨⟩, ⟨⟩⟩⟩
