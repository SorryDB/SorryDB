  intro h₁
  have h₂ : (p : ℝ) > 0 := by exact_mod_cast h₁
  have h₃ : (p : ℝ) + q > 0 := by
    have h₃₁ : (p : ℝ) + q > 0 := by
      by_contra h₃₁
      have h₃₂ : (p : ℝ) + q ≤ 0 := by linarith
      have h₃₃ : q ≤ -(p : ℝ) := by linarith
      have h₃₄ : (p : ℝ) > 0 := by exact_mod_cast h₁
      have h₃₅ : q > 0 := by
        by_contra h₃₅
        have h₃₆ : q ≤ 0 := by linarith
        have h₃₇ : (p : ℝ) * q ≤ 0 := by nlinarith
        have h₃₈ : (p : ℝ) * q / (p + q) > 0 := by
          have h₃₉ : (p : ℝ) + q > 0 := by
            by_contra h₃₉
            have h₄₀ : (p : ℝ) + q ≤ 0 := by linarith
            have h₄₁ : q ≤ -(p : ℝ) := by linarith
            have h₄₂ : (p : ℝ) > 0 := by exact_mod_cast h₁
            nlinarith
          have h₄₃ : (p : ℝ) * q ≥ 0 := by nlinarith
          positivity
        linarith
      have h₃₉ : q > 0 := by linarith
      nlinarith
    exact h₃₁
  have h₄ : (p : ℝ) * q > 0 := by
    have h₄₁ : q > 0 := by
      by_contra h₄₁
      have h₄₂ : q ≤ 0 := by linarith
      have h₄₃ : (p : ℝ) * q ≤ 0 := by nlinarith
      have h₄₄ : (p : ℝ) * q / (p + q) > 0 := by
        have h₄₅ : (p : ℝ) + q > 0 := by
          by_contra h₄₅
