        have h₁₃ : biasedLocalField net x i ≠ 0 := h₂
        have h₁₄ : 0 < ((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
          -- We need to show that the product of the two terms is positive
