lemma biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero :
  biasedUpdateState net x i ≠ x → biasedLocalField net x i ≠ 0 → biasedEnergyDiff net x i < 0 := by sorry

