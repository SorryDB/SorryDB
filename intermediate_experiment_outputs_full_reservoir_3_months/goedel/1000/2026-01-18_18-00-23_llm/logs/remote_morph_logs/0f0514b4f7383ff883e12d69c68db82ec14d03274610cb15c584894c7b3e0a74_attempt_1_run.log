theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h : l.count x = (smaller pivot l).count x + (larger pivot l).count x := by
    have h₁ : ∀ (l : List α), l.count x = (smaller pivot l).count x + (larger pivot l).count x := by
      intro l
      induction l with
      | nil => simp [smaller, larger]
      | cons y ys ih =>
        simp [smaller, larger, List.count_cons, List.filter_cons_of_pos, List.filter_cons_of_neg,
          List.mem_cons, ih]
        split_ifs <;>
          (try { simp_all [le_of_lt] }) <;>
          (try { cases' lt_or_eq_of_le (by assumption : x ≤ y) with h₂ h₂ <;> simp_all [h₂] }) <;>
          (try { cases' lt_or_eq_of_le (by assumption : y ≤ pivot) with h₂ h₂ <;> simp_all [h₂] }) <;>
          (try { omega }) <;>
          (try { ring_nf at * <;> omega }) <;>
          (try { linarith })
    exact h₁ l
  exact h

