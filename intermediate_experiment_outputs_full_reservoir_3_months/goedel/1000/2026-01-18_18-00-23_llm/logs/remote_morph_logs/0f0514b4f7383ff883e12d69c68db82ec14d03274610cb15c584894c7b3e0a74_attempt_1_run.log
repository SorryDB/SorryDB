theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  have h : ∀ (l : List α), l.count x = (quickSort l).count x := by
    intro l
    induction l using List.length_induction with
    | h l ih =>
      cases l with
      | nil => simp [quickSort]
      | cons pivot l =>
        have h₁ : (smaller pivot l).length < (pivot :: l).length := by
          simp [smaller, List.filter]
          <;>
            simp_all [List.length]
          <;>
            omega
        have h₂ : (larger pivot l).length < (pivot :: l).length := by
          simp [larger, List.filter]
          <;>
            simp_all [List.length]
          <;>
            omega
        have ih₁ : (smaller pivot l).count x = (quickSort (smaller pivot l)).count x := ih _ h₁
        have ih₂ : (larger pivot l).count x = (quickSort (larger pivot l)).count x := ih _ h₂
        simp [quickSort, List.count_append, List.count_cons, count_sum_above_below_pivot] at *
        <;>
          simp_all [List.count_append, List.count_cons]
        <;>
          (try { contradiction })
        <;>
          (try { omega })
        <;>
          (try { cases (x = pivot) <;> simp_all [List.count_cons, List.count_append, count_sum_above_below_pivot] <;> ring_nf at * <;> omega })
        <;>
          (try { cases (x ≤ pivot) <;> cases (x = pivot) <;> simp_all [List.count_cons, List.count_append, smaller, larger, count_sum_above_below_pivot] <;> ring_nf at * <;> omega })
  exact h l
```
