theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h₁ : l.count x = (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => ¬y ≤ pivot)).count x := by
    have h₂ : l.count x = (l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot)).count x := by
      have h₃ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) = l := by
        apply List.ext_get
        intro i _
        by_cases h₄ : l.get ⟨i, ‹_›⟩ ≤ pivot
        · simp_all [List.get_filter]
          <;> aesop
        · simp_all [List.get_filter]
          <;> aesop
      rw [h₃]
    rw [h₂]
    have h₄ : (l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot)).count x =
      (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => ¬y ≤ pivot)).count x := by
      apply List.count_append
    rw [h₄]
  have h₂ : l.filter (fun y => y ≤ pivot) = smaller pivot l := by
    rfl
  have h₃ : l.filter (fun y => ¬y ≤ pivot) = larger pivot l := by
    congr
    ext y
    simp [larger, smaller]
    <;>
    by_cases h₄ : y ≤ pivot <;>
    by_cases h₅ : pivot < y <;>
    simp_all [not_le]
    <;>
    (try { contradiction }) <;>
    (try { linarith }) <;>
    (try { omega })
  rw [h₂, h₃] at h₁
  have h₄ : (l.filter (fun y => ¬y ≤ pivot)).count x = (larger pivot l).count x := by
    rw [h₃]
  have h₅ : (l.filter (fun y => y ≤ pivot)).count x = (smaller pivot l).count x := by
    rw [h₂]
  omega

