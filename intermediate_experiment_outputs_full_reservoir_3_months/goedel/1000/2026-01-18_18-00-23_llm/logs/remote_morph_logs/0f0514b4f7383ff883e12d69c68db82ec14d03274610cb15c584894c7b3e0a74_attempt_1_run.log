theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h₁ : (l.count x) = ((smaller pivot l) ++ (larger pivot l)).count x := by
    have h₂ : (smaller pivot l) ++ (larger pivot l) = l := by
      have h₃ : ∀ (y : α), y ∈ (smaller pivot l) ++ (larger pivot l) ↔ y ∈ l := by
        intro y
        simp only [smaller, larger, List.mem_filter, List.mem_append]
        constructor
        · intro h
          simp_all [lt_irrefl, lt_asymm, or_iff_not_imp_left]
          <;> by_cases h₄ : y ≤ pivot <;> by_cases h₅ : pivot < y <;> simp_all [not_le]
          <;> (try { contradiction }) <;> (try { omega }) <;> (try { linarith })
        · intro h
          by_cases h₄ : y ≤ pivot <;> by_cases h₅ : pivot < y <;> simp_all [not_le]
          <;> (try { contradiction }) <;> (try { omega }) <;> (try { linarith })
          <;> (try { left; simp_all }) <;> (try { right; simp_all })
      have h₄ : (smaller pivot l) ++ (larger pivot l) = l := by
        apply List.ext
        intro y
        simp only [List.mem_append, List.mem_filter]
        have h₅ := h₃ y
        simp only [h₅]
        <;> simp_all [List.mem_cons, List.mem_singleton]
        <;> (try { aesop })
        <;> (try { omega })
        <;> (try { linarith })
      exact h₄
    rw [h₂]
  have h₂ : ((smaller pivot l) ++ (larger pivot l)).count x = (smaller pivot l).count x + (larger pivot l).count x := by
    rw [List.count_append]
  linarith

theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  have h₁ : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by
    intro l
    induction l using List.inductionWithCount with
    | nil x => simp [quickSort]
    | cons l l_count pivot rest x =>
      -- Use the induction hypothesis to assert the statement for the smaller and larger lists
      have h₂ : (smaller pivot rest).count x = (quickSort (smaller pivot rest)).count x := by
        have h₃ := this (smaller pivot rest) x
        exact h₃
      have h₃ : (larger pivot rest).count x = (quickSort (larger pivot rest)).count x := by
        have h₄ := this (larger pivot rest) x
        exact h₄
      -- Use the count_sum_above_below_pivot lemma to relate the counts in the original list to the smaller and larger lists
      have h₄ : (pivot :: rest).count x = (smaller pivot rest).count x + (larger pivot rest).count x := by
        have h₅ := count_sum_above_below_pivot pivot rest x
        have h₆ : (pivot :: rest).count x = (rest.count x) := by
          by_cases h₇ : x = pivot
          · simp_all [List.count_cons]
            <;> aesop
          · simp_all [List.count_cons]
            <;> aesop
        have h₇ : (rest.count x) = (smaller pivot rest).count x + (larger pivot rest).count x := by
          have h₈ := count_sum_above_below_pivot pivot rest x
          exact h₈
        linarith
      -- Combine the counts using the properties of quickSort and the induction hypothesis
      have h₅ : (quickSort (pivot :: rest)) = (quickSort (smaller pivot rest)) ++ pivot :: (quickSort (larger pivot rest)) := by
        simp [quickSort]
      have h₆ : (quickSort (pivot :: rest)).count x = ((quickSort (smaller pivot rest)) ++ pivot :: (quickSort (larger pivot rest))).count x := by
        rw [h₅]
      have h₇ : ((quickSort (smaller pivot rest)) ++ pivot :: (quickSort (larger pivot rest))).count x = (quickSort (smaller pivot rest)).count x + (quickSort (larger pivot rest)).count x := by
        simp [List.count_append, List.count_cons]
        <;>
        (try {
          by_cases h₈ : x = pivot
          <;> simp_all [List.count_cons]
          <;> aesop
        })
        <;>
        (try {
          simp_all [List.count_cons]
          <;> aesop
        })
      have h₈ : (quickSort (smaller pivot rest)).count x = (smaller pivot rest).count x := by
        exact h₂
      have h₉ : (quickSort (larger pivot rest)).count x = (larger pivot rest).count x := by
        exact h₃
      -- Simplify the expressions to conclude the proof
      have h₁₀ : (pivot :: rest).count x = (smaller pivot rest).count x + (larger pivot rest).count x := h₄
      have h₁₁ : (quickSort (pivot :: rest)).count x = (smaller pivot rest).count x + (larger pivot rest).count x := by
        calc
          (quickSort (pivot :: rest)).count x = ((quickSort (smaller pivot rest)) ++ pivot :: (quickSort (larger pivot rest))).count x := by rw [h₆]
          _ = (quickSort (smaller pivot rest)).count x + (quickSort (larger pivot rest)).count x := by
            rw [h₇]
          _ = (smaller pivot rest).count x + (larger pivot rest).count x := by
            rw [h₈, h₉]
      linarith
  exact h₁ l x
