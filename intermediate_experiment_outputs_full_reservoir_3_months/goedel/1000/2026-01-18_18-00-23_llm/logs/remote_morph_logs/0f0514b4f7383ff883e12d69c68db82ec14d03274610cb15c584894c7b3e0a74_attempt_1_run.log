theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  have h : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by
    intro l x
    induction l using List.induction with
    | nil =>
      simp [quickSort]
    | cons pivot l ih =>
      have h1 : (quickSort (smaller pivot l)).count x + (quickSort (larger pivot l)).count x =
        (smaller pivot (pivot :: l)).count x + (larger pivot (pivot :: l)).count x := by
        have h2 : (smaller pivot (pivot :: l)).count x = (smaller pivot l).count x := by
          simp [smaller, List.filter_cons_of_pos, List.count_cons, le_rfl]
          <;>
          (try cases (x ≤ pivot) <;> simp_all [List.filter_cons_of_neg, List.filter_cons_of_pos, le_of_lt]) <;>
          (try omega) <;>
          (try { contradiction })
        have h3 : (larger pivot (pivot :: l)).count x = (larger pivot l).count x := by
          simp [larger, List.filter_cons_of_neg, List.count_cons]
          <;>
          (try cases (x > pivot) <;> simp_all [List.filter_cons_of_neg, List.filter_cons_of_pos, le_of_lt]) <;>
          (try omega) <;>
          (try { contradiction })
        have h4 : (quickSort (smaller pivot l)).count x = (smaller pivot l).count x := by
          apply ih
        have h5 : (quickSort (larger pivot l)).count x = (larger pivot l).count x := by
          apply ih
        calc
          (quickSort (smaller pivot l)).count x + (quickSort (larger pivot l)).count x =
              (smaller pivot l).count x + (larger pivot l).count x := by
            rw [h4, h5]
          _ = (smaller pivot (pivot :: l)).count x + (larger pivot (pivot :: l)).count x := by
            rw [h2, h3]
      simp_all [quickSort, List.count_append, List.count_cons, List.count_eq_zero_of_not_mem,
        mem_iff_mem_quickSort, mem_iff_below_or_above_pivot]
      <;>
      (try omega) <;>
      (try {
        cases (x ≤ pivot) <;>
        cases (x > pivot) <;>
        simp_all [smaller, larger, List.filter_cons_of_neg, List.filter_cons_of_pos, le_of_lt]
        <;>
        try omega <;>
        try { contradiction }
      }) <;>
      (try { aesop }) <;>
      (try {
        omega
      })
  apply h
