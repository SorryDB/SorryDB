theorem count_eq_count_quickSort (l : List α) (x : α) : l.count x = (quickSort l).count x := by
  have h_main : ∀ (l : List α), l.count x = (quickSort l).count x := by
    intro l
    induction l using List.induction_on with
    | nil =>
      simp [quickSort]
    | cons pivot l ih =>
      have h₁ : (smaller pivot l).count x + (larger pivot l).count x = l.count x := by
        have h₂ : (smaller pivot l).count x + (larger pivot l).count x = l.count x := by
          have h₃ : (smaller pivot l).count x + (larger pivot l).count x = (smaller pivot l ++ larger pivot l).count x := by
            rw [List.count_append]
          have h₄ : smaller pivot l ++ larger pivot l = l := by
            have h₅ : ∀ (l : List α), smaller pivot l ++ larger pivot l = l := by
              intro l
              induction l with
              | nil => simp [smaller, larger]
              | cons a l ih =>
                cases' le_or_lt a pivot with h h <;>
                  simp_all [smaller, larger, List.filter_cons_of_pos, List.filter_cons_of_neg,
                    List.append_assoc, List.mem_cons, le_of_lt]
                <;> try { contradiction } <;> try { aesop }
            exact h₅ l
          rw [h₄] at h₃
          <;> simp_all [List.count_append]
          <;>
          (try omega) <;>
          (try aesop)
        linarith
      have h₂ : (quickSort (smaller pivot l)).count x = (smaller pivot l).count x := by
        have h₃ : (smaller pivot l).count x = (quickSort (smaller pivot l)).count x := by
          apply ih
          <;>
          (try simp_all [smaller, List.length]) <;>
          (try omega) <;>
          (try aesop)
        linarith
      have h₃ : (quickSort (larger pivot l)).count x = (larger pivot l).count x := by
        have h₄ : (larger pivot l).count x = (quickSort (larger pivot l)).count x := by
          apply ih
          <;>
          (try simp_all [larger, List.length]) <;>
          (try omega) <;>
          (try aesop)
        linarith
