lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  have h₁ : n ≤ S.length ∨ n - 1 < S.length := by
    by_cases h₂ : n ≤ S.length
    · exact Or.inl h₂
    · -- If n > S.length, then n - 1 ≥ S.length
      have h₃ : n - 1 < S.length := by
        have h₄ : S.length < n := by omega
        -- Use the fact that the number of calls is insufficient to make k an expert
        have h₅ : S.length < n := h₄
        -- We need to show that n - 1 < S.length, which follows from S.length < n
        have h₆ : n - 1 < S.length := by
          omega
        exact h₆
      exact Or.inr h₃
  -- Now we need to derive a contradiction if n ≤ S.length
  cases h₁ with
  | inl h₁ =>
    -- Case: n ≤ S.length
    have h₂ : n ≤ S.length := h₁
    -- We need to show that n - 1 < S.length, which follows from n ≤ S.length
    have h₃ : n - 1 < S.length := by
      have h₄ : n - 1 < n := by
        have h₅ : 0 < n := by
          by_contra h₆
          -- If n = 0, then the type Fin n is empty, and the assumption h is impossible
          have h₇ : n = 0 := by omega
          simp_all [Fin.ext_iff, after, makeCalls, initState]
          <;> simp_all [isExpert]
          <;> aesop
        have h₆ : n - 1 < n := by
          omega
        exact h₆
      have h₅ : n ≤ S.length := h₂
      omega
    exact h₃
  | inr h₁ =>
    -- Case: n - 1 < S.length
    exact h₁
```
