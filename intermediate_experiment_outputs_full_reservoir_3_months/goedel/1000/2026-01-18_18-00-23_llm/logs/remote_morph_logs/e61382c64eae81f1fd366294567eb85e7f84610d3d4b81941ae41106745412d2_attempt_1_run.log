theorem AM_GM_two {a b : ℝ} (h : 0 ≤ a) (h' : 0 ≤ b) : Real.sqrt (a * b) ≤ (a + b) / 2 := by
  have h₁ : 0 ≤ (a - b) ^ 2 := by positivity
  have h₂ : 0 ≤ Real.sqrt (a * b) := Real.sqrt_nonneg (a * b)
  have h₃ : 0 ≤ (a + b) / 2 := by linarith
  have h₄ : (Real.sqrt (a * b)) ^ 2 = a * b := Real.sq_sqrt (by positivity)
  nlinarith [sq_nonneg (a - b), sq_nonneg (Real.sqrt (a * b) - (a + b) / 2)]
