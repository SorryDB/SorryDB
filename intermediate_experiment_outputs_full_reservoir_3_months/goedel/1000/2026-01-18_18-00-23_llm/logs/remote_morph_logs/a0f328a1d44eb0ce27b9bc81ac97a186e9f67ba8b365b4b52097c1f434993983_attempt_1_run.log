theorem all_cEdge_rev_spec {X} {tab : Tableau .nil X} (s t : PathIn tab) :
    s ∈ all_cEdge_rev t ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  have h₁ : all_cEdge_rev t = (all_cEdge t).reverse := rfl
  rw [h₁]
  have h₂ : s ∈ (all_cEdge t).reverse ↔ s ∈ all_cEdge t := by
    simp [List.mem_reverse]
    <;>
    aesop
  rw [h₂]
  have h₃ : s ∈ all_cEdge t ↔ (t ⋖_ s ∨ t ♥ s) := by
    rw [all_cEdge_spec]
    <;>
    aesop
  rw [h₃]
  <;>
  (try { aesop }) <;>
  (try {
