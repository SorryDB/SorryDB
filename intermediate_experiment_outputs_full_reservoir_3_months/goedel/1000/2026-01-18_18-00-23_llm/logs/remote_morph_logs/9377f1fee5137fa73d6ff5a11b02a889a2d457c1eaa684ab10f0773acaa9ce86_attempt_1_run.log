### Complete Lean Proof

```lean
@[fun_prop]
lemma wignerMatrixMapScaledMeasurable (n : ℕ) : Measurable (wignerMatrixMapScaled n) := by
  have h₁ : Measurable (wignerMatrixMap n) := by
    apply wignerMatrixMapMeasurable
  
  have h₂ : Continuous fun (A : Matrix (Fin n) (Fin n) ℝ) => (1 / Real.sqrt (n : ℝ)) • A := by
    -- Scalar multiplication by a fixed scalar is continuous in a normed space.
    apply Continuous.const_smul
    -- The identity function on the space of matrices is continuous.
    exact continuous_id
  
  have h₃ : Measurable (wignerMatrixMapScaled n) := by
    -- Define the scalar multiplication function.
    let smul : Matrix (Fin n) (Fin n) ℝ → Matrix (Fin n) (Fin n) ℝ := fun A => (1 / Real.sqrt (n : ℝ)) • A
    -- Show that the composition of smul with wignerMatrixMap n is measurable.
    have h₄ : Measurable (smul ∘ wignerMatrixMap n) := by
      -- Use the fact that smul is continuous and wignerMatrixMap n is measurable.
      have h₅ : Continuous smul := h₂
      have h₆ : Measurable (wignerMatrixMap n) := h₁
      exact h₅.measurable.comp h₆
    -- Since wignerMatrixMapScaled n is exactly smul ∘ wignerMatrixMap n, we can conclude.
    have h₇ : wignerMatrixMapScaled n = smul ∘ wignerMatrixMap n := by
      funext ω
      simp [wignerMatrixMapScaled, wignerMatrixMap, smul]
      <;>
      simp_all [wignerMatrixMap', wignerMatrixEntryFunction]
      <;>
      aesop
    rw [h₇]
    exact h₄
  
  exact h₃
``` 

