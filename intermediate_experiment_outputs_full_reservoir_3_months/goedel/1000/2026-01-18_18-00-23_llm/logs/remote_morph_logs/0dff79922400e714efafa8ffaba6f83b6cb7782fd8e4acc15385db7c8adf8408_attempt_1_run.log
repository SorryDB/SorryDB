  have h : HasDerivAt (fun x : ℝ => x ^ 3) (3 * x ^ 2) x := by
    -- Prove that the derivative of x^3 is 3x^2 using basic derivative rules
    have h₁ : HasDerivAt (fun x : ℝ => x ^ 3) (3 * x ^ 2) x := by
