theorem exists_deriv_cube : ∃ g : ℝ → ℝ, DifferentiableOn 𝕜 𝑈 (fun x : ℝ => x ^ 3)
  ∧ ∀ x ∈ 𝑈, deriv (fun x : ℝ => x ^ 3) x = g x := by
  have h_main : ∃ (g : ℝ → ℝ), DifferentiableOn 𝕜 𝑈 (fun x : ℝ => x ^ 3) ∧ ∀ x ∈ 𝑈, deriv (fun x : ℝ => x ^ 3) x = g x := by
    use fun x => 3 * x ^ 2
    constructor
    · -- Prove that the function is differentiable on 𝑈
      have h₁ : DifferentiableOn 𝕜 𝑈 (fun x : ℝ => x ^ 3) := by
        -- Use the fact that the power function is differentiable everywhere on ℝ
        have h₂ : DifferentiableOn ℝ (fun x : ℝ => x ^ 3) 𝑈 := by
          -- Apply the power rule for differentiation
          apply DifferentiableOn.pow
          exact differentiableOn_id
          <;> norm_num
        -- Since 𝕜 is ℝ, we can directly use the differentiability result
        exact h₂
      exact h₁
    · -- Prove that the derivative matches the given function
      intro x hx
      -- Use the power rule to find the derivative of x^3
      have h₂ : deriv (fun x : ℝ => x ^ 3) x = 3 * x ^ 2 := by
        -- Compute the derivative using basic differentiation rules
        have h₃ : HasDerivAt (fun x : ℝ => x ^ 3) (3 * x ^ 2) x := by
          -- Apply the power rule for differentiation
          simpa using (hasDerivAt_pow 3 x)
        -- Use the fact that the derivative exists to get the result
        have h₄ : deriv (fun x : ℝ => x ^ 3) x = 3 * x ^ 2 := by
          apply HasDerivAt.deriv
          exact h₃
        exact h₄
      -- The result follows directly from the computation
      rw [h₂]
  -- The main result follows directly from the above proof
  exact h_main
