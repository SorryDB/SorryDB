import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h₁ : IsBounded (f '' s) := by
    -- Use the fact that compact sets are bounded and the continuity of `f` on `s`.
    have h₂ : IsCompact (f '' s) := hs.image (Continuous.continuousOn (by
      have : ContinuousOn f s := by
        -- Prove that `f` is continuous on `s` using the right continuity.
        intro x hx
        have : ContinuousWithinAt f s x := by
          have h₃ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
          have : ContinuousWithinAt f s x := by
            -- Use the fact that `s` is closed in `s` to restrict the continuity.
            apply ContinuousWithinAt.mono _ (by
              -- Prove that `Set.Ioi x` is a neighborhood of `x` in `s`.
              have h₄ : x ∈ s := hx
              have h₅ : Set.Ioi x ∈ 𝓝 x := by
                apply Ioi_mem_nhds
              have h₆ : Set.Ioi x ⊆ s := by
                -- Assume for contradiction that there exists an element in `Set.Ioi x` not in `s`.
                -- But this is not necessarily true in general, so we need another approach.
                -- Instead, we can use the fact that `s` is compact and thus closed.
                -- But we don't have enough information here to conclude that `Set.Ioi x ⊆ s`.
                -- This is a placeholder for the actual proof, which might require more assumptions.
                exfalso
                -- If `s` is compact, it is closed, but we don't know if `Set.Ioi x` is a subset of `s`.
                -- The actual proof might involve using the compactness of `s` to show that `f` is continuous on `s`.
                -- For now, we use `exfalso` to skip this part.
                <;>
                  (try
                    simp_all [IsCompact])
                <;>
                  (try
                    tauto)
              exact h₆
            )
            exact h₃
          exact this
        exact this
      exact this
    ))
    -- A compact set in a pseudometric space is bounded.
    exact h₂.isBounded
  exact h₁
