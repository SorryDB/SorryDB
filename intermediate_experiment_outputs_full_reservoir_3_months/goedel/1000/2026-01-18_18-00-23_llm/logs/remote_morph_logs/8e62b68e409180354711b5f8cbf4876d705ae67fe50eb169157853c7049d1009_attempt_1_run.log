lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  haveI : UniformSpace E := PseudoMetricSpace.toUniformSpace E
  -- Use the fact that the image of a compact set under a continuous function is compact.
  have h₁ : IsCompact (f '' s) := by
    have h₂ : ContinuousOn f s := by
      -- Prove that f is continuous on s using the right continuity and the fact that ι is a first-countable topological space.
      refine' fun x hx => hf.right_continuous x _
      -- Use the fact that the filter at x is finer than the restricted filter.
      apply nhdsWithin_le_nhds.trans
      -- Use the fact that the filter at x is finer than the restricted filter.
      <;> simp_all [le_refl]
      <;> exact nhdsWithin_le_nhds
    -- Use the fact that the image of a compact set under a continuous function is compact.
    exact hs.image_of_continuousOn h₂
  -- Use the fact that compact sets are bounded.
  exact h₁.isBounded
```
