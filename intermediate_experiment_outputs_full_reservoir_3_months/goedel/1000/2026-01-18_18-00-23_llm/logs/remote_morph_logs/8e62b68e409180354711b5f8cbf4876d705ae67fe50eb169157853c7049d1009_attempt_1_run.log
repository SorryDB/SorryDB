lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h₁ : IsCompact (f '' s) := by
    apply hs.image_of_continuousWithinOn
    intro x hx
    have h₂ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
    have h₃ : ContinuousWithinAt f (Set.Icc x x) x := by
      have h₄ : ContinuousWithinAt f (Set.univ : Set ι) x := by
        -- Use the fact that the function is right-continuous to deduce continuity at x within Set.Icc x x
        have h₅ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
        have h₆ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
        -- Since f is continuous within Set.Ioi x at x, and Set.Icc x x is a subset of the closure of Set.Ioi x,
        -- we can deduce continuity within Set.Icc x x at x.
        have h₇ : ContinuousWithinAt f (Set.univ : Set ι) x := by
          -- Use the fact that Set.Ioi x is a subset of Set.univ and the continuity within Set.Ioi x
          have h₈ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
          have h₉ : ContinuousWithinAt f (Set.univ : Set ι) x :=
            ContinuousWithinAt.mono h₈ (by intro y hy; exact Set.mem_univ y)
          exact h₉
        exact h₇
      have h₁₀ : ContinuousWithinAt f (Set.Icc x x) x := by
        -- Since Set.Icc x x is a subset of Set.univ and f is continuous within Set.univ at x,
        -- we can deduce continuity within Set.Icc x x at x.
        have h₁₁ : ContinuousWithinAt f (Set.univ : Set ι) x := h₄
        have h₁₂ : ContinuousWithinAt f (Set.Icc x x) x :=
          ContinuousWithinAt.mono h₁₁ (by intro y hy; exact Set.mem_univ y)
        exact h₁₂
      exact h₁₀
    -- Since f is continuous within Set.Icc x x at x, and Set.Icc x x is a neighborhood of x in the subspace topology,
    -- we can deduce that f is continuous at x within the set s.
    have h₁₃ : ContinuousWithinAt f s x := by
      have h₁₄ : x ∈ s := hx
      have h₁₅ : ContinuousWithinAt f (Set.Icc x x) x := h₃
      have h₁₆ : Set.Icc x x ⊆ s := by
        intro y hy
        simp only [Set.mem_Icc] at hy
        have h₁₇ : y = x := by
          linarith
        rw [h₁₇]
        exact h₁₄
      have h₁₇ : ContinuousWithinAt f s x := ContinuousWithinAt.mono h₁₅ h₁₆
      exact h₁₇
    exact h₁₃
  -- Since the image of a compact set under a continuous function is compact, and compact sets are bounded,
  -- we conclude that the image of s under f is bounded.
  exact h₁.isBounded
