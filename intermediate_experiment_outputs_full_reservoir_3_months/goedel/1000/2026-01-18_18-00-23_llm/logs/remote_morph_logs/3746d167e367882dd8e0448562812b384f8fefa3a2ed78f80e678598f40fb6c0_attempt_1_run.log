theorem vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  have h₁ := hxy (⟨0, by decide⟩ : Fin 2) (⟨0, by decide⟩ : Fin 2) ∅
  have h₂ := hxy (⟨1, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) ∅
  have h₃ := hxy (⟨0, by decide⟩ : Fin 2) (⟨0, by decide⟩ : Fin 2) { (⟨1, by decide⟩ : Fin 2), (⟨1, by decide⟩ : Fin 2) }
  have h₄ := hxy (⟨1, by decide⟩ : Fin 2) (⟨1, by decide⟩ : Fin 2) { (⟨0, by decide⟩ : Fin 2), (⟨0, by decide⟩ : Fin 2) }
  norm_num [Fin.ext_iff, Fin.val_zero] at h₁ h₂ h₃ h₄
  <;> simp_all [Fin.ext_iff, Fin.val_zero]
  <;> norm_num at *
  <;> tauto
