lemma IsBernoulliOn.iIndepFun_mem (hX : IsBernoulliOn X u p P) :
    iIndepFun (fun i ω ↦ i ∈ X ω) P :=
  have h1 : ∀ (s : Set (Set ι)), Ber(u, p) s = (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) ((fun p ↦ {a | p a}) ⁻¹' s) := by
    intro s
    simpa [bernoulliOn_apply'] using bernoulliOn_apply' s
  have h2 : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
