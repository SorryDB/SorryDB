  field_simp
  ring_nf
  rw [ω_sq]
  field_simp
  simp only [neg_add_cancel, mul_zero]
  fun_prop

@[simp]
lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = ClassicalMechanics.HarmonicOscillator.InitialConditions.x₀ IC ∧
