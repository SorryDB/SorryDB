lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h1 : x 0 = IC.x₀ := by tauto
  have h2 : ∂ₜ x 0 = IC.v₀ := by tauto
  have h3 : S.EquationOfMotion x := by tauto
  have h4 : x = IC.trajectory S := by
    -- Use the uniqueness of solutions to second-order linear ODEs
    have h5 : S.EquationOfMotion (IC.trajectory S) := by
      apply trajectory_equationOfMotion
    have h6 : x = IC.trajectory S := by
      -- Prove that x and trajectory are equal by showing they satisfy the same ODE and initial conditions
      apply (exists_unique_of_hasDerivAt_of_hasDerivAt (by sorry) (by sorry)).Unique
      <;>
      (try assumption) <;>
