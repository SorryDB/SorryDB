variable {n : ℕ}
variable (hn : Nat.Prime n)

theorem no_divisors_of_prime :
  ∀ (a : ℕ), a ∣ n → a = 1 ∨ a = n := by
  intro a ha
  have h : a = 1 ∨ a = n := by
    -- We use the property of prime numbers that if a prime number divides a product, it must divide at least one of the factors.
    -- Here, we consider the product of 1 and n.
    have h₁ : a = 1 ∨ a = n := by
      -- Since n is a prime number, its only positive divisors are 1 and n itself.
      -- Therefore, if a divides n, then a must be either 1 or n.
