def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := G.vertexSet
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ G.verticesOf M
  indep_empty := by
    refine' ⟨∅, ?_, ?_⟩ <;> simp [isMatching_empty]
    <;> simp_all [Set.subset_def]
  
  indep_subset := by
    intro S T hS hT
    obtain ⟨M, hM, hM'⟩ := hS
    exact ⟨M, hM, hM'.trans hT⟩
  
  indep_aug := by
    intro S T hS hT hST
    obtain ⟨M, hM, hM'⟩ := hS
    have h₁ : ∃ (v : α), v ∈ T ∧ v ∉ S := by
      by_contra! h
      have h₂ : T ⊆ S := by
        intro x hx
        by_cases hx' : x ∈ S
        · exact hx'
        · exfalso
          specialize h x hx hx'
          tauto
      have h₃ : T.encard ≤ S.encard := Set.encard_le_of_subset h₂
      have h₄ : S.encard < T.encard := hST
      linarith
    obtain ⟨v, hvT, hvS⟩ := h₁
    have h₂ : ∃ (M' : Set β), G.IsMatching M' ∧ S ⊆ G.verticesOf M' ∧ v ∈ G.verticesOf M' := by
      obtain ⟨M', hM', hM''⟩ := hT
      have h₃ : v ∈ G.verticesOf M' := by
        have h₄ : T ⊆ G.verticesOf M' := hM''
        exact h₄ hvT
      exact ⟨M', hM', (hM'' : S ⊆ G.verticesOf M').trans (by aesop), h₃⟩
    obtain ⟨M', hM', hM'', hv'⟩ := h₂
    exact ⟨M', hM', hM''.insert hv'⟩
  
  indep_maximal := by
    intro S hS
    simp_all [indep_maximal]
    <;>
    (try aesop)
    <;>
    (try simp_all [exists_prop])
    <;>
    (try tauto)
  
  subset_ground := by
    intro I hI
    obtain ⟨M, hM, hM'⟩ := hI
    have h₁ : I ⊆ G.vertexSet := by
      intro x hx
      have h₂ : x ∈ G.verticesOf M := hM' hx
      have h₃ : x ∈ G.vertexSet := by
        have h₄ : x ∈ T(G, M) := h₂
        have h₅ : T(G, M) ⊆ G.vertexSet := by
          intro y hy
          simp only [Set.mem_setOf_eq, T(G, M)] at hy ⊢
          rcases hy with ⟨e, he, hy⟩
          have h₆ : e ∈ E(G) := by
            have h₇ : M ⊆ E(G) := hM.subset
            exact h₇ he
          simp_all [vertexSet]
          <;> aesop
        exact h₅ h₄
      exact h₃
    exact h₁
