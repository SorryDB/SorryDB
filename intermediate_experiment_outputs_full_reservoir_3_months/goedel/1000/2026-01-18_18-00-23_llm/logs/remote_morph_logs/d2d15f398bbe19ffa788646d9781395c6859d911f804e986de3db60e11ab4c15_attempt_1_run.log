theorem subset_ground (I : Set α) (hI : ∃ M, IsMatching G M ∧ I ⊆ V(G, M)) : I ⊆ G.vertexSet :=
  by
  obtain ⟨M, hM, hI⟩ := hI
  have hM_sub : M ⊆ G.Edge := hM.subset
  intro x hx
  have h x : x ∈ V(G, M) → x ∈ G.vertexSet := by
    intro hxM
    have h1 : x ∈ V(G, M) := hxM
    have h2 : V(G, M) ⊆ G.vertexSet := by
      intro y hy
      rcases hy with ⟨e, he, hy⟩
      exact he.inl
    exact h2 h1
  exact h (hI hx)
```
