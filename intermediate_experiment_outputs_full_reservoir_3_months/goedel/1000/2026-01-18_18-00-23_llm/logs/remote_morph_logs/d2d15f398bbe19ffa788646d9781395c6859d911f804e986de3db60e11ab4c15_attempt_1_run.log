def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, G.isempty_matching, _⟩
    simp [V_eq_empty_iff]
  indep_subset := by
    intro S T hs hS
    obtain ⟨M, hM, hSM⟩ := hs
    refine' ⟨M, hM, _⟩
    exact hS.trans hSM
  indep_aug := by
    intro I J hI hJ hIJ
    obtain ⟨M, hM, hIM⟩ := hI
    obtain ⟨M', hM', hJM⟩ := hJ
    have h : I ⊆ J := hIJ
    have h₁ : J ⊆ V(G, M) := hJM
    have h₂ : I ⊆ V(G, M) := by
      exact Set.Subset.trans h h₁
    have h₃ : ∃ (a : α), a ∈ J ∧ a ∉ I := by
      by_contra h₃
      push_neg at h₃
      have h₄ : J ⊆ I := by
        intro a ha
        by_cases h₅ : a ∈ I
        · exact h₅
        · have h₆ := h₃ a
          aesop
      have h₅ : J ⊆ I := h₄
      have h₆ : J = I := by
        apply Set.Subset.antisymm
        · exact h₅
        · exact hIJ
      rw [h₆] at hJ
      have h₇ : M.encard = M'.encard := by
        sorry
      aesop
    obtain ⟨a, haJ, haI⟩ := h₃
    have h₄ : ∃ (M'', _ : G.IsMatching M''), I ⊆ V(G, M'') ∧ a ∈ V(G, M'') := by
      sorry
    obtain ⟨M'', hM'', hI, ha⟩ := h₄
    exact ⟨M'', hM'', _⟩
    <;> simp_all [Set.Subset.trans]
    <;> aesop
  indep_maximal := by
    sorry
  subset_ground := by
    intro S hS
    obtain ⟨M, hM, hSM⟩ := hS
    have h₁ : S ⊆ V(G) := by
      have h₂ : V(G, M) ⊆ V(G) := by
        intro x hx
        obtain ⟨e, he⟩ := hx
        exact he.left_mem
      exact Set.Subset.trans hSM h₂
    exact h₁
  <;> simp_all [V_eq_empty_iff]
  <;> aesop
