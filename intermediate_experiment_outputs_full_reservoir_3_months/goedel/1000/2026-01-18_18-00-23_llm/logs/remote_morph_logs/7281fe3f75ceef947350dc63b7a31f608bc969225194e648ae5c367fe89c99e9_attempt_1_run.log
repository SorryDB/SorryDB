    intro hxy
    rw [hxy] at h
    have h₄ := h.nodup
    simp_all [Graph.Adj]
  have h₄ : x ∈ V(G) := by
    have h₅ := h₁
    simp only [Graph.inesential] at h₅
    rcases h₅ with ⟨M, hM, hM'⟩
    have h₆ := hM'.1
    simp_all [Graph.Mem, Graph.Vertices]
    <;> aesop
  have h₅ : y ∈ V(G) := by
    have h₆ := h₂
    simp only [Graph.inesential] at h₆
    rcases h₆ with ⟨M, hM, hM'⟩
    have h₇ := hM'.1
    simp_all [Graph.Mem, Graph.Vertices]
    <;> aesop
  have h₆ : ¬G.Infinite := by
    have h₇ := h₁
    simp only [Graph.inesential] at h₇
    rcases h₇ with ⟨M, hM, hM'⟩
    have h₈ : G.Infinite → False := by
