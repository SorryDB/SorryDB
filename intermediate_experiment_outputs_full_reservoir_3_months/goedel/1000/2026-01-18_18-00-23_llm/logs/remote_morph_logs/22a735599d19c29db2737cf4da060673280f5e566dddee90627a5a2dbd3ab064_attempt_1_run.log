        <;> aesop
      have h_edge : (SimpleGraph.LoopWalk.loop ‚ÄĻ_‚Äļ).edgeSet = (@SimpleGraph.LoopWalk.edgeSet _ _ _ _ _ ‚ÄĻ_‚Äļ) := by
        simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges]
