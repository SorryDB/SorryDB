        have h₂ : (j : ℕ) ≤ n := by
          have h₃ : (j : ℕ) ≤ m := hj2
          have h₄ : (m : ℕ) ≤ n := hmn
          omega
        have h₃ : (i : ℕ) ≥ 1 := by exact_mod_cast hi1
        have h₄ : (2 * j : ℕ) ≤ 2 * n := by
          omega
        have h₅ : (2 * j - i : ℕ) ≤ 2 * n - 1 := by
          have h₆ : (2 * j : ℕ) ≤ 2 * n := by omega
