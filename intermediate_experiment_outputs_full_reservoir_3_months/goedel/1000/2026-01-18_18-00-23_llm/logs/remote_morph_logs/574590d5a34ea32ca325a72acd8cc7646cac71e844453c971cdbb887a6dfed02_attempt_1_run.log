lemma construction_rel :
  letI U := construction_omega T hT
  (∀ φ ψ, φ ➝ ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  dsimp only
  intro φ ψ hφψ hφ
  have h₁ : ψ ∈ construction_omega T hT := by
    have h₂ : φ ➝ ψ ∈ T.theory := hφψ
    have h₃ : φ ∈ construction_omega T hT := hφ
    have h₄ : ψ ∈ construction_omega T hT := by
      by_cases h₅ : χ ➝ ψ ∈ T.theory
      · -- Case: χ → ψ ∈ T
        have h₆ : ψ ∈ construction_omega T hT := by
          apply mem_omega_of_mem
          exact h₅
        exact h₆
      · -- Case: χ → ψ ∉ T
        -- We need to show that ψ ∈ construction_omega T hT
        -- This is more complex and requires additional steps
        have h₆ : ∃ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT (encode ψ) ∧ Γ.conj ⋏ ψ ➝ ξ ∈ T.theory := by
          by_contra! h₆
          -- If no such Γ exists, then ψ ∈ construction_omega T hT by definition
          have h₇ : ψ ∈ construction_omega T hT := by
            simp only [construction_omega, Set.mem_iUnion] at *
            have h₈ : ∀ i, ψ ∉ construction T hT i := by
              intro i
              by_contra h₉
              have h₁₀ : ψ ∈ construction T hT i := h₉
              have h₁₁ : ∃ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT (encode ψ) ∧ Γ.conj ⋏ ψ ➝ ξ ∈ T.theory := by
                -- Use the fact that ψ is in the construction to find a suitable Γ
                sorry
              obtain ⟨Γ, hΓ₁, hΓ₂⟩ := h₁₁
              have h₁₂ := h₆ Γ
              tauto
            -- Since ψ is not in any construction T hT i, it is in construction_omega T hT
            exfalso
            exact h₈ (encode ψ) (by simp_all [construction_omega])
          exact h₇
        -- We have a contradiction because we assumed ψ ∉ construction_omega T hT
        sorry
    exact h₄
  exact h₁
