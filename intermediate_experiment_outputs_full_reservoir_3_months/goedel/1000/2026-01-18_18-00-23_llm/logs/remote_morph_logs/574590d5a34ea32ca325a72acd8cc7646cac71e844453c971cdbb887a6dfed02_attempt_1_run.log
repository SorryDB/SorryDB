lemma construction_rel :
  letI U := construction_omega T hT
  (∀ φ ψ, φ ➝ ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  dsimp only [U]
  intro φ ψ hφψ hφ
  have : ψ ∈ construction_omega T hT := by
    have hψ : ψ ∈ construction_omega T hT := by
      simp only [Set.mem_iUnion] at hφ ⊢
      -- Use the fact that φ ∈ construction_omega T hT to find an i such that φ ∈ construction T hT i
      obtain ⟨i, hi⟩ := hφ
      use i + 1
      have h : ψ ∈ construction T hT (i + 1) := by
        dsimp [construction] at hi ⊢
        by_cases h₁ : ∀ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT i → Γ.conj ⋏ (ψ : Formula ℕ) ➝ ξ ∉ T.theory
        · -- Case: h₁ holds
          -- If ψ is in construction T hT i, then it is in construction T hT (i + 1)
          simp_all
          <;>
          (try omega) <;>
          (try tauto)
        · -- Case: h₁ does not hold
          -- If ψ is not in construction T hT i, then we need to check if it is in construction T hT (i + 1)
          simp_all
          <;>
          (try omega) <;>
          (try tauto)
      exact h
    exact hψ
  exact this
```
