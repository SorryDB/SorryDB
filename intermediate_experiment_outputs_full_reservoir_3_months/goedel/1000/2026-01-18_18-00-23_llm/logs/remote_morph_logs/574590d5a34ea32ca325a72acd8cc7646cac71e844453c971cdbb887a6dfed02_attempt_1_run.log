theorem deduction_completes_lindenbaum :
  letI U := construction_omega T hT
  (∀ φ ψ, φ ➝ ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  intro φ ψ h_ψ hφ
  have h₁ : ψ ∈ (construction_omega T hT) := by
    have h₂ : φ ➝ ψ ∈ T.theory := h_ψ
    have h₃ : φ ∈ (construction_omega T hT) := hφ
    -- Use the fact that construction_omega is an FTheory to show that ψ is in it
    have h₄ : ψ ∈ (construction_omega T hT) := by
      simp only [construction_omega, Set.mem_iUnion] at h₃ ⊢
      -- Use the fact that φ is in construction_omega to find an appropriate index
      obtain ⟨i, hi⟩ := h₃
      have h₅ : i ≤ i + 1 := by linarith
      have h₆ : (construction T hT i : Set (Formula ℕ)) ⊆ (construction T hT (i + 1) : Set (Formula ℕ)) :=
        subset_construction_succ
      have h₇ : (construction T hT (i + 1) : Set (Formula ℕ)) ⊆ (⋃ i : ℕ, (construction T hT i : Set (Formula ℕ))) :=
        by
          intro x hx
          exact ⟨i + 1, hx⟩
      -- Use the fact that φ ➝ ψ is in T theory to show ψ is in construction_omega
      have h₈ : ψ ∈ (construction T hT (i + 1) : Set (Formula ℕ)) := by
        have h₉ : φ ∈ (construction T hT i : Set (Formula ℕ)) := hi
        have h₁₀ : φ ➝ ψ ∈ T.theory := h_ψ
        have h₁₁ : ψ ∈ (construction T hT (i + 1) : Set (Formula ℕ)) := by
          -- Use the induction step to show that ψ is in construction T hT (i + 1)
          have h₁₂ : ∀ {φ ψ}, φ ➝ ψ ∈ T.theory → φ ∈ (construction T hT i : Set (Formula ℕ)) → ψ ∈ (construction T hT (i + 1) : Set (Formula ℕ)) := by
            intro φ ψ hφψ hφ
            -- Use the fact that construction T hT (i + 1) contains all implications
            -- that are in T/theory and whose antecedents are in construction T hT i
            simp [construction] at hφ ⊢
            <;>
            (try { cases i <;> simp_all [construction, Set.mem_insert_iff, Set.mem_singleton_iff] <;>
              (try { aesop }) <;>
              (try { omega }) <;>
              (try { aesop }) }) <;>
            (try { aesop }) <;>
            (try { omega }) <;>
            (try { aesop })
          exact h₁₂ h₉ h₁₀
        exact h₁₁
      -- Combine the results to show ψ is in construction_omega
      have h₉ : ψ ∈ (⋃ i : ℕ, (construction T hT i : Set (Formula ℕ))) := h₇ h₈
      exact h₉
    exact h₄
  exact h₁
