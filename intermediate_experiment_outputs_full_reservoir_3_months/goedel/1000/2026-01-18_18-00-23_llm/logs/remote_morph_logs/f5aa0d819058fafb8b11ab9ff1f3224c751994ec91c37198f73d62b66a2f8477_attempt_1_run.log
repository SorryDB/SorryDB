theorem Disjoint_ball_of_mem_setIio {ε : ℝ} (hε : 0 < ε) {x y : ℝ} (hy : y ≤ x - δ) :
    Disjoint (ball x ε) (Ioi y) := by
  rw [Set.disjoint_iff]
  intro z hz
  have h₁ : z ∈ ball x ε := hz.1
  have h₂ : z ∈ Set.Ioi y := hz.2
  have h₃ : |z - x| < ε := h₁
  have h₄ : y < z := h₂
  have h₅ : z - x < ε := by linarith [abs_lt.mp h₃]
  have h₆ : -(ε : ℝ) < z - x := by linarith [abs_lt.mp h₃]
  have h₇ : y < z := h₂
  have h₈ : y ≤ x - δ := hy
  have h₉ : δ > 0 := δ_pos
  nlinarith
```
