theorem f_pose_eq_sval {p pbar : Pose} {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε) :
    pc.f p.innerParams = pc.Sval p := by
  have h₁ : pc.f p.innerParams = ⟪p.inner pc.S, pc.w⟫ := by
    simp [GlobalTheoremPrecondition.f]
    <;>
    simp_all [csimp_all [rotproj_inner])
      <;>
    (try simp_all [rotproj_inner])
    <;>
    linarith
    <;>
    assumption
    <;>
    norm_num
    <;>
    linarith
  have h₂ : pc.Sval p = ⟪p.inner pc.S, pc.w⟫ := by
    simp [GlobalTheoremPrecondition.Sval]
    <;>
    simp_all [csimp_all [rotproj_inner])
      <;>
    (try simp_all [rotproj_inner])
    <;>
    linarith
    <;>
    assumption
    <;>
    norm_num
    <;>
    linarith
  linarith
