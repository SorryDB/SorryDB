        -- Use the given equivalence to show that the result sets are equal
        have h₄ : ⟨σ, Error.Sequence.maxOne_cons n (Error.Call.normal n a c) σ o⟩ = ⟨σ, Error.Sequence.maxOne_cons n (Error.Call.normal n a c) σ o⟩ := rfl
        simp_all [Error.equiv, Error.OSequence.length_def]
        <;> try aesop
