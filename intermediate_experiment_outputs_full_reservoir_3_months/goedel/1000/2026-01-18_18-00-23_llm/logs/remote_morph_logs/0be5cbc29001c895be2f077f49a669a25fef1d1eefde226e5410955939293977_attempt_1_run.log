        <;> try aesop
      -- Since S⌈...⌉a = T⌈τ⌉a, we can deduce that S b = T b
      have h₅ : S b = T b := by
        -- Use the fact that the result sets are equal to deduce S b = T b
        simp_all [Error.eval, Error.dist]
