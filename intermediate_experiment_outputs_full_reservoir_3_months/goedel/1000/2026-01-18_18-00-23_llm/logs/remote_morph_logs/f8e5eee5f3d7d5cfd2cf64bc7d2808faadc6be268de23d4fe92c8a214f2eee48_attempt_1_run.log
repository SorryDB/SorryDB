            -- The derivative of f.unop is smooth
            have h₄ : ContDiff ℝ ⊤ (fderiv ℝ f.unop.toFun) := by
              have h₅ : ContDiff ℝ ⊤ f.unop.toFun := f.unop.dsmooth.contDiff
              -- The derivative of a smooth function is smooth
