```lean
@[simp]
lemma off_diagonal_law (Y : isWignerMatrix n μ ν X P) (i j : Fin n) (hij : i ≠ j) :
  HasLaw (fun ω ↦ X ω i j) μ P:= by
  have h_cases : i < j ∨ j < i := by
    have h : i < j ∨ j < i := by
      -- Since i ≠ j, either i < j or j < i
      cases' lt_or_gt_of_ne hij with h h
      · exact Or.inl h
      · exact Or.inr h
    exact h
  
  have h_main : HasLaw (fun ω ↦ X ω i j) μ P := by
    cases h_cases with
    | inl h_ij =>
      -- Case: i < j
      have h_ji : HasLaw (fun ω => X ω j i) μ P := by
        -- Since j > i, we can apply the off_diag_dist condition
        have h_ji_gt : j > i := by
          -- Prove that j > i given i < j
          exact lt_iff_le_and_ne.mpr ⟨le_of_lt h_ij, by intro h_eq; apply hij; simp_all [h_eq]⟩
        -- Apply the off_diag_dist condition to j and i
        have h_ji_off_diag : HasLaw (fun ω => X ω j i) μ P := Y.off_diag_dist j i h_ji_gt
        exact h_ji_off_diag
      -- Use the symmetry of the matrix to relate X i j and X j i
      have h_symm : (fun ω => X ω i j) = (fun ω => X ω j i) := by
        funext ω
        rw [Y.symm i j ω]
      -- Since X i j = X j i, they have the same law
      rw [h_symm]
      exact h_ji
    | inr h_ji =>
      -- Case: j < i
      -- Directly apply the off_diag_dist condition to i and j
      have h_ij_off_diag : HasLaw (fun ω => X ω i j) μ P := Y.off_diag_dist i j h_ji
      exact h_ij_off_diag
  
  exact h_main
