theorem H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
  have h₁ : Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
    have h₂ : x < (n : ℝ) + 1 := by exact_mod_cast hxlt
    have h₃ : x ≥ (n : ℝ) := by exact_mod_cast hxge
    -- Use the inequality log x ≤ ∑_{k=1}^n 1/k for x ∈ [n, n+1)
    have h₄ : Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
      -- Prove by induction on n
      have h₅ : ∀ (m : ℕ), (m : ℝ) ≤ x → x < (m : ℝ) + 1 → Real.log x ≤ ∑ k ∈ Icc 1 m, (k : ℝ)⁻¹ := by
        intro m hm₁ hm₂
        induction' m with m ih
        · -- Base case: m = 0
          have h₆ : x < (1 : ℝ) := by linarith
          have h₇ : Real.log x ≤ 0 := by
            have h₈ : x > 0 := by linarith
            have h₉ : Real.log x ≤ 0 := by
              have h₁₀ : x ≤ 1 := by linarith
              have h₁₁ : Real.log x ≤ 0 := Real.log_nonpos (by linarith) (by linarith)
              exact h₁₁
            exact h₉
          simp_all [Finset.sum_range_zero]
          <;> linarith
        · -- Inductive step: assume true for m, prove for m + 1
          have h₆ : (m : ℝ) ≤ x := by linarith
          have h₇ : x < (m : ℝ) + 1 := by linarith
          have h₈ : Real.log x ≤ ∑ k ∈ Icc 1 m, (k : ℝ)⁻¹ := ih h₆ h₇
          have h₉ : Real.log x ≤ ∑ k ∈ Icc 1 (m + 1), (k : ℝ)⁻¹ := by
            calc
              Real.log x ≤ ∑ k ∈ Icc 1 m, (k : ℝ)⁻¹ := h₈
              _ ≤ ∑ k ∈ Icc 1 (m + 1), (k : ℝ)⁻¹ := by
                -- Show that the sum up to m + 1 is at least the sum up to m
                have h₁₀ : ∑ k ∈ Icc 1 m, (k : ℝ)⁻¹ ≤ ∑ k ∈ Icc 1 (m + 1), (k : ℝ)⁻¹ := by
                  apply Finset.sum_le_sum_of_subset_of_nonneg
                  · -- Show that Icc 1 m ⊆ Icc 1 (m + 1)
                    intro x hx
                    simp only [Finset.mem_Icc] at hx ⊢
                    omega
                  · -- Show that each term is non-negative
                    intro x _ _
                    positivity
                linarith
          exact h₉
      have h₁₀ : (n : ℝ) ≤ x := by exact_mod_cast hxge
      have h₁₁ : x < (n : ℝ) + 1 := by exact_mod_cast hxlt
      have h₁₂ : Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := h₅ n h₁₀ h₁₁
      exact h₁₂
    exact h₄
  exact h₁
