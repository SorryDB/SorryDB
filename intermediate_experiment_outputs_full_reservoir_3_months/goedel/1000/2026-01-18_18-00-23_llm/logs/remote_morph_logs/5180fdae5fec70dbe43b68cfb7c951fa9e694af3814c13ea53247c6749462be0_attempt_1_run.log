theorem dist_triangle_eq (a b c : ℝ) :
    abs (a - b) + abs (b - c) = abs (a - c) ↔ (b - a) * (b - c) ≤ 0 := by
  have h₁ : abs (a - b) + abs (b - c) = abs (a - c) ↔ (b - a) * (b - c) ≤ 0 := by
    constructor
    · -- Prove the forward direction: if |a - b| + |b - c| = |a - c|, then (b - a)(b - c) ≤ 0
      intro h
      have h₂ : (b - a) * (b - c) ≤ 0 := by
        -- Use the triangle inequality property to deduce the required inequality
        cases' le_total 0 (a - b) with hab hab <;>
        cases' le_total 0 (b - c) with hbc hbc <;>
        cases' le_total 0 (a - c) with hac hac <;>
        simp_all [abs_of_nonneg, abs_of_nonpos, le_of_lt, sub_nonneg, sub_nonpos] <;>
        (try { nlinarith }) <;>
        (try {
          nlinarith [sq_nonneg (b - a), sq_nonneg (b - c)]
        }) <;>
        (try {
          nlinarith [sq_nonneg (a - b), sq_nonneg (b - c)]
        })
      exact h₂
    · -- Prove the reverse direction: if (b - a)(b - c) ≤ 0, then |a - b| + |b - c| = |a - c|
      intro h
      have h₂ : abs (a - b) + abs (b - c) = abs (a - c) := by
        -- Consider cases based on the signs of (a - b) and (b - c)
        cases' le_total 0 (a - b) with hab hab <;>
        cases' le_total 0 (b - c) with hbc hbc <;>
        cases' le_total 0 (a - c) with hac hac <;>
        simp_all [abs_of_nonneg, abs_of_nonpos, le_of_lt, sub_nonneg, sub_nonpos] <;>
        (try { nlinarith }) <;>
        (try {
          nlinarith [sq_nonneg (b - a), sq_nonneg (b - c)]
        }) <;>
        (try {
          nlinarith [sq_nonneg (a - b), sq_nonneg (b - c)]
        })
      exact h₂
  exact h₁
