  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  have hB : ∀ N ∈ D, N = sSup (B N hN) := by
    intro N hN
    by_cases h : N = x ⊔ y
    · simp only [B, h]
      rw [iSup_insert]
      <;> simp_all [iSup_singleton]
      <;>
      (try
        simp_all [disjoint_iff_inf_eq_bot]
        <;>
        (try
          {
            aesop
          }))
      <;>
      (try
        {
          simp_all [iSup_singleton]
          <;>
          (try
            {
              aesop
            })
        })
    · simp only [B, h]
      simp_all [iSup_singleton]
      <;>
      (try
        {
          aesop
        })
  have hB' : ∀ N ∈ D, sSupIndep (B N hN) := by
    intro N hN
    by_cases h : N = x ⊔ y
    · simp only [B, h]
      refine' (by
        exact
          sSupIndep_pair
          (by
            intro hxy
            simp_all [hxy]
            <;>
            (try
              aesop)))
      <;>
      aesop
    · simp only [B, h]
      refine' (by
        exact
          sSupIndep_singleton
          (by
            simp_all [Set.mem_singleton_iff]
            <;>
            (try
              aesop)))
      <;>
      aesop
  have hB'' : ∀ N ∈ D, ⊥ ∉ B N hN := by
    intro N hN
    by_cases h : N = x ⊔ y
    · simp only [B, h]
      intro hxy
      simp_all [Set.mem_insert_iff, Set.mem_singleton_iff]
      <;>
      (try
        {
          simp_all [Disjoint]
          <;>
          (try
            {
              aesop
            })
        })
    · simp only [B, h]
      intro hxy
      simp_all [Set.mem_singleton_iff]
      <;>
      (try
        {
          aesop
        })
  set newD : DirectSumDecomposition M := refinement B hB hB' hB''
  <;>
  aesop
