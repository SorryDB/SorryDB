    (try { aesop })
  have hB'' : ∀ (N : PersistenceSubmodule M), N ∈ D → ⊥ ∉ (B N N ∈ D) := by
    intro N hN
    simp [B]
    <;>
    (try { contradiction }) <;>
    (try { simp_all [hN, hx, hy] }) <;>
    (try { aesop }) <;>
    (try { simp_all [Set.mem_insert_iff, Set.mem_singleton_iff] }) <;>
    (try { aesop })
  have newD : DirectSumDecomposition M := refinement
    B hB hB' hB''
