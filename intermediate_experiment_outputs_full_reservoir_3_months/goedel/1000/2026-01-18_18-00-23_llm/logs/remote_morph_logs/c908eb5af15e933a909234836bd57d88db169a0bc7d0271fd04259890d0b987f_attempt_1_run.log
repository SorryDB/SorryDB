    ∫ x in a..b, 1 / x + 1 / x ^ 2 =
  log b + 1 / a - log a - 1 / b := by
  have h_main : ∫ x in a..b, 1 / x + 1 / x ^ 2 = (log b - 1 / b) - (log a - 1 / a) := by sorry
  have h_final : (log b - 1 / b) - (log a - 1 / a) = log b + 1 / a - log a - 1 / b := by sorry
  sorry
