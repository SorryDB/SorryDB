example [Inhabited a] (ts : List (Tree a)) :
 spine (rollup ([Tree.leaf x] ++ ts)) = [Tree.leaf x] ++ ts := by
  induction ts with
  | nil =>
    simp [rollup, foldl1, spine]
  | cons t ts ih =>
    simp [rollup, foldl1, List.foldl]
    simp [rollup, foldl1] at ih
    simp_all [spine, List.append_assoc]
    <;>
    (try cases t <;> simp_all [spine, List.append_assoc]) <;>
    (try cases ts <;> simp_all [spine, List.append_assoc]) <;>
    (try simp_all [spine, List.append_assoc]) <;>
    (try omega) <;>
    (try ring_nf at * <;> simp_all [spine, List.append_assoc]) <;>
    (try aesop)
