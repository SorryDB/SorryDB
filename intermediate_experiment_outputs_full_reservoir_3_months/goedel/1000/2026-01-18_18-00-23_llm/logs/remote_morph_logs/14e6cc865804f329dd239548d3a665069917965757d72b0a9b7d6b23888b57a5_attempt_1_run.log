      simp only [Set.mem_iUnion, Set.mem_iUnion] at hx
      obtain ⟨N, hN, B', hB', hx⟩ := hx
      refine' ⟨N, hN, B', _⟩
      exact ⟨hx, Set.Subset.refl _⟩
    obtain ⟨N, hN, B', hB'_x, hB'_sub⟩ := h₁
    have h₂ : sSupIndep (B N hN) := hB' N hN
    have h₃ : x ∈ B N hN := hB'_sub hB'_x
    have h₄ : a ≤ x := ha
    have h₅ : a ≤ sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) := ha'
    have h₆ : a ≤ sSup (B N hN \ {x}) := by
      have h₇ : sSup (B N hN \ {x}) ≥ sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) := by
        apply sSup_le_sSup
        · intro y hy
          simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_iUnion, Set.mem_singleton_iff] at hy ⊢
          aesop
        · intro y hy
          simp only [Set.mem_diff, Set.mem_singleton_iff] at hy ⊢
          aesop
      have h₈ : a ≤ sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) := ha'
      calc
        a ≤ sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) := h₈
        _ ≤ sSup (B N hN \ {x}) := h₇
    have h₉ : a ≤ ⊥ := by
      have h₁₀ : Disjoint x (sSup (B N hN \ {x})) := by
        exact (h₂.disjoint_sSup h₃)
      have h₁₁ : a ≤ x := ha
      have h₁₂ : a ≤ sSup (B N hN \ {x}) := h₆
      have h₁₃ : Disjoint a (a : ⊤) := by
        exact Disjoint.trans (Disjoint.of_le_right (h₁₁.trans_le (le_sSup (by aesop : x ∈ sSup (B N hN \ {x})))) h₁₀) (by simp [disjoint_rfl])
      have h₁₄ : a ≤ ⊥ := by
        by_contra h
        have h₁₅ : a ≠ ⊥ := h
        have h₁₆ : ⊥ < a := by
          exact lt_of_not_le_of_bot_lt h₁₅ (bot_lt_iff_ne_bot.mpr h₁₅)
        have h₁₇ : Disjoint a a := by
          simpa [disjoint_self] using h₁₃
        have h₁₈ : (a : ⊤) ≤ ⊥ := by
          have h₁₉ : Disjoint a a := h₁₇
          have h₂₀ : a = ⊥ := by
            simpa [disjoint_self] using h₁₉
          simp [h₂₀]
        exact not_lt_of_le (by simpa using h₁₈) h₁₆
      exact h₁₄
