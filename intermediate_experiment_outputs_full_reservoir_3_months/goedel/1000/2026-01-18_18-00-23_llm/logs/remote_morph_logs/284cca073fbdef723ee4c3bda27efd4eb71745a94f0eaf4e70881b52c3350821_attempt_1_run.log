-- exercise 1.3.i
-- the answer to what is a group homomorphism, but you need to
-- provide the proof.
theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, @CategoryInContext.Functor.homF Unit Unit (Category.Monoid α) (Category.Monoid β) F () () x = f x := by
  classical
  -- Extract the underlying function from the monoid morphism
  have hf : ∀ (x : α), @CategoryInContext.Functor.homF Unit Unit (Category.Monoid α) (Category.Monoid β) F () () x = F.homF (down (x : α)) := by
    intro x
    simp [F, CategoryInContext.Functor]
    <;> aesop
  
  -- Define the group homomorphism using the monoid homomorphism
  use {
    toFun := fun x => F.homF (down (x : α))
    map_one' := by
      have h₁ := congr_arg (fun f => F.homF f) (MonoidHom.map_one (F := fun x => F.homF (down (x : α))))
      simp [hf] at h₁ ⊢
      <;> aesop
    map_mul' := by
      intro x y
      have h₁ := congr_arg (fun f => F.homF f) (MonoidHom.map_mul (F := fun x => F.homF (down (x : α))))
      simp [hf] at h₁ ⊢
      <;> aesop
  }
  <;> simp_all [hf]
  <;> aesop
