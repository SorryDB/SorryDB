theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  use {
    toFun := fun x => F.homF x,
    map_one' := by
      have h₁ := F.map_id ()
      simp [Category.Monoid.id] at h₁ ⊢
      <;> simpa using h₁
    map_mul' := by
      intro x y
      have h₂ := F.map_comp (x : MonoidHom α α) (y : MonoidHom α α)
      simp [MonoidHom.mul_apply] at h₂ ⊢
      <;> simpa using h₂
  }
  intro x
  <;> simp
```
