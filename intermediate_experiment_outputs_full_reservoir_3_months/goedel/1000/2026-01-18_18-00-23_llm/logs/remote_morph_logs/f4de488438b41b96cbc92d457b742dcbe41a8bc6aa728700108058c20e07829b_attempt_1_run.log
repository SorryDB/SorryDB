                -- Use the property of valuations under ring isomorphisms
                simp_all [RingEquiv.map_inv, RingEquiv.val_inv]
                <;>
                (try simp_all [RingEquiv.map_inv, RingEquiv.val_inv]) <;>
                (try simp_all [RingEquiv.map_inv, RingEquiv.val_inv]) <;>
                (try simp_all [RingEquiv.map_inv, RingEquiv.val_inv])
                <;>
