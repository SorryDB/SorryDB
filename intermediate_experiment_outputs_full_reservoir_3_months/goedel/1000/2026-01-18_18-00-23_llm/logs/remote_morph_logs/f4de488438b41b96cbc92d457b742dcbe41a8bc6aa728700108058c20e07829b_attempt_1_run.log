```lean
instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      have h₁ : r.1 = (1 : K) := by
        have h₂ : (r : K) = 1 := by
          cases r with
          | mk x hx =>
            simp_all [Subtype.ext_iff]
            <;> aesop
        simp_all [Subtype.ext_iff]
      rw [h₁]
      have h₂ : valuation L ((1 : K) • (1 : L)) ≤ 1 := by
        simpa [smul_one] using (valuation.map_one L)
      simp_all [smul_one]
      <;>
      (try norm_num) <;>
      (try
        {
          simp_all [ValuativeRel.le_one_iff]
          <;> aesop
        }) <;>
      (try
        {
          simp_all [val_one]
          <;> norm_num
          <;> aesop
        }) <;>
      (try
        {
          simp_all [le_refl]
          <;> aesop
        })
    ⟩
    map_add' := by
      intro r s
      simp [AddSemigroupHom.map_add]
      <;>
      (try simp_all [Subtype.ext_iff])
      <;>
      (try aesop)
    map_one' := by
      simp [AddSemigroupHom.map_add]
      <;>
