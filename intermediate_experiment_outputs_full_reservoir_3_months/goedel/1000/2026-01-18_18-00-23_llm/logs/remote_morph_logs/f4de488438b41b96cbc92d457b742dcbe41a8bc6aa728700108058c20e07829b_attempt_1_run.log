instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      rw [Valuation.mem_integer_iff] at hr ⊢
      have h₁ : valuation L (algebraMap K L (1 : K)) ≤ 0 := by
        have h₂ : valuation L (algebraMap K L (1 : K)) = valuation K (1 : K) := by
          have h₃ : valuation L (algebraMap K L (1 : K)) = valuation K (1 : K) := by
            apply ValuativeExtension.valuation.map_one
          exact h₃
        rw [h₂]
        simp [val_one]
      simp_all [val_one]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try ring_nf at *) <;>
      (try simp_all [val_one]) <;>
      (try norm_num) <;>
      (try linarith)
      ⟩
    map_add' := by
      intro r s
      simp [AddMonoidHom.map_add]
      <;>
      (try simp_all [Subtype.ext_iff]) <;>
      (try ring_nf) <;>
      (try simp_all [algebraMap_add]) <;>
      (try norm_num) <;>
      (try linarith)
    map_one' := by
      simp [one_mul]
      <;>
      (try simp_all [Subtype.ext_iff]) <;>
      (try ring_nf) <;>
      (try simp_all [algebraMap_one]) <;>
      (try norm_num) <;>
      (try linarith)
  }
