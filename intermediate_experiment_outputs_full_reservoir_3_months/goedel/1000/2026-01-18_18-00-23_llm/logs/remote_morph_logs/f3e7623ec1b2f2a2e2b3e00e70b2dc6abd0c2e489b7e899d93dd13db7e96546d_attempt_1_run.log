example (a b : ℝ) (ha : 0 < a) (hb : 0 < b) :
    ∫ x in a..b, 1 / x + 1 / x ^ 2 =
  log b + 1 / a - log a - 1 / b := by
  have : 0 ∉ uIcc a b := by
    intro h
    simp only [uIcc, Set.mem_setOf_eq] at h
    -- Since a and b are positive, the interval [a, b] or [b, a] does not contain 0.
    cases' le_total a b with hab hab <;> simp_all [hab, le_of_lt]
    <;> nlinarith
