def C (u v : Fin 3 → Bool) : ℕ :=
  ∑ i : Fin 3, if u i = v i then 1 else 0

@[simp]
lemma C_sum (u v : Fin 3 → Bool) : C u v + C u v = 2 * C u v := by
  ring

@[simp]
lemma C_sum' (u v : Fin 3 → Bool) : C u v + C u v = 2 * C u v := by
  ring

@[simp]
lemma C_sum'' (u v : Fin 3 → Bool) : C u v + C u v = 2 * C u v := by
  ring
