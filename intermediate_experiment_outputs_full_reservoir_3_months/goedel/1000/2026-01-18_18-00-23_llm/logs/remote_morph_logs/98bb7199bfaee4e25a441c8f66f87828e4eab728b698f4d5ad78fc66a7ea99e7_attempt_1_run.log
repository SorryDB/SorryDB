def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, by simp [IsMatching], by simp⟩
  indep_subset := by
    intro I J hJ hI
    obtain ⟨M, hM, hJ⟩ := hJ
    refine ⟨M, hM, _⟩
    exact hJ.mono hI
```
