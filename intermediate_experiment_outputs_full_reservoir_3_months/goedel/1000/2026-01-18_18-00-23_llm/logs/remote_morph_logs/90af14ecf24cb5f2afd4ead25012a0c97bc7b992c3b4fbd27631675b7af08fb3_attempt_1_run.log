    -- We will use induction on k to prove the statement.
    have h : ∀ (k : ℕ), FreeImageOf (insert 0 (univ : Finset ℕ)) k = imageOf (insert 0 (univ : Finset ℕ)) k := by
      intro k
      -- Base case: when k = 0
      induction k with
      | zero =>
        -- For k = 0, the sets are trivially equal.
        simp [FreeImageOf, imageOf]
      | succ k ih =>
        -- Inductive step: assume the statement holds for k, prove for k + 1.
        simp_all [FreeImageOf, imageOf, Finset.ext_iff, Finset.mem_image, Finset.mem_union]
        <;>
          (try decide) <;>
          (try
            {
