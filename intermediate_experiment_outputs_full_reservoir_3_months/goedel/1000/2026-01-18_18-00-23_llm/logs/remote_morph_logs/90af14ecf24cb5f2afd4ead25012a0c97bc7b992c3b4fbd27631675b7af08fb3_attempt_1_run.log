              intros n
              have h₁ : n ≤ k ∨ n = k + 1 := by
                by_cases h : n ≤ k
                · exact Or.inl h
                · have h₂ : n = k + 1 := by
                    omega
                  exact Or.inr h₂
              cases h₁ with
              | inl h₁ =>
                -- Case: n ≤ k
                simp_all [Finset.mem_image]
                <;>
                  (try omega) <;>
                  (try
                    {
