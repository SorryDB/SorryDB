theorem collectDerivationTreeNodes
    {α : Type}
    {nt : Type}
    [DecidableEq α] [DecidableEq nt]
    {G : ContextFreeGrammar α nt}
    {u v : Word ({x // x ∈ G.V} ⊕ {x // x ∈ G.Z})}
    (cfd : ContextFreeDerivation α nt G u v)
    (h_not_same : u ≠ v)
    :
    ∃ (t : DerivationTree G),
      ∃ (l : List (DerivationTree G)),
      u = wordOf t ∧
      List.of (List.map wordOf l) = v.toList ∧
      List.all (List.map (fun t : DerivationTree G => t.positive) l) = true =
      true ∧
      l.length = cfd.length-1 := by
  have h₁ : u ≠ v := h_not_same
  have h₂ : cfd.length ≥ 1 := by
    by_contra h
    have h₃ : cfd.length = 0 := by
      omega
    have h₄ : u = v := by
      have h₅ : cfd.length = 0 := h₃
      have h₆ : cfd = ContextFreeDerivation.nil := by
        rw [h₅] at cfd
        <;> cases cfd <;> simp_all [ContextFreeDerivation.length]
        <;> aesop
      rw [h₆] at *
      simp [ContextFreeDerivation.nil] at *
      <;> aesop
    contradiction
  -- Use the first step of the derivation to get the root node
  have h₃ : ∃ (d : Derivation G), cfd = (ContextFreeDerivation.step d) := by
    have h₄ : cfd.length ≥ 1 := h₂
    have h₅ : ∃ (d : Derivation G), cfd = (ContextFreeDerivation.step d) := by
      cases cfd with
      | nil => contradiction
      | step d => exact ⟨d, rfl⟩
    exact h₅
  obtain ⟨d, hd⟩ := h₃
  have h₄ : u = d.prod.val.lhs := by
    have h₅ := d.prod.val
    simp_all [ContextFreeDerivation.step, ContextFreeDerivation.length, Derivation.length]
    <;>
    (try omega) <;>
    (try aesop) <;>
    (try simp_all [ContextFreeDerivation.step, ContextFreeDerivation.length, Derivation.length]) <;>
