  · intro i
    simp [Circuit.eval]
    <;> simp_all [eq0, share, is_zero, assert_range, accept]
    <;> aesop
  · intro i
    simp [Circuit.eval]
    <;> simp_all [eq0, share, is_zero, assert_range, accept]
    <;> aesop

end Example_base

end Clap
