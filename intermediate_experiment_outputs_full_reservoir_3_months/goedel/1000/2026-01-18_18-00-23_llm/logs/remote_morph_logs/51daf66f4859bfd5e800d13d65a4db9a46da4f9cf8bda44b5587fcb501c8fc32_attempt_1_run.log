lemma IsBernoulliOn.inter (hX : IsBernoulliOn X u p P) (hY : IsBernoulliOn Y u q P) :
    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  map_eq := sorry
  aemeasurable := by
    have hX' : AEMeasurable X P := by
      have := hX.ae_stronglyMeasurable
      simpa [stronglyMeasurable_def] using this
    have hY' : AEMeasurable Y P := by
      have := hY.ae_stronglyMeasurable
      simpa [stronglyMeasurable_def] using this
    have : AEMeasurable (fun ω => X ω ∩ Y ω) P := by
      have : StronglyMeasurable (fun ω => (X ω, Y ω)) P := by
        -- Prove that the map ω ↦ (X ω, Y ω) is strongly measurable
        exact ⟨fun i ↦ i.fst, fun i ↦ i.snd,
          (hX'.of_sufficient i.measurable₁).to_stronglyMeasurable,
          (hY'.of_sufficient i.measurable₂).to_stronglyMeasurable⟩
      -- Since (X ω, Y ω) is strongly measurable, their intersection is measurable
      have : StronglyMeasurable (fun ω => (X ω, Y ω)) P :=
        ‹_›
      -- Use the fact that the intersection of two measurable sets is measurable
      have : AEMeasurable (fun ω => X ω ∩ Y ω) P := by
        -- Use the fact that the intersection of two measurable sets is measurable
        have : StronglyMeasurable (fun ω => (X ω, Y ω)) P := ‹_›
        -- Use the fact that the intersection of two measurable sets is measurable
        have : AEMeasurable (fun ω => X ω ∩ Y ω) P :=
          (this.map (Prod.measurableClosure (measurableSet_inter : MeasurableSet (· ∩ · : Set ι → Set ι → Set ι))).to_aeMeasurable)
          |>.congr (by
            -- Use the fact that the intersection of two measurable sets is measurable
            simp [Set.inter_def]
            <;> congr 1
            <;> ext <;> simp [Prod.mem_image, exists_prop]
            <;>
              (try
                {
                  intros
                  simp_all [Set.ext_iff]
                  <;>
                    tauto
                })
            <;>
              tauto
          )
        exact this
      exact this
    exact this
