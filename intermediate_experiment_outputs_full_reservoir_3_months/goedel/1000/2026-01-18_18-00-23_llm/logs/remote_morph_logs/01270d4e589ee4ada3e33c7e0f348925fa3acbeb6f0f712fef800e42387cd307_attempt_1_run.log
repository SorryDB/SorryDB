    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x : α | p x} ∈ 𝓝 x := hT
  have h₂ : {x : α | q x} ∈ 𝓝 x := hS
  have h₃ : {x : α | p' x} ∈ 𝓝 x := hT'
  have h₄ : {x : α | q' x} ∈ 𝓝 x := hS'
  have h₅ : {x : α | p x ∧ q x} ∈ 𝓝 x := by
    -- The intersection of {x | p x} and {x | q x} is in the neighborhood filter
    have h₅₁ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      -- Since both sets are in the neighborhood filter, their intersection is as well
      have h₅₂ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
        exact (h₁.inter_mem h₂)
      exact h₅₂
    -- The set {x | p x ∧ q x} is the same as {x | p x} ∩ {x | q x}
    have h₅₃ : {x : α | p x ∧ q x} = {x : α | p x} ∩ {x : α | q x} := by
      ext x
      simp [and_imp]
      <;> tauto
    -- Therefore, {x | p x ∧ q x} is in the neighborhood filter
    rw [h₅₃] at *
    exact h₅₁
  have h₆ : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    -- Similarly, {x | p' x ∧ q' x} is in the neighborhood filter
    have h₆₁ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      exact (h₃.inter_mem h₄)
    have h₆₂ : {x : α | p' x ∧ q' x} = {x : α | p' x} ∩ {x : α | q' x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h₆₂] at *
    exact h₆₁
  -- The union of {x | p x ∧ q x} and {x | p' x ∧ q' x} is in the neighborhood filter
  have h₇ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₇₁ : {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
      -- Since both sets are in the neighborhood filter, their union is as well
      exact (h₅.union_mem h₆)
