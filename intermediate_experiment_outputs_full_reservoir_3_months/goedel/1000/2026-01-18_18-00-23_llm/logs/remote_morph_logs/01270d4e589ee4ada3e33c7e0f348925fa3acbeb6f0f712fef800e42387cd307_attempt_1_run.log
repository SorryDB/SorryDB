def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : (F.map s).map t ≤ H := by
    -- Since Tendsto s F G means F.map s ≤ G, and Tendsto t G H means G.map t ≤ H, we can compose these inequalities.
    calc
      (F.map s).map t = F.map (t ∘ s) := by rw [Filter.map_map]
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G implies F.map (t ∘ s) ≤ G.map t
        have h2 : F.map s ≤ G := hs
        have h3 : F.map (t ∘ s) = (F.map s).map t := by rw [Filter.map_map]
        have h4 : (F.map s).map t ≤ G.map t := Filter.map_mono h2
        simpa [h3] using h4
      _ ≤ H := ht
  -- Since (F.map s).map t ≤ H, we have Tendsto (t ∘ s) F H
  simpa [Filter.map_map] using h1

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    apply Tendsto_comp
    · exact hf
    · exact hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    apply Tendsto_comp
    · exact ha
    · exact hφ
  exact h

