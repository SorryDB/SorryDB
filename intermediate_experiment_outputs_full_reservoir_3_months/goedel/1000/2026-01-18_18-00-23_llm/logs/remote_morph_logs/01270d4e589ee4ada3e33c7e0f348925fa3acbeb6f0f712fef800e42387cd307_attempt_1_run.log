lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have h₁ : F.map f ≤ G.map f := by
    -- Use the fact that the map of a filter is monotone with respect to the filter's order
    exact Filter.map_mono h
  -- Since hs : s ∈ F.map f, and F.map f ≤ G.map f, we have s ∈ G.map f
  exact h₁ hs

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h₁ : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        -- Since F.map s ≤ G (by hs : Tendsto s F G), we have (F.map s).map t ≤ G.map t
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since G.map t ≤ H (by ht : Tendsto t G H), we have G.map t ≤ H
        exact ht
  -- Therefore, Tendsto (t ∘ s) F H holds
  exact h₁

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the composition of tendsto to show that (g ∘ f) tends to atTop along 𝓝 0
    have h₁ : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h₂ : Tendsto g (𝓝 Real.pi) atTop := hg
    -- Apply the composition of tendsto
