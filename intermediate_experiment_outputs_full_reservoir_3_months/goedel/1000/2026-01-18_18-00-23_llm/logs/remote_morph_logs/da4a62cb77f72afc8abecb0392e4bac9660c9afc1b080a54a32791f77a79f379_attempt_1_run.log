@[sorryful]
lemma tendsto_sin_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h₁ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (r * Real.cos (r * 0)) 0 := by
      have h₂ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (Real.cos (r * 0) * r) 0 := by
        -- Use the chain rule to find the derivative of sin(r * x)
        have h₃ : HasDerivAt (fun x : ℝ => r * x) r 0 := by
          simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
        have h₄ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (Real.cos (r * 0) * r) 0 := by
          -- Apply the chain rule
          have h₅ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (Real.cos (r * 0) * r) 0 := by
            -- Use the chain rule for sin and r * x
            simpa using (Real.hasDerivAt_sin (r * (0 : ℝ))).comp 0 h₃
          exact h₅
        exact h₄
      convert h₂ using 1 <;> ring_nf <;> simp [Real.cos_zero]
    have h₃ : (fun x : ℝ => Real.sin (r * x) / x) = (fun x : ℝ => (Real.sin (r * x) - Real.sin (r * (0 : ℝ))) / (x - (0 : ℝ))) := by
      funext x
      by_cases hx : x = 0
      · -- If x = 0, the expression is undefined, but we can use the definition of the derivative
        simp_all
        <;>
        field_simp <;>
        ring_nf <;>
        simp_all [Real.sin_zero]
        <;>
        norm_num
        <;>
        linarith
      · -- If x ≠ 0, simplify the expression
        field_simp [hx, sub_eq_zero, Real.sin_zero]
        <;>
        ring_nf
        <;>
        simp_all [Real.sin_zero]
        <;>
        linarith
    rw [h₃]
    have h₄ : Tendsto (fun x : ℝ => (Real.sin (r * x) - Real.sin (r * (0 : ℝ))) / (x - (0 : ℝ))) (𝓝[≠] 0) (𝓝 (r * Real.cos (r * 0))) := by
      have h₅ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (r * Real.cos (r * 0)) 0 := h₁
      have h₆ : Tendsto (fun x : ℝ => (Real.sin (r * x) - Real.sin (r * (0 : ℝ))) / (x - (0 : ℝ))) (𝓝[≠] 0) (𝓝 (r * Real.cos (r * 0))) := by
        convert h₅.tendsto_slope_zero using 1
        <;>
        simp [sub_eq_add_neg]
        <;>
        field_simp [sub_eq_add_neg]
        <;>
        ring_nf
        <;>
        norm_num
        <;>
        simp_all [Real.sin_zero]
        <;>
        linarith
      exact h₆
    have h₇ : (r * Real.cos (r * 0) : ℝ) = r := by
      have h₈ : Real.cos (r * 0) = 1 := by
        simp [Real.cos_zero]
      rw [h₈]
      <;>
      ring
    have h₈ : Tendsto (fun x : ℝ => (Real.sin (r * x) - Real.sin (r * (0 : ℝ))) / (x - (0 : ℝ))) (𝓝[≠] 0) (𝓝 r) := by
      convert h₄ using 1
      <;>
      simp [h₇]
    exact h₈
