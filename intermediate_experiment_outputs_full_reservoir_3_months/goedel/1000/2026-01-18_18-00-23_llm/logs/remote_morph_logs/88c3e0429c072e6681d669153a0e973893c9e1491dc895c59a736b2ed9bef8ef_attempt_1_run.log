      obtain ⟨n, hn⟩ := h
      have h₁ : π ∈ ⋃ n : ℕ, s n := by
        exact Set.mem_iUnion.mpr ⟨n, hn⟩
      have h₂ : ⋃ n : ℕ, s n = (⋃ n : ℕ, s n) := rfl
