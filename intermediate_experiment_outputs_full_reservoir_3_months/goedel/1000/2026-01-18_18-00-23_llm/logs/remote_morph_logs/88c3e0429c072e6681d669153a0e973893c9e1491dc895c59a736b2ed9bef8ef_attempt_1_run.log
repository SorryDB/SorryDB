/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun S => if Real.pi ∈ S then 1 else 0
  empty := by
    simp [μD]
  mono {S T} hST := by
    by_cases h : Real.pi ∈ S
    · -- Case: π ∈ S
      have h₁ : Real.pi ∈ T := hST h
      simp_all [μD]
      <;> norm_num
    · -- Case: π ∉ S
