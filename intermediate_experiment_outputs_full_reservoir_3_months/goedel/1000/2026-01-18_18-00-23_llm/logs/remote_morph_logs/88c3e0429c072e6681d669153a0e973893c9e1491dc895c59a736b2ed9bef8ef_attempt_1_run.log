  iUnion_nat := by
    by_cases h : Real.pi ∈ ⋃ n : ℕ, ( ({n} : Set ℝ) : Set ℝ )
    · -- Case: π ∈ ⋃ₙ {n}
      have h₁ : ∃ n : ℕ, Real.pi ∈ ({n} : Set ℝ) := by
        simpa using h
      obtain ⟨n, hn⟩ := h₁
      have h₂ : Real.pi = (n : ℝ) := by
