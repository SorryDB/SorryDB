      <;>
      (try
        {
          simp_all [Set.subset_def]
          <;> aesop
        })
      <;>
      (try
        {
          simp_all [Set.subset_def]
          <;> aesop
        })
      <;>
      (try
        {
          simp_all [Set.subset_def]
          <;> aesop
        })

