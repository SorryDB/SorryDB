  norm_num [a, fermatNumber,Nat.log2_eq_log_two]

@[category test, AMS 11]
theorem six : a 6 = 46 := by
  norm_num [a, fermatNumber, Nat.log2_eq_log_two]
  <;>
  rfl

@[category test, AMS 11]
