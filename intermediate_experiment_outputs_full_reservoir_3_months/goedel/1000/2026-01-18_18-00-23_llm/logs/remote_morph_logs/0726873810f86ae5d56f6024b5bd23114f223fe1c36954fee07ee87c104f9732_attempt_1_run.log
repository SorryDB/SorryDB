  F X := Set X
  homF {X Y : Type} (f : X → Y) : Set X → Set Y := Set.image f
  map_id X := by
    funext s
    simp [Set.image_id]
  map_comp {X Y Z : Type} (f : X → Y) (g : Y → Z) :=
    funext (fun s => by
