theorem eq_affineCombination_of_mem_affineSpan_of_fintype [Nontrivial k] {ι : Type*} [Fintype ι]
    (hp : (Finset.affineCombination k Finset.univ p w) ∈ affineSpan k (p '' Set.univ)) :
