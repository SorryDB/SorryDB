theorem result {n : ℕ+} :
    IsLeast {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} (answer n) := by
  have h₁ : answer n ∈ {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} := by
    have h₂ : ∃ ns : NordicSquare n, #ns.UphillPath = answer n := by
      use Classical.choice (⟨1, 123⟩)
      <;> simp_all [NordicSquare, Cell]
      <;> try decide
      <;> try contradiction
      <;> try norm_num
      <;> try aesop
      <;> try ring_nf
      <;> try simp_all [Fin.ext_iff]
      <;> try omega
      <;> try linarith
    obtain ⟨ns, hns⟩ := h₂
    have h₃ : answer n ∈ {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} := by
      refine' ⟨ns, _⟩
      <;> simp_all
    exact h₃
  have h₂ : ∀ k' ∈ {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k}, answer n ≤ k' := by
    intro k' hk'
    have h₃ : ∃ ns : NordicSquare n, #ns.UphillPath = k' := by
      exact hk'
    obtain ⟨ns, hns⟩ := h₃
    have h₄ : answer n ≤ k' := by
      have h₅ : answer n ≤ k' := by
        if h₆ : answer n ≤ k' then
          exact h₆
        else
          exfalso
          have h₇ : k' < answer n := by
            omega
          have h₈ : answer n ≤ k' := by
            if h₉ : answer n ≤ k' then
              exact h₉
            else
              exfalso
              have h₁₀ : k' < answer n := by
                omega
              simp_all [answer]
          omega
      exact h₅
    exact h₄
  exact ⟨h₁, h₂⟩
