  have h₂ : x ∈ V(G, M ∆ E(P)) := by
    have h₃ : x ∈ V(G) := by
      exact V(G)(h₁)
    have h₄ : x ∈ M.biconditional (E(P)).compl := by
      -- We need to show that if x is in M, then it is not in E(P), and vice versa.
      -- But since we are considering the symmetric difference, we can directly conclude that x is in the symmetric difference.
      simp_all [V, Set.mem_setOf_eq, Set.mem_diff, Set.mem_compl_iff]
