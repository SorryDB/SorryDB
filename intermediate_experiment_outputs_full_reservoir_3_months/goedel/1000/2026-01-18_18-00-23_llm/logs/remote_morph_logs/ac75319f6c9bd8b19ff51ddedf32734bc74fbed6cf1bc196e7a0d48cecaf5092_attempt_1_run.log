lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, symmDiff M P.edgeSet) := by
  obtain ⟨hAP, nonempty, hfirst, hlast⟩ := h
  have h₁ : V(G, M) ⊆ V(G, symmDiff M P.edgeSet) := by
    intro x hx
    simp only [Set.mem_setOf_eq, Set.mem_diff, V_singleton_ite] at hx ⊢
    by_cases h₂ : x ∈ V(G, P.edgeSet)
    · -- Case: x ∈ V(G, P.edgeSet)
      have h₃ : x ∈ V(G, M ∆ P.edgeSet) := by
        simp_all [symmDiff]
        <;>
        (try contradiction) <;>
        (try aesop) <;>
        (try
          {
            have h₄ := hAP.mem_chain
            have h₅ := hAP.isTrail
            have h₆ := hAP.vertexDistinct
            simp_all [WList.mem_edgeSet, WList.mem_vertex, WList.mem_edgeSet]
            <;>
            aesop
          })
        <;>
        aesop
      exact h₃
    · -- Case: x ∉ V(G, P.edgeSet)
      have h₃ : x ∈ V(G, M ∆ P.edgeSet) := by
        simp_all [symmDiff]
        <;>
        (try contradiction) <;>
        (try aesop)
      exact h₃
  exact h₁
```
