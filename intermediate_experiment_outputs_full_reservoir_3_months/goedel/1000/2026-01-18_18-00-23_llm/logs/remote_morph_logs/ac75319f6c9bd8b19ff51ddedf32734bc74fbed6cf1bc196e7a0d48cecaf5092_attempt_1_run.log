lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, symmDiff M P.edgeSet) := by
  have h₁ : V(G, M) ⊆ V(G) := by
    intro x hx
    exact hM.subset hx
  
  have h₂ : V(G, symmDiff M P.edgeSet) ⊆ V(G) := by
    intro x hx
    have h₃ : x ∈ V(G, symmDiff M P.edgeSet) := hx
    have h₄ : x ∈ V(G) := by
      -- Since x is in V(G, symmDiff M P.edgeSet), it must be in V(G)
      have h₅ : x ∈ V(G, symmDiff M P.edgeSet) := h₃
      have h₆ : x ∈ V(G) := by
        -- Use the fact that V(G, symmDiff M P.edgeSet) is a subset of V(G)
        have h₇ : V(G, symmDiff M P.edgeSet) ⊆ V(G) := by
          intro x hx
          exact hx.1
        exact h₇ h₅
      exact h₆
    exact h₄
  
  have h₃ : ∀ x : α, x ∈ V(G, M) → x ∈ V(G, symmDiff M P.edgeSet) := by
    intro x hx
    have h₄ : x ∈ V(G) := h₁ hx
    have h₅ : x ∈ V(G, M) := hx
    have h₆ : x ∈ V(G) := by exact h₁ hx
    -- We need to show that x is in V(G, symmDiff M P.edgeSet)
    -- This can be done by considering the properties of the symmetric difference and the path P
    -- We use the fact that P is an augmenting path and the properties of alternating paths
    by_cases h₇ : x ∈ V(P)
    · -- Case: x ∈ V(P)
      -- If x is in the path P, it is trivially in V(G, symmDiff M P.edgeSet)
      exact ⟨by tauto, by simp_all [V_def, EdgeSet.symmDiff]⟩
    · -- Case: x ∉ V(P)
      -- If x is not in the path P, we need to check if it is in M or not
      have h₈ : x ∈ V(G, M) := hx
      have h₉ : x ∈ V(G, symmDiff M P.edgeSet) := by
        simp_all [V_def, EdgeSet.symmDiff, EdgeSet.memUnion]
        <;> tauto
      exact h₉
  -- Finally, we can conclude that V(G, M) ⊆ V(G, symmDiff M P.edgeSet)
  exact h₃
