lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  refine' Set.Subset.mono (by rw [Set.ext_iff]; intro x; simp [hM.subset, h.toIsMatching.subset]) _
  -- We need to show that V(G, M ∆ E(P)) is a superset of V(G, M).
  -- Since M ∆ E(P) contains M \ E(P) and E(P) \ M, and V(G, M ∆ E(P)) includes all vertices of M and E(P),
  -- it is sufficient to show that V(G, M) is a subset of V(G, M ∆ E(P)).

