          simp_all [Set.mem_diff, Set.mem_compl_iff]
          <;> aesop
        }) <;>
      (try
        {
          -- If x is not in M, then we need to show that it is in E(P).
          -- But we already have that x is not in M and is in E(P).
          simp_all [Set.mem_diff, Set.mem_compl_iff]
          <;> aesop
        }) <;>
      (try
        {
          -- If x is in M and E(P), then it is not in the symmetric difference.
          -- But we need to show that x is in the symmetric difference, so we have a contradiction.
          simp_all [Set.mem_diff, Set.mem_compl_iff]
          <;> aesop
        }) <;>
      (try
        {
          -- If x is not in M and not in E(P), then it is in the symmetric difference.
          simp_all [Set.mem_diff, Set.mem_compl_iff]
          <;> aesop
        })
    -- Since x is in M and not in E(P), it is in the symmetric difference.
    simp_all [V, Set.mem_setOf_eq, Set.mem_diff, Set.mem_compl_iff]
    <;>
    (try contradiction) <;>
    (try aesop) <;>
    (try
      {
        simp_all [Set.mem_diff, Set.mem_compl_iff]
        <;> aesop
      })
  exact h₂
