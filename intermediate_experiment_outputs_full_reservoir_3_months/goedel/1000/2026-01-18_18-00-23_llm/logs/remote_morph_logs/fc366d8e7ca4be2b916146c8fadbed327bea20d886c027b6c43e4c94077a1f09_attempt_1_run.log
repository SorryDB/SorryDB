theorem FReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ FReal t := by
  have h₁ : DifferentiableAt ℝ (fun t => (F.resToImagAxis t).re) t := by
    -- Use the fact that F is holomorphic and the composition of differentiable functions is differentiable
    have h₂ : MDifferentiable 𝓝[t] 𝓝 (F.resToImagAxis : ℝ → ℂ) := by
      -- F is holomorphic, and the restriction to the imaginary axis is smooth
      apply F_holo.continuous.continuousOn.differentiableAt
      intro z hz
      -- z is in a neighborhood of t on the imaginary axis
      simp_all [Complex.ext_iff, Real.dist_eq]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try
        {
          use z.2 - t
          <;>
          simp_all [Complex.ext_iff, Real.dist_eq]
          <;>
          ring_nf
          <;>
          norm_num
          <;>
          linarith
        }) <;>
      (try
        {
          use t - z.2
          <;>
          simp_all [Complex.ext_iff, Real.dist_eq]
          <;>
          ring_nf
          <;>
          norm_num
          <;>
          linarith
        })
    -- The real part of a differentiable complex function is differentiable
    have h₃ : DifferentiableAt ℝ (fun t => (F.resToImagAxis t).re) t := by
      have h₄ : DifferentiableAt ℂ (F.resToImagAxis : ℝ → ℂ) t := by
        apply h₂.differentiableAt
      -- The real part of a complex differentiable function is real differentiable
      have h₅ : DifferentiableAt ℝ (fun t => (F.resToImagAxis t).re) t := by
        apply DifferentiableAt.comp (differentiableAt_id : DifferentiableAt ℝ (fun t : ℝ => t) t)
        apply DifferentiableAt.re
        exact h₄
      exact h₅
    exact h₃
  -- Since FReal is defined as the real part of F.resToImagAxis, it is differentiable
  have h₂ : FReal = (fun t => (F.resToImagAxis t).re) := by
    funext t
    simp [FReal]
  rw [h₂]
  exact h₁

