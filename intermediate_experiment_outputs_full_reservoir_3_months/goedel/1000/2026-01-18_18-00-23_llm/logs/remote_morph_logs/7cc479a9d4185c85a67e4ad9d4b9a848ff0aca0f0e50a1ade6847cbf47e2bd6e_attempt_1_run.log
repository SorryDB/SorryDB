```lean
namespace LessEqThan
def circuit (n : ‚Ñï) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ‚àß y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp_all only [circuit_norm, LessThan.circuit, Prod.mk.injEq]
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_holds
    by_cases hy : y.val + 1 = 2^n
    case neg =>
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]
      <;>
      (try omega) <;>
      (try {
        simp_all [Nat.le_of_lt_succ, Nat.succ_le_iff]
        <;>
        omega
      }) <;>
      (try {
        simp_all [Nat.le_of_lt_succ, Nat.succ_le_iff]
        <;>
        omega
      })
    case pos =>
      have h‚ÇÅ : ZMod.val x < 2 ^ n := assumptions.1
      have h‚ÇÇ : ZMod.val y < 2 ^ n := assumptions.2
      have h‚ÇÉ : y.val + 1 = 2 ^ n := hy
      have h‚ÇÑ : ZMod.val y + 1 = 2 ^ n := by
        simp [ZMod.val_one] at h‚ÇÉ ‚ä¢
        <;>
        (try omega) <;>
        (try simp_all [ZMod.val_one]) <;>
        (try omega)
      have h‚ÇÖ : ZMod.val x < y.val + 1 := by
        omega
      have h‚ÇÜ : ZMod.val x < 2 ^ n := assumptions.1
      have h‚Çá : ZMod.val y + 1 = 2 ^ n := by
        simp [ZMod.val_one] at h‚ÇÉ ‚ä¢
        <;>
        (try omega) <;>
        (try simp_all [ZMod.val_one]) <;>
        (try omega)
      have h‚Çà : y.val < 2 ^ n := by
        omega
      simp_all [h‚ÇÖ, h‚ÇÜ, h‚Çá, h‚Çà]
      <;>
      (try omega) <;>
      (try {
        split_ifs at * <;>
        simp_all [Nat.le_of_lt_succ, Nat.succ_le_iff] <;>
        omega
      }) <;>
      (try {
        simp_all [Nat.le_of_lt_succ, Nat.succ_le_iff] <;>
        omega
      })
  completeness := by
    intro i0
    simp [circuit_norm, LessThan.circuit]
    <;>
    (try {
      simp_all [Nat.add_assoc]
      <;>
      omega
    }) <;>
    (try {
      aesop
    })
end LessEqThan
