lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h_sSup_eq_top : sSup D = ⊤ := D.sSup_eq_top'
  have h_lemma : ⨆ p ∈ D, p x = ⊤ := by
    calc
      ⨆ p ∈ D, p x = (⨆ p ∈ D, p x) := rfl
      _ = (sSup D) x := by
        -- Use the fact that the supremum of the pointwise suprema is the supremum of the modules evaluated at x
        simp [iSup_iSup, DirectSum.supmodules_sSup, sSup]
        <;>
        (try
          {
