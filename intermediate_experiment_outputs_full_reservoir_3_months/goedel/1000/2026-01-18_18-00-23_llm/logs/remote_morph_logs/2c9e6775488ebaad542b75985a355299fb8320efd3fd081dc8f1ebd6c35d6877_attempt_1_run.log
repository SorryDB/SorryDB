protected lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h₁ : sSupIndep (D : Set (PersistenceSubmodule M)) := D.sSupIndep'
  have h₂ : sSup (D : Set (PersistenceSubmodule M)) = ⊤ := D.sSup_eq_top'
  calc
    ⨆ p ∈ D, (p : Set (M x)) = ⨆ p ∈ (D : Set (PersistenceSubmodule M)), (p : Set (M x)) := by simp [SetLike.mem_coe]
    _ = (⊤ : M x) := by
      have h₃ : ∀ i : C, ⨆ p ∈ (D : Set (PersistenceSubmodule M)), (p i : Set (M i)) = ⊤ := by
        intro i
        have h₄ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p) = ⊤ :=
          by
            have h₅ : sSup (D : Set (PersistenceSubmodule M)) = ⊤ := h₂
            simpa [SetLike.mem_coe] using h₅
          <;> rfl
        have h₅ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p) i = ⊤ := by
          have h₆ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p) = ⊤ := h₄
          rw [h₆]
          <;> simp [SetLike.mem_coe]
        -- Use the fact that the supremum of the modules at each index is the entire space
        have h₆ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), (p i : Set (M i))) = ⊤ := by
          -- Use the fact that the supremum of the modules at each index is the entire space
          have h₇ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), (p i : Set (M i))) = (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p) i := by
            simp [iSup_image]
          rw [h₇]
          exact h₅
        exact h₆
      have h₇ : ⨆ p ∈ (D : Set (PersistenceSubmodule M)), (p x : Set (M x)) = ⊤ := h₃ x
      exact h₇
    _ = ⊤ := by rfl
