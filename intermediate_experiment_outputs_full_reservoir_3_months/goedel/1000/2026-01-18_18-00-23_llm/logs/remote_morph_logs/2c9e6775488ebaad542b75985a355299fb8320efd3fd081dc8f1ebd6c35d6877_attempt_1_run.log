lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  calc
    ⨆ p ∈ D, p x = ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x := by
      applying le_antisymm
      · -- Show that the supremum over D is less than or equal to the supremum over the range of the function
        apply iSup₂_le_iSup₂_of_inj_on
        · intro p hp
          simp_all [Set.mem_range]
        · intro p hp q hq hpq
          simp_all [Set.mem_range]
          <;> aesop
      · -- Show that the supremum over the range of the function is less than or equal to the supremum over D
        apply iSup₂_le_iSup₂_of_inj_on
        · intro p hp
          simp_all [Set.mem_range]
          <;> aesop
        · intro p hp q hq hpq
          simp_all [Set.mem_range]
          <;> aesop
    _ = ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x := by rfl
    _ = ⊤ := by
      -- Since D is a direct sum decomposition, the supremum of the range of the function is the top element
      have h : ∀ (x : C), ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x = ⊤ := by
        intro x
        have h₁ : ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x = ⊤ := by
          -- Use the fact that the supremum of the carrier set is the top element
          have h₂ : sSup (D.carrier : Set (PersistenceSubmodule M)) = ⊤ := D.sSup_eq_top'
          have h₃ : ∀ (x : C), ⨆ p ∈ (D.carrier : Set (PersistenceSubmodule M)), p x = ⊤ := by
            intro x
            -- Use the fact that the supremum of the carrier set is the top element
            have h₄ : ⨆ p ∈ (D.carrier : Set (PersistenceSubmodule M)), p x = (⨆ p ∈ (D.carrier : Set (PersistenceSubmodule M)), p) x := by
              simp [iSup_apply]
            rw [h₄]
            have h₅ : (⨆ p ∈ (D.carrier : Set (PersistenceSubmodule M)), p) = ⊤ := by
              simpa [sSup_eq_iSup] using h₂
            rw [h₅]
            simp
          have h₆ : ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x = ⊤ := by
            calc
              ⨆ p : (M x), p ∈ Set.range fun p : D => p.val x = ⨆ p ∈ (D.carrier : Set (PersistenceSubmodule M)), p x := by
                -- Show that the supremum over the range of the function is the same as the supremum over the carrier set
                have h₇ : Set.range (fun p : D => p.val x) = {p x | p : (M x), p ∈ (D.carrier : Set (PersistenceSubmodule M))} := by
                  ext y
                  simp [Set.mem_range, Set.mem_setOf_eq]
                  <;>
                  (try aesop) <;>
                  (try {
                    constructor <;> intro h <;>
                    (try simp_all [Set.mem_range, Set.mem_setOf_eq]) <;>
                    (try {
                      aesop
                    }) <;>
                    (try {
                      use y
                      <;> aesop
                    })
                  })
                  <;>
                  (try {
                    aesop
                  })
                rw [h₇]
                -- Use the fact that the supremum over the carrier set is the same as the supremum over the range of the function
                simp [iSup_apply]
                <;>
                (try aesop) <;>
                (try {
                  simp_all [Set.mem_range, Set.mem_setOf_eq]
                  <;> aesop
                })
              _ = ⊤ := h₃ x
          exact h₆
        exact h₁
      exact h x
    _ = ⊤ := by rfl
