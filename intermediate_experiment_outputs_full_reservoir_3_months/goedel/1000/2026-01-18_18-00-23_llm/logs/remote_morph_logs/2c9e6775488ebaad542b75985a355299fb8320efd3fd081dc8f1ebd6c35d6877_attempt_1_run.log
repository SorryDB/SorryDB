lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h₁ : ⨆ p ∈ D, p x ≤ (⨆ p ∈ D, p) x := by
    simp [iSup_le_iff]
    <;> intro p hp <;>
    (try simp_all [iSup_le_iff]) <;>
    (try exact le_iSup p (p x) (by aesop)) <;>
    (try exact le_iSup p (p x)) <;>
    (try simp_all [SetLike.mem_coe]) <;>
    (try simp_all [SetLike.mem_coe]) <;>
    (try aesop)
  have h₂ : (⨆ p ∈ D, p) x = ⊤ := by
    have h₃ : (⨆ p ∈ D, p) = ⊤ := by
      have h₄ : sSup D = ⊤ := D.sSup_eq_top'
      have h₅ : sSup D = ⊤ := by
        simpa [SetLike.coe_iSup] using h₄
      simp_all [sSup_eq_iSup]
      <;> aesop
    simp_all [SetLike.coe_iSup]
    <;> aesop
  have h₃ : ⨆ p ∈ D, p x = ⊤ := by
    have h₄ : ⨆ p ∈ D, p x ≥ ⊤ := by
      -- Use the fact that the iSup of p x is the top element
      have h₅ : ⨆ p ∈ D, p x ≥ ⊤ := by
        have h₆ : (⨆ p ∈ D, p) x = ⊤ := h₂
        have h₇ : (⨆ p ∈ D, p) x ≤ ⨆ p ∈ D, p x := by
          exact le_iSup (fun p hp => (p : SetLike (PersistenceSubmodule M) _).1 x) (x := x)
        have h₈ : ⊤ ≤ ⨆ p ∈ D, p x := by
          calc
            ⊤ = (⨆ p ∈ D, p) x := by rw [h₆]
            _ ≤ ⨆ p ∈ D, p x := h₇
        exact h₈
      exact h₅
    -- Combine the inequalities to get the result
    have h₅ : ⨆ p ∈ D, p x ≤ ⊤ := by
      exact le_top
    have h₆ : ⨆ p ∈ D, p x ≥ ⊤ := h₄
    le_antisymm h₅ h₆
  exact h₃
