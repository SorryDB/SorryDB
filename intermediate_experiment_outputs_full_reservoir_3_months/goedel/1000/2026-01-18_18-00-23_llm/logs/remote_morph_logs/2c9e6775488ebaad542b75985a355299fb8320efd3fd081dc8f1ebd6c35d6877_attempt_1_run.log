          })
      _ = ⊤ x := by
        -- Since the supremum of D is ⊤, we have (sSup D) x = ⊤ x
        rw [h_sSup_eq_top]
      _ = ⊤ := by
        -- Simplify ⊤ x to ⊤
        simp
  exact h_lemma
