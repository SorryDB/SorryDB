    IsNIPWith d (restrictFiniteSymmDiffComponent 𝓒 : Set (Set ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A))) :=
  by
  have h₁ : (restrictFiniteSymmDiffComponent 𝓒 : Set (Set ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A))) ⊆ Set.univ := by
    intro x _
