theorem WeakDeductionTheorem : (Deduction Ax Γ φ) ↔ (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
  have h₁ : (Deduction Ax Γ φ) → (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
    intro h
    have h₂ : Deduction Ax Γ φ := h
    -- Use the induction principle for Deduction to handle each case
    have h₃ : ∀ (φ : Formula α), Deduction Ax Γ φ → (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
      intro φ hφ
      induction hφ <;>
      -- Case analysis on the Deduction structure
      (try simp_all [conj_assoc]) <;>
      (try
        {
          -- If φ is in Γ, we use the fact that ⋀Γ implies φ
          have h₄ : φ ∈ Γ := by assumption
          have h₅ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
            -- Use the fact that if we have ⋀Γ, then we can deduce φ because φ ∈ Γ
            apply (imp_congr_right_1 (by intro; simp_all [h₄]))
            <;> simp_all [h₄]
          exact h₅
        }) <;>
      (try
        {
          -- If φ is a theorem, then ⋀Γ → φ is directly true
          have h₄ : (Hilbert.F Ax) ⊢ φ := by assumption
          have h₅ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
            intro h₆
            -- Since φ is a theorem, we can deduce it regardless of ⋀Γ
            exact h₄
          exact h₅
        }) <;>
      (try
        {
          -- If φ is deduced from ψ using modus ponens, we use the induction hypothesis
          have h₄ : (Hilbert.F Ax) ⊢ ψ ➝ φ := by assumption
          have h₅ : Deduction Ax Γ ψ := by assumption
          have h₆ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ ψ := by
            apply h₃
            exact h₅
          have h₇ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := by
            -- Use the fact that ⋀Γ → ψ and ψ → φ to deduce ⋀Γ → φ
            have h₈ : (Hilbert.F Ax) ⊢ (⋀Γ ➝ ψ) → (ψ ➝ φ) → (⋀Γ ➝ φ) := by
              intro h₉ h₁₀
              exact fun h₁₁ => h₁₀ (h₉ h₁₁)
            exact h₈ h₆ h₄
          exact h₇
        }) <;>
      (try
        {
          -- If φ is the conjunction of two formulas, we use the induction hypothesis on both
          have h₄ : Deduction Ax Γ φ₁ := by assumption
          have h₅ : Deduction Ax Γ φ₂ := by assumption
          have h₆ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ₁ := by
            apply h₃
            exact h₄
          have h₇ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ₂ := by
            apply h₃
            exact h₅
          have h₈ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ (φ₁ ⋏ φ₂) := by
            -- Use the fact that ⋀Γ → φ₁ and ⋀Γ → φ₂ to deduce ⋀Γ → (φ₁ ⋏ φ₂)
            have h₉ : (Hilbert.F Ax) ⊢ (⋀Γ ➝ φ₁) → (⋀Γ ➝ φ₂) → (⋀Γ ➝ (φ₁ ⋏ φ₂)) := by
              intro h₁₀ h₁₁
              exact fun h₁₂ => ⟨h₁₀ h₁₂, h₁₁ h₁₂⟩
            exact h₉ h₆ h₇
          exact h₈
        })
    -- Apply the general result to the specific φ
    exact h₃ φ h₂
  have h₂ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ → Deduction Ax Γ φ := by
    intro h
    -- Use the fact that ⋀Γ → φ implies we can deduce φ from Γ
    have h₃ : Deduction Ax Γ φ := by
      -- If we have ⋀Γ → φ, then we can deduce φ from Γ
      have h₄ : (Hilbert.F Ax) ⊢ ⋀Γ ➝ φ := h
      -- Use the fact that we can deduce ⋀Γ from Γ
      have h₅ : Deduction Ax Γ ⋀Γ := by
        -- Deduce ⋀Γ from Γ by the induction hypothesis
        has h₆ : Deduction Ax Γ ⋀Γ := by
          -- Use the fact that ⋀Γ is the conjunction of all formulas in Γ
          induction Γ using List.induction_on with
          | nil =>
            -- If Γ is empty, then ⋀Γ is trivially true
            apply Deduction.thm
            simp
          | cons φ Γ ih =>
            -- If Γ is not empty, then ⋀Γ is φ ∧ ⋀Γ'
            simp_all [List.conj]
            <;>
            (try
              {
                -- Use the fact that we can deduce φ and ⋀Γ'
                apply Deduction.andIR
                · apply Deduction.ctx
                  simp
                · exact ih
              })
            <;>
            (try
              {
                -- Use the fact that we can deduce φ and ⋀Γ'
                simp_all [Deduction]
                <;>
                (try
                  {
                    apply Deduction.andIR
                    · apply Deduction.ctx
                      simp
                    · exact ih
                  })
              })
            <;>
            (try
              {
                -- Use the fact that we can deduce φ and ⋀Γ'
                simp_all [Deduction]
                <;>
                (try
                  {
                    apply Deduction.andIR
                    · apply Deduction.ctx
                      simp
                    · exact ih
                  })
              })
        exact h₆
      -- Use modus ponens to deduce φ from ⋀Γ → φ and ⋀Γ
      have h₆ : Deduction Ax Γ φ := by
        apply Deduction.mp h₄ h₅
      exact h₆
    exact h₃
  -- Combine the two directions to get the final result
  exact ⟨h₁, h₂⟩
