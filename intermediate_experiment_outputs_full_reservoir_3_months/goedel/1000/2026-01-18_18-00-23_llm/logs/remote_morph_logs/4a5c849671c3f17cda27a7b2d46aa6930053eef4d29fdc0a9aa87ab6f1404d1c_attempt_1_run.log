theorem dt_list {Γ : List (Formula α)} : (Deduction Ax Γ.toFinset φ) ↔ (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
  constructor;
  . intro h;
    induction h with
    | ctx hφ => 
      simp [Set.mem_toFinset] at hφ
      -- We need to prove that the conjunction of Γ implies φ when φ is in Γ.
      -- This can be done by showing that if φ is in Γ, then Γ.conj₂ → φ is a tautology.
      have h₁ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
        -- Use the fact that φ is in Γ to deduce Γ.conj₂ → φ.
        have h₂ : φ ∈ List.toFinset Γ := hφ
        have h₃ : φ ∈ Γ := by
          simp [Set.mem_toFinset] at h₂ ⊢
          <;> aesop
        -- Use the property of conjunction to deduce the implication.
        have h₄ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
          -- If φ is in Γ, then Γ.conj₂ implies φ.
          simp_all [List.conj₂, Formula.prod_eq]
          <;>
          (try { aesop }) <;>
          (try {
            induction Γ <;> simp_all [List.conj₂, Formula.prod_eq]
            <;> (try { aesop }) <;> (try { tauto })
          })
        exact h₄
      exact h₁
    | thm hφ => sorry
    | mp => sorry
    | andIR => sorry
  . sorry
