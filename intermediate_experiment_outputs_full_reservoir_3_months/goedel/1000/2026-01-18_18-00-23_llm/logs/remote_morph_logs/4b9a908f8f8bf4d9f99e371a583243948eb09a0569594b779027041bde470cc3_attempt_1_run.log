structure ACCSystem extends ACCSystemQuad where
  cubicACC : HomogeneousCubic toACCSystemCharges.Charges

namespace ACCSystem

/-- The type of solutions to the anomaly cancellation conditions. -/
structure Sols (Ōá : ACCSystem) extends Ōá.QuadSols where
  cubicSol : Ōá.cubicACC val = 0

/-- Two solutions are equal if the underlying charges are equal. -/
lemma Sols.ext {Ōá : ACCSystem} {S T : Ōá.Sols} (h : S.val = T.val) :
    S = T := by
  have h := ACCSystemQuad.QuadSols.ext h
  cases' S
  simp_all only

/-- A charge `S` is a solution if it extends to a solution. -/
def IsSolution (Ōá : ACCSystem) (S : Ōá.Charges) : Prop :=
  ‚ąÉ (sol : Ōá.Sols), sol.val = S

/-- An instance giving the properties and structures to define an action of `‚Ąö` on `Sols`. -/
instance solsMulAction (Ōá : ACCSystem) : MulAction ‚Ąö Ōá.Sols where
  smul a S := ‚ü®a ‚ÄĘ S.toQuadSols, by
    erw [(Ōá.cubicACC).map_smul, S.cubicSol]
    exact Rat.mul_zero (a ^ 3)‚ü©
  mul_smul a b S := Sols.ext (mul_smul _ _ _)
  one_smul S := Sols.ext (one_smul _ _)

/-- The inclusion of `Sols` into `QuadSols`. -/
def solsInclQuadSols (Ōá : ACCSystem) : Ōá.Sols ‚Üí[‚Ąö] Ōá.QuadSols where
