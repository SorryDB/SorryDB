```lean
theorem lex_order_workbook_plus_exercise_790 :
    ∀ (p q : MvPolynomial (Fin 4) ℕ),
      p ≠ 0 → q ≠ 0 →
      (p * q ≠ 0) ∧
      (p * q ≡ p * q [MOD MvPolynomial.monomial (⟨1, by decide⟩ : Fin 4) 1])
  := by
  intro p q hp hq
  have h_produce : p * q ≠ 0 := by
    intro h
    have h₁ : p = 0 ∨ q = 0 := by
      exact eq_zero_or_eq_zero_of_mul_eq_zero h
    cases h₁ with
    | inl h₂ =>
      exact hp h₂
    | inr h₂ =>
      exact hq h₂
  have h_two : p * q ≡ p * q [MOD MvPolynomial.monomial (⟨1, by decide⟩ : Fin 4) 1] := by
    -- Any polynomial is congruent to itself modulo any polynomial.
    simp [MvPolynomial.ModEq, MvPolynomial.dvd_iff_exists_eq_mul_left]
    <;>
