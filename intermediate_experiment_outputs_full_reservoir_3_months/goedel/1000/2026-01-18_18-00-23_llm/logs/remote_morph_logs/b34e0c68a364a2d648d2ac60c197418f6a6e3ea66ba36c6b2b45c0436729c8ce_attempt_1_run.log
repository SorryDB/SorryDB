theorem necessary_conditions_on_binary_relation_through_subset : 
    ∀ {α : Type*} [DecidableEq α] {R : α → α → Prop} 
    (sub : R.SubRelation), 
    ∀ {C : Finset ℕ} {n : ℕ}, 
    (R.SubRelation)_ (fun i j => i ∈ C → j ∈ C → i ∈ C) sub = True → 
    ∀ (i j : ℕ), i ∈ C → j ∈ C → i ∈ C := by
    intro α _ R sub C n h C' i j hi hj
    have h₁ : (R.SubRelation)_ (fun i j => i ∈ C → j ∈ C → i ∈ C) sub = True := by sorry
    have h₂ : ∀ (i j : ℕ), i ∈ C → j ∈ C → i ∈ C := by sorry
    sorry
