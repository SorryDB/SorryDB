      {X 0, X 1, X 2, X 3} 0 := by
  simp only [← Set.range_get_nil, ← Set.range_get_singleton, ← Set.range_get_cons_list]
  rw [isRemainder_range_fin, ← exists_and_right]
  use [X 0, X 1 ^ 2, X 2 ^ 3, X 3 ^ 4].get
  split_ands
  · split_ands
    · simp [Fin.univ_succ, -List.get_eq_getElem, List.get]
    <;>
      (try decide) <;>
      (try
        {
          norm_num [MvPolynomial.degree_eq_natDegree, natDegree_add_eq_left_of_natDegree_lt,
            natDegree_pow, natDegree_X, Finset.sum_const, Finset.card_fin]
          <;>
          rfl
        }) <;>
      (try
        {
          simp_all [MvPolynomial.degree_eq_natDegree, natDegree_add_eq_left_of_natDegree_lt,
            natDegree_pow, natDegree_X, Finset.sum_const, Finset.card_fin]
          <;>
          norm_num
          <;>
          rfl
        })
  · intro i
    fin_cases i <;>
      (try decide) <;>
      (try
        {
          simp_all [MvPolynomial.degree_eq_natDegree, natDegree_add_eq_left_of_natDegree_lt,
            natDegree_pow, natDegree_X, Finset.sum_const, Finset.card_fin]
          <;>
          norm_num
          <;>
          rfl
        })
``` 

