def Comma_NatTrans {C D E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    let CommaType := Σ (d : D) (e : E), Hom (F.F d) (G.F e)
    letI : CommaType := Comma_category F G
    NaturalTransformation
      (Functor.comp (Comma_category_cod F G) G)
      (Functor.comp (Comma_category_dom F G) F) where
  arrow X := by
    simp only [Σ.instHom]
    dsimp [Comma_category_cod, Comma_category_dom]
    <;>
    (try simp_all [Functor.comp, HomExtensionality])
    <;>
    (try aesop)
    <;>
    (try {
      cases X with
      | mk d e =>
        simp_all [Functor.comp, HomExtensionality]
        <;>
        try { aesop }
        <;>
        try { {
          ext x
          simp_all [Functor.comp, HomExtensionality]
          <;>
          try { aesop }
        } }
    })
    <;>
    (try {
      ext x
      simp_all [Functor.comp, HomExtensionality]
      <;>
      try { aesop }
    })
  naturality {X Y} f := by
    simp only [Σ.instHom]
    dsimp [Comma_category_cod, Comma_category_dom]
    <;>
