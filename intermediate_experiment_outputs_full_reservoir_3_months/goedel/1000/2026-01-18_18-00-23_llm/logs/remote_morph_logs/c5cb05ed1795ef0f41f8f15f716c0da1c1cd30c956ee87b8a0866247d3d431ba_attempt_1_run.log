-- exercise 1.4.v
-- Natural transformation from G ∘ π₂ to F ∘ π₁ for comma category (F ↓ G)
def Comma_NatTrans {C D E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    let CommaType := Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)
    letI : Category CommaType := Comma_category F G
    NaturalTransformation
      (Functor.comp (Comma_category_cod F G) G)
      (Functor.comp (Comma_category_dom F G) F) where
  arrow ⟨⟨d1, e1⟩, h1⟩ := by
    -- Define the specific component of the natural transformation for each object in the comma category
    exact h1
  naturality {X Y} f := by
    -- Prove that the natural transformation satisfies the naturality condition
    simp_all [Comma_category]
    <;>
    (try simp_all [Functor.comp, Category.comp_apply]) <;>
    (try aesop) <;>
    (try simp_all [Function.comp_apply]) <;>
    (try simp_all [Hom, SetLike.ext_iff]) <;>
    (try simp_all [Comma_category, Prod.ext_iff]) <;>
    (try aesop)
```
