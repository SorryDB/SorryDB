  probOutput_selectElem_eq := by
    intro x y
    simp [probOutput_def, bind_assoc, map_map, Function.comp_apply]
    <;>
    (try simp_all [SampleableType.probOutput_selectElem_eq])
    <;>
    (try ring_nf)
    <;>
    (try simp_all [mul_comm])
    <;>
    (try norm_num)
    <;>
    (try linarith)
  probFailure_selectElem := by
    simp [probFailure_def, bind_assoc, map_map, Function.comp_apply]
    <;>
    (try simp_all [SampleableType.probFailure_selectElem])
    <;>
    (try ring_nf)
    <;>
    (try simp_all [mul_comm])
    <;>
    (try norm_num)
    <;>
    (try linarith)

