```lean
class SampleableType (ОІ : Type) where
  selectElem : ProbComp ОІ
  mem_support_selectElem (x : ОІ) : x в€€ support selectElem
  probOutput_selectElem_eq (x y : ОІ) : Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure_selectElem : Pr[вЉҐ | selectElem] = 0

def uniformSample (ОІ : Type) [h : SampleableType ОІ] :
    ProbComp ОІ := h.selectElem

prefix : 90 "$бµ—" => uniformSample

variable (О± : Type) [hО± : SampleableType О±]

@[simp] lemma probOutput_uniformSample [Fintype О±] (x : О±) :
    Pr[= x | $бµ— О±] = (Fintype.card О± : в„ќв‰Ґ0в€ћ)вЃ»В№ := by
  have : (Fintype.card О± : в„ќв‰Ґ0в€ћ) = в€‘ y : О±, 1 :=
    by simp only [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one]
  refine ENNReal.eq_inv_of_mul_eq_one_left ?_
  simp_rw [this, Finset.mul_sum, mul_one]
  rw [в†ђ sum_probOutput_eq_one ($бµ— О±) SampleableType.probFailure_selectElem]
  exact Finset.sum_congr rfl О» y _ в†¦ SampleableType.probOutput_selectElem_eq x y

@[simp] lemma probFailure_uniformSample : Pr[вЉҐ | $бµ— О±] = 0 :=
  SampleableType.probFailure_selectElem

@[simp] instance : HasEvalSPMF.NeverFail ($бµ— О±) := inferInstance

@[simp] lemma evalDist_uniformSample [Fintype О±] [Inhabited О±] :
    evalDist ($бµ— О±) = liftM (PMF.uniformOfFintype О±) := by
  simp [SPMF.evalDist_eq_iff]

@[simp] lemma support_uniformSample : support ($бµ— О±) = Set.univ := by
  simp only [Set.ext_iff, Set.mem_univ, iff_true]
  apply SampleableType.mem_support_selectElem

@[simp] lemma probEvent_uniformSample [Fintype О±] (p : О± в†’ Prop) [DecidablePred p] :
    Pr[p | $бµ— О±] = (Finset.univ.filter p).card / Fintype.card О± := by
  simp only [probEvent_eq_sum_filter_univ, probOutput_uniformSample, Finset.sum_const,
    nsmul_eq_mul, div_eq_mul_inv]

section instances

instance (О± : Type) [Unique О±] : SampleableType О± where
  selectElem := return default
  mem_support_selectElem x := Unique.eq_default x в–ё (by simp)
  probOutput_selectElem_eq x y := by rw [Unique.eq_default x, Unique.eq_default y]
  probFailure_selectElem := by simp

instance : SampleableType Bool where
  selectElem := $! #v[true, false]
  mem_support_selectElem x := by
    fin_cases x <;> simp [support_def, mem_range]
    <;>
    (try decide)
    <;>
    (try {
      use 0
      <;> simp
    })
    <;>
    (try {
      use 1
      <;> simp
    })
  probOutput_selectElem_eq x y := by
    fin_cases x <;> fin_cases y <;> simp [probOutput_def, map_eq_comp, Function.comp]
    <;>
    (try decide)
    <;>
    (try {
      norm_num
      <;>
      simp_all [Fin.forall_fin_two]
      <;>
      norm_num
      <;>
      linarith
    })
  probFailure_selectElem := by
    simp [probFailure_def, map_eq_comp, Function.comp]
    <;>
    (try decide)

/-- Select a uniform element from `О± Г— ОІ` by independently selecting from `О±` and `ОІ`. -/
instance (О± ОІ : Type) [Fintype О±] [Fintype ОІ] [Inhabited О±] [Inhabited ОІ]
    [SampleableType О±] [SampleableType ОІ] : SampleableType (О± Г— ОІ) where
  selectElem := (В·, В·) <$> ($бµ— О±) <*> ($бµ— ОІ)
  mem_support_selectElem x := by
    simp only [support_def, mem_range] at *
    obtain вџЁa, haвџ© := SampleableType.mem_support_selectElem x.1
    obtain вџЁb, hbвџ© := SampleableType.mem_support_selectElem x.2
    refine' вџЁ(a, b), _вџ©
    simp_all [bind_assoc, map_map, Function.comp_apply]
