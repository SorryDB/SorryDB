  have h₁ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (H₂ : ℂ → ℂ) := by
    apply H₂.holo'_MDifferentiable
  have h₂ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => (H₂ z) ^ 3) := by
    -- The cube of a holomorphic function is holomorphic.
    apply MDifferentiable.pow
    exact h₁
  have h₃ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => (H₂ z) ^ 2) := by
    -- The square of a holomorphic function is holomorphic.
    apply MDifferentiable.pow
    exact h₁
  have h₄ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => (H₄ z)) := by
    apply H₄.holo'_MDifferentiable
  have h₅ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => 2 * (H₂ z) ^ 2 + 5 * (H₂ z) * (H₄ z) + 5 * (H₄ z) ^ 2) := by
    -- Sum and product of holomorphic functions are holomorphic.
    apply MDifferentiable.add
    · apply MDifferentiable.add
      · -- 2 * (H₂ z) ^ 2
        apply MDifferentiable.const_mul
        exact h₃
      · -- 5 * (H₂ z) * (H₄ z)
        apply MDifferentiable.mul
        · apply MDifferentiable.const_mul
          exact h₁
        · exact h₄
    · -- 5 * (H₄ z) ^ 2
      apply MDifferentiable.const_mul
      apply MDifferentiable.pow
      exact h₄
  have h₆ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => (H₂ z) ^ 3 * (2 * (H₂ z) ^ 2 + 5 * (H₂ z) * (H₄ z) + 5 * (H₄ z) ^ 2)) := by
    -- Product of holomorphic functions is holomorphic.
    apply MDifferentiable.mul
    · exact h₂
    · exact h₅
  -- Since G is defined as the above product, it is holomorphic.
  simpa [G] using h₆
