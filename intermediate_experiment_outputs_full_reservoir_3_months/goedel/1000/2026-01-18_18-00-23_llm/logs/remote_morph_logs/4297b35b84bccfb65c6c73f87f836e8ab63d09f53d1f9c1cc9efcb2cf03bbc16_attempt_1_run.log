              <;>
                (try decide) <;>
                  (try simp_all [Function.LeftInverse, Function.RightInverse]) <;>
                    (try aesop)
            have h₄ : X' i ∘ Prod.map Prod.snd Prod.fst = (fun (ω : Ω × Ω) => -X' i ω) := by
              -- Verify that the composition with the symmetry gives -X' i
              funext ⟨ω₁, ω₂⟩
              simp [X', X₁, X₂]
              <;> abel
            have h₅ : IdentDistrib (X' i) (X' i ∘ Prod.map Prod.snd Prod.fst) (μ.prod μ) (μ.prod μ) := by
              -- Use the symmetry of the product measure
              have h₆ : IdentDistrib (Prod.map Prod.snd Prod.fst) (Prod.map Prod.fst Prod.snd) (μ.prod μ) (μ.prod μ) := h₃
              have h₇ : (Prod.map Prod.snd Prod.fst) ≈[μ.prod μ] (Prod.map Prod.fst Prod.snd) := by simpa [h₆] using h₆
              exact identDistrib.congr_right (h₇.injective.comp_right _)
            rw [h₄] at h₅
            exact h₅
          exact h₂
