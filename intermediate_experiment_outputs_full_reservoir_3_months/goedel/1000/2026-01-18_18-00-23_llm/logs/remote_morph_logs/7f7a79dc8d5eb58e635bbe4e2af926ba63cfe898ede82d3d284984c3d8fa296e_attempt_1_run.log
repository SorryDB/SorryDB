theorem rbrKnowledgeSoundnessOneShot_implies_rbrKnowledgeSoundness
    {relIn : Set (StmtIn × WitIn)} {relOut : Set (StmtOut × WitOut)}
    {verifier : Verifier oSpec StmtIn StmtOut pSpec}
    {rbrKnowledgeError : pSpec.ChallengeIdx → ℝ≥0}
    (hInit : HasEvalSPMF.NeverFail init)
    (h : verifier.rbrKnowledgeSoundnessOneShot init impl relIn relOut rbrKnowledgeError) :
    verifier.rbrKnowledgeSoundness init impl relIn relOut rbrKnowledgeError := by
  unfold rbrKnowledgeSoundness
  unfold rbrKnowledgeSoundnessOneShot at h
  obtain ⟨stF, oneShotE, h⟩ := h
  refine ⟨fun i => WitIn, oneShotE.toRoundByRound, stF.toKnowledgeStateFunction init impl oneShotE, ?_⟩
  intro stmtIn witIn prover i
  have h₁ := h stmtIn witIn prover i
  simp_all [rbrKnowledgeSoundness, rbrKnowledgeSoundnessOneShot]
  <;>
  (try simp_all [VerifyingSystem]) <;>
  (try simp_all [hasEvalSpmf_neverFail_iff]) <;>
  (try simp_all [probEvent_mono, probEvent_le_one]) <;>
  (try omega) <;>
  (try {
    refine' le_of_sub_nonneg (fun _ => ?_)
    <;>
    simp_all [sub_nonneg]
    <;>
    positivity
  }) <;>
  (try {
    refine' le_of_not_gt (fun hgt => ?_)
    <;>
    simp_all [gt_iff_lt]
    <;>
    linarith
  }) <;>
  (try {
    simp_all [VerifyingSystem]
    <;>
    aesop
  }) <;>
  (try {
    simp_all [VerifyingSystem]
    <;>
    norm_num at *
    <;>
    linarith
  }) <;>
  (try {
    simp_all [VerifyingSystem]
    <;>
    simp_all [hasEvalSpmf_neverFail_iff]
    <;>
    aesop
  })
