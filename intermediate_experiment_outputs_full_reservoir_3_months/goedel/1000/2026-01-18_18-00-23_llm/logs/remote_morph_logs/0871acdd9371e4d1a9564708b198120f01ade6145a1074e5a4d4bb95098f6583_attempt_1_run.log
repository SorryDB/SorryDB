theorem not_reversible_unreverse (hy : y ∈ x.unreverse.moves p) : ¬ Reversible x.unreverse y p := by
  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y₀, hy₀, ⟨z₀, hz₀, rfl⟩⟩ := hy
  by_cases h : Reversible x y₀ p
  · -- Case: y₀ is reversible in x
    have h₁ : reverseSet x y₀ p = h.choose.moves p := by rw [reverseSet_of_reversible h]
    simp_all [h₁, unreverse_def]
    <;>
    (try { contradiction }) <;>
    (try {
      aesop
    }) <;>
    (try {
      norm_num at *
      <;>
      simp_all [reversible_left, reversible_right]
      <;>
      (try { contradiction }) <;>
      (try { aesop })
    })
  · -- Case: y₀ is not reversible in x
    have h₁ : reverseSet x y₀ p = {y₀} := by rw [reverseSet_of_not_reversible h]
    simp_all [h₁]
    <;>
    (try { contradiction }) <;>
    (try {
      aesop
    }) <;>
    (try {
      norm_num at *
      <;>
      simp_all [reversible_left, reversible_right]
      <;>
      (try { contradiction }) <;>
      (try { aesop })
    })
