lemma gaussLaw_iff (q ε : ℝ) (E : StaticElectricField 1) :
    E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = distConst 1 m := by
  constructor
  · -- Prove the forward direction: if E satisfies Gauss's Law, then E is constant.
    intro h
    have h₁ : ∀ x : Fin 1, E x = E 0 := by
      intro x
      -- Since the space is 1-dimensional, all points are equal.
      cases x <;> simp [Fin.ext_iff]
      <;>
      (try decide) <;>
      (try simp_all [Fin.ext_iff]) <;>
      (try ring_nf) <;>
      (try norm_num) <;>
      (try linarith)
    -- Since E is constant, we can write it as a constant function.
    refine' ⟨E 0, _⟩
    ext x
    have h₂ : E x = E 0 := h₁ x
    rw [h₂]
    <;>
    simp [distConst]
    <;>
    ext <;>
    simp [Fin.ext_iff]
    <;>
    (try decide) <;>
    (try simp_all [Fin.ext_iff]) <;>
    (try ring_nf) <;>
    (try norm_num) <;>
    (try linarith)
  · -- Prove the backward direction: if E is constant, then it satisfies Gauss's Law.
    rintro ⟨m, rfl⟩
    -- Simplify the condition for Gauss's Law with the constant electric field.
    simp [GaussLaw, chargeDistribution, distConst, Fin.sum_univ_succ]
    <;>
    (try decide) <;>
    (try simp_all [Fin.ext_iff]) <;>
    (try ring_nf) <;>
    (try norm_num) <;>
    (try linarith)
    <;>
    aesop
```
