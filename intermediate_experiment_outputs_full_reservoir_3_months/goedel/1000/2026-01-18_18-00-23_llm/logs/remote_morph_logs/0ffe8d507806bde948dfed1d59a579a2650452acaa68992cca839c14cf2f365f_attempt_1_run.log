lemma nullmeasurable_measurable_null {s : Set ℝ} (h : NullMeasurableSet s volume) :
    ∃ t ⊆ s, MeasurableSet t ∧ volume t = volume s ∧ volume (s \ t) = 0 := by
  have ⟨t, t_sub_s, t_m, t_eq_s⟩ := h.exists_measurable_subset_ae_eq
  refine' ⟨t, t_sub_s, t_m, _⟩
  have h₁ : volume t = volume s := by
    -- Since t and s are almost everywhere equal, their measures are equal.
    have h₂ : volume t = volume s := by
      -- Use the fact that the measure of t and s are equal if they are almost everywhere equal.
      rw [← t_eq_s]
    exact h₂
  have h₂ : volume (s \ t) = 0 := by
    -- Since t is almost everywhere equal to s, the measure of s \ t is zero.
    have h₃ : volume (s \ t) = 0 := by
      -- Use the fact that the set difference has measure zero if the sets are almost everywhere equal.
      have h₄ : volume (s \ t) = 0 := by
        -- Use the property of almost everywhere equality to conclude that the measure of the set difference is zero.
        have h₅ : (s \ t : Set ℝ) ⊆ {x : ℝ | ¬t_eq_s x} := by
          intro x hx
          simp only [Set.mem_diff, Set.mem_setOf_eq] at hx ⊢
          -- If x is in s \ t, then x is in s but not in t, so x is not in t and thus not almost everywhere equal to s.
          by_contra h₆
          have h₇ : t_eq_s x := by simpa using h₆
          have h₈ : x ∈ t := by
            -- Since t_eq_s x is true, x must be in t if it is in s.
            have h₉ : x ∈ s := hx.1
            have h₁₀ : x ∈ t := by
              -- Use the fact that t_eq_s x implies x ∈ t if x ∈ s.
              simp_all [Filter.eventually_atTop]
              <;>
                (try contradiction) <;>
                  (try aesop) <;>
                    (try norm_num) <;>
                      (try linarith)
            exact h₁₀
          exact hx.2 h₈
        -- Use the fact that the set {x : ℝ | ¬t_eq_s x} has measure zero.
        have h₆ : volume {x : ℝ | ¬t_eq_s x} = 0 := by
          -- Use the property of almost everywhere equality.
          have h₇ : {x : ℝ | ¬t_eq_s x} ∈ volume.ae.nul := by
            -- The set {x : ℝ | ¬t_eq_s x} is the complement of the set where t_eq_s x holds, which is almost everywhere.
