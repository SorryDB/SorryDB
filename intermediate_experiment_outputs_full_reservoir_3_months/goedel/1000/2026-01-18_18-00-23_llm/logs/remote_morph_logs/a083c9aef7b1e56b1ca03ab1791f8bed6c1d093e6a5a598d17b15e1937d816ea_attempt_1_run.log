theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : fastCheckMem label l = true ↔ label ∈ l := by
    induction l with
    | leaf x =>
      simp [fastCheckMem]
      <;>
      (try decide) <;>
      (try {
        cases' le_total label x with h₂ h₂ <;>
        simp_all [h₂, le_of_lt] <;>
        aesop
      }) <;>
      (try {
        cases' lt_or_eq_of_le (le_of_lt (Classical.by_contradiction (fun h₃ => by simp_all [lt_irrefl]))) with h₂ h₂ <;>
        simp_all [h₂, le_of_lt] <;>
        aesop
      })
    | node v l r =>
      simp_all [fastCheckMem, mem, IsOrdered]
      <;>
      (try {
        split_ifs at * <;>
        (try { contradiction }) <;>
        (try {
          simp_all [le_of_lt]
          <;>
          (try {
            aesop
          }) <;>
          (try {
            cases' le_total label v with h₂ h₂ <;>
            simp_all [h₂, le_of_lt] <;>
            aesop
          })
        }) <;>
        (try {
          aesop
        }) <;>
        (try {
          cases' le_total label v with h₂ h₂ <;>
          simp_all [h₂, le_of_lt] <;>
          aesop
        })
      }) <;>
      (try {
        aesop
      }) <;>
      (try {
        cases' le_total label v with h₂ h₂ <;>
        simp_all [h₂, le_of_lt] <;>
        aesop
      })
  exact h₁
