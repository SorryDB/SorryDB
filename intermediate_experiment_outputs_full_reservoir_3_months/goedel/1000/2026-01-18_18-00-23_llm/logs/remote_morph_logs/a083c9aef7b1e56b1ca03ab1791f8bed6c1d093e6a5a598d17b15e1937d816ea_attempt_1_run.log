    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : ∀ (l : LabelledTree α) (h : IsOrdered l) (x : α), fastCheckMem x l = true ↔ x ∈ l := by
    intro l h x
    induction l with
    | leaf x' =>
