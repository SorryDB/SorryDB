        (try { simp_all [IsOrdered] }) <;>
        (try {
          by_cases h₇ : x = x'
          <;> simp_all [h₇]
          <;>
          (try { aesop })
          <;>
          (try {
            have h₈ := h₄ x'
            have h₉ := h₅ x'
