theorem imo_2008_p2_parts_i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  have h₂ : 0 < (x - 1) ^ 2 := by
    apply sq_pos_of_ne_zero
    intro h
    apply h₀.1
    linarith
  
  have h₃ : 0 < (y - 1) ^ 2 := by
    apply sq_pos_of_ne_zero
    intro h
    apply h₀.2.1
    linarith
  
  have h₄ : 0 < (z - 1) ^ 2 := by
    apply sq_pos_of_ne_zero
    intro h
    apply h₀.2.2
    linarith
  
  have h₅ : 0 < (x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2 := by positivity
  
  have h₆ : 0 < (x - 1) ^ 2 * (y - 1) ^ 2 := by positivity
  
  have h₇ : 0 < (x - 1) ^ 2 * (z - 1) ^ 2 := by positivity
  
  have h₈ : 0 < (y - 1) ^ 2 * (z - 1) ^ 2 := by positivity
  
  field_simp [h₂.ne', h₃.ne', h₄.ne']
  rw [le_div_iff (by positivity)]
  nlinarith [sq_nonneg (x - y), sq_nonneg (y - z), sq_nonneg (z - x),
    sq_nonneg (x * y - 1), sq_nonneg (y * z - 1), sq_nonneg (z * x - 1),
    sq_nonneg (x * y + y * z + z * x - 3)]
```
