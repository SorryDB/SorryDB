theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · -- Prove the forward direction: if f is a split mono, then for all c, the function is surjective.
    intro h
    intro c
    obtain ⟨g, hg⟩ := h
    intro h₂
    have h₃ : ∃ (k : Hom c X), g ≫ k = h₂ := by
      use g ≫ h₂
      <;> simp [hg, comp_assoc]
      <;> rw [← hg]
      <;> simp [comp_assoc]
    obtain ⟨k, hk⟩ := h₃
    exact ⟨k, by simp_all [comp_assoc]⟩
