lemma Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h_imp : split_mono f → (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) := by
    intro h
    rcases h with ⟨g, hg⟩
    intro c
    have h₁ : Function.Surjective (fun (g : Hom c X) => g ≫ f) := by
      intro h₂
      -- Given h₂ : Hom c Y, we need to find g' : Hom c X such that g' ≫ f = h₂
      -- We can take g' = h₂ ≫ g
      use h₂ ≫ g
      calc
        (h₂ ≫ g) ≫ f = h₂ ≫ (g ≫ f) := by rw [comp_assoc]
        _ = h₂ ≫ (1 : Hom X X) := by rw [hg]
        _ = h₂ := by simp [comp_one]
    exact h₁
  
  have h_conv : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) → split_mono f := by
    intro h
    have h₁ : Function.Surjective (fun (g : Hom Y X) => g ≫ f) := h Y
    -- Use the surjectivity for c = Y to find a g such that g ≫ f = id
    have h₂ : ∃ (g : Hom Y X), g ≫ f = (1 : Hom X X) := by
      have h₃ : ∃ (g : Hom Y X), g ≫ f = (1 : Hom X X) := by
        -- Since the function is surjective, there exists a g such that g ≫ f = id
        have h₄ : (1 : Hom X X) ∈ Set.range (fun (g : Hom Y X) => g ≫ f) := by
          apply h₁
          <;> simp
        obtain ⟨g, hg⟩ := h₄
        refine' ⟨g, _⟩
        simpa using hg
      exact h₃
    -- Now we have g such that g ≫ f = id, so we can use it to show split_mono f
    obtain ⟨g, hg⟩ := h₂
    refine' ⟨g, _⟩
    -- Show that g ≫ f = id, which is exactly hg
    <;> simp_all [IsSection]
    <;> try simp_all [comp_id]
    <;> try simp_all [id_comp]
  
  exact ⟨h_imp, h_conv⟩
