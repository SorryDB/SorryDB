    [Monoid m]
    [Monad m]
    [Applicative m] : ¬(quoted (m := m) = fun x => pure .missing) := by
  intro h
  have h₁ : (g "hello") = (fun x => pure Syntax.missing) "hello" := by
    have h₂ := congr_fun h "hello"
    -- Since `h` states that `quoted = fun x => pure .missing`, we can apply both sides to "hello"
    -- and obtain `quoted "hello" = (fun x => pure .missing) "hello".
    -- But by definition of `g`, `quoted "hello" = g "hello", so we get the desired equality.
    simpa [quoted, g] using h₂
  
  have h₂ : (g "hello") = pure Syntax.missing := by
    have h₃ : (fun x => pure Syntax.missing) "hello" = pure Syntax.missing := by rfl
    rw [h₁] at *
    <;> simpa [h₃] using h₃
  
  have h₃ : False := by
    have h₄ : g "hello" ≠ pure Syntax.missing := this
    have h₅ : g "hello" = pure Syntax.missing := h₂
    apply h₄
    exact h₅
  
  exact h₃
