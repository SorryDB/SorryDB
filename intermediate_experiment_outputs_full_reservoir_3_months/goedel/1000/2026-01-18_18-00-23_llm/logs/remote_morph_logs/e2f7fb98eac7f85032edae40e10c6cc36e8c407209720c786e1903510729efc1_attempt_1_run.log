theorem kestrel_left_cancellation
    (x y : Bird)
    (kestrel_application : K ◁ x = K ◁ y) :
    (x = y) := by
  have h₁ : (K ◁ x) ◁ x = x := by
    apply K.call
  have h₂ : (K ◁ y) ◁ x = y := by
    have h₃ : (K ◁ y) ◁ x = y := by
      have h₄ := K.call y x
