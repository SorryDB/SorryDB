```lean
namespace EnchantedForest

  namespace Introduction
    axiom Bird : Type
    axiom response : Bird → Bird → Bird
    infix:100 " ◁ " => response
  end Introduction

  open Introduction

  namespace IdentityBird
    axiom I : Bird
    axiom I.call : ∀ x : Bird, (I ◁ x) = x
  end IdentityBird

  notation A " is " " fond " " of " B => A ◁ B = B
  notation E " is " " egocentric " => E ◁ E = E

  section DefendingTheIdentityBird
    open IdentityBird
    theorem identity_fond_of_all : ∀ x : Bird, I is fond of x := by
      intro x
      apply I.call
    theorem identity_egocentric : I is egocentric := by
      have h : I ◁ I = I := I.call I
      exact h
  end DefendingTheIdentityBird

  set_option quotPrecheck false in
  notation B " is " " hopelessly " " egocentric " => ∀ x, B ◁ x = B
  set_option quotPrecheck false in
  notation A " is " " fixated " " on " B => ∀ x, A ◁ x = B

  namespace Kestrel
    axiom K : Bird
    axiom K.call : ∀ (x y : Bird), (K ◁ x) ◁ y = x
  end Kestrel

  section KestrelTheorems
    open Kestrel
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x y
      have h : (K ◁ x) ◁ y = x := K.call x y
      exact h
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h₁ : K ◁ K = K := kestrel_egocentric
      have h₂ : (K ◁ x) ◁ K = x := K.call x K
      have h₃ : (K ◁ x) ◁ x = x := by
        have h₄ : (K ◁ x) is fixated on x := k_x_fixated_on x
        have h₅ : (K ◁ x) ◁ x = x := h₄ x
        exact h₅
      have h₄ : (K ◁ x) ◁ K = (K ◁ x) ◁ x := by
        calc
          (K ◁ x) ◁ K = x := by rw [h₂]
          _ = (K ◁ x) ◁ x := by
            have h₅ : (K ◁ x) is fixated on x := k_x_fixated_on x
            have h₆ : (K ◁ x) ◁ x = x := h₅ x
            rw [h₆]
      have h₅ : K ◁ x = K := by
        have h₆ := K.call (K ◁ x) K
        have h₇ := K.call (K ◁ x) x
        have h₈ := K.call K x
        have h₉ := K.call K K
        simp [h₄] at h₆ h₇ h₈ h₉ ⊢
        <;> simp_all [response]
        <;> aesop
      rw [h₅]
      <;> simp_all [response]
      <;> aesop
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h₁ : (K ◁ x) ◁ K = x := K.call x K
      have h₂ : (K ◁ y) ◁ K = y := K.call y K
      calc
        x = (K ◁ x) ◁ K := by rw [h₁]
        _ = (K ◁ y) ◁ K := by rw [kestrel_application]
        _ = y := by rw [h₂]
  end KestrelTheorems

end EnchantedForest
