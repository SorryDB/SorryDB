    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h₁ : K ◁ K = K := kestrel_egocentric
      have h₂ : (K ◁ x) = K := by
        have h₃ := K.call x K
        have h₄ := K.call K x
        -- Simplify the expressions using the known egocentric property and Kestrel's call property.
        simp_all [egocentric, response]
