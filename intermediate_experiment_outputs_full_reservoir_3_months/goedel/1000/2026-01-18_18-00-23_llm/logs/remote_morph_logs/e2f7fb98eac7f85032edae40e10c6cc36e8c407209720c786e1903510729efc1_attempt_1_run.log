theorem kestrel_left_cancellation
    (x y : Bird)
    (kestrel_application : K ◁ x = K ◁ y) :
    (x = y) := by
  have h₁ : (K ◁ x) ◁ I = (K ◁ y) ◁ I := by
    rw [kestrel_application]
  have h₂ : x = (K ◁ x) ◁ I := by
    have h₃ := K.call x I
    have h₄ := K.call x I
    simp at h₃ h₄ ⊢
    <;> simp_all [I.call]
    <;> aesop
  have h₃ : y = (K ◁ y) ◁ I := by
    have h₄ := K.call y I
    have h₅ := K.call y I
    simp at h₄ h₅ ⊢
    <;> simp_all [I.call]
    <;> aesop
  have h₄ : x = y := by
    have h₅ : (K ◁ x) ◁ I = (K ◁ y) ◁ I := h₁
    have h₆ : x = (K ◁ x) ◁ I := h₂
    have h₇ : y = (K ◁ y) ◁ I := h₃
    have h₈ : (K ◁ x) ◁ I = (K ◁ y) ◁ I := by rw [h₅]
    have h₉ : x = y := by
      calc
        x = (K ◁ x) ◁ I := h₆
        _ = (K ◁ y) ◁ I := by rw [h₈]
        _ = y := by
          have h₁₀ : y = (K ◁ y) ◁ I := h₃
          have h₁₁ : (K ◁ y) ◁ I = y := by
            rw [h₁₀]
            <;> simp [I.call]
          rw [h₁₁]
    exact h₉
  exact h₄
