        (try simp_all [Kestrel, response]) <;>
        (try tauto) <;>
        (try simp_all [Kestrel, response]) <;>
        (try tauto)
      have h₃ : K ◁ x = K := h₂
      have h₄ : K ◁ x = K := by simpa using h₃
      -- Use the derived equality to conclude that K is hopelessly egocentric.
      simpa [h₄] using h₄

