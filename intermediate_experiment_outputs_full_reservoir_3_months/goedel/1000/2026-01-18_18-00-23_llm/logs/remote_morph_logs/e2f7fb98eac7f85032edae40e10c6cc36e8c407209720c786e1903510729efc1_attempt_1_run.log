```lean
  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x y
      have h₁ : (K ◁ x) ◁ y = x := by
        calc
          (K ◁ x) ◁ y = K ◁ x ◁ y := by rfl
          _ = x := by
            have h₂ := K.call x y
            exact h₂
      have h₂ : (K ◁ x) ◁ y = x := h₁
      have h₃ : (K ◁ x) ◁ y = x := by rw [h₂]
      calc
        (K ◁ x) ◁ y = x := by rw [h₃]
        _ = x := by rfl

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h₁ : K ◁ x = K := by
        calc
          K ◁ x = K ◁ x := by rfl
          _ = K := by
            have h₂ := Kestrel.K.call x K
            have h₃ := Kestrel.K.call K x
            have h₄ := Kestrel.K.call x x
            have h₅ : K ◁ x = K := by
              calc
                K ◁ x = Kestrel.K ◁ x := by rfl
                _ = K := by
                  have h₆ : K ◁ K = K := by
                    calc
                      K ◁ K = Kestrel.K ◁ K := by rfl
                      _ = K := by
                        have h₇ : K ◁ K = K := by
                          rw [show (K : EnchantedForest.Introduction.Bird) = K by rfl]
                          exact by
                            have h₈ : K ◁ K = K := by
                              have h₉ := Kestrel.K.call K K
                              simp_all [EnchantedForest.Introduction.Bird]
                              <;>
                              (try contradiction) <;>
                              (try simp_all [EnchantedForest.Introduction.Bird])
                              <;>
                              (try aesop)
                            exact h₈
                        exact h₇
                  have h₇ : K ◁ x = K := by
                    have h₈ := Kestrel.K.call x K
                    simp_all [EnchantedForest.Introduction.Bird]
                    <;>
                    (try contradiction) <;>
                    (try simp_all [EnchantedForest.Introduction.Bird])
                    <;>
                    (try aesop)
                  exact h₇
            have h₈ : K ◁ x = K := by
              exact h₅
            simp_all [EnchantedForest.Introduction.Bird]
            <;>
            (try contradiction) <;>
            (try simp_all [EnchantedForest.Introduction.Bird])
            <;>
            (try aesop)
          _ = K := by rfl
      calc
        K ◁ x = K := by exact h₁
        _ = K := by rfl

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h₁ : (K ◁ x) ◁ K = x := by
        have h₂ := Kestrel.K.call x K
        simpa using h₂
      have h₂ : (K ◁ y) ◁ K = y := by
        have h₃ := Kestrel.K.call y K
        simpa using h₃
      have h₃ : (K ◁ x) ◁ K = (K ◁ y) ◁ K := by
        rw [kestrel_application]
      have h₄ : x = y := by
        calc
          x = (K ◁ x) ◁ K := by rw [h₁]
          _ = (K ◁ y) ◁ K := by rw [h₃]
          _ = y := by rw [h₂]
      exact h₄
