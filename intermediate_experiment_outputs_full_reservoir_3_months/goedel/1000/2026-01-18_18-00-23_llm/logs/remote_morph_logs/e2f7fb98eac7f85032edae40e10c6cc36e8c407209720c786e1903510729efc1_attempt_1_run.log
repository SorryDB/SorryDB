```lean
section KestrelTheorems
  open Kestrel

  -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
  theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
    intro x y
    have h₁ : (K ◁ x) ◁ y = x := by
      apply K.call
    -- This step directly uses the definition of a kestrel to get the required result.
    have h₂ : (K ◁ x) ◁ y = x := by
      apply K.call
    -- Since (K ◁ x) ◁ y = x, we can use this to show (K ◁ x) is fixated on x.
    simp [h₂]
    <;> aesop

  -- An egocentric kestrel must be hopelessly egocentric.
  theorem kestrel_egocentrism
      (kestrel_egocentric : K is egocentric) :
      (K is hopelessly egocentric) := by
    intro y
    have h₁ : K ◁ K = K := by
      simpa [egocentric] using kestrel_egocentric
    have h₂ : (K ◁ y) = K := by
      have h₃ := K.call y K
      have h₄ := K.call K y
      have h₅ := K.call y y
      have h₆ := K.call K K
      simp [h₁] at h₃ h₄ h₅ h₆
      <;>
      (try simp_all [response]) <;>
      (try tauto) <;>
      (try aesop) <;>
      (try {
        have h₇ := K.call y K
        have h₈ := K.call K y
        have h₉ := K.call y y
        have h₁₀ := K.call K K
        simp [h₁] at h₇ h₈ h₉ h₁₀
        <;> simp_all [response]
        <;> aesop
      }) <;>
      (try {
        simp_all [response]
        <;> aesop
      })
    have h₃ : K ◁ y = K := by
      exact h₂
    have h₄ : K ◁ y = K := by
      exact h₂
    simp_all [response]

  -- The left cancellation law for kestrels.
  theorem kestrel_left_cancellation
      (x y : Bird)
      (kestrel_application : K ◁ x = K ◁ y) :
      (x = y) := by
    have h₁ : K ◁ x = K ◁ y := kestrel_application
    have h₂ : (K ◁ x) ◁ K = (K ◁ y) ◁ K := by rw [h₁]
    have h₃ : x = y := by
      have h₄ : (K ◁ x) ◁ K = x := by
        apply K.call
      have h₅ : (K ◁ y) ◁ K = y := by
        apply K.call
      have h₆ : (K ◁ x) ◁ K = (K ◁ y) ◁ K := by rw [h₁]
      have h₇ : x = y := by
        calc
          x = (K ◁ x) ◁ K := by rw [h₄]
          _ = (K ◁ y) ◁ K := by rw [h₆]
          _ = y := by rw [h₅]
      exact h₇
    exact h₃
``` 

