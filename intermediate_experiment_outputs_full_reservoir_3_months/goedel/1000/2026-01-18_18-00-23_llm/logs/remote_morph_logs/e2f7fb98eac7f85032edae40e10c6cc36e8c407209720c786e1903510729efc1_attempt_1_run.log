```lean
theorem kestrel_left_cancellation
    (x y : Bird)
    (kestrel_application : K ◁ x = K ◁ y) :
    (x = y) := by
  have h₁ : x = y := by
    have h₂ : (K ◁ x) ◁ x = x := K.call x x
    have h₃ : (K ◁ y) ◁ x = y := K.call y x
    have h₄ : (K ◁ y) ◁ x = x := by
      calc
        (K ◁ y) ◁ x = (K ◁ x) ◁ x := by rw [kestrel_application]
        _ = x := h₂
    have h₅ : y = x := by
      calc
        y = (K ◁ y) ◁ x := by rw [h₃]
        _ = x := h₄
    -- Now we have y = x, so we can conclude x = y by symmetry.
    exact Eq.symm h₅
  exact h₁
