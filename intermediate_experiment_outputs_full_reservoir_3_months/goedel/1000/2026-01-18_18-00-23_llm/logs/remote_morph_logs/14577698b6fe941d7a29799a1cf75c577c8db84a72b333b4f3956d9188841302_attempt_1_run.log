    -- In particular, ν(G) is the supremum of all such encards, so ν(G) ≤ M.encard.
    have h₃ : ν(G) ≤ M.encard := by
      -- Use the fact that M is a maximum matching to show that ν(G) ≤ M.encard.
      have h₄ : ∀ (M' : Set β), G.IsMatching M' → M'.encard ≤ M.encard := by
        intro M' hM'
        exact h.max M' hM'
      -- Since ν(G) is the supremum of all encards of matchings, and M.encard is an upper bound,
      -- we have ν(G) ≤ M.encard.
      have h₅ : ν(G) ≤ M.encard := by
        -- Use the definition of ν(G) and the fact that M.encard is an upper bound.
        refine' csSup_le (by
          -- Show that the set of encards is nonempty.
          have h₆ : ∃ (M : Set β), G.IsMatching M := by
            exact ⟨∅, by
              -- The empty set is a matching.
