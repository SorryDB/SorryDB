          obtain ⟨M, hM⟩ := h₆
          refine' ⟨M.encard, _⟩
          exact ⟨M, hM, rfl⟩
          ) _
        -- Show that M.encard is an upper bound for the set of encards.
        intro n hn
        obtain ⟨M', hM', rfl⟩ := hn
        exact h₄ M' hM'
      exact h₅
    exact h₃
  -- Combine the two inequalities to get M.encard = ν(G).
  le_antisymm h₁ h₂
