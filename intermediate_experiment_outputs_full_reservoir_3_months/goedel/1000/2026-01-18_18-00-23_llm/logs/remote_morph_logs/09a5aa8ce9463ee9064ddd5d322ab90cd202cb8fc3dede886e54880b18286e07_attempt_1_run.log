namespace ItaLean



/-!
# Filters
-/



section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro P(hP : P ∈ map f G)
  -- Use the fact that the image of G under f contains P to find a set in G whose image under f is P
  rcases hP with ⟨Q, hQ, hQ'⟩
  -- Since F ≤ G, there exists a set in F that is a subset of Q
  have hF : ∃ (R : Set α), R ∈ F ∧ R ⊆ Q := by
    have hG : Q ∈ G := hQ
    have hF : Q ∈ F := h hG
    exact ⟨Q, hF, Set.Subset.refl Q⟩
  -- Obtain the set R in F that is a subset of Q
  rcases hF with ⟨R, hR, hR'⟩
  -- Show that the image of R under f is a subset of P
  have hP' : f '' R ⊆ P := by
    have hQ'' : f '' Q = P := by
      rw [← hQ']
      <;> simp [image]
    have hR'' : f '' R ⊆ f '' Q := by
      apply image_subset_image
      exact hR'
    have hP'' : f '' Q ⊆ P := by
      rw [hQ'']
      <;> simp
    exact Set.Subset.trans hR'' hP''
