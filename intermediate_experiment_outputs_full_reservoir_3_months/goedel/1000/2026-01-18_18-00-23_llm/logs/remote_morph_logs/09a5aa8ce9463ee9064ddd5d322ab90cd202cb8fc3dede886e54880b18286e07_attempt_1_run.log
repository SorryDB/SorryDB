    -- Therefore, S ∈ F.map f because f(T) ⊆ S and T ∈ F
    exact ⟨T, hT_in_F, hT'⟩
  
  -- Now we use h_main to show that F.map f ≤ G.map f
  exact fun S hS => h_main S hS
