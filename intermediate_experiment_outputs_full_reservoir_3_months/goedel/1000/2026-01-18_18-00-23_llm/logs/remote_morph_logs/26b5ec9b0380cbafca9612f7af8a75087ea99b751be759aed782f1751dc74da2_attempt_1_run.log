        -- Choose y i for each i
        choose y hy using h₃
        refine' ⟨y, _⟩
        intro i
        have h₄ : x i ∈ (y i : G i) • A i := hy i
        exact h₄
      -- Obtain y such that x i ∈ (y i) • A i for all i
      obtain ⟨y, hy⟩ := h₁
      -- Define z such that z i = y i for all i
      use y
      intro i
      -- Show that x i ∈ (y i) • A i for all i
      have h₂ : x i ∈ (y i : G i) • A i := hy i
      simpa using h₂
