@[to_additive]
lemma pi {ι : Type*} {G : ι → Type*} [Fintype ι] [∀ i, Group (G i)] {A : ∀ i, Set (G i)} {K : ι → ℝ}
    (hA : ∀ i, IsApproximateSubgroup (K i) (A i)) :
    IsApproximateSubgroup (∏ i, K i) (Set.univ.pi A) where
  one_mem i _ := (hA i).one_mem
  inv_eq_self := by simp [(hA _).inv_eq_self]
  sq_covBySMul := by
    choose F hF hFS using fun i ↦ (hA i).sq_covBySMul
    classical
    refine ⟨Fintype.piFinset F, ?_, ?_⟩
    · calc
        #(Fintype.piFinset F) = ∏ i, (#(F i) : ℝ) := by simp
        _ ≤ ∏ i, K i := by gcongr; exact hF _
    · -- Prove that (Set.univ.pi A)² ⊆ (Fintype.piFinset F) • (Set.univ.pi A)
      intro x hx
      simp only [Set.mem_pi, Set.mem_univ, true_and, Set.mem_image, exists_prop] at hx ⊢
      -- Extract the components of x
      rcases hx with ⟨y, hy, rfl⟩
      -- For each i, use the given condition A i ^ 2 ⊆ F i • A i
      have h : ∀ i, (A i ^ 2 : Set (G i)) ⊆ (F i : Set (G i)) • A i := by
        intro i
        exact hFS i
      -- Show that the product of the subsets is contained in the product of the F i • A i
      have h₁ : (∏ i : ι, (A i : Set (G i)) ^ 2) ⊆ ∏ i : ι, ( (F i : Set (G i)) • A i) := by
        -- Use the fact that each component is contained in the corresponding F i • A i
        apply Set.prod_subset_prod
        intro i _
        exact h i
      -- Relate the product of the subsets to the product of the sets
      have h₂ : (∏ i : ι, (A i : Set (G i)) ^ 2) = (∏ i : ι, (A i : Set (G i))) ^ 2 := by
        -- Show that the product of the squares is the square of the product
        rw [show (∏ i : ι, (A i : Set (G i)) ^ 2) = ∏ i : ι, (A i : Set (G i)) ^ 2 by rfl]
        simp [Set.prod_pow]
        <;>
        simp_all [Set.ext_iff, pow_two, mul_assoc]
        <;>
        aesop
      -- Relate the product of F i • A i to (Fintype.piFinset F) • (Set.univ.pi A)
      have h₃ : (∏ i : ι, ( (F i : Set (G i)) • A i)) = ↑(Fintype.piFinset F) • (∏ i : ι, (A i : Set (G i))) := by
        -- Use the property of products and scalar multiplication
        simp [Set.pi_smul, Set.univ_pi]
        <;>
        simp_all [Set.ext_iff, Finset.prod_const, Fintype.card_finset]
        <;>
        aesop
      -- Combine all the above to get the final result
      simp_all [Set.prod_pow, Set.pi_smul, Set.univ_pi]
      <;>
      aesop
