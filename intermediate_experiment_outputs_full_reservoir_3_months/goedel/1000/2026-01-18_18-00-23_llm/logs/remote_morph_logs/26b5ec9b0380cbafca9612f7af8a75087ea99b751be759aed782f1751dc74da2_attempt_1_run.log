                simp only [Set.mem_pow, Set.mem_prod] at hx ⊢
                specialize hx i
                simp_all [pow_two]
                <;> aesop
              obtain ⟨a, b, ha, hb, hab⟩ := h₅
              exact ⟨a, b, ha, hb, by simp [hab]⟩
            obtain ⟨a, b, ha, hb, hab⟩ := h₄ i
            refine' ⟨a, b, ha, hb, _⟩
            <;> simp_all [pow_two]
            <;> aesop
          have h₃' : x i ∈ A i ^ 2 := h₃
          have h₄ : A i ^ 2 ⊆ (F i : Set (G i)) • A i := by
