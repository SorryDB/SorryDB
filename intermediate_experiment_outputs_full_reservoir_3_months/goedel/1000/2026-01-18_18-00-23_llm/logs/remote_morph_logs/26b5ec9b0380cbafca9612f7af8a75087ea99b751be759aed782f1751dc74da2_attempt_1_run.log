@[to_additive]
lemma pi {ι : Type*} {G : ι → Type*} [Fintype ι] [∀ i, Group (G i)] {A : ∀ i, Set (G i)} {K : ι → ℝ}
    (hA : ∀ i, IsApproximateSubgroup (K i) (A i)) :
    IsApproximateSubgroup (∏ i, K i) (Set.univ.pi A) where
  one_mem i _ := (hA i).one_mem
  inv_eq_self := by simp [(hA _).inv_eq_self]
  sq_covBySMul := by
    choose F hF hFS using fun i ↦ (hA i).sq_covBySMul
    classical
    refine ⟨Fintype.piFinset F, ?_, ?_⟩
    · calc
        #(Fintype.piFinset F) = ∏ i, (#(F i) : ℝ) := by simp
        _ ≤ ∏ i, K i := by gcongr; exact hF _
    · intro x hx
      simp only [Set.mem_pi, Set.mem_univ, forall_true_left] at hx ⊢
      have h1 : ∀ i, (x i) ^ 2 ∈ (F i : Set (G i)) • A i := by
        intro i
        have h2 : (x i) ∈ A i := by
          exact hx i
        have h3 : (x i) ^ 2 ∈ (A i : Set (G i)) ^ 2 := by
          refine' ⟨x i, x i, _⟩ <;> simp_all [pow_two]
          <;>
          (try simp_all [mul_assoc])
          <;>
          (try simp_all [mul_right_inv])
          <;>
          (try simp_all [mul_left_inv])
          <;>
          (try simp_all [one_mul])
          <;>
          (try simp_all [mul_one])
        have h4 : (A i : Set (G i)) ^ 2 ⊆ (F i : Set (G i)) • A i := hFS i
        exact h4 h3
      -- Now we need to show that x^2 is in the product of F_i • A_i
      -- But since each component is in F_i • A_i, the product is in the product of F_i • A_i
      have h2 : ∀ i, (x i) ^ 2 ∈ (F i : Set (G i)) • A i := h1
      -- Use the fact that the product of the F_i • A_i is the product of the F_i • A_i
      have h3 : (∏ i : ι, (x i) ^ 2 : Π i : ι, G i) ∈ (↑(Fintype.piFinset F) • Set.univ.pi A : Set (Π i : ι, G i)) := by
        -- Use the fact that the product of the F_i • A_i is the product of the F_i • A_i
        refine' ⟨fun i => Classical.choose (h2 i), ?_, ?_⟩
        · -- Show that the product of the F_i is in the product of the F_i
          simp_all [Set.mem_pi, Finset.mem_coe, Finset.mem_pi]
          <;>
          (try simp_all [mul_assoc])
          <;>
          (try simp_all [mul_right_inv])
          <;>
          (try simp_all [mul_left_inv])
          <;>
          (try simp_all [one_mul])
          <;>
          (try simp_all [mul_one])
          <;>
          (try aesop)
          <;>
          (try simp_all [Set.mem_smul])
          <;>
          (try aesop)
        · -- Show that the product of the A_i is in the product of the A_i
          simp_all [Set.mem_pi, Finset.mem_coe, Finset.mem_pi]
          <;>
          (try simp_all [mul_assoc])
          <;>
          (try simp_all [mul_right_inv])
          <;>
          (try simp_all [mul_left_inv])
          <;>
          (try simp_all [one_mul])
          <;>
          (try simp_all [mul_one])
          <;>
          (try aesop)
          <;>
          (try simp_all [Set.mem_smul])
          <;>
          (try aesop)
          <;>
          (try
            {
              intro i
              have h4 : (x i) ^ 2 ∈ (F i : Set (G i)) • A i := h2 i
              have h5 : (Classical.choose (h2 i)) ∈ F i := by
                simp_all [Set.mem_smul]
                <;>
                (try aesop)
              simp_all [Set.mem_smul]
              <;>
              (try aesop)
            }
          )
      -- Since x^2 is in the product of the F_i • A_i, we are done
      simpa [pow_two] using h3
