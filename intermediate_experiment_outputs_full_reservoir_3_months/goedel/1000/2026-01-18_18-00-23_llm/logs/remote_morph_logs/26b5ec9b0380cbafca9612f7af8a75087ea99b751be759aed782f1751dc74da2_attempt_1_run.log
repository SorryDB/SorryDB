lemma pi {ι : Type*} {G : ι → Type*} [Fintype ι] [∀ i, Group (G i)] {A : ∀ i, Set (G i)} {K : ι → ℝ}
    (hA : ∀ i, IsApproximateSubgroup (K i) (A i)) :
    IsApproximateSubgroup (∏ i, K i) (Set.univ.pi A) where
  one_mem i _ := (hA i).one_mem
  inv_eq_self := by simp [(hA _).inv_eq_self]
  sq_covBySMul := by
    choose F hF hFS using fun i ↦ (hA i).sq_covBySMul
    classical
    refine ⟨Fintype.piFinset F, ?_, ?_⟩
    · calc
        #(Fintype.piFinset F) = ∏ i, (#(F i) : ℝ) := by simp
        _ ≤ ∏ i, K i := by
          apply Finset.prod_le_prod
          · intro i _
            positivity
          · intro i _
            have h₁ : (F i).card ≤ K i := by
              simpa [hF] using hF i
            simpa using h₁
    · intro x hx
      simp only [Set.mem_univ, forall_true_iff, Set.mem_pi, Set.mem_sq, SetLike.mem_coe] at hx ⊢
      obtain ⟨y, z, rfl⟩ := hx
      refine' ⟨fun i => (y i)⁻¹ * z i, _⟩
      ext i
      have h₂ : y i ∈ A i := by simpa using (hx i).trans (by simp)
      have h₃ : z i ∈ A i := by simpa using (hx i).trans (by simp)
      have h₄ : y i * z i ∈ A i ^ 2 := by
        refine' ⟨y i, z i, _, _⟩ <;> simp_all [pow_two]
        <;> aesop
      have h₅ : y i * z i ∈ (F i : Set (G i)) • A i := hFS i h₄
      simp only [Set.mem_smul, Set.mem_univ, forall_true_iff] at h₅ ⊢
      rcases h₅ with ⟨f, hf, a, ha, h₆⟩
      simp_all [← mul_assoc]
      <;>
      (try simp_all [mul_assoc]) <;>
      (try {
        have h₇ : f * a = y i * z i := by simp_all [← mul_assoc]
        have h₈ : (y i)⁻¹ * z i = (y i)⁻¹ * z i := rfl
        simp_all [mul_assoc, mul_right_inv]
        <;>
        (try {
          have h₉ : a = (y i)⁻¹ * z i := by
            have h₁₀ : f * a = y i * z i := by simp_all [← mul_assoc]
            have h₁₁ : f ∈ (F i : Set (G i)) := by simpa using hf
            simp_all [mul_assoc, mul_right_inv]
            <;> aesop
          simp_all [h₉]
          <;> aesop
        })
        <;>
        aesop
      }) <;>
      aesop
