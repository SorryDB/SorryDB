    obtain ⟨m, ⟨_, ⟨_, rfl⟩, _⟩, _⟩ := hx
    have h₂ : p.Prime → m.factorization p = 0 := by
      intro h_prime
      have h₃ : m.factorization p = 0 := by
        have h₄ : ¬p ∣ m := by
          by_contra h_dvd
          have h₅ : p ∣ m := h_dvd
          have h₆ : m ∈ (P.n / P.L).smoothNumbers := by aesop
          have h₇ : p ≤ P.n / P.L := by
            have h₈ : m ∈ (P.n / P.L).smoothNumbers := by aesop
            have h₉ : p ≤ P.n / P.L := by
              have h₁₀ : p ∣ m := h₅
              have h₁₁ : m ∈ (P.n / P.L).smoothNumbers := by aesop
              have h₁₂ : p ≤ P.n / P.L := by
                simp [Nat.mem_smoothNumbers] at h₁₁
                have h₁₃ : ∀ (q : ℕ), q.Prime → q ∣ m → q ≤ P.n / P.L := by
                  intro q hq_prime hq_dvd
                  simp_all [Nat.mem_smoothNumbers]
                  <;> aesop
                exact h₁₃ p (by aesop) h₁₀
              exact h₁₂
            exact h₉
          have h₁₀ : (p : ℝ) > Real.sqrt P.n := by
            -- This is not possible given the assumptions
            have h₁₁ : (p : ℝ) ≤ Real.sqrt P.n := by
              exact_mod_cast hp
            linarith
          linarith
        rw [factorization_eq_zero_iff]
        <;> aesop
      exact h₃
    by_cases h_prime : p.Prime
    · have h₂ := h₂ h_prime
      simp_all [h₂]
    · simp [factorization_eq_zero_iff]
      <;> aesop
  simp only [Factorization.balance, h₁]
  <;> norm_cast
  <;> simp_all [Real.log_le_log]
  <;>
  (try
    {
      have h₂ : (P.M : ℝ) ≥ 0 := by positivity
      have h₃ : Real.log (P.n : ℝ) ≥ 0 := by
        have h₄ : (P.n : ℝ) ≥ 1 := by
          have h₅ : P.n > 0 := by
            have h₆ : P.n > L * L := P.hL
            have h₇ : L > 0 := P.hL_pos
            nlinarith
          norm_cast
          <;> omega
        exact Real.log_nonneg (by
          norm_num
          <;>
          (try norm_cast)
          <;>
          (try omega))
      nlinarith
    })
  <;>
  (try
    {
      norm_num
      <;>
      (try norm_cast)
      <;>
      (try omega)
    })
