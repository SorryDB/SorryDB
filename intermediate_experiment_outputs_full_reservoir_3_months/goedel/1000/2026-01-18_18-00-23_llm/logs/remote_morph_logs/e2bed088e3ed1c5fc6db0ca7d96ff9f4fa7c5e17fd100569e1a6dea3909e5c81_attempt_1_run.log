```lean
@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Since the number of factors $p$ in the initial factorization is at most $M\log n$, this holds.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) : P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have h : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (Real.log P.n) := by

    -- This step uses the fact that the sum of valuations is bounded by the count of multiples,
    -- but for simplicity, we directly use the given condition.
    norm_num [Factorization.a]
    <;>
    simp_all [Params.initial]
    <;>
    norm_num
    <;>
