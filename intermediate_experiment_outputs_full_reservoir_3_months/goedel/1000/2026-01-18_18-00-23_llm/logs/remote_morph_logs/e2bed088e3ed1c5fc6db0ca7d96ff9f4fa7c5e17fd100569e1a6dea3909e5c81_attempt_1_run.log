  -- We use the fact that the score of f' is less than or equal to the score of f.
  have h₁ : (f'.a.card : ℝ) * (Real.log n) ≤ Real.log n.factorial + (f.score L) := by
    have h₂ : (f'.a.card : ℝ) * (Real.log n) = (f'.waste : ℝ) := by
      rw [waste_eq f' hf'_bal]
      <;> ring_nf
      <;> field_simp
      <;> ring_nf
    have h₃ : (f'.waste : ℝ) ≤ Real.log n.factorial + (f.score L) := by
      have h₄ : (f'.waste : ℝ) = (f'.waste : ℝ) := rfl
      have h₅ : (f'.waste : ℝ) ≤ (f.score L : ℝ) := by
        -- Use the fact that the waste of f' is less than or equal to the score of f
        have h₆ : (f'.waste : ℝ) ≤ (f'.score L : ℝ) := by
          have h₇ : (f'.waste : ℝ) = (f'.waste : ℝ) := rfl
          have h₈ : (f'.waste : ℝ) ≤ (f'.score L : ℝ) := by
            -- Use the fact that the waste is less than or equal to the score
            simp [score, hf'_bal]
            <;>
            (try simp_all [Factorization.sum_eq_zero]) <;>
            (try linarith) <;>
            (try norm_num) <;>
            (try ring_nf) <;>
            (try nlinarith)
          linarith
        have h₉ : (f'.score L : ℝ) ≤ (f.score L : ℝ) := by
          -- Use the fact that the score of f' is less than or equal to the score of f
          have h₁₀ : f'.score L ≤ f.score L := by
            -- Use the fact that the score of f' is less than or equal to the score of f
            exact hf'_score
