@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have h₁ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
    have h₂ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
      -- Use the fact that p ≤ sqrt(n) to bound the balance
      have h₃ : p ≤ Real.sqrt P.n := hp
      have h₄ : (p : ℝ) ≤ Real.sqrt P.n := by exact_mod_cast h₃
      have h₅ : (p : ℝ) ≥ 1 := by
        -- Since p is a prime, it is at least 2
        have h₅₁ : p ≥ 1 := by
          by_contra h₅₁
          have h₅₂ : p = 0 := by omega
          simp_all [Nat.cast_eq_zero, Real.sqrt_eq_zero, Nat.cast_nonneg]
          <;> norm_num at * <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ)]
        exact_mod_cast h₅₁
      -- Use the fact that the balance is bounded by M * log n
      have h₆ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
        -- Use the fact that the balance is bounded by M * log n
        have h₇ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
          -- Use the fact that the balance is bounded by M * log n
          calc
            (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
              -- Use the fact that the balance is bounded by M * log n
              have h₈ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := by
                -- Use the fact that the balance is bounded by M * log n
                norm_cast
                <;>
                (try norm_num) <;>
                (try linarith) <;>
                (try simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]) <;>
                (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)])
                <;>
                (try {
                  have h₉ : p ≤ P.n := by
                    by_contra h₉
                    have h₁₀ : P.n < p := by omega
                    have h₁₁ : (p : ℝ) > Real.sqrt P.n := by
                      have h₁₂ : (p : ℝ) > Real.sqrt P.n := by
                        have h₁₃ : (p : ℝ) > Real.sqrt P.n := by
                          apply Real.lt_of_pow_lt_pow_left 2 (by positivity) (by positivity)
                          have h₁₄ : (p : ℝ) > Real.sqrt P.n := by
                            nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                          nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                        exact h₁₃
                      exact h₁₂
                    have h₁₅ : p > Real.sqrt P.n := by exact_mod_cast h₁₁
                    linarith
                  have h₁₆ : p ≤ P.n := by exact_mod_cast h₉
                  have h₁₇ : p ≤ P.n := by exact_mod_cast h₉
                  simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]
                  <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                }) <;>
                (try {
                  have h₉ : p ≤ P.n := by
                    by_contra h₉
                    have h₁₀ : P.n < p := by omega
                    have h₁₁ : (p : ℝ) > Real.sqrt P.n := by
                      have h₁₂ : (p : ℝ) > Real.sqrt P.n := by
                        have h₁₃ : (p : ℝ) > Real.sqrt P.n := by
                          apply Real.lt_of_pow_lt_pow_left 2 (by positivity) (by positivity)
                          have h₁₄ : (p : ℝ) > Real.sqrt P.n := by
                            nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                          nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                        exact h₁₃
                      exact h₁₂
                    have h₁₅ : p > Real.sqrt P.n := by exact_mod_cast h₁₁
                    linarith
                  have h₁₆ : p ≤ P.n := by exact_mod_cast h₉
                  have h₁₇ : p ≤ P.n := by exact_mod_cast h₉
                  simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]
                  <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                })
                <;>
                (try {
                  have h₉ : p ≤ P.n := by
                    by_contra h₉
                    have h₁₀ : P.n < p := by omega
                    have h₁₁ : (p : ℝ) > Real.sqrt P.n := by
                      have h₁₂ : (p : ℝ) > Real.sqrt P.n := by
                        have h₁₃ : (p : ℝ) > Real.sqrt P.n := by
                          apply Real.lt_of_pow_lt_pow_left 2 (by positivity) (by positivity)
                          have h₁₄ : (p : ℝ) > Real.sqrt P.n := by
                            nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                          nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                        exact h₁₃
                      exact h₁₂
                    have h₁₅ : p > Real.sqrt P.n := by exact_mod_cast h₁₁
                    linarith
                  have h₁₆ : p ≤ P.n := by exact_mod_cast h₉
                  have h₁₇ : p ≤ P.n := by exact_mod_cast h₉
                  simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]
                  <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
                })
              exact h₈
            _ = (P.M : ℝ) * Real.log P.n := by rfl
        exact h₇
      exact h₆
    exact h₂
  have h₂ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log P.n := h₁
  -- Cast the result back to natural numbers if necessary
  norm_cast at h₂ ⊢ <;>
  (try simp_all) <;>
  (try norm_num) <;>
  (try linarith)
  <;>
  (try {
    simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]
    <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
  })
  <;>
  (try {
    simp_all [Nat.cast_le, Nat.cast_lt, Real.sqrt_le_iff]
    <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
  })
  <;>
  (try {
