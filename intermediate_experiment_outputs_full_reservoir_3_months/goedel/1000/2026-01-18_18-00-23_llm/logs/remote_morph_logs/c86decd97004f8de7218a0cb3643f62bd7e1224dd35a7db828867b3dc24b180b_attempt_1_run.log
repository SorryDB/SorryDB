theorem tribonacci_recurrence : ∀ (n : ℕ), (α n).succ = α n.succ.succ.succ := by
  intro n
  have h₁ : α n.succ.succ.succ = α n.succ.succ.succ := rfl
  have h₂ : (α n).succ = α n.succ.succ.succ := by
    -- Use the given recurrence relation to prove the identity.
    have h₃ : α n.succ.succ.succ = (α n).succ := by
      -- Prove that α (n + 3) = α n + 1 using the recurrence relation.
      have h₄ : ∀ (n : ℕ), α n.succ.succ.succ = (α n).succ := by
        intro n
        induction n using Nat.strong_induction_on with
        | h n ih =>
          match n with
          | 0 =>
            -- Base case: n = 0
            norm_num [α]
          | 1 =>
            -- Base case: n = 1
            norm_num [α]
          | 2 =>
            -- Base case: n = 2
            norm_num [α]
          | n + 3 =>
            -- Inductive step: assume the statement holds for all m < n + 3, prove for n + 3
            have h₅ := ih (n + 2) (by omega)
            have h₆ := ih (n + 1) (by omega)
            have h₇ := ih n (by omega)
            simp [α, Nat.succ_eq_add_one] at h₅ h₆ h₇ ⊢
            <;> ring_nf at h₅ h₆ h₇ ⊢ <;>
            (try omega) <;>
            (try simp_all [α]) <;>
            (try norm_num) <;>
            (try omega)
      exact h₄ n
    -- Use the proven statement to conclude the proof.
    rw [h₃]
  exact h₂
