instance : IsOrbifold (n + m) (X × Y) where
  locally_modelled := fun ⟨x,y⟩ ↦ by
    let _ := @DTop X _; let _ := @DTop Y _
    let ⟨u, hu, hxu, Γ, u', hu', ⟨du⟩⟩ := hX.locally_modelled x
    let ⟨v, hv, hyv, Γ', v', hv', ⟨dv⟩⟩ := hY.locally_modelled y
    have := @IsOrbifold.locallyCompactSpace X DTop _ ⟨rfl⟩ _ hX
    refine ⟨u ×ˢ v, by
      rw [dTop_prod_eq_prod_dTop_of_locallyCompact_left]; exact hu.prod hv, ⟨hxu, hyv⟩, ?_⟩
    -- Use the fact that the product of two open sets is open
    -- and construct the diffeomorphism for the product space.
    have h₁ : Nonempty (↑(u ×ˢ v) ≃ₗ[ℝ] ↑(u' ×ˢ v')) := by
      -- Construct the diffeomorphism for the product space
      have h₂ : Nonempty (↑u ≃ₗ[ℝ] ↑u') := ⟨du⟩
      have h₃ : Nonempty (↑v ≃ₗ[ℝ] ↑v') := ⟨dv⟩
      -- Use the product of the two diffeomorphisms
      have h₄ : Nonempty (↑(u ×ˢ v) ≃ₗ[ℝ] ↑(u' ×ˢ v')) := by
        obtain ⟨f⟩ := h₂
        obtain ⟨g⟩ := h₃
        refine' ⟨f.prod g⟩
      exact h₄
    -- Show that u' × v' is an open set in Euclidean space
    have h₂ : IsOpen (u' ×ˢ v') := by
      -- The product of two open sets is open
      exact isOpen_prod.mpr ⟨hu', hv'⟩
    -- Use the fact that u' × v' is an open set in Euclidean space
    -- and construct the diffeomorphism
    have h₃ : ∃ (v₁ : Set (Eucl (n + m))), IsOpen v₁ ∧ Nonempty (↑(u ×ˢ v) ≃ₗ[ℝ] ↑v₁) := by
      -- Use the fact that u' × v' is an open set in Euclidean space
      -- and construct the diffeomorphism
      have h₄ : ∃ (v₁ : Set (Eucl (n + m))), IsOpen v₁ ∧ Nonempty (↑(u' ×ˢ v') ≃ₗ[ℝ] ↑v₁) := by
        -- Use the fact that u' × v' is an open set in Euclidean space
        -- and construct the diffeomorphism
        have h₅ : IsOpen (u' ×ˢ v') := h₂
        have h₆ : ∃ (v₁ : Set (Eucl (n + m))), IsOpen v₁ ∧ Nonempty (↑(u' ×ˢ v') ≃ₗ[ℝ] ↑v₁) := by
          -- Use the fact that u' × v' is an open set in Euclidean space
          -- and construct the diffeomorphism
          refine' ⟨u' ×ˢ v', h₅, _⟩
          -- The identity map is a diffeomorphism
          exact ⟨1⟩
        exact h₆
      -- Use the fact that u' × v' is an open set in Euclidean space
      -- and construct the diffeomorphism
      obtain ⟨v₁, hv₁, hv₁'⟩ := h₄
      have h₅ : Nonempty (↑(u ×ˢ v) ≃ₗ[ℝ] ↑v₁) := by
        -- Use the fact that u × v is diffeomorphic to u' × v'
        -- and v' is diffeomorphic to v₁
        obtain ⟨f⟩ := h₁
        obtain ⟨g⟩ := hv₁'
        refine' ⟨g.comp f⟩
      refine' ⟨v₁, hv₁, h₅⟩
    -- Use the fact that u' × v' is an open set in Euclidean space
    -- and construct the diffeomorphism
    obtain ⟨v₁, hv₁, hv₁'⟩ := h₃
    -- Use the fact that u × v is diffeomorphic to v₁
    refine' ⟨v₁, hv₁, _⟩
    -- Use the fact that u × v is diffeomorphic to v₁
    exact hv₁'
