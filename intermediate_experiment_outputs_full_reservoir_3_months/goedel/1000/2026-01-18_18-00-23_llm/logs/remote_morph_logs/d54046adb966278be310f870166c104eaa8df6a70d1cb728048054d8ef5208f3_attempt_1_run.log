theorem transform_transform {α : Type*} [Fintype α] :
    (∑ x : α, ∑ y : α, 1 : ℝ≥0∞) = (Fintype.card α : ℝ≥0∞) * Fintype.card α := by
  calc
    (∑ x : α, ∑ y : α, 1 : ℝ≥0∞) = ∑ x : α, ∑ y : α, (1 : ℝ≥0∞) := rfl
    _ = ∑ x : α, (Fintype.card α : ℝ≥0∞) := by
      apply Finset.sum_congr rfl
      intro x _
      simp [Finset.sum_const, Finset.card_univ]
      <;> norm_cast
    _ = (Fintype.card α : ℝ≥0∞) * Fintype.card α := by
      simp [Finset.sum_const, Finset.card_univ, mul_comm]
      <;> norm_cast
```
