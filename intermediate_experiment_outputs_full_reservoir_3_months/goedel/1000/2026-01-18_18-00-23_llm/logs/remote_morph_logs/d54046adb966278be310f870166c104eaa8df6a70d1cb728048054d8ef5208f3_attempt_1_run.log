lemma probOutput_uniformSelect.finset [Fintype α] [DecidableEq α] (s : Finset α) (x : α) :
    [ = x | $ s] = if x ∈ s then 1 / (s.card : ℝ≥0∞) else 0 := by
  rw [← pmf_eq]
  <;> simp [Finset.card_coe, Finset.mem_coe]
  <;>
  (try
