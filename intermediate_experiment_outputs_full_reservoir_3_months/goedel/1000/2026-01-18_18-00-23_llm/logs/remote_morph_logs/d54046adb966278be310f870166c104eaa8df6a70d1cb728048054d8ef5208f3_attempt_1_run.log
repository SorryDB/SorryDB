```lean
theorem vector_sampleable_probOutput_eq {α : Type} [SampleableType α] :
    ∀ {n : ℕ} {x y : Vector α n}, Pr[=x | $ᵗ (Vector α n)] = Pr[=y | $ᵗ (Vector α n)] := by
  have h1 : ∀ (n : ℕ), ∀ (x y : Vector α n), Pr[=x | Nat.recAux (pure #v[]) (fun m ih => Vector.push <$> ih <*> $ᵗ α) n] = Pr[=y | Nat.recAux (pure #v[]) (fun m ih => Vector.push <$> ih <*> $ᵗ α) n] := by
    intro n
    induction' n with n ih
    · intro x y
      -- Base case: n = 0, all vectors are empty
      have : x = y := by
        have h₁ : Vector.length x = 0 := by
          simp [Vector.length]
        have h₂ : Vector.length y = 0 := by
          simp [Vector.length]
        have h₃ : x = #v[] := by
          have h₄ := congr_arg (fun v => Vector.length v) h₁
          simp at h₄
          <;> cases x <;> simp_all [Vector.length]
        have h₄ : y = #v[] := by
          have h₅ := congr_arg (fun v => Vector.length v) h₂
          simp at h₅
          <;> cases y <;> simp_all [Vector.length]
        rw [h₃, h₄]
      rw [this]
    · intro x y
      -- Inductive step
      have h₂ := ih x.pop y.pop
      simp_all [Nat.recAux, Vector.get]
      <;>
      (try simp_all [Vector.ext_iff]) <;>
      (try
        {
          simp_all [Vector.ext_iff, Pr[=x | p], SPMF.bind_apply, SPMF.map_apply,
            SPMF.support, SampleableType.mem_support_selectElem]
          <;>
          norm_num
          <;>
          aesop
        }) <;>
      (try
