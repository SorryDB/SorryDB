      aesop
    })
  <;>
  (try
    {
      simp_all [Finset.card_coe]
      <;>
      norm_cast
      <;>
      field_simp
      <;>
      ring
      <;>
      simp_all [Finset.card_coe]
      <;>
      aesop
    })
```
