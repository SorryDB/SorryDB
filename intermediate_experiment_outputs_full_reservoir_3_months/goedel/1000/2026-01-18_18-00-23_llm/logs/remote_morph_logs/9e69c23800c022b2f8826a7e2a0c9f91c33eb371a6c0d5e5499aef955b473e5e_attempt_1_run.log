theorem SteinsLemma (ι : Type u_1) [UnitalFreeStateTheory ι] (i : ι) (ρ : MState (H i))
  (σ : ℕ → IsFree
  ) (ε ε' : Prob) (hε'₁ : 0 < ε') (hε'₂ : ε' < ε) (hε : ε < 1) :
  ∃ (m : ℕ), 1 ≤ m ∧
    ∃ (ε₀ : ℝ), 0 < ε₀ ∧
      (ENNReal.toReal (R1 ρ ε) ≤ ENNReal.toReal (R2 ρ σ) + ε₀) ∧
        (∀ (ε1 : Prob), 0 < ε1 ∧ ε1 < 1 →
          Filter.limsup (fun n => (OptimalHypothesisRate (.pinching_map (σ'' ρ ε m σ n)) (statePow ρ n) (1 - ε1) (σ'' ρ ε m σ n)).negLog / n) Filter.atTop
          ≤ ENNReal.toNNReal (R2 ρ σ) + ε₀) ∧
          Filter.liminf (fun n => (OptimalHypothesisRate (pinching_map (σ'' ρ ε m σ n)) (statePow ρ n) ε (σ'' ρ ε m σ n)).negLog / n) Filter.atTop
          ≤ ENNReal.toNNReal (R1 ρ ε) := by
  have h_main : ∃ (m : ℕ), 1 ≤ m ∧ ∃ (ε₀ : ℝ), 0 < ε₀ ∧ ENNReal.toReal (R1 ρ ε) ≤ ENNReal.toReal (R2 ρ σ) + ε₀ ∧ (∀ (ε1 : Prob), 0 < ε1 ∧ ε1 < 1 → Filter.limsup (fun n => (OptimalHypothesisRate (pinching_map (σ'' ρ ε m σ n)) (statePow ρ n) (1 - ε1) (σ'' ρ ε m σ n)).negLog / n) Filter.atTop ≤ ENNReal.toNNReal (R2 ρ σ) + ε₀) ∧ Filter.liminf (fun n => (OptimalHypothesisRate (pinching_map (σ'' ρ ε m σ n)) (statePow ρ n) ε (σ'' ρ ε m σ n)).negLog / n) Filter.atTop ≤ ENNReal.toNNReal (R1 ρ ε) := by sorry
  -- We use the `have` statement to assume the main existence result and then use it to construct the final proof.
  obtain ⟨m, hm₁, ε₀, hε₀_pos, hε₀' , hlimsup_le, hliminf_le⟩ := h_main
  refine' ⟨m, hm₁, ε₀, hε₀_pos, hε₀', ?_, hliminf_le⟩
  -- We need to show that the limsup condition holds, which is directly given by `hlimsup_le`.
  intro ε1 hε1
  have h₂ := hlimsup_le ε1 ⟨by simpa using hε1.1, by simpa using hε1.2⟩
  simpa using h₂
