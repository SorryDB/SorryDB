partial def select
  (k : Nat) (xs : List a) (ok : k ≤ xs.length) : a :=
  match partition3 (pivot xs) xs with
  | (us, vs, ws) =>
    let m := us.length
    let n := vs.length
    if         h₁ : k ≤ m then select k us (by
      have h₃ : k ≤ xs.length := ok
      have h₄ : m ≤ xs.length := by
        simp [m]
        have h₅ : us.length ≤ xs.length := by
          have h₅₁ : us.length ≤ (us ++ vs ++ ws).length := by
            simp [List.length_append]
            <;> omega
          have h₅₂ : (us ++ vs ++ ws).length = xs.length := by
            simp [partition3]
          linarith
        exact h₅
      have h₅ : k ≤ m := h₁
      have h₆ : m ≤ xs.length := by assumption
      omega
    )
    else if h₂ : k ≤ m + n then vs[k - m - 1]'(by
      have h₃ : k ≤ xs.length := ok
      have h₄ : m + n ≤ xs.length := by
        simp [m, n]
        have h₅ : (us.length + vs.length) ≤ xs.length := by
          have h₅₁ : (us.length + vs.length) ≤ (us ++ vs ++ ws).length := by
            simp [List.length_append]
            <;> omega
          have h₅₂ : (us ++ vs ++ ws).length = xs.length := by
            simp [partition3]
          linarith
        omega
      have h₅ : k ≤ m + n := h₂
      have h₆ : m + n ≤ xs.length := by assumption
      have h₇ : k - m - 1 < vs.length := by
        have h₇₁ : k ≤ m + n := h₂
        have h₇₂ : ¬k ≤ m := h₁
        have h₇₃ : m < k := by omega
        have h₇₄ : k - m ≤ n := by omega
        have h₇₅ : k - m - 1 < vs.length := by
          have h₇₅₁ : vs.length = n := by simp [n]
          have h₇₅₂ : k - m - 1 < n := by
            omega
          omega
        exact h₇₅
      omega
    )
    else if k > m + n then select (k - m - n) ws (by
      have h₃ : k ≤ xs.length := ok
      have h₄ : m + n ≤ xs.length := by
        simp [m, n]
        have h₅ : (us.length + vs.length) ≤ xs.length := by
          have h₅₁ : (us.length + vs.length) ≤ (us ++ vs ++ ws).length := by
            simp [List.length_append]
            <;> omega
          have h₅₂ : (us ++ vs ++ ws).length = xs.length := by
            simp [partition3]
          linarith
        omega
      have h₅ : ¬k ≤ m + n := h₂
      have h₆ : m + n < k := by omega
      have h₇ : k - m - n ≤ ws.length := by
        have h₇₁ : k ≤ xs.length := ok
        have h₇₂ : m + n < k := by omega
        have h₇₃ : (us ++ vs ++ ws).length = xs.length := by simp [partition3]
        have h₇₄ : (us ++ vs ++ ws).length = us.length + vs.length + ws.length := by
          simp [List.length_append]
          <;> omega
        have h₇₅ : m + n + ws.length = xs.length := by
          simp [m, n] at *
          <;> linarith
        have h₇₆ : k - m - n ≤ ws.length := by
          omega
        exact h₇₆
      omega
