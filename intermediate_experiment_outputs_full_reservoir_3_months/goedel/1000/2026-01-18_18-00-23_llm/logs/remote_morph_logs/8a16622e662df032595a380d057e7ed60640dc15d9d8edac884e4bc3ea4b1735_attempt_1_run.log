partial def select
  (k : Nat) (xs : List a) (ok : k ≤ xs.length) : a :=
  match partition3 (pivot xs) xs with
  | (us, vs, ws) =>
    let m := us.length
    let n := vs.length
    if         h₁ : k ≤ m then select k us (by sorry)
    else if h₂ : k ≤ m + n then vs[k - m - 1]'(by sorry)
    else if k > m + n then select (k - m - n) ws (by
      -- Prove that k - m - n ≤ ws.length
      have h₃ : m + n = us.length + vs.length := by rfl
      have h₄ : m + n < us.length + vs.length + ws.length := by
        have h₅ : 0 < us.length + vs.length + ws.length := by
          have h₆ : us.length + vs.length + ws.length = xs.length := by
            simp [partition3, List.length_append, List.length_filter_le]
            <;> rfl
          have h₇ : xs.length ≥ 1 := by
            have h₈ : k ≤ xs.length := ok
            have h₉ : ¬k ≤ m := h₁
            have h₁₀ : ¬k ≤ m + n := h₂
            by_contra h₁₁
            simp_all [h₆]
            <;> omega
          omega
        omega
      have h₆ : k ≤ xs.length := ok
      have h₇ : xs.length = us.length + vs.length + ws.length := by
        simp [partition3, List.length_append, List.length_filter_le]
        <;> rfl
      have h₈ : k > m + n := by omega
      have h₉ : k - m - n ≤ ws.length := by
        have h₁₀ : k ≤ us.length + vs.length + ws.length := by
          omega
        have h₁₁ : m + n = us.length + vs.length := by rfl
        have h₁₂ : k > m + n := by omega
        have h₁₃ : k - m - n ≤ ws.length := by
          omega
        exact h₁₃
      exact h₉
    )
