lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  have h₁ : n - 1 < S.length := by
    have h₂ : n - 1 < S.length := by
      -- Use the fact that the number of calls is at least n-1 to make everyone know the secret
      have h₃ : n - 1 < S.length := by
        -- Prove by contradiction
        have h₄ : ∀ (k : ℕ), k ≤ n → n - 1 < S.length := by
          intro k hk
          -- Base case: when k = 0
          induction' k with k ih
          · simp_all [Nat.sub_eq_zero_iff_le]
            <;> omega
          · cases n with
            | zero =>
              simp_all [Nat.sub_eq_zero_iff_le]
              <;> omega
            | succ n =>
              simp_all [Nat.sub_eq_zero_iff_le]
              <;> omega
        have h₅ : n ≤ n := by omega
        have h₆ := h₄ n h₅
        omega
      exact h₃
    exact h₂
  exact h₁
