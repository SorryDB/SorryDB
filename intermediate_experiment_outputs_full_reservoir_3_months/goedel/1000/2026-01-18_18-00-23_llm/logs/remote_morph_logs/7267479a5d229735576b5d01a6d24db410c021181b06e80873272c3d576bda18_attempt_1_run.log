lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  have h₁ : n ≤ S.length + 1 := by
    -- Use the fact that the number of calls needed to make everyone know a secret is at least n - 1
    -- This is because in the worst case, each call only increments the knowledge of one new agent
    -- Therefore, we need at least n - 1 calls to make all n agents know the secret
    -- We derive a contradiction if S.length < n - 1
    by_contra h₂
    -- Assume that S.length < n - 1
    have h₃ : S.length + 1 < n := by omega
    -- This implies S.length + 1 < n
    -- Use the property that all Know (after S) k to find a contradiction
    have h₄ : allKnow (after S) k := h
    -- Consider the number of calls each agent has participated in
    -- If the number of calls is less than n - 1, not all agents can have the secret
    -- We use the handshaking lemma to bound the number of calls
    have h₅ : n ≤ 0 := by
      -- Calculate the total number of calls participated by all agents
      -- and compare it to the number of possible pairs
      -- If S.length < n - 1, then the sum of calls is less than n(n - 1)/2
      -- which is a contradiction because we need at least n(n - 1)/2 calls to make everyone know the secret
      have h₆ := h₄
      have h₇ : n = 0 := by
        -- Use the fact that after S, all agents know the secret
        -- and the number of calls is less than n - 1 to derive a contradiction
        cases n with
        | zero => simp_all
        | succ n =>
          exfalso
          -- For n ≥ 1, we can find at least one agent who hasn't the secret in less than n - 1 calls
          -- which contradicts the assumption that all agents know the secret
          have h₈ : (Fin.last n : Fin (n + 1)) = Fin.last n := rfl
          have h₉ : allKnow (after S) k := h₄
          simp_all [allKnow, after, initialState, makeCalls]
