    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ‚Č§ hM.restrict‚āā hM') :
    Disjoint (C.edgeSet ‚ą© M) (C.edgeSet ‚ą© M') := by
  have h1 : Disjoint (C.edgeSet ‚ą© M) (C.edgeSet ‚ą© M') := by
    rw [Set.disjoint_iff_inter_eq_empty]
    have h2 : (C.edgeSet ‚ą© M) ‚ą© (C.edgeSet ‚ą© M') = ‚ąÖ := by
      -- We need to show that the intersection of these two sets is empty.
      -- For any edge e in (C.edgeSet ‚ą© M) ‚ą© (C.edgeSet ‚ą© M'), we derive a contradiction.
      apply Set.eq_empty_of_forall_not_mem
      intro e he
      -- Extract the conditions from the membership in the intersection.
      have h3 : e ‚ąą C.edgeSet := by tauto
      have h4 : e ‚ąą M := by tauto
      have h5 : e ‚ąą M' := by tauto
      -- Since e is in both M and M', it must belong to the symmetric difference M ‚ąÜ M'.
      -- But hCG tells us that C is a subgraph of the symmetric difference,
      -- which means e cannot be in M ‚ąÜ M' because it is an edge of C.
      have h6 : e ‚ąą (M ‚ąÜ M').1 := by
        -- The symmetric difference M ‚ąÜ M' is the set of edges in exactly one of M or M'.
        simp only [Set.mem_diff, Set.mem_inter_iff] at he ‚äĘ
        -- We check whether e is in M and M', which it is, but then it cannot be in M ‚ąÜ M'.
        by_cases h : e ‚ąą M
        ¬∑ by_cases h' : e ‚ąą M'
          -- Case: e ‚ąą M and e ‚ąą M'
          ¬∑ simp_all [Set.mem_symmDiff]
            <;> tauto
          -- Case: e ‚ąą M and e ‚ąČ M'
          ¬∑ exfalso
            tauto
        -- Case: e ‚ąČ M
        ¬∑ exfalso
          tauto
      -- But since C is a subgraph of the symmetric difference, e cannot be in M ‚ąÜ M'.
      -- This is a contradiction, so no such e exists.
      have h7 : e ‚ąą (M ‚ąÜ M').1 := h6
      have h8 : C ‚Č§ hM.restrict‚āā hM' := hCG
      have h9 : e ‚ąą C.edgeSet := h3
