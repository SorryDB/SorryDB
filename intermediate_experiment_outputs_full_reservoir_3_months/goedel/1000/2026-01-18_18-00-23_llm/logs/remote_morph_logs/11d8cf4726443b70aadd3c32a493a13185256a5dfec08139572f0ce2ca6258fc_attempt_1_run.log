-- Conditional prime ideals
def cond_prime_ideal (W : Set R) : Set (Ideal R) := {
  I : Ideal R | I ‚âÝ ‚ä§ ‚àß ‚àÄ (a b : R),
    (a ‚àà W ‚àß b ‚àà W ‚àß a * b ‚àà I) ‚Üí (a ‚àà I ‚à® b ‚àà I)
}

-- Lemma: If I ‚àà cond_prime_ideal W and a ‚àà W ‚àñ I, then a is not a zero divisor modulo I.
lemma mul_mem_iff_mem_or_mem (W : Set R) (I ‚àà cond_prime_ideal W) (a b : R) (ha : a ‚àà W) (hb : b ‚àà W) :
    a * b ‚àà I ‚Üî a ‚àà I ‚à® b ‚àà I := by
  have h‚ÇÅ : I ‚âÝ ‚ä§ := I.1
  have h‚ÇÇ : ‚àÄ (a b : R), (a ‚àà W ‚àß b ‚àà W ‚àß a * b ‚àà I) ‚Üí (a ‚àà I ‚à® b ‚àà I) := I.2
  constructor
  ¬∑ intro h
    have h‚ÇÉ : a ‚àà W := ha
    have h‚ÇÑ : b ‚àà W := hb
