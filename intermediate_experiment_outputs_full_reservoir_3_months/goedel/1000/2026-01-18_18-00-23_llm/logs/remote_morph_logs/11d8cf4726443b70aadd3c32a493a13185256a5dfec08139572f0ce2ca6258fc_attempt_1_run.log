namespace GlimpseOfLean

def RingEquiv.comp (g : S ‚âÉ+* T) (f : R ‚âÉ+* S) : R ‚âÉ+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    have h1 : g.symm (g (f x)) = f x := by
      apply Eq.symm
      apply Eq.symm
      -- Use the property of inverse functions to simplify the expression
      rw [‚Üê g.symm_apply_apply (f x)]
