      have h‚ÇÑ : a * b ‚àà I := I.mul_mem_right b h‚ÇÉ
      exact h‚ÇÑ
    | inr h =>
      have h‚ÇÉ : b ‚àà I := h
      have h‚ÇÑ : a * b ‚àà I := I.mul_mem_left a h‚ÇÉ
