@[sorryful]
lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h₁ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h₂ : ∀ x : ℝ, x ≠ 0 → Real.sinh (r * x) / x = r * (Real.sinh (r * x) / (r * x)) := by
      intro x hx
      by_cases hr : r = 0
      · simp [hr]
        <;> field_simp [hx]
        <;> ring_nf
      · field_simp [hx, hr]
        <;> ring_nf
        <;> field_simp [ hr ]
        <;> ring_nf
    have h₃ : Tendsto (fun x : ℝ => r * (Real.sinh (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 r) := by
      have h₄ : Tendsto (fun x : ℝ => Real.sinh (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by
        by_cases hr : r = 0
        · -- Case: r = 0
          simp_all [hr]
          <;>
          (try simp_all) <;>
          (try norm_num) <;>
          (try
            {
              have h₅ : ContinuousAt (fun x : ℝ => (0 : ℝ)) (0 : ℝ) := continuousAt_const
              have h₆ : Tendsto (fun x : ℝ => (0 : ℝ)) (𝓝[≠] (0 : ℝ)) (𝓝 (0 : ℝ)) :=
                  (continuousAt_const.tendsto.mono_left nhdsWithin_le_nhds)
              simp_all
            })
        · -- Case: r ≠ 0
          -- Use the known limit lim_{y -> 0} sinh(y)/y = 1
          have h₅ : Tendsto (fun y : ℝ => Real.sinh y / y) (𝓝[≠] 0) (𝓝 1) := by
            have h₆ : Tendsto (fun y : ℝ => Real.sinh y / y) (𝓝[≠] 0) (𝓝 1) := by
              convert (hasDerivAt_sinh (0 : ℝ)).tendsto_slope_zero using 1
              <;>
              (try simp_all) <;>
              (try norm_num) <;>
              (try field_simp [sub_ne_zero]) <;>
              (try ring_nf) <;>
              (try norm_num) <;>
              (try linarith)
            exact h₆
          -- Compose the limit with y = r * x
          have h₆ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by
            have h₇ : ContinuousAt (fun x : ℝ => r * x) 0 := by
              apply ContinuousAt.mul
              · exact continuousAt_const
              · exact continuousAt_id
            have h₈ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝 (r * 0)) :=
              h₇.tendsto.mono_left nhdsWithin_le_nhds
            have h₉ : (r * (0 : ℝ)) ≠ (0 : ℝ) → False := by
              intro h
              simp at h
              <;>
              (try cases hr) <;>
              (try simp_all) <;>
              (try norm_num at h) <;>
              (try linarith)
            by_cases h₁₀ : r * (0 : ℝ) = (0 : ℝ)
            · -- Case: r * 0 = 0
              have h₁₁ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by
                apply tendsto_nhdsWithin_of_tendsto_nhds_of_eventually_within h₈
                filter_upwards [isOpen_ne.mem_nhds (by simp [hr] : (0 : ℝ) ≠ (0 : ℝ))] with x hx
                simp_all [hr] <;>
                (try norm_num) <;>
                (try
