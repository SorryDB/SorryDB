          have h₆ : HasDerivAt (fun x : ℝ => Real.sinh x) (Real.cosh (r * (0 : ℝ))) (r * (0 : ℝ)) := by
            simpa using Real.hasDerivAt_sinh (r * (0 : ℝ))
          have h₇ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) 0 := by
            -- Use the chain rule
            convert HasDerivAt.comp 0 h₆ h₅ using 1 <;> ring_nf <;> simp [mul_assoc]
