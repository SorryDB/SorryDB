lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h₁ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h₂ : (fun x : ℝ => Real.sinh (r * x) / x) = (fun x : ℝ => (Real.sinh (r * x) - 0) / (x - 0)) := by
      funext x
      by_cases hx : x = 0
      · -- If x = 0, the expression is undefined, but we don't care about this case since we're in 𝓝[≠] 0
        simp_all [hx]
      · -- If x ≠ 0, simplify the expression
        field_simp [hx]
        <;> ring_nf
        <;> simp_all [hx]
        <;> linarith
    rw [h₂]
    -- Use the fact that the derivative of sinh(r * x) at x = 0 is r
    have h₃ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) r 0 := by
      -- Differentiate sinh(r * x) using the chain rule
      have h₄ : HasDerivAt (fun x : ℝ => r * x) r 0 := by
        simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
      have h₅ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
        -- Apply the chain rule
        have h₅₁ : HasDerivAt (fun x : ℝ => r * x) r 0 := h₄
        have h₅₂ : HasDerivAt (fun x : ℝ => Real.sinh x) (Real.cosh (r * 0)) (r * 0) := by
          simpa using Real.hasDerivAt_sinh (r * 0)
        have h₅₃ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
          have h₅₄ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
            convert HasDerivAt.comp 0 h₅₂ h₄ using 1 <;>
            simp [mul_comm] <;>
            ring
          exact h₅₄
        exact h₅₃
      convert h₅ using 1 <;> simp [Real.cosh_zero]
      <;> ring
      <;> norm_num
    -- Use the definition of the derivative to get the limit
    have h₆ : Tendsto (fun x : ℝ => (Real.sinh (r * x) - 0) / (x - 0)) (𝓝[≠] 0) (𝓝 r) := by
      convert h₃.tendsto_slope_zero using 1
      <;> simp
      <;> field_simp
      <;> ring_nf
    exact h₆
  exact h₁
```
