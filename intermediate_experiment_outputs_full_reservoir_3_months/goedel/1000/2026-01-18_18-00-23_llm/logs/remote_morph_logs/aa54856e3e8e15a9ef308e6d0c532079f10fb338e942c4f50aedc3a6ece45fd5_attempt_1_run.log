theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  have h₁ : Mono f := by
    rcases hf with ⟨g, hg⟩
    refine' fun W h k h_eq => _
    have h₂ : h ≫ f = k ≫ f := h_eq
    have h₃ : (h ≫ f) ≫ g = (k ≫ f) ≫ g := by rw [h₂]
    have h₄ : h ≫ (f ≫ g) = k ≫ (f ≫ g) := by
      calc
        h ≫ (f ≫ g) = (h ≫ f) ≫ g := by rw [assoc]
        _ = (k ≫ f) ≫ g := by rw [h₃]
        _ = k ≫ (f ≫ g) := by rw [← assoc]
    have h₅ : f ≫ g = id X := hg
    have h₆ : h ≫ (id X) = k ≫ (id X) := by rw [h₄, h₅]
    have h₇ : h = k := by
      calc
        h = h ≫ id X := by simp [id_comp]
        _ = k ≫ id X := by rw [h₆]
        _ = k := by simp [id_comp]
    exact h₇
  
  have h₂ : Epi f := by
    rcases hf with ⟨g, hg⟩
    refine' fun Z h k h_eq => _
    have h₃ : f ≫ h = f ≫ k := h_eq
    have h₄ : (g ≫ f) ≫ h = (g ≫ f) ≫ k := by
      calc
        (g ≫ f) ≫ h = g ≫ (f ≫ h) := by rw [assoc]
        _ = g ≫ (f ≫ k) := by rw [h₃]
        _ = (g ≫ f) ≫ k := by rw [← assoc]
    have h₅ : g ≫ f = id X := by
      calc
        g ≫ f = id X := by
          have h₅₁ : IsIso f := ⟨g, hg⟩
          have h₅₂ : g ≫ f = id X := by
            simp_all [IsIso]
            <;> aesop
          exact h₅₂
        _ = id X := by rfl
    have h₆ : (id X) ≫ h = (id X) ≫ k := by
      calc
        (id X) ≫ h = (g ≫ f) ≫ h := by rw [h₅]
        _ = (g ≫ f) ≫ k := by rw [h₄]
        _ = (id X) ≫ k := by rw [h₅]
    have h₇ : h = k := by
      calc
        h = id X ≫ h := by simp [comp_id]
        _ = id X ≫ k := by rw [h₆]
        _ = k := by simp [comp_id]
    exact h₇
  
  exact ⟨h₁, h₂⟩
