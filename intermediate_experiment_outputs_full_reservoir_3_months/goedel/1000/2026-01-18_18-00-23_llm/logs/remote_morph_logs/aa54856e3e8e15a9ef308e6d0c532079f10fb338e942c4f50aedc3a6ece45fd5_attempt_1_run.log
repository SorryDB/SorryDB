theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  haveI : Inhabited (α := α) := ⟨X⟩
  constructor
  · -- Prove that f is a monomorphism
    have h₁ : Mono f := by
      -- Use the fact that an isomorphism is a monomorphism
      have h₂ : IsIso f := hf
      exact by
        -- Use the property of isomorphisms to show that f is a monomorphism
        have h₃ :Mono f :=Mono.of_left_inverse (by
          -- Obtain the inverse of f
          obtain ⟨g, hg₁, hg₂⟩ := h₂
          -- Use the inverse to show that f is a left inverse
          refine' ⟨g, _⟩
          -- Use the properties of the inverse to show that f is a monomorphism
