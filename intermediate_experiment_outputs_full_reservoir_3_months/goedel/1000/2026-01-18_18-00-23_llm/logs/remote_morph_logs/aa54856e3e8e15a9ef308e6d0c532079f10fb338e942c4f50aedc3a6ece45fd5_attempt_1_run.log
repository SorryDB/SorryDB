theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  refine' ⟨_, _⟩
  · -- Prove that f is a monomorphism
    rcases hf with ⟨g, hg⟩
    intro W h₁ h₂ h₃
    have h₄ : h₁ = h₂ := by
      calc
        h₁ = h₁ ≫ g.inv (by simp [hg.1, hg.2])
        _ = h₃ ≫ g.inv
        _ = h₂ ≫ g.inv (by simp [hg.1, hg.2])
        _ = h₂ := by simp [hg.1, hg.2]
    exact h₄
  · -- Prove that f is an epimorphism
    rcases hf with ⟨g, hg⟩
    intro Z h₁ h₂ h₃
    have h₄ : h₁ = h₂ := by
