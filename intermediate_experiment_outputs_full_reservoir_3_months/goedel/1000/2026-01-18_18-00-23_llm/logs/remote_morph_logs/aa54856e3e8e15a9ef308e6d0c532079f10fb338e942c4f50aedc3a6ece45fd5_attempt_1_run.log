theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  have h₁ : Mono f := by
    obtain ⟨g, hg⟩ := hf
    have h₂ : g ≫ f = id X := by
      simp_all [IsIso]
    have h₃ : f ≫ g = id Y := by
      simp_all [IsIso]
    intro W h k h₄
    have h₅ : h = k := by
      calc
        h = h ≫ (f ≫ g) := by
          rw [h₃]
          simp [id_comp]
        _ = (h ≫ f) ≫ g := by
          rw [← comp_assoc]
        _ = (k ≫ f) ≫ g := by rw [h₄]
        _ = k ≫ (f ≫ g) := by
          rw [comp_assoc]
        _ = k ≫ (id Y) := by rw [h₃]
        _ = k := by simp [comp_id]
    exact h₅
  have h₂ : Epi f := by
    obtain ⟨g, hg⟩ := hf
    have h₃ : g ≫ f = id X := by
      simp_all [IsIso]
    have h₄ : f ≫ g = id Y := by
      simp_all [IsIso]
    intro Z h k h₅
    have h₆ : h = k := by
      calc
        h = (g ≫ f) ≫ h := by
          simp [h₃, id_comp]
        _ = g ≫ (f ≫ h) := by
          rw [← comp_assoc]
        _ = g ≫ (f ≫ k) := by rw [h₅]
        _ = (g ≫ f) ≫ k := by
          rw [comp_assoc]
        _ = (id X) ≫ k := by simp [h₃]
        _ = k := by simp [comp_id]
    exact h₆
  exact ⟨h₁, h₂⟩
