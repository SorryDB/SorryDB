    intro W h k h_eq_k
    have h₂ : h ≫ f = k ≫ f := h_eq_k
    have h₃ : h ≫ f = k ≫ f := by simpa using h₂
    have h₄ : h = k := by
      -- Use the inverse to show that h and k must be equal
      have h₅ : IsIso f := hf
      have h₆ : ∃ (g : Hom Y X), (g ≫ f = id X) ∧ f ≫ g = id Y := by
        -- Extract the inverse of f from the isIso hypothesis
        cases' hf with g hg
        refine' ⟨g, _⟩
        exact ⟨hg.1, hg.2⟩
      obtain ⟨g, hg⟩ := h₆
      have h₇ : h ≫ f ≫ g = k ≫ f ≫ g := by rw [h₃]
      calc
        h = h ≫ f ≫ g := by
          calc
            h = h ≫ id X := by simp
            _ = h ≫ (g ≫ f) := by rw [hg.1]
            _ = (h ≫ f) ≫ g := by rw [assoc]
            _ = (h ≫ f ≫ g) := by simp [assoc]
        _ = k ≫ f ≫ g := by rw [h₇]
        _ = k := by
          calc
            k ≫ f ≫ g = (k ≫ f) ≫ g := by simp [assoc]
            _ = (k ≫ f ≫ g) := by simp [assoc]
            _ = k ≫ (f ≫ g) := by rw [← assoc]
            _ = k ≫ id Y := by rw [hg.2]
            _ = k := by simp
    exact h₄
  have h2 : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by
    intro Z h k h_eq_k
    have h₃ : f ≫ h = f ≫ k := h_eq_k
    have h₄ : f ≫ h = f ≫ k := by simpa using h₃
    have h₅ : h = k := by
      -- Use the inverse to show that h and k must be equal
