theorem iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  have h₁ : Mono f := by
    -- Prove that f is monic
    have h₂ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by
      intro W h k h_eq
      -- Use the fact that f is an isomorphism to cancel it on the right
      have h₃ : IsIso f := hf
      have h₄ : Hom.IsCancelRight f := by
        -- Since f is an isomorphism, it is cancelable on the right
        exact IsIso.isCancelRight h₃
      -- Cancel f from h ≫ f = k ≫ f to get h = k
      exact h₄ h_eq
    -- The above shows that f is monic
    exact h₂
  have h₂ : Epi f := by
    -- Prove that f is epic
    have h₃ : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by
      intro Z h k h_eq
      -- Use the fact that f is an isomorphism to cancel it on the left
      have h₄ : IsIso f := hf
      have h₅ : Hom.IsCancelLeft f := by
        -- Since f is an isomorphism, it is cancelable on the left
        exact IsIso.isCancelLeft h₄
      -- Cancel f from f ≫ h = f ≫ k to get h = k
      exact h₅ h_eq
    -- The above shows that f is epic
    exact h₃
  -- Combine the two results
  exact ⟨h₁, h₂⟩
