theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    @CategoryInContext.Category.Mono α C X Y f ∧ @CategoryInContext.Category.Epi α C X Y f := by
  have h₁ : @CategoryInContext.Category.Mono α C X Y f := by
    have h₂ : IsIso f := hf
    have h₃ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by
      intro W h k h₄
      have h₅ : ∃ (g : Hom Y X), g ≫ f = id X := by
        exact h₂.repr
      obtain ⟨g, h₆⟩ := h₅
      have h₇ : h ≫ f = k ≫ f := h₄
      have h₈ : h = k := by
        calc
          h = h ≫ id X := by simp
          _ = h ≫ (g ≫ f) := by rw [h₆]
          _ = (h ≫ g) ≫ f := by rw [assoc]
          _ = (k ≫ g) ≫ f := by
            have h₉ : h ≫ g = k ≫ g := by
              calc
                h ≫ g = (h ≫ g) ≫ (id Y) := by simp
                _ = (h ≫ g) ≫ (f ≫ g) := by
                  have h₁₀ : f ≫ g = id Y := by
                    have h₁₁ : g ≫ f = id X := h₆
                    have h₁₂ : IsIso f := h₂
                    have h₁₃ : f ≫ g = id Y := by
                      calc
                        f ≫ g = f ≫ g := rfl
                        _ = id Y := by
                          have h₁₄ : IsIso f := h₂
                          have h₁₅ : f ≫ g = id Y := by
                            exact h₁₄.symm_inv g
                          exact h₁₅
                    exact h₁₃
                  rw [h₁₀]
                  <;> simp
                _ = (h ≫ f) ≫ g := by rw [assoc]
                _ = (k ≫ f) ≫ g := by rw [h₇]
                _ = k ≫ g := by rw [assoc]
            rw [h₉]
          _ = k ≫ (g ≫ f) := by rw [assoc]
          _ = k ≫ id X := by rw [h₆]
          _ = k := by simp
      exact h₈
    exact h₃
  have h₂ : @CategoryInContext.Category.Epi α C X Y f := by
    have h₃ : IsIso f := hf
    have h₄ : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by
      intro Z h k h₅
      have h₆ : ∃ (g : Hom Y X), g ≫ f = id X := by
        exact h₃.repr
      obtain ⟨g, h₇⟩ := h₆
      have h₈ : f ≫ h = f ≫ k := h₅
      have h₉ : h = k := by
        calc
          h = id Y ≫ h := by simp
          _ = (g ≫ f) ≫ h := by
            have h₁₀ : g ≫ f = id X := h₇
            have h₁₁ : IsIso f := h₃
            have h₁₂ : (g ≫ f) = id X := h₁₀
            have h₁₃ : (id X : Hom X X) = id X := rfl
            have h₁₄ : (g ≫ f) ≫ h = (id X : Hom X X) ≫ h := by rw [h₁₂]
            have h₁₅ : (id X : Hom X X) ≫ h = h := by simp
            simp_all [h₁₂]
            <;>
            (try simp_all [h₁₂])
            <;>
            (try simp_all [h₁₂])
          _ = g ≫ (f ≫ h) := by rw [assoc]
          _ = g ≫ (f ≫ k) := by rw [h₈]
          _ = (g ≫ f) ≫ k := by rw [assoc]
          _ = id X ≫ k := by
            have h₁₀ : g ≫ f = id X := h₇
            rw [h₁₀]
          _ = k := by simp
      exact h₉
    exact h₄
  exact ⟨h₁, h₂⟩
