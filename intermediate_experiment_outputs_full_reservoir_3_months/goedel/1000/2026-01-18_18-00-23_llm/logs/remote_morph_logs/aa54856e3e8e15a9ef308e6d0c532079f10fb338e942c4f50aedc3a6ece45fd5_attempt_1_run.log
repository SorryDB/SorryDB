      calc
        h₁ = h₁ ≫ (1 : Hom Y Y) := by simp
        _ = h₁ ≫ (f ≫ g) := by
          simp [hg]
          <;> simp_all [Hom.ext_iff]
          <;> aesop
        _ = (h₁ ≫ f) ≫ g := by
          simp [comp_assoc]
        _ = (h₂ ≫ f) ≫ g := by rw [h₃]
