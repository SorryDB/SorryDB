def BoundedUniformlyHasTendstoEquiv {α : Type*} [PseudoMetricSpace α] (u : ℕ → α) : Prop :=
  Bounded u ∧ Tendsto u Filter.atTop Filter.atTop (fun n m ↦ dist (u n) (u m) < 1)

theorem tendsto_of_bounded_and_has_tendsto_equiv {α : Type*} [PseudoMetricSpace α] [BoundedSpace α]
  {u : ℕ → α} : BoundedUniformlyHasTendstoEquiv u → Tendsto u Filter.atTop (𝓝' ( lim u )) :=
  by
  intro h
  have h₁ : Bounded u := h.1
  have h₂ : Tendsto u Filter.atTop Filter.atTop (fun n m ↦ dist (u n) (u m) < 1) := h.2
  have h₃ : CauchySeq u := by
    have h₄ : ∀ ε > 0, ∃ N, ∀ n m ≥ N, dist (u n) (u m) < ε := by
      intro ε εpos
      obtain ⟨N, hN⟩ := Metric.tendsto_atTop_atTop.mp h₂ (min 1 ε) (by positivity)
      use N
      intro n m hn hm
      have h₅ : dist (u n) (u m) < min 1 ε := hN n m hn hm
      have h₆ : dist (u n) (u m) < ε := lt_of_lt_of_le h₅ (min_le_right 1 ε)
      exact h₆
    exact Metric.cauchySeq_iff.mpr h₄
  have h₅ : Tendsto u Filter.atTop (𝓝 (lim u)) := by
    have h₆ : CauchySeq u := h₃
    have h₇ : Tendsto u Filter.atTop (𝓝 (lim u)) := by
      -- Use the fact that every Cauchy sequence in a complete space converges to its limit
      have h₈ : ∃ x, Tendsto u Filter.atTop (𝓝 x) := complete_of_bounded h₁.isComplete.exists_convergent_subsequence_of_bounded h₁
      obtain ⟨x, hx⟩ := h₈
      have h₉ : lim u = x := by
        -- Use the uniqueness of limits in a Hausdorff space
        have h₁₀ : Tendsto u Filter.atTop (𝓝 x) := hx
        have h₁₁ : Tendsto u Filter.atTop (𝓝 (lim u)) := by
          -- Use the fact that the limit of the sequence exists
          have h₁₂ : lim u = x := by
            -- Use the uniqueness of limits in a Hausdorff space
            have h₁₃ : Tendsto u Filter.atTop (𝓝 x) := hx
            have h₁₄ : Tendsto u Filter.atTop (𝓝 (lim u)) := by
              -- Use the fact that the limit of the sequence exists
              exact Metric.tendsto_atTop_atTop.mp h₂ 1 (by norm_num)
            -- Use the uniqueness of limits in a Hausdorff space
            have h₁₅ : x = lim u := by
              apply tendsto_nhds_unique h₁₃ h₁₄
            rw [h₁₅]
          rw [h₁₂]
          exact hx
        -- Use the uniqueness of limits in a Hausdorff space
        have h₁₆ : x = lim u := by
          apply tendsto_nhds_unique hx h₁₁
        rw [h₁₆]
      -- Use the fact that the limit of the sequence exists
      have h₁₇ : Tendsto u Filter.atTop (𝓝 x) := hx
      have h₁₈ : Tendsto u Filter.atTop (𝓝 (lim u)) := by
        -- Use the fact that the limit of the sequence exists
        rw [h₉] at *
        exact hx
      exact h₁₈
    exact h₇
  exact h₅.mono_left nhdsWithin_le_nhds
