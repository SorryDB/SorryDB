  have h₁ : TestCircuitProofStart.UnfoldTest2.TestSpec p input (eval env ()) := by trivial
  have h₂ : TestCircuitProofStart.UnfoldTest2.TestSpec p input (eval env ()) := by trivial
  exact ⟨h₁, h₂⟩
``` 

