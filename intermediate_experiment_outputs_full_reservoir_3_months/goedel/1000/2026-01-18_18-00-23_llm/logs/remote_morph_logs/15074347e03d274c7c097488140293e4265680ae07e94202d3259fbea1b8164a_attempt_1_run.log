theorem achievesRate_0 (Λ : CPTPMap d₁ d₂) : Λ.AchievesRate 0 := by
  intro ε hε
  use 1, zero_lt_one, 1, default
  constructor
  · have : Nonempty d₁ := by
      have h : Nonempty (CPTPMap d₁ d₂) := by infer_instance
      -- Since we have an instance of CPTPMap d₁ d₂, d₁ must be nonempty because CPTPMap is empty otherwise.
      exact by
        cases' h with m
        -- If CPTPMap d₁ d₂ is nonempty, then d₁ must be nonempty because there is a map from d₁ to d₂.
        infer_instance
    -- Use the fact that d₁ is nonempty to infer the identity map is a CPTPMap from d₁ to d₁.
    infer_instance
  · have : Real.logb 2 (1 : ℕ) = 0 := by norm_num [Real.logb_eq_iff_rpow_eq]
    have h₁ : Real.logb 2 (1 : ℕ) ≥ (0 : ℝ) * 1 := by
      have h₂ : Real.logb 2 (1 : ℕ) = 0 := by norm_num [Real.logb_eq_iff_rpow_eq]
      rw [h₂]
      <;> norm_num
    simp_all [Real.logb_eq_iff_rpow_eq]
    <;>
    (try norm_num) <;>
    (try linarith) <;>
    (try
      {
        have h₃ : Real.logb 2 (1 : ℕ) = 0 := by norm_num [Real.logb_eq_iff_rpow_eq]
        simp_all [h₃]
        <;> norm_num
        <;> linarith
      })
  <;>
  (try
    {
      norm_num [CPTPMap.εApproximates] at *
      <;>
      (try
        {
          intro ρ
          have h₂ : (default : CPTPMap (Fin 1) (Fin 1)).fidelity (default : CPTPMap (Fin 1) (Fin 1)) = 1 := by
            simp [CPTPMap.fidelity]
          have h₃ : (1 : ℝ) - ε ≤ 1 := by linarith
          simpa [h₂, h₃] using le_of_lt (by linarith)
        })
      <;>
      (try
        {
          aesop
        })
    })
