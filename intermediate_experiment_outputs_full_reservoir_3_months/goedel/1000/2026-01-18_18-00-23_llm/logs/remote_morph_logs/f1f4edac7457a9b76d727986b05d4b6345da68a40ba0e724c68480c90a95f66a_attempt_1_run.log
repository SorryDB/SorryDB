lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  have h3 : ctble V := by
    -- Use the fact that U and V are in bijection and U is countable to deduce that V is countable.
    have h4 : Nonempty (U ≃ V) := by
      -- Obtain the equivalence from h1
      have h5 : U ≃ V := h1
      exact ⟨h5⟩
    -- Use the equivalence to get an injective function from U to V
    obtain ⟨e⟩ := h4
    -- Use the fact that the image of a countable set under an injective function is countable
    have h6 : ctble V := by
      -- Since U is countable and e is bijective, V is countable
      have h7 : ctble U := h2
      have h8 : Function.Bijective e := e.bijective
      -- Use the bijectivity to deduce countability
      have h9 : ctble V := by
        -- Use the fact that the cardinality of V is the same as that of U
        have h10 : Cardinal.ofType V = Cardinal.ofType U := by
          -- Since e is a bijection, the cardinalities are equal
          rw [← Cardinal.ofEquiv e.invFun]
          <;> simp [Cardinal.ofEquiv]
          <;> rw [Cardinal.cardinal_congr e.symm]
        -- Use the countability of U to deduce countability of V
        have h11 : Cardinal.ofType U < Cardinal.aleph0 := by
          -- Since U is countable, its cardinality is less than aleph0
          simpa [Cardinal.aleph0] using h2
        -- Conclude that V is countable
        have h12 : Cardinal.ofType V < Cardinal.aleph0 := by
          rw [h10] at *
          exact h11
        -- Use the cardinality condition to deduce countability
        simpa [Cardinal.aleph0] using h12
      -- Conclude the proof
      exact h9
    -- Conclude the proof
    exact h6
  -- Conclude the proof
