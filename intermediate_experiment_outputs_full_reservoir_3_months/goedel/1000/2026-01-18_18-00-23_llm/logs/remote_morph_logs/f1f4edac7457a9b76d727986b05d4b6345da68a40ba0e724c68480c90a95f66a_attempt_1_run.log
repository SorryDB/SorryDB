lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  have h : ∀ n : ℕ, fnz ((2 * n + 1 : ℕ)) = -((n + 1 : ℕ) : ℤ) := by
    intro n
    induction n with
    | zero => simp [fnz]
    | succ n ih =>
      simp_all [fnz, Nat.succ_eq_add_one, mul_add, add_mul, add_assoc]
      <;> ring_nf at *
      <;> norm_num at *
      <;> linarith
  simpa using h k

-- 2.
lemma fnz_fzn : fnz ∘ fzn = id  := by
  have h : ∀ (n : ℤ), fnz (fzn n) = n := by
    intro n
    cases' n with n n
    · simp [fzn, fnz, Int.ofNat_le]
      <;>
      (try decide) <;>
      (try {
        induction n with
        | zero => simp [fnz]
        | succ n ih =>
          simp_all [fnz, fzn, Int.ofNat_le]
          <;> ring_nf at *
          <;> norm_num at *
          <;> linarith
      }) <;>
      (try {
        simp_all [fnz, fzn, Int.ofNat_le]
        <;> ring_nf at *
        <;> norm_num at *
        <;> linarith
      })
    · simp [fzn, fnz, Int.ofNat_le]
      <;>
      (try decide) <;>
      (try {
        induction n with
        | zero => simp [fnz]
        | succ n ih =>
          simp_all [fnz, fzn, Int.ofNat_le]
          <;> ring_nf at *
          <;> norm_num at *
          <;> linarith
      }) <;>
      (try {
        simp_all [fnz, fzn, Int.ofNat_le]
        <;> ring_nf at *
        <;> norm_num at *
        <;> linarith
      })
  funext n
  simp_all [Function.comp_apply]
  <;>
  (try decide) <;>
  (try {
    cases' n with n n <;>
    simp_all [fnz, fzn, Int.ofNat_le] <;>
    (try { contradiction }) <;>
    (try { linarith }) <;>
    (try {
      induction n with
      | zero => simp_all [fnz, fzn, Int.ofNat_le]
      | succ n ih =>
        simp_all [fnz, fzn, Int.ofNat_le]
        <;> ring_nf at *
        <;> norm_num at *
        <;> linarith
    })
  })

-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  have h : ∀ n : ℕ, tri (n + 1) = tri n + n + 1 := by
    intro n
    simp [tri, Nat.succ_eq_add_one, add_assoc]
    <;> ring_nf
    <;> norm_num
    <;> induction n <;> simp_all [tri, Nat.succ_eq_add_one, add_assoc] <;> ring_nf at * <;> norm_num at * <;> linarith
  apply h

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n m : ℕ, n ≤ m → tri n ≤ tri m := by
    intro n m hnm
    induction' hnm with m hnm IH
    · simp [tri]
    · simp_all [tri_step, tri]
      <;> nlinarith
  exact h2 j k h1

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  apply Set.ext
  intro v
  simp [Set.mem_range, Set.mem_Ran, graph]
  <;>
  aesop

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro h
    apply Set.eq_univ_of_forall
    intro v
    have h1 : v ∈ range f := by
      have h2 : ∃ u : U, f u = v := by
        -- Since f is onto, for every v in V, there exists a u in U such that f(u) = v
        have h3 : ∃ u : U, f u = v := h v
        exact h3
      -- Therefore, v is in the range of f
      obtain ⟨u, hu⟩ := h2
      exact ⟨u, hu⟩
    exact h1
  · -- Prove the backward direction: if range f = Univ V, then f is onto
    intro h
    intro v
    have h1 : v ∈ range f := by
      have h2 : v ∈ (Univ : Set V) := by trivial
      have h3 : (Univ : Set V) = range f := by
        rw [h]
        <;> simp [Set.ext_iff]
      rw [h3] at h2
      exact h2
    -- Since v is in the range of f, there exists a u in U such that f(u) = v
    obtain ⟨u, hu⟩ := h1
    exact ⟨u, by simp_all⟩

-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  have h3 : ctble V := h1.symm.transCtble h2
  exact h3
``` 

