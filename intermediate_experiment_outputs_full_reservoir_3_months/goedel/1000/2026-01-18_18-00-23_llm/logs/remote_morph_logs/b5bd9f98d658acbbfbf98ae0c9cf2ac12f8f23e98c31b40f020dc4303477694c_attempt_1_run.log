  -- Using the property that for any a and b > 0, a = b * (a / b) + (a % b)
  -- We can directly use this property to prove the theorem
  have h₂ : b > 0 := by assumption
  -- Since b > 0, we can use the property to conclude the proof
  omega
``` 

