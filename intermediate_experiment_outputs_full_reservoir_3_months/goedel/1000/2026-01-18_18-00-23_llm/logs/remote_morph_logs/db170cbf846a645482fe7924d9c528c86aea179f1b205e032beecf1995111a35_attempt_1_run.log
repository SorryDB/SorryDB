lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have h1 : V(G, M') ⊆ V(G) := by
      intro x hx
      rcases hx with ⟨e, he, hx⟩
      exact ⟨e, by
        exact hM'.subset he
        <;> aesop⟩
    have h2 : V(G, M') ⊆ V(G, M) := h1.trans hsu
    have h3 : (M'.encard : ℕ∞) ≤ M.encard := by
      calc
        M'.encard = (V(G, M').encard : ℕ∞) := by
