```lean
lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have h₁ : ∀ v : α, v ∈ V(G) → ∀ e ∈ M', e ∈ E(G, v) → e ∈ M := by
      intro v hv e he e_v
      have h₂ : v ∈ V(G, M) := hsu hv
      have h₃ : e ∈ E(G) := hM'.subset he
      have h₄ : v ∈ V(G, e) := by
        simp_all [V, mem_setOf_eq, E, incident]
        <;> aesop
      have h₅ : e ∈ M := by
        have h₅₁ : V(G, e) ∩ V(G, M) ≠ ∅ := by
          have h₅₂ : v ∈ V(G, e) ∩ V(G, M) := ⟨h₄, h₂⟩
          exact ⟨h₅₂⟩
        have h₅₃ : e ∈ M := by
          by_contra h₅₄
          have h₅₅ : Disjoint V(G, e) V(G, M) := hM.disjoint e (by aesop) (by aesop) h₅₄
          have h₅₆ : V(G, e) ∩ V(G, M) = ∅ := h₅₅.inter_eq
          exact Set.eq_empty_iff_forall_not_mem.mpr (fun x hx => h₅₆ hx) ⟨v, ⟨h₄, h₂⟩⟩
        exact h₅₃
      exact h₅
    have h₂ : M' ⊆ M := by
      intro e he
      have h₃ : e ∈ E(G) := hM'.subset he
      have h₄ : ∃ v : α, v ∈ V(G) ∧ e ∈ E(G, v) := by
        have h₅ : (G : Graph α β).E e := h₃
        simp_all [E, mem_setOf_eq]
        <;> aesop
      obtain ⟨v, hv, he_v⟩ := h₄
      have h₅ : e ∈ M := h₁ v hv e he he_v
      exact h₅
    have h₃ : M'.encard ≤ M.encard := by
      refine' encard_le_encard _
      exact h₂
    exact h₃
