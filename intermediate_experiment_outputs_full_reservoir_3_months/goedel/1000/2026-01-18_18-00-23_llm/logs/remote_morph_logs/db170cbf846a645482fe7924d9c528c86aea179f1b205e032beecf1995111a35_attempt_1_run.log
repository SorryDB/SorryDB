      intro v
      refine (encard_le_encard ?_).trans (hM.degree_le_one v)
      rintro e ⟨w, hw⟩
      exact ⟨hw.1, w, hw.2⟩
    have h₂ : M'.encard ≤ M.encard := by
      -- Use the fact that the vertex set of G is a subset of the vertex set of M to bound the size of M'
      have h₃ : M'.encard ≤ M.encard := by
        -- Since every vertex in G is covered by M, the number of edges in any matching M' cannot exceed the number of edges in M
