def is_initial_or_not (P : Nat → Bool) (n : Nat) : Bool :=
  if P n = true then true else false

def isEither (P : Nat → Prop) : Prop := (∃ n : ℕ, P n) ∨ ¬∀ n : ℕ, P n

def isNeither (P : Nat → Prop) : Prop := (∀ n : ℕ, ¬ P n) ∨ (∃ n : ℕ, ¬ P n)

def isTrivial (P : Nat → Prop) : Bool := if ∃ n : ℕ, P n then if ∀ n m : ℕ, P n ↔ P m then true else false else if ∀ n : ℕ, ¬ P n then true else false

def isTrue (b : Bool) : Prop := b = true

def isFalse (b : Bool) : Prop := b = false

def notTrue (b : Bool) : Prop := ¬ (b = true)

def notFalse (b : Bool) : Prop := ¬ (b = false)

def parseBool (b : Bool) : String := if b then "true" else "false"

def ipirrelevant (α : Type) (p : α → Bool) : Bool := if p = (λ _ => true) then true else if p = (λ _ => false) then true else false

theorem t1 : ∀ (b : Bool), b = false ∨ b = true := by
  intro b
  cases b <;> simp <;> aesop

theorem t2 : ∀ (α : Type) (p : α → Bool), (∀ x : α, p x = p x) := by
  intro α p x
  rfl

theorem t3 : ∀ (α : Type) (p : α → Bool), (∃ x : α, p x = true) → (∃ x : α, p x = true) := by
  intro α p h
  exact h

