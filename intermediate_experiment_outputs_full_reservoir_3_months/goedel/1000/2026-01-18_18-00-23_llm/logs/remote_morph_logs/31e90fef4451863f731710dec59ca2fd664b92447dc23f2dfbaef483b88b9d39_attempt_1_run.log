theorem OMR_problem_88606 (P A B : Prop) : if P then A else B := by
  have h₁ : (if P then A else B) ↔ P → A ∧ ¬P → B := by
    apply Iff.intro
    · intro h
      by_cases hP : P
      · -- Case: P is true
        simp_all
        <;> tauto
      · -- Case: P is false
        simp_all
        <;> tauto
    · intro h
      by_cases hP : P
      · -- Case: P is true
        simp_all
        <;> tauto
      · -- Case: P is false
        simp_all
        <;> tauto
  
  have h₂ : (P → A ∧ ¬P → B) := by
    intro hP
    by_cases hP' : P
    · -- Case: P is true
      intro h
      simp_all
      <;> tauto
    · -- Case: P is false
      intro h
      simp_all
      <;> tauto
  
  have h₃ : (if P then A else B) := by
    have h₄ : (if P then A else B) ↔ P → A ∧ ¬P → B := h₁
    have h₅ : (P → A ∧ ¬P → B) := h₂
    have h₆ : (if P then A else B) := by
      by_cases hP : P
      · -- Case: P is true
        simp_all
        <;> tauto
      · -- Case: P is false
        simp_all
        <;> tauto
    exact h₆
  
  exact h₃
