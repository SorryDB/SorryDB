      have h₅ : k = 0 := by omega
      have h₆ : (4 * k + 1) = 1 := by simp [h₅]
      have h₇ : ¬Nat.Prime (4 * k + 1) := by
        rw [h₆]
        decide
      exact h₇ (hk.1)
    omega
  
