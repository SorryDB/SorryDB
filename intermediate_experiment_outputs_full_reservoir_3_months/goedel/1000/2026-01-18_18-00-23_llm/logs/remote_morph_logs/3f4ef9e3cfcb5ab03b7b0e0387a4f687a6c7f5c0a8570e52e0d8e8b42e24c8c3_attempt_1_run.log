theorem trivialInvo_fixedPoints : (fixedPoints (trivialInvo k)).Nonempty := by
  have h : (T k).Nonempty := by
    classical
      have h₁ : 1 ≤ k := by
        have h₂ := hk.out.two_le
        omega
      have h₂ : (1 : ℤ) > 0 := by norm_num
      have h₃ : (k : ℤ) > 0 := by exact_mod_cast Nat.cast_pos.mpr (by omega)
      refine' Set.nonempty_of_mem _
      refine' ⟨⟨(k, 1, 1), _⟩, _⟩
      · -- Prove that (k, 1, 1) is in S k
        simp only [S, Set.mem_setOf_eq]
        have h₄ : (4 : ℤ) * k + 1 > 0 := by linarith
        norm_num [h₄]
        <;>
          (try norm_num) <;>
          (try ring_nf) <;>
          (try
            {
              simp_all [Fact.out, Nat.cast_add, Nat.cast_mul, Nat.cast_ofNat]
              <;> norm_num <;>
                (try omega)
            }) <;>
          (try
            {
              have h₅ := hk.out.one_lt
              have h₆ : (4 : ℤ) * k + 1 > 1 := by
                have h₇ : (k : ℕ) ≥ 1 := by omega
                have h₈ : (4 : ℕ) * k + 1 > 1 := by
                  nlinarith
                exact_mod_cast h₈
              norm_num at h₆ ⊢
              <;>
                (try omega)
            })
      · -- Prove that (k, 1, 1) is in T
        simp only [T, gt_iff_lt, Set.mem_setOf_eq]
        norm_num
        <;>
          (try omega) <;>
          (try
            {
              have h₅ := hk.out.one_lt
              have h₆ : (k : ℕ) ≥ 1 := by omega
              norm_num at h₆ ⊢
              <;>
                (try omega)
            })
  obtain ⟨⟨⟨x, y, z⟩, hS⟩, hT⟩ := h
  refine' ⟨⟨⟨⟨x, y, z⟩, hS⟩, hT⟩, _⟩
  simp_all [trivialInvo]
  <;>
    (try ring_nf) <;>
    (try norm_num) <;>
    (try aesop)
