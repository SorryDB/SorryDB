theorem Factorization.card_bound {n : ℕ} (f : Factorization n) (L : ℕ) : ∃ f' :
    Factorization n, f'.total_imbalance = 0 ∧ (f'.a.card : ℝ) * (Real.log n)
      ≤ Real.log n.factorial + (f.score L) := by
  obtain ⟨f', hf'_bal, hf'_score⟩ := lowest_score f L
  refine' ⟨f', hf'_bal, _⟩
  have h₁ : (f'.a.card : ℝ) * Real.log n ≤ Real.log n.factorial + (f'.score L) := by
    have h₂ : (f'.a.card : ℝ) * Real.log n = (f'.waste : ℝ) := by
      have h₃ : f'.total_imbalance = 0 := hf'_bal
      have h₄ : (f'.waste : ℝ) = (f'.a.card : ℝ) * Real.log n := by
        rw [waste_eq f' hf'_bal]
        <;> simp_all [Factorization.total_imbalance_eq_zero]
        <;> norm_cast
        <;> linarith
      linarith
    have h₃ : (f'.score L : ℝ) = (f'.waste : ℝ) := by
      have h₄ : f'.total_imbalance = 0 := hf'_bal
      have h₅ : (f'.score L : ℝ) = (f'.waste : ℝ) := by
        rw [score_eq hf'_bal L]
        <;> simp_all [Factorization.total_imbalance_eq_zero]
        <;> norm_cast
        <;> linarith
      linarith
    have h₄ : Real.log n.factorial ≥ 0 := by
      apply Real.log_nonneg
      <;>
      (try norm_num) <;>
      (try nlinarith [Nat.factorial_pos n]) <;>
      (try exact_mod_cast Nat.factorial_pos n)
    have h₅ : (f'.waste : ℝ) ≤ (f'.waste : ℝ) + 0 := by linarith
    have h₆ : (f'.a.card : ℝ) * Real.log n ≤ Real.log n.factorial + (f'.score L) := by
      linarith
    linarith
  have h₂ : (f'.score L : ℝ) ≤ (f.score L : ℝ) := by
    exact_mod_cast hf'_score
  linarith
