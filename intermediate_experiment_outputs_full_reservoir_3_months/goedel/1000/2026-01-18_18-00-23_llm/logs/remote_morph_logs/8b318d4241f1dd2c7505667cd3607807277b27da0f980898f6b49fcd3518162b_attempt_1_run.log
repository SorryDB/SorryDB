theorem Factorization.card_bound {n : ℕ} (f : Factorization n) (L : ℕ) : ∃ f' :
    Factorization n, f'.total_imbalance = 0 ∧ (f'.a.card : ℝ) * (Real.log n)
      ≤ Real.log n.factorial + (f.score L) := by
  obtain ⟨f', hf'_bal, hf'_score⟩ := lowest_score f L
  refine ⟨f', hf'_bal, _⟩
  have h₁ : (f'.a.card : ℝ) * Real.log n ≤ Real.log (n.factorial) + (f'.score L) := by
    have h₂ : (f'.a.card : ℝ) * Real.log n = (f'.a.card : ℝ) * Real.log n := rfl
    have h₃ : Real.log (n.factorial) + (f'.score L) = Real.log (n.factorial) + (f'.waste : ℝ) + (f'.a.card : ℝ) * Real.log n := by
      have h₄ : (f'.score L : ℝ) = (f'.waste : ℝ) + (f'.a.card : ℝ) * Real.log n := by
        rw [show (f'.score L : ℝ) = (f'.waste : ℝ) + (f'.a.card : ℝ) * Real.log n by
          have h₅ : (f'.score L : ℝ) = (f'.waste : ℝ) + (f'.a.card : ℝ) * Real.log n := by
            norm_cast
            <;> simp [Factorization.score, Factorization.waste, Finset.sum_range_succ, add_assoc]
            <;> linarith
          exact h₅]
      linarith
    have h₄ : (f'.a.card : ℝ) * Real.log n ≤ Real.log (n.factorial) + (f'.a.card : ℝ) * Real.log n := by
      have h₅ : Real.log (n.factorial) ≥ 0 := Real.log_nonneg (by
        have h₆ : (1 : ℝ) ≤ (n.factorial : ℝ) := by
          norm_cast
          exact Nat.one_le_iff_ne_zero.mpr (Nat.factorial_ne_zero n)
        linarith)
      linarith
    linarith
  have h₂ : (f'.a.card : ℝ) * Real.log n ≤ Real.log (n.factorial) + (f.score L : ℝ) := by
    have h₃ : (f'.score L : ℝ) ≤ (f.score L : ℝ) := by
      norm_cast
      <;> simp_all [Factorization.score, Finset.sum_range_succ, add_assoc]
      <;> linarith
    linarith
  exact h₂
