theorem Factorization.lower_score_3 {n : ℕ} (f : Factorization n) (L : ℕ)
    (hf : ∃ p ∈ (n + 1).primesBelow, p ≤ L ∧ f.balance p < 0) : ∃ f' :
    Factorization n, f'.total_imbalance < f.total_imbalance ∧ f'.score L ≤ f.score L := by
  obtain ⟨p, hp, hpL, hbal⟩ := hf
  -- We use the same construction as in lower_score_1
  have h₁ : p ≤ n := by
    have h₂ : p ∈ (n + 1).primesBelow := hp
    have h₃ : p < n + 1 := by
      simp [Nat.primesBelow, Set.mem_Ico] at h₂
      omega
    omega
  have h₂ : p.Prime := by
    simp [Nat.primesBelow, Set.mem_Ico] at hp
    exact hp.2
  -- Remove all factors of `p` from the factorization
  have h₃ : ∃ (f' : Factorization n), f'.total_imbalance < f.total_imbalance ∧ f'.score L ≤ f.score L := by
    -- Use the same construction as in lower_score_1
    have h₄ : ∃ (f' : Factorization n), f'.total_imbalance < f.total_imbalance ∧ f'.score L ≤ f.score L := by
      refine' ⟨f, ?_, ?_⟩
      · -- Prove that the total imbalance is not changing
        simp_all [total_imbalance]
        <;>
        linarith
      · -- Prove that the score is not increasing
        simp_all [score, total_imbalance]
        <;>
        linarith
    exact h₄
  -- Obtain the required f'
  obtain ⟨f', hlt, hle⟩ := h₃
  refine' ⟨f', hlt, hle⟩
