```lean
{- We define the WignerMatrix typeclass, which encapsulates the properties of a Wigner matrix.
It is used to formalize the statement about the limiting distribution of eigenvalues of Wigner matrices.

This file contains the formalization of the Wigner matrix typeclass and some helpful lemmas for working with it. -}

import Mathlib
import Mathlib.Analysis.Basic
import Mathlib.Probability.Basic
import Mathlib.Combinatorics.Basic
import Mathlib.Algebra.Matrix.Basic

variable {n : ‚Ąē}
variable (őľ őĹ : Measure ‚ĄĚ) [IsProbabilityMeasure őľ] [IsProbabilityMeasure őĹ]
  (hőľ_moments : ‚ąÄ (k : ‚Ąē), Integrable (fun x ‚Ü¶ x^k) őľ)
  (hőĹ_moments : ‚ąÄ (k : ‚Ąē), Integrable (fun x ‚Ü¶ x^k) őĹ)
  (hőľ_mean : integral őľ id = 0) (hőĹ_mean : integral őĹ id = 0)
  (hőľ_var : integral őľ (fun x ‚Ü¶ x^2) = 1)
variable {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} (X : ő© ‚Üí Matrix (Fin n) (Fin n) ‚ĄĚ)

@[ext]
structure isWignerMatrix
    (n : ‚Ąē) (őľ őĹ : Measure ‚ĄĚ) (X : ő© ‚Üí Matrix (Fin n) (Fin n) ‚ĄĚ) (P : Measure ő©) where
  meas : Measurable X
  diag_dist : ‚ąÄ i : Fin n, HasLaw (fun ŌČ ‚Ü¶ X ŌČ i i) őĹ P
  off_diag_dist : ‚ąÄ (i j : Fin n), i ‚Č† j ‚Üí HasLaw (fun ŌČ ‚Ü¶ X ŌČ i j) őľ P
  symm : ‚ąÄ (i j : Fin n), ‚ąÄ (ŌČ : ő©), X ŌČ i j = X ŌČ j i
  indep : ‚ąÄ (i j : Fin n) (h : i ‚Č§ j), ‚ąÄ (k l : Fin n) (h' : k ‚Č§ l),
      (i, j) ‚Č† (k, l) ‚Üí (i, j) ‚Č† (l, k) ‚Üí IndepFun (fun ŌČ ‚Ü¶ X ŌČ i j) (fun ŌČ ‚Ü¶ X ŌČ k l) P

/-- The sample space for an `n x n` Wigner matrix. It is the product of ‚ĄĚ over `Index n`. -/
abbrev WignerSpace (n : ‚Ąē) := Fin (n) √ó Fin (n) ‚Üí ‚ĄĚ

instance (n : ‚Ąē) : MeasurableSpace (WignerSpace n) := by
  infer_instance

Noncomputable def wignerMeasureDist (n : ‚Ąē) : (Fin n √ó Fin n) ‚Üí Measure ‚ĄĚ :=
  fun (ij : Fin n √ó Fin n) =>
    if ij.1 = ij.2 then őĹ else őľ

/-- The probability measure on the sample space `WignerSpace n`, which makes the
coordinate projections independent random variables with distributions given by
`wignerMeasureDist`. -/
noncomputable
def WignerMeasure (n : ‚Ąē) : Measure (WignerSpace n) :=
  Measure.pi (wignerMeasureDist őľ őĹ n)

instance instIsProbabilityMeasure (n : ‚Ąē) : IsProbabilityMeasure (WignerMeasure őľ őĹ n) := by
  rw [WignerMeasure]
  -- apply MeasureTheory.Measure.pi.instIsProbabilityMeasure
  sorry

/-- The function that takes an element of WignerSpace (a map `Fin n √ó Fin n ‚Üí ‚ĄĚ`)
to the corresponding function `(Fin n) ‚Üí (Fin n) ‚Üí ‚ĄĚ` that respects the symmetric structure of Wigner matrices. -/
def wignerMatrixEntryFunction (ŌČ : WignerSpace n) : (Fin n) ‚Üí (Fin n) ‚Üí ‚ĄĚ :=
  fun i j =>
    ŌČ (i, j)

 lemma wignerMatrixEntryFunctionSymmetric (ŌČ : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ŌČ i j = wignerMatrixEntryFunction ŌČ j i := by
  sorry

def wignerMatrixMap' (ŌČ : WignerSpace n) : Matrix (Fin n) (Fin n) ‚ĄĚ :=
  Matrix.of (wignerMatrixEntryFunction ŌČ)

/-- A Wigner matrix is defined as a matrix-valued random variable. -/
noncomputable
def wignerMatrixMap (n : ‚Ąē) : (WignerSpace n) ‚Üí Matrix (Fin n) (Fin n) ‚ĄĚ :=
  fun (ŌČ : WignerSpace n) ‚Ü¶ (wignerMatrixMap' ŌČ)

/-- A Wigner matrix is defined as a matrix-valued random variable, rescaled by 1/‚ąön. -/
noncomputable
def wignerMatrixMapScaled (n : ‚Ąē) : (WignerSpace n) ‚Üí Matrix (Fin n) (Fin n) ‚ĄĚ :=
  fun (ŌČ : WignerSpace n) ‚Ü¶ (1 / Real.sqrt (n : ‚ĄĚ)) ‚ÄĘ (wignerMatrixMap' ŌČ)

/-- For any `(n : ‚Ąē)` the map `wignerMatrixMap` is measurable from `WignerSpace n` to `Matrix (Fin n) (Fin n) ‚ĄĚ` -/
@[fun_prop]
lemma wignerMatrixMapMeasurable (n : ‚Ąē) : Measurable (wignerMatrixMap n) := by
  sorry

/-- For any `(n : ‚Ąē)` the map `wignerMatrixMapScaled` is measurable from `WignerSpace n` to `Matrix (Fin n) (Fin n) ‚ĄĚ` -/
@[fun_prop]
lemma wignerMatrixMapScaledMeasurable (n : ‚Ąē) : Measurable (wignerMatrixMapScaled n) := by
  sorry

/-- For any `(n : ‚Ąē)` the map `wignerMatrixMap` is `AEMeasurable` from `WignerSpace n` to `Matrix (Fin n) (Fin n) ‚ĄĚ` -/
@[fun_prop]
lemma wignerMatrixMapAEMeasurable (n : ‚Ąē) : AEMeasurable (wignerMatrixMap n) := by
  fun_prop

/-- For any `(n : ‚Ąē)` the map `wignerMatrixMap` is `AEMeasurable` from `WignerSpace n` to `Matrix (Fin n) (Fin n) ‚ĄĚ` -/
@[fun_prop]
lemma wignerMatrixMapScaledAEMeasurable (n : ‚Ąē) : AEMeasurable (wignerMatrixMapScaled n) := by
  fun_prop

/-- An `n √ó n` Wigner matrix measure is a measure on `Matrix (Fin n) (Fin n) ‚ĄĚ` which is given by
the pushforward of `WignerMeasure` by the map `wignerMatrixMap`. -/
noncomputable
def wignerMatrixMeasure (n : ‚Ąē) (őľ őĹ : Measure ‚ĄĚ) : Measure (Matrix (Fin n) (Fin n) ‚ĄĚ) :=
  Measure.map (wignerMatrixMap n) (WignerMeasure őľ őĹ n)

/-- The measure `wignerMatrixMeasure` is indeed a ProbabilityMeasure. -/
instance (n : ‚Ąē) : IsProbabilityMeasure (wignerMatrixMeasure n őľ őĹ) := by
  sorry
