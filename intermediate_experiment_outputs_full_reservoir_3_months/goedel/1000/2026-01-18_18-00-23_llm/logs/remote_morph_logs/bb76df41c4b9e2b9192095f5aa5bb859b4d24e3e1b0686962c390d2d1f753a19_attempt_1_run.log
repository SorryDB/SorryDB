```lean
structure CatProduct {α β : Type*} [C : Category α] [D : Category β] : Category (α × β) where
  Hom : (α × β) → (α × β) → Type
  id : ∀ (X : α × β), Hom X X
  comp : ∀ (f : Hom X Y) (g : Hom Y Z), Hom X Z
  id_comp : ∀ (f : Hom X Y), f = id X ≫ f
  comp_id : ∀ (f : Hom X Y), f = f ≫ id Y
  assoc : ∀ (f : Hom X Y) (g : Hom Y Z) (h : Hom Z W), f ≻ g ≻ h = f ≻ (g ≻ h)

instance {α β : Type*} [C : Category α] [D : Category β] : CatProduct α β :=
  {
    Hom := fun X Y => (C.Hom X.1 Y.1) × (D.Hom X.2 Y.2)
    id := fun X => (id X.1, id X.2)
    comp := fun f g => (f.1 ≫ g.1, f.2 ≫ g.2)
    id_comp := fun f => by
      simp_all [id_comp]
      <;> simp_all [Prod.ext_iff]
      <;> aesop
    comp_id := fun f => by
      simp_all [comp_id]
      <;> simp_all [Prod.ext_iff]
      <;> aesop
    assoc := fun f g h => by
      simp_all [assoc]
      <;> simp_all [Prod.ext_iff]
      <;> aesop
  }
```

