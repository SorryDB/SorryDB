lemma injective_hRat :
    Function.Injective j₁ := by
  have h : Function.Injective (↑(Algebra.mulLeft _)) := by
    intro x y hxy
    -- Use the fact that multiplication by a non-zero element is injective
    have h₁ : (1 : D) ≠ 0 := by simp
    simp_all [h₁]
  exact h
```
