```lean
lemma injective_hRat :
    Function.Injective j₁ := by
  have h : Function.Injective j₁ := by
    -- Use the fact that the tensor product of injective homomorphisms is injective.
    -- Since the inclusion of ℤ into ZHat is injective and the identity on ℚ is injective,
    -- their tensor product is injective.
    apply map_injective (Algebra.map_mul_left _)
    <;> simp [mul_comm]
    <;> norm_num
    <;>
    (try decide)
    <;>
    (try
      {
        intro x y hxy
        simp_all [mul_comm]
        <;>
        (try norm_num at *)
        <;>
        (try ring_nf at *)
        <;>
        (try aesop)
      })
  exact h
