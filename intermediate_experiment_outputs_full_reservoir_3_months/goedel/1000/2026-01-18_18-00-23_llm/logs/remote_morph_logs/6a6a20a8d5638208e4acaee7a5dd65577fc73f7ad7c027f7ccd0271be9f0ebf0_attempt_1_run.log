-- (Algebra.TensorProduct.assoc ℤ ℚ 𝓞 ZHat).symm.trans Algebra.TensorProduct.includeLeft

lemma injective_hRat :
    Function.Injective j₁ := by
  have h₁ : Function.Injective (fun x : D => (x : D ⊗[ℤ] ZHat)) := by
    intro x y h
    have h₂ : (x : D ⊗[ℤ] ZHat) = (y : D ⊗[ℤ] ZHat) := h
    have h₃ : (x : D ⊗[ℤ] ZHat) = x ⊗ 1 := by simp [Algebra.map_one]
    have h₄ : (y : D ⊗[ℤ] ZHat) = y ⊗ 1 := by simp [Algebra.map_one]
    rw [h₃] at h₂
    rw [h₄] at h₂
    -- Use the fact that the map is injective if we consider the right factor as 1
    have h₅ : x ⊗ (1 : ZHat) = y ⊗ (1 : ZHat) := h₂
    have h₆ : x = y := by
      -- Use the fact that the tensor product with 1 is injective if the other factor is non-zero
      have h₇ : x ⊗ (1 : ZHat) = y ⊗ (1 : ZHat) := h₅
      have h₈ : x = y := by
        -- Use the fact that the tensor product with 1 is injective if the other factor is non-zero
        have h₉ : (x : D) = (y : D) := by
          -- Since ZHat is nontrivial, the tensor product with 1 is injective
          have h₁₀ : (x : D ⊗[ℤ] ZHat) = (y : D ⊗[ℤ] ZHat) := by
            simpa using h₇
          -- Use the fact that the tensor product with 1 is injective if the other factor is non-zero
          have h₁₁ : (x : D ⊗[ℤ] ZHat) = (y : D ⊗[ℤ] ZHat) := h₁₀
          -- Since ZHat is nontrivial, the tensor product with 1 is injective
          have h₁₂ : (x : D) = (y : D) := by
            -- Use the fact that the tensor product with 1 is injective if the other factor is non-zero
            simp [Algebra.map_one] at h₁₁ ⊢
            <;>
            (try aesop) <;>
            (try simp_all [Algebra.map_one]) <;>
            (try norm_cast at * <;> aesop) <;>
            (try simp_all [Algebra.map_one]) <;>
            (try norm_cast at * <;> aesop)
          exact h₁₂
        exact_mod_cast h₉
      exact h₈
    exact h₆
  -- Now we can use the fact that the map is injective to conclude the proof
  have h₂ : Function.Injective j₁ := by
    intro x y h
    have h₃ : (j₁ : D → D^) x = (j₁ : D → D^) y := by simpa using h
    have h₄ : (x : D^) = (y : D^) := by
      simpa [j₁] using h₃
    have h₅ : x = y := by
