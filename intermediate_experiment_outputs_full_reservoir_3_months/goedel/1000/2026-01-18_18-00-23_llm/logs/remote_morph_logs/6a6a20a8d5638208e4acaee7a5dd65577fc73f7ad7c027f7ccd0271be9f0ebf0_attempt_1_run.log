theorem injective_hRat :
    Function.Injective j₁ := by
  intro x y h
  rw [j₁_apply] at h
  -- Use the fact that the tensor product with ZHat is injective because ZHat is flat over ℤ.
  -- This reduces the problem to checking injectivity in the ring of Hurwitz rationals over ℤ.
  simpa [Algebra.Module.Eq_zero_of_tsum_eq_zero] using
    (Function.Injective.comp (Function.Injective.id _) (by infer_instance : Function.Injective (↑) : _) h)
```
