          have h₉ : (a : D) = (b : D) := by
            -- Use the fact that the tensor product is injective when the RHS is 1
            apply (injective_iff_ne_bot.mpr (by
              -- Show that the kernel of the tensor product with 1 is trivial
              have h₁₀ : Module.rank ℤ ZHat ≥ 1 := by
                -- Since ZHat is nontrivial, its rank is at least 1
                have h₁₁ : Module.rank ℤ ZHat = Cardinal.aleph0 := by
                  -- The rank of ZHat is countably infinite
                  simp [ZHat.rank]
                rw [h₁₁]
                -- Since aleph0 ≥ 1, we are done
                simp [Cardinal.one_le_aleph0]
              have h₁₂ : Module.rank ℤ ZHat ≥ 1 := h₁₀
              -- Use the fact that the rank of ZHat is at least 1 to deduce injectivity
              have h₁₃ : ¬Ideal.span ({(0 : D)} : Set D) = ⊤ := by
                -- The zero ideal is not the whole ring
                intro h₁₄
                have h₁₅ : Ideal.span ({(0 : D)} : Set D) = ⊤ := h₁₄
                have h₁₆ : (0 : D) = (1 : D) := by
                  -- If the zero ideal is the whole ring, then 0 = 1
                  have h₁₇ : (1 : D) ∈ Ideal.span ({(0 : D)} : Set D) := by
                    rw [h₁₅]
