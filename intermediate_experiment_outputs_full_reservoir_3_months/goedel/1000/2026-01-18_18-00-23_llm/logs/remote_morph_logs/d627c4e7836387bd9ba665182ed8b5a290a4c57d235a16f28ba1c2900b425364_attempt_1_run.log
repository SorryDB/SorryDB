lemma indistinguishable_then_same_values {n} {a : @Agent n} {S T: @Dist n} {σ τ : OSequence} :
    (S, σ) ~_a (T, τ)  →  S⌈σ⌉a = T⌈τ⌉a := by
  rcases σ with ⟨σ,o⟩
  rcases τ with ⟨τ,o'⟩
  intro ⟨same_len, equ⟩
  have h_main : S⌈⟨σ,o⟩⌉a = T⌈⟨τ,o'⟩⌉a := by
    have h₁ : S⌈⟨σ, o⟩⌉a = T⌈⟨τ, o'⟩⌉a := by
      classical
      have h₂ : ∀ (n : ℕ) (a : @Agent n) (S T : @Dist n) (σ τ : @OSequence n), (S, σ) ~_a (T, τ) → S⌈σ⌉a = T⌈τ⌉a := by
        intro n
        induction' n with n ih
        · -- Base case: n = 0, no agents or actions are possible
          intro a S T σ τ h
          exfalso
          -- Since there are no agents, the context is vacuously true
          exact (a.elim0)
        · -- Inductive step: assume the statement holds for n, prove for n + 1
          intro a S T σ τ h
          match σ, τ with
          | ⟨[], _⟩, ⟨[], _⟩ =>
            -- Both sequences are empty
            simp_all [OSequence.mk.injEq, OSequence.length, OSequence.maxOne]
            <;>
            (try cases a <;> simp_all [Dist.mk.injEq, Dist.length, Dist.maxOne]) <;>
            (try contradiction) <;>
            (try aesop)
          | ⟨[], _⟩, ⟨c :: τ, _⟩ =>
            -- σ is empty, τ is not
            simp_all [OSequence.mk.injEq, OSequence.length, OSequence.maxOne]
            <;>
            (try cases a <;> simp_all [Dist.mk.injEq, Dist.length, Dist.maxOne]) <;>
            (try contradiction) <;>
            (try aesop)
          | ⟨c :: σ, _⟩, ⟨[], _⟩ =>
            -- σ is not empty, τ is empty
            simp_all [OSequence.mk.injEq, OSequence.length, OSequence.maxOne]
            <;>
            (try cases a <;> simp_all [Dist.mk.injEq, Dist.length, Dist.maxOne]) <;>
            (try contradiction) <;>
            (try aesop)
          | ⟨c :: σ, o⟩, ⟨d :: τ, o'⟩ =>
            -- Both σ and τ are non-empty
            simp_all [OSequence.mk.injEq, OSequence.length, OSequence.maxOne]
            <;>
            (try cases a <;> simp_all [Dist.mk.injEq, Dist.length, Dist.maxOne]) <;>
            (try contradiction) <;>
            (try aesop)
      exact h₂ n a S T ⟨σ, o⟩ ⟨τ, o'⟩ ⟨same_len, equ⟩
    exact h₁
  exact h_main
