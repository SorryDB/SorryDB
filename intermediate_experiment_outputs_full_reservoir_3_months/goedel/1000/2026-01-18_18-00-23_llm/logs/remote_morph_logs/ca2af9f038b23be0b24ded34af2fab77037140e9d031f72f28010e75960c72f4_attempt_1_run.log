@[simp] lemma finSupport_uniformSelectFinset [DecidableEq α] (s : Finset α) :
    ($ s).finSupport = if s.Nonempty then s else ∅ := by
  split_ifs with hs <;> simp only [hs, finSupport_eq_iff_support_eq_coe, support_uniformSelectFinset,
    if_true, if_false, Finset.coe_singleton, Finset.coe_empty]
