    ∃ r', invert r = ok r' ∧
    let r_nat := Field51_as_Nat r % p
    let r'_nat := Field51_as_Nat r' % p
    (r_nat ≠ 0 → (r'_nat * r_nat) % p = 1) ∧
    (r_nat = 0 → r'_nat = 0) ∧
    (∀ i, i < 5 → (r'[i]!).val < 2 ^ 52)
    := by
