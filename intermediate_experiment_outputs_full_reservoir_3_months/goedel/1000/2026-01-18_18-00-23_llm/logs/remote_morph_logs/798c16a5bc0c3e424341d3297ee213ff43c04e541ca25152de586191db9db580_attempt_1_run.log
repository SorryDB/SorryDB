      have h_support : (SimpleGraph.LoopWalk.cons ‹_› ‹_›).supportSet = {v} ∪ (‹_› : G.LoopWalk p ih).supportSet := by
        simp [SimpleGraph.LoopWalk.supportSet]; ext; simp [SimpleGraph.LoopWalk.support]
        <;> aesop
