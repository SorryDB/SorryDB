        <;> aesop
      -- By the induction hypothesis, we know that the cardinality of the support set of the rest of the walk is less than or equal to the cardinality of its edge set plus one.
      have h_ind : (‹_› : G.LoopWalk p ih).supportSet.card ≤ (‹_› : G.LoopWalk p ih).edgeSet.card + 1 := by
        assumption
      -- Consider two cases: whether `v` is in the support set of `p_1` or not.
      by_cases hv : v ∈ (‹_› : G.LoopWalk p ih).supportSet
      · -- Case 1: `v` is in the support set of `p_1`.
        -- The cardinality of `{v} ∪ p_1.supportSet` is equal to the cardinality of `p_1.supportSet`.
        have h_card_union : ({v} ∪ (‹_› : G.LoopWalk p ih).supportSet).card = (‹_› : G.LoopWalk p ih).supportSet.card := by
