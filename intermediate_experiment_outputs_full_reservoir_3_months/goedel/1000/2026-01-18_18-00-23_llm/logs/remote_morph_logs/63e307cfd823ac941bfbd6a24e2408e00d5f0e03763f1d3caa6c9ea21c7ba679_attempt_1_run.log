        -- Define the property φ(n) as 4 < n ∧ ∃ (S : List (Call n)), allExpert (after S) ∧ S.length < 2 * n - 4.
        let φ : ℕ → Prop := fun n => 4 < n ∧ (∃ (S : List (Call n)), allExpert (after S) ∧ S.length < 2 * n - 4)
