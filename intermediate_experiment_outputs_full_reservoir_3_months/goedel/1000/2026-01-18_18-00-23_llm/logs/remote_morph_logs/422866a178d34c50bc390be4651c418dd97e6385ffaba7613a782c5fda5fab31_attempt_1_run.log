  simp_rw [buildLayer]
  have h₁ : HasEvalSPMF.NeverFail (List.Vector.mmap (fun x => liftM (query (x.1, x.2))) (List.Vector.ofFn (fun i => (leaves.get ⟨2 * i, by
      have h₂ : 2 * i < 2 ^ n * 2 := by
        have h₃ : i < 2 ^ n := by
          simp only [Fin.is_lt]
          <;>
          (try omega) <;>
          (try
            {
              simp_all [Vector.get]
              <;>
              ring_nf at *
              <;>
              omega
            })
        have h₄ : 2 * i < 2 ^ n * 2 := by
          have h₅ : i < 2 ^ n := h₃
          nlinarith [pow_pos (by norm_num : (0 : ℕ) < 2) n]
        exact h₄
      have h₅ : 2 * i < 2 ^ (n + 1) := by
        have h₆ : 2 * i < 2 ^ n * 2 := h₂
        have h₇ : 2 ^ n * 2 = 2 ^ (n + 1) := by
          ring_nf
          <;>
          simp [pow_succ]
          <;>
          ring_nf
        rw [h₇] at h₆
        exact h₆
      omega
    ⟩, leaves.get ⟨2 * i + 1, by
      have h₂ : 2 * i + 1 < 2 ^ n * 2 := by
        have h₃ : i < 2 ^ n := by
          simp only [Fin.is_lt]
          <;>
          (try omega) <;>
          (try
            {
              simp_all [Vector.get]
              <;>
              ring_nf at *
              <;>
              omega
            })
        have h₄ : 2 * i + 1 < 2 ^ n * 2 := by
          have h₅ : i < 2 ^ n := h₃
          nlinarith [pow_pos (by norm_num : (0 : ℕ) < 2) n]
        exact h₄
      have h₅ : 2 * i + 1 < 2 ^ (n + 1) := by
        have h₆ : 2 * i + 1 < 2 ^ n * 2 := h₂
        have h₇ : 2 ^ n * 2 = 2 ^ (n + 1) := by
          ring_nf
          <;>
          simp [pow_succ]
          <;>
          ring_nf
        rw [h₇] at h₆
        exact h₆
      omega
    ⟩)))).run preexisting_cache := by
