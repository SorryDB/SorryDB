  have h_main : HasEvalSPMF.NeverFail (((simulateQ randomOracle).toFun (List.Vector α (2 ^ n)) (Vector.mmap (fun x => liftM (query (x.1, x.2))) (List.Vector.ofFn fun i => (leaves.get ⟨2 * ↑i, MerkleTree.buildLayer._proof_4 n i⟩, leaves.get ⟨2 * ↑i + 1, MerkleTree.buildLayer._proof_5 n i⟩)))).run preexisting_cache) := by
    intro
    -- We need to show that the evaluation of the SPMF never fails.
