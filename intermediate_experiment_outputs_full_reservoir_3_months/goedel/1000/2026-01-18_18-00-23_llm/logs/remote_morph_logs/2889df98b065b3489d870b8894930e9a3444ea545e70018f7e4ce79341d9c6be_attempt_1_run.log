theorem GReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ GReal t := by
  have h₁ : DifferentiableAt ℝ GReal t :=
    (show IsOpen {x : ℝ | 0 < x} by
        exact isOpen_lt continuous_const continuous_id)
      .differentiableAt_of_mem ht
      (differentiableOn_const _).div differentiableOn_id (fun x hx => by
        norm_num at hx ⊢
        <;> simp_all [GReal]
        <;> field_simp [Real.differentiableAt_id]
        <;> ring_nf
        <;> norm_num
        <;> linarith)
  exact h₁
  <;> try norm_num
  <;> try ring_nf
  <;> try simp_all [GReal]
  <;> try field_simp [Real.differentiableAt_id]
  <;> try linarith
