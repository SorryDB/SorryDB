theorem GReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ GReal t := by
  have h : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) G := by
    have h₁ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₂ := by
      exact H₂_holo
    have h₂ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) H₄ := by
      exact H₄_holo
    have h₃ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => 2 * H₂ z ^ 2 + 5 * H₂ z * H₄ z + 5 * H₄ z ^ 2) := by
      apply MDifferentiable.add
      · apply MDifferentiable.add
        · exact MDifferentiable.mul (differentiableAt_const _ |>.mdifferentiableAt) (h₁.pow 2)
        · exact MDifferentiable.mul (differentiableAt_const _ |>.mdifferentiableAt) (MDifferentiable.mul h₁ h₂)
      · exact MDifferentiable.mul (differentiableAt_const _ |>.mdifferentiableAt) (h₂.pow 2)
    have h₄ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (fun z : ℂ => H₂ z ^ 3) := by
      exact (h₁.pow 3)
    have h₅ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) G := by
      have h₅₁ : G = (fun z : ℂ => H₂ z ^ 3 * (2 * H₂ z ^ 2 + 5 * H₂ z * H₄ z + 5 * H₄ z ^ 2)) := by
        funext z
        rfl
      rw [h₅₁]
      apply MDifferentiable.mul h₄ h₃
    exact h₅
  -- Use the fact that G is holomorphic to deduce that its real part is differentiable
  have h₂ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t).re) t := by
    -- Use the fact that the real part of a holomorphic function is harmonic
    -- and thus differentiable
    apply DifferentiableAt.comp (ht : (0 : ℝ) < t)
    · -- Show that the map t ↦ it is differentiable
      exact (differentiableAt_id.const_mul (Complex.I : ℂ)).differentiableAt
    · -- Show that the restriction of G to the imaginary axis is holomorphic
      apply (h.restrict (𝓝 (Complex.I * t))).differentiableAt
      <;> simp_all [Complex.ext_iff]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try
        {
          apply IsOpen.mem_nhds
          · exact isOpen_Ioi
          · exact ht
        }) <;>
      (try
        {
          exact inferInstance
        }) <;>
      (try
        {
          apply isOpen_Ioi.mem_nhds
          <;> linarith
        })
  -- Conclude that GReal is differentiable at t
  simpa [GReal] using h₂
