theorem GReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ GReal t := by
  have h₁ : GReal t = (G.resToImagAxis t).re := rfl
  have h₂ : DifferentiableAt ℝ (fun (t : ℝ) => (G.resToImagAxis t).re) t := by
    apply DifferentiableAt.comp (differentiableAt_id : DifferentiableAt ℝ (fun t : ℝ => t) t)
    have h₃ : Differentiable (ℝ) (fun (z : ℂ) => (z : ℂ)) := by
      apply Differentiable.differentiableAt
      apply differentiable_id
    have h₄ : DifferentiableAt (ℝ) (fun (t : ℝ) : ℂ => (t : ℝ) * Complex.I) t := by
      have h₅ : DifferentiableAt ℝ (fun (t : ℝ) => (t : ℝ) * Complex.I) t := by
        apply DifferentiableAt.const_mul
        <;> apply differentiableAt_id
      exact h₅
    apply (G.resToImagAxis.differentiableAt).differentiableWithinAt
  have h₃ : (fun (t : ℝ) => (G.resToImagAxis t).re) = (fun (t : ℝ) => GReal t) := by
    funext t
    simp [GReal]
  rw [h₃] at h₂
  exact h₂
```
