                  <;>
                  (try contradiction) <;>
                  (try simp_all [List.eraseIdx, List.get, Nat.succ_eq_add_one, add_assoc])
                })
            <;> (try
              {
                apply IH
                <;>
                  simp_all [List.get, Nat.succ_eq_add_one, add_assoc]
                <;>
                  (try contradiction)
              })
          exact h₁
