  {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
  l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
  := by
  revert idx1 idx2
  induction hPerm with
  | nil => intro ⟨_, _⟩; contradiction
  | cons x l1 l2 =>
    intro (⟨⟩ | ⟨⟩) (⟨⟩ | ⟨⟩) H
    simp_all [List.get]
    <;>
    (try contradiction) <;>
    (try simp_all [List.Perm]) <;>
    (try permutation) <;>
    (try simp_all [List.eraseIdx_cons]) <;>
    (try permutation) <;>
    (try simp_all [List.Perm]) <;>
    (try permutation)
  | swap x y l =>
    intro (⟨n, hn⟩ : Fin (y :: x :: l).length) (⟨m, hm⟩ : Fin (x :: y :: l).length) H
    have h₁ : (y :: x :: l)[(⟨n, hn⟩ : Fin (y :: x :: l).length)] = (x :: y :: l)[(⟨m, hm⟩ : Fin (x :: y :: l).length)] := H
    have h₂ : n < (y :: x :: l).length := hn
    have h₃ : m < (x :: y :: l).length := hm
    have h₄ : (y :: x :: l).length = (x :: y :: l).length := by simp
    have h₅ : m < (y :: x :: l).length := by simpa [h₄] using h₃
    have h₆ : n < (y :: x :: l).length := hn
    have h₇ : (y :: x :: l).get ⟨n, h₂⟩ = (x :: y :: l).get ⟨m, h₃⟩ := by
      simpa [Fin.ext_iff] using h₁
