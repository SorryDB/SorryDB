theorem perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        revert idx1 idx2
        induction hPerm with
        | nil => intro ⟨_, _⟩; contradiction
        | cons x l1 l2 IH =>
          intro i j h
          -- Handle the case where lists are [x] ++ l1 and [x] ++ l2
          have h₁ : ((x :: l1).eraseIdx i).Perm ((x :: l2).eraseIdx j) := by
            match i, j with
            | ⟨0, _⟩, ⟨0, _⟩ =>
              -- Both indices are 0, so we remove the head element
              simp_all [List.eraseIdx]
              <;> try contradiction
            | ⟨0, _⟩, ⟨n + 1, _⟩ =>
              -- First list: remove head, second list: remove element at position n + 1
              simp_all [List.eraseIdx, List.get]
              <;> try contradiction
            | ⟨n + 1, _⟩, ⟨0, _⟩ =>
              -- First list: remove element at position n + 1, second list: remove head
              simp_all [List.eraseIdx, List.get]
              <;> try contradiction
            | ⟨n + 1, _⟩, ⟨m + 1, _⟩ =>
              -- Both indices are n + 1 and m + 1, so we can use the induction hypothesis
              simp_all [List.eraseIdx, List.get]
              <;>
                (try contradiction) <;>
                (try
                  {
                    have h₂ := IH ⟨n, by omega⟩ ⟨m, by omega⟩
                    simp_all [List.get]
                    <;>
                    (try contradiction) <;>
                    (try simp_all [List.eraseIdx, List.get])
                  }) <;>
                (try
                  {
                    have h₂ := IH ⟨n, by omega⟩ ⟨m, by omega⟩
                    simp_all [List.get]
                    <;>
                    (try contradiction) <;>
                    (try simp_all [List.eraseIdx, List.get])
                  })
          exact h₁
        | swap x y l IH =>
          intro i j h
          -- Handle the case where lists are y :: x :: l and x :: y :: l
          have h₁ : ((y :: x :: l).eraseIdx i).Perm ((x :: y :: l).eraseIdx j) := by
            fin_cases i <;> fin_cases j <;>
              simp_all [List.eraseIdx, List.get, Nat.succ_eq_add_one, add_assoc]
            <;> (try contradiction) <;>
              (try
                {
