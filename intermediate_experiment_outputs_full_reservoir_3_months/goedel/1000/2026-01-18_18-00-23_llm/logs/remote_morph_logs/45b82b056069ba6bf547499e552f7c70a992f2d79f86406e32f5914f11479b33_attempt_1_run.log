```lean
theorem list_set_flatten {l : List (List α)} {l1 : List α} {elt : α}
    {idx : Nat} {hidx : idx < l.length}  :
    (l.set idx (l1 ++ [elt])).flatten
    = (l.set idx l1).flatten.insertIdx ((List.take idx (l.map List.length)).sum + l1.length) elt := by
  have h₂ : ∀ (l : List (List α)) (l1 : List α), ∀ (i : ℕ), i < l.length → (l.set i (l1 ++ [elt])).flatten = (l.set i l1).flatten.insertIdx ((List.take i (l.map List.length)).sum + l1.length) elt := by
    intro l l1
    induction' i with i ih
    · intro h
      cases l with
      | nil => contradiction
      | cons hd tl =>
        simp [List.set, List.map, List.take, List.sum]
        <;> simp_all [List.flatten, List.insertIdx, List.length]
        <;>
          (try simp_all [List.set, List.map, List.take, List.sum]) <;>
          (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
          (try ring_nf at *) <;>
          (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
          (try omega)
        <;>
          (try aesop)
    · intro h
      cases l with
      | nil => contradiction
      | cons hd tl =>
        simp_all [List.set, List.map, List.take, List.sum, List.length]
        <;>
          (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
          (try ring_nf at *) <;>
          (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
          (try omega)
        <;>
          (try aesop)
        <;>
          (try
            {
              have h₃ := ih (by omega)
              simp_all [List.set, List.map, List.take, List.sum, List.length]
              <;>
                (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
                (try ring_nf at *) <;>
                (try simp_all [List.flatten, List.insertIdx, List.length]) <;>
                (try omega)
              <;>
                (try aesop)
            })
  exact h₂ l l1 idx hidx
