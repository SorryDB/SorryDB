```lean
def permMapWalk (s : Equiv.Perm (Fin n)) (p : (K n).LoopWalk u v) : (K n).LoopWalk (s u) (s v):=
  p.map (K n) (permMap' n s)

def LoopWalkEquiv (p q : ClosedLoopWalk (K n)): Prop :=
  ∃ (s : Equiv.Perm (Fin n)), ∃ (h_eq : s p.1 = q.1),
    h_eq ▸ (permMapWalk n s p.2) = q.2

def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    constructor
    · intro x
      let s := Equiv.refl (Fin n)
      unfold LoopWalkEquiv
      use s
      have hs : ∀ (y : Fin n), s y = y := by
        intro y
        simp [s]
      have h₁ : s x.1 = x.1 := by
        apply hs
      have h₂ : (h₁ ▸ (permMapWalk n s x.2)) = x.2 := by
        have h₃ : permMapWalk n s x.2 = x.2 := by
          have h₄ : s = Equiv.refl (Fin n) := by
            ext y
            simp [s]
          have h₅ : permMapWalk n s x.2 = x.2 := by
            rw [h₄]
            apply identityWalkMap
            <;> simp [hs]
          exact h₅
        simp_all
      exact ⟨h₁, h₂⟩
    · constructor
      · -- Symmetric
        rintro ⟨s, h₁, h₂⟩
        have h₃ : ∃ (s' : Equiv.Perm (Fin n)), ∃ (h_eq : s' q.1 = p.1), h_eq ▸ (permMapWalk n s' q.2) = p.2 := by
          use s⁻¹
          have h₄ : s⁻¹ q.1 = p.1 := by
            have h₅ : s p.1 = q.1 := h₁
            have h₆ : s⁻¹ (s p.1) = p.1 := by
              simp [Equiv.symm_apply_apply]
            calc
              s⁻¹ q.1 = s⁻¹ (s p.1) := by rw [h₅]
              _ = p.1 := h₆
          have h₅ : (h₄ ▸ (permMapWalk n s⁻¹ q.2)) = p.2 := by
            have h₆ : (s⁻¹ ▸ (permMapWalk n s⁻¹ q.2)) = p.2 := by
              -- Use the fact that s is an involution to reverse the permutation
              have h₇ : permMapWalk n s⁻¹ (permMapWalk n s q.2) = q.2 := by
                -- Prove that the composition of s and s⁻¹ is the identity
                have h₈ : permMapWalk n s⁻¹ (permMapWalk n s q.2) = q.2 := by
                  -- Use the fact that s is an involution to reverse the permutation
                  have h₉ : s⁻¹ * s = 1 := by
                    simp [Equiv.symm_mul]
                  simp_all [permMapWalk, LoopWalk.map, Perm.sign_mul, Perm.sign_inv]
                  <;>
                  (try decide) <;>
                  (try simp_all [Equiv.refl_apply]) <;>
                  (try aesop)
                exact h₈
              have h₈ : permMapWalk n s⁻¹ q.2 = permMapWalk n s⁻¹ q.2 := rfl
              have h₉ : s⁻¹ * s = 1 := by
                simp [Equiv.symm_mul]
              simp_all [permMapWalk, LoopWalk.map, Perm.sign_mul, Perm.sign_inv]
              <;>
              (try decide) <;>
              (try simp_all [Equiv.refl_apply]) <;>
              (try aesop)
            simp_all [permMapWalk, LoopWalk.map, Perm.sign_mul, Perm.sign_inv]
            <;>
            (try decide) <;>
            (try simp_all [Equiv.refl_apply]) <;>
            (try aesop)
          exact ⟨h₄, h₅⟩
        exact h₃
      · -- Transitive
        rintro ⟨s, h₁, h₂⟩ ⟨s', h₃, h₄⟩
        have h₅ : ∃ (s'' : Equiv.Perm (Fin n)), ∃ (h_eq : s'' p.1 = r.1), h_eq ▸ (permMapWalk n s'' p.2) = r.2 := by
          use s' * s
          have h₆ : (s' * s) p.1 = r.1 := by
            calc
              (s' * s) p.1 = s' (s p.1) := by simp [Equiv.mul_apply]
              _ = s' q.1 := by rw [h₁]
              _ = r.1 := by rw [h₃]
          have h₇ : (h₆ ▸ (permMapWalk n (s' * s) p.2)) = r.2 := by
            have h₈ : permMapWalk n (s' * s) p.2 = permMapWalk n s' (permMapWalk n s p.2) := by
              simp [permMapWalk, LoopWalk.map, Equiv.mul_apply]
              <;> aesop
            have h₉ : permMapWalk n s' (permMapWalk n s p.2) = permMapWalk n s' q.2 := by
              rw [h₂]
            have h₁₀ : permMapWalk n s' q.2 = r.2 := by
              rw [h₄]
            simp_all [permMapWalk, LoopWalk.map, Equiv.mul_apply]
            <;> aesop
          exact ⟨h₆, h₇⟩
        exact h₅
