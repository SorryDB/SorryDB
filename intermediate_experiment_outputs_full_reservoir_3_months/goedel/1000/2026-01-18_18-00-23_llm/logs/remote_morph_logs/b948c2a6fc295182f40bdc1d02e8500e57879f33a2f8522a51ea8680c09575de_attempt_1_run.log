lemma identityWalkMap (s : Equiv.Perm (Fin n)) (p : K n).LoopWalk u v (hs : s = Equiv.refl (Fin n))
    (he : ∀u: (Fin n), s u = u):
  p.map K (permMap' n s) = p := by
  subst_vars
  induction p <;>
  simp_all [permMap', LoopWalk.map, Equiv.refl_apply]
  <;>
  try { aesop }
  <;>
  try { simp_all [Equiv.refl_apply] }
  <;>
