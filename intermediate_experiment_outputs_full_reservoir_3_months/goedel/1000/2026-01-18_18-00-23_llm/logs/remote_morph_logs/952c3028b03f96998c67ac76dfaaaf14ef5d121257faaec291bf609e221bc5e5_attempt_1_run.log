          <;> try simp_all [List.length]
          <;> try ring
          <;> try linarith
      exact h₂ p
    exact h₁
  
  have h_final : ∑(e : edgeSet p), edgeCount p e = length p := by
    rw [h_main]
    <;> rw [h_length]
    <;> simp_all [edgeCount]
    <;> rfl
  
