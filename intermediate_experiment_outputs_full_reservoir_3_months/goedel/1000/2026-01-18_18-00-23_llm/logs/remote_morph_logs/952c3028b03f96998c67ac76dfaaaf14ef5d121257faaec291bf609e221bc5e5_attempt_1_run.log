theorem abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  -- We will prove this by induction on the structure of the loop walk.
  have h₁ : ∀ (p : G.LoopWalk u v), ∑ (e : Sym2 V) in p.edgeSet, p.edgeCount e = p.length := by
    intro p
    -- Base case: the empty walk
    induction p with
    | nil =>
      simp [edgeCount, edges, dartEdge, edgeSet, darts]
    | cons h p =>
      -- Inductive step: a walk consisting of an edge followed by another walk
      simp_all [edgeCount, edges, dartEdge, edgeSet, darts, length, Finset.sum_insert, Finset.mem_singleton,
        Finset.mem_coe, Finset.mem_filter, Finset.mem_univ, true_and]
      <;>
