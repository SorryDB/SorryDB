theorem abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p), edgeCount p e = length p := by
  have h_main : ∑(e : edgeSet p), edgeCount p e = (edges p).length := by
    have h₁ : ∑(e : (edges p).toFinset), countP (· = e) (edges p) = (edges p).length := by
      -- Use the property of multisets to show that the sum of counts equals the length of the list
      have h₂ : ∑(e : (edges p).toFinset), countP (· = e) (edges p) = ∑(e : (edges p).toFinset), (edges p).count e := by
        simp [countP]
      rw [h₂]
      -- Use the property of lists that the sum of counts of each element in the list equals the length of the list
      have h₃ : ∑(e : (edges p).toFinset), (edges p).count e = (edges p).length := by
        -- Use the fact that the sum of counts of each element in the list equals the length of the list
        have h₄ : ∀ (l : List (Sym2 V)), ∑(e : l.toFinset), l.count e = l.length := by
          intro l
          -- Use the property of lists to prove the statement by induction
          have h₅ : ∑(e : l.toFinset), l.count e = l.length := by
            classical
            have h₆ : ∑(e : l.toFinset), l.count e = ∑(e : l.toFinset), l.count e := rfl
            rw [h₆]
            -- Use the property of lists to prove the statement by induction
            have h₇ : (l.toFinset : Finset (Sym2 V)).sum (fun e => l.count e) = l.length := by
              have h₈ : (l.toFinset : Finset (Sym2 V)).sum (fun e => l.count e) = Multiset.card (Multiset.map (fun x => x) (l : Multiset (Sym2 V))) := by
                simp [Multiset.card_map, Multiset.sum_toFinset_count_eq_card]
              rw [h₈]
              <;> simp [List.length]
              <;> rfl
            exact h₇
          exact h₅
        -- Apply the general result to the specific list
        exact h₄ (edges p)
      rw [h₃]
    -- Use the fact that edgeSet p is the same as (edges p).toFinset
    simpa [edgeSet] using h₁
  
  have h_length : (edges p).length = length p := by
    have h₁ : (edges p).length = length p := by
      have h₂ : ∀ {u v : V} (p : G.LoopWalk u v), (edges p).length = length p := by
        intro u v
        induction p with
        | nil =>
          simp [edges, length]
        | cons h p =>
          simp_all [edges, length, List.map_append, List.map_singleton]
          <;> simp_all [edges, length]
          <;> try simp_all [G.Adj]
          <;> try simp_all [List.length]
