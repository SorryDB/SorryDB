lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  have h₁ : ∀ {u v : V} (p : G.LoopWalk u v), ∑ (e : edgeSet p), edgeCount p e = p.length := by
    intro u v
    intro p
    induction p with
    | nil =>
      simp [edgeCount, edges, edgeSet, support]
    | cons {u} {v} {w} h p ih =>
      simp_all [edgeCount, edges, edgeSet, support, length, Finset.sum_const,
        Finset.card_map, List.map_append, List.map_singleton, countP_append]
      <;>
      (try simp_all [SimpleGraph.Adj.symm]) <;>
      (try ring_nf) <;>
      (try aesop)
    | loop {u} {v} p ih =>
      simp_all [edgeCount, edges, edgeSet, support, length, Finset.sum_const,
        Finset.card_map, List.map_append, List.map_singleton, countP_append]
      <;>
      (try simp_all [SimpleGraph.Adj.symm]) <;>
      (try ring_nf) <;>
      (try aesop)
  apply h₁
