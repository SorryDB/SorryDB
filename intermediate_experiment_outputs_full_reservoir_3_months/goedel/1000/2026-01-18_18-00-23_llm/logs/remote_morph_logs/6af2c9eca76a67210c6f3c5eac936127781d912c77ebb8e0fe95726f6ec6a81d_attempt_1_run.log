theorem ph_collapse_if_p_eq_np :
  PEqualsNP → ∀ k, ∀ (α : Type) [Primcodable α] (ea : FinEncoding α) (L : Language α),
    SigmakP k ea L ↔ InP ea L := by
  intro p_eq_np k α _ ea L
  have h : ∀ (k : ℕ) (α : Type) [inst : Primcodable α] (ea : FinEncoding α) (L : Language α),
      SigmakP k ea L ↔ InP ea L := by
    intro k α _ ea L
    induction k with
    | zero =>
      simp [SigmakP]
      <;>
      tauto
    | succ k ih =>
      simp_all [SigmakP, Pi0P]
      <;>
      (try { aesop }) <;>
      (try {
        have h₁ := p_eq_np
        simp_all [InP, InNP]
        <;>
        aesop
      }) <;>
      (try {
        exfalso
        simp_all [InP, InNP]
        <;>
        aesop
      }) <;>
      (try {
        aesop
      })
      <;>
      (try {
        exfalso
        simp_all [InP, InNP]
        <;>
        aesop
      })
  exact h k α _ ea L
