theorem Φ₂_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₂ r)
    (Icc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₂_contDiffOn.continuousOn measurableSet_Icc, ?_⟩
  have h : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by
    -- We use the fact that Φ₂ is continuous on the compact interval [0, 1] to show that it has a finite integral.
    have h₁ : ContinuousOn (Φ₂ r) (Icc (0 : ℝ) 1) := Φ₂_contDiffOn.continuousOn
    have h₂ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc
    have h₃ : (Φ₂ r) ∈ ContinuousOn (Icc (0 : ℝ) 1) := h₁
    -- Apply the theorem that a continuous function on a compact set has a finite integral.
    exact continuousOn_hasFiniteIntegral (by simpa using h₃) (by simpa using h₂)
  exact h
```
