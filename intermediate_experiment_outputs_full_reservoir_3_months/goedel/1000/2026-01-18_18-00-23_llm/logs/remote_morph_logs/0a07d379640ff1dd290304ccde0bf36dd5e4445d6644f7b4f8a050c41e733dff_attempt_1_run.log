theorem Φ₂_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₂ r)
    (Icc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₂_contDiffOn.continuousOn measurableSet_Icc, _⟩
  have h : ∀ (x : ℝ), x ∈ Set.Icc (0 : ℝ) 1 → |(Φ₂ r) x| ≤ (fun x => (r : ℝ)^2 / 4 + 1) x := by
    intro x hx
    have h₁ : 0 ≤ x := by exact hx.1
    have h₂ : x ≤ 1 := by exact hx.2
    have h₃ : |Real.cos (r) - (r : ℝ)^2 / 4| ≤ (r : ℝ)^2 / 4 + 1 := by
      -- Prove that |cos(r) - r²/4| ≤ r²/4 + 1
      have h₄ : Real.cos r ≥ -1 := by
        linarith [Real.neg_one_le_cos r]
      have h₅ : Real.cos r ≤ 1 := by
        linarith [Real.cos_le_one r]
      cases' le_total 0 (Real.cos r - (r : ℝ)^2 / 4) with h₆ h₆
      · -- Case: cos(r) - r²/4 ≥ 0
        rw [abs_of_nonneg h₆]
        nlinarith [sq_nonneg (r - 2 / 3)]
      · -- Case: cos(r) - r²/4 ≤ 0
        rw [abs_of_nonpos h₆]
        nlinarith [sq_nonneg (r - 2 / 3)]
    have h₄ : |(Φ₂ r) x| = |Real.cos (r) - (r : ℝ)^2 / 4| := by
      -- Simplify the expression for Φ₂ r x
      simp [Φ₂, Real.cos]
      <;> ring_nf
      <;> norm_num
      <;> field_simp
      <;> ring_nf
      <;> simp_all [abs_mul, abs_of_nonneg, abs_of_nonpos, hr]
      <;> norm_num
      <;> linarith
    rw [h₄]
    have h₅ : (fun x : ℝ => (r : ℝ)^2 / 4 + 1) x = (r : ℝ)^2 / 4 + 1 := by simp
    simp_all [h₅]
    <;> linarith
  -- Use the fact that the constant function is integrable and the domination to conclude the proof
  have h₁ : IntegrableOn (fun x : ℝ => (r : ℝ)^2 / 4 + 1 : ℝ → ℝ) (Set.Icc 0 1) volume := by
    apply ContinuousOn.integrableOn_Icc
    continuity
  have h₂ : HasFiniteIntegral (fun x : ℝ => (r : ℝ)^2 / 4 + 1 : ℝ → ℝ) (volume.restrict (Set.Icc 0 1)) := by
    simpa [volume.restrict_apply] using h₁.hasFiniteIntegral
  have h₃ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Set.Icc 0 1)) := by
    refine' (h₂.of_dominated _ _)
    · -- Prove that Φ₂ r is measurable on [0, 1]
      exact MeasurableOn.abs (ContinuousOn.measurableOn (Φ₂_contDiffOn.continuousOn : ContinuousOn (Φ₂ r) (Set.Icc 0 1)))
    · -- Prove that |Φ₂ r x| ≤ (r : ℝ)^2 / 4 + 1 for x ∈ [0, 1]
      filter_upwards [measurableSet_Icc] with x hx using h x hx
  exact h₃
