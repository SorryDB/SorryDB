### Solution

```lean
theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
    -- Use the fact that Φ₁ is continuous and the interval is compact
    have h₁ : ContinuousOn (Φ₁ r) (Ioc (0 : ℝ) 1) := Φ₁_contDiffOn.continuousOn
    -- Since Φ₁ is continuous on [0,1], it is bounded and thus has finite integral
    have h₂ : BddAbove (Set.range (fun x : ℝ => (Φ₁ r) x)) := by
      -- Prove that Φ₁ is bounded above on [0,1]
      have h₃ : ContinuousOn (Φ₁ r) (Set.Icc 0 1) := by
        -- Prove continuity on [0,1]
        have h₄ : ContinuousOn (Φ₁ r) (Icc 0 1) := by
          apply ContinuousOn.mono Φ₁_contDiffOn.continuousOn
          <;> norm_num
          <;>
          (try norm_num) <;>
          (try linarith)
        exact h₄
      have h₄ : IsCompact (Set.Icc 0 1) := isCompact_Icc
      have h₅ : BddAbove (Set.range (fun x : ℝ => (Φ₁ r) x)) := by
        -- Use the fact that a continuous function on a compact set is bounded
        have h₆ : BddAbove (Set.image (Φ₁ r) (Set.Icc 0 1)) := by
          apply IsCompact.bddAbove_image h₄ (h₃)
        have h₇ : Set.image (Φ₁ r) (Set.Icc 0 1) ⊆ Set.range (fun x : ℝ => (Φ₁ r) x) := by
          intro y hy
          rcases hy with ⟨x, hx, rfl⟩
          exact ⟨x, by simp⟩
        exact Set.BddAbove.mono h₇ h₆
      exact h₅
    -- Use the fact that Φ₁ is bounded and the interval has finite measure to conclude the integral is finite
    have h₃ : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
      -- Use the fact that Φ₁ is bounded and the interval has finite measure
      have h₄ : BddAbove (Set.range (fun x : ℝ => (Φ₁ r) x)) := h₂
      have h₅ : ContinuousOn (Φ₁ r) (Ioc (0 : ℝ) 1) := h₁
      have h₆ : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
        -- Use the fact that Φ₁ is bounded and the interval has finite measure
        have h₇ : ContinuousOn (Φ₁ r) (Ioc (0 : ℝ) 1) := h₁
        have h₈ : BddAbove (Set.range (fun x : ℝ => (Φ₁ r) x)) := h₂
        -- Use the fact that the integral of a continuous function on a compact set is finite
        have h₉ : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
          -- Use the fact that the integral of a continuous function on a compact set is finite
          apply ContinuousOn.hasFiniteIntegral
          <;>
          (try simp_all) <;>
          (try norm_num) <;>
          (try linarith) <;>
          (try exact ⟨1, by norm_num⟩) <;>
          (try exact ⟨0, by norm_num⟩)
          <;>
          (try exact measurableSet_Ioc)
          <;>
          (try exact h₇)
          <;>
          (try exact h₈)
        exact h₉
      exact h₆
    exact h₃
  -- Conclude the proof
  exact h
