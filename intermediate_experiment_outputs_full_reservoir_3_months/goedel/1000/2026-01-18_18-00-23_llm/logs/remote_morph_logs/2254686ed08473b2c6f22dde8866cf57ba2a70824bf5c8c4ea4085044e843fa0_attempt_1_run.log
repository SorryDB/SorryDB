theorem logCauchy (h : ∀ (x : ℂ → ℂ), x 1 = x 0) : False := by
  have h₁ : (∀ (x : ℂ → ℂ), x 1 = x 0) → False := by
    intro h
    let x : ℂ → ℂ := fun n => (n : ℂ)
    have h₂ := h x
    norm_num at h₂ ⊢
  exact h₁ h
