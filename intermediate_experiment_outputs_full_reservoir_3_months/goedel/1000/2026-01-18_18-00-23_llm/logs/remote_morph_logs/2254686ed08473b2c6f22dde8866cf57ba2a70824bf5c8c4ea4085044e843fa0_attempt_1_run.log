lemma logCounting_circleIntegrable {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (logCounting f · r) 0 1 := by
  have h₁ : CircleIntegrable (fun x : ℝ => (0 : ℝ)) 0 1 := by
    apply circleIntegrable_zero
  have h₂ : (logCounting f · r) = (fun x : ℝ => (0 : ℝ)) := by
    ext x
    simp [logCounting, mul_comm]
    <;>
    (try simp_all [h]) <;>
    (try ring_nf) <;>
    (try field_simp [h]) <;>
    (try norm_cast) <;>
    (try simp_all [Complex.ext_iff]) <;>
    (try linarith)
  rw [h₂]
  exact h₁
```
