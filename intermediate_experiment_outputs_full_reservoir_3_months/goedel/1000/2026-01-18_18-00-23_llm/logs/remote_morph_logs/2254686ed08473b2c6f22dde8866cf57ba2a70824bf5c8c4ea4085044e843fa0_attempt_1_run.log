Helper Lemma: The logarithmic counting function is circle integrable. The right
side of the equality in Cartan's theorem is therefore meaningful.
-/
lemma logCounting_circleIntegrable {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (logCounting f · r) 0 1 := by
  have h₁ : CircleIntegrable (fun x : ℝ => logCounting f (x : ℝ) r) 0 1 := by
    -- Use the fact that logCounting f is zero almost everywhere to conclude circle integrability.
    have h₂ : (fun x : ℝ => logCounting f (x : ℝ) r) = (fun _ : ℝ => 0 : ℝ → ℝ) := by
      funext x
      simp [logCounting, Complex.ext_iff]
      <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try simp_all [Complex.ext_iff]) <;>
      (try aesop)
    rw [h₂]
    exact circleIntegrable_zero
  simpa using h₁
