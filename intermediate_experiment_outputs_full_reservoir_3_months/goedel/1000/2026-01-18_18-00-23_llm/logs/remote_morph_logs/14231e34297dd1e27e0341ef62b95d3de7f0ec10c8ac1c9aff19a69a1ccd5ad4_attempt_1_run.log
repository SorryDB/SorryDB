        cases' h₁.1 with t ht
        omega
      have h₇₄ : a ≥ 2 := by
        by_contra h₇₄
        interval_cases a <;> simp_all (config := {decide := true})
      omega
    have h₈ : d > 0 := by linarith
    have h₉ : b > 0 := by linarith
    have h₁₀ : c > 0 := by linarith
    have h₁₁ : d = 2^k - a := by
      have h₁₁₁ : a + d = 2^k := h₄
      have h₁₁₂ : a ≤ 2^k := by omega
      omega
    have h₁₂ : b + c = 2^m := h₅
    have h₁₃ : a * d = b * c := h₃
    have h₁₄ : a < b := h₂.1
    have h₁₅ : b < c := h₂.2.1
    have h₁₆ : c < d := h₂.2.2
    have h₁₇ : d = 2^k - a := h₁₁
    have h₁₈ : a * (2^k - a) = b * c := by
      rw [h₁₇] at h₁₃
      exact h₁₃
    have h₁₉ : b < 2^m := by
      have h₁₉₁ : b + c = 2^m := h₅
      have h₁₉₂ : c > 0 := by linarith
      omega
    have h₂₀ : c < 2^m := by
      have h₂₀₁ : b + c = 2^m := h₅
      have h₂₀₂ : b > 0 := by linarith
      omega
    have h₂₁ : 2^k > 0 := by
      have h₂₁₁ : a > 0 := by linarith
      have h₂₁₂ : d > 0 := by linarith
      have h₂₁₃ : a + d = 2^k := h₄
      omega
    have h₂₂ : 2^m > 0 := by
      have h₂₂₁ : b > 0 := by linarith
      have h₂₂₂ : c > 0 := by linarith
      have h₂₂₃ : b + c = 2^m := h₅
      omega
    have h₂₃ : a * (2^k - a) = b * c := h₁₈
    have h₂₄ : 2^k - a > 0 := by
      have h₂₄₁ : a < d := by omega
      have h₂₄₂ : a + d = 2^k := h₄
      omega
    -- Use the fact that a, b, c, d are odd to derive a contradiction.
    have h₂₅ : a % 2 = 1 := by
      cases' h₁.1 with t ht
      omega
    have h₂₆ : b % 2 = 1 := by
      cases' h₁.2.1 with t ht
      omega
    have h₂₇ : c % 2 = 1 := by
      cases' h₁.2.2.1 with t ht
      omega
    have h₂₈ : d % 2 = 1 := by
      cases' h₁.2.2.2 with t ht
      omega
    have h₂₉ : (2^k) % 2 = 0 := by
      have h₂₉₁ : k ≥ 1 := by
        by_contra h₂₉₁
        have h₂₉₂ : k = 0 := by omega
        have h₂₉₃ : a + d = 2^k := h₄
