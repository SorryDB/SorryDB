        have h₁₃ := h₄ 3 (by norm_num)
        have h₁₄ := h₅ 3 (by norm_num)
        simp at h₆ h₇ h₈ h₉ h₁₀ h₁₁ h₁₂ h₁₃ h₁₄
        <;>
