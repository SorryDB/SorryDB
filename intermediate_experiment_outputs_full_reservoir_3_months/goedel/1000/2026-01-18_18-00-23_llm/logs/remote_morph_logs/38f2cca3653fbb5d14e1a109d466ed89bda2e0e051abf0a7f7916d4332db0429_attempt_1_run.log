```lean4
theorem proposition_3_13 : ∀ (m n : ℕ), m * n % 10 = (m % 10) * (n % 10) % 10 := by
  intro m n
  have h_main : m * n % 10 = (m % 10) * (n % 10) % 10 := by
    have h₁ : m % 10 < 10 := Nat.mod_lt m (by decide)
    have h₂ : n % 10 < 10 := Nat.mod_lt n (by decide)
    have h₃ : m % 10 ≥ 0 := by omega
    have h₄ : n % 10 ≥ 0 := by omega
    -- Use the fact that modulo 10, multiplication is determined by the last digits
    have h₅ : m * n % 10 = ((m % 10) * (n % 10)) % 10 := by
      -- Use the property of modulo operation to simplify the expression
      have h₅₁ : m % 10 = m % 10 := rfl
      have h₅₂ : n % 10 = n % 10 := rfl
      -- Use the fact that (a * b) % m = ((a % m) * (b % m)) % m
      have h₅₃ : m * n % 10 = ((m % 10) * (n % 10)) % 10 := by
        have h₅₄ : m * n % 10 = (m * n) % 10 := rfl
        rw [h₅₄]
        have h₅₅ : (m * n) % 10 = ((m % 10) * (n % 10)) % 10 := by
          -- Use the property of modulo operation to simplify the expression
          have h₅₆ : m % 10 = m % 10 := rfl
          have h₅₇ : n % 10 = n % 10 := rfl
          -- Use the fact that (a * b) % m = ((a % m) * (b % m)) % m
          have h₅₈ : (m * n) % 10 = ((m % 10) * (n % 10)) % 10 := by
            -- Use the property of modulo operation to simplify the expression
            simp [Nat.mul_mod, Nat.add_mod, Nat.mod_mod]
          exact h₅₈
        rw [h₅₅]
      exact h₅₃
    -- The result follows directly from the above steps
    have h₆ : ((m % 10) * (n % 10)) % 10 = (m % 10) * (n % 10) % 10 := by
      simp [Nat.mul_mod, Nat.add_mod, Nat.mod_mod]
    -- Combine the results to get the final answer
    omega
  
  exact h_main
```
