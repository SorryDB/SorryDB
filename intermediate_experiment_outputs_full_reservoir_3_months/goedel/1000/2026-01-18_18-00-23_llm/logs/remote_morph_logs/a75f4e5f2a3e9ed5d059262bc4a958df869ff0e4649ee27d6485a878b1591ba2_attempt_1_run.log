def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    rintro _ ⟨h1, h2⟩ ⟨k1, k2⟩
    refine' ⟨I.add_mem h1 k1, J.add_mem h2 k2⟩
  zero_mem' := by
    refine' ⟨I.zero_mem, J.zero_mem⟩
  smul_mem' := by
    intro a _ h
    aesop

def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx => by
    have h : f x = 0 := by
      simpa using Ideal.mem_ker.mp hx
    rw [h]
    <;> simp

theorem kerLift_mk (f : R →+* S) (x : R) : kerLift f (Ideal.Quotient.mk (ker f) x) = f x := by
  rw [Ideal.Quotient.lift_mk]
  <;>
  simp [Ideal.mem_ker]
  <;>
  aesop
