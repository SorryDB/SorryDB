  aesop? (add safe Aesop.BuiltinRules.ext)
    (config := { warnOnNonterminal := false })
  have h1 : p.snd = q.snd := by
    have h2 : p = q := by
      apply MyProd.ext
      <;>
      (try aesop) <;>
      (try {
        funext x
        <;>
