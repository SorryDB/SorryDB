structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

instance : Eq (MyProd α β) := ⟨fun p q => p.fst = q.fst ∧ p.snd = q.snd⟩

@[ext]
structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

example {p q : MyProd α β} : p = q := by
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;> aesop

example {p q : MyProd α (MyProd β γ)} : p = q := by
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;>
  (try aesop) <;>
  (try {
    cases p'
    cases q'
    simp_all [MyProd.ext_iff]
    <;> aesop
  })

example {p q : MyProd (α → β) γ} : p = q := by
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;>
  (try aesop) <;>
  (try {
    funext x
    <;> aesop
  })
