structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

example {p q : MyProd (α → β) γ} : p = q := by
  have h₁ : p.fst = q.fst := by
    funext x
    have h₂ := congr_fun (congr_arg (fun r : MyProd (α → β) γ => r.fst) (by aesop)) x
    simp at h₂ ⊢
    <;> aesop
  
  have h₂ : p.snd = q.snd := by
    have h₃ := congr_arg (fun r : MyProd (α → β) γ => r.snd) (by aesop)
    simp at h₃ ⊢
    <;> aesop
  
  have h₃ : p = q := by
    cases p <;> cases q <;>
    (try simp_all [MyProd.mk.injEq]) <;>
    (try aesop) <;>
    (try funext x <;> aesop)
    <;> (try simp_all) <;>
    (try aesop)
  
  exact h₃
```
