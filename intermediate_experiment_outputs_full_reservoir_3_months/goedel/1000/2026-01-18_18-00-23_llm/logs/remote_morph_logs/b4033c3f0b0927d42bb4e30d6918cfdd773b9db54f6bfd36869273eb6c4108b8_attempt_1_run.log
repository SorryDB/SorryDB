lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have h₁ : S.ω ≠ 0 := ω_neq_zero S
  have h₂ : ∂ₜ (IC.trajectory S) t = 0 → ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
    intro h
    have h₃ : ∂ₜ (IC.trajectory S) t = 0 := h
    have h₄ : False := by
      simp [trajectory_velocity] at h₃
      <;> simp_all [h₁]
      <;> (try norm_num)
      <;> (try ring_nf at *)
      <;> (try field_simp [h₁] at *)
      <;> (try simp_all [norm_eq_abs, abs_mul, abs_of_pos, abs_of_nonneg])
      <;> (try norm_num at *)
      <;> (try linarith [Real.sqrt_nonneg 2])
    exfalso
    exact h₄
  have h₃ : ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) → ∂ₜ (IC.trajectory S) t = 0 := by
    intro h
    have h₄ : ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := h
    have h₅ : False := by
      simp_all [trajectory, norm_function]
      <;> (try norm_num)
      <;> (try linarith [Real.sqrt_nonneg 2])
    exfalso
    exact h₅
  simp_all
  <;> tauto
