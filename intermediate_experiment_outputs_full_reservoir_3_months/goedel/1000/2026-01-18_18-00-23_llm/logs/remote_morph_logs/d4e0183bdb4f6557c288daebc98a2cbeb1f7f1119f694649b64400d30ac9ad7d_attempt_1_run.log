```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : (fun x : ℝ => r • f x) = (r • •) ∘ f := by
    funext x
    simp [comp_apply]
    <;>
    rfl
  
  -- Use the previously proven lemma to handle the bounded linear map
  have h₂ :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    rw [h₁]
    have h₃ : BoundedLinearMap ℝ E E (r • •) := by
      refine' ⟨fun x => norm_smul_le_norm_smul_norm x _ _ ⟨by norm_num, by norm_num⟩, _⟩
      <;>
      simp_all [IsBoundedSMul]
      <;>
      try norm_num <;>
      try linarith
      <;>
      try continuity
      <;>
      try ring_nf
      <;>
      try norm_num
      <;>
      try linarith
      <;>
      try aesop
    -- Use the bounded linear map to prove the equivalence of interval integrability
    exact
      intervalIntegrable_iff_intervalIntegrable_comp (by continuity) (by continuity) h₃
  -- Conclude the proof by using the established equivalence
  exact h₂
``` 

