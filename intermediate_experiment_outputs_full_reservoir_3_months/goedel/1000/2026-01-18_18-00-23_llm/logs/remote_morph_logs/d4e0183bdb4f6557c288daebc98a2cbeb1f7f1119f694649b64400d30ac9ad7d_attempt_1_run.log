          ext x
          simp [hr]
        have h4 : IntervalIntegrable (0 : ℝ → E) μ a b := by
          apply intervalIntegrable_zero
        simp_all [h3]
      · -- If r ≠ 0, then we can use the fact that scalar multiplication by r⁻¹ is bounded.
        have h3 : IsBoundedSMul R E := inferInstance
        have h4 : IntervalIntegrable f μ a b := by
          -- Use the fact that scalar multiplication by r⁻¹ is bounded to deduce the integrability of f.
          have h5 : IntervalIntegrable (r • f) μ a b := hf
          have h6 : IntervalIntegrable ( (r⁻¹ : R) • (r • f) : ℝ → E) μ a b := by
            exact h5.smul (r⁻¹ : R)
          have h7 : ( (r⁻¹ : R) • (r • f) : ℝ → E) = f := by
