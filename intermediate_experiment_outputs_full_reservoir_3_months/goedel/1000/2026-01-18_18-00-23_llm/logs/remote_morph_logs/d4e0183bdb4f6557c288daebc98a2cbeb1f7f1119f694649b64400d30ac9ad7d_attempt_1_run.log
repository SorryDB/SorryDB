theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    refine' ⟨fun h => _, fun h => _⟩
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that scalar multiplication is continuous to deduce interval integrability of r • f.
        refine' (intervalIntegrable_smul r f).mp h
      exact h₂
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that scalar multiplication is continuous and invertible (if r ≠ 0) to deduce interval integrability of f.
        -- However, since r is an arbitrary element of the scalar space, we need to assume more properties for the reverse direction.
        -- In this proof, we assume that the scalar multiplication by r is invertible and use the continuity of the inverse operation.
        -- But since we don't have more information about r, we can only assume the scalar multiplication is bounded.
        -- Therefore, we cannot directly deduce the interval integrability of f from r • f without additional constraints.
