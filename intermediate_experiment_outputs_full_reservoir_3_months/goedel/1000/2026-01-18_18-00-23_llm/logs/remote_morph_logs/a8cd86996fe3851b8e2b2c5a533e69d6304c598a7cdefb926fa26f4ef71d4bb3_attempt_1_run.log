lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  by
  use fun n => f 0
  use f 0
  constructor
  · intro n
    refine' ⟨{1 : ℝ}, {0}, _⟩
    <;> simp_all [Set.mem_range]
    <;> norm_num
    <;>
    (try { aesop }) <;>
    (try { use 0 <;> simp }) <;>
    (try { use 1 <;> simp }) <;>
    (try { linarith })
  · -- Prove that the sequence is constant and thus tends to f 0
    have h : Tendsto (fun n : ℕ => f 0) atTop (𝓝 (f 0)) := by
      apply tendsto_const_nhds
    exact h
