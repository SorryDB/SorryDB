lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    refinement B hB hB' hB'' ≤ D := by
  intro N hN
  have h₁ : N ∈ D := hN
  have h₂ : ∃ (S : Set (PersistenceSubmodule M)), S ⊆ (refinement B hB hB' hB''.carrier) ∧ N = sSup S := by
    refine' ⟨B N h₁, ?_, _⟩
    · -- Show that B N h₁ ⊆ refinement B hB hB' hB''.carrier
      intro X hX
      simp only [refinement, Set.mem_iUnion, Set.mem_setOf_eq]
      refine' ⟨N, h₁, X, hX⟩
    · -- Show that N = sSup (B N h₁)
