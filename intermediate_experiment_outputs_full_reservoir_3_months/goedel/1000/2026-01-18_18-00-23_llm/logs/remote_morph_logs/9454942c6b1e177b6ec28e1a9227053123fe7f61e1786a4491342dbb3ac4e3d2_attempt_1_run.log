lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    refinement B hB hB' hB'' ≤ D := by
  intro N hN
  have hN' : ∃ (i : ℕ) (N : PersistenceSubmodule M), N ∈ B N i ∧ hB N i = hN := by
    classical
    -- We need to find an index and a corresponding submodule such that the submodule is in B N i and hB N i equals hN.
    -- This is a placeholder for the actual proof, which would involve detailed set theory and properties of DirectSumDecomposition.
    by_cases h : D = ∅
    · exfalso
      have h₁ := D.sSup_eq_top'
      simp_all [Set.sSup_empty]
      <;> aesop
    · -- If D is not empty, we can find a suitable index and submodule.
      have h₂ : ∃ N hN, N ∈ D := by
        by_contra h₃
        push_neg at h₃
        have h₄ : D = ∅ := by
          apply Set.eq_empty_of_forall_not_mem
          intro x hx
          have h₅ := h₃ x
          tauto
        contradiction
      obtain ⟨N, hN⟩ := h₂
      use 0, N
      <;> simp_all
      <;> aesop
  obtain ⟨i, N, hN₁, hN₂⟩ := hN'
  have h₁ : N ∈ D := by
    -- Since N is in B N i and B N i is a subset of D, N must be in D.
    simp_all [Set.mem_iUnion]
    <;> aesop
  -- Since N is in D, we can conclude that the refinement is a subset of D.
  simp_all [Set.mem_iUnion]
  <;> aesop
