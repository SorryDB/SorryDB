  -- Obtain the subset S and its properties
  obtain ⟨S, hS_sub, hS_sup⟩ := h₂
  -- Use S to satisfy the condition for refinement
  refine' ⟨S, hS_sub, _⟩
  -- The supremum of S is N by construction
  rw [hS_sup]
