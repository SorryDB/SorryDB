theorem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have h_main : ∃ s : Set ℕ+, s.Infinite ∧ s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
    use Set.range fun k : ℕ+ => ⟨2 * k.val, by
      have h : 0 < (2 : ℕ) * k.val := by positivity
      exact h⟩
