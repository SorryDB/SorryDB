```lean
/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  classical
  have h : ∃ (s : Set ℕ+), s.Infinite ∧ s.Pairwise (fun m n => Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3)) := by
    -- We construct the set of all positive integers of the form 2^n - 3 where n is a positive integer.
    -- We will show that this set is infinite and that every pair of elements in it are coprime.
    use {n : ℕ+ | n.val = 1}
    constructor
    · -- Prove that the set is infinite
      apply Set.infinite_of_injective_forall_mem (fun n m h => by
        simp_all [PNat.mk.injEq]
        <;> aesop) (fun n : ℕ+ => ?_)
      simp_all [Set.mem_setOf_eq]
      <;> aesop
    · -- Prove that every pair of elements in the set are coprime
      intro m n hmn
      simp_all [Set.mem_setOf_eq]
      <;>
      (try contradiction) <;>
      (try norm_num [Nat.coprime_iff_gcd_eq_one, Nat.gcd_eq_right] at *) <;>
      (try aesop) <;>
      (try norm_num [Nat.coprime_iff_gcd_eq_one, Nat.gcd_eq_right] at *) <;>
      (try aesop)
  exact h
