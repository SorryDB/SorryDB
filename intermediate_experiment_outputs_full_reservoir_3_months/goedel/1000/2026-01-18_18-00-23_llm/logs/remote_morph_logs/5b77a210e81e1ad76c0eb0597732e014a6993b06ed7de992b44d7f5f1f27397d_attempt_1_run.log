/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace imo1971_p3

theorem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have h_main : ∃ (s : Set ℕ+), s.Infinite ∧ s.Pairwise fun m n => Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
    use Set.range fun n : ℕ => ⟨3 * n + 2, by
      have h : 3 * n + 2 > 0 := by
        omega
      exact h⟩
    constructor
    · -- Prove that the set is infinite
      apply Set.infinite_range_of_injective
      intro n m h
      simp_all [PNat.mk.injEq]
      <;> omega
    · -- Prove that every pair of elements is coprime
      rintro ⟨n, hn⟩ ⟨m, hm⟩
      simp_all [Set.mem_range]
      <;>
      (try omega) <;>
