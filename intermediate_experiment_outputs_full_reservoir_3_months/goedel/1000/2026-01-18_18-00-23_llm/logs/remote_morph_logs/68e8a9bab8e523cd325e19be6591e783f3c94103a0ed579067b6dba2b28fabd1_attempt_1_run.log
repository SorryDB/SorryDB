theorem double_spec (q : ProjectivePoint)
  (h_qX_bounds : ∀ i, i < 5 → (q.X[i]!).val ≤ 2 ^ 52)
  (h_qY_bounds : ∀ i, i < 5 → (q.Y[i]!).val ≤ 2 ^ 52)
  (h_qZ_bounds : ∀ i, i < 5 → (q.Z[i]!).val ≤ 2 ^ 52) :
∃ c,
double q = ok c ∧
let X := Field51_as_Nat q.X
let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let X' := Field51_as_Nat c.X
let Y' := Field51_as_Nat c.Y
let Z' := Field51_as_Nat c.Z
let T' := Field51_as_Nat c.T
X' % p = (2 * X * Y) % p ∧
Y' % p = (Y^2 + X^2) % p ∧
(Z' + X^2) % p = Y^2 % p ∧
(T' + Z') % p = (2 * Z^2) % p
:= by
  have h_main : ∃ c, double q = ok c ∧ (let X := Field51_as_Nat q.X; let Y := Field51_as_Nat q.Y; let Z := Field51_as_Nat q.Z; let X' := Field51_as_Nat c.X; let Y' := Field51_as_Nat c.Y; let Z' := Field51_as_Nat c.Z; let T' := Field51_as_Nat c.T; X' % p = (2 * X * Y) % p ∧ Y' % p = (Y^2 + X^2) % p ∧ (Z' + X^2) % p = Y^2 % p ∧ (T' + Z') % p = (2 * Z^2) % p) := by
    have h₁ : double q = ok (double_impl q) := by
      rfl
    refine' ⟨double_impl q, by simp [h₁], _⟩
    dsimp only
    <;> simp_all [Field51_as_Nat, Field.toNat]
