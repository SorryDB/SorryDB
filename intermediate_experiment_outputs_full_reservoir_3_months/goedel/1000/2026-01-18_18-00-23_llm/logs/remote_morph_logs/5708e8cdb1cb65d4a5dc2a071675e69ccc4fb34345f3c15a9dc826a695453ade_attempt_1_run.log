theorem le_antisymm_of_lower_bounds {őĪ : Type*} [PartialOrder őĪ] {S : Set őĪ} {a b : őĪ} (H : S.Nonempty) :
  (‚ąÄ x ‚ąą S, a ‚Č§ x) ‚Üí (‚ąÄ x ‚ąą S, b ‚Č§ x) ‚Üí (‚ąÄ x ‚ąą S, b ‚Č§ x) ‚Üí (‚ąÄ x ‚ąą S, a ‚Č§ x) ‚Üí (a = b) := by
  intro ha hb hb' ha'
  have h‚āĀ : a ‚Č§ b := by
    have h‚āĀ : ‚ąÉ x, x ‚ąą S := H
    obtain ‚ü®x, hx‚ü© := h‚āĀ
    have h‚āā : a ‚Č§ x := ha x hx
    have h‚āÉ : b ‚Č§ x := hb x hx
    -- Since `a` and `b` are both less than or equal to `x`, and `a` is a lower bound,
    -- we can deduce that `a ‚Č§ b`.
    have h‚āĄ : a ‚Č§ x := ha x hx
    have h‚āÖ : b ‚Č§ x := hb x hx
    -- Use the transitivity of the order to compare `a` and `b`.
    have h‚āÜ : a ‚Č§ b := by
      have h‚āá : a ‚Č§ x := ha x hx
      have h‚āą : b ‚Č§ x := hb x hx
      -- Use the fact that `a` is a lower bound and `b` is less than or equal to `x`.
      by_cases hab : a ‚Č§ b
      ¬∑ exact hab
      ¬∑ exfalso
        -- If `a` is not less than or equal to `b`, then `b < a`.
        have h‚āČ : b < a := by
          exact lt_of_not_ge hab
        -- Since `a ‚Č§ x`, we have `b < x`.
        have h‚āĀ‚āÄ : b < x := lt_of_le_of_lt hb x h‚āČ
        -- But `b ‚Č§ x` by assumption, which leads to a contradiction.
        exact not_lt_of_ge (hb x hx) h‚āĀ‚āÄ
    exact h‚āÜ
  
  have h‚āā : b ‚Č§ a := by
    have h‚āā : ‚ąÉ x, x ‚ąą S := H
    obtain ‚ü®x, hx‚ü© := h‚āā
    have h‚āÉ : b ‚Č§ x := hb x hx
    have h‚āĄ : a ‚Č§ x := ha' x hx
    -- Since `b` and `a` are both less than or equal to `x`, and `b` is a lower bound,
    -- we can deduce that `b ‚Č§ a`.
    have h‚āÖ : b ‚Č§ x := hb x hx
    have h‚āÜ : a ‚Č§ x := ha' x hx
    -- Use the transitivity of the order to compare `b` and `a`.
    have h‚āá : b ‚Č§ a := by
      by_cases hab : b ‚Č§ a
      ¬∑ exact hab
      ¬∑ exfalso
        -- If `b` is not less than or equal to `a`, then `a < b`.
        have h‚āą : a < b := by
          exact lt_of_not_ge hab
        -- Since `b ‚Č§ x`, we have `a < x`.
        have h‚āČ : a < x := lt_of_le_of_lt ha' x h‚āą
        -- But `a ‚Č§ x` by assumption, which leads to a contradiction.
        exact not_lt_of_ge (ha' x hx) h‚āČ
    exact h‚āá
  
  have h‚āÉ : a = b := by
    have h‚āĄ : a ‚Č§ b := h‚āĀ
    have h‚āÖ : b ‚Č§ a := h‚āā
    -- Since `a ‚Č§ b` and `b ‚Č§ a`, we can conclude `a = b` by antisymmetry.
    exact le_antisymm h‚āĄ h‚āÖ
  
  exact h‚āÉ
