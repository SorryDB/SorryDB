theorem OMR_problem_695 (n : ℕ) (h : n ≤ 50) : 2 ≤ n → n ≤ 40 ∨ 41 ≤ n ∧ n ≤ 45 ∨ 46 ≤ n ∧ n ≤ 49 ∨ 50 ≤ n := by
  intro h₁
  have h₂ : n ≤ 50 := h
  have h₃ : 2 ≤ n := h₁
  have h₄ : n ≤ 40 ∨ 41 ≤ n ∧ n ≤ 45 ∨ 46 ≤ n ∧ n ≤ 49 ∨ 50 ≤ n := by
    by_cases h₅ : n ≤ 40
    · exact Or.inl h₅
    · -- Case: n > 40
      have h₆ : 41 ≤ n := by
        omega
      by_cases h₇ : n ≤ 45
      · -- Subcase: 41 ≤ n ≤ 45
        exact Or.inr (Or.inl ⟨h₆, h₇⟩)
      · -- Subcase: n > 45
        have h₈ : 46 ≤ n := by
          omega
        by_cases h₉ : n ≤ 49
        · -- Subcase: 46 ≤ n ≤ 49
          exact Or.inr (Or.inr (Or.inl ⟨h₈, h₉⟩))
        · -- Subcase: n > 49
          have h₁₀ : 50 ≤ n := by
            omega
          exact Or.inr (Or.inr (Or.inr h₁₀))
  exact h₄
```
