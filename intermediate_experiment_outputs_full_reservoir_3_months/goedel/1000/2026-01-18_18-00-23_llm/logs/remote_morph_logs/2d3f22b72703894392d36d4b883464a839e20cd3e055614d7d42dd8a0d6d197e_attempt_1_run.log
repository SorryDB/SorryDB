theorem pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  calc
    ⨆ p ∈ D, p x = ⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x := rfl
    _ = ⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x := rfl
    _ = ⊤ := by
      have h : sSup (D : Set (PersistenceSubmodule M)) = ⊤ := by
        simpa [SetLike.coe_sSup] using D.sSup_eq_top'
      -- We need to show that the supremum of the pointwise submodules is the top submodule.
      -- This follows from the fact that the supremum of the submodules is the top submodule.
      have h₂ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) = ⊤ := by
        rw [show (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) = (⨆ p ∈ (SetLike.coe D), p x) by rfl]
        -- Use the fact that the supremum of the submodules is the top submodule to prove the pointwise supremum is the top submodule.
        have h₃ : (⨆ p ∈ (SetLike.coe D), p x) = ⊤ := by
          apply le_antisymm
          · -- Show that the pointwise supremum is less than or equal to the top submodule.
            apply le_top
          · -- Show that the top submodule is less than or equal to the pointwise supremum.
