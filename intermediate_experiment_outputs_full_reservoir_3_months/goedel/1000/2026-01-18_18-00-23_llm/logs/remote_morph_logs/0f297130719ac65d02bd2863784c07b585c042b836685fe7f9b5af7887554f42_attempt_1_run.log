        have h₄ : (2 * a : ℝ) ≠ 0 := by
          intro h₅
          apply h₃
          linarith
        -- Multiply both sides by 4 * a to eliminate the fraction.
        field_simp [h₃, h₄] at h ⊢
        nlinarith [sq_nonneg (2 * a * x + b)]
      -- Solve for x using the quadratic formula.
