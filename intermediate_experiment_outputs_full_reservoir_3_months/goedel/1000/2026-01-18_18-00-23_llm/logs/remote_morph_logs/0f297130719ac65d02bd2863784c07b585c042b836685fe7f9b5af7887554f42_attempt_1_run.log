        have h₆ : a ≠ 0 := ha
        have h₇ : (2 * a : ℝ) ≠ 0 := by
          intro h₈
          apply h₆
          linarith
        -- Use the fact that the square of the difference is zero to find the solutions.
        have h₈ : (2 * a * x + b) ^ 2 = (b ^ 2 - 4 * a * c) := by
          have h₉ : (2 * a : ℝ) ≠ 0 := by
            intro h₁₀
            apply h₆
            linarith
          field_simp [h₆, h₉] at h₂ ⊢
          nlinarith [sq_nonneg (2 * a * x + b)]
        have h₉ : 2 * a * x + b = Real.sqrt (b ^ 2 - 4 * a * c) ∨ 2 * a * x + b = -Real.sqrt (b ^ 2 - 4 * a * c) := by
          apply or_iff_not_imp_left.mpr
          intro h₁₀
          apply eq_of_sub_eq_zero
