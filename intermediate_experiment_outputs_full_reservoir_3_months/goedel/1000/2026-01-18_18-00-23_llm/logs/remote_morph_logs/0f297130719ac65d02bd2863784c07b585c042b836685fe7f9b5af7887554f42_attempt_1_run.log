theorem quadratic_formula {a b c : ℝ} (ha : a ≠ 0) : 
    (a * x ^ 2 + b * x + c = 0) ↔ (x = (-b + Real.sqrt (b ^ 2 - 4 * a * c)) / (2 * a)) ∨ (x = (-b - Real.sqrt (b ^ 2 - 4 * a * c)) / (2 * a)) := by
