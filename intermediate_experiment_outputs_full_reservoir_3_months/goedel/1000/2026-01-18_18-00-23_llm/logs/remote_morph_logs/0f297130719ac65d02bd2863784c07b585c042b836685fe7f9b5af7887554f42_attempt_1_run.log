      ext ε
      rfl
    _ = fun ε => ∑ μ, ∑ ν, (distGDeriv μ (Λ • A) ε (Coordinatization.basisElementForm _ _ _)) (Lorentz.Vector.basis ν) • (Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν : _) := by
      ext ε
      simp [distGDeriv]
      <;>
      congr 1 <;>
      ext <;>
      simp [smul_smul, smul_eq_mul]
      <;>
      abel
    _ = fun ε => ∑ μ, ∑ ν, (distGDeriv μ (Λ • A) ε (Coordinatization.basisElementForm _ _ _)) (Lorentz.Vector.basis ν) • (Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν : _) := by rfl
    _ = fun ε => ∑ μ, ∑ ν, (distDeriv μ (Λ • A) ε ν) • (Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν : _) := by
      ext ε
      simp [distGDeriv]
      <;>
      congr 1 <;>
      ext <;>
      simp [smul_smul, smul_eq_mul]
      <;>
      abel
    _ = fun ε => ∑ μ, ∑ ν, (distDeriv μ A ε ν) • (Λ • (Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν : _) : _) := by
      ext ε
      have h1 : ∀ (μ : Fin 1 ⊕ Fin d) (ν : Fin 1 ⊕ Fin d),
          distDeriv μ (fun x => Λ • A x) ε ν = (distDeriv μ A ε ν) := by
        intro μ ν
        simp [distDeriv, smul_smul]
        <;>
        congr 1 <;>
        ext <;>
        simp [LorentzGroup.injective, mul_assoc]
        <;>
        congr 1 <;>
        ext <;>
        simp [LorentzGroup.injective, mul_assoc]
        <;>
        ring_nf
        <;>
        simp_all [mul_assoc]
      simp [h1]
      <;>
      congr 1 <;>
      ext <;>
      simp [smul_smul, smul_eq_mul]
      <;>
      abel
    _ = fun ε => Λ • (∑ μ, ∑ ν, (distDeriv μ A ε ν) • (Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν : _) : _) := by
      ext ε
      simp [map_sum, smul_smul]
      <;>
      congr 1 <;>
      ext <;>
      simp [smul_smul, smul_eq_mul]
      <;>
      abel
    _ = Λ • deriv A := by
      ext ε
      rfl
