lemma bot_not_mem {S : Set α} (R : refinement S) :
    ⊥ ∉ decomposition_of_refinement R := by
  simp [decomposition_of_refinement]
  intro h
  obtain ⟨I, hI, k, hk⟩ := h
  have h₁ : ⊥ ∉ I := R.bot_not_mem _ hI
  have h₂ : ⊥ ∈ I := by simpa [hk] using hk
  exact h₁ h₂
```
