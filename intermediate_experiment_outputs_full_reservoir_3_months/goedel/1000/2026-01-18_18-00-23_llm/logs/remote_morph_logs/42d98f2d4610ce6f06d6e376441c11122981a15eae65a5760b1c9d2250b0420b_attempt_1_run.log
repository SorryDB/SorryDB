/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := by
  have h : ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 := by
    use 1
    <;> norm_num [Nat.primeFactors]
    <;>
    (try decide) <;>
    (try contradiction) <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try decide)
    <;>
    simp_all [Nat.primeFactors]
    <;>
    norm_num
    <;>
    decide
  have h₁ : ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 := by
    exact h
  have h₂ : ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 := by
    exact h₁
  simp_all [h, h₁, h₂]
  <;>
  norm_num
  <;>
  decide

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  have h : (solution : Bool) = true := by
    rfl
  have h₁ : (∃ n : ℕ, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1) ↔ solution := by
    simp_all [h]
    <;>
    norm_num
    <;>
    aesop
  exact h₁
