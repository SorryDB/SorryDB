theorem exists_subsingleton_of_le_one {α : Type*} {s : Finset α} (h : s.card ≤ 1) : ∃ a : α, s = {a} :=
  by
  have h₁ : s.card ≤ 1 := h
  have h₂ : ∃ a : α, s = {a} := by
    by_cases h₃ : s = ∅
    · exfalso
      have h₄ : s.card = 0 := by simp [h₃]
      have h₅ : (0 : ℕ) ≤ 1 := by norm_num
      have h₆ : s.card ≤ 1 := h₁
      simp_all [h₄]
    · -- Case: s is not empty
      have h₄ : s.Nonempty := Finset.nonempty_iff_ne_empty.mpr h₃
      obtain ⟨a, ha⟩ := h₄
      have h₅ : s.card = 1 := by
        have h₅₁ : s.card ≤ 1 := h₁
        have h₅₂ : s.card ≥ 1 := by
          have h₅₃ : a ∈ s := ha
          have h₅₄ : s.card ≥ 1 := by
            apply Finset.card_pos.mpr
            exact ⟨a, h₅₃⟩
          exact h₅₄
        omega
      have h₆ : s = {a} := by
        apply Finset.eq_singleton_iff_unique_mem.mpr
        constructor
        · exact ha
        · intro x hx
          have h₇ : s.card = 1 := h₅
          have h₈ : x ∈ s := hx
          have h₉ : a ∈ s := ha
          have h₁₀ : x = a := by
            by_contra h₁₁
            have h₁₂ : x ≠ a := h₁₁
            have h₁₃ : s.card ≥ 2 := by
              have h₁₄ : {x, a} ⊆ s := by
                intro y hy
                simp only [Finset.mem_insert, Finset.mem_singleton] at hy
                rcases hy with (rfl | rfl)
                · exact hx
                · exact ha
              have h₁₅ : ({x, a} : Finset α).card ≤ s.card := Finset.card_le_card h₁₄
              have h₁₆ : ({x, a} : Finset α).card = 2 := by
                have h₁₇ : x ≠ a := h₁₂
                simp [h₁₇, Finset.card_insert_of_not_mem, Finset.mem_singleton]
              omega
            omega
          exact h₁₀
      exact ⟨a, h₆⟩
  exact h₂
