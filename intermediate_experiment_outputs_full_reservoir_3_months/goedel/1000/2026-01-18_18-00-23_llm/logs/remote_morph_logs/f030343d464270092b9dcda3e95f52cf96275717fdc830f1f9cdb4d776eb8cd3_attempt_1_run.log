def Comma_category_id_comp {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ (⟨d, e, f⟩ : Σ (d : D) (e : E), Hom (F.F d) (G.F e)),
      id_comp (⟨d, e, f⟩ : Σ (d : D) (e : E), Hom (F.F d) (G.F e)) = by
  intro ⟨d, e, f⟩
  rfl

def Comma_category_comp_id {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ (⟨d, e, f⟩ : Σ (d : D) (e : E), Hom (F.F d) (G.F e)),
      comp_id (⟨d, e, f⟩ : Σ (d : D) (e : E), Hom (F.F d) (G.F e)) = by
  intro ⟨d, e, f⟩
  rfl

def Comma_category_assoc {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ (⟨d₁, e₁, f₁⟩ ⟨d₂, e₂, f₂⟩ ⟨d₃, e₃, f₃⟩ : Σ (d : D) (e : E), Hom (F.F d) (G.F e)),
      (fun f g => assoc f g) ⟨d₁, e₁, f₁⟩ ⟨d₂, e₂, f₂⟩ ⟨d₃, e₃, f₃⟩ = by
  intro ⟨d₁, e₁, f₁⟩ ⟨d₂, e₂, f₂⟩ ⟨d₃, e₃, f₃⟩
  rfl

instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) where
  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := by
    intro ⟨d, e, f⟩
    simp [Comma_category_id_comp]
    <;>
    rfl

  comp_id := by
    intro ⟨d, e, f⟩
    simp [Comma_category_comp_id]
    <;>
    rfl

  assoc := by
    intro ⟨d₁, e₁, f₁⟩ ⟨d₂, e₂, f₂⟩ ⟨d₃, e₃, f₃⟩
    simp [Comma_category_assoc]
    <;>
    rfl

