theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  classical
  use { toFun := fun x => F.homF (X := ()) (Y := ()) x,
        map_one' := by
          have h₁ := F.map_id ()
          simp [Category.monoidHom] at h₁ ⊢
          <;>
          (try simp_all [MonoidHom.coe_one]) <;>
          (try rfl) <;>
          (try simp_all [MonoidHom.coe_one]) <;>
          (try aesop)
          <;>
          (try simp_all [MonoidHom.coe_one]) <;>
          (try aesop)
          <;>
          (try simp_all [MonoidHom.coe_one]) <;>
          (try aesop)
        , map_mul' := fun a b => by
          have h₂ := F.map_comp (id := by
            simp [Category.id]
            <;>
            aesop) (id := by
            simp [Category.id]
            <;>
            aesop)
          simp [Category.monoidHom] at h₂ ⊢
          <;>
          (try simp_all [MonoidHom.coe_mul]) <;>
          (try rfl) <;>
          (try simp_all [MonoidHom.coe_mul]) <;>
          (try aesop)
          <;>
          (try simp_all [MonoidHom.coe_mul]) <;>
          (try aesop)
          <;>
          (try simp_all [MonoidHom.coe_mul]) <;>
          (try aesop)
          }
  intro x
  <;> simp
  <;>
  (try simp_all [MonoidHom.coe_mul]) <;>
  (try rfl) <;>
  (try simp_all [MonoidHom.coe_mul]) <;>
  (try aesop)
  <;>
  (try simp_all [MonoidHom.coe_mul]) <;>
  (try aesop)
  <;>
  (try simp_all [MonoidHom.coe_mul]) <;>
  (try aesop)
