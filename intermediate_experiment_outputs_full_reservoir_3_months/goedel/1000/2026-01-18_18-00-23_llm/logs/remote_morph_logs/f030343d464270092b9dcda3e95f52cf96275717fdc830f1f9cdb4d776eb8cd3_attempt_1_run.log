  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    dsimp [F, homF]
    <;> simp [CD.map_id]
    <;> exact rfl
  
  map_comp f g := by
    dsimp [F, homF]
    <;> simp [CD.map_comp]
