def Hom_c_? {α : Type*} [Category α] (c : α) : Functor α Type where
  F Y := Hom c Y
  homF {Y Z : α} (f : Hom Y Z) (g : Hom c Y) := g ≫ f
  map_id Y := by
    intro g
    simp [id_comp]
    <;> simp_all [comp]
    <;> aesop

  map_comp {Y Z W : α} (f : Hom Y Z) (g : Hom Z W) := by
    intro h
    simp [comp_assoc]
    <;> simp_all [comp]
    <;> aesop

def Hom_?_c {α : Type*} [Category α] (c : α) : ContraFunctor α Type where
  F X := Hom X c
  homF {X Y : α} (f : Hom X Y) (g : Hom Y c) := f ≫ g
  map_id X := by
    intro g
    simp [id_comp]
    <;> simp_all [comp]
    <;> aesop

  map_comp {X Y Z : α} (f : Hom X Y) (g : Hom Y Z) := by
    intro h
    simp [comp_assoc]
    <;> simp_all [comp]
    <;> aesop

def PowerSetFunctor : Functor Type Type where
  F X := Set X
  homF f := Set.image f
  map_id X := by
    simp [Category.id]
    <;> ext <;> simp [Set.mem_image] <;> aesop
  map_comp f g := by
    simp [Category.comp]
    <;> ext <;> simp [Set.mem_image] <;>
    (try aesop) <;>
    (try {
      constructor <;> intro h <;>
      (try { aesop }) <;>
      (try {
        obtain ⟨x, hx, rfl⟩ := h
        obtain ⟨y, hy, rfl⟩ := hx
        use y
        <;> simp_all [Function.comp_apply]
        <;> aesop
      })
    })

def PowerSetContraFunctor : ContraFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Category.id]
    <;> ext <;> simp [Set.mem_preimage] <;> aesop
  map_comp f g := by
    simp [Category.comp]
    <;> ext <;> simp [Set.mem_preimage, Function.comp_apply] <;>
    (try aesop) <;>
    (try {
      constructor <;> intro h <;>
      (try { aesop }) <;>
      (try {
        simp_all [Function.comp_apply]
        <;> aesop
      })
    })

def EndoFunctor (α : Type*) [Category α] := @Functor α α

def IdFunctor {α : Type*} [Category α] : Functor α α where
  F X := X
  homF f := f
  map_id _ := rfl
  map_comp _ _ := rfl

``` 

