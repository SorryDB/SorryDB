theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨fun x => F.F x, _, _⟩
  · -- Prove that F.F is monotone
    intro a b hab
    have h : F.PC (⟨le_refl a⟩ : Hom a a) = ⟨le_refl (F.F a)⟩ := by
      simp [F.map_id]
    -- Extract the proof that F.F a ≤ F.F a from h
    have h₁ : F.PC (⟨hab⟩ : Hom a b) = ⟨hab⟩ := by simp [F.map_id]
    -- Use the fact that F.PC (⟨hab⟩ : Hom a b) is a proof of F.F a ≤ F.F b
    -- to conclude that F.F a ≤ F.F b
    have h₂ : F.F a ≤ F.F b := by
      have h₃ : (F.PC (⟨hab⟩ : Hom a b)).prop = (hab : a ≤ b) := by
        simp [F.map_id]
      -- Since F.PC (⟨hab⟩ : Hom a b) is a proof of F.F a ≤ F.F b,
      -- and (F.PC (⟨hab⟩ : Hom a b)).prop = (hab : a ≤ b),
      -- we can conclude that F.F a ≤ F.F b.
      have h₄ : (F.PC (⟨hab⟩ : Hom a b)).prop = (hab : a ≤ b) := by simp [F.map_id]
      -- Use the fact that F.PC (⟨hab⟩ : Hom a b) is a proof of F.F a ≤ F.F b
      -- to conclude that F.F a ≤ F.F b.
      exact by simpa [h₃] using (F.PC (⟨hab⟩ : Hom a b)).prop
    exact h₂
  · -- Prove that F.F x = f x for all x
    intro x
    rfl
