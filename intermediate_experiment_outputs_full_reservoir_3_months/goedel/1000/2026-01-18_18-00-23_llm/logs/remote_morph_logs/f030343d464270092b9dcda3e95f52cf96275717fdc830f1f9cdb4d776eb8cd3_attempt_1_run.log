theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨F.F, _⟩
  constructor
  · -- Prove that F.F is monotone
    intro x y hxy
    have h : F.homF (Puniv.mk hxy) = F.homF (Puniv.mk hxy) := rfl
    -- Use the fact that F is a functor to deduce that F.F is monotone
    have h₁ : F.homF (Puniv.mk hxy) = (F.homF (Puniv.mk hxy)).down := by simp
    -- Extract the underlying proof from the morphism
    have h₂ : (F.homF (Puniv.mk hxy)).down : F.F x ≤ F.F y := by
      -- Since F is a functor, it preserves the order
      have h₃ : (F.homF (Puniv.mk hxy)).down : F.F x ≤ F.F y := by
        -- Extract the underlying proof from the morphism
        simp [hxy] at h
        <;>
        (try cases h) <;>
        (try simp_all [Puniv.mk, MonoidHom.id, MonoidHom.comp]) <;>
        (try omega) <;>
        (try exact h)
        <;>
        aesop
      exact h₃
    exact h₂
  · -- Prove that F.F x = F.F x for all x : α
    intro x
    rfl
