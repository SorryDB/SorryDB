```lean
def beq (x : BitVec w) (y : BitVec w) : Bool :=
  go (w - 1)
where
  go : Nat → Bool
    | 0     => x.getLsbD (w - 1) == y.getLsbD (w - 1)
    | i + 1 => x.getLsbD ((w - 1) - (i + 1)) == y.getLsbD ((w - 1) - (i + 1)) && go i

def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  by
    have h₁ : (x = y) = (x.beq y = true) := by
      -- Use the fact that the bits are equal if and only if all corresponding bits are equal
      simp [beq, go, Bool.and_assoc]
      <;>
      (try decide) <;>
      (try {
        cases w with
        | zero => simp_all [BitVec.ext_iff]
        | succ w =>
          simp_all [BitVec.ext_iff, List.cons, List.nil]
          <;>
          (try decide) <;>
          (try {
            induction w with
            | zero => simp_all [List.cons, List.nil]
            | succ w ih =>
              simp_all [List.cons, List.nil, Nat.succ_eq_add_one]
              <;>
              (try decide)
          })
      }) <;>
      (try {
        rcases x with ⟨⟩
        rcases y with ⟨⟩
        simp_all [BitVec.ext_iff, List.cons, List.nil]
        <;>
        (try decide) <;>
        (try {
          induction w with
          | zero => simp_all [List.cons, List.nil]
          | succ w ih =>
            simp_all [List.cons, List.nil, Nat.succ_eq_add_one]
            <;>
            (try decide)
        })
      }) <;>
      (try {
        cases w <;> simp_all [BitVec.ext_iff, List.cons, List.nil, Nat.succ_eq_add_one]
        <;>
        (try decide)
      })
      <;>
      simp_all [List.cons, List.nil]
      <;>
      (try decide)
      <;>
      (try {
        aesop
      })
      <;>
      (try {
        norm_num
        <;>
        aesop
      })
      <;>
      (try {
        simp_all [List.cons, List.nil]
        <;>
        aesop
      })
      <;>
      (try {
