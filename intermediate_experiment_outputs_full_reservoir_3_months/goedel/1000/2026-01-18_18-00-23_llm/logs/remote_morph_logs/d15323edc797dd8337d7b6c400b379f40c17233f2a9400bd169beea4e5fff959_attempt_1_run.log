      have h4 : HasLaw (fun ω ↦ u \ X ω) (Ber(u, p) ∘ (fun s ↦ u \ s)⁻¹) P := by
        have h5 : HasLaw (fun ω ↦ X ω) (Ber(u, p)) P := h1
        have h6 : HasLaw (fun ω ↦ u \ X ω) (Ber(u, p) ∘ (fun s ↦ u \ s)⁻¹) P :=
          h5.map (by
            -- Prove that the function `fun s ↦ u \ s` is measurable
            have h7 : Measurable (fun s : Set ι ↦ u \ s) :=
