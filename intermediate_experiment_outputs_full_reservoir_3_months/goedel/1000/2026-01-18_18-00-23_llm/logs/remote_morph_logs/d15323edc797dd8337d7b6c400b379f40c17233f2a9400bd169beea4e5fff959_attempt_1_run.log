      have h3 : Measurable X := h2.measurableX
      exact h3.ae
    
    have h2 : AEMeasurable (fun ω => u \ X ω) P := by
      have h3 : AEMeasurable (fun ω : Ω => (u : Set ι)) P := by
        -- The set `u` is constant and thus measurable.
