lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by sorry
  aemeasurable := by
    have h := hX.2.absolutelyContinuous
    have h₁ := hX.1
    have h₂ : AEMeasurable X P := by
      have h₃ : AEMeasurable X P := by
        have h₄ : HasLaw X Ber(u, p) P := hX.1
        exact h₄.aemeasurable
      exact h₃
    have h₃ : AEMeasurable (fun ω ↦ u \ X ω) P := by
      have h₄ : AEMeasurable X P := h₂
      have h₅ : AEMeasurable (fun ω ↦ u \ X ω) P := by
        apply MeasurableSet.diff (measurableSet_univ) (h₄)
        <;> simp_all [AEMeasurable]
        <;>
        (try simp_all [AEMeasurable])
        <;>
        (try aesop)
      exact h₅
    exact h₃
```

