theorem dist_self (a : Real) : dist a a = zero := by
  have h : dist a a = zero := by
    -- Assume for contradiction that dist a a ≠ zero
    by_contra h₁
    -- Use the fact that the distance from a to a is zero by definition
    have h₂ : dist a a = zero := by
      -- Use the property that the distance from any point to itself is zero
      -- This is a fundamental property of the distance function
