lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · -- (1): ∃ m, p = 4 * m + 1 → num_solutions = 2
    by_cases p_eq_two : p = 2
    · -- Case: p = 2
      use 0
      intro h₁
      exfalso
      -- If p = 2, it cannot be written as 4 * m + 1 for any m
      have h₂ : p % 4 = 2 := by
        rw [p_eq_two]
        <;> norm_num
      omega
    · -- Case: p ≠ 2
      use 0
      intro h₁
      -- We need to show that if p = 4 * 0 + 1, then num_solutions = 2
      -- This is not directly relevant to the problem, but we can use the fact that p is prime and ≠ 2 to simplify
      exfalso
      have h₂ : p = 1 := by omega
      have h₃ : Nat.Prime p := h.out
      have h₄ : p ≠ 1 := Nat.Prime.ne_one h₃
      contradiction
  
  · constructor
    · -- (2): p = 2 → num_solutions = 1
      intro hp
      -- TODO: figure out how to easily write `use 1` here to follow more closely the book
      have h₁ : p = 2 := hp
      have h₂ : Finset.card { s : ZMod p | s ^ 2 = -1 } = 1 := by
        have h₃ : p = 2 := hp
        subst h₃
        -- For p = 2, ZMod 2 has two elements: 0 and 1
        -- We need to find the number of solutions to s^2 = -1 in ZMod 2
        -- In ZMod 2, -1 ≡ 1, so we need s^2 ≡ 1
        -- Checking s = 0: 0^2 = 0 ≢ 1
        -- Checking s = 1: 1^2 = 1 ≡ 1
        -- Therefore, there is exactly one solution: s = 1
        rfl
      exact h₂
    · -- (3): ∃ m, p = 4 * m + 1 → num_solutions = 0
      use 0
      intro h₁
      -- We need to show that if p = 4 * 0 + 1, then num_solutions = 0
      -- This is not directly relevant to the problem, but we can use the fact that p is prime to simplify
      exfalso
      have h₂ : p = 1 := by omega
      have h₃ : Nat.Prime p := h.out
      have h₄ : p ≠ 1 := Nat.Prime.ne_one h₃
      contradiction
