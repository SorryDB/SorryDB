theorem theorem₁  {p : ℕ} [h : Fact p.Prime] (hp : p % 4 = 1) : ∃ a b : ℕ, a ^ 2 + b ^ 2 = p := by
  have h_main : ∃ a b : ℕ, a ^ 2 + b ^ 2 = p := by
    have h₁ : p % 4 ≠ 3 := by
      intro h₂
      have h₃ : p % 4 = 1 := hp
      omega
    -- Use the existing theorem `Nat.Prime.sq_add_sq` to find `a` and `b`
    have h₂ : ∃ a b : ℕ, p = a ^ 2 + b ^ 2 := by
      -- Use the fact that `p` is a prime and `p % 4 ≠ 3`
      have h₃ : p.Prime := h.1
      have h₄ : p % 4 ≠ 3 := h₁
      -- Use the theorem to get the existence of `a` and `b`
      exact Nat.Prime.sq_add_sq h₃ h₄
    -- Reorder the equation to match the required form
    obtain ⟨a, b, h₃⟩ := h₂
    refine' ⟨a, b, _⟩
    linarith
  exact h_main
