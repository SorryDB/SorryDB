lemma product_support {őĪ ő≤ : Type} [Inhabited őĪ] [Inhabited ő≤] [SampleableType őĪ] [SampleableType ő≤] (x : őĪ √ó ő≤) : x ‚ąą support ((fun x1 x2 => (x1, x2)) <$> uniformSample őĪ _ <*> uniformSample ő≤ _) := by
  have h‚āĀ : Set.univ √óňĘ Set.univ = Set.univ := by
    ext ‚ü®a, b‚ü©
    simp
  have h‚āā : support (uniformSample őĪ _) = Set.univ := by
    apply eq_univ_of_forall
