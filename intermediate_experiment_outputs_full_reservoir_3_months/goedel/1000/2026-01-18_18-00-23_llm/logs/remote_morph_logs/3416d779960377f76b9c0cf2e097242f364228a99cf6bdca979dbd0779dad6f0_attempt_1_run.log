```lean
theorem fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  simp [fnz, Nat.cast_add, Nat.cast_mul, Nat.cast_ofNat]
  <;> induction k <;> simp_all [Nat.mul_succ, Nat.add_assoc]
  <;> ring_nf at *
  <;> norm_num at *
  <;> linarith
```

```lean
theorem fnz_fzn : fnz ∘ fzn = id := by
  funext n
  simp [fnz, fzn]
  <;> induction n <;> simp_all [Nat.even_iff, Nat.odd_iff, Nat.mod_eq_of_lt]
  <;> norm_num at *
  <;> ring_nf at *
  <;> omega
```

```lean
theorem tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  simp [tri, Nat.succ_eq_add_one, add_assoc]
  <;> ring_nf
  <;> simp_all [Nat.mul_succ]
  <;> ring_nf at *
  <;> omega
```

```lean
theorem tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n : ℕ, tri n = n * (n + 1) / 2 := by
    intro n
    simp [tri]
    <;> ring_nf
    <;> simp [Nat.mul_add, Nat.add_mul, Nat.mul_one, Nat.mul_zero]
    <;> ring_nf
    <;> norm_num
    <;> rfl
  rw [h2 j, h2 k]
  have h3 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h4 : j ≤ k := h1
    have h5 : j * (j + 1) ≤ k * (k + 1) := by
      have h6 : j ≤ k := h4
      have h7 : j + 1 ≤ k + 1 := by omega
      nlinarith
    have h8 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      have h9 : j * (j + 1) ≤ k * (k + 1) := h5
      have h10 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
        apply Nat.div_le_div_right
        <;> nlinarith
      exact h10
    exact h8
  exact h3
