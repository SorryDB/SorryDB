variable {𝕜 : Type*} [NontriviallyNormedField 𝕜]
variable {E : Type*} [NormedAddCommGroup E] [NormedSpace 𝕜 E]
variable {F : Type*} [NormedAddCommGroup F] [NormedSpace 𝕜 F]

theorem isCompact_closedBall {x : E} {r : ℝ} (hr : 0 ≤ r) :
    IsCompact {y : E | ‖y - x‖ ≤ r} := by
  haveI : CompleteSpace 𝕜 E := by infer_instance
  have h₁ : IsCompact {y : E | ‖y - x‖ ≤ r} :=
    isCompact_closedBall.of_normedSpace x r hr
  exact h₁
```
