    ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
  have h1 : (∫ x in s, exp x * f (exp x)) = ∫ x in s, (exp x • f (exp x)) := by
    simp [mul_comm]
    <;>
    congr
    <;>
    ext
    <;>
    ring
  rw [h1]
