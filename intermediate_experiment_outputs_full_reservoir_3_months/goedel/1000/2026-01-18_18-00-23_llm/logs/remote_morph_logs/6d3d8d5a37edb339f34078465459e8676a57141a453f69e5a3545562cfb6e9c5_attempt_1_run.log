    -- Use the fact that m + 1 ≤ n to deduce m ≤ n
    have h₁ : (m : ℕ∞) ≤ (n : ℕ∞) := by
      have h₂ : (m : ℕ∞) + 1 ≤ (n : ℕ∞) := by simpa using hmn
      exact le_of_add_le_add_left h₂ 0
