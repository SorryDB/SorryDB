  have h₁ : (m : ℕ∞) ≤ (n : ℕ∞) := by
    have h₂ : (m : ℕ∞) + 1 ≤ (n : ℕ∞) := by simpa using hmn
    -- Use the fact that for any x : ℕ∞, x ≤ x + 1 to deduce x ≤ y from x + 1 ≤ y
