theorem Trivialization.smoothAt (e : Trivialization F (π F E)) [MemTrivializationAtlas e]
    {x₀ : TotalSpace F E} (hx₀ : x₀.proj ∈ e.baseSet) :
    ContMDiffAt (IB.prod 𝓘(𝕜, F)) (IB.prod 𝓘(𝕜, F)) ∞ e x₀ := by
  rw [@contMDiffAt_prod_iff]
  refine ⟨(contMDiffAt_proj E).congr_of_eventuallyEq ?_, ?_⟩
  · exact eventually_of_mem (e.open_source.mem_nhds <| e.mem_source.mpr hx₀) fun x hx ↦ e.coe_fst hx
  simp_rw [contMDiffAt_iff_source_of_mem_source (mem_chart_source _ _)]
  simp only [FiberBundle.extChartAt, Function.comp, prod_univ, mfld_simps]
  let e' := trivializationAt F E x₀.proj
  have h : ContMDiffAt IB 𝓟 𝕜 ∞ (fun x : B ↦ (e'.coordChangeL 𝕜 e x : F →L[𝕜] F)) x₀.proj := by
    have h₁ : ContMDiffAt IB 𝓟 𝕜 ∞ (fun x : B ↦ (e'.coordChangeL 𝕜 e x : F →L[𝕜] F)) x₀.proj :=
      (contMDiffOn_coordChangeL e e').contMDiffAt (e'.open_baseSet.inter e.open_baseSet).mem_nhds ⟨hx₀, e.mem_base_set.mpr hx₀⟩
    exact h₁
  have h₂ : ContMDiffAt 𝓟 𝕜 𝓟 𝕜 ∞ (fun x : F ↦ x) (x₀.snd) := by
    apply contDiffAt_id
  have h₃ : ContMDiffAt (IB.prod 𝓟 𝕜) (𝟙 𝕜) ∞ (fun x : B × F ↦ x.2) x₀ :=
    contMDiffAt_snd
  have h₄ : ContMDiffAt (IB.prod 𝓟 𝕜) (𝟙 𝕜) ∞ (fun x : B × F ↦ x.1) x₀ :=
    contMDiffAt_fst
  -- Combine all the necessary smoothness conditions using the fact that the projection maps are smooth
  refine' (h.restrict ?_).comp _ h₄
  <;> simp_all [Function.comp]
  <;> aesop
