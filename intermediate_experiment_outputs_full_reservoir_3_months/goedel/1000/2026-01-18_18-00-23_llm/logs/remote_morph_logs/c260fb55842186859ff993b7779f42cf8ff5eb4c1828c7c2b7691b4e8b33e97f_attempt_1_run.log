lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove the iSupIndep part
    have h₁ : sSupIndep (Set.range (fun p : I => (p : Submodule K (M.obj c)))) :=
        (I.sSupIndep' : sSupIndep (SetLike.coe I)).map (fun p : I => p.val c)
    simpa [Set.range] using h₁
  · -- Prove the iSup_eq_top part
    have h₂ : (⨆ (p : I), (p : Submodule K (M.obj c))) = ⊤ := by
      have h₃ : (⨆ (p : I), (p : Submodule K (M.obj c))) = (⨆ (p : I), (p.val : C ⥤ (Module K)) c) := by simp
