lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h1 : sSup (SetLike.coe D : Set (PersistenceSubmodule M)) = ⊤ := D.sSup_eq_top'
  have h2 : ∀ (s : Set (PersistenceSubmodule M)), sSup s = ⊤ → ∀ (a : C), ⨆ p ∈ s, p a = ⊤ := by
    intro s hs a
    have h3 : (⨆ p ∈ s, p a) = (⨆ p ∈ s, p a) := rfl
    have h4 : (⨆ p ∈ s, p a) = ((sSup s) a) := by
      -- Use the fact that the supremum of a set of persistence submodules at each point is the supremum of their values at that point.
      simp [iSup_sup, sSup_def]
      <;>
      simp_all [iSup_sup, sSup_def]
      <;>
      congr 1 <;>
      ext <;>
      simp [iSup_le_iff, le_iSup]
      <;>
      tauto
    rw [h4]
    have h5 : (sSup s) a = ⊤ := by
      rw [hs]
      <;> simp [top_mem]
    rw [h5]
  have h6 : ∀ (a : C), ⨆ p ∈ (SetLike.coe D : Set (PersistenceSubmodule M)), p a = ⊤ := h2 (SetLike.coe D) h1
  have h7 : ⨆ p ∈ D, p x = ⊤ := h6 x
  exact h7

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := pointwise_iSup_eq_top D x

