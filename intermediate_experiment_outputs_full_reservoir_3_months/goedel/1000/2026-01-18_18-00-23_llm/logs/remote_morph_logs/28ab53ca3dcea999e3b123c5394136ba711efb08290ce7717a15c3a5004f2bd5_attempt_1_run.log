theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: split_epi f → ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g)
    intro h
    intro c
    have h₁ : ∃ (g : Hom Y X), f ≫ g = id X := by
      obtain ⟨g, hg⟩ := h
      refine' ⟨g, _⟩
      simpa [isRetraction] using hg
    obtain ⟨g, hg⟩ := h₁
    intro z
    have h₂ : ∃ (h : Hom Y c), f ≫ h = z := by
      use g ≫ z
      calc
        f ≫ (g ≫ z) = (f ≫ g) ≫ z := by rw [comp_assoc]
        _ = id X ≫ z := by rw [hg]
        _ = z := by simp [id_comp]
    exact h₂
  · -- Prove the backward direction: (∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g)) → split_epi f
    intro h
    have h₁ : ∃ (g : Hom Y X), f ≫ g = id X := by
      have h₂ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
      obtain ⟨g, hg⟩ := h₂ (id X)
      refine' ⟨g, _⟩
      simpa [id_comp] using hg
    obtain ⟨g, hg⟩ := h₁
    exact ⟨g, by simpa [isRetraction] using hg⟩
```
