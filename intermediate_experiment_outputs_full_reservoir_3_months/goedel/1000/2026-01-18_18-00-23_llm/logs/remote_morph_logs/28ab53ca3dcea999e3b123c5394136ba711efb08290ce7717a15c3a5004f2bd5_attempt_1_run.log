```lean
theorem split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective fun g : Hom Y c => comp f g := by
  constructor
  · -- Forward direction: split_epi f → ∀ c, surjective (fun g ↦ f ≫ g)
    rintro ⟨g₀, hg₀⟩ c h
    -- Use g₀ ≫ h as the preimage of h under (fun g ↦ f ≫ g)
    refine' ⟨g₀ ≫ h, _⟩
    -- Verify that f ≫ (g₀ ≫ h) = h
    calc
      comp f (g₀ ≫ h) = (comp f g₀) ≫ h := by rw [comp_assoc]
      _ = (1 : Hom X X) ≫ h := by rw [hg₀]
      _ = h := by simp [one_comp]
  · -- Backward direction: (∀ c, surjective (fun g ↦ f ≫ g)) → split_epi f
    intro h
    -- Use c = X and h = id X to find a right inverse g : Hom Y X
    have h' : Function.Surjective (fun g : Hom Y X => comp f g) := h X
    -- There exists g : Hom Y X such that f ≫ g = id X
    obtain ⟨g, hg⟩ := h' (1 : Hom X X)
    -- Verify that g is indeed a right inverse
    refine' ⟨g, _⟩
    simpa [one_comp] using hg
