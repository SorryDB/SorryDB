          simp [associative]
          <;> simp_all [congr_arg]
          <;> simp_all [congr_arg]
        _ = b ≫ (id X) := by rw [hg]
        _ = b := by simp [congr_arg]
    obtain ⟨h, hh⟩ := h₂
