        -- Use the fact that the real and imaginary parts are smooth
        have h₄ : ContDiffOn 𝕜 ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := by
          simpa using h₂
        -- Use the fact that the real and imaginary parts are smooth
        have h₅ : ContDiffOn (ℝ) ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := by
          -- Convert the complex C^∞ condition to a real C^∞ condition
          have h₆ : ContDiffOn (ℝ) ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := h₄.of_real
          exact h₆
        -- Use the fact that the real and imaginary parts are smooth
        have h₆ : ContDiffOn (ℝ) ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := h₅
        -- Use the fact that the real and imaginary parts are smooth
        have h₇ : ContDiffOn (ℝ) ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := h₆
        -- Use the fact that the real and imaginary parts are smooth
        have h₈ : ContDiffOn (ℝ) ∞ (fun x : ℂ => (Φ₁' r x : ℂ)) ℍ₀ := h₇
        -- Use the fact that the real and imaginary parts are smooth
        simpa using h₈
      -- Use the fact that the real and imaginary parts are smooth
      exact h₃
    -- Use the fact that Φ₁' r is holomorphic and thus smooth to prove it is C^∞
    exact h₁
  -- Use the fact that Φ₂' r = Φ₁' r to conclude that Φ₂' r is C^∞
  have h₁ : Φ₂' r = Φ₁' r := by
    -- Prove that Φ₂' r = Φ₁' r
    funext z
    -- Use the definitions of Φ₂' and Φ₁'
