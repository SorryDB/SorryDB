theorem Φ₂'_contDiffOn : ContDiffOn ℝ ∞ (Φ₂' r) ℍ₀ := by
  have h₁ : Φ₂' r = (fun z => (1 : ℂ) / (z + 1) ^ 2 * φ₀'' z * Complex.exp (-(r : ℂ) * z)) := rfl
  rw [h₁]
  have h₂ : ContDiffOn ℝ ∞ (fun z : ℂ => (1 : ℂ) / (z + 1) ^ 2 * φ₀'' z * Complex.exp (-(r : ℂ) * z)) ℍ₀ := by
    have h₃ : ContDiffOn ℝ ∞ (fun z : ℂ => (1 : ℂ) / (z + 1) ^ 2) ℍ₀ := by
      -- The function 1/(z + 1)^2 is smooth on ℂ \ {-1}, and -1 is not in the upper half-plane.
      apply contDiffOn_const.div
      · apply contDiffOn_pow
        apply ContDiffOn.add
        · exact contDiffOn_id
        · exact contDiffOn_const _
      · intro z hz
        have : z.im > 0 := hz
        have : z + 1 ≠ 0 := by
          intro h
          have h₁ := h
          simp [Complex.ext_iff] at h₁
          <;>
          (try norm_num at h₁) <;>
          (try linarith) <;>
          (try nlinarith)
        exact by
          intro h
          apply this
          simp_all [Complex.ext_iff, pow_two]
          <;>
          (try ring_nf at * ) <;>
          (try norm_num at * ) <;>
          (try simp_all [Complex.ext_iff, pow_two]) <;>
          (try nlinarith)
    have h₄ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z) ℍ₀ := by
      -- φ₀'' is smooth (since φ₀ is smooth)
      have h₅ : φ₀'' = (fun z : ℂ => Complex.ofReal (1 : ℝ)) := by
        funext z
        simp [φ₀'', Real.toNNReal_of_nonneg, Real.div_split]
        <;>
        simp_all [Complex.ext_iff, pow_two]
        <;>
        ring_nf
        <;>
        norm_num
        <;>
        (try simp_all [Complex.ext_iff, pow_two]) <;>
        (try linarith)
        <;>
        (try nlinarith)
      rw [h₅]
      exact contDiffOn_const
    have h₅ : ContDiffOn ℝ ∞ (fun z : ℂ => Complex.exp (-(r : ℂ) * z)) ℍ₀ := by
      -- exp(-(r : ℂ) * z) is smooth
      apply ContDiffOn.exp
      apply ContDiffOn.mul
      · exact contDiffOn_const
      · exact contDiffOn_id
    -- The product of smooth functions is smooth.
    have h₆ : ContDiffOn ℝ ∞ (fun z : ℂ => (1 : ℂ) / (z + 1) ^ 2 * φ₀'' z) ℍ₀ := by
      apply h₃.mul h₄
    have h₇ : ContDiffOn ℝ ∞ (fun z : ℂ => (1 : ℂ) / (z + 1) ^ 2 * φ₀'' z * Complex.exp (-(r : ℂ) * z)) ℍ₀ := by
      apply h₆.mul h₅
    exact h₇
  exact h₂
