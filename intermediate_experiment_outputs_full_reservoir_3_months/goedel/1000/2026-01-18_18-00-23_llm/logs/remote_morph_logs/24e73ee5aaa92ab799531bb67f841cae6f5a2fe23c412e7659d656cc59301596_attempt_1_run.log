          <;>
          (try { contradiction }) <;>
          (try { rfl })
        })
      })
    <;>
    (try
      {
        simp_all [fromRA, consRA, list_cons, List.foldr]
        <;>
        (try { contradiction }) <;>
        (try { rfl })
      })
