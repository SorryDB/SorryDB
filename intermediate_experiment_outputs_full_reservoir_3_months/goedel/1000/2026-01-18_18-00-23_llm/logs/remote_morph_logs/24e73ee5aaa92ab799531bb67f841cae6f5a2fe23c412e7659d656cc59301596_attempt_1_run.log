def consRA {a : Type} : Digit a → SymList a → RAList a
| Digit.cons x xs, ys => (x :: xs, ys)
| Digit.zero, (x :: xs, ys) => (xs, x :: ys)
| Digit.zero, ([] , []) => ([] , [])

def nilRA : RAList a := ([], [])

def fromRA : RAList a → List a
  | (1 :: ys, xs) => 1 :: fromRA (ys, xs)
  | ([] , []) => []
  | (ys, 1 :: xs) => 1 :: fromRA (ys, xs)
  | (ys, [] ) => fromRA (ys.reverse, [])
  | (ys, xs) => fromRA (ys ++ xs.reverse, [])

def toRA {a : Type} : List a → RAList a :=
  List.foldr consRA nilRA

example : ∀ (xs : List a), xs = fromRA (toRA xs) := by
  intro xs
  induction xs with
  | nil => rfl
  | cons x xs ih =>
    simp [toRA, fromRA, consRA]
    rw [ih]
    <;> simp_all [List.foldr]
    <;>
    (try
      {
        cases ds <;> simp_all [Digit, consRA, list_cons, List.foldr]
        <;>
        (try { contradiction }) <;>
        (try { rfl }) <;>
        (try {
