    refine' gen_le_iff.mpr _
    intro s hs
    -- We need to show that it is in the product σ-algebra if it is generated by such sets.
    have h4 : ∃ (t : T) (A : Set Ω), A ∈ 𝓔 t ∧ s = A ×ˢ ({t} : Set T) := by
