    intro t A hA
    have h3 : MeasurableSet ({t} : Set T) := h1 t
    have h4 : MeasurableSet A := by
      have h5 : A ∈ 𝓔 t := hA
      exact (measurableSpace mΩ).measurableSet_of_mem h5
    -- The product of two measurable sets is measurable in the product space
    exact MeasurableSet.prod h4 h3
  
