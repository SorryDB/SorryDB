lemma _root_.MeasureTheory.Filtration.predictable_le_prod (𝓟 : ∀ (t : T), MeasurableSpace (Ω × T)) :
  𝓟 ≤ Prod.instMeasurableSpace := by
  intro t
  <;> simp_all [Monotone]
  <;> aesop
