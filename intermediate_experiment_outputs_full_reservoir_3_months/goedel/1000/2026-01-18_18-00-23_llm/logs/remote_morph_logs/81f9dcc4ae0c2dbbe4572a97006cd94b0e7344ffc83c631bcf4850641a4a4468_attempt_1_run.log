    obtain ⟨t, A, hA, rfl⟩ := h4
    have h5 : MeasurableSet (A ×ˢ ({t} : Set T) : Set (Ω × T)) := h2 t A hA
    -- Since A × {t} is measurable in the product σ-algebra, we can conclude that it is in the product σ-algebra.
