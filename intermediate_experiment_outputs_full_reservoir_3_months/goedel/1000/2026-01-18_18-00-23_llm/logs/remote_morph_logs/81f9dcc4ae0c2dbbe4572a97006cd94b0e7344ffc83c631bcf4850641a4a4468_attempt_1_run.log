lemma _root_.MeasureTheory.Filtration.predictable_le_prod (𝓓 : Filtration T mΩ) :
    𝓓.predictable ≤ Prod.instMeasurableSpace := by
  have h : 𝓓.predictable ≤ (𝓓.map (fun t : T => id : T → (T := T))) := by
    apply Prod.instMeasurableSpace.le_def.mp
    <;> simp [Filtration.map_id]
    <;>
    (try simp_all)
    <;>
    (try norm_num)
    <;>
    (try linarith)
    <;>
    (try aesop)
  
  -- Use the fact that the predictable σ-algebra is a subset of the product σ-algebra
  have h₁ : (𝓓.map (fun t : T => id : T → (T := T))) = 𝓓 := by
    congr 1
    ext
    <;> simp [Filtration.map_id]
    <;>
    (try simp_all)
    <;>
    (try norm_num)
    <;>
    (try linarith)
    <;>
    (try aesop)
  
  -- Simplify the expression to get the final result
  have h₂ : 𝓓.predictable ≤ 𝓓 := by
    calc
      𝓓.predictable ≤ (𝓓.map (fun t : T => id : T → (T := T))) := h
      _ = 𝓓 := h₁
  
  -- Use the fact that the product σ-algebra is the smallest σ-algebra containing all products
  have h₃ : 𝓓 ≤ Prod.instMeasurableSpace := by
    apply le_trans _ (le_refl _)
    <;> simp [Filtration.map_id]
    <;>
    (try simp_all)
    <;>
    (try norm_num)
    <;>
    (try linarith)
    <;>
    (try aesop)
  
  -- Combine the inequalities to get the final result
  calc
    𝓓.predictable ≤ 𝓓 := h₂
    _ ≤ Prod.instMeasurableSpace := h₃
