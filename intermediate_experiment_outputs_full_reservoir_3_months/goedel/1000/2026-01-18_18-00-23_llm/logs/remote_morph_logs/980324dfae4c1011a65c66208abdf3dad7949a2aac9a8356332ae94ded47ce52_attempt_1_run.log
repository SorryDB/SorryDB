    constructor
    · exact ⟨∅, by simp [IsMatching], by simp [V]⟩
    · simp
  
  indep_subset := by
    intro S T hST hT_ind
    rcases hT_ind with ⟨M, hM, hT_subset⟩
    refine' ⟨M, hM, _⟩
