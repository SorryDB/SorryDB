    have h₃ : 0 < (x - 1) ^ 2 := by
      have h₄ : x ≠ 1 := h₀.1
      have h₅ : x - 1 ≠ 0 := by
        intro h₆
        apply h₄
        linarith
      exact sq_pos_of_ne_zero h₅
    have h₄ : 0 < (y - 1) ^ 2 := by
