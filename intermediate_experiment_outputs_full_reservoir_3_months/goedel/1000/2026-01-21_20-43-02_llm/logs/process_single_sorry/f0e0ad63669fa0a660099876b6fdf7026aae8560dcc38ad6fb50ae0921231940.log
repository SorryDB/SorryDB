        have h₆ : x / 2 + x / 2 = x / 2 * 2 := by ring
        rw [h₆]
        omega
      exact h₅
    | inr h₂ =>
      -- Case: x is odd (x % 2 = 1)
      have h₃ : x % 2 = 1 := h₂
      have h₄ : x / 2 * 2 + 1 = x := by
        have h₅ : x % 2 = 1 := h₃
