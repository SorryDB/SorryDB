        have h₉ : x - 1 + 1 = x := by
          have h₁₀ : x ≥ 1 := by
            by_contra h
            have h₁₁ : x = 0 := by omega
            rw [h₁₁] at h₄
            omega
          omega
        have h₁₀ : x / 2 + x / 2 = x := by
          omega
        exact h₁₀
      exact h₅
  exact h₁
