theorem erdos_straus :
    ∀ n : ℕ, 2 ≤ n → ∃ x y z : ℕ, 4 * x * y * z = n * (x * y + x * z + y * z) :=
  by
  intro n hn
  have h₁ : ∃ (x y z : ℕ), 4 * x * y * z = n * (x * y + x * z + y * z) := by
    by_cases h : n % 2 = 0
    · -- Case: n is even
      use 1, 1, (n / 2)
      have h₂ : n % 2 = 0 := h
      have h₃ : 2 * (n / 2) = n := by
        have h₄ : n % 2 = 0 := h₂
        have h₅ : 2 * (n / 2) = n := by
          omega
        exact h₅
      simp [h₃, mul_assoc]
      <;> ring_nf at *
      <;> omega
    · -- Case: n is odd
      use 1, 1, (n - 1) / 2
      have h₂ : n % 2 = 1 := by
        have h₃ : n % 2 ≠ 0 := h
        have h₄ : n % 2 = 1 := by
          have h₅ : n % 2 = 0 ∨ n % 2 = 1 := by omega
          cases h₅ with
          | inl h₅ =>
            exfalso
            apply h₃
            exact h₅
          | inr h₅ =>
            exact h₅
        exact h₄
      have h₃ : 2 * ((n - 1) / 2) + 1 = n := by
        have h₄ : n % 2 = 1 := h₂
        have h₅ : 2 * ((n - 1) / 2) + 1 = n := by
          have h₆ : n ≥ 2 := by omega
          have h₇ : (n - 1) / 2 * 2 = n - 1 := by
            have h₈ : n % 2 = 1 := h₂
            have h₉ : (n - 1) % 2 = 0 := by
              omega
            have h₁₀ : (n - 1) / 2 * 2 = n - 1 := by
              have h₁₁ := Nat.div_add_mod (n - 1) 2
              omega
            exact h₁₀
          omega
        exact h₅
      simp [h₃, mul_assoc]
      <;> ring_nf at *
      <;> omega
  exact h₁
