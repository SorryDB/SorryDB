theorem independent_gamblers_ruin :
    ∀ (P : Finset (Fin 2)), (∀ (x : Fin 2), P.count x ≤ 1) → (∀ (x : Fin 2), x ∈ P → P.count x = 1) → P.card ≤ 2 := by
  intro P h₁ h₂
  have h₃ : P.card ≤ 2 := by
    have h₄ : P ⊆ {0, 1} := by
      intro x hx
      simp only [Finset.mem_insert, Finset.mem_singleton] at hx ⊢
      have : x = 0 ∨ x = 1 := by
        have h₅ : x = 0 ∨ x = 1 := by
          fin_cases x <;> simp_all (config := {decide := true})
        tauto
      aesop
    have h₅ : P.card ≤ ({0, 1} : Finset (Fin 2)).card := Finset.card_le_of_subset h₄
    have h₆ : ({0, 1} : Finset (Fin 2)).card = 2 := by decide
    linarith
  exact h₃
```
