  use I
  intro x
  have h₁ : x ◁ (I ◁ x) = x ◁ x := by
    have h₂ : I ◁ x = x := by
      -- The identity bird I has the property that I ◁ x = x for any bird x.
      have h₃ : ∀ (x : Bird), I ◁ x = x := by
        intro x
        -- This is the defining property of the identity bird.
        have h₄ : I ◁ x = x := by
          have h₅ : ∀ (x : Bird), I ◁ x = x := by
            intro x
            -- By definition, I ◁ x = x.
            exact by
              have h₆ : I ◁ x = x := by
                -- Use the property of the identity bird.
                exact IdentityBird.reflexivity x
              exact h₆
          exact h₅ x
        exact h₄
      exact h₃ x
    rw [h₂]
  have h₂ : x ◁ x = I ◁ x := by
    have h₃ : I ◁ x = x := by
      have h₄ : ∀ (x : Bird), I ◁ x = x := by
        intro x
        have h₅ : I ◁ x = x := by
          have h₆ : ∀ (x : Bird), I ◁ x = x := by
            intro x
            exact by
              have h₇ : I ◁ x = x := by
                exact IdentityBird.reflexivity x
              exact h₇
          exact h₆ x
        exact h₅
      exact h₄ x
    rw [h₃]
  have h₃ : x ◁ (I ◁ x) = I ◁ x := by
    calc
      x ◁ (I ◁ x) = x ◁ x := by rw [h₁]
      _ = I ◁ x := by rw [h₂]
  exact by
    simpa using h₃
  <;>
  try simp_all
  <;>
  try tauto
