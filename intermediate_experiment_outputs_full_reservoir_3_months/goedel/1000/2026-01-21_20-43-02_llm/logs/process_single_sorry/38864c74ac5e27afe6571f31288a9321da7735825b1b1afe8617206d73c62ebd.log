theorem blueprint_lemma_3_3_8 (s : ℕ) (h₁ : s > 0) :
    (∀ (x y : ℕ), x + y = s → x ≤ 2 ∨ y ≤ 2) → False := by
  intro h
  have h₂ : s ≥ 3 := by
    by_contra h₂
    -- If s < 3, then s ≤ 2 because s is a natural number.
    have h₃ : s ≤ 2 := by
      omega
    -- We will check all possible values of s from 1 to 2.
    interval_cases s <;> norm_num at h₁ ⊢ <;>
      (try omega) <;>
      (try {
        -- For s = 1:
        have h₄ := h 0 1
        have h₅ := h 1 0
        norm_num at h₄ h₅
        <;> simp_all (config := {decide := true})
      }) <;>
      (try {
        -- For s = 2:
        have h₄ := h 0 2
        have h₅ := h 1 1
        have h₆ := h 2 0
        norm_num at h₄ h₅ h₆
        <;> simp_all (config := {decide := true})
      })
  
  have h₃ : False := by
    have h₄ := h 3 (s - 3)
    have h₅ : 3 + (s - 3) = s := by
      have h₅₁ : s ≥ 3 := h₂
      have h₅₂ : 3 ≤ s := by linarith
      omega
    have h₆ := h₄ h₅
    cases h₆ with
    | inl h₆ =>
      -- Case: 3 ≤ 2
      omega
