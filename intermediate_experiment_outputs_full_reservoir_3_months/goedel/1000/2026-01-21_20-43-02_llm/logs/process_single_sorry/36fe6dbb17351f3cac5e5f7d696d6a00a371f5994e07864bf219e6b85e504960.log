  have h₂ : (∑' i : α, (f i * g i : ℝ)) ≤ (∑' i : α, (f i : ℝ) ^ p) ^ (1 / p : ℝ) * (∑' i : α, (g i : ℝ) ^ q) ^ (1 / q : ℝ) := by
