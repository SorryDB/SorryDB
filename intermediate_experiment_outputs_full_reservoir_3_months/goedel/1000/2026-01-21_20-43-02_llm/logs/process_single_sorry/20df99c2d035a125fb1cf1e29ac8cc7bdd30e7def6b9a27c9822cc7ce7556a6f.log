                     -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                      have h₂₀ : ({x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} ∩ Set.Icc (0 : ℝ) 1).ToMeasurable = ∅ := by\n                        -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                        classical\n                        have h₂₁ : ({x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} ∩ Set.Icc (0 : ℝ) 1).ToMeasurable = ∅ := by\n                          -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                          have h₂₂ : ({x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} ∩ Set.Icc (0 : ℝ) 1).ToMeasurable = ∅ := by\n                            -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                            apply MeasurableSet.toMeasurable_eq_empty.mpr\n                            -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                            have h₂₃ : ¬ MeasurableSet ({x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} ∩ Set.Icc (0 : ℝ) 1) := by\n                              -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n                              intro h₂₄\n                              -- Use",
      "\n  have h : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n    -- The set of irrational numbers is dense in ℝ and has full measure.\n    have h₁ : Irrational ∼[volume.restrict (Set.univ : Set ℝ)] Set.univ := by\n      -- The set of irrational numbers is a full measure set in ℝ.\n      simp [Irrational, Set.univ, Density]\n      <;>\n      (try norm_num) <;>\n      (try\n        {\n          -- Use the fact that the set of rational numbers has measure zero in ℝ.\n          have h₂ : volume.restrict (Set.univ : Set ℝ) {x : ℝ | ¬Irrational x} = 0 := by\n            have h₃ : {x : ℝ | ¬Irrational x} = Set.range (coe : ℚ → ℝ) := by\n              ext x\n              simp [Irrational]\n              <;>\n              (try constructor <;> intro h <;> (try cases' h with q hq) <;> (try { use q; simp_all }) <;> (try { exact ⟨x, by simp_all⟩ }))\n            rw [h₃]\n            -- The image of a countable set under a measurable function has measure zero.\n            have h₄ : volume.restrict (Set.univ : Set ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by\n              -- Use the fact that the set of rationals is countable.\n              have h₅ : (volume.restrict (Set.univ : Set ℝ)).measure (Set.range (coe : ℚ → ℝ)) = 0 := by\n                -- The set of rationals is countable.\n                have h₆ : Set.Countable (Set.range (coe : ℚ → ℝ)) := by\n                  apply Set.countable_range\n                -- A countable set has measure zero.\n                have h₇ : (volume.restrict (Set.univ : Set ℝ)).measure (Set.range (coe : ℚ → ℝ)) = 0 := by\n                  have h₈ : (volume.restrict (Set.univ : Set ℝ)).measure (Set.range (coe : ℚ → ℝ)) = volume (Set.range (coe : ℚ → ℝ)) := by\n                    simp [MeasureTheory.Measure.restrict_apply]\n                    <;>\n                    (try simp_all [Set.univ])\n                    <;>\n                    (try norm_num)\n                    <;>\n                    (try aesop)\n                  rw [h₈]\n                  -- The volume of a countable set is zero.\n                  have h₉ : volume (Set.range (coe : ℚ → ℝ)) = 0 := by\n                    have h₁₀ : volume (Set.range (coe : ℚ → ℝ)) = 0 := by\n                      apply MeasureTheory.volume_countable\n                      <;>\n                      (try simp_all [Set.range])\n                      <;>\n                      (try aesop)\n                    exact h₁₀\n                  rw [h₉]\n                  <;>\n                  (try simp_all)\n                  <;>\n                  (try aesop)\n                exact h₇\n              -- The measure of the set of rationals is zero.\n              have h₁₁ : volume.restrict (Set.univ : Set ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by\n                rw [MeasureTheory.Measure.restrict_apply]\n                <;>\n                (try simp_all [Set.univ])\n                <;>\n                (try norm_num)\n                <;>\n                (try aesop)\n                <;>\n                (try simp_all [h₅])\n                <;>\n                (try norm_num)\n                <;>\n                (try aesop)\n              exact h₁₁\n            exact h₄\n          -- The complement of the irrationals has measure zero.\n          have h₅ : volume.restrict (Set.univ : Set ℝ) {x : ℝ | ¬Irrational x} = 0 := by\n            exact h₂\n          -- The set of irrationals has full measure.\n          simp_all [Set.univ]\n          <;>\n          (try aesop)\n          <;>\n          (try norm_num)\n          <;>\n          (try simp_all [h₅])\n          <;>\n          (try aesop)\n        })\n      <;>\n      (try aesop)\n      <;>\n      (try norm_num)\n      <;>\n      (try simp_all [h₂])\n      <;>\n      (try aesop)\n    -- Use the fact that the set of irrationals has full measure.\n    have h₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n      have h₃ : Irrational ∼[volume.restrict (Set.univ : Set ℝ)]