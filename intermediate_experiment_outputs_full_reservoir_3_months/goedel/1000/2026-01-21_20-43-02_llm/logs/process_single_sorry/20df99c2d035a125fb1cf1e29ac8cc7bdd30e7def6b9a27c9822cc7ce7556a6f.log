      "\n  have h : ∀ᵐ (x : ℝ), Irrational x := by\n    -- Use the fact that the rationals are countable and the reals are uncountable.\n    have h₁ : ∀ᵐ (x : ℝ), Irrational x := by\n      -- The set of rational numbers has measure zero in the reals.\n      have h₂ : (Set.univ : Set ℝ) \\ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = {x : ℝ | Irrational x} := by\n        ext x\n        simp [Irrational, Set.mem_diff, Set.mem_setOf_eq]\n        <;>\n        (try norm_num) <;>\n        (try aesop) <;>\n        (try\n          {\n            by_cases h : ∃ (a : ℚ), (a : ℝ) = x <;>\n            simp_all [h] <;>\n            (try { aesop }) <;>\n            (try {\n              push_neg at *\n              <;>\n              aesop\n            })\n          })\n      -- The set of irrational numbers is the complement of the rationals, which has measure zero.\n      have h₃ : (Set.univ : Set ℝ) \\ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = {x : ℝ | Irrational x} := h₂\n      -- The set of rationals is countable and hence has measure zero.\n      have h₄ : MeasurableSet {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := by\n        -- The set of rationals is measurable.\n        have h₅ : {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = ⋃ (a : ℚ), {a : ℝ} := by\n          ext x\n          simp [Set.mem_iUnion]\n          <;>\n          (try norm_num) <;>\n          (try aesop) <;>\n          (try\n            {\n              by_cases h : ∃ (a : ℚ), (a : ℝ) = x <;>\n              simp_all [h] <;>\n              (try { aesop }) <;>\n              (try {\n                push_neg at *\n                <;>\n                aesop\n              })\n            })\n        rw [h₅]\n        -- The union of countably many measurable sets is measurable.\n        apply MeasurableSet.iUnion\n        intro a\n        exact measurableSet_singleton\n      -- The complement of a measurable set is measurable.\n      have h₤ : MeasurableSet {x : ℝ | Irrational x} := by\n        have h₆ : MeasurableSet {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := h₄\n        have h₇ : MeasurableSet (Set.univ : Set ℝ) := measurableSet_univ\n        have h₈ : MeasurableSet ({x : ℝ | Irrational x} : Set ℝ) := by\n          have h₉ : {x : ℝ | Irrational x} = (Set.univ : Set ℝ) \\ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := by\n            ext x\n            simp [Irrational, Set.mem_diff, Set.mem_setOf_eq]\n            <;>\n            (try norm_num) <;>\n            (try aesop) <;>\n            (try\n              {\n                by_cases h : ∃ (a : ℚ), (a : ℝ) = x <;>\n                simp_all [h] <;>\n                (try { aesop }) <;>\n                (try {\n                  push_neg at *\n                  <;>\n                  aesop\n                })\n              })\n          rw [h₉]\n          exact h₇.diff h₆\n        exact h₈\n      -- The set of rationals has measure zero.\n      have h₁₀ : measureTheory.volume {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = 0 := by\n        -- The set of rationals is countable.\n        have h₁₁ : {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = ⋃ (a : ℚ), {a : ℝ} := by\n          ext x\n          simp [Set.mem_iUnion]\n          <;>\n          (try norm_num) <;>\n          (try aesop) <;>\n          (try\n            {\n              by_cases h : ∃ (a : ℚ), (a : ℝ) = x <;>\n              simp_all [h] <;>\n              (try { aesop }) <;>\n              (try {\n                push_neg at *\n                <;>\n                aesop\n              })\n            })\n        rw [h₁₁]\n        -- The measure of a countable union of singletons is zero.\n        have h₁₂ : (measureTheory.volume : Measure ℝ) (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) = 0 := by\n          -- Each singleton has measure zero.\n          have h₁₃ : ∀ (a : ℚ), (measureTheory.volume : Measure ℝ) ({a : ℝ} : Set ℝ) = 0 := by\n            intro a\n            simp [Real.volume_singleton]\n          -- The countable union of sets of measure zero has measure zero.\n          have h₁₄ : (measureTheory.volume : Measure ℝ) (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) = 0 := by\n            -- Use the fact that the union is countable.\n            have h₁₅ : (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) = ⋃ (a : ℚ), ({a : ℝ} : Set ℝ) := rfl\n            rw [h₁₅]\n            -- Use the fact that the union is countable.\n            have h₁₆ : (measureTheory.volume : Measure ℝ) (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) ≤ ∑' (a : ℚ), (measureTheory.volume : Measure ℝ) ({a : ℝ} : Set ℝ) := by\n              apply MeasureTheory.measure_le_sum_of_subset\n              <;>\n              (try norm_num) <;>\n              (try\n                {\n                  intro i j\n                  simp [Set.subset_def]\n                  <;>\n                  (try { aesop })\n                })\n              <;>\n              (try\n                {\n                  intro x hx\n                  simp_all [Set.mem_iUnion]\n                  <;>\n                  (try { aesop })\n                })\n            have h₁₇ : ∑' (a : ℚ), (measureTheory.volume : Measure ℝ) ({a : ℝ} : Set ℝ) = 0 := by\n              have h₁₈ : ∀ (a : ℚ), (measureTheory.volume : Measure ℝ) ({a : ℝ} : Set ℝ) = 0 := h₁₃\n              calc\n                ∑' (a : ℚ), (measureTheory.volume : Measure ℝ) ({a : ℝ} : Set ℝ) = ∑' (a : ℚ), 0 := by\n                  congr with a\n                  rw [h₁₈ a]\n                _ = 0 := by simp\n            have h₁₉ : (measureTheory.volume : Measure ℝ) (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) ≤ 0 := by\n              linarith\n            have h₂₀ : 0 ≤ (measureTheory.volume : Measure ℝ) (⋃ (a : ℚ), ({a : ℝ} : Set ℝ)) := by\n              apply MeasureTheory.measure_nonneg\n            linarith\n          exact h₁₄\n        exact h₁₂\n      -- The set of irrationals has full measure.\n      have h₂₁ : ∀ᵐ (x : ℝ), Irrational x := by\n        -- Use the fact that the rationals have measure zero.\n        have h₂₂ : ∀ᵐ (x : ℝ), x ∉ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := by\n          -- The set of rationals has measure zero.\n          have h₂₃ : measureTheory.volume {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} = 0 := h₁₀\n          have h₂₄ : ∀ᵐ (x : ℝ), x ∉ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := by\n            -- Use the fact that the measure is zero.\n            filter_upwards [ae_restrict_compl_null (by\n              -- The set of rationals is measurable.\n              have h₂₅ : MeasurableSet {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := h₄\n              exact h₂₅)] with x hx\n            <;>\n            simp_all [Set.mem_compl_iff]\n            <;>\n            (try { aesop })\n          exact h₂₄\n        -- Convert the statement to irrationals.\n        filter_upwards [h₂₂] with x hx\n        -- If x is not rational, it is irrational.\n        simp only [Irrational, Set.mem_setOf_eq] at hx ⊢\n        <;>\n        (try {\n          aesop\n        }) <;>\n        (try {\n          by_contra h\n          -- If x is not irrational, then it is rational.\n          push_neg at h\n          obtain ⟨a, ha⟩ := h\n          have h₂₅ : x ∈ {x : ℝ | ∃ a : ℚ, (a : ℝ) = x} := by\n            refine' ⟨a, _⟩\n            <;>\n            norm_cast at ha ⊢ <;>\n            linarith\n          contradiction\n        })\n      exact h₂₁\n    exact h₁\n  exact h",
      "\n  have h : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n    -- Use the fact that the set of rational numbers is countable and hence has measure zero in ℝ\n    have h₁ : (Set.univ : Set ℝ) = (Set.univ : Set ℝ) := rfl\n    have h₂ : (Set.countable (Set.range ((↑) : ℚ → ℝ))) := by\n      apply Set.countable_range\n    -- Use the fact that the set of irrational numbers is the complement of the set of rational numbers\n    have h₃ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n      -- Use the fact that the set of rational numbers has measure zero\n      have h₄ : (volume.restrict (Set.univ : Set ℝ)).ae = (volume : Measure ℝ).ae := by\n        simp [Measure.restrict_ae]\n      have h₅ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n        -- Use the fact that the set of rational numbers has measure zero\n        have h₆ : (volume : Measure ℝ) (Set.range ((↑) : ℚ → ℝ)) = 0 := by\n          -- The set of rational numbers is countable and hence has measure zero\n          have h₇ : Set.Countable (Set.range ((↑) : ℚ → ℝ)) := by\n            apply Set.countable_range\n          have h₈ : (volume : Measure ℝ) (Set.range ((↑) : ℚ → ℝ)) = 0 := by\n            apply Measure.ofReal_eq_zero.mpr\n            apply Measure.measure_eq_zero_of_countable_of_ae_stronglyMeasurable\n            · exact h₇\n            · exact measurableSet_range_cast\n          exact h₈\n        -- Use the fact that the set of rational numbers has measure zero to conclude that almost every real number is irrational\n        have h₉ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range ((↑) : ℚ → ℝ) := by\n          have h₁₀ : (volume : Measure ℝ) (Set.range ((↑) : ℚ → ℝ)) = 0 := h₆\n          have h₁₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range ((↑) : ℚ → ℝ) := by\n            filter_upwards [ae_restrict_mem (volume : Measure ℝ)] with x hx using by\n              intro h₁₂\n              have h₁₃ : x ∈ Set.range ((↑) : ℚ → ℝ) := h₁₂\n              have h₁₄ : (volume : Measure ℝ) (Set.range ((↑) : ℚ → ℝ)) > 0 := by\n                have h₁₅ : x ∈ Set.range ((↑) : ℚ → ℝ) := h₁₃\n                have h₁₆ : (volume : Measure ℝ) {x} > 0 := by\n                  have h₁₇ : (volume : Measure ℝ) {x} = (0 : ℝ) := by\n                    simp [volume_singleton]\n                  linarith\n                have h₁₈ : {x} ⊆ Set.range ((↑) : ℚ → ℝ) := by\n                  intro y hy\n                  rw [Set.mem_singleton_iff] at hy\n                  rw [hy]\n                  exact h₁₃\n                have h₁₉ : (volume : Measure ℝ) {x} ≤ (volume : Measure ℝ) (Set.range ((↑) : ℚ → ℝ)) :=\n                  Measure.measure_mono h₁₈\n                linarith\n              linarith\n          exact h₁₁\n        filter_upwards [h₉] with x hx\n        -- Prove that x is irrational if it is not in the range of the embedding of ℚ into ℝ\n        have h₁₀ : x ∉ Set.range ((↑) : ℚ → ℝ) := hx\n        have h₁₁ : Irrational x := by\n          intro h₁₂\n          rcases h₁₂ with ⟨q, hq⟩\n          have h₁₃ : x = (q : ℝ) := by\n            simp_all [Rat.cast_inj]\n          have h₁₄ : x ∈ Set.range ((↑) : ℚ → ℝ) := by\n            use q\n            <;> simp_all [Rat.cast_inj]\n          contradiction\n        exact h₁₁\n      -- Use the fact that the set of rational numbers has measure zero in ℝ to conclude that almost every real number is irrational\n      have h₁₀ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n        filter_upwards [h₅] with x hx\n        simp_all [Measure.restrict_ae]\n      exact h₁₀\n    exact h₃\n  -- Use the fact that the set of rational numbers is countable and hence has measure zero in ℝ to conclude that almost every real number is irrational\n  have h₁ : ∀ᵐ (x : ℝ), Irrational x := by\n    have h₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h\n    have h₃ : (∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x) → (∀ᵐ (x : ℝ), Irrational x) := by\n      intro h₄\n      have h₅ : ∀ᵐ 