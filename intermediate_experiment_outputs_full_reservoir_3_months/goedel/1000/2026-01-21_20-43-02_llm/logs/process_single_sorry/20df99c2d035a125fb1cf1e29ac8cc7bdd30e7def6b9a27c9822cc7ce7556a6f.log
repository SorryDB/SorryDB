  field_simp [Rat.cast_def]\n              <;>\n              norm_cast\n              <;>\n              simp_all [Rat.num_div_den]\n              <;>\n              field_simp at *\n              <;>\n              ring_nf at *\n              <;>\n              norm_cast at *\n              <;>\n              simp_all [Rat.num_div_den]\n              <;>\n              linarith\n            have h₁₄ : x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ)) := by\n              -- Since x = q, and q is in the range of the function n ↦ (n : ℝ), x is also in the range\n              have h₁₅ : (q : ℝ) = x := by simp_all\n              have h₁₆ : (q : ℝ) ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ)) := h₁₃\n              have h₁₇ : x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ)) := by\n                -- Since (q : ℝ) = x and (q : ℝ) is in the range, x is also in the range\n                rw [h₁₅] at *\n                exact h₁₆\n              exact h₁₇\n            simp_all [Set.mem_range]\n            <;>\n            aesop\n          -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n          have h₉ : (volume.restrict (Set.Icc (0 : ℝ) 1)) (Set.Icc (0 : ℝ) 1 ∩ {x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))}) = 0 := by\n            -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n            have h₁₀ : (volume.restrict (Set.Icc (0 : ℝ) 1)) (Set.Icc (0 : ℝ) 1 ∩ {x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))}) = 0 := by\n              -- Use the fact that the set of rationals in [0,1] is countable and hence has measure zero\n              have h₁₁ : Set.Icc (0 : ℝ) 1 ∩ {x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} ⊆ {x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))} := by\n                intro x hx\n                exact hx.2\n              have h₁₂ : (volume.restrict (Set.Icc (0 : ℝ) 1)) (Set.Icc (0 : ℝ) 1 ∩ {x : ℝ | x ∈ Set.range (fun (n : ℤ) ↦ (n : ℝ))}) ≤ (volume.restrict (Set.Icc (0 : ℝ) 1)) {x : ℝ | x ∈ Set.range (