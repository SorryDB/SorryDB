      "\n  have h : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n    have h₁ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n      -- Use the fact that the set of rational numbers is countable and has measure zero.\n      have h₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n        -- The set of rational numbers is countable, hence it has measure zero.\n        have h₃ : (Set.univ : Set ℝ) = Set.univ := rfl\n        -- Use the fact that the set of irrational numbers is dense in the reals.\n        have h₄ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := by\n          -- The set of rational numbers has measure zero in the reals.\n          have h₅ : MeasurableSet (Set.univ : Set ℝ) := measurableSet_univ\n          -- Use the fact that the set of irrational numbers has full measure.\n          have h₆ : (volume.restrict (Set.univ : Set ℝ)) = volume := by\n            simp [h₃]\n          rw [h₆]\n          -- Use the fact that the set of irrational numbers has full measure.\n          have h₇ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n            -- The set of rational numbers is countable and has measure zero.\n            have h₈ : Set.Countable {x : ℝ | Irrational x = false} := by\n              -- The set of rational numbers is countable.\n              have h₉ : {x : ℝ | Irrational x = false} = {x : ℝ | ¬Irrational x} := by\n                simp [Irrational]\n                <;>\n                aesop\n              rw [h₉]\n              -- The set of rational numbers is countable.\n              have h₁₀ : {x : ℝ | ¬Irrational x} = {x : ℝ | ∃ (a : ℚ), (a : ℝ) = x} := by\n                apply Set.ext\n                intro x\n                simp [Irrational]\n                <;>\n                constructor <;>\n                intro h <;>\n                (try { aesop }) <;>\n                (try {\n                  rcases h with ⟨a, ha⟩\n                  use a\n                  <;> simp_all [ha]\n                  <;> aesop\n                }) <;>\n                (try {\n                  aesop\n                })\n              rw [h₁₀]\n              -- The set of rational numbers is countable.\n              have h₁₁ : Set.Countable {x : ℝ | ∃ (a : ℚ), (a : ℝ) = x} := by\n                -- The set of rational numbers is countable.\n                have h₁₂ : Set.Countable {x : ℝ | ∃ (a : ℚ), (a : ℝ) = x} := by\n                  -- The set of rational numbers is countable.\n                  apply Set.Countable.mono (fun x hx => by\n                    rcases hx with ⟨a, ha⟩\n                    -- The set of rational numbers is countable.\n                    simp_all [ha]\n                    <;>\n                    aesop) (Set.countable_range (fun (a : ℚ) => (a : ℝ)))\n                -- The set of rational numbers is countable.\n                exact h₁₂\n              -- The set of rational numbers is countable.\n              exact h₁₁\n            -- The set of rational numbers is countable.\n            have h₉ : {x : ℝ | Irrational x = false} ∈ (volume : Measure ℝ).null_sets := by\n              -- The set of rational numbers is countable.\n              have h₁₀ : Set.Countable {x : ℝ | Irrational x = false} := h₈\n              -- The set of rational numbers has measure zero.\n              have h₁₁ : (volume : Measure ℝ).measure {x : ℝ | Irrational x = false} = 0 := by\n                -- The set of rational numbers has measure zero.\n                apply Volume.measure_countable\n                <;> simp_all [h₁₀]\n                <;>\n                aesop\n              -- The set of rational numbers has measure zero.\n              simp_all [MeasureTheory.NullSets]\n              <;>\n              aesop\n            -- The set of rational numbers is countable.\n            have h₁₀ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n              -- The set of rational numbers is countable.\n              have h₁₁ : {x : ℝ | Irrational x = false} ∈ (volume : Measure ℝ).null_sets := h₉\n              -- The set of rational numbers has measure zero.\n              have h₁₂ : ∀ᵐ (x : ℝ) ∂volume, x ∉ {x : ℝ | Irrational x = false} := by\n                -- The set of rational numbers has measure zero.\n                filter_upwards [h₁₁] with x hx using hx\n              -- The set of rational numbers has measure zero.\n              have h₁₃ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n                filter_upwards [h₁₂] with x hx\n                -- The set of rational numbers has measure zero.\n                simp_all [Irrational]\n                <;>\n                aesop\n              -- The set of rational numbers has measure zero.\n              exact h₁₃\n            -- The set of rational numbers is countable.\n            exact h₁₀\n          -- The set of rational numbers has measure zero.\n          exact h₇\n        -- The set of rational numbers has measure zero.\n        exact h₄\n      -- The set of rational numbers has measure zero.\n      exact h₂\n    -- The set of rational numbers has measure zero.\n    exact h₁\n  -- The set of rational numbers has measure zero.\n  have h₂ : ∀ᵐ (x : ℝ), Irrational x := by\n    -- The set of rational numbers has measure zero.\n    have h₃ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h\n    -- The set of rational numbers has measure zero.\n    have h₄ : (volume.restrict (Set.univ : Set ℝ) : Measure ℝ) = volume := by\n      simp [h]\n    -- The set of rational numbers has measure zero.\n    have h₅ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n      -- The set of rational numbers has measure zero.\n      have h₆ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h₃\n      -- The set of rational numbers has measure zero.\n      have h₇ : (volume.restrict (Set.univ : Set ℝ) : Measure ℝ) = volume := h₄\n      -- The set of rational numbers has measure zero.\n      have h₈ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n        -- The set of rational numbers has measure zero.\n        have h₉ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h₆\n        -- The set of rational numbers has measure zero.\n        have h₁₀ : (volume.restrict (Set.univ : Set ℝ) : Measure ℝ) = volume := h₇\n        -- The set of rational numbers has measure zero.\n        have h₁₁ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n          -- The set of rational numbers has measure zero.\n          have h₁₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h₉\n          -- The set of rational numbers has measure zero.\n          filter_upwards [h₁₂] with x hx using hx\n        -- The set of rational numbers has measure zero.\n        exact h₁₁\n      -- The set of rational numbers has measure zero.\n      exact h₈\n    -- The set of rational numbers has measure zero.\n    exact h₅\n  -- The set of rational numbers has measure zero.\n  exact h₂",
      "\n   - This is straightforward because it's the range of a function from `ℚ`, which is countable.\n   - Actually, Lean knows that `Set.range (fun q : ℚ => (q : ℝ))` is",
      "\n  have h : ∀ᵐ (x : ℝ), Irrational x := by\n    have h₁ : ∀ᵐ (x : ℝ), ({x} : Set ℝ).Nonempty := by\n      -- Prove that for almost every real number x, the singleton set {x} is nonempty.\n      filter_upwards [self_mem_ae_restrict (measurableSet_univ : MeasurableSet (Set.univ : Set ℝ))] with x hx using by\n        exact ⟨x⟩\n    -- Use the fact that the set of irrational numbers is dense in the reals.\n    have h₂ : ∀ᵐ (x : ℝ), Irrational x := by\n      filter_upwards [h₁] with x hx\n      by_contra h₃\n      -- If x is rational, then the singleton set {x} is not a subset of the irrational numbers.\n      have h₄ : ¬Irrational x := h₃\n      have h₅ : ∃ (q : ℚ), (q : ℝ) = x := by\n        rw [irrational_iff_ne_rat] at h₄\n        push_neg at h₄\n        obtain ⟨q, hq⟩ := h₄\n        exact ⟨q, by simp_all [Rat.cast_inj]⟩\n      -- Use the density of the irrational numbers to find a contradiction.\n      obtain ⟨q, hq⟩ := h₅\n      have h₆ : (q : ℝ) = x := hq\n      have h₇ : ¬Irrational (q : ℝ) := by\n        intro h₈\n        exact h₈ ⟨q, by simp⟩\n      simp_all [Irrational]\n    exact h₂\n  exact h",
      "\n  have h_countable : Set.Countable (Set.range (fun q : ℚ => (q : ℝ))) := by\n    have h : Set.Countable (Set.range (fun q : ℚ => (q : ℝ))) := by\n      apply Set.countable_range\n    exact h\n  \n  have h_null : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := by\n    have h₁ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := by\n      apply Measure.measure_eq_zero_of_countable\n      <;> assumption\n    exact h₁\n  \n  have h_main : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by\n    have h₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by\n      have h₂ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := h_null\n      have h₃ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by\n        -- Use the fact that the measure of the set of rationals is zero to conclude that almost every real number is not in the set of rationals.\n        have h₄ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := h₂\n        have h₅ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) :=\n          (ae_restrict_compl (by\n            -- Show that the set of rationals is measurable.\n            have h₆ : MeasurableSet (Set.range (fun q : ℚ => (q : ℝ))) :=\n              MeasurableSet.countable (by\n                -- Use the fact that the set of rationals is countable to show it is measurable.\n                simpa using h_countable)\n            exact h₆))\n        exact h₅\n      exact h₃\n    exact h₁\n  \n  have h_final : ∀ᵐ (x : ℝ), Irrational x := by\n    have h₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := h_main\n    have h₂ : ∀ᵐ (x : ℝ), Irrational x := by\n      filter_upwards [h₁] with x hx\n      -- If x is not in the range of the function that maps rationals to reals, then it is irrational.\n      have h₃ : x ∉ Set.range (fun q : ℚ => (q : ℝ)) := hx\n      have h₄ : Irrational x := by\n        -- Use the definition of irrational numbers to conclude the proof.\n        have h₅ : ¬∃ q : ℚ, (q : ℝ) = x := by\n          intro h\n          obtain ⟨q, hq⟩ := h\n          have h₆ : x ∈ Set.range (fun q : ℚ => (q : ℝ)) := by\n            use q\n            <;> simp_all [hq]\n          contradiction\n        simpa [Irrational] using h₅\n      exact h₄\n    exact h₂\n  \n  exact h_final",
      "\n  have h : ¬∃ (q : ℚ), (q : ℝ) = Real.sqrt 2 := by\n    intro h\n    rcases h with ⟨q, hq⟩\n    have h₁ : Irrational (Real.sqrt 2) := by\n      apply Nat.Prime.irrational_sqrt\n      <;> norm_num\n    exact h₁ ⟨q, by simp_all [Rat.cast_inj]⟩\n\n  have h₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), Irrational x := by\n    -- Use the fact that the set of rationals is countable and hence has measure zero in [0,1]\n    have h₃ : (Set.range (fun (q : ℚ) => (q : ℝ))).toSet.Countable := by\n      apply Set.countable_range\n    have h₄ : volume (Set.Icc (0 : ℝ) 1 : Set ℝ) = 1 := by\n      -- Volume of the interval [0,1] is 1\n      simp [volume_Icc]\n    have h₅ : volume (Set.Icc (0 : ℝ) 1 : Set ℝ) ≠ 0 := by\n      rw [h₄]\n      norm_num\n    -- The set of rationals in [0,1] is countable and hence has measure zero\n    have h₆ : volume.restrict (Set.Icc (0 : ℝ) 1) {x : ℝ | ¬Irrational x} = 0 := by\n      have h₇ : {x : ℝ | ¬Irrational x} = {x : ℝ | ∃ (q : ℚ), (q : ℝ) = x} := by\n        ext x\n        simp [Irrational]\n        <;>\n        (try { aesop }) <;>\n        (try {\n          constructor <;> intro h <;>\n          (try { aesop }) <;>\n          (try {\n            rcases h with ⟨q, hq⟩\n            exact ⟨q, by simp_all [Rat.cast_inj]⟩\n          }) <;>\n          (try {\n            rcases h with ⟨q, hq⟩\n            exact ⟨q, by simp_all [Rat.cast_inj]⟩\n          })\n        })\n      rw [h₇]\n      have h₈ : volume.restrict (Set.Icc (0 : ℝ) 1) {x : ℝ | ∃ (q : ℚ), (q : ℝ) = x} = 0 := by\n        -- The set of rationals is countable and hence has measure zero\n        have h₉ : {x : ℝ | ∃ (q : ℚ), (q : ℝ) = x} = ⋃ (q : ℚ), { (q : ℝ) } := by\n          ext x\n          simp [Set.mem_iUnion, exists_prop]\n          <;>\n          (try { aesop }) <;>\n          (try {\n            constructor <;> intro h <;>\n            (try { aesop }) <;>\n            (try {\n              rcases h with ⟨q, hq⟩\n              exact ⟨q, by simp_all [Rat.cast_inj]⟩\n            }) <;>\n            (try {\n              rcases h with ⟨q, hq⟩\n              exact ⟨q, by simp_all [Rat.cast_inj]⟩\n            })\n          })\n        rw [h₉]\n        -- The measure of a countable union of points is zero\n        have h₁₀ : volume.restrict (Set.Icc (0 : ℝ) 1) (⋃ (q : ℚ), { (q : ℝ) }) = 0 := by\n          have h₁₁ : volume.restrict (Set.Icc (0 : ℝ) 1) (⋃ (q : ℚ), { (q : ℝ) }) ≤ ∑' (q : ℚ), volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) := by\n            -- Use the countable subadditivity of the measure\n            apply MeasureTheory.measure_biUnion_le\n            <;>\n            (try {\n              intro q\n              exact by\n                simp [measurableSet_singleton]\n            })\n          have h₁₂ : ∑' (q : ℚ), volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) = 0 := by\n            -- The measure of each singleton is zero\n            have h₁₃ : ∀ (q : ℚ), volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) = 0 := by\n              intro q\n              -- The measure of a singleton is zero\n              have h₁₄ : volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) = 0 := by\n                -- Use the fact that the measure of a singleton is zero\n                have h₁₅ : ( ({ (q : ℝ) } : Set ℝ) : Set ℝ).volume = 0 := by\n                  simp [volume_singleton]\n                -- Use the fact that the measure is restricted to [0,1]\n                have h₁₆ : volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) = 0 := by\n                  by_cases h₁₇ : (q : ℝ) ∈ Set.Icc (0 : ℝ) 1\n                  · -- If q is in [0,1], then the measure is zero\n                    simp_all [MeasureTheory.Measure.restrict_apply, MeasureTheory.MeasureTheory.measure_singleton]\n                    <;> simp_all [volume_singleton]\n                  · -- If q is not in [0,1], then the measure is zero\n                    simp_all [MeasureTheory.Measure.restrict_apply, MeasureTheory.MeasureTheory.measure_singleton]\n                    <;> simp_all [volume_singleton]\n                    <;> aesop\n                exact h₁₆\n              exact h₁₄\n            -- Sum over all rationals\n            calc\n              ∑' (q : ℚ), volume.restrict (Set.Icc (0 : ℝ) 1) ({ (q : ℝ) } : Set ℝ) = ∑' (q : ℚ), 0 := by\n                congr with q\n                rw [h₁₃ q]\n              _ = 0 := by simp\n          -- The measure of the union is zero\n          have h₁₇ : volume.restrict (Set.Icc (0 : ℝ) 1) (⋃ (q : ℚ), { (q : ℝ) }) ≤ 0 := by\n            linarith\n          -- The measure is non-negative\n          have h₁₈ : 0 ≤ volume.restrict (Set.Icc (0 : ℝ) 1) (⋃ (q : ℚ), { (q : ℝ) }) := by\n            apply MeasureTheory.measure_nonneg\n          -- The measure is zero\n          linarith\n        -- The measure of the union is zero\n        exact h₁₀\n      -- The measure of the set of rationals is zero\n      exact h₈\n    -- The set of irrationals has full measure in [0,1]\n    have h₇ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), Irrational x := by\n      -- The set of irrationals is the complement of the set of rationals\n      have h₈ : volume.restrict (Set.Icc (0 : ℝ) 1) {x : ℝ | ¬Irrational x} = 0 := h₆\n      -- The set of irrationals has full measure\n      have h₉ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), Irrational x := by\n        -- Use the fact that the set of rationals has measure zero\n        have h₁₀ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), x ∈ {x : ℝ | Irrational x} := by\n          -- The complement of the set of rationals has full measure\n          have h₁₁ : volume.restrict (Set.Icc (0 : ℝ) 1) ({x : ℝ | ¬Irrational x} : Set ℝ) = 0 := h₆\n          -- The set of irrationals has full measure\n          have h₁₂ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), x ∉ {x : ℝ | ¬Irrational x} := by\n            -- Use the fact that the set of rationals has measure zero\n            filter_upwards [ae_restrict_compl_null (volume.restrict (Set.Icc (0 : ℝ) 1)) (by simp [h₁₁])] with x hx\n            simp_all\n          -- The set of irrationals has full measure\n          filter_upwards [h₁₂] with x hx\n          simp_all [Set.mem_setOf_eq]\n          <;>\n          (try { aesop })\n        -- The set of irrationals has full measure\n        filter_upwards [h₁₀] with x hx\n        simp_all [Set.mem_setOf_eq]\n        <;>\n        (try { aesop })\n      -- The set of irrationals has full measure\n      exact h₉\n    -- The set of irrationals has full measure in [0,1]\n    exact h₇\n\n  have h₃ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n    -- Use the fact that the set of rationals is countable and hence has measure zero\n    have h₄ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), Irrational x := h₂\n    -- Extend the result to the entire real line by considering multiple intervals\n    have h₅ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by\n      -- Use the fact that the set of rationals is countable and hence has measure zero\n      have h₆ : ∀ (n : ℤ), ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ)), Irrational x := by\n        intro n\n        have h₇ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (0 : ℝ) 1), Irrational x := h₂\n        -- Use the fact that the set of rationals is countable and hence has measure zero\n        have h₈ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ)), Irrational x := by\n          -- Use the fact that the set of rationals is countable and hence has measure zero\n          have h₉ : (volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ))).Translate (-(n : ℝ)) = volume.restrict (Set.Icc (0 : ℝ) 1) := by\n            -- Use the fact that the set of rationals is countable and hence has measure zero\n            have h₁₀ : (volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ))).Translate (-(n : ℝ)) = volume.restrict (Set.Icc (0 : ℝ) 1) := by\n              -- Use the fact that the set of rationals is countable and hence has measure zero\n              calc\n                (volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ))).Translate (-(n : ℝ)) = (volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ))).Translate (-(n : ℝ)) := rfl\n                _ = volume.restrict ((Set.Icc (n : ℝ) (n + 1 : ℝ)).Translate (-(n : ℝ))) := by\n                  simp [MeasureTheory.Measure.translate_restrict]\n                _ = volume.restrict (Set.Icc (0 : ℝ) 1) := by\n                  congr 1\n                  ext x\n                  simp [Set.mem_Icc, Set.mem_translate]\n                  <;>\n                  (try {\n                    constructor <;> intro h <;>\n                    (try { constructor <;> linarith }) <;>\n                    (try { linarith })\n                  })\n                  <;>\n                  (try { ring_nf at * <;> linarith })\n                  <;>\n                  (try { linarith })\n            -- Use the fact that the set of rationals is countable and hence has measure zero\n            exact h₁₀\n          -- Use the fact that the set of rationals is countable and hence has measure zero\n          have h₁₀ : ∀ᵐ (x : ℝ) ∂(volume.restrict (Set.Icc (n : ℝ) (n + 1 : ℝ))).Translate (-(n : ℝ)), Irrational (x + (n : ℝ)) := by\n            -- Use the fact",
      "\n  have h : ∀ᵐ (x : ℝ), Irrational x := by\n    -- Use the fact that the set of rational numbers is countable and thus has measure zero\n    have h₁ : (Set.univ : Set ℝ) = Set.univ := rfl\n    have h₂ : (Set.univ : Set ℝ) ∈ (volume : Measure ℝ) := by\n      exact measurableSpace.volume.measurableSet_univ\n    -- Use the property of the Lebesgue measure that the set of rationals has measure zero\n    have h₃ : ∀ᵐ (x : ℝ), Irrational x := by\n      -- The set of rational numbers has measure zero in the real numbers\n      have h₄ : (volume : Measure ℝ) (Set.univ : Set ℝ) = ∞ := by\n        simp [volume_univ]\n      -- Use the fact that the complement of the rationals is dense and has full measure\n      have h₅ : {x : ℝ | Irrational x} ∈ (volume : Measure ℝ).ae :=\n        by\n          have h₆ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by\n            -- The set of rationals is countable, so it has measure zero\n            have h₇ : (Set.range (coe : ℚ → ℝ)).Countable := Set.countable_range _\n            have h₈ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 :=\n              by\n                -- Use the fact that countable sets have measure zero\n                apply Measure.measure_zero_of_countable\n                exact h₇\n              exact h₈\n          -- The complement of the rationals has full measure\n          have h₉ : {x : ℝ | Irrational x} = (Set.range (coe : ℚ → ℝ))ᶜ := by\n            ext x\n            simp [Irrational, Set.mem_compl_iff, Set.mem_range]\n            <;>\n            aesop\n          rw [h₉]\n          -- Use the fact that the measure of the complement is the complement of the measure\n          have h₁₀ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ))ᶜ = ∞ := by\n            -- Since the measure of the rationals is zero, the complement has full measure\n            have h₁₁ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := h₆\n            have h₁₂ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ))ᶜ = (volume : Measure ℝ) (Set.univ : Set ℝ) := by\n              -- The complement of the rationals is the entire space minus the rationals\n              have h₁₃ : (Set.range (coe : ℚ → ℝ))ᶜ = Set.univ \\ Set.range (coe : ℚ → ℝ) := by\n                ext x\n                simp [Set.mem_compl_iff, Set.mem_diff]\n                <;>\n                tauto\n              rw [h₁₃]\n              <;>\n              simp [volume_iUnion, volume_diff]\n              <;>\n              aesop\n            rw [h₁₂]\n            <;>\n            simp [volume_univ]\n          -- Use the fact that the measure of the complement is the complement of the measure\n          have h₁₃ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ))ᶜ = ∞ := h₁₀\n          -- Use the fact that the complement of the rationals has full measure\n          have h₁₄ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ))ᶜ = ∞ := h₁₀\n          -- Use the fact that the complement of the rationals has full measure\n          exact (ae_restrict_mem (Set.range (coe : ℚ → ℝ))ᶜ) (by simp [h₆]) (by\n            simp_all [h₁₀])\n          <;>\n          aesop\n        -- Use the fact that the complement of the rationals has full measure\n        exact h₅\n      -- Use the fact that the complement of the rationals has full measure\n      exact h₃\n    -- Use the fact that the complement of the rationals has full measure\n    exact h₃\n  -- Use the fact that the complement of the rationals has full measure\n  exact h",
