example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    have h₁ : Irrational (Real.sqrt 2) := by
      apply Nat.Prime.irrational_sqrt
      <;> norm_num
    -- Use the fact that the set of rational numbers has measure zero in ℝ
    have h₂ : (Set.range (coe : ℚ → ℝ)).volume = 0 := by
      -- The set of rational numbers is countable and thus has measure zero
      have h₃ : Set.Countable (Set.range (coe : ℚ → ℝ)) := by
        apply Set.countable_range
      -- A countable set in ℝ has measure zero
      have h₄ : (Set.range (coe : ℚ → ℝ)).volume = 0 := by
        apply MeasureTheory.volume_null_of_countable
        exact h₃
      exact h₄
    -- The complement of the rational numbers in ℝ has full measure
    have h₃ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
      -- The complement of a measure-zero set has full measure
      have h₄ : (Set.range (coe : ℚ → ℝ)).volume = 0 := h₂
      have h₅ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
        apply (measurableSet_mem (measurableSpaceReal : MeasurableSpace ℝ) (measurableSet_range (measurableSpaceRat : MeasurableSpace ℚ))).aebecause
        -- The set of rationals has measure zero
        simp_all [h₄]
      exact h₅
    -- If x is not in the set of rationals, then it is irrational
    filter_upwards [h₃] with x hx
    have h₄ : Irrational x := by
      intro h₅
      -- If x is rational, then it is in the range of the rationals
      have h₆ : ∃ (q : ℚ), (q : ℝ) = x := by
        obtain ⟨q, hq⟩ := h₅
        refine' ⟨q, _⟩
        <;> simp_all [Rat.cast_inj]
      -- Contradiction with hx
      obtain ⟨q, hq⟩ := h₆
      have h₇ : x ∈ Set.range (coe : ℚ → ℝ) := by
        refine' ⟨q, _⟩
        <;> simp_all
      contradiction
    exact h₄
  -- Since the result holds for the volume measure, it holds for the default measure
  simpa using h
