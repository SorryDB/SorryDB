      "\n  have h : ∀ᵐ (x : ℝ), Irrational x := by\n    -- Use the fact that the set of rational numbers is countable and hence has measure zero\n    have h₁ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).measurable := by\n      apply MeasurableSet.range\n      exact measurable_cast\n    -- The set of rational numbers has measure zero\n    have h₂ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n      have h₃ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).measurable := h₁\n      have h₄ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n        have h₅ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = {x : ℝ | ∃ (q : ℚ), (q : ℝ) = x} := by\n          ext x\n          simp [Set.mem_range]\n          <;>\n          aesop\n        have h₆ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n          -- Use the fact that the set of rational numbers is countable and hence has measure zero\n          -- This is a standard result in measure theory\n          have h₇ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := by\n            -- The range of a function from a countable set is countable\n            apply Set.countable_range\n          -- In Lean, we can directly use the fact that the measure of a countable set is zero\n          have h₈ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n            -- Use the fact that the set of rational numbers is countable and hence has measure zero\n            -- This is a standard result in measure theory\n            have h₉ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).measurable := h₁\n            -- Use the fact that the measure of a countable set is zero\n            have h₁₀ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n              -- Use the fact that the set of rational numbers is countable and hence has measure zero\n              -- This is a standard result in measure theory\n              have h₁₁ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) ⊆ Set.univ := by\n                exact Set.subset_univ _\n              -- Use the fact that the measure of a countable set is zero\n              have h₁₂ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := by\n                -- Use the fact that the set of rational numbers is countable and hence has measure zero\n                -- This is a standard result in measure theory\n                exact by\n                  apply Measure.of_outer_measure.measure_zero_of_forgetful_property\n                  <;>\n                  (try norm_num) <;>\n                  (try simp_all [Irrational, Set.mem_range]) <;>\n                  (try aesop) <;>\n                  (try\n                    {\n                      -- Use the fact that the set of rational numbers is countable and hence has measure zero\n                      -- This is a standard result in measure theory\n                      have h₁₃ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := by\n                        -- The range of a function from a countable set is countable\n                        apply Set.countable_range\n                      -- Use the fact that the measure of a countable set is zero\n                      have h₁₄ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := h₁₃\n                      -- Use the fact that the measure of a countable set is zero\n                      exact h₁₄.to_outer_measure_nhds_zero\n                    })\n                  <;>\n                  (try\n                    {\n                      -- Use the fact that the set of rational numbers is countable and hence has measure zero\n                      -- This is a standard result in measure theory\n                      have h₁₃ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := by\n                        -- The range of a function from a countable set is countable\n                        apply Set.countable_range\n                      -- Use the fact that the measure of a countable set is zero\n                      have h₁₄ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := h₁₃\n                      -- Use the fact that the measure of a countable set is zero\n                      exact h₁₄.to_outer_measure_nhds_zero\n                    })\n                  <;>\n                  (try\n                    {\n                      -- Use the fact that the set of rational numbers is countable and hence has measure zero\n                      -- This is a standard result in measure theory\n                      have h₁₃ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := by\n                        -- The range of a function from a countable set is countable\n                        apply Set.countable_range\n                      -- Use the fact that the measure of a countable set is zero\n                      have h₁₄ : (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ).countable := h₁₃\n                      -- Use the fact that the measure of a countable set is zero\n                      exact h₁₄.to_outer_measure_nhds_zero\n                    })\n              exact h₁₂\n            exact h₁₀\n          exact h₈\n        exact h₆\n      exact h₄\n    -- Therefore, the set of irrational numbers has full measure\n    have h₃ : ∀ᵐ (x : ℝ), Irrational x := by\n      -- Use the fact that the set of rational numbers has measure zero\n      have h₄ : ∀ᵐ (x : ℝ), x ∉ Set.range (fun p : ℚ => (p : ℝ)) := by\n        -- The set of rational numbers has measure zero\n        have h₅ : μ (Set.range (fun p : ℚ => (p : ℝ)) : Set ℝ) = 0 := h₂\n        -- Use the fact that the set of rational numbers has measure zero\n        have h₆ : ∀ᵐ (x : ℝ), x ∉ Set.range (fun p : ℚ => (p : ℝ)) := by\n          -- Use the fact that the set of rational numbers has measure zero\n          apply Measure.ae_not_mem_of_measure_zero\n          <;>\n          (try simp_all [h₅]) <;>\n          (try aesop)\n          <;>\n          (try\n            {\n              -- Use the fact tha