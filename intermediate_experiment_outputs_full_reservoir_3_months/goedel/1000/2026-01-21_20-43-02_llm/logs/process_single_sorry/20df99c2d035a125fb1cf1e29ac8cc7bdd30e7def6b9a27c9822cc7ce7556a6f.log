    have h₁ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := by
      apply Measure.measure_eq_zero_of_countable
      <;> assumption
    exact h₁
  
  have h_main : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by
    have h₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by
      have h₂ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := h_null
      have h₃ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by
        -- Use the fact that the measure of the set of rationals is zero to conclude that almost every real number is not in the set of rationals.
        have h₄ : (volume : Measure ℝ) (Set.range (fun q : ℚ => (q : ℝ))) = 0 := h₂
        have h₅ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) :=
          (ae_restrict_compl (by
            -- Show that the set of rationals is measurable.
            have h₆ : MeasurableSet (Set.range (fun q : ℚ => (q : ℝ))) :=
              MeasurableSet.countable (by
                -- Use the fact that the set of rationals is countable to show it is measurable.
                simpa using h_countable)
            exact h₆))
        exact h₅
      exact h₃
    exact h₁
  
  have h_final : ∀ᵐ (x : ℝ), Irrational x := by
    have h₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := h_main
    have h₂ : ∀ᵐ (x : ℝ), Irrational x := by
      filter_upwards [h₁] with x hx
      -- If x is not in the range of the function that maps rationals to reals, then it is irrational.
      have h₃ : x ∉ Set.range (fun q : ℚ => (q : ℝ)) := hx
      have h₄ : Irrational x := by
        -- Use the definition of irrational numbers to conclude the proof.
        have h₅ : ¬∃ q : ℚ, (q : ℝ) = x := by
          intro h
          obtain ⟨q, hq⟩ := h
          have h₆ : x ∈ Set.range (fun q : ℚ => (q : ℝ)) := by
            use q
            <;> simp_all [hq]
          contradiction
        simpa [Irrational] using h₅
      exact h₄
    exact h₂
  
  exact h_final
