Here is the proof that replaces the `sorry`:

```lean
example : ∀ᵐ x : ℝ, Irrational x := by
  have : ae_restrict (measurableSet_univ : MeasurableSet (Set.univ : Set ℝ)) lebesgue
    (by
      -- We use the fact that the measure of the rationals is zero
      have h : (Set.range ((↑) : ℚ → ℝ)).toSet ≈ᵐ[lebesgue] ∅ := by
        -- The rationals are countable and have measure zero
        have h₁ : (Set.range ((↑) : ℚ → ℝ)).toSet ≈ᵐ[lebesgue] ∅ := by
          -- The set of rationals is countable and thus has measure zero
          simpa using measurable_null_iff_ae_restrict.mpr (by
            apply (countable_range_iff.mpr (by infer_instance)).null
          )
        exact h₁
      -- Since the rationals have measure zero, almost every real is irrational
      have h₂ : ∀ᵐ (x : ℝ) ∂lebesgue, Irrational x := by
        -- Use the fact that the rationals have measure zero
        have h₃ : ∀ᵐ (x : ℝ) ∂lebesgue, x ∉ (Set.range ((↑) : ℚ → ℝ)) := by
          -- The set of rationals is countable and thus has measure zero
          have h₄ : (Set.range ((↑) : ℚ → ℝ)).toSet ≈ᵐ[lebesgue] ∅ := h
          -- The intersection of the rationals with any set of measure zero is measure zero
          have h₅ : ∀ᵐ (x : ℝ) ∂lebesgue, x ∉ (Set.range ((↑) : ℚ → ℝ)) := by
            filter_upwards [h₄.eventually (measurableSet_empty)] with x hx
            simp_all [Set.mem_range]
            <;> aesop
          exact h₅
        -- Convert the statement to use the definition of Irrational
        filter_upwards [h₃] with x hx
        simp_all [Irrational, Set.mem_range]
        <;> aesop
      -- Use the fact that the rationals have measure zero to conclude
      exact h₂
    )
  -- Since the set of reals is the whole space, we can use the fact that almost every real is irrational
  exact ae_restrict_iff_ae_restrict.mpr this
