          have h₆ : (Set.range (coe : ℚ → ℝ)).countable := h₁
          have h₇ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by
            apply Measure.of_countable
            <;> simp_all [h₆]
            <;>
            infer_instance
          exact h₇
        exact h₅
      -- Using the fact that the set has measure zero to conclude that it is meager
      have h₈ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (Set.range (coe : ℚ → ℝ)) := by
        have h₉ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := h₃
        have h₁₀ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (Set.range (coe : ℚ → ℝ)) := by
