    ∃ t ⊆ s, MeasurableSet t ∧ volume t = volume s ∧ volume (s \ t) = 0 := by
  obtain ⟨t, ht_sub, ht_measurable, ht_ae⟩ := h.exists_measurable_subset_ae_eq
  refine' ⟨t, ht_sub, ht_measurable, _, _⟩
  · -- Prove that volume t = volume s
    have h₁ : volume t = volume s := by
      have h₂ : (volume : Measure ℝ) t = (volume : Measure ℝ) s := by
        apply measure_congr_ae
        <;> simp_all [Set.ae_restrict]
        <;> try norm_num
        <;> try linarith
      exact h₂
    exact h₁
