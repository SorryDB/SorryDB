lemma nullmeasurable_measurable_null {s : Set ℝ} (h : NullMeasurableSet s volume) :
    ∃ t ⊆ s, MeasurableSet t ∧ volume t = volume s ∧ volume (s \ t) = 0 := by
  obtain ⟨t, t_sub_s, t_m, h₁⟩ := h.exists_measurable_subset_ae_eq
  refine' ⟨t, t_sub_s, t_m, _⟩
  have h₂ : volume t = volume s := by
    have h₃ : (t : Set ℝ) =ᵐ[volume] s := by
      filter_upwards [h₁] with x hx using by simp_all
    exact measure_congr h₃
  have h₃ : volume (s \ t) = 0 := by
    have h₄ : (s \ t : Set ℝ) =ᵐ[volume] ∅ := by
      filter_upwards [h₁] with x hx using by
        by_cases h₅ : x ∈ t
        · simp_all [Set.mem_diff]
        · simp_all [Set.mem_diff]
          <;>
          (try { contradiction }) <;>
          (try { aesop })
    have h₅ : volume (s \ t) = volume (∅ : Set ℝ) := by
      apply measure_congr h₄
    rw [h₅]
    simp
  exact ⟨h₂, h₃⟩
