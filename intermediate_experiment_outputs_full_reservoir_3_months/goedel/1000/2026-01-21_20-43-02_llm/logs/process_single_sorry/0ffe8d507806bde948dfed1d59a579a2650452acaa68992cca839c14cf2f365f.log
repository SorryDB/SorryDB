  refine' ⟨t, t_sub_s, t_m, _, _⟩
  · -- Prove that volume t = volume s using measure_congr and t_eq_s
    have h₁ : volume t = volume s := by
      apply MeasureTheory.measure_congr_set_ae
      · exact t_eq_s
      · exact t_eq_s.symm
    exact h₁
  · -- Prove that volume (s \ t) = 0 using ae_le_set.mp t_eq_s.symm.le
    have h₂ : volume (s \ t) = 0 := by
      have h₃ : volume (s \ t) = 0 := by
        have h₄ : volume (s \ t) = 0 := by
          have h₅ : volume (s \ t) = 0 := by
            -- Use the fact that t_eq_s.symm.le implies that s \ t has measure zero
            have h₆ : s \ t ⊆ {x | False} := by
              intro x hx
              have h₇ : x ∈ s := by exact hx.1
              have h₈ : x ∉ t := by exact hx.2
              have h₉ : x ∈ t := by
                have h₁₀ := t_eq_s.symm
                have h₁₁ : t =ᵐ[volume] s := h₁₀
                have h₁₂ : x ∈ s := h₇
                have h₁₃ : x ∈ t := by
                  have h₁₄ : (t : Set ℝ) =ᵐ[volume] s := h₁₀
                  have h₁₅ : x ∈ s := h₁₂
                  have h₁₆ : x ∈ t := by
                    by_contra h₁₇
                    have h₁₈ : x ∉ t := h₁₇
                    have h₁₉ : (t : Set ℝ) ≠ᵐ[volume] s := by
                      have h₂₀ : ¬(x ∈ t ↔ x ∈ s) := by
                        simp_all
                        <;> tauto
                      have h₂₁ : ¬(∀ᵐ x ∈ (⊤ : Set ℝ), x ∈ t ↔ x ∈ s) := by
                        intro h₂₂
                        have h₂₃ : x ∈ (⊤ : Set ℝ) := by trivial
                        have h₂₄ : x ∈ t ↔ x ∈ s := h₂₂ x h₂₃
                        tauto
                      simpa [Filter.eventually_iff_forall] using h₂₁
                    exact absurd h₁₁ h₁₉
                  exact h₁₆
                exact h₁₃
              tauto
            have h₁₀ : volume (s \ t) = 0 := by
              have h₁₁ : s \ t ⊆ {x | False} := h₆
              have h₁₂ : volume (s \ t) ≤ volume ({x | False} : Set ℝ) := by
                apply volume_mono
                exact h₁₁
              have h₁₃ : volume ({x | False} : Set ℝ) = 0 := by
                simp [volume_bot]
              have h₁₄ : volume (s \ t) ≤ 0 := by
                linarith
              have h₁₅ : 0 ≤ volume (s \ t) := by
                apply MeasureTheory.volume_nonneg
              linarith
            exact h₁₀
          exact h₅
        exact h₄
      exact h₃
    exact h₂
