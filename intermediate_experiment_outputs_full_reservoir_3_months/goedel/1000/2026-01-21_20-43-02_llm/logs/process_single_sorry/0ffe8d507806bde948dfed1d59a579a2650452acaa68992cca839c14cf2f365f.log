      "\n  have h_main : ∃ (t : Set ℝ), t ⊆ s ∧ MeasurableSet t ∧ volume t = volume s ∧ volume (s \\ t) = 0 := by\n    have ⟨t, t_sub_s, t_m, t_eq_s⟩ := h.exists_measurable_subset_ae_eq\n    refine' ⟨t, t_sub_s, t_m, _, _⟩\n    · -- Prove that volume t = volume s\n      exact measure_congr t_eq_s\n    · -- Prove that volume (s \\ t) = 0\n      have h₁ : volume (s \\ t) = 0 := by\n        have h₂ : (s \\ t : Set ℝ) ⊆ {x : ℝ | ¬(x ∈ t)} := by\n          intro x hx\n          simp_all [Set.mem_diff]\n          <;> tauto\n        have h₃ : volume (s \\ t) = 0 := by\n          have h₄ : volume (s \\ t) ≤ volume {x : ℝ | ¬(x ∈ t)} := by\n            apply volume_mono\n            exact h₂\n          have h₅ : volume {x : ℝ | ¬(x ∈ t)} = 0 := by\n            have h₆ : {x : ℝ | ¬(x ∈ t)} = {x : ℝ | x ∉ t} := by rfl\n            rw [h₆]\n            -- Use the fact that the complement of a measurable set is measurable and its volume is zero\n            have h₇ : t_eq_s.symm : (t : Set ℝ) =ᵐ[volume] s := by\n              simpa [ae_eq] using t_eq_s.symm\n            have h₈ : ( {x : ℝ | x ∉ t} : Set ℝ) =ᵐ[volume] {x : ℝ | x ∉ s} := by\n              filter_upwards [h₇] with x hx\n              simp_all [Set.mem_compl_iff]\n              <;> tauto\n            have h₉ : volume {x : ℝ | x ∉ s} = 0 := by\n              have h₁₀ : (s : Set ℝ) =ᵐ[volume] t := by\n                simpa [ae_eq] using t_eq_s\n              have h₁₁ : volume (s : Set ℝ) = volume (t : Set ℝ) := by\n                exact measure_congr t_eq_s\n              -- Since s is almost everywhere equal to t, the complement of s is almost everywhere equal to the complement of t\n              have h₁₂ : volume {x : ℝ | x ∉ s} = 0 := by\n                -- The complement of s is a subset of the complement of t\n                have h₁₃ : {x : ℝ | x ∉ s} ⊆ {x : ℝ | x ∉ t} := by\n                  intro x hx\n                  simp_all [Set.mem_compl_iff]\n                  <;> tauto\n                -- The complement of t has volume zero\n                have h₁₄ : volume {x : ℝ | x ∉ t} = 0 := by\n                  have h₁₅ : (t : Set ℝ) =ᵐ[volume] s := by\n                    simpa [ae_eq] using t_eq_s.symm\n                  have h₁₆ : {x : ℝ | x ∉ t} =ᵐ[volume] {x : ℝ | x ∉ s} := by\n                    filter_upwards [h₁₅] with x hx\n                    simp_all [Set.mem_compl_iff]\n                    <;> tauto\n                  have h₁₇ : volume {x : ℝ | x ∉ s} = 0 := by\n                    have h₁₈ : (s : Set ℝ) =ᵐ[volume] t := by\n                      simpa [ae_eq] using t_eq_s\n                    have h₁₉ : volume {x : ℝ | x ∉ s} = 0 := by\n                      -- Use the fact that the complement of s is almost everywhere equal to the complement of t and the complement of t has volume zero\n                      have h₂₀ : volume {x : ℝ | x ∉ s} ≤ volume {x : ℝ | x ∉ t} := by\n                        apply volume_mono\n                        intro x hx\n                        simp_all [Set.mem_compl_iff]\n                        <;> tauto\n                      have h₂₁ : volume {x : ℝ | x ∉ t} = 0 := by\n                        -- The complement of t has volume zero\n                        have h₂₂ : (t : Set ℝ) =ᵐ[volume] s := by\n                          simpa [ae_eq] using t_eq_s.symm\n                        have h₂₃ : volume {x : ℝ | x ∉ t} = 0 := by\n                          -- Use the fact that the complement of t is almost everywhere equal to the complement of s and the complement of s has volume zero\n                          simp_all [Set.ext_iff, ae_eq]\n                          <;>\n                          (try contradiction) <;>\n                          (try simp_all [volume_eq_zero]) <;>\n                          (try norm_num) <;>\n                          (try linarith)\n                        exact h₂₃\n                      linarith\n                    exact h₁₉\n                  simp_all [Set.ext_iff, ae_eq]\n               