h₃]\n  have h3 : (P.M : ℤ) * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ P.M * ((P.n / P.M + p - 1) / p) := by\n    have h4 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / P.M + p - 1) / p := by\n      have h5 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / P.M + p - 1) / p := by\n        calc\n          (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤\n              (Finset.Ico (P.n - P.n / P.M) P.n).card := Finset.card_le_of_subset (Finset.filter_subset _ _)\n          _ = P.n - (P.n - P.n / P.M) := by\n            simp [Finset.Ico_eq_empty_of_le, Nat.sub_add_cancel (div_le_self P.n P.M)]\n          _ = P.n / P.M := by\n            have h₁ : P.n - (P.n - P.n / P.M) = P.n / P.M := by\n              have h₂ : P.n / P.M ≤ P.n := Nat.div_le_self _ _\n              omega\n            rw [h₁]\n          _ ≤ (P.n / P.M + p - 1) / p := by\n            have h₁ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n              have h₂ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n                have h₃ : (P.n / P.M + p - 1) / p ≥ (P.n / P.M + p - 1) / p := le_refl _\n                have h₄ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n                  have h₅ : p > 0 := by\n                    by_contra h₅\n                    have h₆ : p = 0 := by omega\n                    simp_all\n                  have h₆ : (P.n / P.M + p - 1) / p ≥ (P.n / P.M + p - 1) / p := le_refl _\n                  have h₇ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n                    have h₈ : (P.n / P.M + p - 1) ≥ p * (P.n / P.M) := by\n                      cases P.M with\n                      | zero =>\n                        simp_all\n                      | succ M' =>\n                        cases p with\n                        | zero =>\n                          simp_all\n                        | succ p' =>\n                          simp_all [Nat.mul_sub_left_distrib, Nat.add_assoc]\n                          <;> ring_nf at *\n                          <;> omega\n                    have h₉ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n                      have h₁₀ : p > 0 := by\n                        by_contra h₁₀\n                        have h₁₁ : p = 0 := by omega\n                        simp_all\n                      have h₁₁ : (P.n / P.M + p - 1) / p ≥ P.n / P.M := by\n                        apply Nat.le_div_iff_mul_le (by omega) |>.mpr\n                        <;> nlinarith\n                      exact h₁₁\n                    exact h₉\n                  exact h₇\n                exact h₄\n              exact h₂\n            omega\n      exact h5\n    have h6 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / P.M + p - 1) / p := h4\n    have h7 : (P.M : ℤ) * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ P.M * ((P.n / P.M + p - 1) / p) := by\n      norm_cast at h6 ⊢\n      <;>\n      (try omega) <;>\n      (try nlinarith) <;>\n      (try\n        {\n          cases P.M with\n          | zero => simp_all\n          | succ M' =>\n            cases p with\n            | zero => simp_all\n            | succ p' =>\n              simp_all [Nat.mul_sub_left_distrib, Nat.add_assoc]\n              <;> ring_nf at *\n              <;> omega\n        }\n      )\n    exact h7\n  have h4 : (P.M : ℤ) * ((P.n / P.M + p - 1) / p) ≤ P.n / p + P.M := by\n    have h5 : (P.M : ℤ) * ((P.n / P.M + p - 1) / p) ≤ P.n / p + P.M := by\n      norm_cast at *\n      have h6 : P.M * ((P.n / P.M + p - 1) / p) ≤ P.n / p + P.M := by\n        have h7 : P.M * ((P.n / P.M + p - 1) / p) ≤ P.n / p + P.M := by\n          have h8 : (P.n / P.M + p - 1) / p ≤ (P.n / p + P.M) := by\n            apply Nat.le_of_sub_eq_zero\n            have h9 : p > 0 := by\n              by_contra h9\n              have h10 : p = 0 := by omega\n              simp_all\n            have h10 : (P.n / P.M + p - 1) / p ≤ (P.n / p + P.M) := by\n              have h11 :