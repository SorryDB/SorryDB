      "\n  have h_balance_ge : P.initial.balance p ≥ -P.M := by\n    simp only [Factorization.balance, Factorization.sum, Params.initial]\n    have h₁ : (filter (fun m : ℕ => m ∈ (P.n / P.L).smoothNumbers) (replicate P.M (Ico (P.n - P.n / P.M) P.n)).join).map (fun m : ℕ => m.factorization p) |>.sum = 0 := by\n      apply Multiset.sum_eq_zero\n      intro x hx\n      simp only [Multiset.mem_map, Multiset.mem_filter, Multiset.mem_join, Multiset.mem_replicate] at hx\n      rcases hx with ⟨m, ⟨⟨_, ⟨h₁, _⟩, h₂⟩, h₃⟩, rfl⟩\n      have h₄ : m ∈ (P.n / P.L).smoothNumbers := h₃\n      have h₅ : (m : ℕ) ∈ (P.n / P.L).smoothNumbers := by simpa using h₄\n      have h₆ : p ∉ m.factors := by\n        have h₆₁ : m ∈ (P.n / P.L).smoothNumbers := h₄\n        rw [Finset.mem_filter] at h₆₁\n        obtain ⟨h₆₂, h₆₃⟩ := h₆₁\n        have h₆₄ : p > P.n / P.L := by\n          have h₆₅ : (p : ℝ) > Real.sqrt P.n := hp'\n          have h₆₆ : (Real.sqrt P.n : ℝ) ≥ (P.L : ℝ) := by\n            have h₆₇ : (P.L : ℝ) * (P.L : ℝ) ≤ (P.n : ℝ) := by\n              exact_mod_cast (by nlinarith)\n            have h₆₈ : Real.sqrt (P.n : ℝ) ≥ (P.L : ℝ) := by\n              apply Real.le_sqrt_of_sq_le\n              exact h₆₇\n            linarith\n          have h₆₉ : (p : ℝ) > (P.L : ℝ) := by linarith\n          have h₆₁₀ : p > P.L := by\n            exact_mod_cast h₆₉\n          have h₆₁₁ : p > P.n / P.L := by\n            have h₆₁₂ : (p : ℕ) > P.n / P.L := by\n              have h₆₁₃ : (p : ℕ) > P.L := by exact_mod_cast h₆₉\n              have h₆₁₄ : P.n / P.L < p := by\n                have h₆₁₅ : P.n / P.L < P.L := by\n                  have h₆₁₆ : P.n < P.L * P.L := by\n                    have h₆₁₇ : P.n < P.L * P.L := by\n                      exact by\n                        have h₆₁₈ : (P.L : ℕ) * (P.L : ℕ) > P.n := by\n                          nlinarith\n                        omega\n                    omega\n                  have h₆₁₉ : P.n / P.L < P.L := by\n                    apply Nat.div_lt_of_lt_mul\n                    nlinarith\n                  exact h₆₁₉\n                have h₆₂₀ : P.L ≤ p := by\n                  have h₆₂₁ : (P.L : ℝ) < (p : ℝ) := by\n                    linarith\n                  have h₆₂₂ : (P.L : ℕ) < p := by\n                    exact_mod_cast h₆₂₁\n                  linarith\n                omega\n              omega\n            exact Mod_cast h₆₁₂\n          exact h₆₁₁\n        have h₆₅ : ∀ q ∈ m.factors, q ≤ P.n / P.L := by\n          have h₆₆ : m ∈ (P.n / P.L).smoothNumbers := h₄\n          rw [Finset.mem_filter] at h₆₆\n          obtain ⟨h₆₇, h₆₈⟩ := h₆₆\n          intro q hq\n          have h₆₉ : q ≤ P.n / P.L := by\n            have h₆₁₀ : q ∈ m.factors := hq\n            have h₆₁₁ : q ∈ Finset.filter (fun q => q ≤ P.n / P.L) (Nat.factors m) := h₆₈\n            simp [Finset.mem_filter] at h₆₁₁\n            aesop\n          exact h₆₉\n        have h₆₅₁ : p ∉ m.factors := by\n          intro h₆₅₂\n          have h₆₅₃ : p ≤ P.n / P.L := by\n            have h₆₅₄ : p ∈ m.factors := h₆₅₂\n            have h₆₅₅ : p ≤ P.n / P.L := h₆₅ p h₆₅₄\n            exact h₆₅₅\n          linarith\n        exact h₆₅₁\n      have h₇ : m.factorization p = 0 := by\n        rw [factorization_eq_zero_iff]\n        <;>\n        (try simp_all [Nat.mem_factors, Nat.Prime.ne_one, Nat.Prime.ne_zero]) <;>\n        (try aesop) <;>\n        (try omega)\n      simp_all\n    have h₂ : (P.n.factorial.factorization p : ℤ) ≥ 0 := by\n      norm_cast\n      <;>\n      (try\n        positivity) <;>\n      (try\n        {\n          have h₃ : P.n.factorial.factorization p ≥ 0 := by\n            positivity\n          linarith\n        })\n      <;>\n      (try\n        {\n          positivity\n        })\n    simp_all [h₁]\n    <;>\n    (try\n      norm_num) <;>\n    (try\n      linarith)\n  exact h_balance_ge",
      "\n  have h₁ : P.initial.balance p = ((Multiset.map (·.factorization p) P.initial.a).sum : ℝ) - (P.n.factorial.factorization p : ℝ) := by\n    simp [Factorization.balance, Factorization.sum]\n    <;> ring_nf\n    <;> field_simp\n    <;> norm_cast\n    <;> simp_all [Multiset.sum_map]\n    <;> linarith\n  \n  have h₂ : ((Multiset.map (·.factorization p) P.initial.a).sum : ℝ) = 0 := by\n    have h₃ : (P.initial.a.map (·.factorization p)).sum = 0 := by\n      sum_eq_zero fun x hx ↦ by\n        simp only [Multiset.mem_map, Params.initial, Multiset.mem_filter] at hx\n        obtain ⟨m, ⟨_, hsmooth⟩, rfl⟩ := hx\n        rw [factorization_eq_zero_iff, mem_smoothNumbers'] at *\n        by_cases hprime : p.Prime\n        · by_cases hdvd : p ∣ m\n          · exact ((hsmooth p hprime hdvd).not_gt (by\n              have h₄ : p ≤ P.n / P.L := hp\n              have h₅ : p > 0 := by\n                by_contra h\n                have h₆ : p = 0 := by omega\n                simp_all [h₆]\n                <;> norm_num\n                <;> linarith [Real.sqrt_nonneg (P.n : ℝ)]\n              have h₆ : (p : ℕ) > Real.sqrt P.n := by exact_mod_cast hp'\n              have h₇ : (P.n : ℝ) < (p : ℝ) * (p : ℝ) := by\n                nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : (0 : ℝ) ≤ (P.n : ℝ))]\n              have h₈ : (m : ℕ) ∈ Set.Ico (P.n - P.n / P.M) P.n := by\n                simp_all [Multiset.mem_Ico]\n                <;> omega\n              have h₉ : (m : ℕ) < P.n := by\n                simp_all [Multiset.mem_Ico]\n                <;> omega\n              have h₁₀ : (p : ℕ) > 0 := by omega\n              have h₁₁ : (m : ℕ) < (p : ℕ) ^ 2 := by\n                nlinarith [Nat.div_mul_le_self P.n P.M]\n              have h₁₂ : (p : ℕ) > P.n / P.L := by\n                have h₁₃ : p ≤ P.n / P.L := hp\n                linarith\n              omega\n            )).elim\n          · exact .inr (.inl hdvd)\n        · exact .inl hprime\n    have h₄ : ((Multiset.map (·.factorization p) P.initial.a).sum : ℝ) = 0 := by\n      norm_cast at h₃ ⊢\n      <;> simp_all [Multiset.sum_map]\n      <;> linarith\n    exact h₄\n  \n  have h₃ : (P.n.factorial.factorization p : ℝ) ≤ (P.M : ℝ) := by\n    -- Proof that the p-adic valuation of n! is bounded by M\n    have h₄ : (P.n.factorial.factorization p : ℕ) ≤ P.M := by\n      by_cases h₅ : p.Prime\n      · have h₆ : (P.n.factorial.factorization p : ℕ) ≤ P.M := by\n          -- Use the fact that p is prime and the constraints to bound the valuation\n          have h₇ : p ≤ P.n / P.L := hp\n          have h₈ : p > Real.sqrt P.n := hp'\n          have h₉ : (p : ℝ) > Real.sqrt P.n := by exact_mod_cast hp'\n          have h₁₀ : (P.n : ℝ) < (p : ℝ) * (p : ℝ) := by\n            nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : (0 : ℝ) ≤ (P.n : ℝ))]\n          have h₁₁ : p > 0 := by\n            by_contra h\n            have h₁₂ : p = 0 := by omega\n            simp_all [h₁₂]\n            <;> norm_num\n            <;> linarith [Real.sqrt_nonneg (P.n : ℝ)]\n          have h₁₂ : (P.n.factorial.factorization p : ℕ) ≤ P.M := by\n            have h₁₃ : (P.n.factorial.factorization p : ℕ) = 0 := by\n              have h₁₄ : p > P.n := by\n                have h₁₅ : (p : ℝ) > Real.sqrt P.n := by exact_mod_cast hp'\n                have h₁₆ : (P.n : ℝ) < (p : ℝ) * (p : ℝ) := by\n                  nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : (0 : ℝ) ≤ (P.n : ℝ))]\n                have h₁₇ : (p : ℕ) > 0 := by omega\n                have h₁₈ : (p : ℕ) > Real.sqrt P.n := by exact_mod_cast hp'\n                have h₁₉ : (p : ℕ) > 0 := by omega\n                -- Use the fact that p^2 > n to show p > n\n                have h₂₀ : p * p > P.n := by\n                  norm_cast at h₁₆ ⊢\n                  <;> nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : (0 : ℝ) ≤ (P.n : ℝ))]\n                have h₂₁ : p > P.n := by\n                  by_