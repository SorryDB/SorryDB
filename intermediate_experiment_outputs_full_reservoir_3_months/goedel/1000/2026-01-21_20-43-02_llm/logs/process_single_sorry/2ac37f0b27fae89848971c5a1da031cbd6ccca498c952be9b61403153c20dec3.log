      apply Multiset.sum_nonneg
      intro x hx
      simp only [Multiset.mem_map, Params.initial, Multiset.mem_filter] at hx
      obtain ⟨m, ⟨_, hsmooth⟩, rfl⟩ := hx
      rw [factorization_nonneg]
      <;> norm_cast
      <;> simp_all [mem_smoothNumbers']
      <;> aesop
    simp only [Factorization.balance, Factorization.sum, sub_eq_add_neg, add_assoc]
