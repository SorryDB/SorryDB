def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -∞ = ∞
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - a₁*x - a₃)
    MordellWeilGroup.mk_point E x (-y - E.val.a₁*x - E.val.a₃) (by
      dsimp only at *
      have h₁ : y ^ 2 + E.val.a₁ * x * y + E.val.a₃ * y = x ^ 3 + E.val.a₂ * x ^ 2 + E.val.a₄ * x + E.val.a₆ := by
        have h₂ := P.on_curve x y (by rfl)
        simpa using h₂
      calc
        (-y - E.val.a₁ * x - E.val.a₃) ^ 2 + E.val.a₁ * x * (-y - E.val.a₁ * x - E.val.a₃) + E.val.a₃ * (-y - E.val.a₁ * x - E.val.a₃)
          = (-y - E.val.a₁ * x - E.val.a₃) ^ 2 + (E.val.a₁ * x * (-y - E.val.a₁ * x - E.val.a₃) + E.val.a₃ * (-y - E.val.a₁ * x - E.val.a₃)) := by ring
        _ = x ^ 3 + E.val.a₂ * x ^ 2 + E.val.a₄ * x + E.val.a₆ := by
          ring_nf at h₁ ⊢
          <;>
          (try simp_all [add_assoc, add_comm, add_left_comm])
          <;>
          (try nlinarith)
          <;>
          (try ring_nf at h₁ ⊢ <;> nlinarith)
          <;>
          (try linarith)
          <;>
          (try nlinarith [sq_nonneg (x + y + 1), sq_nonneg (x - y + 1), sq_nonneg (x + y - 1), sq_nonneg (x - y - 1)])
        )
```

