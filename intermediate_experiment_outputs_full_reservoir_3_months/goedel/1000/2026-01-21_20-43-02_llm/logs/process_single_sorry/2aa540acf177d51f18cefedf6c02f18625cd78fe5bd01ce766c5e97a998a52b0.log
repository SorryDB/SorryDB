            ring_nf
            <;>
            (try simp_all [h₃]) <;>
            (try ring_nf at *) <;>
            (try nlinarith)
          )
    else
      match MordellWeilGroup.slope E P Q with
      | none => MordellWeilGroup.infinity E
      | some s =>
        let W := E.val
        let x₃ := s^2 + W.a₁*s - W.a₂ - x₁ - x₂
        let y₃ := s*(x₁ - x₃) - y₁ - W.a₁*x₃ - W.a₃
        MordellWeilGroup.mk_point E x₃ y₃ (by
          dsimp only at *
          have h₁ : y₁^2 + W.a₁*x₁*y₁ + W.a₃*y₁ = x₁^3 + W.a₂*x₁^2 + W.a₄*x₁ + W.a₆ := by
