        ring_nf
        <;>
        (try simp_all [add_assoc])
        <;>
        (try ring_nf at *)
        <;>
        (try simp_all [sub_eq_add_neg])
        <;>
        (try nlinarith)
      have h₂ : y ^ 2 + E.val.a₁ * x * y + E.val.a₃ * y = x ^ 3 + E.val.a₂ * x ^ 2 + E.val.a₄ * x + E.val.a₆ := by
        have h₃ := P.on_curve x y (by simp)
        dsimp only at h₃ ⊢
        exact
