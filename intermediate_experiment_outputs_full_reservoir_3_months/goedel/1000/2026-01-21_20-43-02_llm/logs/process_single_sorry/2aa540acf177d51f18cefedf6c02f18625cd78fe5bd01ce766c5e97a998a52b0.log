structure MordellWeilGroup : Type u where
  point : Option (K × K)
  on_curve : ∀ (x y : K), point = some (x, y) →
    let W := E.val
    y^2 + W.a₁*x*y + W.a₃*y = x^3 + W.a₂*x^2 + W.a₄*x + W.a₆

def MordellWeilGroup.infinity : MordellWeilGroup E :=
  { point := none
  , on_curve := fun x y h => nomatch h
  }

def MordellWeilGroup.mk_point (x y : K)
    (h : let W := E.val; y^2 + W.a₁*x*y + W.a₃*y = x^3 + W.a₂*x^2 + W.a₄*x + W.a₆) :
    MordellWeilGroup E :=
  { point := some (x, y)
  , on_curve := fun x' y' h' => by
      injection h' with h_eq
      cases h_eq
      exact h
  }

def MordellWeilGroup.slope (P Q : MordellWeilGroup E) : Option K :=
  match P.point, Q.point with
  | none, _ => none
  | _, none => none
  | some (x₁, y₁), some (x₂, y₂) =>
    if x₁ = x₂ then
      if y₁ + y₂ + E.val.a₁*x₁ + E.val.a₃ = 0 then
        none
      else
        let W := E.val
        some ((3*x₁^2 + 2*W.a₂*x₁ + W.a₄ - W.a₁*y₁) / (2*y₁ + W.a₁*x₁ + W.a₃))
    else
      some ((y₂ - y₁) / (x₂ - x₁))

def MordellWeilGroup.add (P Q : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point, Q.point with
  | none, _ => Q
  | _, none => P
  | some (x₁, y₁), some (x₂, y₂) =>
    if x₁ = x₂ then
      if y₁ + y₂ + E.val.a₁*x₁ + E.val.a₃ = 0 then
        MordellWeilGroup.infinity E
      else
        match MordellWeilGroup.slope E P Q with
        | none => MordellWeilGroup.infinity E
        | some s =>
          let W := E.val
          let x₃ := s^2 + W.a₁*s - W.a₂ - x₁ - x₂
          let y₃ := s*(x₁ - x₃) - y₁ - W.a₁*x₃ - W.a₃
          MordellWeilGroup.mk_point E x₃ y₃ (by
            dsimp only at *
            have h₁ : y₁^2 + W.a₁*x₁*y₁ + W.a₃*y₁ = x₁^3 + W.a₂*x₁^2 + W.a₄*x₁ + W.a₆ := by
              have h₁ := P.on_curve x₁ y₁ (by simp [P.point])
              simpa [W] using h₁
            have h₂ : y₂^2 + W.a₁*x₂*y₂ + W.a₃*y₂ = x₂^3 + W.a₂*x₂^2 + W.a₄*x₂ + W.a₆ := by
              have h₂ := Q.on_curve x₂ y₂ (by simp [Q.point])
              simpa [W] using h₂
            have h₃ : x₁ = x₂ := by assumption
            have h₄ : y₁ + y₂ + W.a₁*x₁ + W.a₃ ≠ 0 := by
              by_contra h₄
              simp_all [h₃]
            have h₅ : s = (3*x₁^2 + 2*W.a₂*x₁ + W.a₄ - W.a₁*y₁) / (2*y₁ + W.a₁*x₁ + W.a₃) := by
              simp_all [MordellWeilGroup.slope]
              <;>
                (try ring_nf at *) <;>
                (try field_simp at *) <;>
                  (try simp_all) <;>
                  (try norm_num at *) <;>
                  (try linarith)
            rw [h₅]
            have h₆ : 2*y₁ + W.a₁*x₁ + W.a₃ ≠ 0 := by
