def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -∞ = ∞
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - a₁*x - a₃)
    MordellWeilGroup.mk_point E x (-y - E.val.a₁*x - E.val.a₃) (by
      dsimp [MordellWeilGroup.mk_point]
      let W := E.val
      have h₁ : y ^ 2 + W.a₁ * x * y + W.a₃ * y = x ^ 3 + W.a₂ * x ^ 2 + W.a₄ * x + W.a₆ :=
        P.on_curve x y rfl
      ring_nf at h₁ ⊢
      nlinarith [sq_nonneg (y + W.a₁ * x + W.a₃)])
