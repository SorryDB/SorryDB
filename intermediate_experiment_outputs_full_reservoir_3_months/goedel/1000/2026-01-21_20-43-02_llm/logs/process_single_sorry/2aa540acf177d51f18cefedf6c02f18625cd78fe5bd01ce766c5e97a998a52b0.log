(y')² + a₁xy' + a₃y' = (y² + 2a₁xy + 2a₃y + a₁²x² + 2a₁a₃x + a₃²) + (-a₁xy - a₁²x² - a₁a₃x) + (-a₃y - a₁a₃x - a₃²)
