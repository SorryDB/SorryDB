def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -∞ = ∞
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - a₁*x - a₃)
    MordellWeilGroup.mk_point E x (-y - E.val.a₁*x - E.val.a₃) 
      (by
        dsimp only
        let W := E.val
        have h₁ : y ^ 2 + W.a₁ * x * y + W.a₃ * y = x ^ 3 + W.a₂ * x ^ 2 + W.a₄ * x + W.a₆ := P.on_curve x y (by simp_all)
        have h₂ : (-y - W.a₁ * x - W.a₃) ^ 2 + W.a₁ * x * (-y - W.a₁ * x - W.a₃) + W.a₃ * (-y - W.a₁ * x - W.a₃) = x ^ 3 + W.a₂ * x ^ 2 + W.a₄ * x + W.a₆ := by
          calc
            (-y - W.a₁ * x - W.a₃) ^ 2 + W.a₁ * x * (-y - W.a₁ * x - W.a₃) + W.a₃ * (-y - W.a₁ * x - W.a₃)
              = (y + W.a₁ * x + W.a₃) ^ 2 - W.a₁ * x * (y + W.a₁ * x + W.a₃) - W.a₃ * (y + W.a₁ * x + W.a₃) := by
                  ring_nf
                  <;>
                  simp_all [sub_eq_add_neg, add_assoc]
                  <;>
                  ring_nf at *
                  <;>
                  linarith
                _ = (y + W.a₁ * x + W.a₃) * (y + W.a₁ * x + W.a₃ - W.a₁ * x - W.a₃) := by
                  ring_nf
                _ = (y + W.a₁ * x + W.a₃) * y := by ring_nf
                _ = y * (y + W.a₁ * x + W.a₃) := by ring_nf
                _ = y ^ 2 + W.a₁ * x * y + W.a₃ * y := by ring_nf
                _ = x ^ 3 + W.a₂ * x ^ 2 + W.a₄ * x + W.a₆ := by rw [h₁]
        exact h₂
      )
