def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -∞ = ∞
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - a₁*x - a₃)
    MordellWeilGroup.mk_point E x (-y - E.val.a₁*x - E.val.a₃) (by
      dsimp only at E ⊢
      have h₁ : y^2 + (E.val).a₁*x*y + (E.val).a₃*y = x^3 + (E.val).a₂*x^2 + (E.val).a₄*x + (E.val).a₆ := by
        have h₂ := P.on_curve x y rfl
        simpa using h₂
      -- We need to prove that (-y - a₁*x - a₃)^2 + a₁*x*(-y - a₁*x - a₃) + a₃*(-y - a₁*x - a₃) = x^3 + a₂*x^2 + a₄*x + a₆
      -- Expand and simplify both sides to verify the equality.
      have h₃ : (-y - E.val.a₁ * x - E.val.a₃)^2 + E.val.a₁ * x * (-y - E.val.a₁ * x - E.val.a₃) + E.val.a₃ * (-y - E.val.a₁ * x - E.val.a₃) = x ^ 3 + E.val.a₂ * x ^ 2 + E.val.a₄ * x + E.val.a₆ := by
        ring_nf at h₁ ⊢
        -- Use the given equation y² + a₁xy + a₃y = x³ + a₂x² + a₄x + a₆ to substitute and simplify.
        nlinarith [sq_nonneg (y + E.val.a₁ * x + E.val.a₃), sq_nonneg (y - E.val.a₁ * x), sq_nonneg (x + E.val.a₂),
          sq_nonneg (x - E.val.a₂), sq_nonneg (y + E.val.a₃), sq_nonneg (y - E.val.a₃),
          sq_nonneg (E.val.a₁ * x + E.val.a₃)]
      exact h₃
    )
