theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  have h : ∃ (f : α →* β), ∀ (x : α), F.homF (X := ()) (Y := ()) x = f x := by
    -- Extract the monoid homomorphism from the functor
    use F.homF (X := ()) (Y := ()) (1 : α)
    intro x
    have h₁ : F.homF (X := ()) (Y := ()) (1 : α) = F.homF (X := ()) (Y := ()) (1 : α) := rfl
    -- Since the type is Unit, all elements are the same, and the homomorphism is trivial
    simp_all [MonoidHom.map_one]
    <;> aesop
  -- The result follows from the above construction
  exact h
