theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨fun x => F.F x, _, _⟩
  · -- Prove that F.F is monotone
    intro x y hxy
    have h : (PLift (x ≤ y) : (α := α)) := ⟨hxy⟩
    have h₁ : (F.homF h : (β := β)) = F.F x ≤ F.F y := by
      -- Use the fact that F preserves the order
      have h₂ : (F.homF h : (β := β)) = (F.F x ≤ F.F y : Prop) := by
        -- Since h : x ≤ y, F.homF h should map to F.F x ≤ F.F y
        have h₃ : (h : (α := α)) = ⟨x ≤ y⟩ := rfl
        simp_all [Category.Hom, Preorder, Monotone]
        <;>
        (try simp_all [SetLike.le_def]) <;>
        (try aesop) <;>
        (try simp_all [PLift.forall]) <;>
        (try aesop)
      -- Convert the proof to the correct type
      simpa [h₂] using F.map_id _
    -- Extract the monotonicity condition from h₁
    simpa [h₁] using h₁
  · -- Prove that F.F x = f x for all x
    intro x
    rfl
