theorem kestrel_left_cancellation
    (x y : Bird)
    (kestrel_application : K ◁ x = K ◁ y) :
    (x = y) := by
  have h1 : (K ◁ x) ◁ I = x := by
    have h1 := K.call x I
    exact h1
  have h2 : (K ◁ y) ◁ I = y := by
    have h2 := K.call y I
    exact h2
  have h3 : (K ◁ x) ◁ I = (K ◁ y) ◁ I := by
    rw [kestrel_application]
  have h4 : x = y := by
    calc
      x = (K ◁ x) ◁ I := by rw [h1]
      _ = (K ◁ y) ◁ I := by rw [h3]
      _ = y := by rw [h2]
  exact h4
```
