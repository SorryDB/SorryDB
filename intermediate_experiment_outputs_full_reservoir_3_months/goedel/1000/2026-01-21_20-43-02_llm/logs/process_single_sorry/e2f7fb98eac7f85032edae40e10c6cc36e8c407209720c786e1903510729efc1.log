theorem kestrel_left_cancellation
    (x y : Bird)
    (kestrel_application : K ◁ x = K ◁ y) :
    (x = y) := by
  have h1 : x = y := by
    have h2 : (K ◁ x) ◁ I = (K ◁ y) ◁ I := by
      rw [kestrel_application]
    have h3 : (K ◁ x) ◁ I = x := by
      calc
        (K ◁ x) ◁ I = x := by
          -- Apply the Kestrel's property: (K ◁ x) ◁ y = x for any y
          -- Here, we use y = I
          have h4 := K.call x I
          -- Simplify using the given property
          simp at h4 ⊢
          <;> simp_all
          <;> aesop
        _ = x := by rfl
    have h4 : (K ◁ y) ◁ I = y := by
      calc
        (K ◁ y) ◁ I = y := by
          -- Apply the Kestrel's property: (K ◁ y) ◁ z = y for any z
          -- Here, we use z = I
          have h5 := K.call y I
          -- Simplify using the given property
          simp at h5 ⊢
          <;> simp_all
          <;> aesop
        _ = y := by rfl
    -- Substitute back into the equation
    have h5 : x = y := by
      calc
        x = (K ◁ x) ◁ I := by rw [h3]
        _ = (K ◁ y) ◁ I := by rw [h2]
        _ = y := by rw [h4]
    exact h5
  exact h1
