  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x
      intro z
      have h := K.call x z
      exact h

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h₁ := K.call x K
      have h₂ := K.call K x
      have h₃ := K.call x x
      have h₄ : K ◁ K = K := by
        simpa [egocentric] using kestrel_egocentric
      simp_all [egocentric, hopelessly_egocentric, fixated_on]
      <;> (try simp_all)
      <;> (try exact K.call x x)
      <;> (try exact K.call x K)
      <;> (try exact K.call K x)
      <;> (try exact K.call K K)

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h₁ := K.call x x
      have h₂ := K.call y x
      have h₃ := K.call x y
      have h₄ := K.call y y
      have h₅ : (K ◁ x) = (K ◁ y) := kestrel_application
      have h₆ := congr_fun h₅ x
      -- Since K ◁ x = K ◁ y, applying both sides to x should give the same result.
      -- By the property of K, (K ◁ x) ◁ x = x and (K ◁ y) ◁ x = y.
      -- Therefore, x = y.
      simp at h₆
      <;> simp_all [Kestrel,K.call]
      <;> aesop
