et.univ (Set.Ico I.T₀ V) (fun ρ ↦ 1 / ρ.im) := by\n      rw [← riemannZeta.zeroes_sum_union]\n      <;> simp_all [h₅]\n      <;>\n      aesop\n    rw [h₆]\n    <;>\n    simp_all\n  have h₄ : riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 V) (fun ρ ↦ 1 / ρ.im) < I.S₀ + I.B₁ I.T₀ V := by\n    linarith\n  exact h₄",
