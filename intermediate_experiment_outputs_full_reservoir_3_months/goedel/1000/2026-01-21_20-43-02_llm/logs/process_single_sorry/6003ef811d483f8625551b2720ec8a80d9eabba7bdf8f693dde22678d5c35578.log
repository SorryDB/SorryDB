0 / (2 * Real.pi)) := by\n            apply Real.log_lt_log (by positivity)\n            <;>\n            (try norm_num) <;>\n            (try linarith [Real.pi_pos, Real.pi_gt_three])\n          have h₁₂ : Real.log (V / 30610046000) > 0 := Real.log_pos (by\n            norm_num at hV ⊢ <;>\n            (try linarith [Real.pi_pos, Real.pi_gt_three]))\n          nlinarith [Real.pi_gt_three, Real.pi_pos, Real.log_pos (by norm_num : (1 : ℝ) < 2)]\n        })\n  linarith",
