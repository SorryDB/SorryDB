lemma restrict_winning (h : S.pre.IsWinning (G := interGame V PO)) :
    (restrict hWV hW S).pre.IsWinning (G := interGame W PO) := by
  have h₁ : (restrict hWV hW S).pre = S.pre.map (extend hWV) := by
    simp [restrict, Strategy.pre, Set.Inclusion.injEq]
    <;>
    aesop
  rw [h₁]
  have h₂ : S.pre.map (extend hWV).IsWinning (G := interGame W PO) := by
    -- Use the fact that S is a winning strategy and extend is injective
    have h₃ : S.pre.IsWinning (G := interGame V PO) := h
    -- Map the winning set to the extended tree and prove it remains winning
    have h₄ : ∀ (A : List V), A ∈ S.pre → A.map (Set.inclusion hWV) ∈ S.pre.map (extend hWV) := by
      intro A hA
      simp_all [Set.mem_map]
      <;>
      (try simp_all [chainTree, List.isChain_map])
      <;>
      (try aesop)
      <;>
      (try
        {
          use A
          <;>
          simp_all [chainTree, List.isChain_map]
          <;>
          aesop
        })
    -- Use the mapping to show that the winning set in the extended tree is also winning
    have h₅ : S.pre.map (extend hWV).IsWinning (G := interGame W PO) := by
      -- Use the fact that the mapping preserves the winning property
      have h₆ : S.pre.IsWinning (G := interGame V PO) := h₃
      -- Use the fact that the mapping preserves the winning property
      have h₇ : ∀ (A : List V), A ∈ S.pre → (⋂ n, (A.map (Set.inclusion hWV)).1 n) ∈ PO ↔ (⋂ n, A.1 n) ∈ PO := by
        intro A hA
        simp [List.map_map]
        <;>
        aesop
      -- Use the fact that the mapping preserves the winning property
      have h₈ : S.pre.map (extend hWV).IsWinning (G := interGame W PO) := by
        -- Use the fact that the mapping preserves the winning property
        simpa [interGame, chainTree, List.isChain_map] using h₆
      exact h₈
    exact h₅
  exact h₂
