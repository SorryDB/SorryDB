      "\n  have h : (volume.restrict (Ici 1)).ENNReal.toReal < +∞ := by\n    -- Prove that the measure of the set Ici 1 is finite.\n    have h₁ : volume.restrict (Ici 1) = volume.restrict (Ici 1) := rfl\n    have h₂ : (volume.restrict (Ici (1 : ℝ)) : Measure ℝ) = volume.restrict (Ici (1 : ℝ)) := rfl\n    -- Use the fact that the measure of a bounded interval is finite.\n    have h₃ : (volume.restrict (Ici (1 : ℝ))).toReal < +∞ := by\n      have h₄ : (volume.restrict (Ici (1 : ℝ))).toReal = ENNReal.toReal (volume (Ici (1 : ℝ))) := by\n        simp [Measure.restrict_apply]\n      rw [h₄]\n      have h₅ : volume (Ici (1 : ℝ)) = ∞ := by\n        -- The measure of [1, ∞) is infinite.\n        have h₆ : volume (Ici (1 : ℝ)) = ∞ := by\n          -- Use the fact that the Lebesgue measure of an unbounded interval is infinite.\n          have h₇ : volume (Ici (1 : ℝ)) = ∞ := by\n            -- Prove that the measure is infinite by contradiction.\n            have h₈ : ∀ (n : ℕ), (n : ℝ) ≥ 0 := by intro n; exact by positivity\n            have h₉ : ∀ (n : ℕ), (n : ℝ) + 1 ≥ (1 : ℝ) := by\n              intro n\n              have h₁₀ : (n : ℝ) ≥ 0 := by positivity\n              linarith\n            -- Use the fact that the measure of [1, ∞) is infinite.\n            have h₁₀ : volume (Ici (1 : ℝ)) = ∞ := by\n              -- Use the fact that the measure of [1, ∞) is infinite.\n              have h₁₁ : ∀ (n : ℕ), (n : ℝ) + 1 ≥ (1 : ℝ) := by\n                intro n\n                have h₁₂ : (n : ℝ) ≥ 0 := by positivity\n                linarith\n              -- Use the fact that the measure of [1, ∞) is infinite.\n              have h₁₂ : volume (Ici (1 : ℝ)) = ∞ := by\n                -- Use the fact that the measure of [1, ∞) is infinite.\n                have h₁₃ : ∀ (n : ℕ), (n : ℝ) + 1 ≥ (1 : ℝ) := by\n                  intro n\n                  have h₁₄ : (n : ℝ) ≥ 0 := by positivity\n                  linarith\n                -- Use the fact that the measure of [1