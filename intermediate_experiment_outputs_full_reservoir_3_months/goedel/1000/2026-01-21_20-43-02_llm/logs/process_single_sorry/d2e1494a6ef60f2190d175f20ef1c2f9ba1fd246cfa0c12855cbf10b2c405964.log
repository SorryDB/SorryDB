theorem Φ₆_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₆ r)
    (Ici (1 : ℝ)) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₆_contDiffOn.continuousOn measurableSet_Ici, ?_⟩
  have h₁ : HasFiniteIntegral (Φ₆ r) (volume.restrict (Ici 1)) := by
    have h₂ : ∀ x : ℝ, x ∈ Set.Ici 1 → (Φ₆ r x : ℝ) = (r : ℝ) / (x : ℝ) ^ 3 := by
      intro x hx
      simp [hx, Φ₆_def, hr]
      <;>
      ring_nf
      <;>
      field_simp [pow_ne_zero]
      <;>
      ring_nf
      <;>
      norm_num
    have h₃ : HasFiniteIntegral (fun x : ℝ => (r : ℝ) / (x : ℝ) ^ 3) (volume.restrict (Ici 1)) := by
      -- Use the fact that the integral of 1/x^3 from 1 to infinity is finite
      have h₄ : HasFiniteIntegral (fun x : ℝ => (1 : ℝ) / (x : ℝ) ^ 3) (volume.restrict (Set.Ici 1)) := by
        -- Prove that the integral of 1/x^3 from 1 to infinity is finite
        have h₅ : HasFiniteIntegral (fun x : ℝ => (1 : ℝ) / (x : ℝ) ^ 3) (volume.restrict (Set.Ici 1)) := by
          -- Use the fact that the integral of 1/x^3 from 1 to infinity is finite
          convert hasFiniteIntegral_comp_mul_left (fun x => (1 : ℝ) / x ^ 3) (by norm_num) using 1
          <;>
          simp [div_eq_mul_inv]
          <;>
          congr 1 <;> ext x <;> ring_nf <;> field_simp <;> ring_nf
          <;>
          norm_num
          <;>
          simp_all [Set.Ici, le_of_lt]
          <;>
          linarith
        exact h₅
      -- Multiply by r to get the integral of r/x^3
      have h₆ : HasFiniteIntegral (fun x : ℝ => (r : ℝ) / (x : ℝ) ^ 3) (volume.restrict (Set.Ici 1)) := by
        convert HasFiniteIntegral.const_mul r h₄ using 1
        <;>
        simp [div_eq_mul_inv]
        <;>
        congr 1 <;> ext x <;> ring_nf <;> field_simp <;> ring_nf
        <;>
        norm_num
        <;>
        simp_all [Set.Ici, le_of_lt]
        <;>
        linarith
      exact h₆
    -- Use the fact that Φ₆ r x = r / x^3 for x ≥ 1 to conclude the proof
    have h₇ : HasFiniteIntegral (Φ₆ r) (volume.restrict (Ici 1)) := by
      have h₈ : (Φ₆ r) =ᵐ[volume.restrict (Set.Ici 1)] (fun x : ℝ => (r : ℝ) / (x : ℝ) ^ 3) := by
        filter_upwards [self_mem_ae_restrict] with x hx using by
          have h₉ : x ∈ Set.Ici 1 := by simpa using hx
          rw [h₂ x h₉]
      have h₉ : HasFiniteIntegral (fun x : ℝ => (r : ℝ) / (x : ℝ) ^ 3) (volume.restrict (Set.Ici 1)) := h₃
      have h₁₀ : HasFiniteIntegral (Φ₆ r) (volume.restrict (Set.Ici 1)) := by
        apply HasFiniteIntegral.congr_ae h₉ h₈.symm
      exact h₁₀
    exact h₇
  exact h₁
