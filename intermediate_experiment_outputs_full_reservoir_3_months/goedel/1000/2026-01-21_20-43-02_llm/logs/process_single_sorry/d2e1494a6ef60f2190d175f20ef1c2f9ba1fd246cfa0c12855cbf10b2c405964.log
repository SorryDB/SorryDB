      "\n  have h : HasFiniteIntegral (Φ₆ r) (volume.restrict (Ici 1)) := by\n    -- Use the fact that the function is continuous and can be bounded by a decaying exponential\n    have h₁ : ContinuousOn (Φ₆ r) (Set.Ici 1) := Φ₆_contDiffOn.continuousOn\n    -- Use the fact that the function decays sufficiently fast to ensure integrability\n    have h₂ : ∀ (x : ℝ), x ≥ 1 → |(Φ₆ r) x| ≤ (1 / x) ^ 2 := by\n      intro x hx\n      have h₃ : 0 ≤ r := hr\n      have h₄ : x ≥ 1 := hx\n      have h₅ : (Φ₆ r) x = (1 / x : ℝ) ^ (6 : ℝ) * (Real.exp (-r * x) : ℝ) := by\n        -- This is a placeholder for the actual definition of Φ₆ r x\n        simp [Φ₆, Real.exp_neg, pow_two]\n        <;> field_simp [h₄]\n        <;> ring_nf\n        <;> norm_num\n        <;> linarith\n      rw [h₅]\n      have h₆ : (1 / x : ℝ) ^ (6 : ℝ) ≥ 0 := by positivity\n      have h₇ : Real.exp (-r * x) ≤ 1 := by\n        apply Real.exp_le_one_iff.mpr\n        have h₈ : -r * x ≤ 0 := by\n          have h₉ : r ≥ 0 := hr\n          have h₁₀ : x ≥ 1 := hx\n          nlinarith\n        linarith\n      have h₈ : (1 / x : ℝ) ^ (6 : ℝ) * Real.exp (-r * x) ≤ (1 / x : ℝ) ^ (6 : ℝ) := by\n        have h₉ : 0 ≤ (1 / x : ℝ) ^ (6 : ℝ) := by positivity\n        nlinarith\n      have h₉ : (1 / x : ℝ) ^ (6 : ℝ) ≤ (1 / x : ℝ) ^ 2 := by\n        have h₁₀ : (1 : ℝ) / x ≤ 1 := by\n          have h₁₁ : x ≥ 1 := hx\n          have h₁₂ : (1 : ℝ) / x ≤ 1 := by\n            rw [div_le_iff (by positivity)]\n            nlinarith\n          exact h₁₂\n        have h₁₁ : (1 : ℝ) / x ≥ 0 := by positivity\n        have h₁₂ : (1 : ℝ) / x ≤ 1 := h₁₀\n        have h₁₃ : (6 : ℝ) ≥ 2 := by norm_num\n        have h₁₄ : (1 / x : ℝ) ^ (6 : ℝ) ≤ (1 / x : ℝ) ^ (2 : ℝ) := by\n          -- Use the fact that the function x ↦ x^a is decreasing for 0 ≤ x ≤ 1 and a ≥ 0\n          exact Real.rpow_le_rpow_of_exponent_ge (by positivity) (by linarith) (by norm_num)\n        simpa using h₁₄\n      calc\n        |(1 / x : ℝ) ^ (6 : ℝ) * Real.exp (-r * x)