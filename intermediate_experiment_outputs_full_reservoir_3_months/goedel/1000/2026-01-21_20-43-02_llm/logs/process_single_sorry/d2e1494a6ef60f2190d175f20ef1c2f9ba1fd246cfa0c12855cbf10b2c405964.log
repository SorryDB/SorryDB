      "\n  have h₁ : HasFiniteIntegral (fun x : ℝ => (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) * Real.exp (-(x + r) : ℝ))) (volume.restrict (Ici 1)) := by\n    have h₂ : HasFiniteIntegral (fun x : ℝ => (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) * Real.exp (-(x + r) : ℝ))) (volume.restrict (Ici 1)) := by\n      -- Use the fact that the function is dominated by an integrable function\n      have h₃ : ∀ x : ℝ, x ∈ Set.Ici 1 → (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) * Real.exp (-(x + r) : ℝ)) ≤ (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ) := by\n        intro x hx\n        have h₄ : Real.exp (-(x + r) : ℝ) ≤ 1 := by\n          have h₅ : -(x + r : ℝ) ≤ 0 := by\n            have h₆ : x ≥ 1 := by exact hx\n            linarith\n          have h₇ : Real.exp (-(x + r) : ℝ) ≤ Real.exp 0 := Real.exp_le_exp.mpr h₅\n          have h₈ : Real.exp 0 = (1 : ℝ) := Real.exp_zero\n          linarith\n        have h₉ : (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) * Real.exp (-(x + r) : ℝ)) ≤ (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ) := by\n          have h₁₀ : Real.exp (-x - r) ≥ 0 := Real.exp_nonneg _\n          have h₁₁ : (4 * Real.pi * x : ℝ) ≥ 0 := by positivity\n          nlinarith\n        exact h₉\n      -- Show that the dominating function is integrable\n      have h₄ : HasFiniteIntegral (fun x : ℝ => (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ)) (volume.restrict (Ici 1)) := by\n        have h₅ : HasFiniteIntegral (fun x : ℝ => (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ)) (volume.restrict (Ici 1)) := by\n          -- Use the fact that the function decays exponentially\n          have h₆ : IntegrableOn (fun x : ℝ => (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ)) (Set.Ici 1) volume := by\n            -- Prove integrability using comparison\n            have h₇ : ∀ x : ℝ, x ∈ Set.Ici 1 → (4 * Real.pi * x : ℝ) * (Real.exp (-x - r) : ℝ) ≤ (4 * Real.pi * x : ℝ) * Real.exp (-x : ℝ) := by\n              intro x hx\n              have h₈ : Real.exp (-x - r : ℝ) ≤ Real