n (1 : ℝ)..∞, (1 : ℝ) / x ^ 2 := by\n                congr\n                ext x\n                field_simp [pow_two]\n                <;> ring_nf\n              rw [h₁₀]\n              -- Use the fundamental theorem of calculus to compute the integral\n              have h₁₁ : ∫ (x : ℝ) in (1 : ℝ)..∞, (1 : ℝ) / x ^ 2 = 1 := by\n                -- Use the fundamental theorem of calculus\n                have h₁₂ : ∫ (x : ℝ) in (1 : ℝ)..∞, (1 : ℝ) / x ^ 2 = 1 := by\n                  -- Use the fundamental theorem of calculus\n                  norm_num [integral_one_div_pow]\n                  <;>\n                  simp_all [div_eq_mul_inv]\n                  <;>\n                  norm_num\n                  <;>\n                  linarith\n                exact h₁₂\n              rw [h₁₁]\n            rw [h₉]\n          rw [h₇]\n          <;> norm_num\n        -- Use the fact that the integral of 1/x^2 from 1 to infinity is finite to conclude\n        have h₈ : HasFiniteIntegral (fun x : ℝ => (1 / x : ℝ) ^ 2) (volume.restrict (Ici 1)) := by\n          -- Use the fact that the integral of 1/x^2 from 1 to infinity is finite\n          refine' (hasFiniteIntegral_iff_integrableOn.mp _)\n          -- Use the fact that the function is integrable on [1, ∞)\n          apply integrableOn_Ici_of measurableSet_Ici\n          <;>\n          (try norm_num) <;>\n          (try simp_all [div_eq_mul_inv]) <;>\n          (try norm_num) <;>\n          (try linarith)\n          <;>\n          (try\n            {\n              -- Use the fact that the function is bounded by 1/x^2\n              have h₉ : ∀ (x : ℝ), x ≥ 1 → |(1 / x : ℝ) ^ 2| ≤ (1 / x : ℝ) ^ 2 := by\n                intro x hx\n                have h₁₀ : 0 ≤ (1 / x : ℝ) ^ 2 := by positivity\n                rw [abs_of_nonneg h₁₀]\n              -- Use the fact that the integral of 1/x^2 from 1 to infinity is finite\n              have h₁₀ : ∫⁻ (x : ℝ) in Ici 1, (1 / x : ℝ) ^ 2 < ∞ := by\n                -- Use the 