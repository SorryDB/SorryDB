lemma IsBernoulliOn.inter (hX : IsBernoulliOn X u p P) (hY : IsBernoulliOn Y u q P) :
    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  aemeasurable := by
    have h₁ : AEMeasurable (fun ω => X ω) P := hX.2
    have h₂ : AEMeasurable (fun ω => Y ω) P := hY.2
    have h₃ : AEMeasurable (fun ω => X ω ∩ Y ω) P := by
      let f : Ω → Set ι × Set ι := fun ω => (X ω, Y ω)
      have h₄ : AEMeasurable f P := h₁.prod_mk_aemeasurable h₂
      have h₅ : Continuous fun (p : Set ι × Set ι) => p.1 ∩ p.2 := continuous_inf
      have h₆ : AEMeasurable (fun ω => (f ω).1 ∩ (f ω).2) P := h₄.comp h₅.continuous.measurable
      simpa [f] using h₆
    exact h₃
  <;> sorry
