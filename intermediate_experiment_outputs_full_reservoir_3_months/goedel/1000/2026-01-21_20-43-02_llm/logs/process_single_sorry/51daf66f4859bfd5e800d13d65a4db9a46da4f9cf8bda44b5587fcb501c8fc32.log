    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  map_eq := sorry
  aemeasurable := by
    have h₁ : AEMeasurable X P := hX.aemeasurable
    have h₂ : AEMeasurable Y P := hY.aemeasurable
    have h₃ : AEMeasurable (fun ω => X ω ∩ Y ω) P := by
