  map_eq := sorry
  aemeasurable := by
    have h₁ : AEMeasurable X P := hX.measurable
    have h₂ : AEMeasurable Y P := hY.measurable
    have h₃ : AEMeasurable (fun ω ↦ X ω ∩ Y ω) P := by
      apply AEMeasurable.congr (h₁.inter h₂) (ae_restrict_mem)
      funext ω
      <;> simp [Set.inter_comm]
      <;> aesop
