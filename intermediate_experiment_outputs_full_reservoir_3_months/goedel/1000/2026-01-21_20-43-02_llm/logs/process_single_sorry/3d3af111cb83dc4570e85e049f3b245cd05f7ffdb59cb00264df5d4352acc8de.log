```lean
lemma IsMatching.disjoint_inter_of_isCycleGraph_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
  have h₁ : Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
    rw [Set.disjoint_iff]
    intro e he
    have h₂ : e ∈ E(C) := by
      simp only [Set.mem_inter_iff] at he
      exact he.1
    have h₃ : e ∈ M := by
      simp only [Set.mem_inter_iff] at he
      exact he.2
    have h₄ : e ∈ E(C) := by
      simp only [Set.mem_inter_iff] at he ⊢
      exact he.1
    have h₅ : e ∈ M := by
      simp only [Set.mem_inter_iff] at he ⊢
      exact he.2
    have h₆ : C ≤ hM.restrict₂ hM' := hCG
    have h₇ : e ∈ E(C) := h₂
    have h₈ : e ∈ E(hM.restrict₂ hM') := h₆.coe_subgraph.edge_subset h₇
    have h₉ : e ∈ E(G ↾ (M ∆ M')) := by
      simpa [IsMatching.restrict₂, Subgraph.coe_subgraph] using h₈
    have h₁₀ : e ∈ (M ∆ M') := by
      simpa [E, Subgraph, dif_eq_left] using h₉
    have h₁₁ : e ∈ M ∪ M' := by
      simp only [Set.mem_union, Set.mem_diff] at h₁₀ ⊢
      tauto
    have h₁₂ : e ∉ M' := by
