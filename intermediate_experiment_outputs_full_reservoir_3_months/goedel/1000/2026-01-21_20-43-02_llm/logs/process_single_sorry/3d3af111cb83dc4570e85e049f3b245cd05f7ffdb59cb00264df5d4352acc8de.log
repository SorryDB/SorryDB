  -- Since C is a cycle, each vertex has exactly two edges.\n              have h₁₃ : C.IsCycleGraph := hC\n              have h₁₄ : ∀ (v : α), v ∈ V(C) → (E(C, v) : Finset β).card = 2 := by\n                intro v hv\n                have h₁₅ := h₁₃.two_degree v hv\n                simp_all [E]\n                <;>\n                (try decide) <;>\n                (try omega)\n              have h₁₅ := h₁₄ v h₁₀\n              simp_all [E]\n              <;>\n              (try decide) <;>\n              (try omega)\n            have h₁₆ : (E(C, v) : Finset β).card % 2 = 0 := by\n              omega\n            exact h₁₆\n          exact h₁₁\n        -- Use the fact that C is a cycle graph and a component of the restriction of G to M ∆ M'\n        -- to show that the intersections of E(C) with M and M' have the same cardinality.\n        simp_all [Set.encard_eq_zero]\n        <;>\n        (try decide) <;>\n        (try omega)\n      exact h₆\n    exact h₅\n  exact h₁",
      "\n  let H := hM.restrict₂ hM'\n  have hV : V(C) ⊆ V(H) := by\n    have hV' : V(C) ⊆ V(H) := by\n      have hV'' : C ≤ H := hCG.le _\n      exact hV''.mono\n    exact hV'\n  have hE : E(C) ⊆ E(H) := by\n    have hE' : E(C) ⊆ E(H) := by\n      have hE'' : C ≤ H := hCG.le _\n      exact hE''.mono\n    exact hE'\n  have hCube : Cube M M' C := by\n    refine' ⟨hM, hM', hC, _, _, _⟩\n    <;> simp_all [IsMatching.restrict₂, Set.ext_iff]\n    <;>\n      (try { aesop }) <;>\n      (try {\n        intros\n        simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n        <;>\n          (try { omega }) <;>\n          (try { aesop }) <;>\n          (try {\n            simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n            <;> aesop\n          })\n      })\n    <;>\n      (try { aesop }) <;>\n      (try {\n        intros\n        simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n        <;>\n          (try { omega }) <;>\n          (try { aesop }) <;>\n          (try {\n            simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n            <;> aesop\n          })\n      })\n  have hCard : (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    apply hCube.cardMatchings\n    <;>\n      (try { simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff] }) <;>\n      (try { aesop }) <;>\n      (try {\n        intros\n        simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n        <;>\n          (try { omega }) <;>\n          (try { aesop }) <;>\n          (try {\n            simp_all [Set.mem_inter_iff, Set.mem_symmDiff, Set.mem_singleton_iff]\n            <;> aesop\n          })\n      })\n  exact hCard",
