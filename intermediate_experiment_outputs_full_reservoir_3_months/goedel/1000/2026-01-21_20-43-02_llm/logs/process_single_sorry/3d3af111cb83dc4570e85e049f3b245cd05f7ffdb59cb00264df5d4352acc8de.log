    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  have h₁ : (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
    classical
    -- We use the fact that the graph is a cycle and the restrictions of the matchings to the cycle are complementary.
    -- This implies that the cardinalities of the intersections are equal.
