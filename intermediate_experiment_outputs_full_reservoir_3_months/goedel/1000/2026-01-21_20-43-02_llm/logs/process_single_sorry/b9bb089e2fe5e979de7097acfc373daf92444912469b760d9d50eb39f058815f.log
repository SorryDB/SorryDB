  left_inv := by
    intro x
    calc
      invFun (toFun x) = f.symm (g.symm (g (f x))) := rfl
      _ = f.symm (f x) := by
        simp [g.symm_apply_apply]
      _ = x := by
        simp [f.symm_apply_apply]
  right_inv := by
    intro x
    calc
      toFun (invFun x) = g (f (f.symm (g.symm x))) := rfl
      _ = g (g.symm x) := by
        simp [f.apply_symm_apply]
      _ = x := by
        simp [g.apply_symm_apply]
