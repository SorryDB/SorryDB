### Solution

```lean
def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Equiv.apply_symm_apply]
  right_inv := by
    intro x
    simp [Equiv.apply_symm_apply]
  map_add' := by
    intro x y
    rw [g.map_add (f x) (f y), add_assoc]
    <;> simp [f.map_add]
```
