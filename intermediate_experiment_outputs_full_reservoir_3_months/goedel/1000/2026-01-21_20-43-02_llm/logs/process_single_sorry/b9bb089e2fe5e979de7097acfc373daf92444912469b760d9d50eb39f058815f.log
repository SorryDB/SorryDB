def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [IsEquiv.left_inv]
    <;>
    simp_all [RingHom.map_add, AddMonoidHom.map_add]
    <;>
    ring_nf
    <;>
    simp_all [IsEquiv.left_inv]
    <;>
    aesop

  right_inv := by
    intro x
    simp [IsEquiv.right_inv]
    <;>
    simp_all [RingHom.map_add, AddMonoidHom.map_add]
    <;>
    ring_nf
    <;>
    simp_all [IsEquiv.right_inv]
    <;>
    aesop

  map_add' := by
    intro x y
    calc
      g (f (x + y)) = g (f x + f y) := by
        -- Use the fact that `f` is an additive homomorphism to distribute `f` over addition
        simp [MapAddHom.map_add, RingHom.map_add]
        <;>
        simp_all [RingHom.map_add, AddMonoidHom.map_add]
        <;>
        aesop
      _ = g (f x) + g (f y) := by
        -- Use the fact that `g` is an additive homomorphism to distribute `g` over addition
        simp [MapAddHom.map_add, RingHom.map_add]
        <;>
        simp_all [RingHom.map_add, AddMonoidHom.map_add]
        <;>
        aesop
