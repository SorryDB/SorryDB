```lean
/- In class we mentioned that if Disjunction could eliminate to
types, this would lead to a contradiction. Proof this.
Recall: `rfl` can prove that any two proofs of the same proposition are equal. -/
inductive Disjunction (P Q : Prop) : Prop where
  | left  : P → Disjunction P Q
  | right : Q → Disjunction P Q

open Disjunction
example
    (rec : ∀ (P Q : Prop) (motive : Disjunction P Q → Type)
      (h_left : ∀ hp : P, motive (left hp)) (h_right : ∀ hq : Q, motive (right hq))
      (h : Disjunction P Q), motive h)
    (comp_left : ∀ P Q motive h_left h_right (hp : P),
      rec P Q motive h_left h_right (left hp) = h_left hp)
    (comp_right : ∀ P Q motive h_left h_right (hq : Q),
      rec P Q motive h_left h_right (right hq) = h_right hq) : False := by
  have h₁ : False := by
    classical
    -- Define a proposition that is always false
    let P : Prop := False
    -- Define a proposition that is always true
    let Q : Prop := True
    -- Consider the disjunction P ∨ Q, which is False ∨ True ≡ True
    -- We will use the given recursor to derive a contradiction
    have h₂ : Disjunction P Q := by
      -- Since Q is True, we can use the right constructor of Disjunction
      exact Disjunction.right (by trivial)
    -- Define a motive that maps any proof of Disjunction P Q to the type P
    -- This is a type that is always empty since P is False
    have h₃ := rec P Q (fun _ => P) (fun hp => hp) (fun hq => by
      -- This branch is unreachable because P is False
      exfalso
      exact hq)
      h₂
    -- Since h₃ is a term of type P, which is False, we have a contradiction
    exact h₃
  exact h₁
