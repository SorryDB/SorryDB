lemma intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · intro h
    -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that the norm of r • f is bounded by the norm of r times the norm of f.
      have h₂ : ∀ᵐ (x : ℝ) ∂μ.restrict (Set.Ioc a b), ‖r • f x‖ ≤ ‖r‖ * ‖f x‖ := by
        filter_upwards [ae_restrict_mem] with x hx
        -- Use the property of the norm of a scalar multiple.
        have h₃ : ‖r • f x‖ = ‖r‖ * ‖f x‖ := by
          simp [norm_smul]
        linarith
      -- Use the fact that the integral of ‖f‖ is finite.
      have h₃ : IntervalIntegrable (fun x : ℝ => ‖f x‖) μ a b := by
        exact h.norm
      -- Use the boundedness of ‖r‖ and the fact that ‖r • f‖ ≤ ‖r‖ * ‖f‖ to conclude.
      have h₄ : IntervalIntegrable (fun x : ℝ => ‖r • f x‖) μ a b := by
        refine' IntervalIntegrable.of_norm _
        refine' (by
          -- Use the fact that ‖r‖ is constant and ‖f‖ is integrable.
          have h₅ : (fun x : ℝ => ‖r‖ * ‖f x‖) = (fun x : ℝ => ‖r‖ * ‖f x‖) := rfl
          have h₆ : IntervalIntegrable (fun x : ℝ => ‖r‖ * ‖f x‖) μ a b := by
            -- ‖r‖ is a constant and ‖f‖ is integrable.
            exact (h₃.const_mul ‖r‖)
          -- Use the fact that ‖r • f‖ ≤ ‖r‖ * ‖f‖.
          refine' h₆.of_ae_le h₂
          )
      -- Use the fact that the integral of ‖r • f‖ is finite to conclude that r • f is interval integrable.
      exact h₄.of_norm
    exact h₁
  · intro h
    -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
    have h₁ : IntervalIntegrable f μ a b := by
