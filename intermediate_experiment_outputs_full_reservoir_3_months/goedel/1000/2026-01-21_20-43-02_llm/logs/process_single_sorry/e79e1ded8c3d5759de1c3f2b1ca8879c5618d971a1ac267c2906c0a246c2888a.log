    have h₅ : g x = -x + 1 := by simp [g]
    have h₆ : (if x ≤ y then f x else g x) = -x + 1 := by rw [h₄, h₅]
    -- (if x ≤ y then f y else g y) = g y = -y + 1
    have h₇ : (if x ≤ y then f y else g y) = g y := by simp [h₃]
    have h₈ : g y = -y + 1 := by simp [g]
