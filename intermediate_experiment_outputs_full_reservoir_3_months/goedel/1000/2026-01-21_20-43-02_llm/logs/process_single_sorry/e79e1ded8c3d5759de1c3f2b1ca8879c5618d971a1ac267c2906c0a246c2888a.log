class InterestingQuestion extends AbstractQuestion {
    // Define the type of question here
    protected String _type;

    // Define the answer to the question
    protected String _answer;

    // Define the correctness status
    protected Boolean _correct;

    // Constructor for the question with type, answer, and correctness status
    constructor(String type, String answer, Boolean correct) {
        _type = type;
        _answer = answer;
        _correct = correct;
    }

    // Method to check if the answer is correct
    @override
    check_answer(String expected_answer) {
        if (_correct) {
            return _answer == expected_answer;
        } else {
            return false;
        }
    }

    // Method to get the type of the question
    get_type() {
        return _type;
    }

    // Method to get the answer to the question
    get_answer() {
        return _answer;
    }
}
