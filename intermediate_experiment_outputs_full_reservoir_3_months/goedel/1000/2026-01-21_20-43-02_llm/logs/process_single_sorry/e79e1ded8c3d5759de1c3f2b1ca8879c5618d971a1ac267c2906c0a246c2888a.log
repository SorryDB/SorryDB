    (if x ≤ y then f y else g y) < y := by
  intro h
  have h₁ : x < 1 := h.1
  have h₂ : y > 1 := h.2
  -- Case split based on x ≤ y
  by_cases h₃ : x ≤ y
  · -- Case 1: x ≤ y
    -- We need to show that (if x ≤ y then f x else g x) < y
    -- Since x ≤ y, (if x ≤ y then f x else g x) = f x = x
    -- Therefore, we need to show x < y
    have h₄ : (if x ≤ y then f x else g x) = f x := by simp [h₃]
    have h₅ : f x = x := by simp [f]
    have h₆ : (if x ≤ y then f x else g x) = x := by rw [h₄, h₅]
    -- Since x < 1 and y > 1, we have x < y
    have h₇ : x < y := by linarith
    -- Therefore, (if x ≤ y then f x else g x) < y
    have h₈ : (if x ≤ y then f x else g x) < y := by
      rw [h₆]
      linarith
    -- We can directly use this to conclude the proof
    exact Or.inl h₈
  · -- Case 2: x > y
