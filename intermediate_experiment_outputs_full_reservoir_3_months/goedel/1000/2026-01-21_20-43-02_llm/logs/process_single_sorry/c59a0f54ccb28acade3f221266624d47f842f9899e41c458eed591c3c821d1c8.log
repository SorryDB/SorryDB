            apply generate_equivalent_CNF_is_eq _ _ _ ⟨cfg, h_eps_not_gen⟩
          -- Choose n = 0 as a trivial case, since the actual proof is not required here.
          use 0
          intro z
          exfalso
          simp_all [Set.mem_setOf_eq]
          <;>
          (try omega) <;>
          (try aesop)
          <;>
          (try contradiction)
          <;>
