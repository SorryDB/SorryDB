        have z₂_mem := z₂_mem.left
        -- Erlange die Existenz einer Ableitung nach z₂ in cfg
        unfold ContextFreeGrammar.GeneratedLanguage at z₂_mem
        apply Nonempty.elim_to_inhabited at z₂_mem
        apply z₂_mem
        case f =>
        intro h_exists_deriv_z₂
