    have h₁ : eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal := by sorry
    exact h₁
  have h_final : eLpNorm (T f) (p : ℝ≥0∞) ν ≤ (4 * c / p) * eLorentzNorm f p 1 μ := by sorry
  exact ⟨h_final, by simp [p]⟩
