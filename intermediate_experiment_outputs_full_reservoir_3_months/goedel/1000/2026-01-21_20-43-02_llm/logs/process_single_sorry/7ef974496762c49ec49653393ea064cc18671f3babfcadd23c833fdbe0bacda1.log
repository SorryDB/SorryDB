```lean
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  have h₁ : UniformContinuous f := by
    -- Use the fact that for any ε > 0, the set of ε-almost periods is relatively dense
    -- to show that f is uniformly continuous.
    refine' Metric.uniformContinuous_iff.mpr fun ε εpos => _
    -- For each ε > 0, find a δ > 0 such that for all x, y, if |x - y| < δ then |f(x) - f(y)| < ε
    have h₂ : IsRelDense {t | ∀ x, ‖f (x + t) - f x‖ ≤ ε} := by
      have h₃ : 0 < ε := εpos
      -- Use the assumption that the set of ε-almost periods is relatively dense
      have h₄ : IsRelDense {t | IsLinftyAP ε t f} := hf ε εpos
      -- The set {t | ∀ x, ‖f (x + t) - f x‖ ≤ ε} is the same as {t | IsLinftyAP ε t f}
      simpa [IsLinftyAP] using h₄
    -- Obtain l such that the set is relatively dense with respect to l
    obtain ⟨l, hl⟩ := h₂
    -- Use the relative density to find a suitable δ
    have h₃ : 0 < l := by
      have h₄ : IsRelDenseWith {t | ∀ x, ‖f (x + t) - f x‖ ≤ ε} l := hl
      exact IsRelDenseWith.pos h₄
    -- We will use δ = l as our candidate
    use l
    constructor
    · -- Show that δ > 0
      exact h₃
    · -- Show that for all x, y, if |x - y| < δ then |f(x) - f(y)| < ε
      intro x y hxy
      -- Use the fact that the set of ε-almost periods is relatively dense
      have h₄ : IsRelDenseWith {t | ∀ x, ‖f (x + t) - f x‖ ≤ ε} l := hl
      -- Obtain t in the interval [0, l) such that x - y + t is in the set
      obtain ⟨t, ⟨ht₀, ht₁⟩, ht₂⟩ := h₄ (x - y)
      -- Use the property of the set to bound the difference
      have h₅ : ∀ x, ‖f (x + t) - f x‖ ≤ ε := ht₂
      have h₆ : ‖f (y + t) - f y‖ ≤ ε := h₅ y
      have h₇ : ‖f (x + t) - f x‖ ≤ ε := h₅ x
      -- Use the triangle inequality to bound |f(x) - f(y)|
      have h₈ : ‖f x - f y‖ ≤ ε := by
        calc
          ‖f x - f y‖ = ‖(f (x + t) - f y) - (f (x + t) - f x)‖ := by ring_nf
          _ ≤ ‖f (x + t) - f y‖ + ‖f (x + t) - f x‖ := norm_sub_le _ _
          _ = ‖f (y + t) - f y‖ + ‖f (x + t) - f x‖ := by
            have h₉ : x + t = y + t + (x - y) := by ring
            have h₁₀ : f (x + t) = f (y + t + (x - y)) := by rw [h₉]
            rw [h₁₀]
            have h₁₁ : ‖f (y + t + (x - y)) - f y‖ = ‖f (y + t) - f y‖ := by
              have h₁₂ : y + t + (x - y) = y + t + (x - y) := rfl
              have h₁₃ : ‖f (y + t + (x - y)) - f y‖ = ‖f (y + t + (x - y)) - f y‖ := rfl
              -- Use the fact that the set is relatively dense to get the bound
              have h₁₄ : ‖f (y + t + (x - y)) - f y‖ = ‖f (y + t) - f y‖ := by
                have h₁₅ : y + t + (x - y) = (y + t) + (x - y) := by ring
                have h₁₆ : x - y = t' := by sorry
                sorry
              exact h₁₄
            rw [h₁₁]
            <;> ring_nf
          _ ≤ ε + ε := by
            gcongr <;>
            (try norm_num) <;>
            (try linarith) <;>
            (try assumption) <;>
            (try simp_all [IsLinftyAP]) <;>
            (try linarith)
          _ = 2 * ε := by ring
          _ ≤ ε + ε := by linarith
          _ ≤ ε + ε := by linarith
          _ ≤ ε := by
            -- Use the fact that 2 * ε ≤ ε is false to get a contradiction
            have h₉ : False := by
              have h₁₀ : 0 < ε := εpos
              linarith
            cases h₉
      -- Convert the bound to the required form
      calc
        dist (f x) (f y) = ‖f x - f y‖ := by simp [Complex.dist_eq]
        _ ≤ ε := h₈
        _ < ε := by linarith
  exact h₁
