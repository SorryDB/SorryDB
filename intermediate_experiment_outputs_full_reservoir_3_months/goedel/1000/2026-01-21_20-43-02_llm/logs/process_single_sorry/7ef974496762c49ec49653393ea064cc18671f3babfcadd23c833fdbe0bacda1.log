lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  have h₁ : ∀ (ε : ℝ), 0 < ε → (∃ l > 0, ∀ x, ∃ y ∈ Set.Ico 0 l, x + y ∈ {t | IsLinftyAP ε t f}) := by
    intro ε hε
    have h₂ : IsRelDense {t | IsLinftyAP ε t f} := hf (by simpa using hε)
    obtain ⟨l, hl⟩ := h₂
    have h₃ : 0 < l := IsRelDenseWith.pos hl
    refine' ⟨l, h₃, _⟩
    intro x
    have h₄ : ∃ y ∈ Set.Ico 0 l, x + y ∈ {t | IsLinftyAP ε t f} := hl x
    exact h₄
  -- Use the fact that for any ε > 0, there exists a relatively dense set of ε-almost periods to show uniform continuity.
  have h₂ : UniformContinuous f := by
    have h₃ : UniformContinuous f := by
      -- Use the definition of uniform continuity and the properties of f to complete the proof.
      have h₄ : ∀ ε : ℝ, 0 < ε → (∃ δ : ℝ, 0 < δ ∧ ∀ ⦃x y : ℝ⦄, |x - y| < δ → ‖f x - f y‖ < ε) := by
        intro ε hε
        -- Use the given property of f to find δ.
        have h₅ : ∃ l > 0, ∀ x, ∃ y ∈ Set.Ico 0 l, x + y ∈ {t | IsLinftyAP (ε / 2) t f} := by
          have h₆ := h₁ (ε / 2) (by linarith)
          exact h₆
        obtain ⟨l, hl_pos, hl⟩ := h₅
        -- Use the δ = l / 2 to satisfy the uniform continuity condition.
        use l / 2
        constructor
        · linarith
        · intro x y hxy
          -- Use the triangle inequality and the given property to bound the difference.
          have h₆ : ∃ y ∈ Set.Ico 0 l, y ∈ {t | IsLinftyAP (ε / 2) t f} := hl 0
          obtain ⟨y, hy, hy'⟩ := h₆
          have h₇ : IsLinftyAP (ε / 2) y f := hy'
          have h₈ : ∀ x, ‖f (x + y) - f x‖ ≤ ε / 2 := by simpa [IsLinftyAP] using h₇
          -- Use the fact that y is an ε/2-almost period to bound the difference.
          have h₉ : ‖f x - f y‖ ≤ ε / 2 := by
            have h₁₀ : ‖f (y + (x - y)) - f y‖ ≤ ε / 2 := h₈ y
            have h₁₁ : f (y + (x - y)) = f x := by
              ring_nf
              <;> simp [sub_eq_add_neg]
              <;> ring_nf
            rw [h₁₁] at h₁₀
            linarith
          have h₁₀ : ‖f y - f (x + y)‖ ≤ ε / 2 := by
            have h₁₁ : ‖f ((x + y) + (-y)) - f (x + y)‖ ≤ ε / 2 := h₈ (x + y)
            have h₁₂ : f ((x + y) + (-y)) = f x := by
              ring_nf
              <;> simp [sub_eq_add_neg]
              <;> ring_nf
            rw [h₁₂] at h₁₁
            have h₁₃ : ‖f x - f (x + y)‖ ≤ ε / 2 := by simpa using h₁₁
            have h₁₄ : ‖f y - f (x + y)‖ = ‖f (x + y) - f y‖ := by
              rw [norm_sub_rev]
            have h₁₅ : ‖f (x + y) - f y‖ ≤ ε / 2 := by
              have h₁₆ : ‖f (y + (x - y)) - f y‖ ≤ ε / 2 := h₈ y
              have h₁₇ : f (y + (x - y)) = f x := by
                ring_nf
                <;> simp [sub_eq_add_neg]
                <;> ring_nf
              rw [h₁₇] at h₁₆
              have h₁₈ : ‖f x - f y‖ ≤ ε / 2 := by simpa using h₁₆
              calc
                ‖f (x + y) - f y‖ = ‖f (x + y) - f y‖ := rfl
                _ ≤ ‖f (x + y) - f y‖ := le_refl _
                _ ≤ ε / 2 := by
                  have h₁₉ : ‖f (x + y) - f y‖ ≤ ε / 2 := by
                    have h₂₀ := h₈ (x + y)
                    have h₂₁ := h₈ y
                    have h₂₂ := h₈ x
                    have h₂₃ := h₈ 0
                    simp_all [IsLinftyAP]
                    <;> linarith
                  linarith
            linarith
          -- Combine the inequalities to get the final result.
          have h₁₁ : ‖f x - f y‖ ≤ ε / 2 := h₉
          have h₁₂ : ‖f y - f (x + y)‖ ≤ ε / 2 := h₁₀
          calc
            ‖f x - f y‖ ≤ ε / 2 := h₉
            _ < ε := by linarith
          <;>
          simp_all [abs_lt]
          <;>
          linarith
      -- Use the δ to prove uniform continuity.
      have h₅ : UniformContinuous f := by
        refine' Metric.uniformContinuous_iff.mpr _
        intro ε hε
        obtain ⟨δ, hδ_pos, hδ⟩ := h₄ ε hε
        refine' ⟨δ, hδ_pos, _⟩
        intro x y hxy
        have h₆ : ‖f x - f y‖ < ε := hδ hxy
        simpa [dist_eq_norm] using h₆
      exact h₅
    exact h₃
  exact h₂
