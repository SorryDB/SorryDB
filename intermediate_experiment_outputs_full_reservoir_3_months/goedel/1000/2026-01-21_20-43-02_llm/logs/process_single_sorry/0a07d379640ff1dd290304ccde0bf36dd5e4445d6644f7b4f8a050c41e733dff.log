      rfl
    -- Use the fact that the function is continuous and the interval is compact to show it is integrable
    have h₄ : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc 0 1)) := by
      refine' ContinuousOn.hasFiniteIntegral_of_locallyCompact _
      <;>
      (try simp_all [h₃]) <;>
      (try continuity) <;>
      (try
        {
          -- Show that the set Ioc 0 1 is locally compact
          apply IsLocallyCompact.of_forall_exists_isCompact_mem_nhds
          intro x hx
          have h₅ : x ∈ Set.Ioc (0 : ℝ) 1 := hx
          have h₆ : 0 < x := by linarith [h₅.1]
          have h₇ : x ≤ 1 := h₅.2
          -- Choose a compact interval containing x
          use IsCompact.Icc (x / 2) (x + (1 - x) / 2)
          constructor
          · -- Prove that the interval is compact
            exact isCompact_Icc
          · -- Prove that x is in the interval and the interval is a neighborhood of x
            constructor
            · -- x is in the interval
              constructor <;> nlinarith
            · -- The interval is a neighborhood of x
              have h₈ : x ∈ Set.Ioo (x / 2) (x + (1 - x) / 2) := by
                constructor <;> nlinarith
              have h₉ : Set.Ioo (x / 2) (x + (1 - x) / 2) ⊆ Set.Ioc (0 : ℝ) 1 := by
                intro y hy
                constructor
                · -- y > 0
                  linarith [hy.1]
                · -- y ≤ 1
                  linarith [hy.2]
              -- Use the fact that the interval is open and contained in Ioc 0 1
              filter_upwards [isOpen_Ioo.mem_nhds h₈] with y hy
              exact hy
