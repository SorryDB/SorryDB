      "\n  have h₁ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₂ r) (Icc 0 1) := Φ₂_contDiffOn.continuousOn\n    have h₃ : IsCompact (Icc 0 1) := isCompact_Icc\n    have h₄ : (Icc (0 : ℝ) 1).volume < ∞ := by\n      simp [Real.volume_Icc]\n      <;> norm_num\n      <;> linarith\n    -- Use the fact that the function is continuous on a compact set to deduce it is bounded\n    -- and thus has finite integral\n    have h₅ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) :=\n      (hasFiniteIntegral_of_continuousOn_of_isCompact (by continuity) h₃)\n    exact h₅\n  exact h₁",
      "\n  -- We use the fact that the volume of the interval is finite and the function is continuous to deduce the integral is finite.\n  refine' hasFiniteIntegral_of_hasFiniteIntegral_restrict_of_null (by\n    -- Use the fact that the function is continuous on [0, 1] and the interval has finite measure.\n    have h : ∃ (c : ℝ), ∀ (x : ℝ), x ∈ Icc (0 : ℝ) 1 → |Φ₂ r x| ≤ c := by\n      -- Since Φ₂ is continuous on [0, 1], it is bounded.\n      have h₁ : ContinuousOn (Φ₂ r) (Icc (0 : ℝ) 1) := Φ₂_contDiffOn.continuousOn\n      have h₂ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n      obtain ⟨c, hc⟩ := Metric.isCompact_iff_isClosed_bounded.mp h₂ |>.2\n      obtain ⟨d, hd⟩ := Metric.isCompact_iff_isClosed_bounded.mp (h₂.compact_image h₁) |>.2\n      refine' ⟨d, _⟩\n      intro x hx\n      have h₃ : (Φ₂ r x : ℝ) ∈ Set.Icc (-d : ℝ) d := by\n        have h₄ : (Φ₂ r x : ℝ) ∈ Set.Icc (-d : ℝ) d := by\n          have h₅ : (Φ₂ r x : ℝ) ∈ (h₁.image (Icc (0 : ℝ) 1)).closure := by\n            apply subset_closure\n            apply h₁.mem_image_of_mem\n            exact hx\n          have h₆ : (h₁.image (Icc (0 : ℝ) 1)).closure ⊆ Set.Icc (-d : ℝ) d :=\n            by\n              have h₇ : (h₁.image (Icc (0 : ℝ) 1)).closure ⊆ Set.Icc (-d : ℝ) d :=\n                Metric.closure_minimal (by\n                  -- Show that h₁.image (Icc (0 : ℝ) 1) is bounded by d\n                  have h₈ : ∀ y ∈ (h₁.image (Icc (0 : ℝ) 1)), |y| ≤ d := by\n                    intro y hy\n                    obtain ⟨x, hx, rfl⟩ := h₁.mem_image.mp hy\n                    have h₉ : |Φ₂ r x| < d := by\n                      have h₁₀ : (x : ℝ) ∈ Icc (0 : ℝ) 1 := hx\n                      have h₁₁ : |(Φ₂ r x : ℝ)| < d := by\n                        have h₁₂ := hd x hx\n                        simp_all [Real.dist_eq]\n                        <;> linarith\n                      exact h₁₁\n                    have h₁₀ : |y| < d := by\n                      simpa [abs_of_nonneg, abs_of_nonpos] using h₉\n                    linarith\n                  -- Use the fact that the set is bounded to show it is contained in Icc (-d) d\n                  intro y hy\n                  have h₁₁ : |y| ≤ d := by\n                    obtain ⟨x, hx, rfl⟩ := h₁.mem_image.mp hy\n                    have h₁₂ := hd x hx\n                    simp_all [Real.dist_eq]\n                    <;> linarith\n                  have h₁₃ : -d ≤ y := by\n                    linarith [abs_le.mp h₁₁]\n                  have h₁₄ : y ≤ d := by\n                    linarith [abs_le.mp h₁₁]\n                  exact ⟨h₁₃, h₁₄⟩\n                ) (by\n                  -- Show that Icc (-d) d is closed\n                  exact isClosed_Icc\n                )\n              exact h₇\n            exact h₆\n          have h₈ : (Φ₂ r x : ℝ) ∈ Set.Icc (-d : ℝ) d := by\n            apply h₆\n            apply h₅\n          exact h₈\n        exact h₄\n      have h₉ : |(Φ₂ r x : ℝ)| ≤ d := by\n        simp only [abs_le] at h₃ ⊢\n        constructor <;> linarith\n      exact h₉\n    obtain ⟨c, hc⟩ := h\n    -- Use the fact that the function is bounded to show that the integral is finite.\n    have h₁ : HasFiniteIntegral (fun x => (c : ℝ)) (volume.restrict (Set.Icc 0 1)) := by\n      -- The constant function has a finite integral over [0, 1].\n      have h₂ : HasFiniteIntegral (fun x => (c : ℝ)) (volume.restrict (Set.Icc 0 1)) := by\n        convert hasFiniteIntegral_const.volume_restrict (Set.Icc 0 1) using 1\n        <;> simp [volume_Icc]\n        <;> norm_num\n        <;> linarith\n      exact h₂\n    -- Use the fact that the function is bounded to show that the integral is finite.\n    have h₂ : HasFiniteIntegral (fun x => |Φ₂ r x|) (volume.restrict (Set.Icc 0 1)) := by\n      -- Use the fact that |Φ₂ r x| ≤ c to show that the integral is finite.\n      have h₃ : ∀ x ∈ (Set.Icc 0 1 : Set ℝ), |Φ₂ r x| ≤ (c : ℝ) := by\n        intro x hx\n        exact hc x hx\n      -- Use the fact that the function is bounded to show that the integral is finite.\n      have h₄ : HasFiniteIntegral (fun x => |Φ₂ r x|) (volume.restrict (Set.Icc 0 1)) := by\n        refine' HasFiniteIntegral.of_norm_bounded _ h₁ _\n        -- Use the fact that |Φ₂ r x| ≤ c to show that the integral is finite.\n        filter_upwards [self_mem_ae_restrict] with x hx using by\n          have h₅ : x ∈ (Set.Icc 0 1 : Set ℝ) := hx\n          have h₆ : |Φ₂ r x| ≤ (c : ℝ) := h₃ x h₅\n          calc\n            ‖(|Φ₂ r x| : ℝ)‖ = |Φ₂ r x| := by simp [norm_of_nonneg (abs_nonneg (Φ₂ r x))]\n            _ ≤ (c : ℝ) := h₆\n            _ = ‖(c : ℝ)‖ := by simp [norm_of_nonneg (by\n              -- Show that c is non-negative\n              have h₇ : ∀ (x : ℝ), x ∈ Icc (0 : ℝ) 1 → |Φ₂ r x| ≤ c := hc\n              have h₈ : (0 : ℝ) ∈ Icc (0 : ℝ) 1 := by\n                exact ⟨by linarith, by linarith⟩\n              have h₉ : |Φ₂ r 0| ≤ c := h₇ 0 h₈\n              have h₁₀ : 0 ≤ c := by\n                have h₁₁ : 0 ≤ |Φ₂ r 0| := abs_nonneg _\n                linarith\n              exact h₁₀\n            )]\n      exact h₄\n    -- Use the fact that the integral of |Φ₂ r x| is finite to show that the integral of Φ₂ r x is finite.\n    have h₃ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Set.Icc 0 1)) := by\n      have h₄ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Set.Icc 0 1)) := by\n        -- Use the fact that the integral of |Φ₂ r x| is finite to show that the integral of Φ₂ r x is finite.\n        refine' hasFiniteIntegral_of_abs h₂\n      exact h₄\n    exact h₃\n  ) (by\n    -- Use the fact that the measure of the complement of [0, 1] is 0.\n    have h₁ : volume.restrict (Set.Icc 0 1) (Set.univ \\ Set.Icc 0 1) = 0 := by\n      simp [Set.ext_iff]\n      <;> aesop\n    exact h₁\n  )⟩",
      "we can directly use that `Φ₂` is continuous and the interval is compact. \n\nBut Lean might need a direct proof using `HasFiniteIntegral`, perhaps by showing that the absolute value is bounded by an integrable function. \n\nHmm, perhaps for the purpose of this problem, we can just assume that the fact that `Φ₂` is continuous on `[0,1]` is sufficient to automatically deduce that it has finite integral there, but perhaps Lean wants an explicit bound.\n\nBut let me try to prove it directly in the general case:\n\n**Claim**: If `f : [a,b] → ℝ` is continuous, then `f` is integrable on `[a,b]`.\n\n*Proof*: For any `ε > 0`, there exists `δ > 0` such that `|x - y| < δ ⇒ |f(x) - f(y)| < ε/(b - a)`. Then any partition with step `≤ δ` gives a Riemann sum differing by at most `ε`. So the Riemann integral exists, hence the Lebesgue integral does too. \n\nBut perhaps Lean needs this to be formalized in terms of Bochner integration.\n\nBut perhaps we can try to use that `Φ₂ r` is continuous on `[0,1]`, and hence bounded, and `[0,1]` has finite volume, so `Φ₂ r` is finite a.e. and `∫ |Φ₂ r| < ∞`. \n\nAlternatively,",
      "\n  have h₁ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc (0 : ℝ) 1)) := by\n    -- Use the fact that Φ₂ is continuous on [0,1] and has a finite integral there.\n    have h₂ : ContinuousOn (Φ₂ r) (Icc (0 : ℝ) 1) := Φ₂_contDiffOn.continuousOn\n    have h₃ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n    have h₄ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc (0 : ℝ) 1)) := by\n      -- Apply the appropriate lemma to conclude the integral is finite.\n      apply ContinuousOn.hasFiniteIntegral_Icc\n      <;> (try norm_num) <;>\n      (try aesop) <;>\n      (try norm_num at * <;> aesop)\n    exact h₄\n  exact h₁.integrableOn",
      "\n  have h₁ : HasFiniteIntegral (fun x : ℝ => (Φ₂ r) x) (volume.restrict (Icc (0 : ℝ) 1)) := by\n    -- Use the fact that Φ₂_r is continuous on a compact set and the integral is finite\n    have h₂ : ContinuousOn (fun x : ℝ => (Φ₂ r) x) (Icc (0 : ℝ) 1) := Φ₂_contDiffOn.continuousOn\n    have h₃ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n    -- Apply the lemma to establish the finite integral\n    have h₄ : HasFiniteIntegral (fun x : ℝ => (Φ₂ r) x) (volume.restrict (Icc (0 : ℝ) 1)) :=\n      h₃.hasFiniteVolume.hasFiniteIntegral_of_continuousOn h₂\n    exact h₄\n  exact h₁",
      "\n  refine' Metric.finiteIntegral_of_le (fun x hx ↦ by\n    -- Establish that the function is bounded above by an integrable function\n    have h₁ : Φ₂ r x ≤ (1 : ℝ) := by\n      -- Use the fact that Φ₂ is bounded above by 1 on [0,1]\n      have h₂ : Φ₂ r x ≤ 1 := by\n        -- This is a placeholder for the actual bound; in reality, we need to prove that Φ₂ r x ≤ 1\n        -- For the sake of this proof, we assume this bound is known or can be derived\n        -- In a real scenario, we would provide the detailed steps here\n        have h₃ : x ∈ Set.Icc 0 1 := hx\n        have h₄ : 0 ≤ x := by exact hx.1\n        have h₅ : x ≤ 1 := by exact hx.2\n        -- This is a placeholder for the actual bound; in reality, we need to prove that Φ₂ r x ≤ 1\n        -- For the sake of this proof, we assume this bound is known or can be derived\n        -- In a real scenario, we would provide the detailed steps here\n        -- For now, we assume the bound directly\n        norm_num [Φ₂, MagicFunction.a.RadialFunctions.k0] at h₃ ⊢\n        <;>\n        (try\n          {\n            refine' le_of_sub_nonneg _\n            field_simp\n            rw [le_div_iff (by positivity)]\n            nlinarith [sq_nonneg (r - 1), sq_nonneg (x - 1), mul_nonneg hr (sub_nonneg.mpr h₅)]\n          })\n        <;>\n        (try\n          {\n            nlinarith [sq_nonneg (r - 1), sq_nonneg (x - 1), mul_nonneg hr (sub_nonneg.mpr h₅)]\n          })\n        <;>\n        (try\n          {\n            positivity\n          })\n        <;>\n        (try\n          {\n            nlinarith [sq_nonneg (r - 1), sq_nonneg (x - 1), mul_nonneg hr (sub_nonneg.mpr h₅)]\n          })\n      exact h₂\n    -- Use the bound to show that the integral is finite\n    linarith) (volume.restrict (Icc 0 1)) (1 : ℝ)\n  <;>\n  norm_num\n  <;>\n  (try\n    {\n      -- Prove that the integral of the constant function 1 over [0,1] is 1\n      have h₁ : HasFiniteIntegral (fun x : ℝ => (1 : ℝ)) (volume.restrict (Icc (0 : ℝ) 1)) := by\n        -- The integral of 1 over [0,1] is 1, which is finite\n        have h₂ : HasFiniteIntegral (fun x : ℝ => (1 : ℝ)) (volume.restrict (Icc (0 : ℝ) 1)) := by\n          -- Use the fact that the measure of [0,1] is 1\n          simpa [MeasureTheory.integral_const] using (hasFiniteVolume_Icc (0 : ℝ) (1 : ℝ))\n        exact h₂\n      -- Use the fact that the integral of 1 is finite to conclude the proof\n      exact h₁\n    })\n  <;>\n  (try\n    {\n      -- Use the fact that the integral of 1 is finite to conclude the proof\n      have h₁ : HasFiniteIntegral (fun x : ℝ => (1 : ℝ)) (volume.restrict (Icc (0 : ℝ) 1)) := by\n        simpa [MeasureTheory.integral_const] using (hasFiniteVolume_Icc (0 : ℝ) (1 : ℝ))\n      exact h₁\n    })\n  <;>\n  (try\n    {\n      -- Use the fact that the integral of 1 is finite to conclude the proof\n      exact hasFiniteVolume_Icc (0 : ℝ) (1 : ℝ)\n    })",
      "",
      "\n  have h₁ : Continuous (fun x : ℝ => Φ₂ r x) := by\n    continuity\n  -- Use the fact that Φ₂ r is continuous on the compact set [0,1] to show it is integrable\n  have h₂ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    -- Use the fact that the function is continuous and the set is compact to deduce finite integral\n    have h₃ : ContinuousOn (fun x : ℝ => Φ₂ r x) (Set.Icc 0 1) := by\n      exact Φ₂_contDiffOn.continuousOn\n    have h₄ : IsCompact (Set.Icc (0 : ℝ) 1) := isCompact_Icc\n    -- Use the fact that continuous functions on compact sets are integrable\n    have h₅ : (fun x : ℝ => Φ₂ r x) ∈ ContinuousOn (fun x : ℝ => Φ₂ r x) (Set.Icc 0 1) := h₃\n    have h₆ : HasFiniteIntegral (fun x : ℝ => Φ₂ r x) (volume.restrict (Icc 0 1)) := by\n      apply isCompact_hasFiniteIntegral_Icc\n      <;> (try simp_all [h₁, h₃, h₄])\n      <;> (try continuity)\n      <;> (try exact h₃)\n    exact h₆\n  exact h₂",
      "\n  have h : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    -- Use the fact that Φ₂ r is continuous on [0, 1] to show it is integrable\n    have h₁ : ContinuousOn (Φ₂ r) (Icc 0 1) := Φ₂_contDiffOn.continuousOn\n    -- Apply the theorem that continuous functions on compact intervals are integrable\n    have h₂ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n      -- Use the fact that the interval [0, 1] is compact and the function is continuous\n      apply ContinuousOn.hasFiniteIntegral\n      <;> simp_all [measurableSet_Icc]\n      <;> norm_num\n      <;>\n      (try\n        {\n          -- Show that the interval [0, 1] has finite volume\n          apply isCompact_Icc.measurableSet\n          <;> simp [hr]\n        })\n      <;>\n      (try\n        {\n          -- Use the fact that the function is continuous on [0, 1]\n          exact h₁\n        })\n    exact h₂\n  -- Use the fact that the function has a finite integral to conclude integrability\n  simpa using h.integrableOn",
      "\n  exact h₂",
      "\n  exact ContinuousOn.hasFiniteIntegral_Icc (by norm_num) Φ₂_contDiffOn.continuousOn",
      "",
      " sorry\nhave h₂ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Set.Icc 0 1)) := by sorry",
      "\n  have h : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    -- The function Φ₂(r, ε) is continuous on [0, 1] and hence bounded. Since [0, 1] is compact, the integral is finite.\n    have h₁ : ContinuousOn (fun ε : ℝ => Φ₂ r ε) (Icc 0 1) := Φ₂_contDiffOn.continuousOn\n    have h₂ : ContinuousOn (fun ε : ℝ => (Φ₂ r ε : ℝ)) (Icc 0 1) := by\n      exact h₁\n    have h₃ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n    -- Use the fact that continuous functions on compact sets are bounded and hence have finite integrals.\n    have h₄ : HasFiniteIntegral (fun ε : ℝ => (Φ₂ r ε : ℝ)) (volume.restrict (Icc 0 1)) := by\n      apply ContinuousOn.hasFiniteIntegral_of_isCompact h₂ (by\n        simpa [Set.Icc] using h₃)\n    simpa using h₄\n  exact h",
      "\n  have h₂ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    -- Use the fact that Φ₂ is continuous and the interval is bounded to show the integral is finite\n    have h₃ : ContinuousOn (Φ₂ r) (Icc (0 : ℝ) 1) := Φ₂_contDiffOn.continuousOn\n    have h₄ : BddAbove (Icc (0 : ℝ) 1) := by\n      use 1\n      intro x hx\n      simp only [Icc.mem_Icc] at hx ⊢\n      linarith\n    have h₅ : BddBelow (Icc (0 : ℝ) 1) := by\n      use 0\n      intro x hx\n      simp only [Icc.mem_Icc] at hx ⊢\n      linarith\n    -- Use the fact that the function is continuous and the interval is bounded to show the integral is finite\n    have h₆ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n      -- Use the fact that the function is continuous and the interval is bounded to show the integral is finite\n      refine' ContinuousOn.hasFiniteIntegral_restrict_Icc _ _ _\n      · exact h₃\n      · exact hr\n      · norm_num\n    exact h₆\n  -- Use the fact that the integral is finite to show integrability\n  simpa [hasFiniteIntegral_iff_integrable] using h₂",
      "\n  -- Use the fact that Φ₂ is continuous on the closed interval [0, 1] and hence its absolute value is bounded there.\n  have h₁ : ContinuousOn (fun x : ℝ => |(Φ₂ r) x|) (Icc (0 : ℝ) 1) := by\n    apply ContinuousOn.abs\n    exact Φ₂_contDiffOn.continuousOn\n  -- Find a bounded function that dominates |Φ₂ r| on [0, 1].\n  have h₂ : ∃ (g : ℝ → ℝ), (∫⁻ (x : ℝ) in Icc (0 : ℝ) 1, ENNReal.ofReal (g x)) < ⊤ ∧ ∀ x ∈ Icc (0 : ℝ) 1, |(Φ₂ r) x| ≤ g x := by\n    -- Since Φ₂ is continuous on [0, 1], it is bounded by some M.\n    have h₃ : ∃ M : ℝ, ∀ x ∈ Icc (0 : ℝ) 1, |(Φ₂ r) x| ≤ M := by\n      -- Use the fact that Φ₂ is continuous on a compact set to get boundedness.\n      obtain ⟨M, hM⟩ := Metric.isCompact_Icc.exists_forall_ge (by continuity) (Set.nonempty_Icc.mpr (by norm_num))\n      refine' ⟨M, _⟩\n      intro x hx\n      specialize hM x hx\n      simp [abs_le] at hM ⊢\n      <;>\n      (try cases' le_total 0 ((Φ₂ r) x) with h h <;> simp_all [abs_of_nonneg, abs_of_nonpos, le_of_lt]) <;>\n      (try linarith) <;>\n      (try nlinarith)\n    -- Use the bound to construct a dominating function.\n    obtain ⟨M, hM⟩ := h₃\n    use fun x => M\n    constructor\n    · -- The integral of the constant function M over [0, 1] is M, which is finite.\n      have h₄ : (∫⁻ (x : ℝ) in Icc (0 : ℝ) 1, ENNReal.ofReal (M : ℝ)) = ENNReal.ofReal (M * 1) := by\n        simp [MeasureTheory.integral_const, Icc_eq_empty]\n        <;> field_simp [ENNReal.ofReal_mul]\n        <;> ring_nf\n        <;> simp_all [ENNReal.ofReal_one]\n        <;> norm_num\n      rw [h₄]\n      <;> simp [ENNReal.ofReal_lt_top]\n      <;> norm_num\n      <;> linarith\n    · -- For all x in [0, 1], |Φ₂ r x| ≤ M.\n      intro x hx\n      specialize hM x hx\n      linarith\n  -- Apply the boundedness to conclude integrability.\n  obtain ⟨g, hg₁, hg₂⟩ := h₂\n  have h₃ : HasFiniteIntegral (fun x : ℝ => |(Φ₂ r) x|) (volume.restrict (Icc (0 : ℝ) 1)) := by\n    refine' (MeasureTheory.hasFiniteIntegral_of_dominated_by (fun x hx => hg₂ x hx) (by simpa using hg₁)).trans _\n    -- The dominating function g has a finite integral, so |Φ₂ r| does as well.\n    <;> simp_all [abs_nonneg]\n  -- Since |Φ₂ r| has a finite integral, Φ₂ r is integrable.\n  convert h₃.integrable_of_abs using 1 <;> simp [Real.norm_eq_abs]",
      "\n  have h₁ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₂ r) (Icc 0 1) := Φ₂_contDiffOn.continuousOn\n    have h₃ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n    have h₄ : BddBelow (Set.range (fun x : ℝ => (Φ₂ r) x)) := by\n      have h₅ : ∀ x, (Φ₂ r) x ≥ 0 := by\n        intro x\n        have h₆ : (Φ₂ r) x = (r * (x ^ 2 - 1)) ^ 2 := by\n          simp [Φ₂]\n          <;> ring_nf\n          <;> field_simp\n          <;> ring_nf\n        rw [h₆]\n        nlinarith [sq_nonneg (r * (x ^ 2 - 1))]\n      refine' ⟨0, _⟩\n      intro y\n      rcases y with ⟨x, rfl⟩\n      exact h₅ x\n    have h₅ : HasFiniteIntegral (Φ₂ r) (volume.restrict (Icc 0 1)) := by\n      apply ContinuousOn.hasFiniteIntegral\n      <;> aesop\n    exact h₅\n  exact h₁",
      "\n  exact (Φ₂_contDiffOn.continuousOn.integrableOn_Icc).has_finite_integral",
      "\n  apply ContinuousOn.hasFiniteIntegral\n  <;> simp_all [continuousOn_const, continuousOn_id, ContinuousOn.div]\n  <;> apply ContinuousOn.mul\n  <;> (try continuity) <;> (try apply ContinuousOn.mul) <;> (try continuity) <;>\n    (try apply ContinuousOn.div) <;> (try continuity)\n  <;> norm_num\n  <;>\n    (try\n      {\n        refine' ContinuousOn.mul (ContinuousOn.pow continuousOn_id 2) _\n        continuity\n      })\n  <;>\n    (try\n      {\n        refine' ContinuousOn.mul (ContinuousOn.pow continuousOn_id _) _\n        continuity\n      })\n  <;>\n    (try continuity)\n  <;>\n    (try norm_num)\n  <;>\n    (try\n      {\n        refine' ContinuousOn.div _ _\n        · continuity\n        · continuity\n        · intro x hx\n          have h₁ : 0 < x := by\n            cases' hx with hx₁ hx₂\n            linarith\n          have h₂ : x ≤ 1 := by\n            cases' hx with hx₁ hx₂\n            linarith\n          positivity\n      })",
