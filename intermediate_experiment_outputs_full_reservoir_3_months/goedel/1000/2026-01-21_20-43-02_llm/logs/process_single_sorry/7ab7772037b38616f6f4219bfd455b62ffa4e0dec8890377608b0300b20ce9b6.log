    have h₁ : IntervalIntegrable f μ a b := h
    have h₂ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that the interval is integrable for f to show it is for r • f
      have h₃ : IntervalIntegrable (r • f) μ a b := by
        -- Use the boundedness of the scalar multiplication to preserve integrability
        refine' (h₁.is_interval_integrable' (a..b)).map (r • •)
        <;>
        simp_all [isBoundedSMul_iff]
        <;>
        (try
