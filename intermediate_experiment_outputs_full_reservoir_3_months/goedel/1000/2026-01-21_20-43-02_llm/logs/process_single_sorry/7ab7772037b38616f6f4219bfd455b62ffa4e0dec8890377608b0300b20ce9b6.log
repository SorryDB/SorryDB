theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · intro h
    have h₁ : IntervalIntegrable f μ a b := h
    -- Use the fact that the integral of r • f is r times the integral of f
    have h₂ : IntervalIntegrable (r • f) μ a b := by
      -- Use the boundedness of the scalar multiplication to show that r • f is integrable
      have h₃ : IsBoundedSMul R E := inferInstance
      -- Use the fact that the integral of r • f is r times the integral of f
      have h₄ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that the scalar multiplication is bounded to show that r • f is integrable
        exact IsBoundedSMul.intervalIntegrable_smul r h₁
      exact h₄
    exact h₂
  · intro h
    have h₁ : IntervalIntegrable (r • f) μ a b := h
    -- Use the fact that the integral of f is the scalar inverse of the integral of r • f
    have h₂ : IntervalIntegrable f μ a b := by
      -- Use the boundedness of the scalar multiplication to show that f is integrable
      have h₃ : IsBoundedSMul R E := inferInstance
      -- Use the fact that the scalar multiplication is bounded to show that f is integrable
      have h₄ : IntervalIntegrable f μ a b := by
        -- Use the fact that the scalar multiplication is bounded to show that f is integrable
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, so f can be anything
          subst hr
          simp_all [zero_smul]
          <;>
          (try simp_all [intervalIntegrable_zero]) <;>
          (try aesop) <;>
          (try simp_all [intervalIntegral.integral_congr_ae]) <;>
          (try simp_all [MeasureTheory.ae_restrict_iff]) <;>
          (try simp_all [MeasureTheory.ae_restrict_iff]) <;>
          (try simp_all [MeasureTheory.ae_restrict_iff]) <;>
          (try simp_all [MeasureTheory.ae_restrict_iff])
          <;>
          (try {
            refine' ⟨by simp_all [intervalIntegrable_zero], _⟩
            simp_all [intervalIntegral.integral_congr_ae]
            <;>
            simp_all [MeasureTheory.ae_restrict_iff]
          })
        · -- If r ≠ 0, then we can use the fact that r • f is integrable to show that f is integrable
          have h₅ : IntervalIntegrable f μ a b := by
            -- Use the fact that the scalar multiplication is bounded to show that f is integrable
            have h₆ : IntervalIntegrable (r • f) μ a b := h₁
            have h₇ : IntervalIntegrable f μ a b := by
              -- Use the fact that the scalar multiplication is bounded to show that f is integrable
              convert IsBoundedSMul.intervalIntegrable_smul r h₇ using 1 <;>
                (try simp_all [smul_smul]) <;>
                (try field_simp [hr]) <;>
                (try ring_nf) <;>
                (try simp_all [hr]) <;>
                (try aesop)
            exact h₇
          exact h₅
      exact h₄
    exact h₂
