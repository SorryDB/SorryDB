    have h₁ : IntervalIntegrable (r • f) μ a b := h
    have h₂ : IntervalIntegrable f μ a b := by
      -- Use the fact that the interval is integrable for r • f to show it is for f
      have h₃ : IntervalIntegrable f μ a b := by
        -- Use the boundedness of the scalar multiplication to preserve integrability
