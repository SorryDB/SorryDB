theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro hf
      have h₁ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that the scalar multiplication by a bounded scalar preserves interval integrability.
        have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
          -- Use the property of interval integrability under bounded scalar multiplication.
          refine' hf.of_norm_bounded _ _ _
          · -- Show that the norm of the scalar is finite.
            exact (norm_nonneg r)
          · -- Show that the scalar multiplication is bounded by the norm of the scalar.
            intro x
            simp [norm_smul]
          · -- The measure is the same.
            exact μ
        -- Simplify the expression to match the required form.
        simpa using h₂
      exact h₁
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro hf
      have h₁ : IntervalIntegrable f μ a b := by
        -- Use the fact that if r • f is interval integrable, then f is interval integrable if r is non-zero.
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, and f is trivially interval integrable.
          have h₂ : (r • f) = (fun _ : ℝ => (0 : E)) := by
            funext x
            simp [hr]
          have h₃ : IntervalIntegrable (fun _ : ℝ => (0 : E)) μ a b := by
            -- The zero function is interval integrable.
            apply intervalIntegrable_zero
          have h₄ : IntervalIntegrable f μ a b := by
            -- If r = 0, then r • f = 0, so f is interval integrable if 0 is interval integrable.
            simpa [h₂] using hf
          exact h₄
        · -- If r ≠ 0, then we can use the fact that scalar multiplication by a non-zero scalar is invertible.
          have h₂ : IntervalIntegrable (fun x : ℝ => (r⁻¹ : R) • (r • f x)) μ a b := by
            -- Use the fact that the scalar multiplication by r⁻¹ is bounded.
            refine' hf.of_norm_bounded _ _ _
            · -- Show that the norm of r⁻¹ is finite.
              exact (norm_nonneg (r⁻¹ : R))
            · -- Show that the scalar multiplication is bounded by the norm of r⁻¹.
              intro x
              simp [norm_smul]
              <;>
              (try simp_all [hr])
              <;>
              (try norm_num)
              <;>
              (try field_simp [hr])
              <;>
              (try ring_nf)
              <;>
              (try simp_all [hr])
            · -- The measure is the same.
              exact μ
          -- Simplify the expression to match the required form.
          have h₃ : IntervalIntegrable (fun x : ℝ => (r⁻¹ : R) • (r • f x)) μ a b := h₂
          have h₄ : (fun x : ℝ => (r⁻¹ : R) • (r • f x)) = f := by
            funext x
            have h₅ : (r⁻¹ : R) • (r • f x) = f x := by
              calc
