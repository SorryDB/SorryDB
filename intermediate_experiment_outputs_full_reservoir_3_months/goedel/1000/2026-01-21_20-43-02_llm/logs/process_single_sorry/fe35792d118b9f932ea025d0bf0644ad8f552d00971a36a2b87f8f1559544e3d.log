ist.filter_append_filter_neg S (fun c => (isInitialCall S c))]\n                          <;> simp [List.length_append]\n                        exact h₁₁\n                      exact h₁₀\n                linarith\n              linarith\n            linarith\n          linarith\n        linarith\n      have h₅ : (S.filter (fun c => ¬(isInitialCall S c))).length = (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => (isFinalCall S c))).length := by\n        have h₆ : (S.filter (fun c => ¬(isInitialCall S c))).length = (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => (isFinalCall S c))).length := by\n          have h₇ : (S.filter (fun c => ¬(isInitialCall S c))).length = (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => (isFinalCall S c))).length := by\n            classical\n            calc\n              (S.filter (fun c => ¬(isInitialCall S c))).length = ((S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => ¬(isFinalCall S c))).length + ((S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => (isFinalCall S c))).length := by\n                have h₈ : (S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => ¬(isFinalCall S c))).length + ((S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => (isFinalCall S c))).length = (S.filter (fun c => ¬(isInitialCall S c))).length := by\n                  have h₉ : (S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => ¬(isFinalCall S c))).length + ((S.filter (fun c => ¬(isInitialCall S c))).filter (fun c => (isFinalCall S c))).length = (S.filter (fun c => ¬(isInitialCall S c))).length := by\n                    classical\n                    rw [← List.filter_append_filter_neg (S.filter (fun c => ¬(isInitialCall S c))) (fun c => (isFinalCall S c))]\n                    <;> simp [List.length_append]\n                  exact h₉\n                linarith\n              _ = (S.fi