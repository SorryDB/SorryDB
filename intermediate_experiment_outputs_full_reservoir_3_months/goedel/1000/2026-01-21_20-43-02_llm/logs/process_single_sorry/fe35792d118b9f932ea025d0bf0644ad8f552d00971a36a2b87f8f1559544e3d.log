      "\n    have h₃ : initPart.length + midPart.length + finalPart.length = (List.filter (fun c => isInitialCall m S c) S).length + (List.filter (fun c => ¬(isInitialCall m S c) ∧ ¬(isFinalCall m S c)) S).length + (List.filter (fun c => isFinalCall m S c) S).length := by rfl\n    have h₄ : (List.filter (fun c => isInitialCall m S c) S).length + (List.filter (fun c => ¬(isInitialCall m S c) ∧ ¬(isFinalCall m S c)) S).length + (List.filter (fun c => isFinalCall m S c) S).length = S.length := by\n      have h₅ : (List.filter (fun c => isInitialCall m S c) S).length + (List.filter (fun c => ¬(isInitialCall m S c) ∧ ¬(isFinalCall m S c)) S).length + (List.filter (fun c => isFinalCall m S c) S).length = S.length := by\n        have h₆ : ∀ (P Q R : Call m → Prop), (∀ (x : Call m), (P x ∨ Q x ∨ R x)) → ((List.filter P S).length + (List.filter Q S).length + (List.filter R S).length) = S.length := by\n          intro P Q R hPQR\n          have h₇ : (List.filter P S).length + (List.filter Q S).length + (List.filter R S).length = S.length := by\n            have h₈ : (List.filter P S).length + (List.filter Q S).length + (List.filter R S).length = S.length := by\n              -- Use the fact that the predicates are mutually exclusive and exhaustive\n              have h₉ : ∀ (x : Call m), x ∈ S → (P x ∨ Q x ∨ R x) := by\n                intro x hx\n                exact hPQR x\n              -- Use the partition lemma to sum the lengths\n              have h₁₀ : (List.filter P S).length + (List.filter Q S).length + (List.filter R S).length = S.length := by\n                -- Use the partition lemma to sum the lengths\n                classical\n                calc\n                  (List.filter P S).length + (List.filter Q S).length + (List.filter R S).length = (List.filter P S).length + (List.filter Q S).length + (List.filter R S).length := rfl\n                  _ = S.length := by\n                    -- Use the partition lemma to sum the lengths\n                    have