instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      -- Use the properties of the valuation to show that the image of `r` is in the valuation ring of `L`.
      obtain ⟨r, hr⟩ := r
      have h₁ : (algebraMap K L r) = algebraMap K L r := rfl
      have h₂ : valuation L (algebraMap K L r) ≤ 1 := by
        -- Use the fact that `AlgebraMap` is compatible with the valuation.
        have h₃ : valuation L (algebraMap K L r) ≤ 1 := by
          -- Use the property of `ValuativeExtension` to show that the valuation of the image is at most 1.
          have h₄ : valuation K r ≤ 1 := by
            -- Since `r` is in the valuation ring of `K`, its valuation is at most 1.
            rcases r with (_ | _ | r) <;> simp_all [Valuation.mem_integer_iff, valuation_eq_zero_iff]
            <;>
            (try contradiction) <;>
            (try norm_num) <;>
            (try linarith)
          -- Use the property of `ValuativeExtension` to transfer the valuation inequality.
          have h₅ : valuation L (algebraMap K L r) ≤ 1 := by
            exact ValuativeExtension.valuation_map_le_one _ h₄
          exact h₅
        exact h₃
      -- Use the fact that the valuation is at most 1 to show that the image is in the valuation ring of `L`.
      have h₃ : (algebraMap K L r) ∈ {x : L | valuation L x ≤ 1} := by
        simpa using h₂
      -- Use the definition of the valuation ring to show that the image is in `𝒪[L]`.
      simpa [Set.mem_setOf_eq] using h₃
    ⟩
    map_add' r s := by
      -- Prove that the map is additive.
      simp [Pi.add_apply]
      <;>
      (try simp_all [AdditiveMonoidHom.map_add]) <;>
      (try ring_nf) <;>
      (try norm_num) <;>
      (try aesop)
    map_one' := by
      -- Prove that the map sends 1 to 1.
      simp [Pi.one_apply]
      <;>
      (try simp_all [RingHom.map_one]) <;>
      (try ring_nf) <;>
      (try norm_num) <;>
      (try aesop)
  }
