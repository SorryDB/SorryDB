      -- This follows from the fact that `r.1` is in the integer ring of `K` and the valuation map is compatible.
      have h₁ : valuation L (algebraMap K L r.1) ≤ 1 := by
        -- The valuation of the algebra map is less than or equal to 1.
        have h₂ : valuation K r.1 ≤ 1 := by
          -- Since `r.1` is in the integer ring of `K`, its valuation in `K` is less than or equal to 1.
          simpa [Valuation.mem_integer_iff] using r.2
        have h₃ : valuation L (algebraMap K L r.1) ≤ valuation K r.1 := by
          -- The valuation in `L` is less than or equal to the valuation in `K`.
          exact (ValuativeExtension.map_rel_le _ _).trans (by simp [h₂])
        -- Combine the inequalities to get the desired result.
        linarith
      -- Use the fact that the valuation is less than or equal to 1 to conclude that the element is in the integer ring of `L`.
      have h₂ : valuation L (algebraMap K L r.1) ≥ 0 := by
        exact zero_le _
      have h₃ : valuation L (algebraMap K L r.1) ≤ 1 := h₁
      have h₄ : valuation L (algebraMap K L r.1) ≥ 0 := h₂
      -- Use the fact that the valuation is between 0 and 1 to conclude that the element is in the integer ring of `L`.
      simp_all [Valuation.mem_integer_iff]
