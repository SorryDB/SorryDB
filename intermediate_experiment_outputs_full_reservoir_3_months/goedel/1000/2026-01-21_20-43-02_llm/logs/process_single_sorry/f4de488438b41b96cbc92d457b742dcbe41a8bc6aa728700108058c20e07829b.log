```lean
instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      have h₁ : valuation L (algebraMap K L r) ≤ 1 := by
        have h₂ : valuation K (1 : K) ≤ 1 := by simp [le_refl]
        have h₃ : valuation L (algebraMap K L (1 : K)) ≤ 1 := by
          have h₄ : valuation L (algebraMap K L (1 : K)) = valuation K (1 : K) := by
            simpa [Algebra.id] using (ValuativeExtension.map_one (algebraMap K L)).symm
          rw [h₄]
          exact h₂
        have h₅ : valuation L (algebraMap K L r) = valuation L (algebraMap K L r) := rfl
        have h₆ : valuation K (r : K) ≤ 1 := by simpa using hr
        have h₇ : valuation L (algebraMap K L r) = valuation K (r : K) := by
          simpa [Algebra.id] using (ValuativeExtension.map_one (algebraMap K L)).symm
        rw [h₇]
        exact h₆
      have h₂ : valuation L (algebraMap K L r) ≤ 1 := h₁
      have h₃ : valuation L (algebraMap K L r) ≤ 1 := h₂
      exact by
        have h₄ : valuation L (algebraMap K L r) ≤ 1 := h₃
        simpa [le_one_iff_eq_zero_or_one, val_one_or_zero] using h₄
    ⟩
    map_add' := by
      intro r s
      simp [add_def, mul_def, algebraMap]
      <;>
      (try cases r <;> cases s <;> simp_all [add_assoc, add_comm, add_left_comm])
      <;>
      (try { ring_nf at * <;> norm_num })
      <;>
      (try { simp_all [add_assoc, add_comm, add_left_comm] })
      <;>
      (try { linarith })
    map_one' := by
      simp [add_def, mul_def, algebraMap]
      <;>
      (try cases r <;> cases s <;> simp_all [add_assoc, add_comm, add_left_comm])
      <;>
      (try { ring_nf at * <;> norm_num })
      <;>
      (try { simp_all [add_assoc, add_comm, add_left_comm] })
      <;>
      (try { linarith })
      <;>
      (try {
        simp_all [add_assoc, add_comm, add_left_comm]
        <;>
        norm_num
        <;>
        linarith
      })
  }
