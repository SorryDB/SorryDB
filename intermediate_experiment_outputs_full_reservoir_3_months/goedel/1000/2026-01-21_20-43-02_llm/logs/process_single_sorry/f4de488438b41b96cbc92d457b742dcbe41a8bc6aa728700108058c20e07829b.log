          have h₂ : valuation L (algebraMap K L r.1) = valuation K (r.1) := by
            rw [← ValuativeExtension.ext_iff]
            <;> simp_all [Algebra.map_one]
          have h₃ : valuation K (r.1) ≤ valuation K 1 := by
            have h₄ : r.1 ∈ 𝒪[K] := r.2
            have h₅ : valuation K (r.1) ≤ 0 := by
              rw [Valuation.mem_integer_iff] at h₄
              simpa using h₄
            have h₆ : valuation K 1 = 0 := by
