      simp_all [Subtype.ext_iff]
      <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try simp_all [add_assoc]) <;>
      (try simp_all [add_comm]) <;>
      (try simp_all [add_left_comm])
    map_one' := by
      simp [Subtype.ext_iff]
