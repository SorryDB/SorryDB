lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  haveI : ValuationRing L (O_L L) := O_L.valuationRing
  haveI : HausdorffSpace L := inferInstance
  haveI : StrictOrderedRingWithZeroDivisors L := inferInstance
  haveI : IsT2Space L := inferInstance
  haveI : IsLocalRing L := inferInstance
  -- Use the fact that the valuation is invariant under ring automorphisms
  have h : valuation L (e x) = valuation L x := by
    -- Use the property of valuations under ring automorphisms
    have h₁ : valuation L (e x) = valuation L x := by
      -- Since e is an automorphism, it preserves the valuation
      have h₂ : e.toRingHom is an automorphism of L
      have h₃ : valuation L (e x) = valuation L x := by
        -- Use the fact that the valuation is preserved under automorphisms
        rw [← valuation.map_eq_iff_le_isOpen (e.toRingHom).openMap]
        <;> simp_all [RingHom.map_mul, valuation.map_mul]
        <;> norm_num
        <;> aesop
      exact h₃
    exact h₁
  exact h
