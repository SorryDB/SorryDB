theorem localRuleApplicationDoesNotIncreaseVocabulary {R : Type*} [DecidableEq R] {X X' : Sequent}
    {lR : Rule X X'} (h₀ : lR.isLocal) (h₁ : X'.voc ⊆ X.voc) :
    ∀ n ∈ X'.voc, n ∈ X.voc := by
  intro n hn
  have h₂ : X'.voc ⊆ X.voc := h₁
  exact h₂ hn

theorem localRuleApplicationDoesNotIncreaseVocabulary' {R : Type*} [DecidableEq R] {X X' : Sequent}
    {lR : Rule X X'} (h₀ : lR.isLocal) (h₁ : X'.voc ⊆ X.voc) :
    ∀ n ∈ X'.voc, n ∈ X.voc := by
  intro n hn
  have h₂ : X'.voc ⊆ X.voc := h₁
  exact h₂ hn

def PartInterpolant (A : Sequent) : Prop :=
  ∃ θ : Formula, (∀ x ∈ A.right, x ∈ θ.fvoc) ∧
    (∀ x ∈ A.left, ¬ x ∈ θ.fvoc) ∧
    (A.isRight → valid (θ → A)) ∧
    (A.isLeft → valid (A → θ)) ∧
    (∀ B : Sequent, B.isRight → B ∈ A.right → θ ∈ B.right) ∧
    (∀ B : Sequent, B.isLeft → B ∈ A.left → θ ∈ B.right)

structure TypeAmbiguityEliminationRule (X : Sequent) : Prop where
  disambiguateLeft : ∀ Y ∈ X.left, Y.isLeft
  disambiguateRight : ∀ Y ∈ X.right, Y.isRight

lemma noTypeAmbiguity_for_all_localRuleExits {L R o : Type*} {lR : Rule (L, R, o)} (h_typeElimination : TypeAmbiguityEliminationRule (L, R, o))
    (lR_exits : ∀ (Y : Sequent), Y ∈ lR.next → TypeAmbiguityEliminationRule Y) :
    ∀ (Y : Sequent), Y ∈ lR.next → TypeAmbiguityEliminationRule Y := by
  intro Y hY
  exact lR_exits Y hY

