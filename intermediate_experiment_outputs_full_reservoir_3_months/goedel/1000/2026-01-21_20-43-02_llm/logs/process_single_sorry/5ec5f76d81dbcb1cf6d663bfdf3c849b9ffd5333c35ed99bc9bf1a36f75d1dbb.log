noncomputable def colimPreservesFiniteProductsOfIsSifted {C : Type u} [Category.{v} C] :
    PreservesFiniteProducts (colim : (C ⥤ _) ⥤ Type max u w) := by
  classically
  intro k X
  have h₁ : colim (fun i : k => colim (X i)) ≃ colim (fun x : (Σ i : k, (X i).obj) => x.2) := by
    apply Equiv.Perm.trans _
    apply Equiv.symm
    apply AdjointEquivalence.right
    apply colimTypeᵒᵖ_lan
  have h₂ : colim (fun x : (Σ i : k, (X i).obj) => x.2) ≃ colim (X : k ⥤ _) := by
    have h₃ : (Σ i : k, (X i).obj) = (X : k ⥤ _).weightedΣ := by
      ext
      <;> simp [WeightedΣ]
      <;> aesop
    have h₄ : (fun x : (Σ i : k, (X i).obj) => x.2) = (X : k ⥤ _).weightedΣCoprod := by
      ext
      <;> simp [WeightedΣ, weightedΣCoprod]
      <;> aesop
    rw [h₃] at *
    rw [h₄] at *
    -- Use the fact that colim (weightedΣCoprod X) ≃ colim X
    apply Equiv.Perm.trans _
    apply Equiv.symm
    apply AdjointEquivalence.right
    apply colimWeightedΣCoprod
  have h₃ : colim (fun i : k => colim (X i)) ≃ colim (X : k ⥤ _) := by
    calc
      colim (fun i : k => colim (X i)) ≃ colim (fun x : (Σ i : k, (X i).obj) => x.2) := by rw [h₁]
      _ ≃ colim (X : k ⥤ _) := by rw [h₂]
  apply h₃.symm
