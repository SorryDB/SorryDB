-- example 1.4.7
def NatTrans_Hom_c_?_Hom_?_c {α : Type*} [C : Category α] (c d : α) (h : Hom c d) :
    NaturalTransformation (Hom_c_? d) (Hom_c_? c) where
  arrow X := fun f => h ≫ f
  naturality {X Y} f := by
    funext g
    simp only [Category.comp, Function.comp_apply, Hom_c_?]
    rw [assoc]

