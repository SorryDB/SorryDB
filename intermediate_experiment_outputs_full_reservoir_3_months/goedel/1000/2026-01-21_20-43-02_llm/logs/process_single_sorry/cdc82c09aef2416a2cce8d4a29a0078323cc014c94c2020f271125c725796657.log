theorem common_center {A B : Set ℝ²} (psa : PointSym A) (psb : PointSym B)
    (b_convex : Convex ℝ B)
    (v : ℝ²) (hin : (· + v) '' A ⊆ B) : A ⊆ B := by
  intro a ha
  have h1 : a + v ∈ B := by
    simp only [Set.mem_image, Set.subset_def] at hin
    have h2 : ∃ (x : ℝ²), x ∈ A ∧ x + v = a + v := by
      refine' ⟨a, ha, _⟩
      simp
    specialize hin a h2
    exact hin
  have h2 : a - v ∈ B := by
    have han : -a ∈ A := psa a ha
    have hnav : -a + v ∈ B := by
      simp only [Set.mem_image, Set.subset_def] at hin
      have h3 : ∃ (x : ℝ²), x ∈ A ∧ x + v = (-a) + v := by
        refine' ⟨-a, han, _⟩
        simp
      specialize hin (-a) h3
      exact hin
    have hnn : -(-a + v) ∈ B := psb (-a + v) hnav
    have h : -(-a + v) = a - v := by
      ext <;> simp [Prod.ext_iff, add_assoc] <;> ring_nf at * <;> linarith
    rw [h] at hnn
    exact hnn
  have segment_sub_b := convex_iff_segment_subset.mp b_convex h1 h2
  exact segment_sub_b (mem_segment_add_sub a v)

