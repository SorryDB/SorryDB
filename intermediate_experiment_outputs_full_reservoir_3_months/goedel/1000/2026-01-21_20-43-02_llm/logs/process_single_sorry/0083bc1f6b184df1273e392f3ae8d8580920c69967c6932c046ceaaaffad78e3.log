      "\n  by\n    -- Step 1: Use őĶ = 1 to find a relatively dense set of almost periods\n    have h‚āĀ : IsRelDense {t | IsLinftyAP 1 t f} := hf 1 (by norm_num)\n    -- Step 2: Obtain l such that {t | IsLinftyAP 1 t f} is relatively dense with respect to l\n    obtain ‚ü®l, hl‚ü© := h‚āĀ\n    -- Step 3: Use the bound on f over the interval [0, l]\n    have h‚āā : ‚ąÉ C, ‚ąÄ x ‚ąą Set.Icc 0 l, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n      -- f is continuous on [0, l], hence bounded\n      have h‚āÉ : ContinuousOn (fun x : ‚ĄĚ => ‚ÄĖf x‚ÄĖ : ‚ĄĚ ‚Üí ‚ĄĚ) (Set.Icc 0 l) := by\n        -- The norm is continuous, and the composition of continuous functions is continuous\n        apply ContinuousOn.norm\n        -- f is uniformly almost periodic, hence continuous\n        have h‚āĄ : Continuous f := by\n          sorry\n        exact h‚āĄ.continuousOn\n      -- The continuous function ‚ÄĖf‚ÄĖ on the compact interval [0, l] attains its maximum\n      have h‚āĄ : ‚ąÉ C, ‚ąÄ x ‚ąą Set.Icc 0 l, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n        have h‚āÖ : IsCompact (Set.Icc 0 l) := isCompact_Icc\n        obtain ‚ü®C, x, hx, hC‚ü© := h‚āÖ.exists_forall_ge (Set.nonempty_Icc.mpr (by linarith [hl.pos])) (h‚āÉ)\n        refine' ‚ü®C, fun x hx => _‚ü©\n        have h‚āÜ : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n          have h‚āá : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n            have h‚āą : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n              calc\n                ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n                  -- Use the fact that C is an upper bound\n                  have h‚āČ : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n                    exact le_of_not_gt fun h => by\n                      have h‚āĀ‚āÄ := hC\n                      simp_all [Set.mem_Icc]\n                      <;> linarith\n                  exact h‚āČ\n                _ = C := by rfl\n            exact h‚āą\n          exact h‚āá\n        exact h‚āÜ\n      exact h‚āĄ\n    obtain ‚ü®C, hC‚ü© := h‚āā\n    -- Step 4: Extend the bound to all of ‚ĄĚ using the almost periodicity\n    have h‚āÉ : ‚ąÉ C', ‚ąÄ x : ‚ĄĚ, ‚ÄĖ