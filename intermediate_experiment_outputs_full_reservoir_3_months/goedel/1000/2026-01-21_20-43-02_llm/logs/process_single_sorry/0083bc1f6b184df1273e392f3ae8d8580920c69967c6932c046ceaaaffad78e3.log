      "\n  have h‚āĀ : ‚ąÉ C, ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n    -- Use the uniform continuity to find a bounded set\n    have h‚āā : UniformContinuous f := hf.uniformContinuous\n    -- Use the fact that f is uniformly continuous to find a C\n    have h‚āÉ : ‚ąÉ C, ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n      -- Use the uniform continuity to find a bounded set\n      have h‚āĄ : (Set.range f).IsPrecompact := by\n        -- Show that the range of f is precompact\n        have h‚āÖ : IsCompact (Set.Icc 0 1) := isCompact_Icc\n        have h‚āÜ : Continuous f := h‚āā.to_continuous\n        exact isPrecompact_of_isCompact closure_of_isClosed (by continuity) (by\n          -- Use the fact that the closure of the range is compact\n          have h‚āá : ContinuousOn f (Set.Icc 0 1) := h‚āÜ.continuousOn\n          have h‚āą : IsCompact (f '' Set.Icc 0 1) := isCompact_image_of_continuousOn\n            (Set.isCompact_Icc) h‚āá\n          have h‚āČ : f '' Set.Icc 0 1 ‚äÜ closure (Set.range f) := by\n            have h‚āĀ‚āÄ : f '' Set.Icc 0 1 ‚äÜ Set.range f := by\n              intro y hy\n              obtain ‚ü®x, hx, rfl‚ü© := hy\n              exact ‚ü®x, rfl‚ü©\n            exact closure_mono h‚āĀ‚āÄ\n          exact Set.Subset.trans h‚āČ (by simp [Set.subset_univ]))\n      -- Use the fact that the range is precompact to find a C\n      have h‚āÖ : ‚ąÉ C, ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n        -- Use the boundedness of the precompact set\n        have h‚āÜ : BddAbove (Set.range fun x : ‚ĄĚ => ‚ÄĖf x‚ÄĖ) := by\n          -- Show that the set is bounded above\n          have h‚āá : (Set.range (fun x : ‚ĄĚ => ‚ÄĖf x‚ÄĖ)).IsPrecompact := by\n            -- Use the precompactness of the range of f\n            have h‚āą : (Set.range f).IsPrecompact := h‚āĄ\n            have h‚āČ : (Set.range (fun x : ‚ĄĚ => ‚ÄĖf x‚ÄĖ)) = (fun x : ‚Ąā => ‚ÄĖx‚ÄĖ) '' Set.range f := by\n              ext y\n              simp [Set.mem_image]\n              <;>\n              (try { aesop }) <;>\n              (try {\n                constructor <;> intro h <;>\n                (try { aesop }) <;>\n                (try {\n                  obtain ‚ü®x, rfl‚ü© := h\n                  refine' ‚ü®f x, _‚ü© <;> simp\n                }) <;>\n                (try {\n                  obtain ‚ü®x, hx, rfl‚ü© := h\n                  refine' ‚ü®x, _‚ü© <;> simp_all [Complex.norm_eq_abs]\n                  <;>\n                  aesop\n                })\n              })\n            rw [h‚āČ]\n            exact (IsPrecompact.image (isPrecompact_closure continuous_norm) h‚āĄ)\n          -- Use the fact that the precompact set is bounded\n          exact isPrecompact_bddAbove h‚āá\n        -- Use the boundedness to find a C\n        obtain ‚ü®C, hC‚ü© := h‚āÜ\n        refine' ‚ü®C, _‚ü©\n        intro x\n        have h‚āá : ‚ÄĖf x‚ÄĖ ‚ąą Set.range fun x : ‚ĄĚ => ‚ÄĖf x‚ÄĖ := by\n          exact Set.mem_range_self x\n        have h‚āą : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n          exact hC h‚āá\n        exact h‚āą\n      exact h‚āÖ\n    exact h‚āÉ\n  exact h‚āĀ",
      "\n  have h‚āĀ : ‚ąÉ C, ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n    by_contra! h\n    -- Assume that f is unbounded\n    have h‚āā : ‚ąÄ C, ‚ąÉ x, ‚ÄĖf x‚ÄĖ > C := by simpa using h\n    -- Choose őĶ = 1\n    have h‚āÉ : 0 < (1 : ‚ĄĚ) := by norm_num\n    -- Since f is uniformly almost periodic, the set of 1-almost periods is relatively dense\n    have h‚āĄ : IsRelDense { t : ‚ĄĚ | IsLinftyAP (1 : ‚ĄĚ) t f } := hf (by norm_num)\n    -- Obtain the length l such that the set is relatively dense\n    obtain ‚ü®l, hl‚ü© := h‚āĄ\n    -- For x = 0, there exists a y ‚ąą [0, l) such that 0 + y is in the set\n    have h‚āÖ : ‚ąÉ y ‚ąą Set.Ico 0 l, (0 : ‚ĄĚ) + y ‚ąą { t : ‚ĄĚ | IsLinftyAP (1 : ‚ĄĚ) t f } := hl 0\n    obtain ‚ü®y, hy, hy'‚ü© := h‚āÖ\n    -- y is a 1-almost period\n    have h‚āÜ : IsLinftyAP (1 : ‚ĄĚ) y f := hy'\n    -- Find a point x‚āÄ where ‚ÄĖf x‚āÄ‚ÄĖ is large enough\n    have h‚āá : ‚ąÉ x‚āÄ, ‚ÄĖf x‚āÄ‚ÄĖ > ‚ÄĖf 0‚ÄĖ + 1 + 1 := by\n      have h‚āá‚āĀ := h‚āā (‚ÄĖf 0‚ÄĖ + 1 + 1)\n      obtain ‚ü®x‚āÄ, h‚āá‚āā‚ü© := h‚āá‚āĀ\n      exact ‚ü®x‚āÄ, by linarith‚ü©\n    obtain ‚ü®x‚āÄ, hx‚āÄ‚ü© := h‚āá\n    -- Use the 1-almost period to get a contradiction\n    have h‚āą : ‚ÄĖf (x‚āÄ + y) - f x‚āÄ‚ÄĖ ‚Č§ (1 : ‚ĄĚ) := h‚āÜ x‚āÄ\n    have h‚āČ : ‚ÄĖf (x‚āÄ + y)‚ÄĖ ‚Č• ‚ÄĖf x‚āÄ‚ÄĖ - ‚ÄĖf (x‚āÄ + y) - f x‚āÄ‚ÄĖ := by\n      calc\n        ‚ÄĖf (x‚āÄ + y)‚ÄĖ = ‚ÄĖf x‚āÄ + (f (x‚āÄ + y) - f x‚āÄ)‚ÄĖ := by ring_nf\n        _ ‚Č• ‚ÄĖf x‚āÄ‚ÄĖ - ‚ÄĖf (x‚āÄ + y) - f x‚āÄ‚ÄĖ := by\n          -- Using the reverse triangle inequality\n          have h‚āČ‚āĀ : ‚ÄĖf x‚āÄ‚ÄĖ ‚Č§ ‚ÄĖf (x‚āÄ + y)‚ÄĖ + ‚ÄĖf (x‚āÄ + y) - f x‚āÄ‚ÄĖ := by\n            calc\n              ‚ÄĖf x‚āÄ‚ÄĖ = ‚ÄĖf (x‚āÄ + y) - (f (x‚āÄ + y) - f x‚āÄ)‚ÄĖ := by ring_nf\n              _ ‚Č§ ‚ÄĖf (x‚āÄ + y)‚ÄĖ + ‚ÄĖf (x‚āÄ + y) - f x‚āÄ‚ÄĖ := norm_sub_le _ _\n          linarith\n    -- Derive a contradiction from the inequalities\n    have h‚āĀ‚āÄ : ‚ÄĖf (x‚āÄ + y)‚ÄĖ ‚Č• ‚ÄĖf x‚āÄ‚ÄĖ - 1 := by\n      linarith\n    h