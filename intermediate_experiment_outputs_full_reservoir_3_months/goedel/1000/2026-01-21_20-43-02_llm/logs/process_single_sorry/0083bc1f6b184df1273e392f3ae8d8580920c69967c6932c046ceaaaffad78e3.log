      "\n  have h‚āĀ : ‚ąÉ C, ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n    by_cases h : BddAbove (Set.range (fun x => ‚ÄĖf x‚ÄĖ : ‚ĄĚ ‚Üí ‚ĄĚ))\n    ¬∑ -- Case 1: The set {‚ÄĖf x‚ÄĖ | x ‚ąą ‚ĄĚ} is bounded above\n      obtain ‚ü®C, hC‚ü© := h\n      refine' ‚ü®C, _‚ü©\n      intro x\n      have h‚āā : ‚ÄĖf x‚ÄĖ ‚Č§ C := by\n        have h‚āÉ : ‚ÄĖf x‚ÄĖ ‚ąą Set.range (fun x => ‚ÄĖf x‚ÄĖ : ‚ĄĚ ‚Üí ‚ĄĚ) := by\n          exact Set.mem_range_self x\n        exact hC h‚āÉ\n      exact h‚āā\n    ¬∑ -- Case 2: The set {‚ÄĖf x‚ÄĖ | x ‚ąą ‚ĄĚ} is not bounded above\n      exfalso\n      -- We will show that if the set is not bounded above, then f cannot be uniformly almost periodic\n      -- This is a contradiction because we assumed hf : IsUnifAlmostPeriodic f\n      have h‚āā : ¬¨BddAbove (Set.range (fun x => ‚ÄĖf x‚ÄĖ : ‚ĄĚ ‚Üí ‚ĄĚ)) := h\n      -- Use the definition of IsUnifAlmostPeriodic to derive a contradiction\n      have h‚āÉ : ‚ąÄ őĶ > 0, IsRelDense {t | IsLinftyAP őĶ t f} := hf\n      -- Choose őĶ = 1\n      have h‚āĄ : IsRelDense {t | IsLinftyAP 1 t f} := h‚āÉ 1 (by norm_num)\n      -- Extract l from the definition of IsRelDense\n      obtain ‚ü®l, hl‚ü© := h‚āĄ\n      -- Use the fact that the set is not bounded above to find a contradiction\n      have h‚āÖ : 0 < l := IsRelDenseWith.pos hl\n      -- Since the set is not bounded above, there exists x such that ‚ÄĖf x‚ÄĖ > 0 + 1\n      have h‚āÜ : ‚ąÉ (x : ‚ĄĚ), ‚ÄĖf x‚ÄĖ > 0 + 1 := by\n        by_contra h‚āÜ\n        -- If no such x exists, then the set is bounded above by 1\n        push_neg at h‚āÜ\n        have h‚āá : ‚ąÄ (x : ‚ĄĚ), ‚ÄĖf x‚ÄĖ ‚Č§ 1 := by\n          intro x\n          have h‚āą : ‚ÄĖf x‚ÄĖ > 0 + 1 ‚Üí False := by tauto\n          by_cases h‚āČ : ‚ÄĖf x‚ÄĖ > 0 + 1\n          ¬∑ exfalso\n            exact h‚āą h‚āČ\n          ¬∑ -- If ‚ÄĖf x‚ÄĖ ‚Č§ 0 + 1, then ‚ÄĖf x‚ÄĖ ‚Č§ 1\n            have h‚āĀ‚āÄ : ‚ÄĖf x‚ÄĖ ‚Č§ 0 + 1 := by linarith\n            linarith\n        -- The set {‚ÄĖf x‚ÄĖ | x ‚ąą ‚ĄĚ} is b