      "\n    have h₃ : Function.Injective χ.linSolsIncl := by\n      -- Prove that the linear solutions inclusion is injective\n      intro S T h\n      -- Extract the equality of the underlying charges\n      have h₄ : S.val = T.val := by\n        simpa [linSolsIncl] using h\n      -- Use the extensionality lemma for linear solutions\n      exact LinSols.ext h₄\n    -- Use the fact that the linear solutions inclusion is injective\n    exact h₃\n  \n  have h₃ : Function.Injective ⇑(ACCSystemQuad.quadSolsIncl χ) := by\n    have h₄ : Function.Injective (MulActionHom.comp χ.linSolsIncl.toMulActionHom χ.quadSolsInclLinSols) := by\n      -- Use the fact that the composition of injective functions is injective\n      have h₅ : Function.Injective χ.quadSolsInclLinSols := h₁\n      have h₆ : Function.Injective ⇑χ.linSolsIncl := h₂\n      -- Use the property of injective functions to prove the composition is injective\n      have h₇ : Function.Injective (MulActionHom.comp χ.linSolsIncl.toMulActionHom χ.quadSolsInclLinSols) := by\n        -- Use the fact that the composition of injective functions is injective\n        have h₈ : Function.Injective χ.quadSolsInclLinSols := h₁\n        have h₉ : Function.Injective ⇑χ.linSolsIncl := h₂\n        -- Use the property of injective functions to prove the composition is injective\n        apply Function.Injective.comp (χ.quadSolsInclLinSols) h₂\n      exact h₇\n    -- Use the fact that the composition of injective functions is injective\n    simpa [quadSolsIncl] using h₄\n  \n  exact h₃",
