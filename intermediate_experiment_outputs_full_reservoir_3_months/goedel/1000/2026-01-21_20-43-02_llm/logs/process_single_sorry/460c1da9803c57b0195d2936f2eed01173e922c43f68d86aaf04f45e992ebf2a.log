  have h2 : Function.Injective χ.linSolsIncl := by
    intro S T hST
    have h : S.val = T.val := by simpa using hST
    have h₂ : S = T := by
      apply ACCSystemLinear.LinSols.ext
      exact h
    exact h₂
  
  have h_main : Function.Injective χ.quadSolsIncl := by
    have h3 : χ.quadSolsIncl = (χ.linSolsIncl : χ.LinSols →ₗ[ℚ] χ.Charges) ∘ (χ.quadSolsInclLinSols : χ.QuadSols →[ℚ] χ.LinSols) := by
