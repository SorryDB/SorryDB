    -- Prove that the linear inclusion is injective.
    exact (χ.):.linSolsIncl_injective
  have h₂ : Function.Injective (χ.quadSolsInclLinSols : χ.QuadSols →[ℚ] χ).2 := by
    -- Prove that the quadratic inclusion is injective.
    refine' fun S₁ S₂ h => _
    -- Extract the linear part of S₁ and S₂ and use the injectivity of the linear inclusion.
    have h₃ : S₁.toLinSols = S₂.toLinSols := by
      simpa [χ.quadSolsInclLinSols] using h
    -- Use the injectivity of the linear inclusion to conclude that S₁ = S₂.
    have h₄ : S₁ = S₂ := by
      cases S₁ <;> cases S₂ <;> simp_all [χ.quadSolsInclLinSols]
      <;>
      (try simp_all [accSystemQuad.cases]) <;>
      (try aesop) <;>
      (try simp_all [accSystemLinear.cases]) <;>
      (try aesop)
    exact h₄
  -- Combine the injectivity of the two inclusions to prove the injectivity of the composition.
  have h₃ : Function.Injective (χ.quadSolsIncl : χ.QuadSols →ₗ[ℚ] χ).2 := by
    refine' Function.Injective.comp h₁ _
    exact h₂
  exact h₃
