@[sorryful]
lemma quadSolsIncl_injective (χ : ACCSystemQuad) :
    Function.Injective χ.quadSolsIncl := by
  intro S T h
  have h₁ : S.val = T.val := by
    -- We use the fact that the underlying charge is injective when mapped into the charges module.
    have h₂ : (χ.quadSolsIncl : χ.QuadSols → χ.Charges) S = (χ.quadSolsIncl : χ.QuadSols → χ.Charges) T := by exact h
    simp [χ.quadSolsIncl, χ.linSolsIncl, ACCSystemLinear.linSolsIncl] at h₂
    <;> simp_all [QuadSols.ext_iff]
    <;> aesop
  -- If the underlying charges are equal, then the solutions are equal by the properties of the linear and quadratic equations.
  have h₂ : S = T := by
    apply Subtype.ext
    <;> simp_all [Subtype.ext_iff, QuadSols.ext_iff]
    <;> aesop
  exact h₂
