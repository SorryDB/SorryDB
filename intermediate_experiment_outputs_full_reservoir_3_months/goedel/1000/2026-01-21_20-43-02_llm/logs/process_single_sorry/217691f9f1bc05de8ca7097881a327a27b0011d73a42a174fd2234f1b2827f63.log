theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable
    intro h
    -- Use the fact that the interval integral of r • f is r times the interval integral of f
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Use the property of interval integrability under scalar multiplication
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Apply the interval integrability of f and scalar multiplication
        convert h.smul_left r using 1
        <;> simp [smul_smul]
      exact h₂
    exact h₁
  · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable
    intro h
    -- Use the fact that the interval integral of f is r⁻¹ times the interval integral of r • f
    have h₁ : IntervalIntegrable f μ a b := by
      -- Use the property of interval integrability under scalar multiplication
      have h₂ : IntervalIntegrable f μ a b := by
        -- Apply the interval integrability of r • f and scalar multiplication
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, and we can use the zero function's interval integrability
          simp_all [hr, smul_zero]
          <;>
          (try
            {
              -- Use the fact that the zero function is interval integrable
              exact intervalIntegrable_zero μ a b
            })
          <;>
          (try
            {
              -- Use the fact that the zero function is interval integrable
              exact intervalIntegrable_zero μ a b
            })
        · -- If r ≠ 0, then we can use the fact that scalar multiplication by r⁻¹ is bounded
          have h₃ : IntervalIntegrable f μ a b := by
            -- Use the property of interval integrability under scalar multiplication
            convert h.smul_left (r⁻¹) using 1
            <;> field_simp [hr] <;> simp [smul_smul]
            <;>
            (try
              {
                -- Simplify the expression to show it equals f
                congr 1 <;> ext <;> ring_nf <;> field_simp [hr] <;> simp [smul_smul]
              })
          exact h₃
      exact h₂
    exact h₁
