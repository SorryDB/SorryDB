theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    -- Proof of the forward direction: if f is interval integrable, then r • f is interval integrable.
    constructor
    · intro h
      -- Use the fact that scalar multiplication preserves interval integrability.
      exact by
        have h₂ : IntervalIntegrable f μ a b := h
        have h₃ : IntervalIntegrable (r • f) μ a b := by
          -- Use the property of bounded scalar multiplication to preserve integrability.
          refine' (rsmul_comp_smul _ _).symm.mpr _
          -- Use the fact that the scalar multiplication by r is bounded to conclude the proof.
          simpa [intervalIntegral.integral_comp_rsmul_right] using h₂
        exact h₃
    · intro h
      -- Proof of the reverse direction: if r • f is interval integrable, then f is interval integrable.
      have h₂ : IntervalIntegrable (r • f) μ a b := h
      have h₃ : IntervalIntegrable f μ a b := by
        -- Use the fact that the scalar multiplication by r has an inverse.
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, and we can directly check the integrability.
          simp_all [hr, zero_smul]
          <;>
          (try norm_num) <;>
          (try simp_all [intervalIntegral.integral_zero]) <;>
          (try exact intervalIntegrable_zero _) <;>
          (try exact by simp_all [intervalIntegral.integral_zero])
        · -- If r ≠ 0, use the fact that the scalar multiplication by r is invertible.
          have h₄ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
            -- Use the property of bounded scalar multiplication to preserve integrability.
            refine' (rsmul_comp_smul _ _).symm.mpr _
            -- Use the fact that the scalar multiplication by r⁻¹ is bounded to conclude the proof.
            simpa [intervalIntegral.integral_comp_rsmul_right] using h₂
          -- Simplify the expression to get back f.
          have h₅ : r⁻¹ • (r • f) = f := by
            ext x
            simp [hr, smul_smul]
            <;>
            field_simp [hr]
            <;>
            ring
          -- Substitute back to get the integrability of f.
          rw [h₅] at h₄
          exact h₄
      exact h₃
  exact h₁
