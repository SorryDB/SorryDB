  have h₁ : False := by
    have h₂ : 1 < 2 := by decide
    have h₃ : ∃ c : ℕ, 1 < c ∧ c < 2 := h 1 2 h₂
    obtain ⟨c, hc₁, hc₂⟩ := h₃
    have h₄ : c = 1 := by
      omega
    have h₅ : 1 < 1 := by
      linarith
    omega
  exact h₁
