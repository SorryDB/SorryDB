instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) := by
  have h : Injective (lightToProfinite.obj S) := by
    refine' fun X Y g f h => _
    have h₁ : (lightToProfinite.obj S).from X = (lightToProfinite.obj S).from Y := by
      simp_all
    have h₂ : ∃ (k : (lightToProfinite.obj S).from Y ⟶ (lightToProfinite.obj S).from X), k ∘ f = g := by
      apply injective_of_light
      <;> simpa using h₁
    obtain ⟨k, hk⟩ := h₂
    refine' ⟨k, _⟩
    simp_all [funext_iff]
  exact h
