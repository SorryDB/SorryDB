instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) := by
  have h₁ : Injective S := by infer_instance
  have h₂ : Injective (lightToProfinite.obj S) := by
    intro X Y f g h
    classical
    -- Use the fact that S is injective in the category of light profinite spaces
    -- and that the light to profinite map preserves injectivity.
    have h₃ : (lightToProfinite.map f : (X : Type) → (S : Type)) = (lightToProfinite.map g : (Y : Type) → (S : Type)) := by
      -- Convert the equality of the images to functions between the types
      convert congr_fun h 0 using 1
      <;> simp [Function.funext_iff]
      <;> aesop
    -- Use the injectivity of S to conclude that f = g
    have h₄ : f = g := by
      -- Use the injectivity of S to get the equality of the functions
      have h₅ := h₁.factors (lightToProfinite.map f) (lightToProfinite.map g) h₃
      -- Extract the equality of the functions from the injectivity condition
      cases h₅ with
      | intro k h₅ =>
        -- Use the equality of the functions to show that f = g
        have h₆ : f = g := by
          have h₇ : (lightToProfinite.map f : (X : Type) → (S : Type)) = (lightToProfinite.map g : (Y : Type) → (S : Type)) := by
            convert congr_fun h 0 using 1
            <;> simp [Function.funext_iff]
            <;> aesop
          simp [h₇]
          <;>
          (try simp_all [Function.funext_iff])
          <;>
          (try aesop)
          <;>
          (try simp_all [Type.cast_inj])
        exact h₆
    exact h₄
  exact h₂
