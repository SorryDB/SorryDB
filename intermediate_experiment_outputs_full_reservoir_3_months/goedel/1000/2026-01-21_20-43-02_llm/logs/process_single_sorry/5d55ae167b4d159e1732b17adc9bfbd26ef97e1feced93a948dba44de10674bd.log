lemma light_key_extension_lemma (X Y S T : LightProfinite.{u}) [hS : Finite S]
    (f : X ⟶ Y) [Mono f] (f' : S ⟶ T) [Epi f']
    (g : X ⟶ S) (g' : Y ⟶ T) (h_comm : f ≫ g' = g ≫ f') :
    ∃ k : Y ⟶ S, (k ≫ f' = g') ∧ (f ≫ k = g)  := by
  haveI : T2Space (X : Type _)  := inferInstanceAs (T2Space (X : Type _))
  haveI : T2Space (Y : Type _)  := inferInstanceAs (T2Space (Y : Type _))
  haveI : T2Space (S : Type _)  := inferInstanceAs (T2Space (S : Type _))
  haveI : T2Space (T : Type _)  := inferInstanceAs (T2Space (T : Type _))
  haveI : CompactSpace (X : Type _)  := inferInstanceAs (CompactSpace (X : Type _))
  haveI : CompactSpace (Y : Type _)  := inferInstanceAs (CompactSpace (Y : Type _))
  haveI : Finite (S : Type _)  := inferInstanceAs (Finite (S : Type _))
  haveI : Function.Injective (f : X → Y)  := inferInstanceAs (Function.Injective (f : X → Y))
  haveI : Function.Surjective (f' : S → T)  := inferInstanceAs (Function.Surjective (f' : S → T))
  haveI : Continuous (f : X → Y)  := inferInstanceAs (Continuous (f : X → Y))
  haveI : Continuous (g : X → S)  := inferInstanceAs (Continuous (g : X → S))
  haveI : Continuous (g' : Y → T)  := inferInstanceAs (Continuous (g' : Y → T))
  obtain ⟨k_fun, k_cont, h2, h3⟩ := key_extension_lemma (X : Type _) (Y : Type _) (S : Type _) (T : Type _) (f : X → Y) (inferInstanceAs (Continuous (f : X → Y))) (inferInstanceAs (Function.Injective (f : X → Y))) (f' : S → T) (inferInstanceAs (Function.Surjective (f' : S → T))) (g : X → S) (inferInstanceAs (Continuous (g : X → S))) (g' : Y → T) (inferInstanceAs (Continuous (g' : Y → T))) (by simpa [Function.comp] using congr_arg (fun x : X → T ↦ x) h_comm)
  refine ⟨TopCat.ofHom ⟨k_fun, k_cont⟩, ConcreteCategory.hom_ext_iff.mpr (congrFun h2), ConcreteCategory.hom_ext_iff.mpr (congrFun h3)⟩

