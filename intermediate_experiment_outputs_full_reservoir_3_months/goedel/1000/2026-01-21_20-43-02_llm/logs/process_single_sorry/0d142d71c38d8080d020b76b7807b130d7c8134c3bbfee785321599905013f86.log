```lean
def parts₁ (xs : List ℕ) : List (Partition ℕ) := 
  List.foldr (fun x ps => ps.bind (extendl x)) [[]] xs

def extendl (x : ℕ) : Partition ℕ → List (Partition ℕ) := 
  fun p => [p.cons x, p]

def Parts : List ℕ → List (Partition ℕ) → List (Partition ℕ) := 
  fun xs ps => ps.bind (extendl x)

def parts₂ (xs : List ℕ) : List (Partition ℕ) := 
  List.foldr (fun x ps => ps.bind (extendl x)) [[]] xs

example : ∀ xs : List ℕ, (parts₁ xs).length = 2^(xs.length - 1) := by
  intro xs
  induction xs with
