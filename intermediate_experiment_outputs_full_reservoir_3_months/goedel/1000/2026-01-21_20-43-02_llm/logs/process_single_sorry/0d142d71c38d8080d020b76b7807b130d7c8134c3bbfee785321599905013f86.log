theorem h_main : List.filter (flip List.all ok) ∘ parts₁ = List.foldr (concatMap ∘ okextendl) [[]] := by
  funext xs
  unfold parts₁
  simp [Function.comp]
  induction xs with
  | nil =>
    simp [List.foldr, flip]
  | cons a as ih =>
    have h1 := h a
    simp_all [List.foldr, Function.comp, List.filter_map, List.filter_append, List.filter_cons,
      List.filter_nil, List.map_append, List.map_map]
    <;>
    (try simp_all [h1]) <;>
    (try simp_all [List.filter_map, List.filter_append, List.filter_cons, List.filter_nil, List.map_append,
      List.map_map]) <;>
    (try simp_all [concatMap, extendl, okextendl, ok, List.all_cons, List.all_nil]) <;>
    (try aesop) <;>
    (try
      {
        have h2 := h1 []
        have h3 := h1 [[]]
        simp at h2 h3 ⊢
        <;> aesop
      }) <;>
    (try
      {
        have h2 := h1 [[[]]]
        simp at h2 ⊢
        <;> aesop
      }) <;>
    (try
      {
        simp_all [h1]
        <;> aesop
      })
```

