lemma wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
  by_cases h : i = j
  · -- Case: i = j
    simp [h]
    <;>
    (try aesop) <;>
    (try {
      simp_all [wignerMatrixEntryFunction, le_refl, Fin.ext_iff]
      <;>
      aesop
    })
  · -- Case: i ≠ j
    by_cases h₁ : i < j
    · -- Subcase: i < j
      have h₂ : j < i ∨ i = j ∨ i < j := by omega
      have h₃ : ¬(j < i) := by
        intro hj
        have h₄ := lt_asymm hj h₁
        contradiction
      have h₄ : i ≠ j := h
      simp_all [h, h₁, h₃, h₄, le_of_lt, le_of_lt]
      <;>
      (try {
        simp_all [wignerMatrixEntryFunction, Fin.ext_iff]
