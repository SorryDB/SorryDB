theorem wignerMatrixSymmetric (n : ℕ) (i j : Fin n) {ω : WignerSpace n} :
  wignerMatrixMap n ω i j = wignerMatrixMap n ω j i := by
  rw[wignerMatrixMap]
  rw[wignerMatrixMap']
  simp [wignerMatrixEntryFunction]
  <;>
  by_cases h : i = j <;>
  by_cases h' : i < j <;>
  by_cases h'' : j < i <;>
  simp_all [h, h', h'', lt_irrefl, lt_asymm, le_of_lt]
  <;>
  try { exfalso; omega }
  <;>
  try {
    (try {
      simp_all [lt_irrefl, lt_asymm, le_of_lt]
      <;>
      (try { exfalso; omega })
    })
    <;>
    (try {
      cases i <;> cases j <;>
      simp_all [Fin.ext_iff, Fin.val_zero, Fin.val_succ, lt_succ_iff]
      <;>
      (try { omega })
      <;>
      (try { aesop })
    })
  }
  <;>
  (try {
    have h₁ : i ≠ j := by tauto
    have h₂ : ¬i < j := by tauto
    have h₃ : ¬j < i := by tauto
    exfalso
    have h₄ : i.val < n := i.is_lt
    have h₅ : j.val < n := j.is_lt
    have h₆ : i.val ≠ j.val := by
      intro h₆
      apply h₁
      simp_all [Fin.ext_iff]
    have h₇ : i.val < j.val ∨ j.val < i.val := by omega
    cases h₇ with
    | inl h₇ =>
      have h₈ : i < j := by
        simp_all [Fin.ext_iff, Fin.val_lt]
        <;> omega
      contradiction
    | inr h₇ =>
      have h₈ : j < i := by
        simp_all [Fin.ext_iff, Fin.val_lt]
        <;> omega
      contradiction
  })
  <;>
  (try {
    aesop
  })
  <;>
  (try {
    simp_all [Fin.ext_iff, Fin.val_lt]
    <;>
    (try { omega })
    <;>
    (try { aesop })
  })
