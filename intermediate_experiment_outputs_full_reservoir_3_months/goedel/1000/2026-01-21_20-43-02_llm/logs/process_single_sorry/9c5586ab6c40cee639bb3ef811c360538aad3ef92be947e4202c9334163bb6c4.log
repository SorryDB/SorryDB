      have h₂ : ¬(i < j) := h₁
      have h₃ : j < i := by
        by_cases h₄ : j < i
        · exact h₄
        · -- If j ≥ i and i ≠ j, then j > i
          have h₅ : i ≤ j := by
            omega
          have h₆ : i ≠ j := h
          have h₇ : i < j := lt_of_le_of_ne h₅ (Ne.symm h₆)
          contradiction
      have h₄ : ¬(i < j) := h₁
      simp_all [h, h₃, h₄, le_of_lt, le_of_lt]
