        have h₅ : x ∈ D₂.carrier := by
          -- Use the fact that D₁ ≤ D₂ and D₂ ≤ D₁ to show x ∈ D₂
          have h₆ : ∃ B : Set (PersistenceSubmodule M), B ⊆ D₂.carrier ∧ x = sSup B := by
            -- Since D₁ ≤ D₂, there exists a subset B of D₂ such that x = sSup B
