theorem DirectSumDecompositionPartialOrder {C : Type*} [Category.{0, 0} C] {K : Type*} [DivisionRing K] {M : C ⥤ ModuleCat K} :
    PartialOrder (DirectSumDecomposition M) := by
  refine' partialOrder_of_le_of_not_lt _ _ _ _
  · -- Prove that ≤ is reflexive
    intro D
    exact fun N hN => ⟨{N}, by simp_all [Set.singleton_subset_iff] <;> aesop⟩
  · -- Prove that < is irreflexive
    intro D
    intro h
    have h₁ := h
    simp only [lt_iff_le_not_le] at h₁
    have h₂ := h₁.1
    have h₃ := h₁.2
    exfalso
    exact h₃ (le_rfl)
  · -- Prove that ≤ is antisymmetric
    intro D₁ D₂ h₁ h₂
    have h₃ : ∀ N, N ∈ D₁ → N ∈ D₂ := by
      intro N hN
      by_contra h
      push_neg at h
      have h₄ := h₂ ⟨N, hN⟩
      simp_all [SetLike.mem_coe]
      <;>
      (try { exfalso; exact h₂.ne h }) <;>
      (try { exfalso; exact h₃.ne h }) <;>
      (try { aesop })
      <;>
      (try {
        have h₅ := h₁ ⟨N, hN⟩
        simp_all [SetLike.mem_coe]
        <;>
        (try { exfalso; exact h.ne h }) <;>
        (try { aesop })
      })
    have h₄ : D₁.carrier = D₂.carrier := by
      apply Set.Subset.antisymm
      · intro x hx
        exact h₃ x hx
      · intro x hx
        have h₅ := h₁ ⟨x, hx⟩
        simp_all [SetLike.mem_coe]
        <;>
        (try { exfalso; exact h₂.ne h }) <;>
        (try { aesop })
    exact Subtype.ext h₄
  · -- Prove that ≤ is transitive
    intro D₁ D₂ D₃ h₁ h₂
    intro N hN
    have h₃ := h₂ N hN
    obtain ⟨C, hC₁, hC₂⟩ := h₃
    have h₄ : ∀ N : C, N ∈ D₂ → ∃ B : Set (PersistenceSubmodule M), B ⊆ D₃ ∧ N = sSup B := by
      intro N hN
      exact h₁ ⟨N, hN⟩
    have h₅ : ∃ B : Set (PersistenceSubmodule M), B ⊆ D₃ ∧ C = sSup B := h₄ C (by simp_all [SetLike.mem_coe])
    obtain ⟨B, hB₁, hB₂⟩ := h₅
    use B
    <;>
    (try {
      simp_all [Set.Subset.trans]
      <;>
      aesop
    }) <;>
    (try {
      simp_all [sSup_eq_sSup]
      <;>
      aesop
    })
