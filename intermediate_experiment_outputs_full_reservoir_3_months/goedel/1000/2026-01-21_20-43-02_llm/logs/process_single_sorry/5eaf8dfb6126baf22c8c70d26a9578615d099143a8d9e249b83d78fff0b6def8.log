theorem antisymm_submodule (R : Type*) [Semiring R] (B C : Submodule R (Module R)) :
    B ⊓ C = ⊥ ∧ C ≤ B → C = 0 := by
  intro h
  have h₁ : C = ⊥ := by
    have h₂ : B ⊓ C = ⊥ := h.1
    have h₃ : C ≤ B := h.2
    have h₄ : C ≤ B ⊓ C := by
      exact ⟨h₃, le_rfl⟩
    have h₅ : C ≤ ⊥ := by
      rw [h₂] at h₄
      exact h₄
    have h₆ : C = ⊥ := by
      exact le_bot_iff.mp h₅
    exact h₆
  
  have h₂ : C = 0 := by
    rw [h₁]
    <;> simp [Submodule.bot_eq_zero]
  
  exact h₂
```
