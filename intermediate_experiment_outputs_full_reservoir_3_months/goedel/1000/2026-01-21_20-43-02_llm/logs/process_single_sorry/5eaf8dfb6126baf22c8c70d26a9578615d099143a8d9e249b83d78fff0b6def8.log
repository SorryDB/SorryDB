/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_J_le_I h_I_le_J
    have h_final_left : ∀ N ∈ J, N ∈ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_J, h_N_not_in_I⟩
      let N' : J := ⟨N, h_N_in_J⟩
      have h_A : ∃ A : I, N ≤ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with ⟨A, h_N_le_A⟩
      choose f hf hf' using h_J_le_I
      let h_B₁ := hf' N'.prop
      let h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : A.val ∈ f N'.prop := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup (f N'.prop)) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup (f N'.prop) ≤ A.val := h_B₁ ▸ h_N_le_A
        have h_last : sSup (f N'.prop) = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val ≤ N := by
        simpa [← h_B₁] using le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N ∈ I := by
        exact h_A_eq_N ▸ A.prop
      aesop
    have h_final_right : ∀ N ∈ I, N ∈ J := by
      intro N hN_in_I
      by_contra h_neg
      push_neg at h_neg
      have h' := h_I_le_J
      have h'' := h_J_le_I
      have h₃ := h_final_left
      have h₄ : ∃ (A : J), N ≤ A.val := by
        -- Since I ≤ J, for any N in I, there exists A in J such that N ≤ A
        have h₅ : ∀ (N : I), ∃ A : J, N.val ≤ A.val := by
          intro N
          exact (RefinementMapSurj' J I (invOf (fun N : I => h_I_le_J (N.1)) N)).val
        obtain ⟨A, hA⟩ := h₅ ⟨N, hN_in_I⟩
        exact ⟨A, hA⟩
      obtain ⟨A, hA⟩ := h₄
      have h₅ : ∃ (B : I), A.val ≤ B.val := by
        -- Since J ≤ I, for any A in J, there exists B in I such that A ≤ B
        have h₆ : ∀ (A : J), ∃ B : I, A.val ≤ B.val := by
          intro A
          exact (RefinementMapSurj' I J h_J_le_I A).val
        obtain ⟨B, hB⟩ := h₆ A
        exact ⟨B, hB⟩
      obtain ⟨B, hB⟩ := h₅
      have h₆ : N ≤ B.val := le_trans hA hB
      have h₇ : B.val ∈ I := B.2
      have h₈ : A.val ∈ J := A.2
      have h₉ : N ∈ I := hN_in_I
      have h₁₀ : ¬(A.val ∈ I) := by
        intro h
        have h₁₁ : A.val ∈ J := A.2
        simp_all [h_neg]
        <;> aesop
      have h₁₁ : ¬(A.val ∈ I) := h₁₀
      have h₁₂ : A.val ∈ I := by
        have h₁₃ : A.val ∈ I := by
          simp_all [h_final_left]
          <;> aesop
        exact h₁₃
      simp_all
    have h_final : I = J := by
      apply.eq_of_subset_of_subset
      `·` intro N hN
         exact ⟨h_final_left N hN, hN.2⟩
      `·` intro N hN
         exact ⟨h_final_right N hN.1, hN.2⟩
    simp_all [h_final]
