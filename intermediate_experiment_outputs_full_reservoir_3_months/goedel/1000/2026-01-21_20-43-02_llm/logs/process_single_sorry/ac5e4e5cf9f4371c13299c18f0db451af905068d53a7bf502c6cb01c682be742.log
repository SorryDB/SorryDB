```lean
def foo (n : ℕ) : ℕ :=
  let rec fib : ℕ → ℕ := fun n =>
    match n with
    | 0 => 0
    | 1 => 1
    | n + 2 => fib (n + 1) + fib n
  fib n

theorem fib_eq (n : ℕ) : foo n = fib n :=
  have h : ∀ n : ℕ, foo n = fib n := by
    intro n
    dsimp [foo]
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 =>
        rfl
      | 1 =>
        rfl
      | k + 2 =>
        have h₁ := ih (k + 1) (by omega)
        have h₂ := ih k (by omega)
        simp_all [Nat.add_assoc]
        <;> simp_all [fib_add_two]
        <;> ring_nf at *
        <;> linarith
  exact h n
