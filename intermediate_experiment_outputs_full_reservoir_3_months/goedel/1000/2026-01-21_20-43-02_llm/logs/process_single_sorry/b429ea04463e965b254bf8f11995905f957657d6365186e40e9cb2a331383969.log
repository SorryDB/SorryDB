  (h : List (Constraint F) → Constraints F → Prop)
  (h₁ : ∀ (constraints : Constraints F), h (constraints.to_constraints) constraints)
  (h₂ : ∀ (constraints' : Constraints F), h (constraints'.to_constraints) constraints' →
    (h₁ constraints') ∨ (constraints'.is_subsumed))
