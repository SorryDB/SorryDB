theorem CompletenessCore_h_workbook (F : Type) {Input Output : TypeMap} [ProvableType Input] [ProvableType Output] (cc : CompletenessCore F Input Output) (constraints' : Constraints F) (hl : cc.h (constraints'.to_constraints) constraints') :
    cc.h₁ constraints' ∨ constraints'.is_subsumed := by
  have h₂ : ∀ (constraints' : Constraints F), cc.h (constraints'.to_constraints) constraints' → (cc.h₁ constraints') ∨ (constraints'.is_subsumed) := by
    intro constraints' hl
    exact cc.h₂ constraints' hl
  exact h₂ constraints' hl
