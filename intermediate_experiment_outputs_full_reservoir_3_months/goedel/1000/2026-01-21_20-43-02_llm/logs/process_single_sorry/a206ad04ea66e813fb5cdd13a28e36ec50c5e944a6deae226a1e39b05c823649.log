  have h₃ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
  calc
    ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₂
    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr
    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring

lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h₁ : (cfc_toComplexMeasure ha x y).variation Set.univ =
      ‖cfc_toLinearFunctional ha x y‖ := by
    simp [ComplexRMK.illes_rieszMeasure, MeasureTheory.additive.one_le, MeasureTheory.additive.total]
    <;>
    simp_all [ContinuousLinearMap.norm_def, norm_eq_abs, toLinearFunctional_apply]
    <;>
