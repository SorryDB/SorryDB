    have h₃₁ : (‖x‖ : ℝ) ≤ ‖x‖ₑ := by
      -- Prove that the norm of x in ℝ is less than or equal to its `norm` in ℂ
      -- (which is actually the square root of the sum of squares of real and imaginary parts)
