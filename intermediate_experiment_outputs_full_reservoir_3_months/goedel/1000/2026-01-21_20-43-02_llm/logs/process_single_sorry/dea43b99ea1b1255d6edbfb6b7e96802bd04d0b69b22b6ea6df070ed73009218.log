      "\n  have h₁ : (Pr[=true | do let b ←$ᵗ Bool; let b' ← ob; return !decide (b = b')]) = 1 - Pr[=true | do let b ←$ᵗ Bool; let b' ← ob; return decide (b = b')] := by\n    calc\n      (Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')]) =\n          1 - Pr[≠true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')] := by\n        rw [← one_sub_eq]\n        <;>\n        simp [unique_probFailure, probFailure_of_comp]\n        <;>\n        aesop\n      _ = 1 - Pr[=false | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')] := by\n        simp [ne_eq, DecidableEq]\n        <;>\n        aesop\n      _ = 1 - (1 - Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) := by\n        calc\n          (1 - Pr[= false | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')]) =\n              1 - (1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')]) := by\n            have h₂ : Pr[= false | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')] = 1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')] := by\n              simp [eq_self_iff_true, add_comm]\n              <;>\n              aesop\n            rw [h₂]\n          _ = 1 - (1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) := by\n            have h₃ : Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')] = 1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')] := by\n              simp only [not_eq, tetraEq_iff, or_false_iff, false_or_iff] at *\n              <;>\n              simp_all [not_eq, tetraEq_iff, or_false_iff, false_or_iff, probOutput_bind_eq_sum_fintype]\n              <;>\n              ring_nf at *\n              <;>\n              norm_num at *\n              <;>\n              (try omega)\n              <;>\n              (try\n                {\n                  simp_all [Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_comm]\n                  <;>\n                  ring_nf at *\n                  <;>\n                  norm_num at *\n                  <;>\n                  (try omega)\n                })\n              <;>\n              (try\n                {\n                  simp_all [Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_comm]\n                  <;>\n                  ring_nf at *\n                  <;>\n                  norm_num at *\n                  <;>\n                  (try omega)\n                  <;>\n                  (try linarith)\n                })\n              <;>\n              (try\n                {\n                  simp_all [Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_comm]\n                  <;>\n                  ring_nf at *\n                  <;>\n                  norm_num at *\n                  <;>\n                  (try omega)\n                  <;>\n                  (try linarith)\n                })\n            rw [h₃]\n            <;>\n            simp_all [sub_sub, sub_eq_add_neg]\n            <;>\n            ring_nf at *\n            <;>\n            norm_num at *\n            <;>\n            (try omega)\n            <;>\n            (try linarith)\n          _ = 1 - (1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) := by rfl\n      _ = 1 - (1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) := by rfl\n      _ = 1 - Pr[= true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')] := by\n        ring_nf at *\n        <;>\n        norm_num at *\n        <;>\n        aesop\n  \n  have h₂ : (Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) = Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')] := by\n    rfl\n  \n  have h₃ : (Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return !decide (b = b')]) = (1 - Pr[=true | do let b ← $ᵗ Bool; let b' ← ob; return decide (b = b')]) := by\n    rw [h₁]\n    <;>\n    simp_all [sub_sub, sub_eq_add_neg]\n    <;>\n    r