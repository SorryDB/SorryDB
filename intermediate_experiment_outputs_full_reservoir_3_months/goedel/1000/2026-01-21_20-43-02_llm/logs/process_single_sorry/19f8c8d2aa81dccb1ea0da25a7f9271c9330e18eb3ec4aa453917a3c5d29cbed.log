lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  have h₁ : i < w := by
    have h₂ : i < Vector.size args := by
      simp_all [Vector.size]
      <;> omega
    have h₃ : Vector.size args = w := by simp [Vector.size]
    linarith
  
  have h₂ : ¬args[i] = 0 := by tauto
  have h₃ : ¬args[i] = 1 := by tauto
  
  have h₄ : (args[i] : ZMod p) ≠ 0 := by
    intro h₅
    apply h₂
    simpa [h₅] using ZMod.val_zero.eq (by assumption)
  have h₅ : (args[i] : ZMod p) ≠ 1 := by
    intro h₆
    apply h₃
    simpa [h₆] using ZMod.val_one (by assumption)
  
  have h₆ : (args[i] : ZMod p) * (1 - args[i]) ≠ 0 := by
    have h₇ : (1 : ZMod p) - args[i] ≠ 0 := by
      intro h₈
      have h₉ : (1 : ZMod p) = args[i] := by
        rw [← sub_eq_zero] at h₈
        simp_all [sub_eq_zero]
        <;> ring_nf at *
        <;> simp_all [ZMod.nat_cast_self]
      apply h₅
      simp_all [sub_eq_add_neg]
      <;> aesop
    have h₈ : (args[i] : ZMod p) ≠ 0 := h₄
    intro h₉
    have h₁₀ : (args[i] : ZMod p) = 0 ∨ (1 : ZMod p) - args[i] = 0 := by
      simpa [sub_eq_zero, mul_eq_mul_left_iff] using h₉
    cases h₁₀ with
    | inl h₁₀ =>
      exact h₈ h₁₀
    | inr h₁₀ =>
      exact h₇ h₁₀
  
  have h₇ : (DecidableEq (ZMod p)) := inferInstance
  @decide
