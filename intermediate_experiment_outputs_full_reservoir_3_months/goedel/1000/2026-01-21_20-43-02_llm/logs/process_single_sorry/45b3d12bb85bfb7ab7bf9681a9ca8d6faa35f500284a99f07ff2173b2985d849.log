def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set ↑A}
    (h : val_image U A X1 = val_image U A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x : U) ∈ val_image U A X1 := by
    refine' ⟨x, hx, rfl⟩
  have h₂ : (x : U) ∈ val_image U A X2 := by
    rw [h] at h₁
    exact h₁
  -- Extract the element from X2 that maps to x
  rcases h₂ with ⟨y, hy, hy'⟩
  -- Since x and y are both in A and their coerced values are equal, x = y in A
  have h₃ : (x : U) = (y : U) := by simpa using hy'
  have h₄ : x = y := by
    apply Subtype.ext
    simpa using h₃
  -- Since y is in X2 and x = y, x is in X2
  rw [h₄]
  exact hy
