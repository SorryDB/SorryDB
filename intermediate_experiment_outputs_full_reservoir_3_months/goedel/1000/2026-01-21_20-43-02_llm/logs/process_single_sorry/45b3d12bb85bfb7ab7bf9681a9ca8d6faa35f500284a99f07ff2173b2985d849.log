  have h₃ : (x : U) = (y : U) := by simpa using hy'
  have h₄ : y ∈ X2 := hy
  have h₅ : x = y := by
    have h₅₁ : (x : U) = (y : U) := h₃
    exact Subtype.ext h₅₁
  rw [h₅] at hx
  exact hx
