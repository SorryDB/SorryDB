lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h1 : x.val ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp
  have h2 : x.val ∈ val_image A X2 := by
    rw [h] at h1
    exact h1
  have h3 : ∃ (y : A), y ∈ X2 ∧ y.val = x.val := by
    simpa [val_image] using h2
  obtain ⟨y, hy, hy'⟩ := h3
  have h4 : x = y := by
    apply Subtype.ext
    <;> simp_all [Subtype.ext_iff]
  rw [h4]
  exact hy
