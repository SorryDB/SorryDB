def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  have h₁ : ∀ (x : A), x ∈ X1 → x ∈ X2 := by
    intro x hx
    have h₂ : (x : U) ∈ val_image A X1 := by
      refine' ⟨x, hx, _⟩
      <;> simp
    have h₃ : (x : U) ∈ val_image A X2 := by
      rw [h] at h₂
      exact h₂
    -- Since (x : U) is in val_image A X2, there exists some y ∈ X2 such that y.val = x.val.
    -- But x : A and y : A, and A is a subtype of U, so y.val = x.val implies y = x.
    -- Therefore, x ∈ X2.
    obtain ⟨y, hy, hy'⟩ := h₃
    have h₄ : (y : U) = (x : U) := by
      simp_all [Subtype.ext_iff]
      <;> aesop
    have h₅ : y = x := by
      apply Subtype.ext
