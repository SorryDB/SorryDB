```lean
def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set ↑A}
    (h : val_image U A X1 = val_image U A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x : U) ∈ val_image U A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp [Subtype.coe_mk]
  
  have h₂ : (x : U) ∈ val_image U A X2 := by
    rw [h] at h₁
    exact h₁
  
  have h₃ : ∃ (y : ↑A), y ∈ X2 ∧ (x : U) = (y : U) := by
    -- Extract the element y from X2 such that (x : U) = (y : U)
    have h₃ : (x : U) ∈ val_image U A X2 := h₂
    -- Use the definition of val_image to get the required y
    simp only [val_image, Set.mem_setOf_eq] at h₃
    -- Obtain y from the existential statement
    obtain ⟨y, hy, hy'⟩ := h₃
    -- Refine the existential statement with y
    refine' ⟨y, hy, _⟩
    -- Simplify the equality (x : U) = (y : U)
    <;> simp_all [Subtype.coe_mk]
    <;> aesop
  
  have h₄ : ∃ (y : ↑A), y ∈ X2 ∧ x = y := by
    obtain ⟨y, hy, hy'⟩ := h₃
    refine' ⟨y, hy, _⟩
    -- Since x and y are in A and their coercions to U are equal, x = y in A
    apply Subtype.ext
    simpa using hy'
  
  have h₅ : x ∈ X2 := by
    obtain ⟨y, hy, hy'⟩ := h₄
    rw [hy']
    exact hy
  
  exact h₅
``` 

