lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set ↑A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x : U) ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp [Subtype.val]
  have h₂ : (x : U) ∈ val_image A X2 := by
    rw [h] at h₁
    exact h₁
  obtain ⟨y, hy, hy'⟩ := h₂
  have h₃ : x = y := by
    have h₄ : (x : U) = (y : U) := by
      simp_all [Subtype.val]
    have h₅ : x = y := by
      cases x
      cases y
      simp_all [Subtype.ext_iff]
      <;> aesop
    exact h₅
  rw [h₃]
  exact hy
```

