  {y : U | ∃ x ∈ X, x.val = y}

lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set ↑A}
    (h : val_image U A X1 = val_image U A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x : U) ∈ val_image U A X1 := by sorry
  have h₂ : (x : U) ∈ val_image U A X2 := by sorry
  have h₃ : ∃ (y : ↑A), y ∈ X2 ∧ (x : U) = (y : U) := by sorry
  have h₄ : ∃ (y : ↑A), y ∈ X2 ∧ x = y := by sorry
  have h₅ : x ∈ X2 := by sorry
  sorry
``` 

