theorem key_inequality (n : ℕ) (x y : ℝ) :
    (x + y) ^ n = ∑ k in Finset.range (n + 1), (n.choose k) • x ^ k * y ^ (n - k) := by
  have h : (x + y) ^ n = ∑ k in Finset.range (n + 1), (n.choose k : ℝ) * x ^ k * y ^ (n - k) := by
    have h₁ : (x + y) ^ n = ∑ k in Finset.range (n + 1), (n.choose k : ℝ) * x ^ k * y ^ (n - k) := by
      rw [add_pow]
      <;> simp [mul_assoc, mul_comm, mul_left_comm, Finset.sum_range_succ, add_mul]
      <;> norm_cast
      <;> field_simp
      <;> ring_nf
      <;> norm_num
      <;> simp_all [Nat.choose_succ_succ, add_mul, mul_add, mul_assoc, mul_comm, mul_left_comm]
      <;> linarith
    exact h₁
  have h₂ : ∑ k in Finset.range (n + 1), (n.choose k : ℝ) * x ^ k * y ^ (n - k) = ∑ k in Finset.range (n + 1), (n.choose k : ℝ) • (x ^ k * y ^ (n - k)) := by
    apply Finset.sum_congr rfl
    intro k hk
    <;> simp [smul_eq_mul, mul_assoc]
    <;> ring_nf
    <;> norm_num
    <;> simp_all [Nat.choose_succ_succ, add_mul, mul_add, mul_assoc, mul_comm, mul_left_comm]
    <;> linarith
  have h₃ : ∑ k in Finset.range (n + 1), (n.choose k : ℝ) • (x ^ k * y ^ (n - k)) = ∑ k in Finset.range (n + 1), (n.choose k) • x ^ k * y ^ (n - k) := by
    apply Finset.sum_congr rfl
    intro k hk
    <;> simp [smul_eq_mul, mul_assoc]
    <;> ring_nf
    <;> norm_num
    <;> simp_all [Nat.choose_succ_succ, add_mul, mul_add, mul_assoc, mul_comm, mul_left_comm]
    <;> linarith
  calc
    (x + y) ^ n = ∑ k in Finset.range (n + 1), (n.choose k : ℝ) * x ^ k * y ^ (n - k) := h
    _ = ∑ k in Finset.range (n + 1), (n.choose k : ℝ) • (x ^ k * y ^ (n - k)) := by
      rw [h₂]
    _ = ∑ k in Finset.range (n + 1), (n.choose k) • x ^ k * y ^ (n - k) := by
      rw [h₃]
