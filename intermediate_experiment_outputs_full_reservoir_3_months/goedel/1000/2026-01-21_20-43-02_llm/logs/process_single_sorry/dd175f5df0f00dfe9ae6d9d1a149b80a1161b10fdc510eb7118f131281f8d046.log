      "by\n    have h₁ : MeasurableEmbedding edgeSet := measurableEmbedding_edgeSet\n    have h₂ : Measure.map (fun ω => (G ω)ᶜ) P = (G(V, σ p)) := by\n      have h₃ : MeasurableEmbedding edgeSet := measurableEmbedding_edgeSet\n      have h₄ : Measure.map (edgeSet ∘ (fun ω => (G ω)ᶜ)) P = Ber (diagSetᶜ) (σ p) := by\n        have h₅ : HasLaw (fun ω => (G ω)ᶜ) G(V, σ p) P := by\n          have h₆ : HasLaw G G(V, p) P := hG\n          have h₇ : G(V, σ p) = (G(V, p)).map (fun G => Gᶜ) := by\n            simp [binomialRandom_eq_map]\n            <;>\n            simp_all [Measure.map_comp]\n            <;>\n            congr 1 <;>\n            ext <;>\n            simp (config := { contextual := true }) [Set.compl_compl, Set.compl_eq_empty]\n            <;>\n            aesop\n          have h₈ : HasLaw (fun ω => (G ω)ᶜ) ((G(V, p)).map (fun G => Gᶜ)) P := by\n            have h₉ : HasLaw (fun ω => (G ω)ᶜ) ((G(V, p)).map (fun G => Gᶜ)) P := by\n              have h₁₀ : (fun ω => (G ω)ᶜ) = (fun G => Gᶜ) ∘ G := by\n                ext <;> simp\n              rw [h₁₀]\n              exact h₆.map _\n            exact h₉\n          rw [h₇] at *\n          exact h₈\n        have h₁₁ : HasLaw (edgeSet ∘ (fun ω => (G ω)ᶜ)) (edgeSet ∘ (fun G => Gᶜ)) P := by\n          have h₁₂ : Measurable (fun ω => (G ω)ᶜ) := by\n            intro\n            have h₁₃ : Measurable G := by\n              have h₁₄ : HasLaw G G(V, p) P := hG\n              exact h₁₄.measurable\n            have h₁₅ : Measurable (fun ω => (G ω)ᶜ) := by\n              apply Measurable.compl\n              exact h₁₃\n            exact h₁₅\n          have h₁₆ : Measurable (fun G => Gᶜ) := by\n            apply Measurable.compl\n            apply measurable_id\n          have h₁₇ : HasLaw (fun ω => (G ω)ᶜ) ((G(V, p)).map (fun G => Gᶜ)) P := by\n            have h₁₈ : HasLaw G G(V, p) P := hG\n            have h₁₉ : HasLaw (fun ω => (G ω)ᶜ) ((G(V, p)).map (fun G => Gᶜ)) P := by\n              have h₂₀ : (fun ω => (G ω)ᶜ)