      "by\n    have h_main : (Measure.map (fun ω ↦ (G ω)ᶜ) P) = (G(V, σ p)) := by\n      rw [hG.map_eq]\n      -- Now we need to show that the image of the map G(V, p) under the complement operation is G(V, σ p)\n      -- This can be done by understanding that (G(V, p)) ∘ (·ᶜ)⁻¹ = G(V, σ p)\n      -- For each graph G, the complement is Gᶜ, and the probability of Gᶜ is the same as the probability of G in G(V, σ p)\n      -- Therefore, we can directly show this using the properties of the binomial distribution and the complement of the graph\n      have h₁ : (G(V, σ p)) = (G(V, p)).image (fun G : SimpleGraph V => Gᶜ) := by\n        -- Use the fact that the measure on the complement graph is the same as the measure on the original graph with the complement probability\n        -- We can use the properties of the binomial distribution and the complement of the graph to show this\n        rw [binomialRandom_apply]\n        rw [binomialRandom_apply]\n        -- Here we need to show that the probability of the complement graph is the same as the probability of the original graph with the complement probability\n        -- This is a direct consequence of the properties of the binomial distribution and the complement of the graph\n        <;> simp [symm_eq_toNNReal, Real.compl_mul, mul_comm]\n        <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg])\n        <;>\n        (try ring_nf) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg]) <;>\n        (try simp_all [toNNReal_of_nonneg, Real.compl_nonneg])\n      -- Now we need to show that the measure of the image is the same as the image of the measure\n      -- This is done using the properties of the complement function and the binomial distribution\n      calc\n        (Measure.map (fun ω ↦ (G ω)ᶜ) (G(V, p))) = (G(V, p)).image (fun G : SimpleGraph V => Gᶜ) := by\n          -- The image of the map is the measure on the complement graph\n          rw [Measure.map_image]\n          <;>\n          (try simp_all [Function.Injective]) <;>\n          (try {use G; funext v; simp [v] }) <;>\n          (try {use v; funext w; simp [w] }) <;>\n          (try {\n            ext v w\n            <;>\n            simp [SimpleGraph.compl_apply]\n            <;>\n            tauto\n          })\n          <;>\n          (try {\n            aesop\n          }) <;>\n          (try {\n            simp_all [Function.Injective]\n            <;>\n            aesop\n          })\n          <;>\n          (try {\n            refine' fun G₁ G₂ h => _\n            <;>\n            (try simp_all [Fintype.card_eq_zero])\n            <;>\n            aesop\n          })\n          <;>\n          (try {\n            aesop\n          })\n        _ = (G(V, σ p)) := by rw [h₁]\n    -- Finally, we use the main result to complete the proof\n    exact h_main\n  <;> try simp_all [IsBinomialRandom]\n  <;> try simp_all [HasLaw]",
      "by\n    have h₁ : G(V, p) = map fromEdgeSet Ber(diagSetᶜ, p) := by\n      rw [binomialRandom_eq_map]\n    have h₂ : map (fun ω => (G ω)ᶜ) P = G(V, unitInterval.symm p) := by\n      have h₃ : IsBinomialRandom G p P := hG\n      have h₄ : HasLaw G (G(V, p)) P := h₃\n      have h₅ : HasLaw (fun ω => (G ω)ᶜ) (G(V, unitInterval.symm p)) P :=\n        by\n          have h₆ : HasLaw (fun ω => (G ω)ᶜ) (map (fun (G : SimpleGraph V) => Gᶜ) (G(V, p))) P :=\n            h₄.map (fun (G : SimpleGraph V) => Gᶜ)\n          have h₇ : map (fun (G : SimpleGraph V) => Gᶜ) (G(V, p)) = G(V, unitInterval.symm p) := by\n            calc\n              map (fun (G : SimpleGraph V) => Gᶜ) (G(V, p)) = map (fun (G : SimpleGraph V) => Gᶜ) (map fromEdgeSet Ber(diagSetᶜ, p)) := by\n                rw [← h₁]\n              _ = map (fun (G : SimpleGraph V) => Gᶜ) (map fromEdgeSet Ber(diagSetᶜ, p)) := rfl\n              _ = map (fun S => (fromEdgeSet S)ᶜ) (map (fun (S : Set (Sym2 V)) => S) (Ber(diagSetᶜ, p))) := by\n                simp [Function.comp_def]\n                <;>\n                  congr 1 <;>\n                  ext <;>\n                  simp [Set.ext_iff] <;>\n                  aesop\n              _ = map (fun S => (fromEdgeSet S)ᶜ) (Ber(diagSetᶜ, p)) := by\n                simp [map_map]\n                <;>\n                  congr 1 <;>\n                  ext <;>\n                  simp [Set.ext_iff] <;>\n                  aesop\n              _ = G(V, unitInterval.symm p) := by\n                calc\n                  map (fun S => (fromEdgeSet S)ᶜ) (Ber(diagSetᶜ, p)) = map (fun S => (fromEdgeSet S)ᶜ) (Ber(diagSetᶜ, p)) := rfl\n                  _ = G(V, unitInterval.symm p) := by\n                    rw [binomialRandom_eq_map]\n                    <;>\n                  simp [Function.comp_def, SimplyGraph.map_fromEdgeSet_compl]\n                    <;>\n                  congr 1 <;>\n                  ext <;>\n                  simp [Set.ext_iff]\n                    <;>\n                  aesop\n          rw [h₇] at h₆\n          exact h₆\n        exact h₅\n      have h₈ : map (fun ω => (G ω)ᶜ) P = G(V, unitInterval.symm p) := by\n        have h₉ : HasLaw (fun ω => (G ω)ᶜ) (G(V, unitInterval.symm p)) P := h₅\n        have h₁₀ : map (fun ω => (G ω)ᶜ) P = G(V, unitInterval.symm p) := by\n          apply HasLaw.map\n          exact h₉\n        exact h₁₀\n      exact h₈\n    rw [h₂]\n    <;>\n      simp_all [IsBinomialRandom]",
