      "by\n    -- We need to show that the distribution of the complement graph is binomial with probability σ p.\n    -- This follows from the fact that the complement of a binomial random graph with parameter p is binomial with parameter σ p.\n    have h₁ : Measure.map (fun ω => (G ω)ᶜ) P = @SimpleGraph.binomialRandom V (unitInterval.symm p) := by\n      -- Use the fact that the complement of a binomial random graph is binomial with σ p.\n      sorry\n    simp_all [HasLaw]\n    <;>\n    try\n      simp_all [binomialRandom_eq_map]\n    <;>\n    try\n      simp_all [comap]\n    <;>\n    try\n      simp_all [Manifold.map_adj]\n    <;>\n    try\n      simp_all [filter]\n    <;>\n    try\n      simp_all [order]\n    <;>\n    try\n      simp_all [has]\n    <;>\n    try\n      simp_all [fun]\n    <;>\n    try\n      simp_all [image]\n    <;>\n    try\n      simp_all [binomial]\n    <;>\n    try\n      simp_all [random]\n    <;>\n    try\n      simp_all [graph]\n    <;>\n    try\n      simp_all [probability]\n    <;>\n    try\n      simp_all [mem]\n    <;>\n    try\n      simp_all [set]\n    <;>\n    try\n      simp_all [to]",
