  by
  -- Use the `add_assoc` instance to directly apply the associativity property
  have h : a + (b + c) = (a + b) + c := by
    -- Since `AddAssoc α` is in scope, we can use the built-in associativity lemma
    apply add_assoc
  -- The result follows directly from the associativity property
  exact h
