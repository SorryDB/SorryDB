### Solution

```lean
def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [RingHom.map_one]
  map_mul' := by
    intros x y
    have h1 : f (x * y) = f x * f y := by
      apply f.map_mul
    have h2 : g (f (x * y)) = g (f x * f y) := by
      rw [h1]
    have h3 : g (f x * f y) = g (f x) * g (f y) := by
      apply g.map_mul
    calc
      g (f (x * y)) = g (f x * f y) := h2
      _ = g (f x) * g (f y) := h3
