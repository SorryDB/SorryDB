def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro a b ha hb
    -- Since a and b are in both I and J, we need to show that a + b is in both I and J.
    have h₁ : a ∈ I := ha.1
    have h₂ : a ∈ J := ha.2
    have h₃ : b ∈ I := hb.1
    have h₄ : b ∈ J := hb.2
    -- Since I and J are ideals, they are additive subgroups, so a + b is in both I and J.
    have h₅ : a + b ∈ I := I.add_mem h₁ h₃
    have h₆ : a + b ∈ J := J.add_mem h₂ h₄
    exact ⟨h₅, h₆⟩
