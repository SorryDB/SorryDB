def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro a b ha hb
    have ha' : a ∈ I := ha.1
    have hb' : b ∈ I := hb.1
    have ha'' : a ∈ J := ha.2
    have hb'' : b ∈ J := hb.2
    exact ⟨I.add_mem ha' hb', J.add_mem ha'' hb''⟩
