    ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  -- Step 1: Show that for any test function φ, the integrals of φ x • f x and φ x • f' x are equal
  have h₁ : ∀ (φ : 𝓓^{n}(Ω, ℝ)), (∫ x, φ x • f x ∂μ.restrict Ω) = (∫ x, φ x • f' x ∂μ.restrict Ω) := by sorry

  -- Step 2: Use the integral equality to show that the distributions are equal in all cases
  have h₂ : ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by sorry

  -- Final conclusion
  exact h₂
