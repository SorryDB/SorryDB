lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
    ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  have h₁ : ∀ (φ : 𝓓^{n}(Ω, ℝ)), (∫ x, φ x • f x ∂μ.restrict Ω) = (∫ x, φ x • f' x ∂μ.restrict Ω) := by
    intro φ
    have h₂ : (∫ x, φ x • f x ∂μ.restrict Ω) = (∫ x, φ x • f' x ∂μ.restrict Ω) := by
      -- Use the fact that f and f' are equal almost everywhere on Ω
      have h₃ : f =ᵐ[μ.restrict Ω] f' := h
      have h₄ : (fun x => φ x • f x) =ᵐ[μ.restrict Ω] (fun x => φ x • f' x) := by
        filter_upwards [h₃] with x hx
        simp [hx]
        <;>
        simp_all [smul_eq_mul]
        <;>
        ring_nf
        <;>
        simp_all [smul_eq_mul]
        <;>
        linarith
      -- Apply the integral_congr_ae lemma to show the integrals are equal
      have h₅ : (∫ x, φ x • f x ∂μ.restrict Ω) = (∫ x, φ x • f' x ∂μ.restrict Ω) := by
        apply integral_congr_ae h₄
      exact h₅
    exact h₂
  -- Use the fact that the integrals are equal to show the distributions are equal
  have h₂ : ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
    funext φ
    by_cases hf : LocallyIntegrableOn f Ω μ
    · by_cases hf' : LocallyIntegrableOn f' Ω μ
      · -- Case: Both f and f' are locally integrable on Ω
        have h₃ : (∫ x, φ x • f x ∂μ.restrict Ω) = (∫ x, φ x • f' x ∂μ.restrict Ω) := h₁ φ
        simp_all [ofFunWithOrder, TestFunction.integralAgainstBilinCLM_apply, TestFunction.integralOn]
        <;>
        simp_all [ofFunWithOrder, TestFunction.integralAgainstBilinCLM_apply, TestFunction.integralOn]
        <;>
        aesop
      · -- Case: f is locally integrable but f' is not
        exfalso
        have h₃ : ¬LocallyIntegrableOn f' Ω μ := hf'
        have h₄ : LocallyIntegrableOn f Ω μ := hf
        have h₅ : f =ᵐ[μ.restrict Ω] f' := h
        have h₆ : LocallyIntegrableOn f' Ω μ := by
          have h₇ : LocallyIntegrableOn f Ω μ := hf
          have h₈ : f =ᵐ[μ.restrict Ω] f' := h
          exact locallyIntegrableOn_ae_congr h₈ h₇
        contradiction
    · -- Case: f is not locally integrable on Ω
      by_cases hf' : LocallyIntegrableOn f' Ω μ
      · -- Case: f' is locally integrable but f is not
        exfalso
        have h₃ : ¬LocallyIntegrableOn f Ω μ := hf
        have h₄ : LocallyIntegrableOn f' Ω μ := hf'
        have h₅ : f =ᵐ[μ.restrict Ω] f' := h
        have h₆ : LocallyIntegrableOn f Ω μ := by
          have h₇ : LocallyIntegrableOn f' Ω μ := hf'
          have h₈ : f =ᵐ[μ.restrict Ω] f' := h
          exact locallyIntegrableOn_ae_congr h₈.symm h₇
        contradiction
