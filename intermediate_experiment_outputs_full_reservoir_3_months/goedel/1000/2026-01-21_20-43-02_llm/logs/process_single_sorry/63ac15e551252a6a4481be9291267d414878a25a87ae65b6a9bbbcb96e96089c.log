        sorry
      rw [h₈] at h₇
      simpa [h₇] using h₃
    have h₄ : (infiniteProd (fun i => (p * q : I) : ι → I)) = Ber(u, (p * q : I)) := by
      sorry
    rw [h₄] at h₃
    simpa [h₃] using h₃
  
  aemeasurable := by
    have h₁ : IsBernoulliOn X u p P := hX
    have h₂ : IsBernoulliOn Y u q P := hY
    have h₃ : AEMeasurable (fun ω : Ω => X ω ∩ Y ω) P := by
      have h₄ : AEMeasurable X P := by
        exact h₁.aemeasurable
      have h₅ : AEMeasurable Y P := by
        exact h₂.aemeasurable
      have h₆ : AEMeasurable (fun ω : Ω => X ω ∩ Y ω) P := by
        -- Use the fact that the intersection of two measurable functions is measurable
        refine' AEMeasurable.congr (h₄.inf h₅) _
        -- Show that the intersection of the sets is the same as the intersection of the functions
