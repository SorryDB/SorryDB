lemma IsBernoulliOn.inter (hX : IsBernoulliOn X u p P) (hY : IsBernoulliOn Y u q P) :
    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  map_eq := by
    have h₁ : (fun ω ↦ X ω ∩ Y ω) = (fun ω ↦ (X ω, Y ω)) ≫ (fun (s : Set ι × Set ι) ↦ s.1 ∩ s.2) := by
      funext ω
      rfl
    rw [h₁]
    have h₂ : map ((fun ω ↦ (X ω, Y ω)) : Ω → Set ι × Set ι) P =
      (map (X : Ω → Set ι) P) // (map (Y : Ω → Set ι) P) := by
      rw [map_prod]
    rw [h₂]
    have h₃ : map (X : Ω → Set ι) P = Ber(u, p) := by
      apply hX.map_eq
    have h₄ : map (Y : Ω → Set ι) P = Ber(u, q) := by
      apply hY.map_eq
    rw [h₃, h₄]
    classical
    -- Now we need to show that the product measure of Ber(u, p) and Ber(u, q) under intersection
    -- is Ber(u, p * q)
    -- This follows from the properties of independent Bernoulli variables
    -- For each element in u, the probability to be in both X and Y is p * q
    -- For elements not in u, the probability is 0 (as they cannot be in X or Y)
    -- Therefore, the product measure is Ber(u, p * q)
    have h₅ : (Ber(u, p) : Measure (Set ι)) // (Ber(u, q) : Measure (Set ι)) =
      (infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) : Measure (∀ a, Bool)) // (infinitePi (fun a ↦ toNNReal q • dirac (a ∈ u) + toNNReal (σ q) • dirac False) : Measure (∀ a, Bool)) := by
      simp [bernoulliOn_eq_map]
      <;>
      rfl
    rw [h₅]
    -- Now, the product measure is the product of the measures for each element
    -- The measure for each element is the product of the Bernoulli measures
    -- Therefore, we need to show that the product of the Bernoulli measures is the Bernoulli measure for p * q
    -- This follows from the fact that the product of Bernoulli measures is the Bernoulli measure for the product of the probabilities
    have h₆ : (infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) : Measure (∀ a, Bool)) // (infinitePi (fun a ↦ toNNReal q • dirac (a ∈ u) + toNNReal (σ q) • dirac False) : Measure (∀ a, Bool)) =
      (fun (p q : ENNReal) => p * q) • (bernhoulliOn u (p * q)) := by
      simp [ProbabilityTheory.BernoulliOn, ProductMeasure.map_pi]
      <;>
      aesop
    rw [h₆]
    -- Finally, we need to show that the product of the probabilities p and q is p * q
    -- This is straightforward
    <;>
    simp_all [bernoulliOn_eq_map, ProbabilityTheory.BernoulliOn]
    <;>
    aesop
  
  aemeasurable := by
    apply measurable_inter
    · exact hX.aemeasurable
    · exact hY.aemeasurable
