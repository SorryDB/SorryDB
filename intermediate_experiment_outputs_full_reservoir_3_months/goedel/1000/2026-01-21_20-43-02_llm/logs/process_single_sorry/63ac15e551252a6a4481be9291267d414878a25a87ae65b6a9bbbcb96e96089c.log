```lean4
theorem isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=
  hasLaw_congr hXY

lemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :
    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where
  aemeasurable_fst := by fun_prop
  aemeasurable_snd := by fun_prop
  map_eq := by
    have h₁ : HasLaw X (BernoulliOn u p) P := hX
    have h₂ : ∀ (k : ι), k ∈ u → IdentDistrib (fun ω => k ∈ X ω) (bernoulli p) P := by
      intro k hk
      have h₃ : HasLaw (fun ω => k ∈ X ω) (bernoulli p) P := by sorry
      exact h₃.identDistrib
    have h₃ : IdentDistrib (fun ω => i ∈ X ω) (bernoulli p) P := h₂ i hi
    have h₄ : IdentDistrib (fun ω => j ∈ X ω) (bernoulli p) P := h₂ j hj
    have h₅ : IdentDistrib (fun ω => i ∈ X ω) (fun ω => j ∈ X ω) P P := by
      calc
        IdentDistrib (fun ω => i ∈ X ω) (bernoulli p) P := h₃
        _ = IdentDistrib (fun ω => i ∈ X ω) (bernoulli p) P := rfl
        _ ≈ IdentDistrib (fun ω => j ∈ X ω) (bernoulli p) P := by
          -- Since the distributions of both are the same, they are identically distributed
          refine' (h₃.symm.trans _) h₄
        _ = IdentDistrib (fun ω => j ∈ X ω) (bernoulli p) P := rfl
    -- Since both are identically distributed to the same measure, they are identically distributed to each other
    have h₆ : (fun ω => i ∈ X ω) ≈[P] (fun ω => j ∈ X ω) := by
      exact h₅.ae_eq
    exact h₆.symm

