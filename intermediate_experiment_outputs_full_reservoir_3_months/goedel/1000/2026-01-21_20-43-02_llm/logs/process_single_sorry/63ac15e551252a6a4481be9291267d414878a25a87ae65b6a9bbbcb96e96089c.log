        simpa [HasLaw] using h₂.map_fun measurableFrom
      have h₆ : HasLaw (fun ω => (fun i => i ∈ X ω ∧ i ∈ Y ω) : Ω → ι → Bool)
          ((h₄.map_product h₅ : HasLaw (fun ω => ((fun i => i ∈ X ω), (fun i => i ∈ Y ω))) (h₁.map_fst.product h₂.map_fst) P)
            .map (fun ω => (fun i => (fun p : (ι → Bool) × (ι → Bool) => p.1 i && p.2 i) ω))) P := by
        simpa [HasLaw, Function.comp] using h₄.map_product h₅ |>.map (by continuity)
      have h₇ : HasLaw (fun ω => (fun i => i ∈ (X ω ∩ Y ω : Set ι)) : Ω → ι → Bool)
          ((h₄.map_product h₅ : HasLaw (fun ω => ((fun i => i ∈ X ω), (fun i => i ∈ Y ω))) (h₁.map_fst.product h₂.map_fst) P)
            .map (fun ω => (fun i => (fun p : (ι → Bool) × (ι → Bool) => p.1 i && p.2 i) ω))) P := by
        congr 1
        if (arg1 : Ω) : ω => { funext fun (i : ι) => by simp [Set.mem_inter_iff] }
      have h₈ : ((h₄.map_product h₅ : HasLaw (fun ω => ((fun i => i ∈ X ω), (fun i => i ∈ Y ω))) (h₁.map_fst.product h₂.map_fst) P)
