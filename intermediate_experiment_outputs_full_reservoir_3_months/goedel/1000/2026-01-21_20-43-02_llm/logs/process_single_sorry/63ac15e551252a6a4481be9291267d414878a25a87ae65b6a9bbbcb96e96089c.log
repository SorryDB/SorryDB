lemma IsBernoulliOn.inter (hX : IsBernoulliOn X u p P) (hY : IsBernoulliOn Y u q P) :
    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  map_eq := by
    have hA : HasLaw X (Ber u p) P := hX
    have hB : HasLaw Y (Ber u q) P := hY
    have hAB : HasLaw (fun ω ↦ (X ω, Y ω)) (productMeasure (Ber u p) (Ber u q)) P :=
