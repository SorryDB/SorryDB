```lean
theorem imo_1959_p1
  (n : ℕ)
  (h₀ : 0 < n) :
  Nat.gcd (21*n + 4) (14*n + 3) = 1 := by
  have h₁ : Nat.gcd (21 * n + 4) (14 * n + 3) = 1 := by
    -- Use the Euclidean algorithm to find the gcd
    have h₂ : Nat.gcd (21 * n + 4) (14 * n + 3) = Nat.gcd (14 * n + 3) (7 * n + 1) := by
      have h₃ : 21 * n + 4 = 1 * (14 * n + 3) + (7 * n + 1) := by
        ring_nf
        <;> omega
      rw [h₃]
      <;> simp [Nat.gcd_comm, Nat.gcd_assoc]
      <;> ring_nf at *
      <;> omega
    rw [h₂]
    -- Continue simplifying the gcd
    have h₄ : Nat.gcd (14 * n + 3) (7 * n + 1) = Nat.gcd (7 * n + 1) 1 := by
      have h₅ : 14 * n + 3 = 2 * (7 * n + 1) + 1 := by
        ring_nf
        <;> omega
      rw [h₅]
      <;> simp [Nat.gcd_comm, Nat.gcd_assoc]
      <;> ring_nf at *
      <;> omega
    rw [h₄]
    -- The gcd of any number and 1 is 1
    simp [Nat.gcd_one_right]
    <;>
    (try omega)
    <;>
    (try ring_nf at *)
    <;>
    (try omega)
  exact h₁
```

