theorem imo_1959_p1
  (n : ℕ)
  (h₀ : 0 < n) :
  Nat.gcd (21*n + 4) (14*n + 3) = 1 := by
  have h₁ : (21*n + 4).gcd (14*n + 3) = 1 := by
    -- Use the Euclidean algorithm to find the gcd
    have h₂ : (21*n + 4).gcd (14*n + 3) = (14*n + 3).gcd (7*n + 1) := by
      rw [Nat.gcd_comm]
      -- Apply the Euclidean step: gcd(a, b) = gcd(b, a % b)
      -- (21n + 4) = 1 * (14n + 3) + (7n + 1)
      have h₃ : 21*n + 4 = 1 * (14*n + 3) + (7*n + 1) := by
        ring_nf
        <;> omega
      rw [← h₃]
      simp [Nat.gcd_comm, Nat.gcd_assoc, Nat.gcd_comm]
      <;> simp [Nat.gcd_comm]
      <;> ring_nf at *
      <;> simp_all [Nat.gcd_comm]
    rw [h₂]
    -- Continue with the Euclidean algorithm: gcd(14n + 3, 7n + 1)
    have h₃ : (14*n + 3).gcd (7*n + 1) = (7*n + 1).gcd 1 := by
      rw [Nat.gcd_comm]
      -- Apply the Euclidean step: gcd(a, b) = gcd(b, a % b)
      -- (14n + 3) = 2 * (7n + 1) + 1
      have h₄ : 14*n + 3 = 2 * (7*n + 1) + 1 := by
        ring_nf
        <;> omega
      rw [← h₄]
      simp [Nat.gcd_comm, Nat.gcd_assoc, Nat.gcd_comm]
      <;> simp [Nat.gcd_comm]
      <;> ring_nf at *
      <;> simp_all [Nat.gcd_comm]
    rw [h₃]
    -- Final step: gcd(7n + 1, 1) = 1
    have h₄ : (7*n + 1).gcd 1 = 1 := by
      simp [Nat.gcd_one_right]
    rw [h₄]
  exact h₁
