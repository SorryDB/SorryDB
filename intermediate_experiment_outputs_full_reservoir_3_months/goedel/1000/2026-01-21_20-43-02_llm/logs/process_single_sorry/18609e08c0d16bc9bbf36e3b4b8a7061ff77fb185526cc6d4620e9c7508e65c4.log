```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · intro h
      -- Use the fact that scalar multiplication by r is bounded to deduce interval integrability
      have h₁ : IntervalIntegrable (r • f) μ a b := by
        -- Use the boundedness of scalar multiplication to deduce the integrability of (r • f)
        have h₂ : IntervalIntegrable f μ a b := h
        -- Use the fact that r is bounded to conclude that (r • f) is interval integrable
        refine' IsBoundedSMul.intervalIntegrable_smul_of_integrable _ _
        exact h₂
      exact h₁
    · intro h
      -- Use the fact that scalar multiplication by r is bounded to deduce interval integrability
      have h₁ : IntervalIntegrable (r • f) μ a b := h
      -- Use the boundedness of scalar multiplication to deduce the integrability of f
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that r is invertible (since it's in a normed group) to deduce the integrability of f
        refine' (inferInstance : IsBoundedSMul R E).intervalIntegrable_smul_inv_of_integrable _ _
        exact h₁
      exact h₂
  exact h_main
