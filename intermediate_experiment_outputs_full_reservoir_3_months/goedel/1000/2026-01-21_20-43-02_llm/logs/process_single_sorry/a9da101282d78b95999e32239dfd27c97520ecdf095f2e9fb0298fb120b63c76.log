n                exact h19\n              -- The derivative exists\n              exact h17.differentiableAt\n            })\n          <;>\n          (try\n            {\n              -- No need for further steps\n              simp_all [mul_assoc]\n              <;>\n              norm_num\n              <;>\n              linarith\n            })\n        -- The integral of the derivative is the function evaluated at the bounds\n        exact h16\n      -- Combine the results\n      calc\n        ∫ x in a..b, 2 * x * exp (x ^ 2) = ∫ x in a..b, (exp (x ^ 2))' := by rw [h3]\n        _ = exp (b ^ 2) - exp (a ^ 2) := by rw [h15]\n    -- The final result\n    exact h2\n  -- The final result\n  exact h1",
