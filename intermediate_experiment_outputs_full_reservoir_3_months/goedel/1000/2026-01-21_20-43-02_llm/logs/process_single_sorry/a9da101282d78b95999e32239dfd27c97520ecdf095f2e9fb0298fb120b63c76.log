example (a b : ℝ) : ∫ x in a..b, 2 * x * exp (x ^ 2) =
    exp (b ^ 2) - exp (a ^ 2) := by
  have h₁ : (∫ x in a..b, 2 * x * exp (x ^ 2)) = exp (b ^ 2) - exp (a ^ 2) := by
    -- Use the substitution u = x², du = 2x dx
    have h₂ : ∫ x in a..b, 2 * x * exp (x ^ 2) = ∫ x in a..b, exp (x ^ 2) * (2 * x) := by
      congr
      ext x
      ring
    rw [h₂]
    -- Use the fundamental theorem of calculus to evaluate the integral
    have h₃ : ∫ x in a..b, exp (x ^ 2) * (2 * x) = exp (b ^ 2) - exp (a ^ 2) := by
      -- The antiderivative of exp(x²) * 2x is exp(x²)
      have h₄ : ∫ x in a..b, exp (x ^ 2) * (2 * x) = exp (b ^ 2) - exp (a ^ 2) := by
        -- Use the fact that the derivative of exp(x²) is 2x exp(x²)
        have h₅ : (fun x : ℝ => exp (x ^ 2)) = (fun x : ℝ => exp (x ^ 2)) := rfl
        rw [intervalIntegral.integral_comp_mul_left (fun x => exp (x ^ 2)) (by norm_num : (2 : ℝ) ≠ 0)]
        <;> simp [exp_ne_zero]
        <;> norm_num
        <;> ring_nf
        <;> field_simp [exp_ne_zero]
        <;> ring_nf
        <;> norm_num
        <;> linarith
      exact h₄
    rw [h₃]
  exact h₁
