theorem IsBinomialRandom.identDistrib_mem_edgeSet (hG : IsBinomialRandom G p P) :
    IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
  have h₁ : IsBinomialRandom G p P := hG
  have h₂ : HasLaw G (G(V, p)) P := h₁
  have h₃ : IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
    have h₄ : HasLaw (fun ω : Ω => e₁ ∈ (G ω).edgeSet) (G(V, p).push (fun G : SimpleGraph V => e₁ ∈ (G:SimpleGraph V).edgeSet)) P := by
      apply h₂.comp
      <;>
      (try
        exact measurable_iff_adj.2 fun u v => by
          simp [measurable_const, measurable_id]
          <;>
          aesop)
      <;>
      simp [measurable_const, measurable_id]
      <;>
      aesop
    have h₅ : HasLaw (fun ω : Ω => e₂ ∈ (G ω).edgeSet) (G(V, p).push (fun G : SimpleGraph V => e₂ ∈ (G:SimpleGraph V).edgeSet)) P := by
      apply h₂.comp
      <;>
      (try
        exact measurable_iff_adj.2 fun u v => by
          simp [measurable_const, measurable_id]
          <;>
          aesop)
      <;>
      simp [measurable_const, measurable_id]
      <;>
      aesop
    have h₆ : G(V, p).push (fun G : SimpleGraph V => e₁ ∈ (G:SimpleGraph V).edgeSet) = G(V, p).push (fun G : SimpleGraph V => e₂ ∈ (G:SimpleGraph V).edgeSet) := by
      -- Prove that the distributions of membership in the edge set for e₁ and e₂ are the same
      -- This follows from the symmetry in the definition of the binomial random graph model
      -- where each edge is included with probability p independently.
      have h₇ : (e₁ ∈ (·:SimpleGraph V).edgeSet) = (e₂ ∈ (·:SimpleGraph V).edgeSet) := by
        ext G
        have h₈ : e₁ ∈ G.edgeSet ↔ e₂ ∈ G.edgeSet := by
          cases' Eq.eq_or_ne e₁ e₂ with h h <;> simp_all [Sym2.ext_iff]
          <;>
          (try omega) <;>
          (try
            {
              simp_all [SimpleGraph.mem_adj, SimpleGraph.mem_edgeSet, Sym2.mk.injEq]
              <;>
              aesop
            }) <;>
          (try
            {
              exfalso
              aesop
            })
        simp_all
      rw [h₇]
    have h₇ : IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
      have h₈ : HasLaw (fun ω : Ω => e₁ ∈ (G ω).edgeSet) (G(V, p).push (fun G : SimpleGraph V => e₁ ∈ (G:SimpleGraph V).edgeSet)) P := h₄
      have h₉ : HasLaw (fun ω : Ω => e₂ ∈ (G ω).edgeSet) (G(V, p).push (fun G : SimpleGraph V => e₁ ∈ (G:SimpleGraph V).edgeSet)) P := by
        rw [h₆] at h₅
        exact h₅
      exact h₈.trans h₉.symm
    exact h₇
  exact h₃
