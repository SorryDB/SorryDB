theorem Lean4ProofSketch (V : Type) [IsCountable V] (m : MeasurableSpace V) : 
    ∃ (f : V → V), ∀ v w : V, f v ≠ f w → v ≠ w := by
  have h_main : ∃ (f : V → V), ∀ v w : V, f v ≠ f w → v ≠ w := by
    classical
    -- Use the fact that V is countable to construct an injection from V to ℕ
    have h : Nonempty (V ≃ ℕ) := by
      apply IsCountable.nonempty_equiv_nat
      <;> infer_instance
    -- Obtain the equivalence between V and ℕ
    obtain ⟨e⟩ := h
    -- Use the equivalence to define an injective function from V to V
    use fun v => e.symm (e v + 1)
    intro v w h₁
    -- Show that the function is injective
    have h₂ : e.symm (e v + 1) = e.symm (e w + 1) → v = w := by
      intro h₂
      have h₃ : e v + 1 = e w + 1 := by
        apply e.injective
        simpa using h₂
      have h₄ : e v = e w := by
        omega
      have h₅ : v = w := by
        apply e.injective
        simpa using h₄
      exact h₅
    -- Conclude the proof by contraposition
    contrapose! h₁
    apply h₂
    <;> simp_all
  -- Use the main result to conclude the proof
  exact h_main
