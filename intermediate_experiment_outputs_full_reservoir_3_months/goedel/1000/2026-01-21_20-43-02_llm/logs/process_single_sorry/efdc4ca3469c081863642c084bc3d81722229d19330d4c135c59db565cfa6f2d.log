        have h₇ : (G(V, p)).map (fun G => e₁ ∈ G.edgeSet) = (G(V, p)).map (fun G => e₂ ∈ G.edgeSet) := by
          -- The probability that e₁ is in the edge set is p, and similarly for e₂.
