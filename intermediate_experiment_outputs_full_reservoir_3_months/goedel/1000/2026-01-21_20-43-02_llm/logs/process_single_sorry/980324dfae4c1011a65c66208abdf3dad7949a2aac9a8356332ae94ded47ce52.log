      intro h
      have h₁ : Maximal (fun S : Set α => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
        refine' ⟨hI_exists, _⟩
        intro T hT hT_I
        exact h T hT hT_I
      contradiction
