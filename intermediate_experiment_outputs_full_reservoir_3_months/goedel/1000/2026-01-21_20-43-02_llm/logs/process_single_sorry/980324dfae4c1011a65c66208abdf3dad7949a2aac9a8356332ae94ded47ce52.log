      "\n    intro I B hI h¬Imax hBmax\n    by_contra! h\n    have h₁ := h¬Imax\n    simp only [not_not] at h₁\n    have h₂ : ∀ (x : α), x ∈ B → x ∉ I → ∀ (M : Set β), (G.IsMatching M → (insert x I ⊆ V(G, M) → False)) := by\n      intro x hxI hxM M hM hins\n      by_cases h : x ∈ I\n      · exfalso\n        exact hxM h\n      · have h₃ := h x hxI\n        obtain ⟨M, hM, hins⟩ := h₃\n        have h₄ : x ∈ B \\ I := by\n          apply And.intro hxI\n          intro h₅\n          exfalso\n          exact h₅ h\n        have h₅ : ∃ (M : Set β), G.IsMatching M ∧ (insert x I ⊆ V(G, M)) := by\n          exact ⟨M, hM, hins⟩\n        have h₆ := h h₄\n        simp_all\n    have h₃ : ∀ (x : α), x ∈ B → x ∉ I → False := by\n      intro x hxI hxM\n      have h₄ := h₂ x hxI hxM\n      have h₅ : ∀ (M : Set β), (G.IsMatching M → (insert x I ⊆ V(G, M) → False)) := by\n        intro M hM hins\n        exact h₄ M hM hins\n      have h₆ : ∀ (M : Set β), G.IsMatching M → (insert x I ⊆ V(G, M) → False) := h₅\n      by_contra! h₇\n      have h₈ := h₇\n      exfalso\n      have h₉ : False := by\n        simp_all\n      simp_all\n    have h₄ : B ⊆ I := by\n      intro x hx\n      by_contra hxI\n      have h₅ : x ∈ B := hx\n      have h₆ : x ∉ I := hxI\n      have h₇ := h₃ x h₅ h₆\n      simp_all\n    have h₅ : B = I := by\n      have h₆ : I ⊆ B := by\n        have h₇ : (fun S : Set α => ∃ M : Set β, G.IsMatching M ∧ S ⊆ V(G, M)) I := hI\n        have h₈ : ¬Maximal (fun S : Set α => ∃ M : Set β, G.IsMatching M ∧ S ⊆ V(G, M)) I := h¬Imax\n        have h₉ : Maximal (fun S : Set α => ∃ M : Set β, G.IsMatching M ∧ S ⊆ V(G, M)) B := hBmax\n        have h₁₀ : B ⊆ I → False := by\n          intro h₁₀\n          have h₁₁ : B = I := by\n            apply Set.Subset.antisymm h₁₀\n            intro x hx\n            have h₁₂ := h₄\n            simp_all [Set.Subset]\n          simp_all [h₁₁]\n          <;> aesop\n        have h₁₁ : I ⊆ B := by\n          by_contra h₁₂\n          have h₁₃ : ∃ x, x ∈ I ∧ x ∉ B := by\n            exact Set.nonempty_iff_ne_empty.mpr (by\n              intro h₁₄\n              have h₁₅ : I = ∅ := by\n                simp_all [Set.Subset]\n              simp_all [Set.Subset]\n              <;> aesop) |>.imp fun x hx => ⟨x, hx⟩\n          obtain ⟨x, hxI, hxB⟩ := h₁₃\n          have h₁₄ := h₂ x hxI\n          simp_all [Set.Subset]\n          <;> aesop\n        simp_all [Set.Subset]\n        <;> aesop\n      have h₇ : B ⊆ I := h₄\n      exact Set.Subset.antisymm h₆ h₇\n    have h₆ : Maximal (fun S : Set α => ∃ M : Set β, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n      simp_all [Set.Subset]\n      <;> aesop\n    simp_all\n  <;> aesop",
