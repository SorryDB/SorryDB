            aesop
          })
        <;>
        (try
          {
            exact ⟨G.allEdgesMatching, by aesop, by aesop⟩
          })
        <;>
        (try
          {
            simp_all [Set.subset_def]
            <;> aesop
          })
    exact h
  <;> aesop
