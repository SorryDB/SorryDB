def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, ?_, ?_⟩ <;> simp [Set.Subset]
    <;> exact Graph.isEmptyMatching
  
  indep_subset := by
    intro S S' hS hS'
    obtain ⟨M, hM, hM'⟩ := hS
    refine' ⟨M, hM, _⟩
    exact Set.Subset.trans hM' hS'
  
  indep_aug := by
    intro I B hI hI_not_max hB_max
    have h₁ : ∃ (x : α), x ∈ B \ I ∧ ∃ (M : Set β), G.IsMatching M ∧ (insert x I) ⊆ V(G, M) := by
      classical
      by_contra! h
      have h₂ : ∀ (x : α), x ∈ B \ I → ∀ (M : Set β), G.IsMatching M → ¬(insert x I ⊆ V(G, M)) := h
      have h₃ : ∀ (x : α), x ∈ B \ I → ∀ (M : Set β), G.IsMatching M → ¬(insert x I ⊆ V(G, M)) := h₂
      -- We will show that if no such x exists, then I must be maximal, contradicting hI_not_max.
      have h₄ : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
        refine' ⟨by tauto, ?_⟩
        intro S hS
        -- Assume S is an independent set containing I.
        -- We need to show that S = I.
        have h₅ : ∃ M, G.IsMatching M ∧ S ⊆ V(G, M) := hS
        by_contra h₆
        have h₇ : S ≠ I := by tauto
        have h₈ : I ⊂ S := by
          apply Set.ssubset_iff_of_subset (Set.Subset.trans (by tauto) (by tauto)).mpr
          aesop
        -- Obtain an element x in S \ I.
        obtain ⟨x, hx⟩ := Set.ssubset_iff_of_subset (by tauto).mpr h₈
        have h₉ : x ∈ S := by tauto
        have h₁₀ : x ∉ I := by tauto
        have h₁₁ : x ∈ B \ I → ∀ M, G.IsMatching M → ¬(insert x I ⊆ V(G, M)) := by
          intro hx'
          exact h₃ x hx'
        -- Consider whether x is in B.
        by_cases hx' : x ∈ B
        · -- Case: x ∈ B
          have h₁₂ : x ∈ B \ I := by
            exact ⟨hx', h₁₀⟩
          have h₁₃ : ∀ M, G.IsMatching M → ¬(insert x I ⊆ V(G, M)) := h₁₁ h₁₂
          -- We have a contradiction because x is in B and not in I.
          aesop
        · -- Case: x ∉ B
          -- If x is not in B, we need to show that S cannot contain I and is not better than I.
          have h₁₂ : ∃ M, G.IsMatching M ∧ S ⊆ V(G, M) := hS
          obtain ⟨M, hM, hM'⟩ := h₁₂
          have h₁₃ : I ⊆ S := Set.Subset.trans (by tauto) (by tauto)
          have h₁₄ : ∃ M, G.IsMatching M ∧ S ⊆ V(G, M) := ⟨M, hM, hM'⟩
          have h₁₅ : ¬Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := hI_not_max
          -- We have a contradiction because I is not maximal and cannot contain x.
          tauto
      -- Contradiction arises as I is not maximal.
      tauto
    -- The existence of x follows from the previous step.
    obtain ⟨x, hx, M, hM, hM'⟩ := h₁
    refine' ⟨x, hx, M, hM, _⟩
    <;> simp_all [Set.Subset]
    <;> aesop
