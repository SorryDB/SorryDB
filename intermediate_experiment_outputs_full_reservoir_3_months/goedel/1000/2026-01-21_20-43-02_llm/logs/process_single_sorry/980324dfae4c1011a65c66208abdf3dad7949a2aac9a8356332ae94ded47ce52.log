                have h₁₂ := hBmax\n                have h₁₃ : ∃ M, @Graph.IsMatching α β G M ∧ J ⊆ V(G, M) := by\n                  simpa [hJ] using hJ.mem\n                -- Use the fact that B is maximal to deduce J ⊆ B\n                have h₁₄ : ∀ (M : Set β), @Graph.IsMatching α β G M → J ⊆ V(G, M) → J ⊆ B := by\n                  intro M hM' hM''\n                  have h₁₅ : ∃ (M' : Set β), @Graph.IsMatching α β G M' ∧ J ⊆ V(G, M') := ⟨M, hM', hM''⟩\n                  have h₁₆ : J ⊆ B := by\n                    by_contra h₁₆\n                    have h₁₇ : ¬J ⊆ B := h₁₆\n                    have h₁₈ := h₁₃\n                    have h₁₉ := h₁₈\n                    simp_all [hBmax]\n                    <;> aesop\n                  exact h₁₆\n                -- Obtain the specific M for which J ⊆ V(G, M)\n                obtain ⟨M, hM', hM''⟩ := h₁₃\n                have h₂₀ := h₁₄ M hM' hM''\n                exact h₂₀\n              exact h₁₁\n            exact h₁₀ hx₁\n          have h₁₀ : x ∈ B \\ I := by\n            exact ⟨h₉, hx₂⟩\n          -- Use the fact that x ∈ B \\ I to find a contradiction\n          have h₁₁ : ∀ M : Set β, @Graph.IsMatching α β G M → ¬(insert x I ⊆ V(G, M)) := by\n            intro M hM'\n            exact h₄ x h₁₀ M hM'\n          -- Use the fact that J ⊆ B to find a contradiction\n          have h₁₂ : ∃ M, @Graph.IsMatching α β G M ∧ J ⊆ V(G, M) := by\n            simpa [hJ] using hJ.mem\n          obtain ⟨M, hM', hM''⟩ := h₁₂\n          have h₁₃ : insert x I ⊆ V(G, M) := by\n            have h₁₄ : I ⊆ V(G, M) := by\n              have h₁₅ : I ⊆ J := by\n                -- Since J properly contains I, I ⊆ J\n                have h₁₆ : I ⊂ J := by\n                  refine Set.ssubset_iff_subset_ne.mpr ⟨hJp, _⟩\n                  intro h₁₇\n                  simp_all\n                exact h₁₆.1\n              have h₁₆ : J ⊆ V(G, M) := hM''\n              exact h₁₆.trans h₁₅\n            have h₁₅ : x ∈ V(G, M) := by\n            