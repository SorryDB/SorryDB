      "\n    intro I B hI hI_not_max hB_max\n    have h₁ : ∃ x ∈ B \\ I, ∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M) := by\n      classical\n      by_contra! h\n      have h₂ : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n        refine ⟨fun S hS => _, _⟩\n        · -- Assume S is a superset of I and S ⊆ V(G, M) for some M\n          have h₃ : I ⊆ S := by\n            by_contra h₄\n            -- If I is not a subset of S, then there exists an element in I not in S\n            have h₅ : ∃ x, x ∈ I ∧ x ∉ S := by\n              simp_all [Set.subset_def]\n              <;> tauto\n            obtain ⟨x, hx⟩ := h₅\n            simp_all [Set.subset_def]\n          -- We need to show that S cannot be in the independent family unless S = I\n          obtain ⟨M, hM, hS⟩ := hS\n          obtain ⟨M', hM', hI⟩ := hI\n          simp_all [Set.subset_def]\n          <;> tauto\n        · -- Show that I is in the independent family\n          exact hI\n      -- Contradiction with the assumption that I is not maximal\n      exact hI_not_max h₂\n    exact h₁",
