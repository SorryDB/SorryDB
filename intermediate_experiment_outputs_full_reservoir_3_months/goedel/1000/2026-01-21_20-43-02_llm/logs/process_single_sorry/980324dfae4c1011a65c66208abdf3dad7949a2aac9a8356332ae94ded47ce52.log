        tauto
      exact h₆
    -- Since I is not maximal, there exists a strict superset of I that is matchable
    have h₅ : ∃ T : Set α, (∃ M, G.IsMatching M ∧ T ⊆ V(G, M)) ∧ I ⊂ T := by
