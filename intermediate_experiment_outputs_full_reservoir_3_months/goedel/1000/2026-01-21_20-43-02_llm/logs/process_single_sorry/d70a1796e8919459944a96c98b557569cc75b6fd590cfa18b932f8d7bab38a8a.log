### Complete Lean 4 Proof

```lean
@[simp]
def to_cs {p : ℕ} [Fact (Nat.Prime p)] {F : Type} [Semiring F] (c : Circuit p F) : Cs p F :=
  match c with
  | .nil => .n
  | .eq0 _ c => .n
  | .lam k => .lam (fun x => to_cs (k x))
  | .share e k =>
    let e := Exp.eval (k := F) e
    .cons (e : F) (to_cs (k e))
  | .is_zero e k =>
    let e := Exp.eval (k := F) e
    let inv : (F) := e⁻¹
    let o : (F) := if e = 0 then 1 else 0
    .cons inv (.cons o (to_cs (k o)))
  | .assert_range w e c =>
    let bits : List F := num2bits w (Exp.eval (k := F) e)
    .foldl (fun acc b => .cons b acc) (.nil) bits

```

