lemma HasLocallyIntegrableSup.locally_classDL [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
    [MeasurableSpace ι]
    (hX1 : HasLocallyIntegrableSup X 𝓕 P) (hX2 : Adapted 𝓕 X) (h𝓕 : 𝓕.IsRightContinuous) :
    Locally (ClassDL · 𝓕 P) 𝓕 X P := by
  have h₁ : ∀ t, ClassDL (X ⬝| 𝓕 t) 𝓕 P := by
    intro t
    have h₂ : ClassDL (fun s => X s) 𝓕 P := by
      -- Use the fact that the supremum of the supports is locally integrable to prove the class DL condition
      exact isStable_classDL.of hX1 (IsRightContinuous.mono h𝓕)
    have h₃ : Adapted 𝓕 (X ⬝| 𝓕 t) := by
      -- Prove that the process restricted to the filter 𝓕 t is adapted
      apply hX2.restrict_adapted_of_mono_filtration (Filtration.mono _ (le_refl ι)) t
      intro s hs
      exact hs
    -- Use the class DL property of the original process to deduce the class DL property of the restricted process
    have h₄ : ClassDL (X ⬝| 𝓕 t) 𝓕 P := by
      simpa [h₃] using h₂.restrict_adapted_of_mono_filtration h₃ t
    exact h₄
  -- Use the class DL property of the restricted process to prove the locally class DL condition
  exact Locally.deterministic fun t => h₁ t
``` 

