lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by
    rcases hX with ⟨hX⟩
    rw [HasLaw] at hX ⊢
    -- Use the fact that the image of the complement set is the complement of the image
    have h : (fun ω ↦ u \ X ω) = fun ω ↦ (u : Set ι) \ (X ω) := rfl
    rw [h]
    -- Use the properties of the product measure and the fact that the complement of a Bernoulli set is Bernoulli with the complement probability
    simpa [Set.setOf_forall] using hX.congr' (by
      -- Show that the complement set is equivalently described by the complement condition
      ext s
      simp only [Set.mem_compl_iff, Set.mem_map, Set.mem_setOf_eq]
      <;>
      simp_all [Set.setOf_forall, Set.mem_diff]
      <;>
      tauto)
