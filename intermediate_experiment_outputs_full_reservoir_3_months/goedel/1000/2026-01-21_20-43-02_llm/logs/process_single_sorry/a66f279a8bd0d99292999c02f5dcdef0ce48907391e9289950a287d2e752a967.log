lemma map_sdiff {EnablingDeletion : Type*} [DecidableEq EnablingDeletion] (s t : Set EnablingDeletion) :
    s \ t = s ∩ tᶜ := by
  ext x
  simp [Set.mem_sdiff, Set.mem_compl_iff]
  <;> tauto

@[simp] lemma destruct_eq_zero (x : WithBot ℕ) : x = 0 ↔ ∃ n : ℕ, x = (n : WithBot ℕ) ∧ x = 0 := by
  constructor
  · intro h
    refine' ⟨0, _⟩
    simp_all
  · rintro ⟨n, hn, hx⟩
    rw [hx]
    <;> simp_all
    <;> norm_cast
    <;> simp_all

@[simp, norm_cast] lemma map_sdiff {Ω : Type*} [DecidableEq Ω] (s t : Set Ω) (μ : Measure Ω) :
    μ (s \ t) = μ (s ∩ tᶜ) := by
  rw [map_sdiff]
  <;> simp [Set.mem_sdiff, Set.mem_compl_iff]
  <;>
  (try simp_all [Set.mem_sdiff, Set.mem_compl_iff]) <;>
  (try aesop) <;>
  (try simp_all [Set.mem_sdiff, Set.mem_compl_iff]) <;>
  (try aesop) <;>
  (try simp_all [Set.mem_sdiff, Set.mem_compl_iff]) <;>
  (try aesop)

