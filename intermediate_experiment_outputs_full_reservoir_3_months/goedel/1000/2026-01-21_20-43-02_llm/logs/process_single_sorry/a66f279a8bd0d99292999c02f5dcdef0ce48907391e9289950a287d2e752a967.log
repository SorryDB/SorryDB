lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by
    have h₁ : map (fun ω => u \ X ω) P = map (fun s => u \ s) (map (fun ω => X ω) P) := by
      simp [map_map]
      <;> rfl
    rw [h₁]
    have h₂ : map (fun ω => X ω) P = Ber(u, p) := by
      exact hX.map_eq
    rw [h₂]
    -- We need to show that the map of u \ s under Ber(u, p) is equal to Ber(u, σ p)
    -- This involves showing that the measure of u \ s is equal to the product of measures for each element not in s
