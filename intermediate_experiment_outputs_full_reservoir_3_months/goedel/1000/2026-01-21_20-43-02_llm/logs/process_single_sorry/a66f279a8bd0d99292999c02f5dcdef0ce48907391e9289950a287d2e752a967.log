theorem undesired_theorem (f : ℕ → ℕ) : (f 0 = 1) ∧ (f 1 = 0) ∧ (∀ n ≥ 2, f n = 2) → (∀ n, f n ≥ 1) := by
  intro h
  have h₁ : f 0 = 1 := h.1
  have h₂ : f 1 = 0 := h.2.1
  have h₃ : ∀ n ≥ 2, f n = 2 := h.2.2
  have h₄ : ∀ n, f n ≥ 1 := by
    intro n
    have h₅ : n = 0 ∨ n = 1 ∨ n ≥ 2 := by
      by_cases h₅ : n = 0
      · exact Or.inl h₅
      · by_cases h₆ : n = 1
        · exact Or.inr (Or.inl h₆)
        · have h₇ : n ≥ 2 := by
            have h₈ : n ≠ 0 := h₅
            have h₉ : n ≠ 1 := h₆
            have h₁₀ : n ≥ 2 := by
              by_contra h₁₀
              interval_cases n <;> simp_all (config := {decide := true})
            exact h₁₀
          exact Or.inr (Or.inr h₇)
    rcases h₅ with (rfl | rfl | h₅)
    · -- Case n = 0
      norm_num [h₁]
    · -- Case n = 1
      norm_num [h₂] at *
      <;>
      (try contradiction) <;>
      (try norm_num) <;>
      (try omega)
    · -- Case n ≥ 2
      have h₆ : f n = 2 := h₃ n h₅
      norm_num [h₆]
  exact h₄
