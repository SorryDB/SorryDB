  have h_y_lt_two_pow : y.val < 2^n := h_assumptions.2
  have h_y_add_one_eq_two_pow : y.val + 1 = 2^n := h_y_add_one_eq
  have h_y_eq_two_pow_sub_one : y.val = 2^n - 1 := by
    omega
  have h_x_lt_two_pow : x.val < 2^n := h_assumptions.1
  have h_x_le_y : x.val тЙд y.val := by
    have hтВБ : x.val < 2^n := h_assumptions.1
    have hтВВ : y.val = 2^n - 1 := h_y_eq_two_pow_sub_one
    have hтВГ : x.val тЙд 2^n - 1 := by
