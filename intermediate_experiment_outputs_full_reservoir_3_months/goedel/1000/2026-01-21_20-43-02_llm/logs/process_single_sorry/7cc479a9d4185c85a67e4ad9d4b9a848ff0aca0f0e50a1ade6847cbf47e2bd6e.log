theorem LessEqThan_circularity : тИА (n : тДХ) (hn : 2^(n+1) < p) (i : тДХ) (env : Environment (F p)) (input : Var fieldPair (F p)) (x y : F p), Expression.eval env input.1 = x тЖТ Expression.eval env input.2 = y тЖТ (x.val < 2^n тИз y.val < 2^n) тЖТ (y.val + 1 < 2^n тЖТ env.get (i + n + 1) = if x.val < y.val + 1 then 1 else 0) тЖТ 2^n < 2^(n+1) тЖТ (y.val + 1 : тДХ) < p тЖТ (y.val + 1 = 2^n) тЖТ (env.get (i + n + 1) = if x.val тЙд y.val then 1 else 0) := by
