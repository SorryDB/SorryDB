### Solution

```lean
lemma integral_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by
  have h1 : ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ := rfl
  have h2 : (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) = ∫ x, f x ∂μ i := by
    -- Use the fact that the integral over the product space can be reduced to the integral over the i-th component
    have h3 : (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) = ∫ x, f x ∂μ i := by
      -- Apply the Fubini-Tonelli theorem to reduce the integral over the product space to the integral over the i-th component
      calc
        (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) = ∫ x, f x ∂μ i := by
          -- Use the fact that the integral over the product space can be reduced to the integral over the i-th component
          have h4 : (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) = ∫ x, f x ∂μ i := by
            -- Apply the Fubini-Tonelli theorem to reduce the integral over the product space to the integral over the i-th component
            rw [← MeasureTheory.integral_integral_pi (fun i => IsProbabilityMeasure.to_measure (inferInstance : ∀ i, IsProbabilityMeasure (μ i))) hf]
            <;> simp [Function.comp_def, Fin.sum_univ_succ]
            <;> rfl
          exact h4
        _ = ∫ x, f x ∂μ i := by rfl
    exact h3
  exact h2
