      "\n  have h₁ : ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by\n    -- Use the property of the product measure to reduce the integral over the product space to an integral over one of the components\n    have h₂ : ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by\n      -- Apply the Fubini theorem to the product measure and evaluate the integral\n      calc\n        ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ := rfl\n        _ = ∫ x, f x ∂μ i := by\n          -- Use the property of product measures and integrals over product spaces\n          -- Here, we are essentially using the fact that the integral over the product space can be computed by integrating over one component at a time\n          -- This is a simplified version of Fubini's theorem for product measures\n          -- Specifically, we use the fact that the integral of a function that depends only on one coordinate over a product space is equal to the integral of that function over the corresponding coordinate space\n          -- This is formalized in the lemma `MeasureTheory.integral_fst`\n          -- We also use the fact that the product measure of probability measures is a probability measure\n          -- and the integrability of f over μ i to ensure that the integral is well-defined\n          simp [MeasureTheory.integral_pi]\n          <;>\n          simp_all [Finset.prod_const, Finset.card_fin]\n          <;>\n          try simp_all [MeasureTheory.integral_const, MeasureTheory.integral_id]\n          <;>\n          try simp_all [hf]\n          <;>\n          try simp_all [MeasureTheory.integral_mul_left]\n          <;>\n          try simp_all [MeasureTheory.integral_mul_right]\n          <;>\n          try simp_all [MeasureTheory.integral_comp_mul_left]\n          <;>\n          try simp_all [MeasureTheory.integral_comp_mul_right]\n          <;>\n          try simp_all [MeasureTheory.integral_comp_add_left]\n          <;>\n 