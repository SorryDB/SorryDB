lemma integral_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by
  have h : ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ (x : ℝ), f x ∂μ i := by
    calc
      _ = ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ := rfl
      _ = ∫ x, f x ∂μ i := by
        -- Use the Fubini-Tonelli theorem to evaluate the integral over the product space
        -- by fixing the i-th component and integrating over the other components.
        have h₁ : (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) = ∫ x, f x ∂μ i := by
          -- Apply the generalization of Fubini-Tonelli for product measures
          calc
            (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) =
                ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ := rfl
            _ = ∫ (x : ℝ), f x ∂μ i := by
              -- Use the fact that the integral over the product space can be reduced to the integral over the i-th component
              -- when the function depends only on that component.
              have h₂ : (∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ) =
                  ∫ (x : ℝ), f x ∂μ i := by
                -- Use the projections and the properties of product measures
                rw [Measure.integral_pi_eq_integral_fiber (μ := μ) (E := ℝ) (F := fun _ => ℝ)]
                <;>
                  simp_all [hf, IsProbabilityMeasure, MeasureTheory.integral_const, Finset.sum_const,
                    nsmul_eq_mul, mul_one]
                <;>
                  congr 1 <;> ext <;> simp [Function.funext_iff]
                <;>
                  aesop
              exact h₂
        exact h₁
  exact h
