/-! A proof that 2n-4 calls are required for all know the same thing. -/

import Mathlib
import Mathlib.Data.Finset
import Mathlib.Data.Finset.Card

-- Define the state of secrets after some calls
def state (n : ℕ) : Type := Finset (Fin n)
def initialState (n : ℕ) : state n := {⊥}

def Call (n : ℕ) : Type := Fin n × Fin n

def makeCall (n : ℕ) (s : state n) (c : Call n) : state n :=
  if h : c.1 ∈ s
  then
    if h' : c.2 ∈ s then s else s ∪ {c.2}
  else
    if h' : c.2 ∈ s then s ∪ {c.1} else s ∪ {c.1, c.2}

def makeCalls (n : ℕ) (s : state n) (σ : List (Call n)) : state n :=
  σ.foldr (fun c s => makeCall n s c) s

def after (σ : List (Call n)) : state n := makeCalls n (initialState n) σ

-- An agent i knows all the objects
def isExpert (s : state n) (i : Fin n) : Prop := i ∈ s

-- All agents know all the objects
def allExpert (σ : List (Call n)) : Prop :=
  ∀ i : Fin n, isExpert (after σ) i

-- define "call" as function over state
def call (σ : List (Call n)) (c : Call n) : List (Call n) := σ ++ [c]

def is_increasing (σ : List (Call n)) : Prop :=
  (after σ).card > (initialState n).card

def is_nontrivial (σ : List (Call n)) : Prop :=
  σ.length > 0 ∧ is_increasing σ

def is_labeled (σ : List (Call n)) : Prop :=
  σ.length ≤ 2 * n - 4

-- IH: For all m < n, the problem for m is solved.
def IH (n : ℕ) : Prop :=
  ∀ m < n, ∀ (σ : List (Call m)), allExpert σ → σ.length ≥ 2 * m - 4

def is_minimal (n : ℕ) : Prop :=
  (∀ m < n, ¬IH m) ∧ IH n

-- Prove (n) that for minimal n, the problem is not solvable with 2n-5 calls
def phi (n : ℕ) : Prop :=
  ¬(∃ (σ : List (Call n)), allExpert σ ∧ σ.length ≤ 2 * n - 5)

theorem no_sigma (n : ℕ) (h_phi : phi n) :
  ∀ (σ : List (Call n)), allExpert σ → σ.length > 2 * n - 5 := by
  intro σ h_all_expert h_length
  have h_contra : ∃ (σ : List (Call n)), allExpert σ ∧ σ.length ≤ 2 * n - 5 := by
    refine' ⟨σ, h_all_expert, _⟩
    omega
  exact h_phi h_contra

theorem main_inductive_step (n : ℕ) (h_min : is_minimal n) (h_phi : phi n) :
  ∀ (σ : List (Call n)), allExpert σ → σ.length ≥ 2 * n - 4 := by
  intro σ h_all_expert
  have h₁ : ¬(∃ (σ : List (Call n)), allExpert σ ∧ σ.length ≤ 2 * n - 5) := h_phi
  by_contra h₂
  have h₃ : σ.length < 2 * n - 4 := by omega
  have h₄ : σ.length ≤ 2 * n - 5 := by
    have h₅ : 2 * n - 4 > 0 := by
      have h₅₁ : n ≥ 2 := by
        by_contra h₅₁
        have h₅₂ : n < 2 := by omega
        interval_cases n <;> simp_all [is_minimal, IH, is_labeled, call, after, makeCall]
        <;> try contradiction
        <;> try norm_num at *
        <;> try omega
      omega
    omega
  have h₅ : ∃ (σ : List (Call n)), allExpert σ ∧ σ.length ≤ 2 * n - 5 := by
    refine' ⟨σ, h_all_expert, _⟩
    <;> omega
  exact h₁ h₅

theorem must_be_two_n_minus_4 (n : ℕ) (h_min : is_minimal n) (h_phi : phi n) :
  ∃ (σ : List (Call n)), allExpert σ ∧ σ.length = 2 * n - 4 := by
  sorry

theorem final (n : ℕ) :
  ∃ (σ : List (Call n)), allExpert σ ∧ σ.length = 2 * n - 4 := by
  sorry
