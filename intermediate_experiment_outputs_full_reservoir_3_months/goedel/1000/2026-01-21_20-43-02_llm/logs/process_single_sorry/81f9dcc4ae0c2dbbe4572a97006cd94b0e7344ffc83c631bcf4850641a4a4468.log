lemma _root_.MeasureTheory.Filtration.predictable_le_prod (𝓓 : Filtration T mΩ) :
    𝓓.predictable ≤ Prod.instMeasurableSpace := by
  have h : 𝓓.predictable ≤ (inferInstance : MeasurableSpace (T × Ω)) := by
    -- Use the fact that the product of two measurable spaces is measurable
    have h₁ : 𝓓.predictable ≤ (inferInstance : MeasurableSpace (T × Ω)) := by
      -- The predictable sigma-algebra is a subset of the product sigma-algebra
      -- because it is generated by the product of the discrete and measurable sigma-algebras
      have h₂ : 𝓓.predictable ≤ (inferInstance : MeasurableSpace (T × Ω)) := by
        -- Use the fact that the product of two measurable spaces is measurable
        apply MeasurableSpace.le_of_eq (le_refl _)
      exact h₂
    exact h₁
  exact h
