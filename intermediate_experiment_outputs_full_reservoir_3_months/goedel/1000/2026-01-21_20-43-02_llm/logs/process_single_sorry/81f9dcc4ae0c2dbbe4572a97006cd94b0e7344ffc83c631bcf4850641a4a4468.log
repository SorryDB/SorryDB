```lean
lemma _root_.MeasureTheory.Filtration.predictable_le_prod (𝓕 : Filtration T mΩ) :
    𝓕.predictable ≤ Prod.instMeasurableSpace := by
  -- The predictable sigma-algebra is generated by left-continuous adapted processes.
  -- The product sigma-algebra is the product of the Borel sigma-algebra on T and the sigma-algebra on Ω.
  -- Every left-continuous adapted process is measurable with respect to the product sigma-algebra.
  -- Therefore, the predictable sigma-algebra is a subset of the product sigma-algebra.
  have h : 𝓕.predictable ≤ (Prod.instMeasurableSpace : MeasurableSpace (T × Ω)) := by
    -- We use the fact that the predictable sigma-algebra is the smallest sigma-algebra containing all left-continuous adapted processes.
    -- Since each such process is measurable with respect to the product sigma-algebra, the predictable sigma-algebra must be a subset of it.
    refine' MeasurableSpace.le_of_forall_mem _ _
    intro x hx
    -- For any set x in the predictable sigma-algebra, we need to show that it is also in the product sigma-algebra.
    -- This is true because the predictable sigma-algebra is generated by sets that are measurable in the product sigma-algebra.
    exact by
      -- We use the fact that the predictable sigma-algebra is generated by sets of the form {t} × A where A is measurable in Ω.
      -- Each such set is also a set of the form {t} × A in the product sigma-algebra.
