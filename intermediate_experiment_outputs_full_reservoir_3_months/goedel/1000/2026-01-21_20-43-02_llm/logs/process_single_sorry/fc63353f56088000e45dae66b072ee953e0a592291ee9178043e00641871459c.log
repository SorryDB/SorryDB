theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  have h_main : ∃ (f : α → β), (Monotone f ∧ ∀ x : α, F.F x = f x) := by
    use F.F
    constructor
    · -- Prove that F.F is monotone
      intro x y hxy
      have h : (PLift.mk hxy : (α := α) : α ≤ y) := by exact ⟨hxy⟩
      -- Use the fact that the image of the ambient category is order preserving
      have h' : F.homF h : (α := β) : F.F x ≤ F.F y := by
        simpa [PLift.coe_mk] using h'
      -- Convert the lifted order to an order in β
      exact h'.down
    · -- Prove that F.F is trivially equal to itself
      intro x
      rfl
  exact h_main
