  F Y := Hom c Y
  homF {Y Z : α} (f : Hom Y Z) (g : Hom c Y) := g ≫ f
  map_id Y := by
    intro g
    simp [id]
    <;> simp_all [comp_def]
    <;> rfl
  
  map_comp {Y Z W : α} (f : Hom Y Z) (g : Hom Z W) := by
    intro h
    simp [comp_assoc]
    <;> simp_all [comp_def]
    <;> rfl
  
