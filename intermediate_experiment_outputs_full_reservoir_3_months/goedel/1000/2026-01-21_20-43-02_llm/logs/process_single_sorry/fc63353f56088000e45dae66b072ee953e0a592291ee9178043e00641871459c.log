theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  haveI : Nonempty α := ⟨1⟩
  haveI : Nonempty β := ⟨1⟩
  have h1 : F.F () = (α := Unit → β := Unit) := by
    haveI := (inferInstance : Monoid α)
    haveI := (inferInstance : Monoid β)
    simp [F.map_id]
    <;>
    (try trivial) <;>
    (try simp_all) <;>
    (try aesop)
  have h2 : ∀ (x : α), F.homF (X := ()) (Y := ()) x = (x : α → x : β) := by
    intro x
    haveI := (inferInstance : Monoid α)
    haveI := (inferInstance : Monoid β)
    simp_all [F.map_id, F.map_comp]
    <;>
    (try trivial) <;>
    (try simp_all) <;>
    (try aesop)
  use (MonoidHom.id α)
  <;>
  (try simp_all) <;>
  (try aesop)
