    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  have h₁ : ∀ x : α, F.homF (X := ()) (Y := ()) x = F.homF (X := ()) (Y := ()) 1 * F.homF (X := ()) (Y := ()) x := by
    intro x
    have h₂ : (1 : α) * x = x := by simp
    have h₃ : F.homF (X := () : Unit) (Y := () : Unit) (MonoidHom.mul (1 : α) x) = F.homF (X := () : Unit) (Y := () : Unit) (1 : α) * F.homF (X := () : Unit) (Y := () : Unit) x := by
      apply F.map_comp
      <;> simp
    simp [MonoidHom.mul] at h₃ ⊢
    <;> simp_all [MonoidHom.mul]
    <;> simp_all [mul_assoc]
    <;> try { simp_all [MonoidHom.one] }
    <;> try { simp_all [MonoidHom.mul] }
    <;> try { simp_all [mul_assoc] }
    <;> try { simp_all [MonoidHom.one] }
    <;> try { simp_all [MonoidHom.mul] }

  have h₂ : F.homF (X := ()) (Y := ()) 1 = 1 := by
    have h₃ : (1 : α) = 1 := by simp
    have h₄ : F.homF (X := () : Unit) (Y := () : Unit) (1 : α) = 1 := by
      simp [F.map_id]
    simp_all [MonoidHom.one]
    <;> try { simp_all [MonoidHom.mul] }
    <;> try { simp_all [mul_assoc] }
    <;> try { simp_all [MonoidHom.one] }
    <;> try { simp_all [MonoidHom.mul] }

  have h₃ : ∀ x : α, F.homF (X := ()) (Y := ()) x = F.homF (X := ()) (Y := ()) x := by
    intro x
    rfl

  -- Use the fact that the image of the identity element is the identity to construct the group homomorphism
  have h₄ : ∃ (f : α →* β), ∀ x : α, F.homF (X := ()) (Y := ()) x = f x := by
    use {
      toFun := fun x => F.homF (X := ()) (Y := ()) x,
      map_one' := by
        have h₅ : F.homF (X := () : Unit) (Y := () : Unit) (1 : α) = 1 := by
          simp [F.map_id]
        simp_all [MonoidHom.one]
        <;> try { simp_all [MonoidHom.mul] }
        <;> try { simp_all [mul_assoc] }
        <;> try { simp_all [MonoidHom.one] }
        <;> try { simp_all [MonoidHom.mul] }
      map_mul' := by
        intro x y
        have h₅ : F.homF (X := () : Unit) (Y := () : Unit) (x * y) = F.homF (X := () : Unit) (Y := () : Unit) x * F.homF (X := () : Unit) (Y := () : Unit) y := by
          apply F.map_comp
          <;> simp
        simp_all [MonoidHom.mul]
        <;> try { simp_all [mul_assoc] }
        <;> try { simp_all [MonoidHom.one] }
        <;> try { simp_all [MonoidHom.mul] }
    }
    intro x
    <;> simp
  exact h₄
