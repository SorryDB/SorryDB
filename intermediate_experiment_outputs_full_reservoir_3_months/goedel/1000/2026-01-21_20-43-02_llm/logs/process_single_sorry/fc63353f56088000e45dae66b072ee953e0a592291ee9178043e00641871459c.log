def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    cases X with
    | mk x y hxy =>
      simp [F, homF]
      <;> rfl
  
  map_comp f g := by
    cases f with
    | mk hk properties =>
      cases g with
      | mk hk' properties' =>
        simp [F, homF] at *
        <;>
        (try simp_all) <;>
        (try { rfl }) <;>
        (try { simp_all [CD.comp] }) <;>
        (try { aesop }) <;>
        (try {
          simp_all [CD.comp] <;>
          aesop
        })
        <;>
        (try {
          simp_all [CD.comp] <;>
          rfl
        })
  
def Comma_category_cod {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) E where
  F := fun ⟨_, Y, _⟩ => Y
  homF := fun ⟨hk, _⟩ => hk.2
  map_id X := by
    cases X with
    | mk x y hxy =>
      simp [F, homF]
      <;> rfl
  
  map_comp f g := by
    cases f with
    | mk hk properties =>
      cases g with
      | mk hk' properties' =>
        simp [F, homF] at *
        <;>
        (try simp_all) <;>
        (try { rfl }) <;>
        (try { simp_all [CE.comp] }) <;>
        (try { aesop }) <;>
        (try {
          simp_all [CE.comp] <;>
          aesop
        })
        <;>
        (try {
          simp_all [CE.comp] <;>
          rfl
        })
