def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    cases X with
    | mk x y h =>
      simp [id]
  map_comp f g := by
    cases f with
    | mk ⟨h₁, h₂⟩ _ =>
    cases g with
    | mk ⟨h₃, h₄⟩ _ =>
      simp_all [comp]
      <;>
      (try aesop)
      <;>
      (try simp_all [F, homF, map_id, map_comp])
      <;>
      (try aesop)
      <;>
      (try simp_all [comp])
      <;>
      (try aesop)

