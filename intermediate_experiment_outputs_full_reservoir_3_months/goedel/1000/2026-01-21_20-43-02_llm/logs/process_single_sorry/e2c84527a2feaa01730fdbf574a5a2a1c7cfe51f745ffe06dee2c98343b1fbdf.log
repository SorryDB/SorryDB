      -- Since midS is false, we use the else branch of the construction
      have h₄ : ¬∃ s ∈ S, (a n + b n) / 2 ≤ s := midS
      have h₅ : (ab (n + 1)).val.1 = (ab n).val.1 := by
        -- The construction in the else branch uses the same left endpoint
