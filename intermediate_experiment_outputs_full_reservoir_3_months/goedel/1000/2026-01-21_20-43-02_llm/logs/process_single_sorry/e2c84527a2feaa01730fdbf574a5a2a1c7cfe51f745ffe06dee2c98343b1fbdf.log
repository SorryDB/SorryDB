theorem verify_countdown_sequence : ∀ (T : ℕ), ∃ (n : ℕ), ¬ CountDownSequence T n := by
  intro T
  use T + 1
  intro h
  have h₁ : (univ : Finset ℕ).Inf < T + 1 := by
    simp [Finset.inf_empty]
    <;> omega
  have h₂ := h₁
  simp_all [CountDownSequence, Finset.mem_filter, Finset.mem_range]
  <;>
  (try omega) <;>
  (try {
    have h₃ := h₂
    simp_all [Finset.inf_empty]
    <;> omega
  })
  <;>
  (try {
    cases T <;> simp_all [Finset.inf_empty, Finset.mem_range, Finset.mem_filter]
    <;> norm_num at *
    <;> omega
  })
