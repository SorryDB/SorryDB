```lean4
import Mathlib.Analysis.RCLike.Inner
import Mathlib.Data.Real.ConjExponents
import LeanAPAP.Prereqs.LpNorm.Discrete.Defs

/-! # Inner product -/

open Finset Function MeasureTheory RCLike Real
open scoped ComplexConjugate ENNReal NNReal NNRat

variable {őĻ ūĚēú S : Type*} [Fintype őĻ]

namespace RCLike
variable [RCLike ūĚēú] {mőĻ : MeasurableSpace őĻ} [DiscreteMeasurableSpace őĻ] {f : őĻ ‚Üí ūĚēú}

@[simp] lemma wInner_one_self {_ : MeasurableSpace őĻ} [DiscreteMeasurableSpace őĻ] (f : őĻ ‚Üí ūĚēú) :
    ‚ü™f, f‚üę_[ūĚēú] = ((‚ÄĖf‚ÄĖ_[2] : ‚ĄĚ) : ūĚēú) ^ 2 := by
  simp_rw [‚Üź algebraMap.coe_pow, ‚Üź NNReal.coe_pow]
  simp [dL2Norm_sq_eq_sum_nnnorm, wInner_one_eq_sum]

lemma dL1Norm_mul (f g : őĻ ‚Üí ūĚēú) : ‚ÄĖf * g‚ÄĖ_[1] = ‚ü™fun i ‚Ü¶ ‚ÄĖf i‚ÄĖ, fun i ‚Ü¶ ‚ÄĖg i‚ÄĖ‚üę_[‚ĄĚ] := by
  simp [wInner_one_eq_sum, dL1Norm_eq_sum_nnnorm, mul_comm]

/-- **Cauchy-Schwarz inequality** -/
lemma wInner_one_le_dL2Norm_mul_dL2Norm (f g : őĻ ‚Üí ‚ĄĚ) : ‚ü™f, g‚üę_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ_[2] * ‚ÄĖg‚ÄĖ_[2] := by
  simpa [dL2Norm_eq_sum_nnnorm, PiLp.norm_eq_of_L2, sqrt_eq_rpow, wInner_one_eq_inner]
    using real_inner_le_norm ((WithLp.equiv 2 _).symm f) _

end RCLike

/-! ### H√∂lder inequality -/

namespace MeasureTheory
section Real
variable {őĪ : Type*} {mőĪ : MeasurableSpace őĪ} [DiscreteMeasurableSpace őĪ] [Fintype őĪ] {p q : ‚ĄĚ‚Č•0‚ąě}
  {f g : őĪ ‚Üí ‚ĄĚ}

lemma dL1Norm_mul_of_nonneg (hf : 0 ‚Č§ f) (hg : 0 ‚Č§ g) : ‚ÄĖf * g‚ÄĖ_[1] = ‚ü™f, g‚üę_[‚ĄĚ] := by
  convert dL1Norm_mul f g using 2 <;> ext a <;> refine (norm_of_nonneg ?_).symm; exacts [hf _, hg _]

/-- **H√∂lder's inequality**, binary case. -/
lemma wInner_one_le_dLpNorm_mul_dLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    ‚ü™f, g‚üę_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ_[p] * ‚ÄĖg‚ÄĖ_[q] := by
  sorry

/-- **H√∂lder's inequality**, binary case. -/
lemma abs_wInner_one_le_dLpNorm_mul_dLpNorm [p.HolderConjugate q] (f g : őĪ ‚Üí ‚ĄĚ) :
    |‚ü™f, g‚üę_[‚ĄĚ]| ‚Č§ ‚ÄĖf‚ÄĖ_[p] * ‚ÄĖg‚ÄĖ_[q] :=
  (abs_wInner_le zero_le_one).trans <| (wInner_one_le_dLpNorm_mul_dLpNorm p q).trans_eq <| by
    simp_rw [dLpNorm_abs]

end Real

