      "h\n    else\n      -- Slope between two different points\n      match MordellWeilGroup.slope E P Q with\n      | none =>\n        -- This case should not happen because xâ‚پ â‰  xâ‚‚\n        have h : P.point = some (xâ‚پ, yâ‚پ) := by simp_all\n        have hâ‚پ : Q.point = some (xâ‚‚, yâ‚‚) := by simp_all\n        have hâ‚‚ : xâ‚پ â‰  xâ‚‚ := by simp_all\n        have hâ‚ƒ : s = (yâ‚‚ - yâ‚پ) / (xâ‚‚ - xâ‚پ) := by simp_all [MordellWeilGroup.slope]\n        simp_all [MordellWeilGroup.slope]\n        <;> field_simp [hâ‚‚, sub_eq_zero, Ne.symm hâ‚‚] at *\n        <;> simp_all\n        <;> aesop\n      | some s =>\n        let W := E.val\n        let xâ‚ƒ := s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚\n        let yâ‚ƒ := s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ\n        have h : yâ‚ƒ ^ 2 + W.aâ‚پ * xâ‚ƒ * yâ‚ƒ + W.aâ‚ƒ * yâ‚ƒ = xâ‚ƒ ^ 3 + W.aâ‚‚ * xâ‚ƒ ^ 2 + W.aâ‚„ * xâ‚ƒ + W.aâ‚† := by\n          have hâ‚€ : xâ‚پ â‰  xâ‚‚ := by simp_all\n          have hâ‚پ : s = (yâ‚‚ - yâ‚پ) / (xâ‚‚ - xâ‚پ) := by simp_all [MordellWeilGroup.slope]\n          have hâ‚‚ : yâ‚پ ^ 2 + W.aâ‚پ * xâ‚پ * yâ‚پ + W.aâ‚ƒ * yâ‚پ = xâ‚پ ^ 3 + W.aâ‚‚ * xâ‚پ ^ 2 + W.aâ‚„ * xâ‚پ + W.aâ‚† := by\n            have hâ‚ƒ := P.on_curve xâ‚پ yâ‚پ (by simp_all)\n            simp_all [E.val]\n            <;> ring_nf at *\n            <;> simp_all\n          have hâ‚ƒ : yâ‚‚ ^ 2 + W.aâ‚پ * xâ‚‚ * yâ‚‚ + W.aâ‚ƒ * yâ‚‚ = xâ‚‚ ^ 3 + W.aâ‚‚ * xâ‚‚ ^ 2 + W.aâ‚„ * xâ‚‚ + W.aâ‚† := by\n            have hâ‚„ := Q.on_curve xâ‚‚ yâ‚‚ (by simp_all)\n            simp_all [E.val]\n            <;> ring_nf at *\n            <;> simp_all\n          simp_all [xâ‚ƒ, yâ‚ƒ, W]\n          <;> field_simp [hâ‚€, sub_eq_zero, Ne.symm hâ‚€]\n          <;> ring_nf at *\n          <;> nlinarith\n        exact MordellWeilGroup.mk_point E xâ‚ƒ yâ‚ƒ h",
