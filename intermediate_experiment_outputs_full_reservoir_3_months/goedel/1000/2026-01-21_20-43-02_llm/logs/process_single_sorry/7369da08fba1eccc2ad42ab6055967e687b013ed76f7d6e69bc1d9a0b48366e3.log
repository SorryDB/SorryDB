    have hâ‚† : 2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ â‰  0 := by\n              by_contra hâ‚†\n              have hâ‚‡ : s = (3 * xâ‚پ ^ 2 + 2 * W.aâ‚‚ * xâ‚پ + W.aâ‚„ - W.aâ‚پ * yâ‚پ) / (2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ) := by\n                exact hâ‚…\n              rw [hâ‚†] at hâ‚‡\n              simp_all [div_zero]\n              <;>\n              (try { contradiction }) <;>\n              (try { simp_all [hâ‚ƒ] }) <;>\n              (try { nlinarith })\n            have hâ‚‡ : s * (2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ) = 3 * xâ‚پ ^ 2 + 2 * W.aâ‚‚ * xâ‚پ + W.aâ‚„ - W.aâ‚پ * yâ‚پ := by\n              have hâ‚ˆ : s = (3 * xâ‚پ ^ 2 + 2 * W.aâ‚‚ * xâ‚پ + W.aâ‚„ - W.aâ‚پ * yâ‚پ) / (2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ) := by\n                exact hâ‚…\n              rw [hâ‚ˆ]\n              field_simp [hâ‚†]\n              <;>\n              ring_nf\n            have hâ‚ˆ : (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) ^ 3 + W.aâ‚‚ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) ^ 2 + W.aâ‚„ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) + W.aâ‚† = (s * (xâ‚پ - (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚)) - yâ‚پ - W.aâ‚پ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) - W.aâ‚ƒ) ^ 2 + W.aâ‚پ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) * (s * (xâ‚پ - (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚)) - yâ‚پ - W.aâ‚پ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) - W.aâ‚ƒ) + W.aâ‚ƒ * (s * (xâ‚پ - (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚)) - yâ‚پ - W.aâ‚پ * (s ^ 2 + W.aâ‚پ * s - W.aâ‚‚ - xâ‚پ - xâ‚‚) - W.aâ‚ƒ) := by\n              have hâ‚‰ : xâ‚‚ = xâ‚پ := by\n                linarith\n              rw [hâ‚‰]\n              have hâ‚پâ‚€ : s * (2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ) = 3 * xâ‚پ ^ 2 + 2 * W.aâ‚‚ * xâ‚پ + W.aâ‚„ - W.aâ‚پ * yâ‚پ := by\n                exact hâ‚‡\n              have hâ‚پâ‚پ : 2 * yâ‚پ + W.aâ‚پ * xâ‚پ + W.aâ‚ƒ â‰  0 := by\n                exact hâ‚†\n              nlinarith [sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚„), sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚†)]\n            simp_all [hâ‚ƒ]\n            <;>\n            ring_nf at *\n            <;>\n            nlinarith [sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚„), sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚†)]\n          )",
      "\n            (by\n              -- Prove that (xâ‚ƒ, yâ‚ƒ) lies on the curve\n              dsimp only at *\n              have hâ‚پ : yâ‚پ ^ 2 + W.aâ‚پ * xâ‚پ * yâ‚پ + W.aâ‚ƒ * yâ‚پ = xâ‚پ ^ 3 + W.aâ‚‚ * xâ‚پ ^ 2 + W.aâ‚„ * xâ‚پ + W.aâ‚† := by\n                -- Extract the fact that (xâ‚پ, yâ‚پ) lies on the curve from P\n                have hâ‚‚ : âˆ€ (x y : K), P.point = some (x, y) â†’ y ^ 2 + W.aâ‚پ * x * y + W.aâ‚ƒ * y = x ^ 3 + W.aâ‚‚ * x ^ 2 + W.aâ‚„ * x + W.aâ‚† := P.on_curve\n                have hâ‚ƒ : P.point = some (xâ‚پ, yâ‚پ) := rfl\n                specialize hâ‚‚ xâ‚پ yâ‚پ hâ‚ƒ\n                exact hâ‚‚\n              have hâ‚‚ : yâ‚‚ ^ 2 + W.aâ‚پ * xâ‚‚ * yâ‚‚ + W.aâ‚ƒ * yâ‚‚ = xâ‚‚ ^ 3 + W.aâ‚‚ * xâ‚‚ ^ 2 + W.aâ‚„ * xâ‚‚ + W.aâ‚† := by\n                -- Extract the fact that (xâ‚‚, yâ‚‚) lies on the curve from Q\n                have hâ‚ƒ : âˆ€ (x y : K), Q.point = some (x, y) â†’ y ^ 2 + W.aâ‚پ * x * y + W.aâ‚ƒ * y = x ^ 3 + W.aâ‚‚ * x ^ 2 + W.aâ‚„ * x + W.aâ‚† := Q.on_curve\n                have hâ‚„ : Q.point = some (xâ‚‚, yâ‚‚) := rfl\n                specialize hâ‚ƒ xâ‚‚ yâ‚‚ hâ‚„\n                exact hâ‚ƒ\n              have hâ‚ƒ : xâ‚پ = xâ‚‚ := by assumption\n              have hâ‚„ : yâ‚پ + yâ‚‚ + E.val.aâ‚پ * xâ‚پ + E.val.aâ‚ƒ â‰  0 := by\n                intro hâ‚…\n                apply (show (yâ‚پ + yâ‚‚ + E.val.aâ‚پ * xâ‚پ + E.val.aâ‚ƒ = 0) â†’ False by\n                  intro hâ‚†\n                  have hâ‚‡ : yâ‚پ + yâ‚‚ + E.val.aâ‚پ * xâ‚پ + E.val.aâ‚ƒ = 0 := hâ‚†\n                  simp_all [E]\n                  )\n                <;> simp_all [E]\n              have hâ‚… : MordellWeilGroup.slope E P Q = some s := by\n                simp_all [MordellWeilGroup.slope]\n                <;>\n                  (try simp_all) <;>\n                  (try norm_num) <;>\n                  (try ring_nf at *) <;>\n                  (try field_simp [hâ‚„] at *) <;>\n                  (try simp_all [hâ‚ƒ, sub_ne_zero]) <;>\n                  (try linarith)\n              simp_all [MordellWeilGroup.slope]\n              <;>\n                (try norm_num) <;>\n                (try ring_nf at *) <;>\n                (try field_simp [hâ‚„] at *) <;>\n                (try simp_all [hâ‚ƒ, sub_ne_zero]) <;>\n                (try linarith)\n              <;>\n                (try\n                  {\n                    nlinarith [sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚„)]\n                  })\n            )",
      "(by\n            dsimp only [xâ‚ƒ, yâ‚ƒ, W]\n            <;>\n            (try ring_nf) <;>\n            (try norm_num) <;>\n            (try simp_all [pow_two, pow_three]) <;>\n            (try ring_nf at *) <;>\n            (try field_simp [E.val.IsElliptic.ne_zero, E.val.IsElliptic.ne_zero] at *) <;>\n            (try nlinarith [sq_pos_of_pos (by norm_num : (0 : â„•) < 2)]) <;>\n            (try\n              {\n                cases' eq_or_ne (xâ‚پ - xâ‚‚) 0 with h h <;>\n                  simp_all [h]\n                  <;>\n                  ring_nf at *\n                  <;>\n                  nlinarith [sq_pos_of_pos (by norm_num : (0 : â„•) < 2)]\n              })\n          )",
      "= s(xâ‚پ - xâ‚ƒ) - yâ‚پ - aâ‚پxâ‚ƒ - aâ‚ƒ`,\n\nwe can try to find it from the tangent line:\n\nThe tangent line is `y = s(x - xâ‚پ) + yâ‚پ`, and `(xâ‚ƒ, yâ‚ƒ)` should be the other intersection point. But actually, the line is tangent, so `xâ‚ƒ = xâ‚پ`, but then `yâ‚ƒ = yâ‚پ`, which does not make sense. \n\nBut perhaps my previous approach was interrupted. \n\nAnother approach would be:\n\nGiven that `(xâ‚پ, yâ‚پ)` is on the curve, we have `yâ‚پآ² + aâ‚پxâ‚پyâ‚پ + aâ‚ƒyâ‚پ = xâ‚پآ³ + aâ‚‚xâ‚پآ² + aâ‚„xâ‚پ + aâ‚†`.\n\nWe have `xâ‚ƒ = sآ² + aâ‚پs - aâ‚‚ - xâ‚پ - xâ‚‚`, but `xâ‚پ = xâ‚‚`, so `xâ‚ƒ = sآ² + aâ‚پs - aâ‚‚ - 2xâ‚پ`.\n\nWe also have `yâ‚ƒ = s(xâ‚پ - xâ‚ƒ) - yâ‚پ - aâ‚پxâ‚ƒ - aâ‚ƒ`.\n\nNow, we need to compute `yâ‚ƒآ² + aâ‚پxâ‚ƒyâ‚ƒ + aâ‚ƒyâ‚ƒ - xâ‚ƒآ³ - aâ‚‚xâ‚ƒآ² - aâ‚„xâ‚ƒ -",
      "(by\n            let W := E.val\n            have hâ‚پ : yâ‚پ^2 + W.aâ‚پ*xâ‚پ*yâ‚پ + W.aâ‚ƒ*yâ‚پ = xâ‚پ^3 + W.aâ‚‚*xâ‚پ^2 + W.aâ‚„*xâ‚پ + W.aâ‚† := by\n              apply P.on_curve xâ‚پ yâ‚پ\n              <;> simp\n            have hâ‚‚ : yâ‚‚^2 + W.aâ‚پ*xâ‚‚*yâ‚‚ + W.aâ‚ƒ*yâ‚‚ = xâ‚‚^3 + W.aâ‚‚*xâ‚‚^2 + W.aâ‚„*xâ‚‚ + W.aâ‚† := by\n              apply Q.on_curve xâ‚‚ yâ‚‚\n              <;> simp\n            have hâ‚ƒ : xâ‚‚ = xâ‚پ := by simp_all\n            have hâ‚„ : yâ‚‚ + yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ â‰  0 := by simp_all\n            have hâ‚… : s = (3*xâ‚پ^2 + 2*W.aâ‚‚*xâ‚پ + W.aâ‚„ - W.aâ‚پ*yâ‚پ) / (2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ) := by\n              simp_all [MordellWeilGroup.slope]\n            have hâ‚† : 2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ â‰  0 := by\n              by_contra hâ‚†\n              have hâ‚‡ : 2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ = 0 := by\n                simpa using hâ‚†\n              have hâ‚ˆ : s = 0 := by\n                have hâ‚‰ : s = (3*xâ‚پ^2 + 2*W.aâ‚‚*xâ‚پ + W.aâ‚„ - W.aâ‚پ*yâ‚پ) / (2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ) := by\n                  simp_all [MordellWeilGroup.slope]\n                rw [hâ‚‰]\n                simp [hâ‚‡]\n                <;>\n                  field_simp [hâ‚‡] at * <;>\n                  ring_nf at * <;>\n                  simp_all [MordellWeilGroup.slope] <;>\n                  nlinarith\n              have hâ‚‰ : s = (3*xâ‚پ^2 + 2*W.aâ‚‚*xâ‚پ + W.aâ‚„ - W.aâ‚پ*yâ‚پ) / (2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ) := by\n                simp_all [MordellWeilGroup.slope]\n              simp_all [hâ‚‰]\n              <;>\n                (try { contradiction }) <;>\n                (try {\n                  have hâ‚پâ‚€ := hâ‚پ\n                  simp_all [hâ‚†]\n                  <;>\n                  ring_nf at * <;>\n                  simp_all [MordellWeilGroup.slope]\n                  <;>\n                  nlinarith\n                })\n            have hâ‚‡ : xâ‚ƒ = s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚ := by rfl\n            have hâ‚ˆ : yâ‚ƒ = s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ := by rfl\n            have hâ‚‰ : xâ‚‚ = xâ‚پ := by simp_all\n            simp_all [hâ‚‰]\n            <;>\n              ring_nf at * <;>\n              field_simp [hâ‚†] at * <;>\n              (try {\n                nlinarith\n              }) <;>\n              (try {\n                simp_all [MordellWeilGroup.slope]\n                <;>\n                ring_nf at *\n                <;>\n                nlinarith\n              }) <;>\n              (try {\n                simp_all [MordellWeilGroup.slope]\n                <;>\n                ring_nf at *\n                <;>\n                nlinarith\n              })\n          )\n    else\n      match MordellWeilGroup.slope P Q with\n      | none => MordellWeilGroup.infinity E\n      | some s =>\n        let W := E.val\n        let xâ‚ƒ := s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚\n        let yâ‚ƒ := s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ\n        MordellWeilGroup.mk_point E xâ‚ƒ yâ‚ƒ (by\n          let W := E.val\n          have hâ‚پ : yâ‚پ^2 + W.aâ‚پ*xâ‚پ*yâ‚پ + W.aâ‚ƒ*yâ‚پ = xâ‚پ^3 + W.aâ‚‚*xâ‚پ^2 + W.aâ‚„*xâ‚پ + W.aâ‚† := by\n            apply P.on_curve xâ‚پ yâ‚پ\n            <;> simp\n          have hâ‚‚ : yâ‚‚^2 + W.aâ‚پ*xâ‚‚*yâ‚‚ + W.aâ‚ƒ*yâ‚‚ = xâ‚‚^3 + W.aâ‚‚*xâ‚‚^2 + W.aâ‚„*xâ‚‚ + W.aâ‚† := by\n            apply Q.on_curve xâ‚‚ yâ‚‚\n            <;> simp\n          have hâ‚ƒ : xâ‚‚ â‰  xâ‚پ := by\n            intro h\n            simp_all\n          have hâ‚„ : s = (yâ‚‚ - yâ‚پ) / (xâ‚‚ - xâ‚پ) := by\n            simp_all [MordellWeilGroup.slope]\n            <;>\n            field_simp [sub_ne_zero.mpr hâ‚ƒ] <;>\n            ring_nf <;>\n            simp_all\n          have hâ‚… : xâ‚ƒ = s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚ := by rfl\n          have hâ‚† : yâ‚ƒ = s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ := by rfl\n          simp_all [hâ‚…, hâ‚†]\n          <;>\n          ring_nf at * <;>\n          (try {\n            field_simp [sub_ne_zero.mpr hâ‚ƒ] at *\n            <;>\n            ring_nf at *\n            <;>\n            nlinarith [sq_pos_of_ne_zero (sub_ne_zero.mpr hâ‚ƒ)]\n          }) <;>\n          (try {\n            simp_all [MordellWeilGroup.slope]\n            <;>\n            ring_nf at *\n            <;>\n            nlinarith\n          })\n          <;>\n          (try {\n            simp_all [MordellWeilGroup.slope]\n            <;>\n            ring_nf at *\n            <;>\n            nlinarith\n          })\n        )",
      "â‚†",
      "(by\n            dsimp only at *\n            have hâ‚پ : (xâ‚ƒ : K) = s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚ := rfl\n            have hâ‚‚ : (yâ‚ƒ : K) = s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ := rfl\n            rw [hâ‚پ, hâ‚‚]\n            have hâ‚ƒ : yâ‚پ^2 + W.aâ‚پ*xâ‚پ*yâ‚پ + W.aâ‚ƒ*yâ‚پ = xâ‚پ^3 + W.aâ‚‚*xâ‚پ^2 + W.aâ‚„*xâ‚پ + W.aâ‚† := by\n              simpa [W] using (Q.on_curve xâ‚پ yâ‚پ (by simp [hâ‚پ]))\n            have hâ‚„ : yâ‚‚^2 + W.aâ‚پ*xâ‚‚*yâ‚‚ + W.aâ‚ƒ*yâ‚‚ = xâ‚‚^3 + W.aâ‚‚*xâ‚‚^2 + W.aâ‚„*xâ‚‚ + W.aâ‚† := by\n              simpa [W] using (P.on_curve xâ‚‚ yâ‚‚ (by simp [hâ‚پ]))\n            have hâ‚… : xâ‚پ = xâ‚‚ := by simp_all\n            simp_all [hâ‚…, add_assoc]\n            <;> ring_nf at *\n            <;> simp_all [mul_assoc]\n            <;> norm_num\n            <;>\n            (try\n              {\n                field_simp at *\n                <;>\n                ring_nf at *\n                <;>\n                simp_all [mul_assoc]\n                <;>\n                norm_num\n                <;>\n                nlinarith\n              })\n            <;>\n            (try\n              {\n                variable {K : Type*} {a b : K}\n                <;>\n                simp_all [add_assoc]\n                <;>\n                ring_nf at *\n                <;>\n                nlinarith\n              })\n          )",
