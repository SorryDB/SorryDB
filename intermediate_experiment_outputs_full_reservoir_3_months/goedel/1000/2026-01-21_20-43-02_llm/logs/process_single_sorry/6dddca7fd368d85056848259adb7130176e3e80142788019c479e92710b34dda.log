theorem Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement
    B
    (fun N hN => if N = x ⊔ y then
      calc
        N = x ⊔ y := hN
        _ = sSup (B N hN) := by
          simp only [B]
          <;> simp_all [hxy, sSup_pair]
          <;> aesop
      else
      calc
        N = N := rfl
        _ = sSup ({N} : Set (PersistenceSubmodule M)) := by simp
        _ = sSup (B N hN) := by simp only [B] <;> aesop)
    (fun N hN => if N = x ⊔ y then
      (SetLike.sSupIndep' (Set.toFinset ({x, y} : Set (PersistenceSubmodule M))))
      else
      SetLike.sSupIndep' (Set.toFinset ({N} : Set (PersistenceSubmodule M))))
    (fun N hN => by
      have h₁ : ⊥ ∉ (if N = x ⊔ y then ({x, y} : Set (PersistenceSubmodule M)) else ({N} : Set (PersistenceSubmodule M))) := by
        split_ifs with h
        · intro h₂
          simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at h₂
          cases h₂ with
          | inl h₂ =>
            have h₃ : ⊥ = x := h₂
            have h₄ : x ≠ ⊥ := by
              by_contra h₄
              simp_all [h₄]
              <;> aesop
            contradiction
          | inr h₂ =>
            have h₃ : ⊥ = y := h₂
            have h₄ : y ≠ ⊥ := by
              by_contra h₄
              simp_all [h₄]
              <;> aesop
            contradiction
        · intro h₂
          simp only [Set.mem_singleton_iff] at h₂
          have h₃ : ⊥ = N := h₂
          have h₄ : N ≠ ⊥ := by
            by_contra h₄
            have h₅ : N = ⊥ := by simpa using h₄
            have h₆ : ⊥ ∈ D := by simpa [h₅] using hN
            have h₇ : ⊥ ∉ D := D.not_bot_mem'
            contradiction
          contradiction
      simpa [B] using h₁)
  <;> simp_all
  <;> aesop
