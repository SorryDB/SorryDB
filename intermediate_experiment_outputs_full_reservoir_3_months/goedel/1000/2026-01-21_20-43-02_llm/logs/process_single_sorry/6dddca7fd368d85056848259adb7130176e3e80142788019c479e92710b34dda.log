  exact h₆\n            contradiction\n          exact h₃\n      simp_all\n    }) <;>\n  (try\n    {\n      have h₂ : ∀ (N : PersistenceSubmodule M) (hN : N ∈ D), N = sSup (B N hN) := by\n        intro N hN\n        by_cases h : N = x ⊔ y\n        · have h₃ : B N hN = {x, y} := by\n            simp [B, h]\n          rw [h₃]\n          have h₄ : sSup ({x, y} : Set (PersistenceSubmodule M)) = x ⊔ y := by\n            simp [sSup_insert, sSup_singleton, hxy]\n            <;> aesop\n          simp_all\n          <;> aesop\n        · have h₃ : B N hN = {N} := by\n            simp [B, h]\n          rw [h₃]\n          simp\n          <;> aesop\n      simp_all\n    }) <;>\n  (try\n    {\n      have h₃ : ∀ (N : PersistenceSubmodule M) (hN : N ∈ D), sSupIndep (B N hN) := by\n        intro N hN\n        by_cases h : N = x ⊔ y\n        · have h₄ : B N hN = {x, y} := by\n            simp [B, h]\n          rw [h₄]\n          have h₅ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by\n            have h₆ : x ⊔ y ∈ D := hN\n            have h₇ : Disjoint x y := hxy\n            have h₈ : x ≠ ⊥ := hx\n            have h₉ : y ≠ ⊥ := hy\n            have h₁₀ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by\n              simp [sSupIndep_pair, h₇, h₈, h₉]\n              <;> aesop\n            exact h₁₀\n          exact h₅\n        · have h₄ : B N hN = {N} := by\n            simp [B, h]\n          rw [h₄]\n          have h₅ : sSupIndep ({N} : Set (PersistenceSubmodule M)) := by\n            apply Set.singleton_sSupIndep\n          exact h₅\n      simp_all\n    })",
      "\n      intro N hN\n      by_cases h : N = x ⊔ y\n      · simp [h]\n        <;>\n        (try simp_all [submodule_span_insert, submodule_span_singleton, sSup_insert, sSup_singleton])\n        <;>\n        (try {\n          -- We need to show that x ⊔ y = x ⊔ y\n          simp_all [disjoint_iff_le_compl]\n          <;>\n          (try {\n            -- Since x and y are disjoint, x ⊔ y is the sum of x and y\n            simp_all [Inf_eq_top]\n            <;>\n            (try {\n              exact eq_comm.2 (le_antisymm (by\n                -- Show that x ⊔ y ≤ x ⊔ y\n                simp_all [le_sup_right]\n                ) (by\n                  -- Show that x ⊔ y ≥ x ⊔ y\n                  simp_all [le_sup_left]\n                  ))\n            })\n          })\n        }) <;>\n        (try {\n          -- Use the fact that x and y are disjoint to conclude the proof\n          simp_all [disjoint_iff_le_compl]\n          <;>\n          (try {\n            simp_all [Inf_eq_top]\n            <;>\n            (try {\n              exact eq_comm.2 (le_antisymm (by\n                simp_all [le_sup_right]\n                ) (by\n                  simp_all [le_sup_left]\n                  ))\n            })\n          })\n        }) <;>\n        (try {\n          simp_all [submodule_span_insert, submodule_span_singleton, sSup_insert, sSup_singleton]\n          <;>\n          (try {\n            simp_all [disjoint_iff_le_compl]\n            <;>\n            (try {\n              simp_all [Inf_eq_top]\n              <;>\n              (try {\n                exact eq_comm.2 (le_antisymm (by\n                  simp_all [le_sup_right]\n                  ) (by\n                    simp_all [le_sup_left]\n                    ))\n              })\n            })\n          })\n        }) <;>\n        (try {\n          simp_all [submodule_span_insert, submodule_span_singleton, sSup_insert, sSup_singleton]\n          <;>\n          (try {\n            simp_all [disjoin