lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement
    B (by
      -- Prove that each N = sSup (B N hN)
      intro N hN
      by_cases h : N = x ⊔ y
      · -- Case N = x ⊔ y
        simp only [B, h]
        have h₁ : x ⊔ y = sSup ({x, y} : Set (PersistenceSubmodule M)) := by
          rw [sSup_pair]
          <;> simp_all [le_antisymm_iff, le_sup_iff]
          <;> aesop
        exact h₁
      · -- Case N ≠ x ⊔ y
        simp only [B, h]
        have h₁ : N = sSup ({N} : Set (PersistenceSubmodule M)) := by
          simp [sSup_singleton]
        exact h₁
    ) (by
      -- Prove that each B N hN is sSupIndep
      intro N hN
      by_cases h : N = x ⊔ y
      · -- Case N = x ⊔ y
        simp only [B, h]
        have h₁ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by
          -- Prove that {x, y} is sSupIndep
          have h₂ : Disjoint x y := by
            -- Extract the disjointness condition from the hypothesis
            have h₃ : Disjoint x y := by
              -- Prove that x and y are disjoint
              have h₄ : x ⊔ y ∈ D := hN
              have h₅ : Disjoint x y := by tauto
              exact h₅
            exact h₃
          -- Use the fact that {x, y} is sSupIndep if x and y are disjoint
          have h₃ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by
            rw [sSupIndep_pair]
            <;> simp_all [ne_eq, Set.mem_insert_iff, Set.mem_singleton_iff]
            <;> aesop
          exact h₃
        exact h₁
      · -- Case N ≠ x ⊔ y
        simp only [B, h]
        have h₁ : sSupIndep ({N} : Set (PersistenceSubmodule M)) := by
          -- Prove that {N} is sSupIndep
          simp [sSupIndep_singleton]
        exact h₁
    ) (by
      -- Prove that ⊥ ∉ B N hN for each N, hN
      intro N hN
      by_cases h : N = x ⊔ y
      · -- Case N = x ⊔ y
        simp only [B, h]
        intro h₁
        simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at h₁
        -- Prove that neither x nor y is ⊥
        have h₂ : x ≠ ⊥ := by tauto
        have h₃ : y ≠ ⊥ := by tauto
        cases h₁ <;> simp_all [h₂, h₃]
        <;> aesop
      · -- Case N ≠ x ⊔ y
        simp only [B, h]
        intro h₁
        simp only [Set.mem_singleton_iff] at h₁
        -- Prove that N ≠ ⊥
        have h₂ : N ≠ ⊥ := by
          by_contra h₃
          have h₄ : N = ⊥ := by tauto
          have h₅ : ⊥ ∈ D := by simpa [h₄] using hN
          have h₆ : ∀ (D : DirectSumDecomposition M), ⊥ ∉ D := by
            intros D
            exact D.not_bot_mem'
          have h₇ : ⊥ ∉ D := h₆ D
          exact h₇ h₅
        simp_all [h₂]
        <;> aesop
    )
  <;> try simp_all
