      have h₁ : ⊥ ≠ x := by
        intro h₂
        have h₃ : x = ⊥ := by rw [h₂]
        contradiction
      have h₂ : ⊥ ≠ y := by
        intro h₃
        have h₄ : y = ⊥ := by rw [h₃]
        contradiction
