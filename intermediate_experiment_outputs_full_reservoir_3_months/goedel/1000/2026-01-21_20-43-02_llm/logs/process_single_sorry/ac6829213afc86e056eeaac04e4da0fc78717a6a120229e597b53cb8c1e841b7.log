theorem Vector.mapIdx_eq_map {v : Vector α n} (f : α → β) :
    v.mapIdx (λ _ => f) = v.map f := by
  have h : ∀ (v : Vector α n), v.mapIdx (λ _ => f) = v.map f := by
    intro v
    vector_induction v with
    | mk0 => rfl
    | mk1 a v ih =>
      simp_all [Vector.map, Vector.mapIdx, Vector.get]
      <;>
      (try decide) <;>
      (try ring_nf) <;>
      (try norm_num) <;>
      (try rfl) <;>
      (try simp_all [Function.comp]) <;>
      (try aesop)
  exact h v
