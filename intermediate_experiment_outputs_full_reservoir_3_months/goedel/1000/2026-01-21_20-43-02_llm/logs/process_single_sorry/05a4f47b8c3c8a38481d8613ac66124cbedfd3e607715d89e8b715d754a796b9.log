j => eLpNorm (Y j) 2 P) i\n            have h₈ : eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ (⨆ j, eLpNorm (X j) 2 P) + (⨆ j, eLpNorm (Y j) 2 P) := by\n              gcongr <;> simp_all [le_iSup]\n            exact h₈\n          _ = (⨆ i, eLpNorm (X i) 2 P) + (⨆ j, eLpNorm (Y j) 2 P) := by\n            simp [iSup_add]\n      have h₆ : (⨆ i, eLpNorm (X i) 2 P) + (⨆ i, eLpNorm (Y i) 2 P) < ∞ := by\n        have h₇ : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded\n        have h₈ : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded\n        -- The sum of two finite values is finite\n        have h₉ : (⨆ i, eLpNorm (X i) 2 P) + (⨆ i, eLpNorm (Y i) 2 P) < ∞ := by\n          -- Use the fact that the sum of two finite values is finite\n          have h₁₀ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) < ∞ := by exact_mod_cast h₇\n          have h₁₁ : (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by exact_mod_cast h₈\n          -- Use the fact that the sum of two finite values is finite\n          have h₁₂ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) + (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by\n            -- Use the fact that the sum of two finite values is finite\n            exact ENNReal.add_lt_top h₁₀ h₁₁\n          -- Convert back to ℝ≥0∞\n          exact_mod_cast h₁₂\n        exact h₉\n      -- Combine the inequalities to get the final result\n      calc\n        ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ (⨆ i, eLpNorm (X i) 2 P) + (⨆ j, eLpNorm (Y j) 2 P) := h₅\n        _ < ∞ := h₆\n    calc\n      ⨆ i, eLpNorm ((fun i ω ↦ X i ω + Y i ω) i) 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := h₃\n      _ < ∞ := h₄",
