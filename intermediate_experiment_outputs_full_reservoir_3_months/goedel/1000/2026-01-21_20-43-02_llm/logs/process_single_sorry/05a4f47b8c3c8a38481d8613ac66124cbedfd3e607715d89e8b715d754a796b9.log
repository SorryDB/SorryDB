          have h4 : ⨆ i : ι, eLpNorm (X i) 2 P + ⨆ i : ι, eLpNorm (Y i) 2 P ≥ ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
            apply iSup_add_le
          linarith
        _ < ∞ := by
          -- Since both iSup are finite, their sum is finite
          have h4 : ⨆ i, eLpNorm (X i) 2 P < ∞ := h1
          have h5 : ⨆ i, eLpNorm (Y i) 2 P < ∞ := h2
          have h6 : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) + ⨆ i, eLpNorm (Y i) 2 P < ∞ := by
