      "-- Prove that the sum of two cadlag functions is cadlag\n    have hX_cadlag : IsCadlag (fun x : ι => X x ω) := hX.cadlag ω\n    have hY_cadlag : IsCadlag (fun x : ι => Y x ω) := hY.cadlag ω\n    -- Use the fact that the sum of cadlag functions is cadlag\n    refine' ⟨fun t => by\n      -- Right-continuity of the sum\n      have hX_right_cont : ContinuousWithinAt (fun x : ι => X x ω) (Set.Ici t) t := hX_cadlag.isRightContinuous t\n      have hY_right_cont : ContinuousWithinAt (fun x : ι => Y x ω) (Set.Ici t) t := hY_cadlag.isRightContinuous t\n      have h_sum_right_cont : ContinuousWithinAt (fun x : ι => X x ω + Y x ω) (Set.Ici t) t := ContinuousWithinAt.add hX_right_cont hY_right_cont\n      exact h_sum_right_cont, fun t => by\n      -- Left limit of the sum\n      have hX_left_lim : Tendsto (fun x : ι => X x ω) (nhdsWithin t (Set.Iio t)) (nhds (X t ω)) := hX_cadlag.hasLeftLimit t\n      have hY_left_lim : Tendsto (fun x : ι => Y x ω) (nhdsWithin t (Set.Iio t)) (nhds (Y t ω)) := hY_cadlag.hasLeftLimit t\n      have h_sum_left_lim : Tendsto (fun x : ι => X x ω + Y x ω) (nhdsWithin t (Set.Iio t)) (nhds (X t ω + Y t ω)) := Tendsto.add hX_left_lim hY_left_lim\n      exact h_sum_left_lim⟩\n  · sorry",
      "-- Prove that the sum process is cadlag\n    have hX_cadlag : IsCadlag (fun x => X x ω) := hX.cadlag ω\n    have hY_cadlag : IsCadlag (fun x => Y x ω) := hY.cadlag ω\n    exact IsCadlag.add hX_cadlag hY_cadlag\n  · -- Prove that the sum process is uniformly bounded in L2 norm\n    have hX_bounded : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded\n    have hY_bounded : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded\n    have h_sum_bounded : ⨆ i, eLpNorm (fun ω => X i ω + Y i ω) 2 P < ∞ := by\n      calc\n        ⨆ i, eLpNorm (fun ω => X i ω + Y i ω) 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by sorry\n        _ = (⨆ i, eLpNorm (X i) 2 P) + (⨆ i, eLpNorm (Y i) 2 P) := by sorry\n        _ < ∞ := by sorry\n    exact h_sum_bounded",
