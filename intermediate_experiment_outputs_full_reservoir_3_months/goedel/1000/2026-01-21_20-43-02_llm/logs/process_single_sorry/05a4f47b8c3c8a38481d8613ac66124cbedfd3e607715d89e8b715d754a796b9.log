                 _ ≤ ∫ ω : Ω, (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by\n                        -- Use the fact that the norm of the sum is less than or equal to the sum of the norms\n                        have h₆ : ∀ ω : Ω, ‖X i ω + Y i ω‖ ^ 2 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by\n                          intro ω\n                          have h₇ : ‖X i ω + Y i ω‖ ≤ ‖X i ω‖ + ‖Y i ω‖ := norm_add_le (X i ω) (Y i ω)\n                          have h₈ : ‖X i ω + Y i ω‖ ^ 2 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by\n                            exact pow_le_pow_of_le_left (by positivity) h₇ 2\n                          exact h₈\n                        -- Use the fact that the integral of a function that is less than or equal to another function is less than or equal to the integral of the other function\n                        refine' integral_mono (by\n                          -- Prove that the function is non-negative\n                          have h₁₀ : ∀ ω : Ω, 0 ≤ ‖X i ω + Y i ω‖ ^ 2 := by\n                            intro ω\n                            positivity\n                          have h₁₁ : ∀ ω : Ω, 0 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by\n                            intro ω\n                            positivity\n                          exact ConvergenceTheorems.ae_restrict_set.mpr (h₁₀, h₁₁)\n                          ) (by\n                            -- Prove that the function is less than or equal to the other function\n                            filter_upwards with ω\n                            exact h₆ ω\n                          ) (by\n                            -- Prove that the function is integrable\n                            have h₁₀ : ∫ ω : Ω, ‖X i ω + Y i ω‖ ^ 2 < ∞ := by\n                              -- Use the fact that the integral of the sum is less than or equal to the sum of the integrals\n                              have h₁₁ : ∫ ω : Ω, ‖X i ω + Y i ω‖ ^ 2 < ∞ := by\n                                -- Use the fact that the integral of the sum is