lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h₁ : (supportSet p).card ≤ (support p).length := by
    simp [supportSet]
    <;>
    exact Finset.card_le_of_subset (Finset.subset_univ _)
  have h₂ : (support p).length ≤ (edgeSet p).card + 1 := by
    have h₃ : (support p).length ≤ (darts p).length + 1 := by
      -- The number of vertices is at most the number of edges plus one
      have h₄ : ∀ (p : G.LoopWalk u v), (support p).length ≤ (darts p).length + 1 := by
        intro p
        induction p with
        | nil => simp [support, darts]
        | cons u v' _ h p ih =>
          simp_all [support, darts, List.length]
          <;>
          omega
        | loop p ih =>
          simp_all [support, darts, List.length]
          <;>
          omega
      exact h₄ p
    have h₅ : (darts p).length = (edgeSet p).card := by
      -- The number of edges is equal to the number of darts
      simp [edgeSet]
      <;>
      simp_all [darts]
      <;>
      rw [List.length_toFinset_of_nodup]
      <;>
      simp_all [List.nodup_cons, List.nodup_nil]
      <;>
      aesop
    linarith
  have h₃ : (supportSet p).card ≤ (edgeSet p).card + 1 := by
    calc
      (supportSet p).card ≤ (support p).length := h₁
      _ ≤ (edgeSet p).card + 1 := h₂
  exact h₃
