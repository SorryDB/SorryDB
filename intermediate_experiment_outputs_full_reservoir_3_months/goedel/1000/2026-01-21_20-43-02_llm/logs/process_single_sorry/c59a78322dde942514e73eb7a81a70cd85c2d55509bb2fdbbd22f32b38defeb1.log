theorem vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h₁ : (supportSet p).card ≤ (support p).length := by
    simp [supportSet]
    <;>
    exact
      (Finset.card_le_card (Finset.filter_subset _ _)).trans (by simp [List.length_toFinset])
  have h₂ : (support p).length ≤ (edgeSet p).card +1 := by
    have h₃ : (support p).length ≤ (p.edges).length +1 := by
      -- The length of the support is at most the length of the edge list plus one.
      -- This is because each edge connects two vertices, so the number of vertices is at most the number of edges plus one.
      -- Note: This is a loose bound, but it suffices for our purposes.
      induction p with
      | nil =>
        simp [support, edges, darts]
      | cons u v w _ h p ih =>
        simp_all [support, edges, darts, List.length, Finset.card_insert_of_not_mem, Finset.mem_singleton]
        <;>
        (try omega) <;>
        (try simp_all [Sym2.mk.injEq]) <;>
        (try omega) <;>
        (try simp_all [List.length]) <;>
        (try omega)
      | loop u v p ih =>
        simp_all [support, edges, darts, List.length, Finset.card_insert_of_not_mem, Finset.mem_singleton]
        <;>
        (try omega) <;>
        (try simp_all [Sym2.mk.injEq]) <;>
        (try omega) <;>
        (try simp_all [List.length]) <;>
        (try omega)
    have h₄ : (p.edges).length = (edgeSet p).card := by
      -- The length of the edge list is equal to the cardinality of the edge set.
      -- This is because each edge is counted once in the set.
      simp [edgeSet, edges, darts]
      <;>
      rw [List.toFinset_card]
    linarith
  have h₃ : (supportSet p).card ≤ (edgeSet p).card +1 := by
    linarith
  exact h₃
