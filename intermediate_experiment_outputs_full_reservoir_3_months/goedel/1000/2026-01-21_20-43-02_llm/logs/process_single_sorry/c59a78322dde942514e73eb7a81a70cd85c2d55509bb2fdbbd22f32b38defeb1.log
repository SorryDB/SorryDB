lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  -- We will prove this by induction on the structure of the LoopWalk.
  have h₁ : (supportSet p).card ≤ (edgeSet p).card +1 := by
    -- Base case: when the loop walk is nil
    def loop_walk_card (p : G.LoopWalk u v) : ℕ :=
      match p with
      | LoopWalk.nil => 0
      | LoopWalk.cons _ p => p.length.succ
      | LoopWalk.loop p => p.length.succ
    -- Use induction on the loop_walk_card
    have h₂ : ∀ (p : G.LoopWalk u v), (supportSet p).card ≤ (edgeSet p).card + 1 := by
      intro p
      induction p using LoopWalk.induction_on with
      | nil =>
        -- Base case: nil
        simp [supportSet, edgeSet]
        <;> aesop
      | cons h p ih =>
        -- Inductive step: cons
        simp_all [supportSet, edgeSet, LoopWalk.darts, LoopWalk.edges, Finset.card_insert_of_not_mem,
          Finset.mem_singleton, Finset.card_singleton, List.mem_map, List.mem_cons, List.mem_singleton]
        <;>
        (try decide) <;>
        (try omega) <;>
        (try
          {
            cases' ih with h₃ h₃ <;>
            simp_all [supportSet, edgeSet, LoopWalk.darts, LoopWalk.edges, Finset.card_insert_of_not_mem,
              Finset.mem_singleton, Finset.card_singleton, List.mem_map, List.mem_cons, List.mem_singleton]
            <;>
            (try omega)
          }) <;>
        (try
          {
            aesop
          })
      | loop p ih =>
        -- Inductive step: loop
        simp_all [supportSet, edgeSet, LoopWalk.darts, LoopWalk.edges, Finset.card_insert_of_not_mem,
          Finset.mem_singleton, Finset.card_singleton, List.mem_map, List.mem_cons, List.mem_singleton]
        <;>
        (try decide) <;>
        (try omega) <;>
        (try
          {
            cases' ih with h₃ h₃ <;>
            simp_all [supportSet, edgeSet, LoopWalk.darts, LoopWalk.edges, Finset.card_insert_of_not_mem,
              Finset.mem_singleton, Finset.card_singleton, List.mem_map, List.mem_cons, List.mem_singleton]
            <;>
            (try omega)
          }) <;>
        (try
          {
            aesop
          })
    -- Apply the induction hypothesis
    exact h₂ p
  exact h₁
