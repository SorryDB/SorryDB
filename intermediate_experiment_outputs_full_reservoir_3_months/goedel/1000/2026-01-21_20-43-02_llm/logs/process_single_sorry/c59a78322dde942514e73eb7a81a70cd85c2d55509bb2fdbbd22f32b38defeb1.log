lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h₁ : (supportSet p : List V).toFinset.card ≤ (edgeSet p : List (Sym2 V)).toFinset.card + 1 := by
    have h₂ : (support p).toFinset.card ≤ (edges p).toFinset.card + 1 := by
      -- Use the fact that the number of vertices in a walk is at most the number of edges plus one
      have h₃ : (support p).toFinset.card ≤ (support p).length := by
        -- The number of unique vertices is at most the number of all vertices
        apply (Finset.card_le_of_subset (Finset.subset_univ _)).trans
        simp [List.toFinset_card]
      have h₄ : (edges p).length = (support p).length - 1 := by
        -- The number of edges is one less than the number of vertices in a simple path (not directly applicable, but gives intuition)
        have h₅ : ∀ (w : G.LoopWalk u v), (edges w).length = (support w).length - 1 := by
          intro w
          induction w with
          | nil => simp [edges, support]
          | cons h p ih =>
            cases p with
            | nil =>
              simp_all [edges, support, List.length]
              <;>
              simp_all [LoopWalk.length, LoopWalk.support, List.length]
              <;>
              omega
            | cons h' p =>
              simp_all [edges, support, List.length]
              <;>
              simp_all [LoopWalk.length, LoopWalk.support, List.length]
              <;>
              omega
          | loop p ih =>
            cases p with
            | nil =>
              simp_all [edges, support, List.length]
              <;>
              simp_all [LoopWalk.length, LoopWalk.support, List.length]
              <;>
              omega
            | cons h' p =>
              simp_all [edges, support, List.length]
              <;>
              simp_all [LoopWalk.length, LoopWalk.support, List.length]
              <;>
              omega
            | loop p =>
              simp_all [edges, support, List.length]
              <;>
              simp_all [LoopWalk.length, LoopWalk.support, List.length]
              <;>
              omega
        exact h₅ p
      have h₆ : (edges p).toFinset.card ≤ (edges p).length := by
        -- The number of unique edges is at most the number of edges
        have h₇ : (edges p).toFinset.card ≤ (edges p).length := by
          apply (Finset.card_le_of_subset (Finset.subset_univ _)).trans
          simp [List.toFinset_card]
        exact h₇
      -- Combine the inequalities to get the desired result
      have h₇ : (support p).toFinset.card ≤ ((edges p).length) + 1 := by
        have h₈ : (support p).toFinset.card ≤ (support p).length := h₃
        have h₉ : (support p).length = (edges p).length + 1 := by
          omega
        omega
      have h₈ : (edges p).toFinset.card + 1 ≥ (support p).toFinset.card := by
        omega
      have h₉ : (edges p).toFinset.card ≥ 0 := by positivity
      omega
    -- Convert the list inequalities to Finset inequalities
    simpa [edgeSet, supportSet] using h₂
  simpa [edgeSet, supportSet] using h₁
