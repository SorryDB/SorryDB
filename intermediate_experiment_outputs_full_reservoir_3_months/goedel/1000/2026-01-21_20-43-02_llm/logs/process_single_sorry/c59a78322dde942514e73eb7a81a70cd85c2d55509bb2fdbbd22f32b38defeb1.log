/- The `supportSet` of a LoopWalk is the set of vertices it visits.-/
def supportSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset V :=
  (support p).toFinset

/-- The `edgeSet` of a LoopWalk is the set of edges it visits.-/
def edgeSet {u v: V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (Sym2 V) := (edges p).toFinset

/- The `edgeCount` of a walk is the number of times it traverses an edge.-/
def edgeCount {u v : V} (p : G.LoopWalk u v) (e : Sym2 V) : ℕ := countP (· = e) p.edges

/-The sum of edge counts over all edges in a walk's edge set is the length of the walk.-/
lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  sorry

/--Edge counting lemma in the proof of vertex_edge_inequality.-/
lemma edge_count_lemma {u v : V} (p : G.LoopWalk u v) : ∀ (e : Sym2 V),
    edgeCount p e ≤ count e (edges p) := by
  intro e
  simp [edgeCount, countP]
  <;> simp_all [List.count_cons, List.count_eq_zero, Finset.mem_coe]
  <;> try contradiction
  <;> try simp_all [List.mem_cons, List.mem_nil_iff]
  <;> try omega

/-- The number of vertices is at most the number of edges plus one (by induction). -/
lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  sorry
