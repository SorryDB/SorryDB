def f (x : Fin 3 тЖТ тДЭ) : тДЭ := x 0 + x 1 - x 2

def C : Set (Fin 3 тЖТ тДЭ) := {x : Fin 3 тЖТ тДЭ | f x тЙе 1}

lemma hC : Convex тДЭ C := by
  -- We need to show that C is convex.
  -- The set C is defined by the inequality f(x) тЙе 1.
  -- The function f(x) = xтВА + xтВБ - xтВВ is linear, and its graph is a plane.
  -- The set C is on one side of this plane, hence it is convex.
  have hтВБ : Convex тДЭ {x : Fin 3 тЖТ тДЭ | f x тЙе 1} := by
    -- Use the fact that the linear image of a convex set is convex.
    have hтВВ : Convex тДЭ (Set.Ici (1 : тДЭ)) := convex_Ici
    -- The preimage of a convex set under a linear map is convex.
    have hтВГ : Convex тДЭ ({x : Fin 3 тЖТ тДЭ | f x тЙе 1} : Set (Fin 3 тЖТ тДЭ)) :=
      (convex_le_of_isOpen _ (isOpen_Ioi.mem_nhds (by norm_num))).of_le hтВВ (fun x => by simp [f])
    exact hтВГ
  exact hтВБ

def x (i : тДХ) : Fin 3 тЖТ тДЭ := fun _ => (i : тДЭ) / (i + 1)

def y (s : Set тДХ) : Fin 3 тЖТ тДЭ :=
  fun j =>
    if j = 0 then (1 : тДЭ) else if j = 1 then 0 else if j = 2 then if s = тИЕ then 0 else -100 end

