lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  have h_main : ∃ P, G.IsAugPath hM P := by
    by_contra! h
    -- Assume the contrary: no augmenting path exists.
    have h₁ : G.IsMaxMatching M := by
      -- We will show that M is a maximum matching if no augmenting path exists.
      exact ⟨hM, fun M' hM' => by
