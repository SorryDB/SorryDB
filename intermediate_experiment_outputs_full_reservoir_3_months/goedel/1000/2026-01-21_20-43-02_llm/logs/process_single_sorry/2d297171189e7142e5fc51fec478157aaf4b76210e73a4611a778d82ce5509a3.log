      have h₃ : ¬( {x : ℝ | x < 0} : Set ℝ) ∋ Real.pi := by
        norm_num [Real.pi_pos.le]
        <;>
        linarith [Real.pi_gt_three]
      simp [h₃, μD]
      <;>
      aesop
    -- Therefore, {x | x < 0} is almost equal to ∅ with respect to μD.
    exact Set.eventually_of_forall fun x => by
      simp_all [μD]
      <;>
      aesop
  exact h

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  -- Use the transitivity of the almost everywhere equality.
  have h3 : f =ᵐ[μL] h := by
    -- Since f =ᵐ[μL] g and g =ᵐ[μL] h, by transitivity, f =ᵐ[μL] h.
    have h4 : f =ᵐ[μL] h := h1.trans h2
