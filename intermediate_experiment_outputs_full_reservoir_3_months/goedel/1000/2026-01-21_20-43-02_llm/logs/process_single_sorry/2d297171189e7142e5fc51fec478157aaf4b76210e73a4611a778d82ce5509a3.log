section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    fun s => if π ∈ s then 1 else 0
  empty := by
    norm_num [Set.not_mem_empty]
  mono {S T} hST := by
    by_cases h : π ∈ T <;> by_cases hS : π ∈ S <;> simp_all [h, hS]
    <;> aesop
  iUnion_nat := by
    intro s
    by_cases h : ∀ n, π ∈ s n
    · -- Case: For all n, π ∈ s n
      have h₁ : π ∈ ⋃ n : ℕ, s n := by
        -- Since π ∈ s 0, it belongs to the union
        have h₂ : π ∈ s 0 := h 0
        exact Set.mem_iUnion.mpr ⟨0, h₂⟩
      simp_all [h₁]
    · -- Case: There exists n such that π ∉ s n
      have h₁ : ∃ n, π ∉ s n := by
        by_contra h₁
        push_neg at h₁
        exact h h₁
      obtain ⟨n, hn⟩ := h₁
      -- Since π ∉ s n, the sum of measures is 0
      have h₂ : ∀ m, (μD : OuterMeasure ℝ).measureOf (s m) = 0 := by
        intro m
        by_cases hm : π ∈ s m
        · exfalso
          have h₃ : m = n := by
            by_contra h₃
            have h₄ := h m
            simp_all
            <;> aesop
          simp_all
          <;> aesop
        · simp_all [hm]
          <;> aesop
      -- The measure of the union is 0
      have h₃ : (μD : OuterMeasure ℝ).measureOf (⋃ n : ℕ, s n) = 0 := by
        by_cases h₃ : π ∈ ⋃ n : ℕ, s n
        · exfalso
          have h₄ : ∃ n, π ∈ s n := by
            simp only [Set.mem_iUnion] at h₃
            obtain ⟨n, hn⟩ := h₃
            exact ⟨n, hn⟩
          obtain ⟨n, hn⟩ := h₄
          have h₅ : π ∈ s n := hn
          have h₆ : π ∉ s n := by
            have h₇ := h n
            simp_all
            <;> aesop
          contradiction
        · simp_all [h₃]
          <;> aesop
      -- The sum of the measures is 0
      calc
        (μD : OuterMeasure ℝ).measureOf (⋃ n : ℕ, s n) = 0 := h₃
        _ ≤ ∑' n : ℕ, (μD : OuterMeasure ℝ).measureOf (s n) := by
          have h₄ : ∀ n, (μD : OuterMeasure ℝ).measureOf (s n) = 0 := h₂
          calc
            (0 : ℝ≥0∞) = ∑' n : ℕ, 0 := by simp [tsum_zero]
            _ = ∑' n : ℕ, (μD : OuterMeasure ℝ).measureOf (s n) := by
              congr with n
              rw [h₂ n]
              <;> simp
  
  <;> simp_all [μD]
  <;> norm_num
  <;> aesop

def μL : Measure ℝ := by
  exact volume.restrict univ

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h : (μD : OuterMeasure ℝ).measureOf {x : ℝ | x < 0} = 0 := by
    have h₁ : (π : ℝ) ∉ {x : ℝ | x < 0} := by
      have h₂ : (π : ℝ) > 0 := Real.pi_pos
      intro h₃
      linarith
    simp [h₁]
    <;> aesop
  have h₂ : (μD : OuterMeasure ℝ).measureOf (∅ : Set ℝ) = 0 := by
    simp
    <;> aesop
  have h₃ : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    rw [MeasureTheory.ae_iff]
    <;> simp_all [h, h₂]
    <;> aesop
  exact h₃

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  refine' h1.trans _
  <;> simpa [MeasureTheory.ae_eq] using h2

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  refine' h1.trans _
  <;> simpa [MeasureTheory.ae_eq] using h2

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  refine' h1.trans _
  <;> simpa [MeasureTheory.ae_eq] using h2

end Lp

