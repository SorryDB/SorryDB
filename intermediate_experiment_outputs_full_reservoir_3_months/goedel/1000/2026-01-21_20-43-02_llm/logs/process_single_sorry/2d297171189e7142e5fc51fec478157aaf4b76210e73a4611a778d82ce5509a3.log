/-!
# Filters
-/


section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro S hS
  have h' : F.map f ≤ G.map f := by
    apply Filter.map_mono h
  exact h' hS

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  rw [Tendsto] at hs ht ⊢
  -- Use the property of filter maps to show that (t ∘ s) tends to H along F
  have h : (F.map (t ∘ s)) ≤ H := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        simp [Filter.map_map]
        <;>
        congr 1 <;>
        ext <;>
        simp [Function.comp]
        <;>
        congr 1 <;>
        ext <;>
        simp [Function.comp]
      _ ≤ G.map t := by
        -- Since F.map s ≤ G, we have (F.map s).map t ≤ G.map t
        exact Filter.map_mono hs
      _ ≤ H := ht
  exact h

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the composition property of tendsto to combine the limits of f and g
    have h₁ : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h₂ : Tendsto g (𝓝 Real.pi) atTop := hg
    -- Apply the composition property of tendsto
    have h₃ : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp h₁ h₂
    exact h₃
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    have h₁ : Tendsto a atTop (𝓝 (-1)) := ha
    have h₂ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
    have h₃ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp h₁ h₂
    exact h₃
  exact h

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₁ : {x : α | p x} ∈ 𝓝 x := hT
    have h₂ : {x : α | q x} ∈ 𝓝 x := hS
    have h₃ : {x : α | p' x} ∈ 𝓝 x := hT'
    have h₄ : {x : α | q' x} ∈ 𝓝 x := hS'
    -- Use the fact that the intersection of two neighborhoods is a neighborhood
    have h₅ : {x : α | p x ∧ q x} ∈ 𝓝 x := by
      apply Filter.mem_of_superset (Filter.inter_mem h₁ h₂)
      intro y hy
      simp only [Set.mem_setOf_eq] at hy ⊢
      tauto
    have h₆ : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
      apply Filter.mem_of_superset (Filter.inter_mem h₃ h₄)
      intro y hy
      simp only [Set.mem_setOf_eq] at hy ⊢
      tauto
    -- Use the fact that the union of two neighborhoods is a neighborhood
    have h₇ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
      apply Filter.mem_of_superset (Filter.union_mem h₅ h₆)
      intro y hy
      simp only [Set.mem_setOf_eq] at hy ⊢
      tauto
    exact h₇
  exact h

end Filter

