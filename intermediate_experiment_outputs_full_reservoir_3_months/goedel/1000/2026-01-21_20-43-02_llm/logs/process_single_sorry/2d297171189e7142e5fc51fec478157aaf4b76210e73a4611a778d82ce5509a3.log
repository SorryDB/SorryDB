section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  -- Use the property that the image of a smaller filter is smaller
  exact Filter.map_mono h


/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the transitivity of the filter relation
  have h : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = F.map s |>.map t := by
        -- Show that the image of F under t ∘ s is the same as the image of (F under s) under t
        simp [Function.comp]
        <;>
        rw [Filter.map_map]
      _ ≤ G.map t := by
        -- Since F.map s ≤ G, the image of F.map s under t ≤ image of G under t
        exact Filter.map_mono hs
      _ ≤ H := ht
  -- Use the fact that h : F.map (t ∘ s) ≤ H to conclude that Tendsto (t ∘ s) F H
  exact h


