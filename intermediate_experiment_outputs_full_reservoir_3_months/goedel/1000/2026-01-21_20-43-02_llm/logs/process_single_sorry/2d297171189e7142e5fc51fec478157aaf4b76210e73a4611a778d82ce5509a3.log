section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    intro s
    -- If the set contains π, then the measure is 1; otherwise, it is 0.
    if (s : Set ℝ) ∋ Real.pi then 1 else 0
  empty := by
    -- The empty set has measure 0.
    simp [Set.not_mem_empty]
  mono {S T} hST := by
    -- If S is a subset of T and S contains π, then T contains π.
    by_cases h : (S : Set ℝ) ∋ Real.pi <;> simp_all [h]
    <;>
    aesop
  iUnion_nat := by
    -- The measure of a countable union is bounded by the sum of the measures.
    intro s
    by_cases h : ∃ (n : ℕ), (s n : Set ℝ) ∋ Real.pi
    · -- If there exists a set containing π, then the union contains π.
      obtain ⟨n, hn⟩ := h
      have h₁ : Real.pi ∈ ⋃ (n : ℕ), (s n : Set ℝ) := by
        exact Set.mem_iUnion.mpr ⟨n, hn⟩
      simp_all
      <;>
      norm_num
      <;>
      aesop
    · -- If no set contains π, then the union does not contain π.
      have h₁ : ¬(⋃ (n : ℕ), (s n : Set ℝ)) ∋ Real.pi := by
        intro h₂
        obtain ⟨n, hn⟩ := Set.mem_iUnion.mp h₂
        exact h ⟨n, hn⟩
      simp_all
      <;>
      norm_num
      <;>
      aesop

def μL : Measure ℝ := by
  -- Use the volume measure on ℝ as the Lebesgue measure.
  volume.ge

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h :  {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    -- Since μD is 1 at π and 0 elsewhere, and π is not in {x | x < 0}, the symmetric difference has measure 0.
    have h₁ : ( {x : ℝ | x < 0} : Set ℝ) Δ (∅ : Set ℝ) = {x : ℝ | x < 0} := by
      simp [Set.ext_iff]
      <;>
      aesop
    have h₂ : μD ( {x : ℝ | x < 0} : Set ℝ) Δ (∅ : Set ℝ) = 0 := by
