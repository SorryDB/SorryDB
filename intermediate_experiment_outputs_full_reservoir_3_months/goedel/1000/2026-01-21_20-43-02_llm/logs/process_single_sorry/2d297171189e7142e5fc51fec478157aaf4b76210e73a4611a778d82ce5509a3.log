lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h₁ : Tendsto (t ∘ s) F H := by
    have h₂ : Tendsto s F G := hs
    have h₃ : Tendsto t G H := ht
    have h₄ : Tendsto (t ∘ s) F H := Tendsto.comp h₃ h₂
    exact h₄
