def ONE : PreLp (fun n : ℕ ↦ ℝ) := (fun _ : ℕ ↦ 1)

def GEO : PreLp (fun n : ℕ ↦ ℝ) := (fun n : ℕ ↦ (1 / n))

example : Memℓp ONE ∞ := by
  have h : ∀ (n : ℕ), ‖(1 : ℝ)‖ = 1 := by
    intro n
    simp [Real.norm_eq_abs, abs_of_nonneg]
  -- We need to show that the sum of the absolute values of the sequence is bounded.
  -- For the sequence (1, 1, 1, ...), the sum of the absolute values is not bounded, but we are working with p = ∞.
  -- For p = ∞, the norm of the sequence is the supremum of the absolute values, which is 1 in this case.
  -- Therefore, the sequence belongs to ℓ^∞.
  simp [h, PreLp.instNorm]
  <;>
  (try norm_num) <;>
  (try simp_all [ENNReal.ofReal_eq_top_iff]) <;>
  (try norm_num) <;>
  (try aesop)
  <;>
  (try
    {
      -- Use the fact that the supremum of the sequence is 1
      have h₁ : (⊤ : ENNReal) = ⊤ := rfl
      simp_all [ENNReal.ofReal_eq_top_iff]
      <;> norm_num
      <;> aesop
    })
