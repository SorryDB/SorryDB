lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have : s ∈ G.map f := by
    -- Use the fact that F ≤ G to show that s ∈ G.map f
    have h₂ : F.map f ≤ G.map f := by
      -- The map of a filter under a function is monotone
      exact Filter.map_mono h
    -- Since s ∈ F.map f and F.map f ≤ G.map f, we have s ∈ G.map f
    exact h₂ hs
  -- The result follows from the above steps
  exact this

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the fact that the composition of two functions is the composition of their maps
  have h₁ : (F.map s).map t ≤ H := by
    -- Since t tends to H along G, and s tends to G along F, we can compose these two facts
    calc
      (F.map s).map t ≤ G.map t := by
        -- Because F.map s ≤ G (by definition of Tendsto)
        exact Filter.map_mono hs
      _ ≤ H := ht
  -- Now we need to show that F.map (t ∘ s) ≤ H
  have h₂ : F.map (t ∘ s) ≤ H := by
    -- Use the fact that (F.map s).map t = F.map (t ∘ s)
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        -- Prove that (F.map s).map t = F.map (t ∘ s)
        rw [Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ H := h₁
  -- Therefore, t ∘ s tends to H along F
  exact h₂

