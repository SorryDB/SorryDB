-- The density function (angular part) in the polar decomposition of a complex measure.
noncomputable def ang (μ : ComplexMeasure α) := μ.rnDeriv μ.var

@[simp]
lemma ang_neg (μ : ComplexMeasure α) : (-μ).ang = -μ.ang := by
  rw [show (-μ).ang = (-μ).rnDeriv (-μ).var by rfl]
  rw [show μ.ang = μ.rnDeriv μ.var by rfl]
  have h1 : (-μ : ComplexMeasure α).var = μ.var := by
    simp [var, MeasureTheory.VectorMeasure.variation_neg]
  have h2 : (-μ : ComplexMeasure α).rnDeriv (-μ : ComplexMeasure α).var = -μ.rnDeriv μ.var := by
    rw [h1]
    -- Use the fact that the derivative of -μ with respect to μ is -1 times the derivative of μ with respect to μ
    have h3 : (-μ : ComplexMeasure α).rnDeriv μ.var = -μ.rnDeriv μ.var := by
      rw [show (-μ : ComplexMeasure α) = (-1 : ℂ) • μ by simp [Complex.ext_iff]]
      rw [← Real.norm_eq_abs]
      simp [MeasureTheory.rnDeriv_smul]
