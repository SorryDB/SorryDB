          have h₄ : Nat.Prime p := Fact.out
          exact absurd (Nat.Prime.ne_zero h₄) (by simp_all [h])))]
    exact h₃
  simp [h₁, pow_succ]
  <;> ring_nf
  <;> simp_all [mul_assoc]
  <;> norm_num
  <;> linarith
