  intro n hn
  have h₁ : multiplicity (NumberField.classNumber (H.Kn n)) p = 0 := by
    have h₂ : p ≠ 0 := by
      have h₃ : Nat.Prime p := Fact.out
      exact Nat.Prime.ne_zero h₃
    have h₃ : multiplicity (NumberField.classNumber (H.Kn n)) p = 0 := by
      simp [multiplicity.ne_zero_of_pos,
