ave h4 : HasLaw (fun ω : Index n → ℝ => ω ⟨(j, i), hlt⟩) ((wignerMeasureDist μ ν n) ⟨(j, i), hlt⟩) (WignerMeasure μ ν n) := by\n          apply MeasureTheory.hasLaw_fst\n          <;>\n          (try simp_all [wignerMeasureDist, WignerMeasure]) <;>\n          (try aesop) <;>\n          (try simp_all [Measure.pi]) <;>\n          (try simp_all [MeasureTheory.isProbabilityMeasure_pi]) <;>\n          (try simp_all [Real.isProbabilityMeasure]) <;>\n          (try simp_all [IsProbabilityMeasure])\n        rw [h3] at h4\n        exact h4\n      have h5 : (fun ω : Index n → ℝ => ω ⟨(j, i), hlt⟩) = (fun ω => (wignerMatrixMap n ω) j i) := by\n        funext ω\n        simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n        <;>\n        simp_all [Fin.ext_iff,Prod.mk.injEq]\n        <;>\n        (try {cases n <;> simp_all [Fin.ext_iff]}) <;>\n        (try {omega}) <;>\n        (try {\n          split_ifs <;>\n          (try {simp_all [Fin.ext_iff,Prod.mk.injEq]}) <;>\n          (try {omega})\n        })\n        <;>\n        aesop\n      have h6 : HasLaw (fun ω => (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n        rw [← h5]\n        exact h2\n      have h7 : HasLaw (fun ω => (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        have h8 : (fun ω => (wignerMatrixMap n ω) i j) = (fun ω => (wignerMatrixMap n ω) j i) := by\n          funext ω\n          have h9 : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n            have h10 : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n              simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n              <;>\n              simp_all [Fin.ext_iff,Prod.mk.injEq]\n              <;>\n              (try {cases n <;> simp_all [Fin.ext_iff]}) <;>\n              (try {omega}) <;>\n              (try {\n                split_ifs <;>\n                (try {simp_all [Fin.ext_iff,Prod.mk.injEq]}) <;>\n                (try {omega})\n              })\n              <;>\n              aesop\n            exact h10\n          rw [h9]\n        rw [h8]\n        exact h6\n      exact h7\n    exact h1",
      "\n  have h₁ : i < j ∨ j < i := by sorry\n  have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by sorry\n  sorry",
      "\n  have h₁ : i < j ∨ j < i := by\n    have h₂ : i ≠ j := h\n    have h₃ : i < j ∨ j < i := by\n      by_cases h₄ : i < j\n      · exact Or.inl h₄\n      · have h₅ : j < i := by\n          cases' lt_or_gt_of_ne h₂ with h₆ h₆\n          · exfalso\n            exact h₆ h₂\n          · exact h₆\n        exact Or.inr h₅\n    exact h₃\n  cases h₁ with\n  | inl h₁ =>\n    -- Case: i < j\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Use the fact that for i < j, the entry (i, j) follows μ\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        have h₄ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n          sorry\n        exact h₄\n      exact h₃\n    exact h₂\n  | inr h₁ =>\n    -- Case: j < i\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n      -- Use the fact that for j < i, the entry (j, i) follows μ\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n        have h₄ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n          sorry\n        exact h₄\n      exact h₃\n    have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Use the symmetry of the matrix to transfer the law from (j, i) to (i, j)\n      have h₄ : ∀ ω : WignerSpace n, (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n        intro ω\n        have h₅ : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n          have h₆ : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n            rw [wignerMatrixMap]\n            rw [wignerMatrixMap]\n            simp [wignerMatrixEntryFunctionSymmetric]\n          exact h₆\n        exact h₅\n      have h₅ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        have h₆ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by\n          funext ω\n          rw [h₄ ω]\n        rw [h₆]\n        exact h₂\n      exact h₅\n    exact h₃",
      "",
      "\n  have h₁ : i < j ∨ j < i := by\n    cases' lt_or_gt_of_ne h with h₂ h₂\n    · exact Or.inl h₂\n    · exact Or.inr h₂\n  cases' h₁ with h₁ h₁\n  · -- Case: i < j\n    -- We use the fact that the entry (i, j) is directly mapped from the index (i, j)\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Prove that the entry (i, j) has law μ using the definition of WignerMeasure and wignerMatrixMap\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        -- Use the fact that the entry (i, j) is directly mapped from the index (i, j)\n        have h₄ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω ⟨(i, j), h₁⟩) := by\n          funext ω\n          simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n          <;> simp_all [Fin.ext_iff, Fin.val_succ]\n          <;> aesop\n        rw [h₄]\n        -- Use the fact that the measure of the coordinate function is μ\n        have h₅ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), h₁⟩) μ (WignerMeasure μ ν n) := by\n          -- Use the fact that the measure of the coordinate function is μ\n          have h₆ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), h₁⟩) (wignerMeasureDist μ ν n ⟨(i, j), h₁⟩) (WignerMeasure μ ν n) := by\n            apply MeasureTheory.hasLaw_pi_coord\n          have h₇ : wignerMeasureDist μ ν n ⟨(i, j), h₁⟩ = μ := by\n            simp [wignerMeasureDist]\n            <;> simp_all [Fin.ext_iff, Fin.val_succ]\n            <;> aesop\n          rw [h₇] at h₆\n          exact h₆\n        exact h₅\n      exact h₃\n    exact h₂\n  · -- Case: j < i\n    -- We use the fact that the entry (i, j) is the same as the entry (j, i) due to symmetry\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Prove that the entry (i, j) has law μ using the definition of WignerMeasure and wignerMatrixMap\n      have h₃ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by\n        funext ω\n        have h₄ : wignerMatrixMap n ω i j = wignerMatrixMap n ω j i := by\n          rw [show wignerMatrixMap n ω = (Matrix.of (wignerMatrixEntryFunction ω)) by rfl]\n          rw [Matrix.ext_iff]\n          simp [wignerMatrixEntryFunction]\n          <;>\n          (try cases' lt_or_gt_of_ne h with h₅ h₅ <;> simp_all [h₅, Fin.ext_iff, Fin.val_succ]) <;>\n          (try {\n            aesop\n          }) <;>\n          (try {\n            simp_all [Fin.ext_iff, Fin.val_succ]\n            <;>\n            (try omega)\n          })\n          <;>\n          (try {\n            cases' le_total i j with h₅ h₅ <;>\n            simp_all [h₅, Fin.ext_iff, Fin.val_succ] <;>\n            (try omega)\n          })\n        rw [h₄]\n      rw [h₃]\n      -- Use the fact that the entry (j, i) has law μ\n      have h₄ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n        -- Prove that the entry (j, i) has law μ using the definition of WignerMeasure and wignerMatrixMap\n        have h₅ : j < i := h₁\n        have h₆ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n          -- Use the fact that the entry (j, i) is directly mapped from the index (j, i)\n          have h₇ : (fun ω ↦ (wignerMatrixMap n ω) j i) = (fun ω ↦ ω ⟨(j, i), h₅⟩) := by\n            funext ω\n            simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n            <;> simp_all [Fin.ext_iff, Fin.val_succ]\n            <;> aesop\n          rw [h₇]\n          -- Use the fact that the measure of the coordinate function is μ\n          have h₈ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(j, i), h₅⟩) μ (WignerMeasure μ ν n) := by\n            -- Use the fact that the measure of the coordinate function is μ\n            have h₉ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(j, i), h₅⟩) (wignerMeasureDist μ ν n ⟨(j, i), h₅⟩) (WignerMeasure μ ν n) := by\n              apply MeasureTheory.hasLaw_pi_coord\n            have h₁₀ : wignerMeasureDist μ ν n ⟨(j, i), h₅⟩ = μ := by\n              simp [wignerMeasureDist]\n              <;> simp_all [Fin.ext_iff, Fin.val_succ]\n              <;> aesop\n            rw [h₁₀] at h₉\n            exact h₉\n          exact h₈\n        exact h₆\n      exact h₄\n    exact h₂",
      "\n  have h₁ : i < j ∨ j < i := by\n    cases' lt_or_gt_of_ne h with h₂ h₂\n    · exact Or.inl h₂\n    · exact Or.inr h₂\n  cases h₁ with\n  | inl h₁ =>\n    exact offDiagonalHasLaw' n h₁\n  | inr h₁ =>\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n      apply offDiagonalHasLaw'\n      <;> assumption\n    have h₃ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by\n      funext ω\n      rw [wignerMatrixMap]\n      simp [wignerMatrixMap', Matrix.ext_iff, Fin.ext_iff]\n      <;>\n      (try cases' le_or_lt i j with h₄ h₄ <;> cases' le_or_lt j i with h₅ h₅ <;>\n        simp_all [wignerMatrixEntryFunction, Fin.ext_iff, le_of_lt, le_of_lt]) <;>\n      (try\n        {\n          simp_all [wignerMatrixEntryFunction, Fin.ext_iff, le_of_lt, le_of_lt]\n          <;>\n          (try contradiction) <;>\n          (try omega) <;>\n          (try\n            {\n              simp_all [wignerMatrixEntryFunction, Fin.ext_iff, le_of_lt, le_of_lt]\n              <;>\n              try omega\n            })\n        }) <;>\n      (try\n        {\n          simp_all [wignerMatrixEntryFunction, Fin.ext_iff, le_of_lt, le_of_lt]\n          <;>\n          try omega\n        })\n    rw [h₃]\n    exact h₂",
      "",
      "the statement is for `i ≠ j`, and Lean's `lt_trichotomy` would allow us to use these cases. \n\nBut we can also notice that `offDiagonalHasLaw'` is the case `i < j`, and we can reuse it by symmetry in the case `i > j`.\n\nBut is `offDiagonalHasLaw'` actually already proved?\n\nNo, it is not: it has a sorry itself. \n\nHowever, perhaps the method is to prove `offDiagonalHasLaw'` and then deduce `offDiagonalHasLaw`. \n\nAlternatively, perhaps we can construct a more general statement.\n\nBut for now, perhaps we can prove `offDiagonalHasLaw'` by leveraging the fact that `(wignerMatrixMap n ω) i j = ω ⟨(i,j), _⟩` when `i < j`, and that this coordinate has `μ`.\n\n#### Formal Proof Approach for `offDiagonalHasLaw'`\n\n1. **Case `i < j`**:\n   - We need to prove that `(fun ω ↦ (wignerMatrixMap n ω) i j)` is `ω ↦ ω ⟨(i,j), _⟩`.\n   - Then `HasLaw` follows because `WignerMeasure` assigns `μ` to this coordinate.\n\n2. **Formal Steps**:\n   - For `i < j`, `(wignerMatrixMap n ω) i j = ω ⟨(i,j), _⟩` (by definition of `wignerMatrixEntryFunction`).\n   - The measurable space structure is compatible, so we can use the `HasLaw` of the projection in the product measure.\n\nBut `WignerMeasure` is a product measure, and for the coordinate `⟨(i,j), _⟩`, since `(i,j)` is not diagonal, the measure is `μ`.\n\n#### Formal Proof Approach for `offDiagonalHasLaw`\n\n1. **Case `i ≠ j`**:\n   - Use `lt_trichotomy i j` to split into `i < j` and `j < i`.\n   - In the case `i < j`, use `offDiagonalHasLaw'`.\n   - In the case `j < i`, reduce to the `i < j` case via symmetry:\n     - `(wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i` (by symmetric property).\n     - But `(wignerMatrixMap n ω) j i` is covered by `offDiagonalHasLaw'` (since `j < i`), so it has law `μ`.\n   - However, `HasLaw` does not directly allow this unless we have some equivalence of measures, which is not straightforward.\n\nBut perhaps it's better to redo it all from scratch for `i ≠ j`, as follows:\n\n1. If `i < j`, then `(wignerMatrixMap n ω) i j = ω ⟨(i,j), _⟩` and the projection `⟨(i,j), _⟩` has `μ`.\n2. If `i > j`, then `(wignerMatrixMap n ω) i j = ω ⟨(j,i), _⟩` (since `j < i`) and `⟨(j,i), _⟩` has `μ`.\n\nBut in Lean, `WignerMeasure` is a product measure over the coordinates. \n\n### Step-by-Step Abstract Plan\n\n1. **Prove `offDiagonalHasLaw'` (`i < j`)**:\n   - Express `(wignerMatrixMap n ω) i j` as `ω ⟨(i,j), _⟩`.\n   - Show that this is the projection to `⟨(i,j), _⟩` in `WignerSpace n`.\n   - Since `(i,j)` is not diagonal, `wignerMeasureDist` assigns `μ`.\n   - Therefore, `(fun ω ↦ ω ⟨(i,j), _⟩)` has law `μ`.\n\n2. **Prove",
      "\n  have h₁ : i < j ∨ j < i := by\n    -- Since i ≠ j, we have either i < j or j < i.\n    have h₁ : i.val ≠ j.val := by\n      intro h_eq\n      apply h\n      exact Fin.ext h_eq\n    cases lt_or_gt_of_ne h₁ with\n    | inl h₂ => exact Or.inl (by\n      -- If i.val < j.val, then i < j.\n      have h₃ : i < j := by\n        simpa [Fin.ext_iff] using h₂\n      exact h₃\n    )\n    | inr h₂ => exact Or.inr (by\n      -- If i.val > j.val, then j < i.\n      have h₃ : j < i := by\n        simpa [Fin.ext_iff] using h₂\n      exact h₃\n    )\n  \n  cases h₁ with\n  | inl h₁ =>\n    -- Case: i < j\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Use the fact that the off-diagonal entries are independent and have law μ\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        -- Prove that the entry (i, j) has law μ\n        have h₄ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), h₁⟩ : Index n)) μ (WignerMeasure μ ν n) := by\n          -- The (i, j) entry corresponds to the random variable ω (⟨(i, j), h₁⟩ : Index n)\n          have h₅ : (wignerMeasureDist μ ν n : Index n → Measure ℝ) (⟨(i, j), h₁⟩ : Index n) = μ := by\n            -- Since i ≠ j, the measure is μ\n            have h₆ : (⟨(i, j), h₁⟩ : Index n).val.1 ≠ (⟨(i, j), h₁⟩ : Index n).val.2 := by\n              simp_all [Index, Prod.ext_iff]\n              <;> aesop\n            simp [wignerMeasureDist, h₆]\n          -- The law of ω (⟨(i, j), h₁⟩ : Index n) is μ\n          have h₇ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), h₁⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), h₁⟩ : Index n)) (WignerMeasure μ ν n) := by\n            -- Use the product measure to get the law of the (i, j) entry\n            have h₈ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), h₁⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), h₁⟩ : Index n)) (WignerMeasure μ ν n) := by\n              -- Use the product measure to get the law of the (i, j) entry\n              apply MeasureTheory.hasLaw_pi\n              <;> simp_all [Index]\n            exact h₈\n          -- Since the measure is μ, the law is μ\n          rw [h₅] at h₇\n          exact h₇\n        -- Relate ω (⟨(i, j), h₁⟩ : Index n) to (wignerMatrixMap n ω) i j\n        have h₈ : (fun ω : WignerSpace n ↦ (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n ↦ ω (⟨(i, j), h₁⟩ : Index n)) := by\n          funext ω\n          simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n          <;>\n          (try\n            {\n              split_ifs <;>\n              (try\n                {\n                  simp_all [Index, Fin.ext_iff, Fin.val_mk]\n                  <;>\n                  (try\n                    {\n                      aesop\n                    })\n                  <;>\n                  (try\n                    {\n                      linarith\n                    })\n                })\n              <;>\n              (try\n                {\n                  simp_all [Index, Fin.ext_iff, Fin.val_mk]\n                  <;>\n                  (try\n                    {\n                      aesop\n                    })\n                  <;>\n                  (try\n                    {\n                      linarith\n                    })\n                })\n            })\n          <;>\n          (try\n            {\n              simp_all [Index, Fin.ext_iff, Fin.val_mk]\n              <;>\n              (try\n                {\n                  aesop\n                })\n              <;>\n              (try\n                {\n                  linarith\n                })\n            })\n          <;>\n          (try\n            {\n              simp_all [Index, Fin.ext_iff, Fin.val_mk]\n              <;>\n              (try\n                {\n                  aesop\n                })\n              <;>\n              (try\n                {\n                  linarith\n                })\n            })\n          <;>\n          (try\n            {\n              simp_all [Index, Fin.ext_iff, Fin.val_mk]\n              <;>\n              (try\n                {\n                  aesop\n                })\n              <;>\n              (try\n                {\n                  linarith\n                })\n            })\n        -- Use the fact that the entries are independent and have law μ\n        rw [h₈]\n        exact h₄\n      exact h₃\n    exact h₂\n  | inr h₁ =>\n    -- Case: j < i\n    have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      -- Use the fact that the off-diagonal entries are independent and have law μ\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n        -- Prove that the entry (j, i) has law μ\n        have h₄ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(j, i), h₁⟩ : Index n)) μ (WignerMeasure μ ν n) := by\n          -- The (j, i) entry corresponds to the random variable ω (⟨(j, i), h₁⟩ : Index n)\n          have h₅ : (wignerMeasureDist μ ν n : Index n → Measure ℝ) (⟨(j, i), h₁⟩ : Index n) = μ := by\n            -- Since j ≠ i, the measure is μ\n            have h₆ : (⟨(j, i), h₁⟩ : Index n).val.1 ≠ (⟨(j, i), h₁⟩ : Index n).val.2 := by\n              simp_all [Index, Prod.ext_iff]\n              <;> aesop\n            simp [wignerMeasureDist, h₆]\n          -- The law of ω (⟨(j, i), h₁⟩ : Index n) is μ\n          have h₇ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(j, i), h₁⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(j, i), h₁⟩ : Index n)) (WignerMeasure μ ν n) := by\n            -- Use the product measure to get the law of the (j, i) entry\n            have h₈ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(j, i), h₁⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(j, i), h₁⟩ : Index n)) (WignerMeasure μ ν n) := by\n              -- Use the product measure to get the law of the (j, i) entry\n              apply MeasureTheory.hasLaw_pi\n              <;> simp_all [Index]\n 