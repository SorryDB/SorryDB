      "\n  have h₁ : i < j ∨ j < i := by\n    have h₂ : i ≠ j := h\n    have h₃ : i < j ∨ j < i := by\n      cases' lt_or_gt_of_ne h₂ with h₂ h₂\n      · exact Or.inl h₂\n      · exact Or.inr h₂\n    exact h₃\n  \n  have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    cases h₁ with\n    | inl h₁ =>\n      -- Case: i < j\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        -- Use the property for the case i < j\n        have h₄ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), h₁⟩) μ (WignerMeasure μ ν n) := by\n          -- The coordinate in WignerSpace corresponding to (i, j) has law μ\n          have h₅ : wignerMeasureDist μ ν n ⟨(i, j), h₁⟩ = μ := by\n            -- Since i ≠ j (as i < j), the measure is μ\n            simp [wignerMeasureDist, h₁.ne']\n            <;> simp_all [Fin.ext_iff]\n            <;> aesop\n          -- Use the independence of coordinates in WignerMeasure\n          have h₆ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), h₁⟩) (wignerMeasureDist μ ν n ⟨(i, j), h₁⟩) (WignerMeasure μ ν n) := by\n            have h₇ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), h₁⟩) (wignerMeasureDist μ ν n ⟨(i, j), h₁⟩) (WignerMeasure μ ν n) := by\n              apply Measure.pi_hasLaw\n              <;> simp_all [wignerMeasureDist]\n              <;> aesop\n            exact h₇\n          -- Substitute the measure\n          rw [h₅] at h₆\n          exact h₆\n        -- Relate the coordinate in WignerSpace to the matrix entry\n        have h₅ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n => ω ⟨(i, j), h₁⟩) := by\n          funext ω\n          simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n          <;> split_ifs <;> simp_all [Fin.ext_iff, le_of_lt] <;>\n            (try { contradiction }) <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [Fin.ext_iff]\n              <;> omega\n            }) <;>\n            (try {\n              cases' lt_or_gt_of_ne h with h h <;>\n              simp_all [Fin.ext_iff] <;>\n              omega\n            })\n          <;>\n            (try {\n              cases' lt_or_gt_of_ne h with h h <;>\n              simp_all [Fin.ext_iff] <;>\n              omega\n            })\n          <;>\n            (try {\n              simp_all [Fin.ext_iff]\n              <;> omega\n            })\n        rw [h₅] at *\n        exact h₄\n      exact h₃\n    | inr h₁ =>\n      -- Case: j < i\n      have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n        -- Use the property for the case j < i\n        have h₄ : HasLaw (fun ω : WignerSpace n => ω ⟨(j, i), h₁⟩) μ (WignerMeasure μ ν n) := by\n          -- The coordinate in WignerSpace corresponding to (j, i) has law μ\n          have h₅ : wignerMeasureDist μ ν n ⟨(j, i), h₁⟩ = μ := by\n            -- Since j ≠ i (as j < i), the measure is μ\n            simp [wignerMeasureDist, h₁.ne']\n            <;> simp_all [Fin.ext_iff]\n            <;> aesop\n          -- Use the independence of coordinates in WignerMeasure\n          have h₆ : HasLaw (fun ω : WignerSpace n => ω ⟨(j, i), h₁⟩) (wignerMeasureDist μ ν n ⟨(j, i), h₁⟩) (WignerMeasure μ ν n) := by\n            have h₇ : HasLaw (fun ω : WignerSpace n => ω ⟨(j, i), h₁⟩) (wignerMeasureDist μ ν n ⟨(j, i), h₁⟩) (WignerMeasure μ ν n) := by\n              apply Measure.pi_hasLaw\n              <;> simp_all [wignerMeasureDist]\n              <;> aesop\n            exact h₇\n          -- Substitute the measure\n          rw [h₅] at h₆\n          exact h₆\n        -- Relate the coordinate in WignerSpace to the matrix entry\n        have h₅ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) j i) = (fun ω : WignerSpace n => ω ⟨(j, i), h₁⟩) := by\n          funext ω\n          simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n          <;> split_ifs <;> simp_all [Fin.ext_iff, le_of_lt] <;>\n            (try { contradiction }) <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [Fin.ext_iff]\n              <;> omega\n            }) <;>\n            (try {\n              cases' lt_or_gt_of_ne h with h h <;>\n              simp_all [Fin.ext_iff] <;>\n              omega\n            })\n          <;>\n            (try {\n              cases' lt_or_gt_of_ne h with h h <;>\n              simp_all [Fin.ext_iff] <;>\n              omega\n            })\n          <;>\n            (try {\n              simp_all [Fin.ext_iff]\n              <;> omega\n            })\n        rw [h₅] at *\n        exact h₄\n      have h₄ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n        -- Use the symmetry of the Wigner matrix to transfer the law from (j, i) to (i, j)\n        have h₅ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by\n          funext ω\n          have h₆ : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n            have h₇ : (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by\n              simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n              <;>\n                (try { split_ifs <;> simp_all [Fin.ext_iff, le_of_lt] <;>\n                  (try { contradiction }) <;>\n                  (try { aesop }) <;>\n                  (try {\n                    simp_all [Fin.ext_iff]\n                    <;> omega\n                  }) <;>\n                  (try {\n                    cases' lt_or_gt_of_ne h with h h <;>\n                    simp_all [Fin.ext_iff] <;>\n                    omega\n                  }) }) <;>\n                (try {\n                  cases' lt_or_gt_of_ne h with h h <;>\n                  simp_all [Fin.ext_iff] <;>\n                  omega\n                }) <;>\n                (try {\n                  simp_all [Fin.ext_iff]\n                  <;> omega\n                })\n              <;>\n             