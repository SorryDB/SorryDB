      "\n  by_cases h₂ : i < j\n  · -- Case: i < j\n    have h₃ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      sorry\n    exact h₃\n  · -- Case: i ≥ j\n    have h₃ : j < i := by\n      sorry\n    have h₄ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by\n      sorry\n    have h₅ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n      sorry\n    exact h₅",
      "\n   - Note that `(wignerMatrixMap n ω) i j = ω ⟨(i, j), _⟩`.\n   - Show that `(fun ω ↦ ω ⟨(i, j), _⟩)` has law `μ` under `WignerMeasure μ ν n`.\n   - Conclude that `(fun ω ↦ (wignerMatrixMap n ω) i j)` has law `μ` because it is equal everywhere to the above function.\n\n2. **Case `j < i`:**\n   - Note that `(wignerMatrixMap n ω) i j = ω ⟨(j, i), _⟩`.\n   - Show that `(fun ω ↦ ω ⟨(j, i), _⟩)` has law `μ` under `WignerMeasure μ ν n`.\n   - Conclude that `(fun ω ↦ (wignerMatrixMap n ω) i j)` has law `μ`.\n\nHowever, in Lean, we need to use the actual API of `MeasureTheory`. \n\nThe critical step is to get that `(fun ω ↦ ω p)` under `Measure.pi f` has law",
      "\n  have h_or : i < j ∨ j < i := by\n    have h₁ : i ≠ j := h\n    have h₂ : i < j ∨ j < i := by\n      cases lt_or_gt_of_ne h₁\n      · exact Or.inl ‹_›\n      · exact Or.inr ‹_›\n    exact h₂\n  \n  have h_main : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    have h₁ : i < j ∨ j < i := h_or\n    cases h₁ with\n    | inl h₁ =>\n      -- Case: i < j\n      have h₂ : (fun ω : Index n → ℝ => (wignerMatrixMap n ω) i j) = (fun ω : Index n → ℝ => ω ⟨(i, j), h₁⟩) := by\n        funext ω\n        rw [wignerMatrixMap]\n        simp [wignerMatrixMap', wignerMatrixEntryFunction]\n        <;>\n        (try { simp_all [Fin.ext_iff, Fin.val_succ] <;>\n          (try { aesop }) <;>\n          (try { omega }) }) <;>\n        (try {\n          by_cases h : i = j\n          <;> simp_all [h]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          simp_all [h₁]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          by_cases h : i < j <;> simp_all [h] <;>\n          (try { aesop }) <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          exfalso\n          <;>\n          simp_all [Fin.ext_iff]\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          simp_all [Fin.ext_iff]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n      rw [h₂]\n      -- Prove that the law of the projection is μ\n      have h₃ : HasLaw (fun ω : Index n → ℝ => ω ⟨(i, j), h₁⟩) μ (WignerMeasure μ ν n) := by\n        have h₄ : HasLaw (fun ω : Index n → ℝ => ω ⟨(i, j), h₁⟩) (wignerMeasureDist μ ν n ⟨(i, j), h₁⟩) (WignerMeasure μ ν n) :=\n          (hasLaw_fst _ _).comp (WignerMeasure.measurable _)\n        have h₅ : wignerMeasureDist μ ν n ⟨(i, j), h₁⟩ = μ := by\n          simp [wignerMeasureDist]\n          <;>\n          simp_all [Fin.ext_iff, Fin.val_succ]\n          <;>\n          (try { aesop }) <;>\n          (try { omega })\n        rw [h₅] at h₄\n        exact h₄\n      exact h₃\n    | inr h₁ =>\n      -- Case: j < i\n      have h₂ : (fun ω : Index n → ℝ => (wignerMatrixMap n ω) i j) = (fun ω : Index n → ℝ => ω ⟨(j, i), h₁⟩) := by\n        funext ω\n        rw [wignerMatrixMap]\n        simp [wignerMatrixMap', wignerMatrixEntryFunction]\n        <;>\n        (try { simp_all [Fin.ext_iff, Fin.val_succ] <;>\n          (try { aesop }) <;>\n          (try { omega }) }) <;>\n        (try {\n          by_cases h : i = j\n          <;> simp_all [h]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          simp_all [h₁]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          by_cases h : i < j <;> simp_all [h] <;>\n          (try { aesop }) <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          exfalso\n          <;>\n          simp_all [Fin.ext_iff]\n          <;>\n          (try { omega })\n        })\n        <;>\n        (try {\n          simp_all [Fin.ext_iff]\n          <;>\n          (try { aesop })\n          <;>\n          (try { omega })\n        })\n      rw [h₂]\n      -- Prove that the law of the projection is μ\n      have h₃ : HasLaw (fun ω : Index n → ℝ => ω ⟨(j, i), h₁⟩) μ (WignerMeasure μ ν n) := by\n        have h₄ : HasLaw (fun ω : Index n → ℝ => ω ⟨(j, i), h₁⟩) (wignerMeasureDist μ ν n ⟨(j, i), h₁⟩) (WignerMeasure μ ν n) :=\n          (hasLaw_fst _ _).comp (WignerMeasure.measurable _)\n        have h₅ : wignerMeasureDist μ ν n ⟨(j, i), h₁⟩ = μ := by\n          simp [wignerMeasureDist]\n          <;>\n          simp_all [Fin.ext_iff, Fin.val_succ]\n          <;>\n          (try { aesop }) <;>\n          (try { omega })\n        rw [h₅] at h₄\n        exact h₄\n      exact h₃\n  \n  exact h_main",
      "\n  have h₁ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by sorry\n  sorry",
