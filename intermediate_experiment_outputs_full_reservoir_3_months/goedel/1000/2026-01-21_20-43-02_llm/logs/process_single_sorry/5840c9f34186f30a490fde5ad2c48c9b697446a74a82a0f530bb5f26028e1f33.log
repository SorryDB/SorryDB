    (pc : GlobalTheoremPrecondition poly pbar ε) : ℝ² → ℝ :=
  fun q₂ => rotproj_outer_unit P pc.w q₂

theorem GlobalTheoremPrecondition.fu_outer_pose_eq
    {p pbar : Pose} {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε)
    (P : ℝ³) :
    (pc.fu_outer P p.outerParams) * ‖P‖ = ⟪pc.w, p.outer P⟫ := by
  have h₁ : (pc.fu_outer P p.outerParams) = (rotproj_outer_unit P pc.w p.outerParams) := rfl
  rw [h₁]
  simp only [rotproj_outer_unit]
  have h₂ : ⟪rotM (p.outerParams 0) (p.outerParams 1) P, pc.w⟫ = ⟪p.outer P, pc.w⟫ := by
