    exact h₃
  exact h

def μD : OuterMeasure ℝ where
  measureOf := fun s : Set ℝ =>
    if (Real.pi ∈ s) then 1 else 0
  empty := by
    simp [Set.not_mem_empty]
    <;> norm_num
  mono {S T} hST := by
    by_cases h : Real.pi ∈ S
    · -- Case: π ∈ S
      have h₁ : Real.pi ∈ T := hST h
      simp_all [Set.not_mem_empty]
      <;> norm_num
    · -- Case: π ∉ S
      by_cases h₂ : Real.pi ∈ T
      · -- Subcase: π ∈ T
        simp_all [Set.not_mem_empty]
        <;> norm_num
      · -- Subcase: π ∉ T
        simp_all [Set.not_mem_empty]
        <;> norm_num
  iUnion_nat := by
    by_cases h : Real.pi ∈ (⋃ n : ℕ, (· : Set ℝ) n)
    · -- Case: π ∈ ⋃ n : ℕ, (· : Set ℝ) n
      have h₁ : ∃ n : ℕ, Real.pi ∈ (· : Set ℝ) n := by
        simp only [Set.mem_iUnion] at h
        exact h
      -- Since π is in some set in the union, the measure of the union is 1.
      simp_all [Set.not_mem_empty]
      <;> norm_num
      <;>
      (try {
        rcases h₁ with ⟨n, hn⟩
        <;>
        (try {
          simp_all [Set.not_mem_empty]
          <;> norm_num
        })
      })
    · -- Case: π ∉ ⋃ n : ℕ, (· : Set ℝ) n
      have h₁ : ∀ n : ℕ, Real.pi ∉ (· : Set ℝ) n := by
        intro n
        intro h₂
        have h₃ : Real.pi ∈ (⋃ n : ℕ, (· : Set ℝ) n) := by
          apply Set.mem_iUnion.mpr
          exact ⟨n, h₂⟩
        contradiction
      -- Since π is not in any set in the union, the measure of the union is 0.
      simp_all [Set.not_mem_empty]
      <;> norm_num
      <;>
      (try {
        simp_all [Set.not_mem_empty]
        <;> norm_num
      })

