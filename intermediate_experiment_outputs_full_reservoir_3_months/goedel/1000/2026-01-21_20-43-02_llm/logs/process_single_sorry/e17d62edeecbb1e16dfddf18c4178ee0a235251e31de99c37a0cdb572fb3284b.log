    have h11 : {x | p' x ∧ q' x} ∈ 𝓝 x := h5
    have h12 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
