      <;> try { contradiction }
    · have h' : Real.pi ∉ S := by
        intro h''
        have h''' : Real.pi ∈ T := hST h''
        contradiction
      simp_all [measureOf]
      <;> split_ifs at * <;> simp_all
      <;> try { contradiction }
  iUnion_nat := by
    intro s
    have h₁ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = if Real.pi ∈ (⋃ n : ℕ, s n) then (1 : ℝ≥0∞) else 0 := by
      by_cases h : ∃ n : ℕ, Real.pi ∈ s n
