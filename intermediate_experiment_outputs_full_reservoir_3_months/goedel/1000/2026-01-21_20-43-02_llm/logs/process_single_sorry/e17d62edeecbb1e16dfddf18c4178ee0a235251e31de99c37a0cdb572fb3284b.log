lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro t ht
  have h₁ : F.map f ≤ G.map f := by
    -- Use the fact that the image of a filter under a function is monotone with respect to the filter order
    exact h.map f
  -- Since t is in the image of F under f, it is also in the image of G under f
  have h₂ : t ∈ G.map f := h₁ ht
  exact h₂

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  rw [show t ∘ s = t ∘ s by rfl]
  -- We use the fact that the composition of two functions is the same as applying one after the other.
  have h₁ : (F.map (t ∘ s)) ≤ H := by
    -- We need to show that the image of F under t ∘ s is less than or equal to H.
    calc
      F.map (t ∘ s) = F.map (t ∘ s) := rfl
      _ = (F.map s).map t := by
        -- The image of F under t ∘ s is the same as the image of the image of F under s under t.
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        -- Since F.map s ≤ G, the image of F.map s under t is less than or equal to the image of G under t.
        exact hs.1.map t
      _ ≤ H := by
        -- Since G.map t ≤ H, we have the desired result.
        exact ht.1
  -- Therefore, t ∘ s tends to H along F.
  exact h₁

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the composition of tendsto properties to show that g ∘ f tends to atTop along 𝓝 0
    have h₁ : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h₂ : Tendsto g (𝓝 Real.pi) atTop := hg
    -- Apply the composition of tendsto properties
    have h₃ : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp h₁ h₂
    exact h₃
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h₁ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    -- Use the composition of tendsto properties to show that φ ∘ a tends to 𝓝 (Complex.I) along atTop
    have h₂ : Tendsto a atTop (𝓝 (-1)) := ha
    have h₃ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
    -- Apply the composition of tendsto properties
    have h₄ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp h₂ h₃
    exact h₄
  exact h₁

