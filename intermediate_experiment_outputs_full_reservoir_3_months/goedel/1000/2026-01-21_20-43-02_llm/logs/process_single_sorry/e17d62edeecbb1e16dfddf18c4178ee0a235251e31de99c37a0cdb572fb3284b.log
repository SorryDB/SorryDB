              _ = (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0) := by
                -- Only the term at n contributes to the sum
                have h₇ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0) := by
                  rw [tsum_eq_single n]
                  · simp
                  · intro m hm
                    rw [h₆ m hm]
                    <;> simp
                rw [h₇]
              _ = (1 : ℝ≥0∞) := by
                simp [hn]
          rw [h₅]
        rw [h₃]
        <;> simp [h₂]
      · -- Case: There does not exist n such that Real.pi ∈ s n
        have h₂ : Real.pi ∉ ⋃ n : ℕ, s n := by
          intro h₃
          rcases Set.mem_iUnion.mp h₃ with ⟨n, hn⟩
          have h₄ : ∃ n : ℕ, Real.pi ∈ s n := ⟨n, hn⟩
          contradiction
        have h₃ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = 0 := by
          have h₄ : ∀ n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0) = 0 := by
