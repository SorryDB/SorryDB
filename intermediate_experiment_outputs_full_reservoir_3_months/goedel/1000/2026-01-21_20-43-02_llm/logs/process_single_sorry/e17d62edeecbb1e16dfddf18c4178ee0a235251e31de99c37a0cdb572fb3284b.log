```lean
noncomputable section

namespace ItaLean

/-!
# Filters
-/


section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  -- Use the property of the map function on filters to preserve the order
  exact Filter.map_mono h

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the fact that the composition of functions maps the filter F to H via G
  have h₁ : F.map (t ∘ s) ≤ H := by
    -- Apply the transitivity of the order relation to the composition of functions
    calc
      F.map (t ∘ s) = F.map (t ∘ s) := rfl
      _ = (F.map s).map t := by
        -- Use the associativity of the map function for filters
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G (from hs) and the monotonicity of the map function
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Use the fact that G.map t ≤ H (from ht)
        exact ht
  -- Use the derived inequality to conclude the proof
  exact h₁


example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Apply the composition theorem for Tendsto
  exact Tendsto_comp hf hg


example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  -- Apply the composition theorem for Tendsto
  exact Tendsto_comp ha hφ


/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  -- Use the filter_upwards tactic to combine the neighborhoods and deduce the goal
  have h₁ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of neighborhoods is a neighborhood
    have h₂ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      -- The intersection of {x | p x} and {x | q x} is in 𝓝 x
      exact mem_nhds_inter hT hS
    have h₃ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      -- The intersection of {x | p' x} and {x | q' x} is in 𝓝 x
      exact mem_nhds_inter hT' hS'
    -- Combine the two intersections to get the desired set
    have h₄ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
      -- Use the fact that the union of two neighborhoods is a neighborhood
      have h₅ : ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) ∈ 𝓝 x := by
        -- The union of two neighborhoods is a neighborhood
        exact mem_nhds_union h₂ h₃
      -- Use the fact that the union of the two intersections is contained in the desired set
      have h₆ : ({x : α | p x} ∩ {x : α | q x}) ∪ ({x : α | p' x} ∩ {x : α | q' x}) ⊆ {x : α | p x ∧ q x ∨ p' x ∧ q' x} := by
        intro y hy
        -- Check if y is in the union of the two intersections
        cases hy with
        | inl hy =>
          -- If y is in the first intersection, then p y and q y hold
          have h₇ : y ∈ {x : α | p x} := hy.1
          have h₈ : y ∈ {x : α | q x} := hy.2
          -- Therefore, p y ∧ q y holds
          exact Or.inl ⟨h₇, h₈⟩
        | inr hy =>
          -- If y is in the second intersection, then p' y and q' y hold
          have h₉ : y ∈ {x : α | p' x} := hy.1
          have h₁₀ : y ∈ {x : α | q' x} := hy.2
          -- Therefore, p' y ∧ q' y holds
          exact Or.inr ⟨h₉, h₁₀⟩
      -- Use the fact that the union of the two intersections is a neighborhood and is contained in the desired set
      exact nhdsWithin_le_nhds (h₅.mono h₆)
    -- The desired set is in 𝓝 x
    exact h₄
  -- The desired set is in 𝓝 x
  exact h₁

end Filter

