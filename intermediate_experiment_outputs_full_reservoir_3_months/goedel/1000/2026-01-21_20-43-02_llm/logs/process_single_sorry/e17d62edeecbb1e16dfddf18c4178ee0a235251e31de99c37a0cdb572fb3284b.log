              split_ifs <;> simp_all [le_refl]) (summable_geometric_two)) (by
              simp_all [summable_geometric_two])
          _ = (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0 : ℝ≥0∞) := by
            -- Simplify the sum to just the term where n = n
