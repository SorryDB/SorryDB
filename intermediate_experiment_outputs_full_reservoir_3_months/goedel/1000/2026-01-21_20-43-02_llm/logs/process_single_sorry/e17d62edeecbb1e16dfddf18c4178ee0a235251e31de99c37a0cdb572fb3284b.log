        cases' h with n hn
        have h₂ : Real.pi ∈ ⋃ n : ℕ, s n := by
          exact Set.mem_iUnion.mpr ⟨n, hn⟩
        have h₃ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = (1 : ℝ≥0∞) := by
          have h₄ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = ∑' n : ℕ, if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0 := rfl
          rw [h₄]
          have h₅ : (∑' n : ℕ, (if Real.pi ∈ s n then (1 : ℝ≥0∞) else 0)) = (1 : ℝ≥0∞) := by
            -- Only one term in the sum is 1, the rest are 0
            have h₆ : ∀ (m : ℕ), m ≠ n → (if Real.pi ∈ s m then (1 : ℝ≥0∞) else 0) = 0 := by
