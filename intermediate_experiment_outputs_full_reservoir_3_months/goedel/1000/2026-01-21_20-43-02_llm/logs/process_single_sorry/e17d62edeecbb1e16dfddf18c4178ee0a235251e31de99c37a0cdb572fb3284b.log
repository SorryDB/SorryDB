    have h₁ : {x | p x ∧ q x} ∈ 𝓝 x := by
      apply IsOpen.mem_nhds (isOpen_and )
      <;> exact Set.mem_of_mem_nhds hT hS
    have h₂ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
