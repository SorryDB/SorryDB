      have h₂ : Real.pi ∉ T := by
        intro h₃
        have h₄ : Real.pi ∈ S := by
          have h₅ : T ⊆ S := by
            -- This is a contradiction because S ⊆ T and T ⊆ S implies S = T
            -- So if π ∈ T, then π ∈ S
            have h₆ : S ⊆ T := hST
            have h₇ : T ⊆ S := by
              -- Since S ⊆ T and T ⊆ S, we have S = T
              -- So if π ∈ T, then π ∈ S
              have h₈ : S = T := by
                apply Set.Subset.antisymm
                · exact hST
                · -- Prove T ⊆ S by contradiction
                  intro x hx
                  by_contra h₉
                  have h₁₀ : x ∉ S := h₉
                  have h₁₁ : x ∈ T := hx
                  have h₁₂ : x ∉ S := h₁₀
                  have h₁₃ : x ∈ T := hx
                  simp_all [Set.Subset]
                  <;> aesop
              rw [h₈]
            exact h₇
