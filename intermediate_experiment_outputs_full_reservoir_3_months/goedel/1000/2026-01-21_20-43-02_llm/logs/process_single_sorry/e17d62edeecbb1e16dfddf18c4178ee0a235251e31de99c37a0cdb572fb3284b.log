    -- Convert the intersection to the desired set
    have h5 : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h5] at *
    exact h2
  have h6 : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h7 : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood
      have h8 : {x | p' x} ∈ 𝓝 x := hT'
      have h9 : {x | q' x} ∈ 𝓝 x := hS'
      exact Filter.inter_mem h8 h9
    -- Convert the intersection to the desired set
    have h10 : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h10] at *
    exact h7
  -- The union of two neighborhoods is a neighborhood
  have h11 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext x
    simp [or_comm]
    <;> aesop
  rw [h11]
  exact Filter.union_mem h1 h6

end Filter

section Lp

open MeasureTheory ENNReal Set

def μD : OuterMeasure ℝ where
  measureOf := fun s =>
    if Real.pi ∈ s then 1 else 0
  empty := by
    simp [μD]
  mono {S T} hST := by
    by_cases h : Real.pi ∈ T
    · -- Case: Real.pi ∈ T
      have h₁ : Real.pi ∈ S := by
        -- Since S ⊆ T and Real.pi ∈ T, Real.pi ∈ S
        have h₂ : S ⊆ T := hST
        exact h₂ h
      simp_all [μD]
      <;> aesop
    · -- Case: Real.pi ∉ T
      have h₁ : Real.pi ∉ S := by
        -- Since S ⊆ T and Real.pi ∉ T, Real.pi ∉ S
        intro h₂
        have h₃ : S ⊆ T := hST
        have h₄ : Real.pi ∈ T := h₃ h₂
        contradiction
      simp_all [μD]
      <;> aesop
  iUnion_nat := by
    by_cases h : Real.pi ∈ ⋃ n : ℕ, (Set.univ : Set ℝ)
    · -- Case: Real.pi ∈ ⋃ n : ℕ, (Set.univ : Set ℝ)
      simp_all [μD]
      <;>
      (try { contradiction }) <;>
      (try { aesop }) <;>
      (try {
        have h₁ : Real.pi ∈ (Set.univ : Set ℝ) := by simp
        have h₂ : ∃ n : ℕ, Real.pi ∈ (Set.univ : Set ℝ) := ⟨0, h₁⟩
        aesop
      }) <;>
      (try {
        simp_all [Set.mem_iUnion]
        <;>
        aesop
      })
    · -- Case: Real.pi ∉ ⋃ n : ℕ, (Set.univ : Set ℝ)
      simp_all [μD]
      <;>
      (try { contradiction }) <;>
      (try { aesop }) <;>
      (try {
        have h₁ : Real.pi ∈ (Set.univ : Set ℝ) := by simp
        have h₂ : ∃ n : ℕ, Real.pi ∈ (Set.univ : Set ℝ) := ⟨0, h₁⟩
        simp_all [Set.mem_iUnion]
        <;>
        aesop
      }) <;>
      (try {
        simp_all [Set.mem_iUnion]
        <;>
        aesop
      })

def μL : Measure ℝ := by
  exact volume

def LebesgueFilter := ae μL
def DiracFilter := ae μD

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h : μD {x : ℝ | x < 0} = 0 := by
    by_cases h₁ : Real.pi < (0 : ℝ)
    · -- Case: Real.pi < 0 (impossible)
      simp_all [μD]
      <;> norm_num at h₁ ⊢ <;>
      (try { contradiction }) <;>
      (try { linarith [Real.pi_pos] })
    · -- Case: ¬(Real.pi < 0)
      simp_all [μD]
      <;>
      (try { norm_num at h₁ ⊢ }) <;>
      (try { linarith [Real.pi_pos] }) <;>
      (try { aesop })
  -- Use the fact that the measure of {x : ℝ | x < 0} is 0 to show it is almost everywhere equal to ∅
  have h₂ : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    rw [MeasureTheory.ae_iff]
    simp_all [μD]
    <;>
    (try { aesop }) <;>
    (try { norm_num }) <;>
    (try { linarith [Real.pi_pos] })
  exact h₂

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    -- Use the transitivity of the equivalence relation for almost everywhere equality
    have h4 : f =ᵐ[μL] g := h1
    have h5 : g =ᵐ[μL] h := h2
    -- Transitivity of the almost everywhere equality
    exact h4.trans h5
  exact h3
