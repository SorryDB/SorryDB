lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  rw [Tendsto] at *
  simpa [Function.comp] using ht.mono_left hs

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x | p x} ∈ 𝓝 x := hT
  have h₂ : {x | q x} ∈ 𝓝 x := hS
  have h₃ : {x | p' x} ∈ 𝓝 x := hT'
  have h₄ : {x | q' x} ∈ 𝓝 x := hS'
  have h₅ : {x | p x ∧ q x} ∈ 𝓝 x := by
    -- Intersection of p and q is in the neighborhood filter
    have h₅₁ : {x | p x} ∈ 𝓝 x := hT
    have h₅₂ : {x | q x} ∈ 𝓝 x := hS
    -- The intersection of two sets in the neighborhood filter is also in the neighborhood filter
    have h₅₃ : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext
      simp [and_true]
      <;> aesop
    rw [h₅₃]
    -- Use the property of filters to show the intersection is in the neighborhood filter
    exact Filter.inter_mem h₅₁ h₅₂
  have h₆ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    -- Intersection of p' and q' is in the neighborhood filter
    have h₆₁ : {x | p' x} ∈ 𝓝 x := hT'
    have h₆₂ : {x | q' x} ∈ 𝓝 x := hS'
    -- The intersection of two sets in the neighborhood filter is also in the neighborhood filter
    have h₆₃ : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext
      simp [and_true]
      <;> aesop
    rw [h₆₃]
    -- Use the property of filters to show the intersection is in the neighborhood filter
    exact Filter.inter_mem h₆₁ h₆₂
  -- The union of the two sets is in the neighborhood filter
  have h₇ : {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₇₁ : {x | p x ∧ q x} ∈ 𝓝 x := h₅
    have h₇₂ : {x | p' x ∧ q' x} ∈ 𝓝 x := h₆
    -- The union of two sets in the neighborhood filter is also in the neighborhood filter
    have h₇₃ : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
      ext
      simp [or_true]
      <;> aesop
    rw [h₇₃]
    -- Use the property of filters to show the union is in the neighborhood filter
    exact Filter.union_mem h₇₁ h₇₂
  exact h₇

end Filter

