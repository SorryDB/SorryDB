theorem ita_lean2_27_c_2007 :
  ∀ (α : Type*) [CommSemiring α] [BeklemishevAlgorithm α],
  ∀ (n : ℕ) (arr : ℕ → α), (n ≤ 1 ∨ n = 2) →
  ∀ (I : ℕ → α), (I 0 = 3 ∧ I 1 = 2) →
  ∀ (p : ℕ → α), (∃ (m : ℕ), p m = 0) →
  ∃ (Q : ℕ → α), polynomial_periodic Q n arr =
      polynomial_periodic (polynomial_sub (polynomial_periodic (polynomial_sum p (n - 1) 0)
          (polynomial_mul I (polynomial_inverse (polynomial_sub (polynomial_C (arr 0)) (polynomial_X))))) n arr) n arr := by
