/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the property of filter maps to compose the two tendsto conditions
  have h₁ : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = F.map s |>.map t := by
        rw [← Filter.map_map]
        <;> simp [Function.comp]
        <;> rfl
      _ ≤ G.map t := by
        -- Since hs : F.map s ≤ G, we can use the monotonicity of map t
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since ht : G.map t ≤ H, we can directly use it
        exact ht
  -- Conclude the proof by showing F.map (t ∘ s) ≤ H
  exact h₁

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Use the composition of tendsto to show that g ∘ f tends to atTop along 𝓝 0
  have h₁ : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  -- The result follows directly from the composition of tendsto
  exact h₁

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  -- Use the composition of tendsto to show that φ ∘ a tends to 𝓝 (Complex.I) along atTop
  have h₁ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  -- The result follows directly from the composition of tendsto
  exact h₁

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  -- Use the fact that the union of two neighborhoods is a neighborhood
  have h₁ : {x | p x ∧ q x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of two neighborhoods is a neighborhood
    have h₂ : {x | p x} ∈ 𝓝 x := hT
    have h₃ : {x | q x} ∈ 𝓝 x := hS
    -- The intersection of {x | p x} and {x | q x} is {x | p x ∧ q x}
    have h₄ : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext x
      simp [and_imp]
      <;> tauto
    -- Since the intersection of two neighborhoods is a neighborhood, {x | p x ∧ q x} is a neighborhood of x
    rw [h₄]
    exact Filter.mem_inter h₂ h₃
  -- Similarly, {x | p' x ∧ q' x} is a neighborhood of x
  have h₂ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h₃ : {x | p' x} ∈ 𝓝 x := hT'
    have h₄ : {x | q' x} ∈ 𝓝 x := hS'
    have h₅ : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h₅]
    exact Filter.mem_inter h₃ h₄
  -- The union of two neighborhoods is a neighborhood
  have h₃ : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext x
    simp [or_iff_not_imp_left]
    <;> tauto
  rw [h₃]
  -- Since both sets are neighborhoods of x, their union is also a neighborhood of x
  exact Filter.mem_union h₁ h₂

end Filter

