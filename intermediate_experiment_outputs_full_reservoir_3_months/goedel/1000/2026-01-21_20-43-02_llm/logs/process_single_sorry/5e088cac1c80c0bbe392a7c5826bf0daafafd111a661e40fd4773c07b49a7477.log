        ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2 ^ (3 * k)) % 5 =
            ∑ k ∈ Finset.range (n + 1), ((Nat.choose (2 * n + 1) (2 * k + 1)) * (2 ^ (3 * k)) % 5) := by
