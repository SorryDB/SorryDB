    PrvState := fun i => P.PrvState i × OuterStmtIn × OuterWitIn,
    input := fun (ctxIn : OuterStmtIn × OuterWitIn) =>
      (P.input (lens.proj ctxIn), (ctxIn.1, ctxIn.2)),
    sendMessage := fun (i : Fin n) (prvState : P.PrvState i.castSucc × OuterStmtIn × OuterWitIn) =>
      do
        -- Extract the inner prover state
        let innerPrvState : P.PrvState i.castSucc := prvState.1
        -- Extract the outer statement and witness
        let outerStmtIn : OuterStmtIn := prvState.2.1
        let outerWitIn : OuterWitIn := prvState.2.2
        -- Use the inner prover's sendMessage to get the next message and updated inner state
        let ⟨msg, innerPrvState'⟩ := P.sendMessage i innerPrvState
        -- Return the message and the updated state (including outer data)
        return ⟨msg, (innerPrvState', outerStmtIn, outerWitIn)⟩,
    receiveChallenge := fun (i : Fin n) (prvState : P.PrvState i.succ × OuterStmtIn × OuterWitIn) =>
      do
        -- Extract the inner prover state
        let innerPrvState : P.PrvState i.succ := prvState.1
        -- Extract the outer statement and witness
        let outerStmtIn : OuterStmtIn := prvState.2.1
        let outerWitIn : OuterWitIn := prvState.2.2
        -- Use the inner prover's receiveChallenge to get the new inner state function
        let f := P.receiveChallenge i innerPrvState
        -- Return the new state function and keep the same outer data
        return fun chal => (f chal, outerStmtIn, outerWitIn),
    output := fun (prvState : P.PrvState 0 × OuterStmtIn × OuterWitIn) =>
      do
        -- Extract the inner prover state
        let innerPrvState : P.PrvState 0 := prvState.1
        -- Extract the outer statement and witness
        let outerStmtIn : OuterStmtIn := prvState.2.1
        let outerWitIn : OuterWitIn := prvState.2.2
        -- Use the inner prover's output to get the inner statement and witness outputs
        have h : Output innerPrvState = (InnerStmtOut × InnerWitOut) := rfl
        let ⟨innerStmtOut, innerWitOut⟩ : (InnerStmtOut × InnerWitOut) := P.output innerPrvState
        -- Lift the outputs to the outer context
        let liftedStmtOut : OuterStmtOut := lens.liftStmt innerStmtOut
        let liftedWitOut : OuterWitOut := lens.liftWit (outerStmtIn, outerWitIn) innerWitOut
        -- Return the lifted outputs as a pair
        return (liftedStmtOut, liftedWitOut)
  }
