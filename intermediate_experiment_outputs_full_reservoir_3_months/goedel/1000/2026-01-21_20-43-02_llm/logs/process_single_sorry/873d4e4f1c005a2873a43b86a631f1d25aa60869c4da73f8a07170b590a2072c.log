### Solution

```lean
lemma quadSolsInclLinSols_injective (χ : ACCSystemQuad) :
    Function.Injective χ.quadSolsInclLinSols := by
  intro S T h
  have h₁ : S.val = T.val := by
    have h₂ : (S : χ.LinSols) = (T : χ.LinSols) := by exact h
    have h₃ : (S : χ.LinSols).val = (T : χ.LinSols).val := by
      apply Eq.symm
      apply Eq.symm
      exact h₂
    simpa [QuadSols.val, LinSols.val] using h₃
  have h₂ : S = T := by
    apply QuadSols.ext
    exact h₁
  exact h₂
