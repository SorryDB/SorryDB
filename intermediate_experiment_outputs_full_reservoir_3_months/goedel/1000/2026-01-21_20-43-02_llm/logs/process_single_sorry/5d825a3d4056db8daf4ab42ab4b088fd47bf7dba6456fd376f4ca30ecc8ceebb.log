        -- Use the fact that the localizations are isomorphic to deduce the pseudo-isomorphism
        have h₃ : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl N)) := h
        -- Use the properties of the localizations to deduce the pseudo-isomorphism
        exact by
          -- Use the structure theorem of finitely generated torsion modules up to pseudo-isomorphism
          -- to conclude that M and N are pseudo-isomorphic
          trivial
      exact h₂
  exact h1
