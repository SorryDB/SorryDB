theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  have h1 : M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
    constructor
    · intro h
      intro p hp
      have h₂ : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
        -- Use the fact that M and N are pseudo-isomorphic to show that their localizations are isomorphic
        have h₃ : PseudoIsomorphism A M N (h) := by
          exact h
        -- Use the properties of pseudo-isomorphism to deduce the isomorphism of localized modules
        have h₄ : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
          (LocalizedModule p.1.primeCompl N)) := by
          -- Use the fact that the localization of a pseudo-isomorphism is an isomorphism
          refine' ⟨h₃.map_localization (p.1.primeCompl)⟩
        exact h₄
      exact h₂
    · intro h
      -- Use the fact that the localizations are isomorphic to show that M and N are pseudo-isomorphic
