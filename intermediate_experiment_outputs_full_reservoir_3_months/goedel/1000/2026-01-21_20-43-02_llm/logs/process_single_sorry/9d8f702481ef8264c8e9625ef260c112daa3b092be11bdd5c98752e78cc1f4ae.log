theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : @Functor α β (@CategoryInContext.Category.Preorder α) (@CategoryInContext.Category.Preorder β)) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨F.F, _⟩
  constructor
  · -- Prove that F.F is monotone
    intro x y hxy
    have h : (F.homF (hxy : α ≤ y) : β ≤ F.F y) := by
      have h1 := hxy
      have h2 : (α := α) (β := β) [C : @CategoryInContext.CategoryPreorder α] [D : @CategoryInContext.CategoryPreorder β] (F : @Functor α β C D) {X Y : α} (f : C.Hom X Y) : D.Hom (F.F X) (F.F Y) := F.homF
      -- Use the properties of the functor to show that the image of the relation is preserved
      have h3 : (hxy : α ≤ y) = (hxy : α ≤ y) := rfl
      have h4 : F.homF (hxy : α ≤ y) = (F.homF (hxy : α ≤ y) : β ≤ F.F y) := rfl
      simpa [PLift.mk.injEq] using h4
    simpa [PLift.mk.injEq] using h
  · -- Prove that F.F is the same as F.F
    intro x
    rfl
