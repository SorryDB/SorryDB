-- exercise 1.3.ii
-- we didn't define the category of preorders in section 1.1, so we do it here
noncomputable instance Category.Preorder (α : Type*) [Preorder α] : Category α where
  Hom X Y := PLift (X ≤ Y) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans f.down g.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  have h₁ : ∃ (f : α → β), (∀ x : α, F.F x = f x) := by
    refine' ⟨F.F, _⟩
    intro x
    rfl
  obtain ⟨f, hf⟩ := h₁
  refine' ⟨f, _, hf⟩
  intro x y hxy
  have h₂ : (⟨hxy⟩ : PLift (x ≤ y)) ≫ id y = ⟨hxy⟩ := by
    simp [comp]
  have h₃ : id x ≫ (⟨hxy⟩ : PLift (x ≤ y)) = ⟨hxy⟩ := by
    simp [comp]
  have h₄ : F.homF (⟨hxy⟩ : PLift (x ≤ y)) ≫ id (F.F y) = F.homF (⟨hxy⟩ : PLift (x ≤ y)) := by
    simp [comp]
  have h₅ : id (F.F x) ≫ F.homF (⟨hxy⟩ : PLift (x ≤ y)) = F.homF (⟨hxy⟩ : PLift (x ≤ y)) := by
    simp [comp]
  have h₆ : F.homF (⟨hxy⟩ : PLift (x ≤ y)) : (PLift (F.F x ≤ F.F y)) := by
    apply F.homF
    <;> simp_all [PLift.mk.injEq]
    <;> try simp_all [comp]
    <;> try simp_all [id]
    <;> try simp_all [le_refl]
    <;> try simp_all [le_trans]
  have h₇ : (F.homF (⟨hxy⟩ : PLift (x ≤ y))).down : F.F x ≤ F.F y := by
    exact h₆.down
  have h₈ : (F.homF (⟨hxy⟩ : PLift (x ≤ y))).down : F.F x ≤ F.F y := by
    exact h₆.down
  have h₉ : f x ≤ f y := by
    have h₁₀ : F.F x ≤ F.F y := by simpa [hf] using h₈
    have h₁₁ : f x = F.F x := by
      have h₁₂ := hf x
      simp_all
    have h₁₂ : f y = F.F y := by
      have h₁₃ := hf y
      simp_all
    simp_all [h₁₁, h₁₂]
  exact h₉
