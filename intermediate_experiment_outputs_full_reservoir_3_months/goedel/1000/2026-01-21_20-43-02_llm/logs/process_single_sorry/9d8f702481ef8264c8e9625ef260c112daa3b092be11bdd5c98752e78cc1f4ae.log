theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨F.F, _, _⟩
  · -- Prove that F.F is monotone
    intro x y hxy
    have h : Hom x y := ⟨hxy⟩
    have h' := F.homF h
    -- Since F is a functor, it preserves the order
    have h'' : (F.F x : β) ≤ F.F y := by
      -- Use the fact that F is a functor and the composition of morphisms is preserved
      -- In this case, h is a proof that x ≤ y, and F.homF(h) gives a proof that F x ≤ F y
      simpa [Morphism] using (h' : (F.F x : β) ≤ (F.F y))
    exact h''
  · -- Prove that F.F x = f x for all x (trivially true since f = F.F)
    intro x
    rfl
