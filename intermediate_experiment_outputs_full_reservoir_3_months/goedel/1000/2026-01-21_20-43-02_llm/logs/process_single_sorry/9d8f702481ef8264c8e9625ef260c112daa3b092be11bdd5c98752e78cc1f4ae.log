      "\n  refine' ⟨F.F, _, _⟩\n  · intro a b h\n    have h₁ : (h : (⟨h, by simp⟩ : @Preorder α _ .Hom a b)) = (⟨h, by simp⟩ : @Preorder α _ .Hom a b) := rfl\n    have h₂ : (F.homF (⟨h, by simp⟩ : @Preorder α _ .Hom a b) : @Preorder β _ .Hom (F.F a) (F.F b)) = (⟨by\n        have h₃ : F.homF (⟨h, by simp⟩ : @Preorder α _ .Hom a b) : @Preorder β _ .Hom (F.F a) (F.F b) := F.homF (⟨h, by simp⟩ : @Preorder α _ .Hom a b)\n        exact by\n          cases' h₃ with h₃ h₃ <;> simp_all [Preorder]\n          <;> tauto\n      , by simp⟩ : @Preorder β _ .Hom (F.F a) (F.F b)) := by simp [h₁]\n    cases' h₂ with h₂ h₂ <;> simp_all [Preorder]\n    <;> tauto\n  · intro x\n    rfl",
      "\n  have h_main : ∃ (f : α → β), Monotone f ∧ ∀ x : α, @ CategoryInContext.Functor.F α β (@ CategoryInContext.Category.Preorder α _) (@ CategoryInContext.Category.Preorder β _) F x = f x := by\n    refine' ⟨F.F, _, _⟩\n    · -- Prove that F.F is monotone\n      intro x y h\n      -- Use the fact that F is a functor between preorders to deduce F x ≤ F y from x ≤ y\n      have h₁ : (⟨h⟩ : (PLift (x ≤ y))) = (⟨h⟩ : (PLift (x ≤ y))) := rfl\n      -- Apply F's action on morphisms to the arrow x ≤ y\n      have h₂ : F.homF ⟨h⟩ : PLift (F x ≤ F y) := by\n        exact F.homF ⟨h⟩\n      -- Extract the proof that F x ≤ F y from the lifted hom\n      exact h₂.prop\n    · -- Prove that F.F x = F.F x for all x (trivial)\n      intro x\n      rfl\n  exact h_main",
      "\n  refine' ⟨F.F, _, _⟩\n  · refine' fun a b h => _\n    have h₁ : ∃ (x : (@CategoryInContext.Category_preorder α).Hom a b), True := by\n      exact ⟨⟨h⟩, by trivial⟩\n    obtain ⟨x, _⟩ := h₁\n    have h₂ : ∃ (y : (@CategoryInContext.Category_preorder β).Hom (F.F a) (F.F b)), True := by\n      exact ⟨F.homF x, by simp⟩\n    obtain ⟨y, _⟩ := h₂\n    have h₃ : (F.F a : β) ≤ (F.F b : β) := by\n      cases y with\n      | mk y' => exact y'\n    exact h₃\n  · intro x\n    rfl",
      "\n  have h₁ : ∀ (x y : α), x ≤ y → F.F x ≤ F.F y := by\n    intro x y hxy\n    have h₂ : (⟨hxy, by trivial⟩ : (x : α) ≤ y) := ⟨hxy, by trivial⟩\n    have h₃ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl\n    have h₄ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl\n    -- Extract the monotonicity condition from the Hom set\n    have h₅ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl\n    -- Use the properties of the functor to deduce the monotonicity\n    have h₆ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl\n    -- Convert the proof in the Hom set to a proof in the preorder\n    exact (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y)\n  -- Define the function f as F.F\n  refine' ⟨F.F, ⟨fun a b hab => h₁ a b hab, _⟩⟩\n  -- Show that F.F is equal to itself\n  intro x\n  rfl",
