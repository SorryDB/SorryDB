theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨F.F, _, _⟩
  · -- Prove that F.F is monotone
    intro a b hab
    -- Since F is a functor, it preserves the order (i.e., it is monotone).
    -- Specifically, for any a ≤ b in α, we need to show that F.F a ≤ F.F b in β.
    -- This is achieved by using the fact that the homF of the functor maps the order relation in α to the order relation in β.
    have h : F.homF (show (⟨a, by trivial⟩ : PLift α) ≤ ⟨b, by trivial⟩ by
      exact ⟨hab⟩) = (⟨le_refl (F.F a)⟩ : PLift (F.F a ≤ F.F a)) := by
      simp [F.map_id]
      <;>
      rfl
    -- Simplify the above statement to extract the required inequality.
    simp [F.map_id] at h
    <;>
    simp_all [PLift.forall]
    <;>
    aesop
  
  · -- Prove that for all x: α, F.F x = F.F x
    intro x
    rfl
