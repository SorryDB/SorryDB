theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  have h₁ : ∀ (x y : α), x ≤ y → F.F x ≤ F.F y := by
    intro x y hxy
    have h₂ : (⟨hxy, by trivial⟩ : (x : α) ≤ y) := ⟨hxy, by trivial⟩
    have h₃ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl
    have h₄ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl
    -- Extract the monotonicity condition from the Hom set
    have h₅ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl
    -- Use the properties of the functor to deduce the monotonicity
    have h₆ : (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) = (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y) := rfl
    -- Convert the proof in the Hom set to a proof in the preorder
    exact (F.homF {X := x} {Y := y} ⟨hxy, by trivial⟩ : (F.F x : β) ≤ F.F y)
  -- Define the function f as F.F
  refine' ⟨F.F, ⟨fun a b hab => h₁ a b hab, _⟩⟩
  -- Show that F.F is equal to itself
  intro x
  rfl
