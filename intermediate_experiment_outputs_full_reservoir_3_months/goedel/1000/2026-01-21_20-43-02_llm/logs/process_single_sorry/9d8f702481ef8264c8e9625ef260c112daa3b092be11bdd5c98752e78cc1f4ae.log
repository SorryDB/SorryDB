theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨fun x => F.F x, ?_, ?_⟩
  · -- Prove that f is monotone
    refine' fun a b hab => _
    have h : (ha : F.F a) ≤ (hb : F.F b) := by
      -- Use the fact that F maps the inequality a ≤ b to F F a ≤ F F b
      have h₁ : (hab : @Preorder α _ a b) := hab
      have h₂ : (F.map_le : @PLift (a ≤ b) → @PLift (F.F a ≤ F.F b)) := by
        -- Construct the proof that F maps the inequality
        have h₃ : (F.homF : @Preorder α _ a b → @Preorder β _ (F.F a) (F.F b)) := by
          -- Use the homF function of the functor to map the inequality
          intro h₄
          exact F.homF h₄
        -- Convert the proof to the correct type
        exact fun h₄ => ⟨h₃ h₄⟩
      -- Use the constructed proof to get the inequality
      have h₄ : @PLift (a ≤ b) := ⟨hab⟩
      have h₅ : @PLift (F.F a ≤ F.F b) := h₂ h₄
      exact h₅
    -- Convert the proof back to the correct type
    exact h
  · -- Prove that f x = F.F x for all x
    intro x
    rfl
