    -- Use the definition of `mean` to directly get the tendsto property
    have h2 : mean f = limUnder atTop (fun X ↦ ⨍ x in (0)..X, f x) := rfl
    rw [h2]
    -- The limit of the function is itself by definition of `limUnder`
    exact tendsto_limUnder_atTop
  exact h1
