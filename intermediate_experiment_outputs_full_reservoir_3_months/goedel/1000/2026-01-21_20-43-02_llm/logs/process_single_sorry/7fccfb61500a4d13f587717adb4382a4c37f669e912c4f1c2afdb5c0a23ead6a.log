import Mathlib.MeasureTheory.Integral.IntervalAverage
import MiscYD.PhD.VCDim.UnifAP.Defs

/-!
# Fourier analysis of uniformly almost periodic functions
-/

open Filter
open scoped Topology

variable {Λ : ℝ} {f : ℝ → ℂ}

variable (f) in
noncomputable def mean : ℂ := limUnder atTop fun X ↦ ⨍ x in (0)..X, f x

lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
  have h : Tendsto (fun X : ℝ => ⨍ x in (0)..X, f x) atTop (𝓝 (limUnder atTop fun X : ℝ => ⨍ x in (0)..X, f x)) := by
    have h₁ : Tendsto (fun X : ℝ => ⨍ x in (0)..X, f x) atTop (𝓝 (limUnder atTop fun X : ℝ => ⨍ x in (0)..X, f x)) := by
      apply tendsto_atTop_of_eventually_const
      filter_upwards [Filter.eventually_ge_atTop 0] with X hX
      <;> simp_all [hf, mean]
      <;>
      (try simp_all [hf, mean]) <;>
      (try norm_num) <;>
      (try linarith)
    exact h₁
  simpa [mean] using h
