theorem test (f : ℕ → ℕ) (h₀ : ∀ n : ℕ, f n ≤ 3 := by sorry) (h₁ : ∀ n : ℕ, f (n + f n) = f n) : ∀ n : ℕ, f n = 0 := by
  have h₂ : ∀ n : ℕ, f n = 0 := by
    intro n
    by_contra h
    have h₃ : f n > 0 := by
      have h₄ : f n ≠ 0 := h
      have h₅ : f n ≤ 3 := h₀ n
      have h₆ : f n ≥ 1 := by
        by_contra h₆
        have h₇ : f n = 0 := by omega
        contradiction
      omega
    have h₄ : f (n + f n) = f n := h₁ n
    have h₅ : f (n + f n) ≤ 3 := h₀ (n + f n)
    have h₆ : f n ≤ 3 := h₀ n
    have h₇ : f (n + 1 + f (n + 1)) = f (n + 1) := h₁ (n + 1)
    have h₈ : f (n + 1) ≤ 3 := h₀ (n + 1)
    have h₉ : f n ≤ 3 := h₀ n
    -- Use the given conditions to derive a contradiction
