theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  have h₁ : ∀ᶠ (n : ℕ) in Filter.atTop, ∃ P : Params, P.n = n ∧ (P.M : ℕ) = 1 ∧ (P.L : ℕ) = 1 := by
    filter_upwards [Filter.eventually_ge_atTop 1] with n hn
    have h₂ : n > 1 * 1 := by nlinarith
    refine' ⟨{n := n, M := 1, L := 1, hL_pos := by decide, hL := by nlinarith}, by rfl, by rfl, by rfl⟩
  filter_upwards [h₁] with n hn
  obtain ⟨P, hPn, hPM, hPL⟩ := hn
  refine' ⟨P, by simp_all [hPM, hPL], _⟩
  have h₂ : P.L = 1 := by simp_all
  have h₃ : P.M = 1 := by simp_all
  simp_all [Factorization	score, Int.cast_zero]
  <;>
  (try norm_num) <;>
  (try simp_all) <;>
  (try ring_nf) <;>
  (try norm_cast) <;>
  (try linarith)
  <;>
  (try
    {
      simp_all [Factorization.score, Int.cast_zero]
      <;> norm_num
      <;>
      (try ring_nf)
      <;>
      (try norm_cast)
      <;>
      (try linarith)
    })
  <;>
  (try
    {
      norm_num at *
      <;>
      simp_all [Factorization.score, Int.cast_zero]
      <;>
      linarith
    })
