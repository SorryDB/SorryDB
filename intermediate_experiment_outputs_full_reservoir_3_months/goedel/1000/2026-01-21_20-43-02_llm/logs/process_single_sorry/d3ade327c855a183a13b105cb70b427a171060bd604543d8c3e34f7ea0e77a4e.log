    <;> aesop
  hpos := fun m hm ↦ by
    simp only [Multiset.mem_filter, Multiset.mem_join, Multiset.mem_replicate] at hm
    obtain ⟨_, hsmooth⟩ := hm
    exact pos_of_ne_zero (mem_smoothNumbers.mp hsmooth).1
}

