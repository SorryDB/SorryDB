theorem Params.initial.waste (P : Params) : P.initial.waste ≤ P.n * log (1 - 1/P.M)⁻¹ := by
  have h₁ : P.n > 0 := by
    nlinarith
  have h₂ : P.M > 0 := by
    by_contra h
    simp_all [params]
  -- Since log(1 - 1/M) is negative, (1 - 1/M)^{-1} > 1, and the inequality follows.
  have h₃ : (log (1 - 1 / P.M : ℝ)⁻¹ : ℝ) ≥ 0 := by
    have h₄ : (1 : ℝ) - 1 / P.M > 0 := by
      have h₅ : (1 : ℝ) / P.M < 1 := by
        norm_cast
        apply (div_lt_one (by positivity)).mpr
        <;> norm_num <;> omega
      linarith
    have h₅ : (log (1 - 1 / P.M : ℝ)⁻¹ : ℝ) = -log (1 - 1 / P.M : ℝ) := by
      rw [log_inv]
      <;> ring
    rw [h₅]
    have h₆ : Real.log (1 - 1 / (P.M : ℝ)) ≤ 0 := by
      apply Real.log_nonpos
      <;> norm_num <;>
      (try positivity) <;>
      (try {
        apply le_of_sub_nonneg
        field_simp
        ring_nf
        positivity
      }) <;>
      (try {
        have h₇ : (P.M : ℝ) ≥ 1 := by norm_cast <;> omega
        have h₈ : (1 : ℝ) - 1 / (P.M : ℝ) ≤ 1 := by
          apply sub_le_self
          positivity
        linarith
      })
    linarith
  have h₄ : (P.n : ℝ) * Real.log (1 - 1 / P.M : ℝ)⁻¹ ≥ 0 := by
    have h₅ : (P.n : ℝ) ≥ 0 := by positivity
    have h₆ : Real.log (1 - 1 / P.M : ℝ)⁻¹ ≥ 0 := by
      exact_mod_cast h₃
    nlinarith
  have h₅ : P.initial.waste ≤ P.n * log (1 - 1 / P.M)⁻¹ := by
