  constructor
  · -- Show that the product of copies of Λ emulates B = id.
    -- Since B is trivially id, and there's only one copy, we can directly compare.
    have h₁ : (CPTPMap.diural : CPTPMap (Fin 1) (Fin 1)) = (CPTPMap.ident : CPTPMap (Fin 1) (Fin 1)) := by
      ext i j
