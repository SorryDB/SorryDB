theorem achievesRate_0 (Λ : CPTPMap d₁ d₂) : Λ.AchievesRate 0 := by
  intro ε hε
  use 1, zero_lt_one, 1, default
  constructor
  · have : Nonempty d₁ := ⟨Classical.choice (Fintype.nonempty_iff_ne_empty.mpr (by
      intro h
      simp_all [Fintype.card_eq_zero_iff_apply]
      <;> aesop)
    )⟩
    -- Use the fact that d₁ is nonempty to construct the identity map
    haveI : Nonempty d₁ := this
    haveI : Nonempty (Fin 1) := ⟨⟨0, by norm_num⟩⟩
    -- Use the identity map to show that the composition is the identity
    refine' ⟨CPTPMap.id, CPTPMap.id, _⟩
    simp [CPTPMap.piProd]
    <;>
    (try decide) <;>
    (try simp_all [CPTPMap.id, CPTPMap.piProd]) <;>
    (try aesop) <;>
    (try norm_num) <;>
    (try simp_all [Fintype.card_fin]) <;>
    (try ext i; simp_all [CPTPMap.id, CPTPMap.piProd, Fin.sum_univ_succ]) <;>
    (try aesop)
  · norm_num [Real.logb_eq_zero]
    <;> simp_all [CPTPMap.fidelity_self_eq_one]
    <;> norm_num
    <;> linarith
