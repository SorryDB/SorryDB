theorem achievesRate_0 (Λ : CPTPMap d₁ d₂) : Λ.AchievesRate 0 := by
  intro ε hε
  use 1, zero_lt_one, 1, default
  constructor
  · have : Nonempty d₁ := by
      classical
      have : Nonempty (CPTPMap d₁ d₂) := by
