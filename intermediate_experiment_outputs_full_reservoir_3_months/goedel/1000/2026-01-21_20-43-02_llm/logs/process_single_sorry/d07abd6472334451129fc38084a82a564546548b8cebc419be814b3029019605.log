theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  -- We use the fact that the set of even integers is in bijection with all integers,
  -- which is a countable set.
  have : ({n : ℤ | even n} : Set ℤ) = (⊤ : Set ℤ) ∩ {n : ℤ | even n} := by
    simp [Set.ext_iff]
  rw [this]
  -- The intersection of a countable set with another countable set is countable.
  -- The set of all integers is countable, and the set of even integers is countable.
  -- Therefore, their intersection is countable.
  exact inferInstance
