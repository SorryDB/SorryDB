theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : Denumerable {n : Int | even n} := by
    have h₁ : Denumerable {n : ℤ | (2 : ℤ) ∣ n} := by
      let f : ℕ → {n : ℤ | (2 : ℤ) ∣ n} := fun n => ⟨2 * (n : ℤ), by
        -- Prove that 2 divides 2 * n
        norm_num [dvd_mul_right]
        ⟩
      have hf : Function.Injective f := by
        intro a b hab
        simp [f] at hab
        -- Prove that the function is injective
        norm_cast at hab ⊢
        <;>
        (try omega) <;>
        (try ring_nf at hab ⊢ <;> omega)
      -- Use the injective function to show that the set is denumerable
      refine' Denumerable.of_injective _ hf
    -- Show that the set of even integers is the same as the set of integers divisible by 2
    have h₂ : {n : ℤ | even n} = {n : ℤ | (2 : ℤ) ∣ n} := by
      apply Set.ext
      intro n
      simp [Int.even_iff, Int.emod_eq_emod_iff_emod_sub_eq_zero]
      <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try omega)
    -- Use the previous result to conclude the proof
    simpa [h₂] using h₁
  exact h
