          omega
        })
      · -- Show that every element in the range of the map is even
        intro x hx
        simp [Int.even_iff, Set.mem_range] at hx ⊢
        <;>
        (try { omega }) <;>
        (try {
          use x / 2
          omega
        })
    -- The set of even integers is in bijection with the set of all integers, which is countable
    have h₂ : Dcountable (Set.range (fun n : ℤ => 2 * n)) := by
      apply Set.dcountable_range
    -- Therefore, the set of even integers is countable
    exact h₂.ofEquiv h₁.symm
  -- Since the set of even integers is countable, it is denumerable
  have h₃ : denum {n : ℤ | even n} := by
    simpa [Dcountable] using h
  exact h₃
