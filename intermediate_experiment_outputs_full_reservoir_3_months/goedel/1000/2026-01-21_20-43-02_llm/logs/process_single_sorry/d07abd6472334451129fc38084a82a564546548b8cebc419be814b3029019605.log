      simp [Int.even_iff]
      <;> ring_nf
      <;> simp [Int.emod_eq_of_lt]
      <;> omega
    exact ⟨f, g, by
      -- Prove that f and g are inverses of each other
      ext x
      cases x <;> simp_all [Set.ext_iff]
      <;> (try { omega }) <;> (try { ring_nf at * <;> omega })
      <;> (try {
        use x / 2
        <;> ring_nf at *
        <;> omega
      })
      <;> (try {
        use x.val
        <;> ring_nf at *
        <;> omega
      })
    ⟩
  -- Use the fact that the set of even integers is in bijection with the universal set to prove it is denumerable
  have h₁ : denum {n : Int | even n} := by
    have h₂ : denum Set.univ := by
      exact denum_univ
    have h₃ : {n : Int | even n} ≃ Set.univ := h
    exact denum_congr h₃ h₂
  exact h₁
