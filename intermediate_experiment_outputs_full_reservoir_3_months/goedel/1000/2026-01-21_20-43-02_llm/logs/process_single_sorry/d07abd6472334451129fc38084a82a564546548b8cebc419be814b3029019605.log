  have h : {n : Int | even n} ≃ Set.univ := by
    let f : {n : Int | even n} → Set.univ := by
      intro x
      have h₁ : even x.val := x.prop
      have h₂ : ∃ k : ℤ, x.val = 2 * k := by
        rw [Int.even_iff] at h₁
        use x.val / 2
        omega
      refine' ⟨x.val / 2, _⟩
      <;> simp [h₂, Int.even_iff]
      <;> ring_nf
      <;> omega
    let g : Set.univ → {n : Int | even n} := by
      intro x
