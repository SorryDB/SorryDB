theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  -- We will show that the set of even integers is countably infinite.
  -- First, define a function that maps the integers to the even integers.
  have h : DEnum (Set.Iio (2 : ℕ)) := DEnum.of (d_Iio (2 : ℕ))
  -- Define a function that maps a natural number to an even integer.
  let f : ℕ → Int := fun n => 2 * (n : Int)
  -- Show that the function f is injective.
  have hf : Function.Injective f := by
    intro a b h
    simp [f] at h
    <;> norm_cast at h ⊢ <;>
    (try omega) <;>
    (try linarith) <;>
    (try ring_nf at h ⊢) <;>
    (try omega)
  -- Show that the function f is a surjection from ℕ to the even integers.
  have hf' : ∀ (n : Int), even n → ∃ (a : ℕ), f a = n := by
    intro n hn
    have h₁ : ∃ (k : Int), n = 2 * k := by
      rw [even_iff_two_dvd] at hn
      obtain ⟨k, hk⟩ := hn
      exact ⟨k, by linarith⟩
    obtain ⟨k, hk⟩ := h₁
    use k.toNat
    simp [f]
    <;>
    (try omega) <;>
    (try {
      cases' le_or_lt 0 k with hk' hk' <;>
      simp [Int.toNat_of_nonneg hk', hk'] at hk ⊢ <;>
      ring_nf at hk ⊢ <;>
      omega
    })
    <;>
    (try {
      omega
    })
  -- Use the fact that f is injective and surjective to conclude that the set of even integers is countably infinite.
  exact Set.denum_of_eq_range_of_direct_sum (by simp [Set.ext_iff, hf']) (Set.range_nonempty _) ⟨f, hf⟩
