      constructor
      · intro h
        obtain ⟨k, hk⟩ := h
        use k
        <;> omega
      · rintro ⟨k, rfl⟩
        use k
        <;> ring
        <;> simp [Int.mul_emod]
        <;> norm_num
    rw [h₁]
    -- The set of even integers is the range of the function n ↦ 2 * n
    -- Since the function n ↦ 2 * n is injective, the range is countable
    have h₂ : denum (Set.range (fun (n : ℤ) => 2 * n)) := by
      -- The function n ↦ 2 * n is injective, so the range is countable
      have h₃ : Function.Injective (fun (n : ℤ) => 2 * n) := by
        intro a b h₄
        -- If 2 * a = 2 * b, then a = b
        omega
      -- The range of an injective function on a denumerable set is denumerable
      exact denum_range_of_injective h₃
    exact h₂
  exact h
