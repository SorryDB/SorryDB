theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have : denum {n : Int | even n} := by
    -- Use the fact that the set of even integers is in bijection with the integers
    -- and the integers are denumerable.
    have : {n : Int | even n} ≃ Int := by
      -- Define the bijection between the set of even integers and the integers
      -- by mapping each even integer to its half.
      refine' ⟨fun x => Int.emod x 2, _, fun y => 2 * y, _, _⟩
      -- Prove that the function is well-defined and injective
      · -- Show that the function maps even integers to integers
        intro x hx
        simp only [Set.mem_setOf_eq] at hx
        have : x % 2 = 0 := by
          simp [Int.even_iff] at hx ⊢
          <;> omega
        simp_all [Int.emod_emod]
      · -- Show that the function is injective
        intro a b h
        simp_all [Int.emod_eq_emod_iff_emod_sub_eq_zero]
        <;> omega
      · -- Prove that the function is surjective
        intro y
        use 2 * y
        <;> simp [Int.even_iff, Int.mul_emod]
        <;> ring_nf
        <;> norm_num
        <;> omega
    -- Since the set of even integers is in bijection with the integers and the integers are denumerable,
    -- the set of even integers is also denumerable.
    exact denum.congr (denum_int) this
  exact this
