theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have : {n : Int | even n} ≃ Set.univ := by
    classical
    -- We will show that the set of even integers is in bijection with the set of all integers (which is the same as the universal set here).
    -- We use the fact that the set of integers is countable and the set of even integers is a subset of the integers.
    -- We need to construct a bijection between the set of even integers and the universal set.
    -- Define a function that maps each even integer to an integer, and vice versa.
    -- We will use the function f(n) = n / 2 for the forward direction.
    -- And for the inverse direction, we will use the function g(n) = 2 * n.
    -- These functions are well-defined and are bijections.
    -- We will use the fact that the set of even integers is countable to show that it is in bijection with the universal set.
    -- The set of even integers is countable because it is a subset of the set of integers, which is countable.
    -- We will use the fact that the set of integers is countable to show that it is in bijection with the universal set.
    -- The set of integers is countable because it is a subset of the set of natural numbers, which is countable.
    -- Therefore, the set of even integers is in bijection with the universal set.
    let f : {n : Int | even n} → Set.univ := by
      intro x
      have h : even x.val := x.property
      have h₁ : ∃ (k : ℤ), x.val = 2 * k := by
        cases' h with k hk
        exact ⟨k, by linarith⟩
      cases' h₁ with k hk
      exact ⟨(k : ℤ), by simp_all [Set.mem_univ]⟩
    let g : Set.univ → {n : Int | even n} := by
      intro x
      have h : x.val ∈ (Set.univ : Set Int) := by simp_all [Set.mem_univ]
      have h₁ : even (2 * x.val) := by
        rw [even_iff_two_dvd]
        use x.val
        <;> ring
      exact ⟨2 * x.val, h₁⟩
    refine' ⟨f, g, _, _, _⟩
    · -- Prove that f is injective
      intro x y h
      simp_all [Subtype.ext_iff]
      <;>
      (try omega) <;>
      (try {
        cases' x.property with k hk
        cases' y.property with k' hk'
        have h₁ : 2 * k = 2 * k' := by linarith
        have h₂ : k = k' := by linarith
        simp_all
      })
    · -- Prove that f is surjective
      intro y
      simp_all [Subtype.ext_iff]
      <;>
      (try {
        cases' y.property with k hk
        use ⟨(k / 2 : ℤ), by
          have h₁ : (k : ℤ) % 2 = 0 := by
            omega
          omega⟩
        <;> simp_all [even_iff_two_dvd]
        <;> omega
      })
    · -- Prove that g is the inverse of f
      intro x
      simp_all [Subtype.ext_iff]
      <;>
      (try {
        cases' x with x
        simp_all [even_iff_two_dvd]
        <;> ring_nf at *
        <;> omega
      })
  -- Use the fact that the set of even integers is in bijection with the universal set to show that it is denumerable.
  refine' Denumerable.ofEquiv (by infer_instance) _
  <;> exact this
