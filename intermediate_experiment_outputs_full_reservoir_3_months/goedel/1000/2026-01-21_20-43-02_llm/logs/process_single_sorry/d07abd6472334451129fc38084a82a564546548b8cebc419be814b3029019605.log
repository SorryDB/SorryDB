  have h : Dcountable {n : ℤ | even n} := by
    have h₁ : {n : ℤ | even n} ≃ Set.range (fun n : ℤ => 2 * n) := by
      apply Set.Equiv.of_insertion
      · -- Show that the map n ↦ 2n is injective and its range is the set of even integers
        intro n
        simp [Int.even_iff, Set.mem_range]
        <;>
        (try { use n; ring_nf }) <;>
        (try { use -n; ring_nf }) <;>
        (try { omega })
