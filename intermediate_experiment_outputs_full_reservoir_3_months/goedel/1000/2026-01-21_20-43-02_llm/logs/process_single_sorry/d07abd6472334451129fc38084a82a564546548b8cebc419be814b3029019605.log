theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : {n : Int | even n} = Set.range (fun (n : Int) => 2 * n) := by
    ext n
    simp [Int.even_iff]
    <;>
    (try { constructor <;> intro h <;> use n / 2 <;> omega }) <;>
    (try {
      constructor <;> intro h <;>
      (try { use n / 2 <;> omega }) <;>
      (try {
        have h₁ : n % 2 = 0 := by omega
        have h₂ : ∃ (k : ℤ), n = 2 * k := by
          use n / 2
          have h₃ : n % 2 = 0 := by omega
          omega
        obtain ⟨k, hk⟩ := h₂
        use k
        <;> linarith
      }) <;>
      omega
    })
  
  rw [h]
  apply denum_range
  <;>
  infer_instance
