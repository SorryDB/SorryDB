have hn_small : 2 * (b - a) / n < δ := by
  calc
    2 * (b - a) / (n : ℝ) ≤ 2 * (b - a) / (N : ℝ) := by
      have h₁ : (n : ℝ) ≥ (N : ℝ) := by
        exact_mod_cast hn
      have h₂ : 0 < (N : ℝ) := by positivity
      have h₃ : 0 < (n : ℝ) := by positivity
      have h₄ : 0 < 2 * (b - a) := by linarith
      -- Use the fact that if n ≥ N and N > 0, then 1/n ≤ 1/N
      have h₅ : (2 * (b - a) : ℝ) / n ≤ (2 * (b - a) : ℝ) / N := by
        apply div_le_div_of_le_left (by positivity) (by positivity)
        exact_mod_cast hn
      linarith
    _ < δ := by
      have h₅ : (1 : ℝ) / (δ / (2 * (b - a))) < (N : ℝ) := by
        exact_mod_cast hN
      have h₆ : 0 < δ := hδ₁
      have h₇ : 0 < (2 : ℝ) * (b - a) := by linarith
      have h₈ : 0 < δ / (2 * (b - a)) := by positivity
      have h₉ : 0 < (1 : ℝ) / (δ / (2 * (b - a))) := by positivity
      -- Use the inequality to show that 2*(b - a)/N < δ
      have h₁₀ : (2 * (b - a) : ℝ) / (N : ℝ) < δ := by
        have h₁₁ : (1 : ℝ) / (δ / (2 * (b - a))) < (N : ℝ) := h₅
        have h₁₂ : (1 : ℝ) / (δ / (2 * (b - a))) = (2 * (b - a)) / δ := by
          field_simp
          <;> ring
          <;> field_simp
          <;> linarith
        rw [h₁₂] at h₁₁
        have h₁₃ : (2 * (b - a) : ℝ) / δ < (N : ℝ) := h₁₁
        have h₁₄ : 0 < (2 * (b - a) : ℝ) := by linarith
        have h₁₅ : 0 < δ := hδ₁
        have h₁₆ : 0 < (N : ℝ) := by positivity
        -- Use the inequality (2*(b - a))/δ < N to prove (2*(b - a))/N < δ
        have h₁₇ : (2 * (b - a) : ℝ) / (N : ℝ) < δ := by
          calc
            (2 * (b - a) : ℝ) / (N : ℝ) = (2 * (b - a) : ℝ) / (N : ℝ) := rfl
            _ < δ := by
              -- Use the fact that (2*(b - a))/δ < N to get (2*(b - a))/N < δ
              have h₁₈ : 0 < (N : ℝ) := by positivity
              have h₁₉ : 0 < δ := hδ₁
              have h₂₀ : 0 < (2 * (b - a) : ℝ) := by linarith
              -- Use the division inequality to transform the inequality
              have h₂₁ : (2 * (b - a) : ℝ) / δ < (N : ℝ) := h₁₃
              have h₂₂ : (2 * (b - a) : ℝ) < δ * (N : ℝ) := by
                calc
                  (2 * (b - a) : ℝ) = ((2 * (b - a) : ℝ) / δ) * δ := by field_simp [h₁₉.ne'] <;> ring
                  _ < (N : ℝ) * δ := by
                    gcongr
                  _ = δ * (N : ℝ) := by ring
              -- Divide both sides by N to get (2*(b - a))/N < δ
              have h₂₃ : (2 * (b - a) : ℝ) / (N : ℝ) < δ := by
                calc
                  (2 * (b - a) : ℝ) / (N : ℝ) < (δ * (N : ℝ)) / (N : ℝ) := by
                    gcongr
                  _ = δ := by
                    field_simp [h₁₈.ne']
