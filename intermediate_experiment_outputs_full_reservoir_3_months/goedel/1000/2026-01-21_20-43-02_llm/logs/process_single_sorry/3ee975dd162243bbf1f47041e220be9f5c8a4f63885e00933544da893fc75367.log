  have h₁ : ContinuousOn f (Icc a b) := by
    have h₂ : ∀ x ∈ Icc a b, ContinuousWithinAt f (Icc a b) x := by
      intro x hx
      have h₃ : ∀ ε > 0, ∃ δ > 0, ∀ y ∈ Icc a b, |y - x| < δ → |f y - f x| < ε := by
        intro ε hε
        have h₄ : ∃ δ > 0, ∀ (x : ℝ), x ∈ Icc a b → ∀ (y : ℝ), y ∈ Icc a b → |y - x| < δ → |f y - f x| < ε := by
          exact hf ε hε
        obtain ⟨δ, hδ, hδ'⟩ := h₄
        refine' ⟨δ, hδ, _⟩
        intro y hy hy'
        exact hδ' x hx y hy hy'
      exact Metric.continuousWithinAt_iff.mpr h₃
    exact fun x hx => h₂ x hx
  -- Use the fact that continuous functions on closed intervals are bounded
  have h₂ : BddAbove (Set.range (fun x : ℝ => |f x|)) := by
    have h₃ : BddAbove (Set.range (fun x : ℝ => |f x|)) := by
      -- Use the fact that f is bounded on [a, b]
