      "\n  obtain ⟨s, hs⟩ := heq\n  rw [hs]\n  have h_card_eq : (p.snd.edgeSet).image (s.map ≫ s.map) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by\n    have h_edges_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges.toFinset = (p.edges.toFinset).image (s.map ≫ s.map) := by\n      intro u v p\n      induction' p with u v w h p ih\n      · simp [SimpleGraph.LoopWalk.edges]\n      · simp_all [SimpleGraph.LoopWalk.edges, List.map_append, List.map_singleton, Finset.image_union]\n        <;>\n        (try simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n        (try ext <;> simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n        (try aesop) <;>\n        (try norm_num) <;>\n        (try ring_nf) <;>\n        (try omega)\n      · simp_all [SimpleGraph.LoopWalk.edges, List.map_append, List.map_singleton, Finset.image_union]\n        <;>\n        (try simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n        (try ext <;> simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n        (try aesop) <;>\n        (try norm_num) <;>\n        (try ring_nf) <;>\n        (try omega)\n    have h₁ := h_edges_eq p.1 p.1 p.2\n    simp_all [SimpleGraph.LoopWalk.edgeSet]\n    <;>\n    (try simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n    (try ext <;> simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n    (try aesop) <;>\n    (try norm_num) <;>\n    (try ring_nf) <;>\n    (try omega)\n  have h₂ : (p.snd.edgeSet).image (s.map ≫ s.map) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by\n    exact h_card_eq\n  have h₃ : (p.snd.edgeSet).card = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet.card := by\n    have h₄ : (p.snd.edgeSet).image (s.map ≫ s.map) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := h₂\n    have h₅ : (p.snd.edgeSet).image (s.map ≫ s.map) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by rw [h₄]\n    have h₆ : (p.snd.edgeSet).card = ((p.snd.edgeSet).image (s.map ≫ s.map)).card := by\n      apply Finset.card_image_of_injective\n      intro x y hxy\n      simp_all [Function.funext_iff]\n      <;>\n      (try aesop) <;>\n      (try simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try omega)\n    have h₇ : ((p.snd.edgeSet).image (s.map ≫ s.map)).card = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet.card := by\n      rw [h₄]\n    linarith\n  simp_all [SimpleGraph.LoopWalk.edgeSet]\n  <;>\n  (try simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n  (try ext <;> simp_all [Equiv.Perm.map, Function.comp_apply]) <;>\n  (try aesop) <;>\n  (try norm_num) <;>\n  (try ring_nf) <;>\n  (try omega)",
      "\n  obtain ⟨ s, hs ⟩ := heq;\n  rw [hs];\n  -- Since these two sets are equal, their cardinalities are equal.\n  have h_card_eq : (p.snd.edgeSet).image (fun e => (s e.1, s e.2)) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by\n    -- By definition of `permMapWalk`, the edge set of the permuted walk is the image of the edge set of the original walk under `s`.\n    have h_edge_eq : (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet = (p.snd.edgeSet).image (fun e => (s e.1, s e.2)) := by\n      have h_edge_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edgeSet = (p.edges).toFinset.image (fun e => (s e.1, s e.2)) := by\n        intros u v p\n        induction' p with u v w h p ih\n        · rfl\n        · -- By definition of `permMapWalk`, the edge set of the permuted walk is the image of the edge set of the original walk under `s`. We can prove this by induction on the walk. For the cons case, we have:\n          simp_all [SimpleGraph.LoopWalk.permMapWalk, SimpleGraph.LoopWalk.edges, List.map_cons, Finset.image_insert, Finset.insert_image]\n          <;>\n          (try decide) <;>\n          (try aesop) <;>\n          (try {\n            simp_all [Equiv.Perm.sign_mul, Finset.ext_iff]\n            <;>\n            aesop\n          }) <;>\n          (try {\n            simp_all [Equiv.Perm.sign_mul, Finset.ext_iff]\n            <;>\n            aesop\n          })\n          <;>\n          (try {\n            simp_all [Equiv.Perm.sign_mul, Finset.ext_iff]\n            <;>\n            aesop\n          })\n        · -- By definition of `edgeSet`, the edge set of a loopwalk is the same as the edge set of the underlying walk.\n          simp_all [SimpleGraph.LoopWalk.permMapWalk, SimpleGraph.LoopWalk.edges, Finset.image_insert, Finset.insert_image]\n          <;>\n          (try decide) <;>\n          (try aesop) <;>\n          (try {\n            simp_all [Equiv.Perm.sign_mul, Finset.ext_iff]\n            <;>\n            aesop\n          }) <;>\n          (try {\n            simp_all [Equiv.Perm.sign_mul, Finset.ext_iff]\n            <;>\n            aesop\n          })\n      have h₁ := h_edge_eq (p.1) (p.1) (p.2)\n      simp_all [finset_image]\n      <;>\n      aesop\n    rw [h_edge_eq]\n    <;>\n    rfl\n  rw [← h_card_eq]\n  -- The cardinality of the image is the same as the cardinality of the original set because s is a permutation (bijection).\n  <;>\n  rw [Finset.card_image_of_injective]\n  <;>\n  (try {\n    simp_all [Function.Injective]\n    <;>\n    aesop\n  }) <;>\n  (try {\n    simp_all [Equiv.Perm.sign_mul]\n    <;>\n    aesop\n  }) <;>\n  (try {\n    simp_all [Equiv.Perm.sign_mul]\n    <;>\n    aesop\n  }) <;>\n  (try {\n    simp_all [Equiv.Perm.sign_mul]\n    <;>\n    aesop\n  }) <;>\n  (try {\n    simp_all [Equiv.Perm.sign_mul]\n    <;>\n    aesop\n  })",
