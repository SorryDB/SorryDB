      classical
      -- We can prove that the image of the edges under s is the same as the original edges because the graph is complete and the permutation does not actually change the edges.
      have h_edge_invariance : (SimpleGraph.LoopWalk.permMapWalk n s p.2).edges.toFinset = (p.2.edges).toFinset := by
