```lean
lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  rw [hs]
  have h_card_eq : (p.snd.edges).image s = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edges := by
    -- By definition of `permMapWalk`, the edges of the permuted walk are the images of the edges of the original walk under `s`.
    have h_edges_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges = List.map (fun d => s d) p.edges := by
      intros u v p
      induction' p with u v w h p ih
      · rfl
      · simp_all [SimpleGraph.LoopWalk.edges, List.map, List.cons, Equiv.Perm.mapMap]
        <;>
          (try decide) <;>
          (try simp_all [Equiv.Perm.mapMap]) <;>
          (try ring_nf) <;>
          (try aesop)
      · simp_all [SimpleGraph.LoopWalk.edges, List.map, List.cons, Equiv.Perm.mapMap]
        <;>
          (try decide) <;>
          (try simp_all [Equiv.Perm.mapMap]) <;>
          (try ring_nf) <;>
          (try aesop)
    have h₁ := h_edges_eq _ _ p.snd
    simp_all [List.map]
    <;>
      (try decide) <;>
      (try aesop)
  rw [← h_card_eq]
  <;>
    simp_all [Finset.card_image_of_injective]
  <;>
    (try decide) <;>
    (try aesop)
