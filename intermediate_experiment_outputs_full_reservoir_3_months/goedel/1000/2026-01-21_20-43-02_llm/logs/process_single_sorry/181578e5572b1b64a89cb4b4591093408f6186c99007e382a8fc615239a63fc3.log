        have : n - c * n = a := by omega
        rw [← this]
        have : n = 1 * n := by rw [one_mul]
        rewrite (occs := .pos [1]) [this]
        exact Eq.symm (Nat.sub_mul 1 c n)
      have h' := this ▸ h.2
      rw [this]
      have : 1 - c = 0 := by
        have : n = 1 * n := by rw [one_mul]
        rw (occs := .pos [2]) [this] at h'
        have h' := Nat.lt_of_mul_lt_mul_right h'
        linarith
      simp [this]
    exfalso
