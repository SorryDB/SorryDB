theorem exists_func_deriv_cube : ∃ g : ℝ → ℝ, (fun x : ℝ => x ^ 3).HasDerivAt g := by
  have h_main : ∃ (g : ℝ → ℝ), (fun x : ℝ => x ^ 3).HasDerivAt g := by
    use fun x => 3 * x ^ 2
    intro x
    -- Use the fact that the derivative of x^n is n*x^(n-1)
    have h : HasDerivAt (fun x : ℝ => x ^ 3) (3 * x ^ 2) x := by
      -- Apply the power rule for derivatives
      have h₁ : HasDerivAt (fun x : ℝ => x ^ 3) (3 * x ^ 2) x := by
        -- Use the known derivative of x^n
        simpa using (hasDerivAt_pow 3 x).const_mul (1 : ℝ)
      exact h₁
    -- The result follows directly from the above calculation
    exact h
  -- The main result follows directly from the existence of the derivative function
  exact h_main
