theorem differentiability_exercise : ∃ g : ℝ → ℝ,
  deriv (fun x ↦ x ^ 3) g := by
  use (fun x ↦ 3 * x ^ 2)
  intro x ε hε
  let δ : ℝ := min 1 (ε / (3 * |x| + 1))
  have δ_le1 : δ ≤ 1 := by
    exact min_le_left _ _
  have δ_le2 : δ ≤ ε / (3 * |x| + 1) := by
    exact min_le_right _ _
  have δpos : 0 < δ := by
    have h₁ : 0 < ε / (3 * |x| + 1) := by
      apply div_pos hε
      have h₂ : (0 : ℝ) ≤ 3 * |x| := by positivity
      linarith [abs_nonneg x]
    have h₂ : 0 < 1 := by norm_num
    have h₃ : 0 < δ := by
      -- Since both 1 and ε / (3 * |x| + 1) are positive, their minimum is also positive.
      cases' le_total 1 (ε / (3 * |x| + 1)) with h h <;>
        simp_all [δ, min_eq_left, min_eq_right] <;>
        (try positivity) <;>
        (try linarith)
    exact h₃
  use δ, δpos
  intro h hne hh
  have h₁ : |((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2| < ε := by
    have h₂ : ((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2 = h * (3 * x + h) := by
      have h₃ : h ≠ 0 := hne
      field_simp [h₃, sub_eq_zero, add_eq_zero_iff_eq_neg]
      ring_nf
      <;>
      simp_all [pow_three]
      <;>
      ring_nf at *
      <;>
      nlinarith [sq_pos_of_ne_zero h₃]
    rw [h₂]
    have h₃ : |h * (3 * x + h)| < ε := by
      have h₄ : |h| < δ := by
        simpa [abs_sub_lt_iff] using hh
      have h₅ : |h| < 1 := by
        calc
          |h| < δ := h₄
          _ ≤ 1 := δ_le1
      have h₆ : |3 * x + h| ≤ 3 * |x| + 1 := by
        have h₇ : |3 * x + h| ≤ 3 * |x| + |h| := by
          calc
            |3 * x + h| ≤ |3 * x| + |h| := abs_add (3 * x) h
            _ = 3 * |x| + |h| := by simp [abs_mul, abs_of_nonneg (by norm_num : (3 : ℝ) ≥ 0)]
        have h₈ : 3 * |x| + |h| ≤ 3 * |x| + 1 := by
          linarith [abs_nonneg h]
        linarith
      calc
        |h * (3 * x + h)| = |h| * |3 * x + h| := by rw [abs_mul]
        _ ≤ |h| * (3 * |x| + 1) := by
          gcongr
          <;>
          simp_all [abs_mul, abs_of_nonneg]
          <;>
          linarith [abs_nonneg x]
        _ < δ * (3 * |x| + 1) := by
          gcongr
          <;>
          simp_all [abs_mul, abs_of_nonneg]
          <;>
          linarith [abs_nonneg x]
        _ ≤ (ε / (3 * |x| + 1)) * (3 * |x| + 1) := by
          have h₉ : δ ≤ ε / (3 * |x| + 1) := δ_le2
          have h₁₀ : 0 ≤ 3 * |x| + 1 := by positivity
          have h₁₁ : 0 ≤ ε / (3 * |x| + 1) := by
            apply div_nonneg
            · linarith
            · positivity
          nlinarith
        _ = ε := by
          have h₁₂ : 3 * |x| + 1 ≠ 0 := by positivity
          field_simp [h₁₂]
          <;>
          ring_nf
          <;>
          linarith
    exact h₃
  exact h₁
