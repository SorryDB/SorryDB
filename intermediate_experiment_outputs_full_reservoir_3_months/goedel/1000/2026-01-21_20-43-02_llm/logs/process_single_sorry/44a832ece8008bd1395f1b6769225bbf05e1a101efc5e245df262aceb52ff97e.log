variable {R} [CommRing R]

example (I : Ideal R) (x y : R) (hx : x ∈ I) : y * x + x * y - 0 ∈ I := by
  have h₁ : y * x ∈ I := I.mul_mem_right y hx
  have h₂ : x * y ∈ I := I.mul_mem_left x hx
  have h₃ : y * x + x * y ∈ I := I.add_mem h₁ h₂
  have h₄ : (0 : R) ∈ I := I.zero_mem
  have h₅ : y * x + x * y - 0 ∈ I := by
    simpa [sub_eq_add_neg, add_assoc] using I.add_mem h₃ (I.neg_mem h₄)
  exact h₅

example {S} [CommRing S] (f : R →+* S) (x : R) : x ∈ ker f ↔ f x = 0 := by
  rw [mem_ker]

def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    exact ⟨I.add_mem hx.1 hy.1, J.add_mem hx.2 hy.2⟩
  zero_mem' := by
    exact ⟨I.zero_mem, J.zero_mem⟩
  smul_mem' := by
    intro r x hx
    exact ⟨I.smul_mem r hx.1, J.smul_mem r hx.2⟩

example (I : Ideal R) (x y z : R ⧸ I) :
