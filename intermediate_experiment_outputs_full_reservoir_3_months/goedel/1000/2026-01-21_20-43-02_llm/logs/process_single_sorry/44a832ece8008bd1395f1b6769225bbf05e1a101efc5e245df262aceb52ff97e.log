### Solution

```lean
def chineseMap  : (R ⧸ ⨅ i, I i) →+* Π i, R ⧸ I i :=
  Quotient.lift (⨅ i, I i) (Pi.ringHom fun i : ι ↦ Quotient.mk (I i))
    (by
      intro a ha
      have h : ∀ i : ι, a ∈ I i := by
        intro i
        exact ha i
      -- For each i : ι, a ∈ I i implies that Quotient.mk (I i) a = 0 in R ⧸ I i.
      have h' : ∀ i : ι, (Quotient.mk (I i)) a = 0 := by
        intro i
        have hi : a ∈ I i := h i
        rw [Quotient.eq_zero_iff_mem]
        exact hi
      -- Therefore, Pi.ringHom fun i => Quotient.mk (I i) a = 0 in ∏ i, R ⧸ I i.
      ext i
      exact h' i)
```
