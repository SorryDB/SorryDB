      <;>
      ring_nf
      <;>
      norm_cast
      <;>
      omega
    }) <;>
    (try {
      aesop
    }) <;>
    (try {
      norm_num
      <;>
      aesop
    })
  
  probFailure_selectElem := by
    -- Prove that the probability of failure is zero
    simp [ProbabilityMonoid.Prob]
    <;>
