  selectElem := $[0..n]
  mem_support_selectElem x := by
    -- Show that every element is in the support of the uniform distribution over Fin (n + 1)
    simp [Finset.mem_range]
    <;>
    (try cases n <;> simp_all [Fin.ext_iff, Nat.mod_eq_of_lt]) <;>
    (try omega) <;>
    (try {
      aesop
    }) <;>
    (try {
      norm_num
      <;>
      aesop
    })
  
  probOutput_selectElem_eq x y := by
    -- Prove that the probability of selecting any two elements is the same
    simp [Finset.mem_range, Fin.val_mk]
    <;>
    (try cases n <;> simp_all [Fin.ext_iff, Nat.mod_eq_of_lt]) <;>
    (try {
      field_simp [Nat.cast_add_one_ne_zero]
      <;>
      ring_nf
      <;>
