theorem are_cards_eq {α : Type} [SampleableType α] {n : ℕ} {x y : Fin (n + 1)} :
  Pr[=x | $[0..n]] = Pr[=y | $[0..n]] := by
  have h₁ : Pr[=x | $[0..n]] = 1 / (n + 1 : ℝ≥0∞) := by
    simp [getFin]
    <;> simp_all [Finset.mem_univ]
    <;> field_simp [ENat.cast_add_one_ne_zero]
    <;> simp_all [Nat.cast_add, Nat.cast_one]
  have h₂ : Pr[=y | $[0..n]] = 1 / (n + 1 : ℝ≥0∞) := by
    simp [getFin]
    <;> simp_all [Finset.mem_univ]
    <;> field_simp [ENat.cast_add_one_ne_zero]
    <;> simp_all [Nat.cast_add, Nat.cast_one]
  rw [h₁, h₂]
  <;> simp_all
  <;> simp_all
  <;> simp_all
