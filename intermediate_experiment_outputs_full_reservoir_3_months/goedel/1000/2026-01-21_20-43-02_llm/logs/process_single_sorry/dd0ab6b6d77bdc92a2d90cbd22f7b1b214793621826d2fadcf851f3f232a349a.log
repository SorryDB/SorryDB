theorem mono {α : Type*} [MeasurableSpace α] (measure : OuterMeasure α) (μ : MeasurableSpace α → ℝ≥0∞) (h : ∀ s : Set α, μ s = measure s) :
  ∀ (s t : Set α), s ⊆ t → μ s ≤ μ t := by
  intro s t hst
  rw [h, h]
  exact measure.mono hst

theorem mono' (s t : Set α) (hst : s ⊆ t) : μ s ≤ μ t := by
  have h : μ s = measure s ∧ μ t = measure t := by
