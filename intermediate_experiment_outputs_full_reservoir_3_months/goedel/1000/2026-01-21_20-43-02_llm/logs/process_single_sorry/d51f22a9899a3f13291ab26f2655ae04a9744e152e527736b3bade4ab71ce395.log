theorem soundness : ŌłĆ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs]
    <;> constructor
  | lam k h =>
    simp [Circuit.eval,to_cs]
    <;> constructor
    <;> intro x
    <;> apply h
    <;> simp_all [h]
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    <;> split
    <;> apply h
    <;> simp_all [h]
  | share e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    <;> apply rw_bisim.right
    <;> intro x
    <;> simp [Exp.eval]
    <;> split
    <;> have hmy : x = Exp.eval e := by
      norm_num at *
      <;> simp_all [Exp.eval]
      <;> rfl
    <;> rw [hmy]
    <;> apply h
    <;> simp_all [h]
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    <;> split
    <;> case is_zero.h.h.isTrue he0 =>
      <;> split
      <;> case isTrue hsub =>
        <;> split
        <;> case isTrue hmul =>
          simp [*] at *
          <;> have hmy : o = 1 := by
            norm_num at *
            <;> simp_all [Exp.eval]
            <;> rfl
          <;> rw [hmy]
          <;> apply h
          <;> simp_all [h]
        <;> case isFalse hmul =>
          <;> simp_all [h]
      <;> case isFalse hsub =>
        <;> simp_all [h]
    <;> case is_zero.h.h.isFalse he0 =>
      <;> split
      <;> case isTrue hsub =>
        <;> split
        <;> case isTrue hmul =>
          simp [*] at *
          <;> rw [hmul]
          <;> apply h
          <;> simp_all [h]
        <;> case isFalse hmul =>
          <;> simp_all [h]
      <;> case isFalse hsub =>
        <;> simp_all [h]
  | assert_range w e c h =>
    have hŌéü : ŌłĆ (w : ŌäĢ) (d : denotation (ZMod p)) (k : Vector (ZMod p) w ŌåÆ Cs p (ZMod p)),
      (ŌłĆ args : Vector (ZMod p) w, rw_bisim d (k args).eval) ŌåÆ
      rw_bisim d (Cs.curry k).eval := by
      intro w
      induction w
      case _ =>
        intros d k h
        simp [Cs.curry]
        <;> apply h
      case _ ih =>
        intros d k h
        simp [Cs.curry]
        <;> constructor
        <;> intro x
        <;> apply ih
        <;> intro args
        <;> apply h
    simp [Circuit.eval, to_cs]
    <;> apply hŌéü
    <;> intro args
    <;> split
    <;> case (h args).isTrue =>
      <;> simp_all [h]
      <;> (try decide)
      <;> (try omega)
    <;> case (h args).isFalse =>
      <;> simp_all [h]
      <;> (try decide)
      <;> (try omega)
