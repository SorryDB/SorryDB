theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)
    intro h c
    obtain ⟨g, hg⟩ := h
    refine' fun h' => ⟨g ≫ h', _⟩
    simp [hg, comp_assoc]
    <;>
    (try simp_all [IsSection, comp_assoc]) <;>
    (try simp_all [IsLeftInverse, comp_assoc]) <;>
    (try simp_all [IsRightInverse, comp_assoc]) <;>
    (try simp_all [IsRetraction, comp_assoc]) <;>
    (try simp_all [IsSplitMono, comp_assoc])
    <;>
    (try simp_all [IsSplitEpi, comp_assoc])
  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
    obtain ⟨g, hg⟩ := h₁ (id Y)
    use g
    <;>
    (try simp_all [IsSection, comp_assoc]) <;>
    (try simp_all [IsLeftInverse, comp_assoc]) <;>
    (try simp_all [IsRightInverse, comp_assoc]) <;>
    (try simp_all [IsRetraction, comp_assoc]) <;>
    (try simp_all [split_mono, comp_assoc]) <;>
    (try simp_all [split_epi, comp_assoc])
