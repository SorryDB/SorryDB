### Lean 4 Proof

```lean
theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h₁ : split_mono f ↔ ∃ (g : Hom Y X), IsSection f g := by
    simp [split_mono, IsSection, IsLeftInverse]
    <;>
    aesop
  
  have h₂ : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) ↔ (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) := by
    rfl
  
  rw [h₁]
  constructor
  · intro h
    obtain ⟨g, hg⟩ := h
    intro c
    have h₃ : Function.Surjective (fun g : Hom c X => g ≫ f) := by
      intro h₄
      have h₅ : (fun g : Hom c X => g ≫ f) (h₄ ≫ g) = h₄ := by
        calc
          (fun g : Hom c X => g ≫ f) (h₄ ≫ g) = (h₄ ≫ g) ≫ f := rfl
          _ = h₄ ≫ (g ≫ f) := by rw [Composition.ext]
          _ = h₄ ≫ id X := by rw [hg]
          _ = h₄ := by simp
      refine' ⟨h₄ ≫ g, _⟩
      <;> simp_all [Composition.ext]
    exact h₃
  · intro h
    have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
    have h₄ : ∃ (g : Hom Y X), IsSection f g := by
      have h₅ : ∃ (g : Hom Y X), (fun g : Hom Y X => g ≫ f) g = id Y := by
        have h₆ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
        specialize h₆ (id Y)
        obtain ⟨g, hg⟩ := h₆
        refine' ⟨g, _⟩
        <;> simp_all
      obtain ⟨g, hg⟩ := h₅
      refine' ⟨g, _⟩
      have h₆ : g ≫ f = id Y := by
        calc
          g ≫ f = (fun g : Hom Y X => g ≫ f) g := rfl
          _ = id Y := by rw [hg]
      exact h₆
    exact h₄
```


