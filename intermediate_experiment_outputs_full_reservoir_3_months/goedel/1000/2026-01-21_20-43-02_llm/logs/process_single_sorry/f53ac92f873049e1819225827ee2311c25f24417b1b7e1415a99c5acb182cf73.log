theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h_main : (split_mono f) ↔ (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) := by
    constructor
    · -- Prove the forward direction: if f is split mono, then ∀ c, the function is surjective.
      intro h
      obtain ⟨g, hg⟩ := h
      intro c
      intro y
      use g ≫ y
      calc
        (g ≫ y) ≫ f = g ≫ (y ≫ f) := by rw [comp_assoc]
        _ = y ≫ (g ≫ f) := by rw [comp_assoc]
        _ = y ≫ id X := by rw [hg]
        _ = y := by simp [comp_id]
    · -- Prove the reverse direction: if ∀ c, the function is surjective, then f is split mono.
      intro h
      have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
      obtain ⟨g, hg⟩ := h₁ (id Y)
      have h₂ : g ≫ f = id Y := by simpa using hg
      refine' ⟨g, _⟩
      calc
        f ≫ g = f ≫ g := rfl
        _ = id X := by
          have h₃ : (g ≫ f) = id Y := by simpa using h₂
          have h₄ : g ≫ f = id Y := h₃
          have h₅ : f ≫ g = id X := by
            calc
              f ≫ g = f ≫ g := rfl
              _ = id X := by
                have h₆ : ∀ (x : α) (h : Hom X x), h = h ≫ (g ≫ f) := by
                  intro x h
                  have h₇ : Function.Surjective (fun g : Hom x X => g ≫ f) := h x
                  have h₈ : ∃ (g' : Hom x X), g' ≫ f = h := by
                    obtain ⟨g', hg'⟩ := h₇ h
                    exact ⟨g', by simp_all [Function.Surjective]⟩
                  obtain ⟨g', hg'⟩ := h₈
                  calc
                    h = g' ≫ f := by rw [hg']
                    _ = g' ≫ (g ≫ f) := by
                      rw [h₄]
                      <;> simp [comp_assoc]
                have h₉ := h₆ Y (id Y)
                have h₁₀ := h₆ X (id X)
                simp at h₉ h₁₀
                <;>
                (try simp_all [comp_assoc, id_comp, comp_id]) <;>
                (try
                  {
                    calc
                      f ≫ g = f ≫ g := rfl
                      _ = id X := by
                        have h₁₁ := h₆ X (id X)
                        have h₁₂ := h₆ Y (id Y)
                        simp at h₁₁ h₁₂
                        <;>
                        simp_all [comp_assoc, id_comp, comp_id]
                        <;>
                        (try
                          {
                            have h₁₃ := h₆ X (f ≫ g)
                            simp at h₁₃
                            <;>
                            simp_all [comp_assoc, id_comp, comp_id]
                            <;>
                            (try
                              {
                                have h₁₄ := h₆ X (f ≫ g)
                                simp at h₁₄
                                <;>
                                simp_all [comp_assoc, id_comp, comp_id]
                              })
                          })
                  }) <;>
                (try
                  {
                    have h₁₁ := h₆ X (f ≫ g)
                    simp at h₁₁
                    <;>
                    simp_all [comp_assoc, id_comp, comp_id]
                  })
                <;>
                (try
                  {
                    have h₁₁ := h₆ Y (g ≫ f)
                    simp at h₁₁
                    <;>
                    simp_all [comp_assoc, id_comp, comp_id]
                  })
              _ = id X := by simp
          exact h₅
  exact h_main
