theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h₁ : split_mono f ↔ ∃ (g : Hom Y X), IsSection f g := by
    rfl
  rw [h₁]
  constructor
  · intro h
    obtain ⟨g, hg⟩ := h
    intro c
    have h₂ : Function.Surjective (fun g : Hom c X => g ≫ f) := by
      intro h₃
      -- Use the section to find a preimage for h₃
      have h₄ : Hom c Y := by
        calc
          Hom c Y ≃ Hom c Y := rfl
          _ ≃ Hom c Y := rfl
      -- Use the section property to find a preimage
      have h₅ : ∃ (h₆ : Hom c X), h₆ ≫ f = h₃ := by
        -- Use the surjectivity of the map g ≫ f
        have h₆ : Function.Surjective (fun g : Hom c X => g ≫ f) := by
          intro h₃
          -- Use the section to find a preimage
          use (h₃ ≫ g)
          rw [hg]
          <;> simp [comp_assoc]
        -- Apply the surjectivity to find a preimage
        exact h₆ h₃
      -- Obtain the preimage and conclude the proof
      obtain ⟨h₆, h₇⟩ := h₅
      exact h₆
    exact h₂
  · intro h
    have h₂ : ∃ (g : Hom Y X), IsSection f g := by
      -- Use the surjectivity to find a right inverse
      have h₃ : ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := h
      -- Use the surjectivity to find a right inverse for X
      have h₄ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X
      -- Find a section using the surjectivity
      have h₅ : ∃ (g : Hom X X), g ≫ f = id X := by
        have h₆ : id X ∈ Set.range (fun g : Hom X X => g ≫ f) := by
          have h₇ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X
          have h₈ : id X ∈ Set.range (fun g : Hom X X => g ≫ f) := by
            -- Use the surjectivity to find a preimage for id X
            have h₉ : ∃ (g : Hom X X), g ≫ f = id X := by
              -- Use the surjectivity of the map g ≫ f
              have h₁₀ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X
              -- Apply the surjectivity to find a preimage
              have h₁₁ : ∃ (g : Hom X X), g ≫ f = id X := by
                exact h₁₀ (id X)
              exact h₁₁
            -- Obtain the preimage and conclude the proof
            obtain ⟨g, hg⟩ := h₉
            exact ⟨g, by simp_all [Set.mem_range]⟩
          exact h₈
        obtain ⟨g, hg⟩ := h₆
        exact ⟨g, by simp_all [Set.mem_range]⟩
      -- Use the section to find a right inverse for Y
      obtain ⟨g, hg⟩ := h₅
      have h₆ : IsSection f g := by
        -- Use the section property to conclude the proof
        have h₇ : g ≫ f = id X := hg
        exact h₇
      -- Conclude the proof by providing the right inverse
      refine' ⟨g, h₆⟩
    -- Use the section to find a right inverse and conclude the proof
    exact h₂
