theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h₁ : split_mono f ↔ (∃ (g : Hom Y X), g ≫ f = id X) := by
    constructor
    · -- Prove the forward direction: if split_mono f, then ∃ g : Hom Y X, g ≫ f = id X
      rintro ⟨g, hg⟩
      exact ⟨g, by simpa [IsSection] using hg⟩
    · -- Prove the reverse direction: if ∃ g : Hom Y X, g ≫ f = id X, then split_mono f
      rintro ⟨g, hg⟩
      exact ⟨g, by simpa [IsSection] using hg⟩
  
  constructor
  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)
    intro h
    have h₂ : ∃ (g : Hom Y X), g ≫ f = id X := by
      rw [h₁] at h
      exact h
    obtain ⟨g, hg⟩ := h₂
    intro c
    refine' fun hY => _
    -- For any hY : Hom c Y, we need to find g : Hom c X such that g ≫ f = hY
    have h₃ : (hY ≫ g) ≫ f = hY := by
      calc
        (hY ≫ g) ≫ f = hY ≫ (g ≫ f) := by rw [assoc]
        _ = hY ≫ id X := by rw [hg]
        _ = hY := by simp
    refine' ⟨hY ≫ g, _⟩
    <;> simp_all [assoc]
  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f
    intro h
    have h₂ : Function.Surjective (fun (g : Hom Y X) => g ≫ f) := by
      apply h
    -- Since the function is surjective, there exists g : Hom Y X such that g ≫ f = id X
    have h₃ : ∃ (g : Hom Y X), g ≫ f = id X := by
      have h₄ : (id X : Hom X X) ∈ Set.range (fun (g : Hom Y X) => g ≫ f) := by
        apply h₂
      obtain ⟨g, hg⟩ := h₄
      refine' ⟨g, _⟩
      simp_all [assco]
    -- Therefore, f is a split mono
    rw [h₁]
    exact h₃
