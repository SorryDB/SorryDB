theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · -- Prove the forward direction: if f is a split mono, then for all c, g ↦ g ≫ f is surjective.
    intro h
    rcases h with ⟨g, hg⟩
    intro c
    intro <;>
    (try cases') <;>
    (try simp_all [Hom.ext_iff, Function.Surjective]) <;>
    (try
      {
        use g ≫ f
        <;> simp_all [Hom.ext_iff, Function.Surjective]
        <;>
        (try
          {
            aesop
          })
      }) <;>
    (try
      {
        aesop
      })
  · -- Prove the reverse direction: if for all c, g ↦ g ≫ f is surjective, then f is a split mono.
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
    have h₂ : ∃ (g : Hom Y X), g ≫ f = id Y := by
      have h₃ : ∃ (g : Hom Y X), g ≫ f = id Y := by
        -- Use the surjectivity to find a g such that g ≫ f = id Y
        have h₄ : ∃ (g : Hom Y X), g ≫ f = id Y := by
          have h₅ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h₁
          have h₆ : (id Y : Hom Y Y) = id Y := rfl
          -- Use the surjectivity to find a g such that g ≫ f = id Y
          have h₇ : ∃ (g : Hom Y X), g ≫ f = id Y := by
            -- Use the surjectivity to find a g such that g ≫ f = id Y
            obtain ⟨g, hg⟩ := h₅ (id Y)
            exact ⟨g, by simpa using hg⟩
          exact h₇
        exact h₄
      exact h₃
    obtain ⟨g, hg⟩ := h₂
    -- Use the g found above to show that f is a split mono
    exact ⟨g, by simpa [hg] using hg⟩
