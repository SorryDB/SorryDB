theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  apply Iff.intro
  · -- Prove the forward direction: if f is a split mono, then for all c, the map (g : Hom c X) ↦ g ≫ f is surjective.
    intro h_split_mono c
    rcases h_split_mono with ⟨g, hg⟩
    have h_surj : Function.Surjective (fun g' : Hom c X => g' ≫ f) := by
      intro h
      -- Since f is a split mono, there exists a g such that f ≫ g = id X.
      -- We can use this to construct a g' such that g' ≫ f = h.
      use h ≫ g
      calc
        (h ≫ g) ≫ f = h ≫ (g ≫ f) := by rw [→ assoc]
        _ = h ≫ id X := by rw [hg]
        _ = h := by simp [id_comp]
    exact h_surj
  · -- Prove the reverse direction: if for all c, the map (g : Hom c X) ↦ g ≫ f is surjective, then f is a split mono.
    intro h_surj_all
    -- We need to find a g such that g ≫ f = id X.
    have h_c : Function.Surjective (fun g' : Hom Y X => g' ≫ f) := h_surj_all Y
    -- Since the map is surjective for c = Y, there exists a g such that g ≫ f = id X.
    have h_exists_g : ∃ (g : Hom Y X), g ≫ f = id X := by
      have h_id : ∃ (g' : Hom Y X), g' ≫ f = id X := by
        have h1 : Function.Surjective (fun g' : Hom Y X => g' ≫ f) := h_surj_all Y
        have h2 : (id X : Hom X X) ∈ Set.range (fun g' : Hom Y X => g' ≫ f) := by
