      have h₄ : ∃ (g : Hom Y X), g ≫ f = (1 : Hom X X) := by
        -- Use the surjectivity to find g such that g ≫ f = id X
        have h₅ : (1 : Hom X X) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by
          have h₆ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h₃
          have h₇ : (1 : Hom X X) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by
            specialize h₆ (1 : Hom X X)
            obtain ⟨g, hg⟩ := h₆
            exact ⟨g, by simp_all⟩
          exact h₇
        obtain ⟨g, hg⟩ := h₅
        exact ⟨g, by simp_all⟩
      obtain ⟨g, hg⟩ := h₄
      refine' ⟨g, _⟩
      simp_all [one_eq_id]
    · intro h
      obtain ⟨g, hg⟩ := h
      intro c
