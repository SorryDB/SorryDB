    intro h_split c
    have h₁ : split_mono f := h_split
    rcases h₁ with ⟨g, hg⟩
    have h₂ : Function.Surjective (fun g : Hom c Y => g ≫ f) := by
      intro z
      -- Use the right inverse g to construct the required element in Hom c Y.
      have h₃ : ∃ (y : Hom c Y), y ≫ f = z := by
        -- We need to find y : Hom c Y such that y ≫ f = z.
        -- Let's consider the composition z ≫ g.
        use z ≫ g
        calc
          (z ≫ g) ≫ f = z ≫ (g ≫ f) := by rw [comp_assoc]
          _ = z ≫ (1 : Hom X X) := by
            have h₄ : g ≫ f = 1 := by
              calc
                g ≫ f = 1 := by
                  have h₅ : g ≫ f = 1 := by
                    simpa [hg] using hg
                  exact h₅
                _ = 1 := by rfl
            simp [h₄]
          _ = z := by simp
      obtain ⟨y, hy⟩ := h₃
      refine' ⟨y, _⟩
      simp_all
    exact h₂
  · -- (←) Assume for any c, the function (· ≫ f) : Hom c Y → Hom c X is surjective. Then f is split mono.
    intro h_surj
    -- Use the surjectivity to find the right inverse g : Hom X Y.
    have h₁ : Function.Surjective (fun g : Hom X Y => g ≫ f) := by
      have h₂ : ∀ c : α, Function.Surjective (fun g : Hom c Y => g ≫ f) := h_surj
      exact h₂ X
    -- Since (· ≫ f) is surjective, there exists g : Hom X Y such that g ≫ f = 1.
    have h₂ : ∃ (g : Hom X Y), g ≫ f = 1 := by
      have h₃ : (1 : Hom X X) ∈ Set.range (fun g : Hom X Y => g ≫ f) := by
        have h₄ : Function.Surjective (fun g : Hom X Y => g ≫ f) := h₁
        exact h₄ _
      obtain ⟨g, hg⟩ := h₃
      refine' ⟨g, _⟩
      simp_all
