theorem split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  have h_imp : split_mono f → (∀ (c : α), Function.Surjective (fun g : Hom c X => g ≫ f)) := by
    intro h
    rcases h with ⟨g, hg⟩
    intro c y
    use y ≫ g
    simp [hg, comp_assoc]
    <;> rfl
  
  have h_conv : (∀ (c : α), Function.Surjective (fun g : Hom c X => g ≫ f)) → split_mono f := by
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y
    obtain ⟨g, hg⟩ := h₁ (id Y)
    have hg' : g ≫ f = id Y := by simpa using hg
    refine' ⟨g, _⟩
    rw [← hg']
    <;> simp [id_comp]
  
  constructor
  · intro h
    exact h_imp h
  · intro h
    exact h_conv h
```
