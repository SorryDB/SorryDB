theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  dsimp only [split_mono]
  constructor
  · rintro ⟨g, hg⟩
    intro c
    have h₁ : Function.Surjective (fun g : Hom c X => g ≫ f) := by
      -- Given that g ≫ f = id X, we can use g to construct the required surjective function.
      intro z
      have h₂ : (cat := C) Hom c Y := z
      have h₃ : (fun g : Hom c X => g ≫ f) (z ≫ g) = z := by
        calc
          (z ≫ g) ≫ f = z ≫ (g ≫ f) := by rw [comp_assoc]
          _ = z ≫ (1 : Hom X X) := by rw [hg]
          _ = z := by simp
      exact ⟨z ≫ g, h₃⟩
    exact h₁
  · intro h
    have h₁ : Function.Surjective (fun g : Hom Y Y => (g : Hom Y Y) ≫ f) := h Y
    have h₂ : ∃ (g : Hom Y X), (fun g : Hom Y X => g ≫ f) g = (1 : Hom Y Y) := by
      -- Use the surjectivity to find a g such that g ≫ f = id Y.
      have h₃ : ∃ (g : Hom Y X), (fun g : Hom Y X => g ≫ f) g = (1 : Hom Y Y) := by
        have h₄ : (1 : Hom Y Y) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by
          apply h₁
          <;> simp
        obtain ⟨g, hg⟩ := h₄
        refine' ⟨g, _⟩
        simpa using hg
      exact h₃
    obtain ⟨g, hg⟩ := h₂
    refine' ⟨g, _⟩
    -- Show that g ≫ f = id Y.
    have h₃ : g ≫ f = (1 : Hom Y Y) := by
      simpa using hg
    exact h₃
