theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)
    intro h
    intro c
    -- Extract the section g from the split_mono condition
    rcases h with ⟨g, hg⟩
    -- Show that (fun g : Hom c X => g ≫ f) is surjective
    refine' fun y => _
    -- Use g ≫ y as the preimage of y under the composition
    refine' ⟨g ≫ y, _⟩
    -- Verify that (g ≫ y) ≫ f = y
    calc
      (g ≫ y) ≫ f = g ≫ (y ≫ f) := by rw [assoc]
      _ = g ≫ (y ≫ f) := by rfl
      _ = y := by
        have h₁ : g ≫ f = id X := by
          have h₂ : IsSection g f := by
            -- Prove that g is a section of f
            exact ⟨hg⟩
          -- Use the definition of IsSection to get g ≫ f = id X
          exact h₂
        calc
          g ≫ (y ≫ f) = (g ≫ f) ≫ y := by rw [assoc]
          _ = (id X) ≫ y := by rw [h₁]
          _ = y := by simp [id_comp]
  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f
    intro h
    -- Show that there exists a g such that g ≫ f = id X
    have h₁ : ∃ (g : Hom Y X), g ≫ f = id X := by
      -- Use the surjectivity condition with c = X
      have h₂ : Function.Surjective (fun g : Hom X X => g ≫ f) := h X
      -- Since id X is in Hom X X, there exists a g such that g ≫ f = id X
      have h₃ : id X ∈ Set.univ := by simp
      obtain ⟨g, hg⟩ := h₂ (id X)
      refine' ⟨g, _⟩
      -- Verify that g ≫ f = id X
      simpa using hg
    -- Obtain the g and the condition g ≫ f = id X
    obtain ⟨g, hg⟩ := h₁
    -- Prove that f is a split mono
    refine' ⟨g, _⟩
    -- Use the condition g ≫ f = id X to conclude
    simpa [IsSection] using hg
