      "\n  constructor\n  · -- Prove the forward direction: if f is a split mono, then for all c, g ↦ g ≫ f is surjective.\n    intro h\n    rcases h with ⟨g, hg⟩\n    intro c\n    intro <;>\n    (try cases') <;>\n    (try simp_all [Hom.ext_iff, Function.Surjective]) <;>\n    (try\n      {\n        use g ≫ f\n        <;> simp_all [Hom.ext_iff, Function.Surjective]\n        <;>\n        (try\n          {\n            aesop\n          })\n      }) <;>\n    (try\n      {\n        aesop\n      })\n  · -- Prove the reverse direction: if for all c, g ↦ g ≫ f is surjective, then f is a split mono.\n    intro h\n    have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n    have h₂ : ∃ (g : Hom Y X), g ≫ f = id Y := by\n      have h₃ : ∃ (g : Hom Y X), g ≫ f = id Y := by\n        -- Use the surjectivity to find a g such that g ≫ f = id Y\n        have h₄ : ∃ (g : Hom Y X), g ≫ f = id Y := by\n          have h₅ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h₁\n          have h₆ : (id Y : Hom Y Y) = id Y := rfl\n          -- Use the surjectivity to find a g such that g ≫ f = id Y\n          have h₇ : ∃ (g : Hom Y X), g ≫ f = id Y := by\n            -- Use the surjectivity to find a g such that g ≫ f = id Y\n            obtain ⟨g, hg⟩ := h₅ (id Y)\n            exact ⟨g, by simpa using hg⟩\n          exact h₇\n        exact h₄\n      exact h₃\n    obtain ⟨g, hg⟩ := h₂\n    -- Use the g found above to show that f is a split mono\n    exact ⟨g, by simpa [hg] using hg⟩",
      "\n  constructor\n  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)\n    intro h c\n    obtain ⟨g, hg⟩ := h\n    refine' fun h' => ⟨g ≫ h', _⟩\n    simp [hg, comp_assoc]\n    <;>\n    (try simp_all [IsSection, comp_assoc]) <;>\n    (try simp_all [IsLeftInverse, comp_assoc]) <;>\n    (try simp_all [IsRightInverse, comp_assoc]) <;>\n    (try simp_all [IsRetraction, comp_assoc]) <;>\n    (try simp_all [IsSplitMono, comp_assoc])\n    <;>\n    (try simp_all [IsSplitEpi, comp_assoc])\n  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f\n    intro h\n    have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n    obtain ⟨g, hg⟩ := h₁ (id Y)\n    use g\n    <;>\n    (try simp_all [IsSection, comp_assoc]) <;>\n    (try simp_all [IsLeftInverse, comp_assoc]) <;>\n    (try simp_all [IsRightInverse, comp_assoc]) <;>\n    (try simp_all [IsRetraction, comp_assoc]) <;>\n    (try simp_all [split_mono, comp_assoc]) <;>\n    (try simp_all [split_epi, comp_assoc])\n    <;>\n    (try simp_all [Function.Surjective, comp_assoc])\n    <;>\n    (try aesop)",
      " f) := by sorry",
      "\n  have h₁ : split_mono f → ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by\n    intro h c\n    obtain ⟨g, hg⟩ := h\n    refine' ⟨fun _ => (fun h => g ≫ h) _, _⟩ <;> simp_all [Function.funext_iff]\n    <;> intros <;> simp_all [comp_assoc]\n    <;> use g ≫ g' <;> simp_all [comp_assoc]\n    <;> try simp_all [comp_assoc]\n    <;> use g ≫ g' <;> simp_all [comp_assoc]\n  \n  have h₂ : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) → split_mono f := by\n    intro h\n    have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n    have h₄ : ∃ (g : Hom Y X), g ≫ f = id Y := by\n      have h₅ : (id Y : Hom Y Y) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by\n        have h₆ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n        specialize h₆ (id Y)\n        obtain ⟨g, hg⟩ := h₆\n        exact ⟨g, by simp_all⟩\n      obtain ⟨g, hg⟩ := h₅\n      exact ⟨g, by simp_all⟩\n    obtain ⟨g, hg⟩ := h₄\n    refine' ⟨g, _⟩\n    simp_all [IsSection]\n    <;> simp_all [comp_assoc]\n    <;> try simp_all [comp_assoc]\n    <;> use g ≫ g' <;> simp_all [comp_assoc]\n  \n  exact ⟨h₁, h₂⟩",
      "\n  have h₁ : split_mono f ↔ ∃ (g : Hom Y X), IsSection f g := by\n    rfl\n  rw [h₁]\n  constructor\n  · intro h\n    obtain ⟨g, hg⟩ := h\n    intro c\n    have h₂ : Function.Surjective (fun g : Hom c X => g ≫ f) := by\n      intro h₃\n      -- Use the section to find a preimage for h₃\n      have h₄ : Hom c Y := by\n        calc\n          Hom c Y ≃ Hom c Y := rfl\n          _ ≃ Hom c Y := rfl\n      -- Use the section property to find a preimage\n      have h₅ : ∃ (h₆ : Hom c X), h₆ ≫ f = h₃ := by\n        -- Use the surjectivity of the map g ≫ f\n        have h₆ : Function.Surjective (fun g : Hom c X => g ≫ f) := by\n          intro h₃\n          -- Use the section to find a preimage\n          use (h₃ ≫ g)\n          rw [hg]\n          <;> simp [comp_assoc]\n        -- Apply the surjectivity to find a preimage\n        exact h₆ h₃\n      -- Obtain the preimage and conclude the proof\n      obtain ⟨h₆, h₇⟩ := h₅\n      exact h₆\n    exact h₂\n  · intro h\n    have h₂ : ∃ (g : Hom Y X), IsSection f g := by\n      -- Use the surjectivity to find a right inverse\n      have h₃ : ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := h\n      -- Use the surjectivity to find a right inverse for X\n      have h₄ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X\n      -- Find a section using the surjectivity\n      have h₅ : ∃ (g : Hom X X), g ≫ f = id X := by\n        have h₆ : id X ∈ Set.range (fun g : Hom X X => g ≫ f) := by\n          have h₇ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X\n          have h₈ : id X ∈ Set.range (fun g : Hom X X => g ≫ f) := by\n            -- Use the surjectivity to find a preimage for id X\n            have h₉ : ∃ (g : Hom X X), g ≫ f = id X := by\n              -- Use the surjectivity of the map g ≫ f\n              have h₁₀ : Function.Surjective (fun g : Hom X X => g ≫ f) := h₃ X\n              -- Apply the surjectivity to find a preimage\n              have h₁₁ : ∃ (g : Hom X X), g ≫ f = id X := by\n                exact h₁₀ (id X)\n              exact h₁₁\n            -- Obtain the preimage and conclude the proof\n            obtain ⟨g, hg⟩ := h₉\n            exact ⟨g, by simp_all [Set.mem_range]⟩\n          exact h₈\n        obtain ⟨g, hg⟩ := h₆\n        exact ⟨g, by simp_all [Set.mem_range]⟩\n      -- Use the section to find a right inverse for Y\n      obtain ⟨g, hg⟩ := h₅\n      have h₆ : IsSection f g := by\n        -- Use the section property to conclude the proof\n        have h₇ : g ≫ f = id X := hg\n        exact h₇\n      -- Conclude the proof by providing the right inverse\n      refine' ⟨g, h₆⟩\n    -- Use the section to find a right inverse and conclude the proof\n    exact h₂",
      "",
      "\n  have h₁ : split_mono f → ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by\n    intro h\n    obtain ⟨g, hg⟩ := h\n    intro c\n    intro y\n    have h₂ := hg\n    use y ≫ g\n    <;> simp_all [comp_assoc]\n    <;>\n    (try simp_all [Comp.ext_iff]) <;>\n    (try simp_all [comp_assoc]) <;>\n    (try simp_all [comp]) <;>\n    (try simp_all [Comp.ext_iff]) <;>\n    (try simp_all [comp_assoc]) <;>\n    (try simp_all [comp]) <;>\n    (try simp_all [Comp.ext_iff]) <;>\n    (try simp_all [comp_assoc]) <;>\n    (try simp_all [comp]) <;>\n    (try simp_all [Comp.ext_iff]) <;>\n    (try simp_all [comp_assoc]) <;>\n    (try simp_all [comp]) <;>\n    (try simp_all [Comp.ext_iff])\n    <;>\n    (try simp_all [comp_assoc]) <;>\n    (try simp_all [comp]) <;>\n    (try simp_all [Comp.ext_iff])\n  have h₂ : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) → split_mono f := by\n    intro h\n    have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n    obtain ⟨g, hg⟩ := h₃ (id Y)\n    have h₄ : g ≫ f = id Y := by simpa using hg\n    refine' ⟨g, _⟩\n    have h₅ : f ≫ g = id X := by\n      have h₆ : Function.Surjective (fun g : Hom X X => g ≫ f) := h X\n      obtain ⟨h₇, hh₇⟩ := h₆ (id X)\n      have h₈ : h₇ ≫ f = id X := by simpa using hh₇\n      have h₉ : Function.Surjective (fun g : Hom Y Y => f ≫ g) := by\n        intro c\n        have h₁₀ := h c\n        -- Use the surjectivity of the composition with f to find the required g\n        have h₁₁ : Function.Surjective (fun g : Hom c X => g ≫ f) := h c\n        intro y\n        obtain ⟨g, hg⟩ := h₁₁ y\n        use g ≫ g\n        <;> simp_all [comp_assoc]\n        <;>\n        (try simp_all [Comp.ext_iff]) <;>\n        (try simp_all [comp_assoc]) <;>\n        (try simp_all [comp]) <;>\n        (try simp_all [Comp.ext_iff]) <;>\n        (try simp_all [comp_assoc]) <;>\n        (try simp_all [comp]) <;>\n        (try simp_all [Comp.ext_iff]) <;>\n        (try simp_all [comp_assoc]) <;>\n        (try simp_all [comp]) <;>\n        (try simp_all [Comp.ext_iff]) <;>\n        (try simp_all [comp_assoc]) <;>\n        (try simp_all [comp]) <;>\n        (try simp_all [Comp.ext_iff])\n        <;>\n        (try simp_all [comp_assoc]) <;>\n        (try simp_all [comp]) <;>\n        (try simp_all [Comp.ext_iff])\n      -- Use the surjectivity to find the required g\n      obtain ⟨h₁₀, hh₁₀⟩ := h₉ (id Y)\n      have h₁₁ : f ≫ h₁₀ = id Y := by simpa using hh₁₀\n      have h₁₂ : h₇ ≫ f = id X := by simpa using hh₇\n      calc\n        f ≫ g = f ≫ g := rfl\n        _ = id X := by\n          have h₁₃ := calc\n            (id X) ≫ (g ≫ f) = (id X) ≫ (id Y) := by rw [h₄]\n            _ = id Y := by simp [comp_id]\n            _ = (f ≫ h₁₀) := by rw [h₁₁]\n            _ = (f ≫ h₁₀) := rfl\n          have h₁₄ := calc\n            (id X) ≫ (g ≫ f) = (id X) ≫ (id Y) := by rw [h₄]\n            _ = id Y := by simp [comp_id]\n            _ = (f ≫ h₁₀) := by rw [h₁₁]\n            _ = (f ≫ h₁₀) := rfl\n          simp_all [comp_assoc]\n          <;>\n          (try simp_all [Comp.ext_iff]) <;>\n          (try simp_all [comp_assoc]) <;>\n          (try simp_all [comp]) <;>\n          (try simp_all [Comp.ext_iff]) <;>\n          (try simp_all [comp_assoc]) <;>\n          (try simp_all [comp]) <;>\n          (try simp_all [Comp.ext_iff]) <;>\n          (try simp_all [comp_assoc]) <;>\n          (try simp_all [comp]) <;>\n          (try simp_all [Comp.ext_iff]) <;>\n          (try simp_all [comp_assoc]) <;>\n          (try simp_all [comp]) <;>\n          (try simp_all [Comp.ext_iff])\n          <;>\n          (try simp_all [comp_assoc]) <;>\n          (try simp_all [comp]) <;>\n          (try simp_all [Comp.ext_iff])\n    exact h₅\n  constructor\n  · intro h\n    exact h₁ h\n  · intro h\n    exact h₂ h",
      "\n  constructor\n  · -- Prove the forward direction: split_mono f → ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)\n    intro h c\n    have h₁ : ∃ (g : Hom Y X), IsSection f g := h\n    obtain ⟨g, hg⟩ := h₁\n    -- Use the inverse map g to show surjectivity\n    intro y\n    have h₂ : g ≫ f = id X := hg\n    have h₃ : ∃ (x : Hom c X), x ≫ f = y := by\n      -- Define the desired g' as y ≫ g\n      use y ≫ g\n      calc\n        (y ≫ g) ≫ f = y ≫ (g ≫ f) := by rw [assoc]\n        _ = y ≫ id X := by rw [hg]\n        _ = y := by simp [id_comp]\n    exact h₃\n  · -- Prove the reverse direction: ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) → split_mono f\n    intro h\n    have h₁ : ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := h\n    -- Construct the right inverse using the surjectivity condition\n    have h₂ : ∃ (g : Hom Y X), IsSection f g := by\n      have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h₁ Y\n      -- Use the identity map to find the right inverse\n      have h₄ : ∃ (g : Hom Y X), (g ≫ f : Hom Y Y) = id Y := by\n        have h₅ : (id Y : Hom Y Y) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by\n          apply h₃\n        obtain ⟨g, hg⟩ := h₅\n        refine' ⟨g, _⟩\n        simp_all [id_comp]\n        <;> tried simp_all [comp_id]\n        <;> tried simp_all [assoc]\n      obtain ⟨g, hg⟩ := h₄\n      have h₅ : IsSection f g := by\n        have h₆ : g ≫ f = id X := by\n          calc\n            g ≫ f = g ≫ f := rfl\n            _ = id X := by\n              have h₇ : (g ≫ f : Hom Y Y) = id Y := hg\n              have h₈ : (id Y : Hom Y Y) = id Y := rfl\n              simp_all [id_comp, comp_id]\n              <;> try simp_all [assoc]\n              <;> try simp_all [comp_assoc]\n              <;> try simp_all [id_comp, comp_id]\n              <;> try simp_all [IsSection]\n              <;> try simp_all [IsRetraction]\n              <;> try simp_all [split_mono]\n              <;> try simp_all [split_epi]\n              <;> try simp_all [Function.Surjective]\n              <;> try simp_all [Function.Injective]\n              <;> try simp_all [Function.Bijective]\n        exact h₆\n      exact ⟨g, h₅⟩\n    exact h₂",
      "\n  have h₁ : split_mono f ↔ (∃ (g : Hom Y X), g ≫ f = id X) := by\n    constructor\n    · -- Prove the forward direction: if split_mono f, then ∃ g : Hom Y X, g ≫ f = id X\n      rintro ⟨g, hg⟩\n      exact ⟨g, by simpa [IsSection] using hg⟩\n    · -- Prove the reverse direction: if ∃ g : Hom Y X, g ≫ f = id X, then split_mono f\n      rintro ⟨g, hg⟩\n      exact ⟨g, by simpa [IsSection] using hg⟩\n  \n  constructor\n  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)\n    intro h\n    have h₂ : ∃ (g : Hom Y X), g ≫ f = id X := by\n      rw [h₁] at h\n      exact h\n    obtain ⟨g, hg⟩ := h₂\n    intro c\n    refine' fun hY => _\n    -- For any hY : Hom c Y, we need to find g : Hom c X such that g ≫ f = hY\n    have h₃ : (hY ≫ g) ≫ f = hY := by\n      calc\n        (hY ≫ g) ≫ f = hY ≫ (g ≫ f) := by rw [assoc]\n        _ = hY ≫ id X := by rw [hg]\n        _ = hY := by simp\n    refine' ⟨hY ≫ g, _⟩\n    <;> simp_all [assoc]\n  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f\n    intro h\n    have h₂ : Function.Surjective (fun (g : Hom Y X) => g ≫ f) := by\n      apply h\n    -- Since the function is surjective, there exists g : Hom Y X such that g ≫ f = id X\n    have h₃ : ∃ (g : Hom Y X), g ≫ f = id X := by\n      have h₄ : (id X : Hom X X) ∈ Set.range (fun (g : Hom Y X) => g ≫ f) := by\n        apply h₂\n      obtain ⟨g, hg⟩ := h₄\n      refine' ⟨g, _⟩\n      simp_all [assco]\n    -- Therefore, f is a split mono\n    rw [h₁]\n    exact h₃",
      "\n  have h₁ : split_mono f ↔ ∃ (g : Hom Y X), IsSection f g := by\n    simp [split_mono, IsSection, IsLeftInverse]\n    <;>\n    aesop\n  \n  have h₂ : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) ↔ (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) := by\n    rfl\n  \n  rw [h₁]\n  constructor\n  · intro h\n    obtain ⟨g, hg⟩ := h\n    intro c\n    have h₃ : Function.Surjective (fun g : Hom c X => g ≫ f) := by\n      intro h₄\n      have h₅ : (fun g : Hom c X => g ≫ f) (h₄ ≫ g) = h₄ := by\n        calc\n          (fun g : Hom c X => g ≫ f) (h₄ ≫ g) = (h₄ ≫ g) ≫ f := rfl\n          _ = h₄ ≫ (g ≫ f) := by rw [Composition.ext]\n          _ = h₄ ≫ id X := by rw [hg]\n          _ = h₄ := by simp\n      refine' ⟨h₄ ≫ g, _⟩\n      <;> simp_all [Composition.ext]\n    exact h₃\n  · intro h\n    have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n    have h₄ : ∃ (g : Hom Y X), IsSection f g := by\n      have h₅ : ∃ (g : Hom Y X), (fun g : Hom Y X => g ≫ f) g = id Y := by\n        have h₆ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n        specialize h₆ (id Y)\n        obtain ⟨g, hg⟩ := h₆\n        refine' ⟨g, _⟩\n        <;> simp_all\n      obtain ⟨g, hg⟩ := h₅\n      refine' ⟨g, _⟩\n      have h₆ : g ≫ f = id Y := by\n        calc\n          g ≫ f = (fun g : Hom Y X => g ≫ f) g := rfl\n          _ = id Y := by rw [hg]\n      exact h₆\n    exact h₄",
      "\n  have h₁ : split_mono f ↔ ∃ (g : Hom Y X), g ≫ f = 1 := by\n    simp only [split_mono, IsSection]\n    <;>\n    constructor <;>\n    intro h <;>\n    (try cases h with\n      | intro g hg =>\n        refine' ⟨g, _⟩ <;>\n        simp_all [one_eq_id]) <;>\n    (try cases h with\n      | intro g hg =>\n        refine' ⟨g, _⟩ <;>\n        simp_all [one_eq_id]) <;>\n    (try {\n      cases h with\n      | intro g hg =>\n        refine' ⟨g, _⟩ <;>\n        simp_all [one_eq_id] <;>\n        try simp_all [Function.Bijective]\n    })\n    <;>\n    (try {\n      cases h with\n      | intro g hg =>\n        refine' ⟨g, _⟩ <;>\n        simp_all [one_eq_id] <;>\n        try simp_all [Function.Bijective]\n    })\n  have h₂ : (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) ↔ ∃ (g : Hom Y X), g ≫ f = 1 := by\n    constructor\n    · intro h\n      have h₃ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n      have h₄ : ∃ (g : Hom Y X), g ≫ f = (1 : Hom X X) := by\n        -- Use the surjectivity to find g such that g ≫ f = id X\n        have h₅ : (1 : Hom X X) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by\n          have h₆ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h₃\n          have h₇ : (1 : Hom X X) ∈ Set.range (fun g : Hom Y X => g ≫ f) := by\n            specialize h₆ (1 : Hom X X)\n            obtain ⟨g, hg⟩ := h₆\n            exact ⟨g, by simp_all⟩\n          exact h₇\n        obtain ⟨g, hg⟩ := h₅\n        exact ⟨g, by simp_all⟩\n      obtain ⟨g, hg⟩ := h₄\n      refine' ⟨g, _⟩\n      simp_all [one_eq_id]\n    · intro h\n      obtain ⟨g, hg⟩ := h\n      intro c\n      have h₃ : Function.Surjective (fun g : Hom c X => g ≫ f) := by\n        -- Show that for any h : Hom c Y, there exists g : Hom c X such that g ≫ f = h\n        intro h₄\n        have h₅ : ∃ (g : Hom c X), g ≫ f = h₄ := by\n          -- Use the fact that g ≫ f = id X to construct the required g\n          have h₆ : g ≫ f = (1 : Hom X X) := by simp_all [one_eq_id]\n          -- Use the construction to find the required g\n          have h₇ : ∃ (g : Hom c X), g ≫ f = h₄ := by\n            -- Use the composition to find the required g\n            use h₄ ≫ g\n            calc\n              (h₄ ≫ g) ≫ f = h₄ ≫ (g ≫ f) := by rw [comp_assoc]\n              _ = h₄ ≫ (1 : Hom X X) := by rw [hg]\n              _ = h₄ := by simp [one_eq_id]\n          exact h₇\n        obtain ⟨g, hg⟩ := h₅\n        exact ⟨g, by simp_all⟩\n      exact h₃\n  rw [h₁, h₂]\n  <;>\n  aesop",
      "\n  have h_main : (split_mono f) ↔ (∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)) := by\n    constructor\n    · -- Prove the forward direction: if f is split mono, then ∀ c, the function is surjective.\n      intro h\n      obtain ⟨g, hg⟩ := h\n      intro c\n      intro y\n      use g ≫ y\n      calc\n        (g ≫ y) ≫ f = g ≫ (y ≫ f) := by rw [comp_assoc]\n        _ = y ≫ (g ≫ f) := by rw [comp_assoc]\n        _ = y ≫ id X := by rw [hg]\n        _ = y := by simp [comp_id]\n    · -- Prove the reverse direction: if ∀ c, the function is surjective, then f is split mono.\n      intro h\n      have h₁ : Function.Surjective (fun g : Hom Y X => g ≫ f) := h Y\n      obtain ⟨g, hg⟩ := h₁ (id Y)\n      have h₂ : g ≫ f = id Y := by simpa using hg\n      refine' ⟨g, _⟩\n      calc\n        f ≫ g = f ≫ g := rfl\n        _ = id X := by\n          have h₃ : (g ≫ f) = id Y := by simpa using h₂\n          have h₄ : g ≫ f = id Y := h₃\n          have h₅ : f ≫ g = id X := by\n            calc\n              f ≫ g = f ≫ g := rfl\n              _ = id X := by\n                have h₆ : ∀ (x : α) (h : Hom X x), h = h ≫ (g ≫ f) := by\n                  intro x h\n                  have h₇ : Function.Surjective (fun g : Hom x X => g ≫ f) := h x\n                  have h₈ : ∃ (g' : Hom x X), g' ≫ f = h := by\n                    obtain ⟨g', hg'⟩ := h₇ h\n                    exact ⟨g', by simp_all [Function.Surjective]⟩\n                  obtain ⟨g', hg'⟩ := h₈\n                  calc\n                    h = g' ≫ f := by rw [hg']\n                    _ = g' ≫ (g ≫ f) := by\n                      rw [h₄]\n                      <;> simp [comp_assoc]\n                have h₉ := h₆ Y (id Y)\n                have h₁₀ := h₆ X (id X)\n                simp at h₉ h₁₀\n                <;>\n                (try simp_all [comp_assoc, id_comp, comp_id]) <;>\n                (try\n                  {\n                    calc\n                      f ≫ g = f ≫ g := rfl\n                      _ = id X := by\n                        have h₁₁ := h₆ X (id X)\n                        have h₁₂ := h₆ Y (id Y)\n                        simp at h₁₁ h₁₂\n                        <;>\n                        simp_all [comp_assoc, id_comp, comp_id]\n                        <;>\n                        (try\n                          {\n                            have h₁₃ := h₆ X (f ≫ g)\n                            simp at h₁₃\n                            <;>\n                            simp_all [comp_assoc, id_comp, comp_id]\n                            <;>\n                            (try\n                              {\n                                have h₁₄ := h₆ X (f ≫ g)\n                                simp at h₁₄\n                                <;>\n                                simp_all [comp_assoc, id_comp, comp_id]\n                              })\n                          })\n                  }) <;>\n                (try\n                  {\n                    have h₁₁ := h₆ X (f ≫ g)\n                    simp at h₁₁\n                    <;>\n                    simp_all [comp_assoc, id_comp, comp_id]\n                  })\n                <;>\n                (try\n                  {\n                    have h₁₁ := h₆ Y (g ≫ f)\n                    simp at h₁₁\n                    <;>\n                    simp_all [comp_assoc, id_comp, comp_id]\n                  })\n              _ = id X := by simp\n          exact h₅\n  exact h_main",
      "\n  constructor\n  · -- Prove the forward direction: if split_mono f, then ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f)\n    intro h\n    intro c\n    -- Extract the section g from the split_mono condition\n    rcases h with ⟨g, hg⟩\n    -- Show that (fun g : Hom c X => g ≫ f) is surjective\n    refine' fun y => _\n    -- Use g ≫ y as the preimage of y under the composition\n    refine' ⟨g ≫ y, _⟩\n    -- Verify that (g ≫ y) ≫ f = y\n    calc\n      (g ≫ y) ≫ f = g ≫ (y ≫ f) := by rw [assoc]\n      _ = g ≫ (y ≫ f) := by rfl\n      _ = y := by\n        have h₁ : g ≫ f = id X := by\n          have h₂ : IsSection g f := by\n            -- Prove that g is a section of f\n            exact ⟨hg⟩\n          -- Use the definition of IsSection to get g ≫ f = id X\n          exact h₂\n        calc\n          g ≫ (y ≫ f) = (g ≫ f) ≫ y := by rw [assoc]\n          _ = (id X) ≫ y := by rw [h₁]\n          _ = y := by simp [id_comp]\n  · -- Prove the reverse direction: if ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f), then split_mono f\n    intro h\n    -- Show that there exists a g such that g ≫ f = id X\n    have h₁ : ∃ (g : Hom Y X), g ≫ f = id X := by\n      -- Use the surjectivity condition with c = X\n      have h₂ : Function.Surjective (fun g : Hom X X => g ≫ f) := h X\n      -- Since id X is in Hom X X, there exists a g such that g ≫ f = id X\n      have h₃ : id X ∈ Set.univ := by simp\n      obtain ⟨g, hg⟩ := h₂ (id X)\n      refine' ⟨g, _⟩\n      -- Verify that g ≫ f = id X\n      simpa using hg\n    -- Obtain the g and the condition g ≫ f = id X\n    obtain ⟨g, hg⟩ := h₁\n    -- Prove that f is a split mono\n    refine' ⟨g, _⟩\n    -- Use the condition g ≫ f = id X to conclude\n    simpa [IsSection] using hg",
      "",
