        -- Show that for any h : Hom c Y, there exists g : Hom c X such that g ≫ f = h
        intro h₄
        have h₅ : ∃ (g : Hom c X), g ≫ f = h₄ := by
          -- Use the fact that g ≫ f = id X to construct the required g
