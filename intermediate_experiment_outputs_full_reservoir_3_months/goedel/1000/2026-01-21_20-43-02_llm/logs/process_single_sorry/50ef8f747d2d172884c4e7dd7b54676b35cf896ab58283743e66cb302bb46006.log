theorem sum_of_prod {X : Type*} [CommSemiring X] (f : ℕ → X) (m n : ℕ) :
  ∑ i ∈ range (m * n), f i =
    ∑ j ∈ range m, ∑ k ∈ range n, f (j + k * m) := by
  have h : ∀ m n : ℕ, ∑ i ∈ range (m * n), f i = ∑ j ∈ range m, ∑ k ∈ range n, f (j + k * m) := by
    intro m n
    have h₁ : ∀ m n : ℕ, ∑ i ∈ range (m * n), f i = ∑ j ∈ range m, ∑ k ∈ range n, f (j + k * m) := by
      intro m n
      -- We use the fact that the sum over m * n terms can be reorganized into a double sum over m and n
      calc
        ∑ i ∈ range (m * n), f i = ∑ i ∈ range (m * n), f i := rfl
        _ = ∑ j in Finset.range m, ∑ k in Finset.range n, f (j + k * m) := by
          -- We use the property of sums to reorganize the terms
          have h₂ : ∀ m n : ℕ, ∑ i in Finset.range (m * n), f i = ∑ j in Finset.range m, ∑ k in Finset.range n, f (j + k * m) := by
            intro m n
            -- We use the fact that the sum over m * n terms can be reorganized into a double sum over m and n
            calc
              ∑ i in Finset.range (m * n), f i = ∑ i in Finset.range (m * n), f i := rfl
              _ = ∑ j in Finset.range m, ∑ k in Finset.range n, f (j + k * m) := by
                -- We use the property of sums to reorganize the terms
                rw [Finset.sum_range_mul]
                <;> simp [add_comm, add_left_comm, add_assoc]
                <;>
                  rw [Finset.sum_comm]
