lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h₁ : IsBounded (f '' s) := by
    -- Use the fact that the image of a compact set under a continuous function is compact, hence bounded.
    have h₂ : ContinuousOn f s := by
      -- Prove that `f` is continuous on `s`.
      have h₃ : ∀ (a : ι), ContinuousWithinAt f (Set.Ioi a) a := hf.right_continuous
      -- Since `f` is right-continuous, it is continuous on `s` in the subspace topology.
      refine' continuousOn_iff_continuous_restrict.mpr _
      apply Continuous ContinuousOn_iff.mpr
      -- Use the fact that `f` is right-continuous to show continuity on `s`.
      intro x hx
      have h₄ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
      have h₅ : ContinuousWithinAt f s x := by
        -- Since `s` is compact and `f` is right-continuous, it is continuous on `s`.
        have h₆ : ContinuousWithinAt f (Set.Ici x) x := by
          -- Use the fact that `f` is right-continuous to show continuity from the right.
          have h₇ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
          have h₈ : ContinuousWithinAt f (Set.Ici x) x := by
            apply ContinuousWithinAt.mono h₇
            -- Show that `Set.Ioi x` is a subset of `Set.Ici x`.
            exact fun y hy => by
              simp only [Set.mem_Ioi, Set.mem_Ici] at hy ⊢
              exact le_of_lt hy
          exact h₈
        -- Use the fact that `s` is compact to show continuity on `s`.
        have h₉ : ContinuousWithinAt f s x := by
          have h₁₀ : x ∈ s := hx
          have h₁₁ : ContinuousWithinAt f (Set.Ici x) x := h₆
          have h₁₂ : ContinuousWithinAt f s x := by
            -- Use the fact that `s` is compact and `f` is continuous from the right.
            have h₁₃ : s ∈ 𝓝[s] x := by
              apply mem_nhdsWithin_of_mem_nhds
              exact hs.isClosed.mem_nhds h₁₀
            -- Use the fact that `f` is continuous from the right to show continuity on `s`.
            have h₁₄ : ContinuousWithinAt f (Set.Ici x) x := h₆
            have h₁₅ : ContinuousWithinAt f s x := by
              -- Use the fact that `s` is compact and `f` is continuous from the right.
              apply ContinuousWithinAt.mono h₁₄
              -- Show that `Set.Ici x` is a subset of `s` in the neighborhood of `x`.
              filter_upwards [h₁₃] with y hy
              simp_all [Set.mem_Ici]
              <;>
              (try aesop) <;>
              (try simp_all [Set.mem_Ici]) <;>
              (try linarith) <;>
              (try exact le_of_lt (by aesop))
            exact h₁₅
          exact h₁₂
        exact h₉
      -- Use the fact that `f` is continuous within `s` to show continuity on `s`.
      exact h₅
    -- Since `f` is continuous on `s` and `s` is compact, `f '' s` is compact, hence bounded.
    have h₃ : IsCompact (f '' s) := hs.image h₂
    -- Use the fact that compact sets are bounded.
    exact IsCompact.isBounded h₃
  exact h₁
