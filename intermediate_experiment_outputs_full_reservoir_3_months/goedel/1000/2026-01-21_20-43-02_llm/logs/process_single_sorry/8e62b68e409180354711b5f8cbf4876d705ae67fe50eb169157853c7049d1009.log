import Mathlib.Topology.Bases
import Mathlib.Topology.MetricSpace.Pseudo.Defs

/-! # cadlag functions

-/

open Filter TopologicalSpace Bornology
open scoped Topology

variable {ι E : Type*} [PartialOrder ι] [TopologicalSpace ι] [TopologicalSpace E]

/-- The predicate that a function is right continuous. -/
abbrev Function.RightContinuous (f : ι → E) :=
  ∀ a, ContinuousWithinAt f (Set.Ioi a) a

/-- A function is cadlag if it is right-continuous and has left limits. -/
structure IsCadlag (f : ι → E) : Prop where
  right_continuous : Function.RightContinuous f
  left_limit : ∀ x, ∃ l, Tendsto f (𝓝[<] x) (𝓝 l)

/-- A càdlàg function maps compact sets to bounded sets. -/
lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h1 : IsBounded (f '' s) := by
    -- Use the fact that ι is first-countable and the image of a compact set under a continuous function is compact.
    -- Since f is right-continuous, we can use the compactness of s to show the boundedness of f(s).
    -- Here, we leverage the fact that in a pseudometric space, a compact set is bounded.
    have h2 : IsCompact (f '' s) := by
      -- Since f is right-continuous, it is continuous from the right, but we need to show that it maps compact sets to compact sets.
      -- However, we cannot directly use the continuity of f because it is only right-continuous.
      -- Instead, we will use the fact that the restriction of f to s is continuous under the right-order topology.
      -- But this might not be straightforward, so we take an alternative approach.
      -- Alternatively, we use the fact that if a function is right-continuous, it can be extended to a continuous function on the one-point compactification of ι.
      -- However, this approach might require more advanced concepts than we have available here.
      -- A better approach is to realize that if we impose the condition that f is *continuous* (not just right-continuous), then the proof becomes straightforward.
      -- But since we only have right-continuity, we need to find another way.
      -- 
      -- Given the constraints (no imports, limited space), we cannot construct a full proof here.
      -- Therefore, we assume that f is continuous (which is a stronger condition), and show that f(s) is compact since s is compact.
      -- But this is not what the problem states! The problem states that f is right-continuous and has left limits, which is not enough to conclude that f(s) is compact unless we know more about s.
      -- 
      -- To avoid this, we take another approach:
      -- In a pseudometric space, a set is compact iff it is complete and totally bounded.
      -- We could try to show that f(s) is totally bounded by using the fact that s is compact and f is "continuous enough" (but we would need to formalize what that means).
      -- However, given the time and space constraints, we will instead assume that f is continuous (which is not given in the problem statement) to proceed.
      -- 
      -- But we cannot do this because the problem states right-continuity, not continuity.
      -- 
      -- Another approach would be to notice that in ℝ, right-continuous functions can be shown to map compact sets to bounded sets because they are "almost" continuous.
