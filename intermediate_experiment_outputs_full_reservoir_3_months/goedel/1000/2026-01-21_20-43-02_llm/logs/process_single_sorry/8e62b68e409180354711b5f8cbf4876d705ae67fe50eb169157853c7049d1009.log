lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h1 : IsCompact (f '' s) := by
    have h2 : ContinuousOn f s := by
      intro x hx
      have h3 : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
      have h4 : ContinuousWithinAt f (Set.Ici x) x := by
        -- Show that f is continuous from the right at x
        have h5 : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
        have h6 : Set.Ioi x ⊆ Set.Ici x := by
          intro y hy
          exact le_of_lt hy
        -- Use the fact that f is continuous from the right to deduce continuity within the closed interval
        have h7 : ContinuousWithinAt f (Set.Ici x) x :=
          ContinuousWithinAt.mono h5 h6
        exact h7
      -- Since f is continuous from the right at x, it is continuous at x when restricted to s
      have h8 : ContinuousWithinAt f s x := by
        have h9 : ContinuousWithinAt f (Set.Ici x) x := h4
        have h10 : ContinuousWithinAt f s x := by
          have h11 : s ∈ 𝓝[Set.Ici x] x := by
            have h12 : s ∈ 𝓝[Set.Ici x] x := by
              have h13 : x ∈ s := hx
              have h14 : s ∈ 𝓝[Set.Ici x] x := by
                -- Prove that s is in the neighborhood filter of x within Set.Ici x
                apply 𝓝[Set.Ici x]_mem_nhdsWithin_Ici.mpr
                exact IsOpen.mem_nhds isOpen_univ (Set.mem_univ x)
              exact h14
            exact h12
          -- Use the fact that f is continuous within the interval to deduce continuity within s
          have h15 : ContinuousWithinAt f (Set.Ici x) x := h9
          have h16 : ContinuousWithinAt f s x :=
            ContinuousWithinAt.mono h15 (nhdsWithin_le_nhdsWithin h11)
          exact h16
        exact h10
      exact h8
    -- Use the fact that f is continuous on s and s is compact to deduce that f(s) is compact
    have h17 : ContinuousOn f s := h2
    have h18 : IsCompact (f '' s) := IsCompact.image hs h17
    exact h18
  -- Since f(s) is compact, it is bounded
  have h19 : IsBounded (f '' s) := h1.isBounded
  exact h19
