            intro ω
            have h₈ : (τ i ω : WithTop ι) ≤ (j : WithTop ι) := h₆ ω
            have h₉ : (X (τ i ω).unbot ω) = (X (τ i ω).unbot ω) := rfl
            have h₁₀ : |(stoppedValue X (τ i) ω)| ≤ |(X j ω)| := by
              by_cases h : (τ i ω).isBot
