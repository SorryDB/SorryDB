                  simp [h]
                have h₁₂ : (τ i ω : WithTop ι) ≤ (j : WithTop ι) := h₈
                have h₁₃ : (τ i ω).unbot ≤ j := by
                  simpa [h₁₁] using h₁₂
                have h₁₄ : (X (τ i ω).unbot ω) = (X (τ i ω).unbot ω) := rfl
                have h₁₅ : |(X (τ i ω).unbot ω)| ≤ |(X j ω)| := by
                  -- Use the fact that X is a submartingale
