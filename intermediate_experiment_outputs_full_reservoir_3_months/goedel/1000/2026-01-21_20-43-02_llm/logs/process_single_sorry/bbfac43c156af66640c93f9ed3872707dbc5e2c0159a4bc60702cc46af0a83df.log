    have h₂ : UniformIntegrable (fun (i : ℕ) ↦ stoppedValue X (τ i)) 1 μ := by
      -- Use the fact that the stopped values are uniformly integrable if they are bounded by an integrable function
      have h₃ : ∀ i : ℕ, ∃ j : ι, ∀ᵐ (ω : Ω) ∂μ, |(stoppedValue X (τ i) ω)| ≤ |(X j ω)| := by
        intro i
        have h₄ : ∃ j : ι, ∀ ω : Ω, τ i ω ≤ up j := by
          use n
          intro ω
          have h₅ : (τ i ω : WithTop ι) ≤ (n : WithTop ι) := by
            exact hτ_le i ω
          exact by
            cases' τ i ω with ω ω <;> simp_all [WithTop.coe_le_coe, WithTop.bot_le]
            <;>
            (try { contradiction }) <;>
            (try { omega }) <;>
            (try {
              use n
              <;> simp_all [WithTop.coe_le_coe, WithTop.bot_le]
              <;> omega
            })
          <;>
          (try {
            use n
            <;> simp_all [WithTop.coe_le_coe, WithTop.bot_le]
            <;> omega
          })
        obtain ⟨j, hj⟩ := h₄
        use j
        have h₅ : ∀ᵐ (ω : Ω) ∂μ, |(stoppedValue X (τ i) ω)| ≤ |(X j ω)| := by
          have h₆ : ∀ (ω : Ω), (τ i ω : WithTop ι) ≤ (j : WithTop ι) := by
            intro ω
