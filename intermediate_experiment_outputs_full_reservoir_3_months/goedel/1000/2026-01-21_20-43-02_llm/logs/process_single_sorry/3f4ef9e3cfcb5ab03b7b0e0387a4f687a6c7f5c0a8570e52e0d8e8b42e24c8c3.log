      "\n  have h₁ : ∃ (⟨⟨⟨x, y, z⟩, hS⟩, hT⟩ : T k), trivialInvo k ⟨⟨⟨x, y, z⟩, hS⟩, hT⟩ = ⟨⟨⟨x, y, z⟩, hS⟩, hT⟩ := by\n    classical\n    by_contra! h\n    have h₂ : Fintype.card (T k) = 0 := by\n      have h₃ : Fintype.card (T k) = 0 := by\n        have h₄ : ∀ (a : T k), False := by\n          intro a\n          exact h a\n        have h₅ : Empty (T k) := by\n          take <;> exact h₄ ‹_›\n        exact Fintype.card_eq_zero_iff.mpr (by\n          exact isEmpty_iff.mpr h₅)\n      exact h₃\n    have h₃ : Fintype.card (U k) = 0 := by\n      have h₄ : Fintype.card (T k) = Fintype.card (U k) := by\n        simp [sameCard]\n      rw [h₄] at h₂\n      exact h₂\n    have h₅ : Fintype.card (U k) > 0 := by\n      have h₆ : Nonempty (U k) := by\n        use ⟨⟨(1, 1, 1), by\n          simp [S]\n          norm_num\n          <;>\n          (try decide) <;>\n          (try\n            {\n              have h₁ := hk.1\n              cases' h₁ with h₁ h₂\n              have h₃ : (4 : ℤ) * 1 * 1 + 1 ^ 2 = 5 := by norm_num\n              have h₄ : (5 : ℤ) = (4 : ℤ) * k + 1 := by\n                have h₅ : (4 : ℕ) * k + 1 = 5 := by\n                  have h₆ : Nat.Prime (4 * k + 1) := hk.1\n                  have h₇ : 4 * k + 1 = 5 := by\n                    norm_num at *\n                    <;>\n                    (try omega) <;>\n                    (try\n                      {\n                        have h₈ := h₆.eq_two_or_odd\n                        cases' h₈ with h₈ h₈ <;>\n                        omega\n                      })\n                    <;>\n                    omega\n                  omega\n                omega\n              omega\n            }) <;>\n          (try\n            {\n              nlinarith [hk.1.two_le]\n            })\n          <;>\n          omega\n        ⟩, by\n          simp [U]\n          <;>\n          (try decide) <;>\n          (try\n            {\n              have h₁ := hk.1\n              cases' h₁ with h₁ h₂\n           