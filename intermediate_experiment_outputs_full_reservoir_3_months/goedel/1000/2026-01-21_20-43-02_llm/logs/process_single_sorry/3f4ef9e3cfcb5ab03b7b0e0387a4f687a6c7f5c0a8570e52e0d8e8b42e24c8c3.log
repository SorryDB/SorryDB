theorem trivialInvo_fixedPoints : (fixedPoints (trivialInvo k)).Nonempty := by
  have h₁ : ∃ x : ℕ, 0 < x ∧ x ≤ k ∧ ∃ y z : ℕ, y ≤ k ∧ z ≤ k ∧ 4 * x * y + (z : ℤ)^2 = 4 * k + 1 := by sorry

  obtain ⟨x, hx₁, hx₂, y, z, hy₁, hz₁, h⟩ := h₁
  have h₂ : 0 < (x : ℤ) := by exact_mod_cast hx₁
  have h₃ : 0 < (y : ℤ) := by sorry
  have h₄ : 4 * (x : ℤ) * (y : ℤ) + (z : ℤ) ^ 2 = 4 * k + 1 := by sorry
  have h₅ : (x : ℤ) > 0 := by exact_mod_cast hx₁
  have h₆ : (y : ℤ) > 0 := by sorry
  have h₇ : (z : ℤ) ^ 2 = 4 * k + 1 - 4 * (x : ℤ) * (y : ℤ) := by sorry
  have h₈ : (z : ℤ) ^ 2 ≥ 0 := by sorry
  have h₉ : 4 * (x : ℤ) * (y : ℤ) ≤ 4 * k := by sorry
  have h₁₀ : 4 * k + 1 - 4 * (x : ℤ) * (y : ℤ) ≥ 1 := by sorry
  have h₁₁ : (z : ℤ) ≠ 0 := by sorry
  have h₁₂ : (z : ℤ) ^ 2 ≥ 1 := by sorry

  use ⟨⟨(x, y, 1), by sorry⟩, by sorry⟩
  <;> simp_all [trivialInvo, fixedPoints, Set.mem_setOf_eq]
  <;> norm_cast
  <;> aesop
```

