      "\n  have h₃ : (fixedPoints (trivialInvo k)).Nonempty :=\n    by\n      -- Use the fact that the cardinality of `T k` is odd and `trivialInvo` is an involution to deduce that there is a fixed point.\n      sorry\n    exact h₃",
