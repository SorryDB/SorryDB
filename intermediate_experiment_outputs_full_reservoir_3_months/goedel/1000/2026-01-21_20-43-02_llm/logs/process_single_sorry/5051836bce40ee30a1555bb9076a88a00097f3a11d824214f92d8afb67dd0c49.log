theorem offDiagonalHasLaw' (n : ℕ) {i j : Fin n} (h : i < j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  have h₁ : HasLaw (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) μ (WignerMeasure μ ν n) := by
    have h₂ : (WignerMeasure μ ν n) = Measure.pi (wignerMeasureDist μ ν n) := rfl
    rw [h₂]
    have h₃ : HasProdLaw (Measure.pi (wignerMeasureDist μ ν n))
      (wignerMeasureDist μ ν n ⟨(i, j), h⟩) (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩)
      (Pi.measurableSpace _)
      (Pi.val ⊥ (⟨(i, j), h⟩ : Index n)) := by
      apply MeasureTheory.hasProdLaw_pi_eval
    have h₄ : (wignerMeasureDist μ ν n ⟨(i, j), h⟩) = μ := by
      -- (i, j) with i < j means (i, j).1 ≠ (i, j).2
      have h₅ : (⟨(i, j), h⟩: Index n).val.1 ≠ (⟨(i, j), h⟩ : Index n).val.2 := by
        simp [h] at *
        <;> omega
      simp [wignerMeasureDist, h₅]
      <;> aesop
    rw [h₄] at h₃
    have h₅ : HasProdLaw (Measure.pi (wignerMeasureDist μ ν n)) μ (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) (Pi.measurableSpace _) (Pi.val ⊥ (⟨(i, j), h⟩ : Index n)) := by
      simpa using h₃
    have h₆ : HasLaw (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) μ (Measure.pi (wignerMeasureDist μ ν n)) := by
      -- Use the fact that the product measure has law μ for each component
      have h₇ : (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) = (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) := rfl
      rw [h₇]
      -- Use the fact that the product measure has law μ for each component
      have h₈ : HasProdLaw (Measure.pi (wignerMeasureDist μ ν n)) μ (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) (Pi.measurableSpace _) (Pi.val ⊥ (⟨(i, j), h⟩ : Index n)) := by
        simpa using h₅
      -- Use the fact that the product measure has law μ for each component
      have h₉ : HasLaw (fun (ω : WignerSpace n) => ω ⟨(i, j), h⟩) μ (Measure.pi (wignerMeasureDist μ ν n)) := by
