```lean
lemma offDiagonalHasLaw' (n : ℕ) {i j : Fin n} (h : i < j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  have h₁ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
    classical
    -- Use the fact that the measure is product and the entries are independent
    have h₂ : HasLaw (fun ω ↦ ω ⟨(i, j), h.le⟩) μ (WignerMeasure μ ν n) := by
      -- The entry (i,j) in WignerSpace is distributed according to μ
      have h₃ : wignerMeasureDist μ ν n ⟨(i, j), h.le⟩ = μ := by
        simp [wignerMeasureDist, h.ne']
        <;>
        (try decide) <;>
        (try aesop)
      -- Use the product measure property
      have h₄ : HasLaw (fun ω ↦ ω ⟨(i, j), h.le⟩) (wignerMeasureDist μ ν n ⟨(i, j), h.le⟩) (WignerMeasure μ ν n) := by
        apply Measure.pi_hasLaw
        <;> simp [wignerMeasureDist]
      -- Substitute the measure
      rw [h₃] at h₄
      exact h₄
    -- The (i,j)-th entry of the matrix is the same as ω ⟨(i,j), h.le⟩
    have h₅ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω ⟨(i, j), h.le⟩) := by
      funext ω
      simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]
      <;> split_ifs <;> simp_all [Fin.ext_iff, Fin.val_mk]
      <;>
      (try contradiction) <;>
      (try omega) <;>
      (try aesop)
    rw [h₅]
    exact h₂
  exact h₁
```
