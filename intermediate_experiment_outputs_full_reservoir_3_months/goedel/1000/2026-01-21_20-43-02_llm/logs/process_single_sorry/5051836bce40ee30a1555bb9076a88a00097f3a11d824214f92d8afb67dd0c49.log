lemma offDiagonalHasLaw' (n : ℕ) {i j : Fin n} (h : i < j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  have h₁ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), by exact le_of_lt h⟩) μ (WignerMeasure μ ν n) := by
    -- The law of the coordinate projection is μ
    have h₂ : wignerMeasureDist μ ν n ⟨(i, j), by exact le_of_lt h⟩ = μ := by
      simp [wignerMeasureDist, h, Fin.ext_iff, Fin.val_mk]
      <;>
      (try omega) <;>
      (try aesop)
    -- Use the fact that the coordinate has measure μ
    have h₃ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), by exact le_of_lt h⟩) (wignerMeasureDist μ ν n ⟨(i, j), by exact le_of_lt h⟩) (WignerMeasure μ ν n) := by
      apply MeasureTheory.hasLaw_pi
    -- Substitute h₂ into h₃
    rw [h₂] at h₃
    exact h₃
  -- Show that (wignerMatrixMap n ω) i j is equal to ω ⟨(i,j), h⟩
  have h₄ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n => ω ⟨(i, j), by exact le_of_lt h⟩) := by
    funext ω
    rw [wignerMatrixMap]
    rw [wignerMatrixMap']
    simp [wignerMatrixEntryFunction, h, le_of_lt]
    <;>
    (try simp_all [Fin.ext_iff]) <;>
    (try aesop)
    <;>
    (try omega)
  -- Use h₄ to transfer the law from h₁ to the desired function
  rw [h₄]
  exact h₁
