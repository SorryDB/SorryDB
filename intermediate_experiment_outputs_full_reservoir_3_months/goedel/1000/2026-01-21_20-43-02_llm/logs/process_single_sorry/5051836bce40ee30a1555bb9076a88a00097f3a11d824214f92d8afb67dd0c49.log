instance (n : ℕ) : IsProbabilityMeasure (wignerMatrixMeasure n μ ν) := by
  rw [wignerMatrixMeasure]
  -- The measure is given by the pushforward of `WignerMeasure` by `wignerMatrixMap`.
  -- Since `WignerMeasure` is a probability measure and `wignerMatrixMap` is measurable,
  -- its pushforward is also a probability measure.
  apply MeasureTheory.Measure.map_prob

