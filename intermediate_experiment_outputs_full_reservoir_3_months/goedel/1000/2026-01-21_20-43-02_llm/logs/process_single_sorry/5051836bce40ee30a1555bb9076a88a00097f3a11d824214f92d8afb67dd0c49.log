      exfalso
      simp_all [Fin.ext_iff]
      <;> omega
    }) <;>
    (try {
      have h₁ : i = j := by
        have h₁ := Fin.ext_iff.1 (by assumption)
        omega
      simp_all [Fin.ext_iff]
