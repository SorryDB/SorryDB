ap', wignerMatrixEntryFunction]\n    <;> simp_all [Fin.ext_iff, h]\n    <;> try { contradiction }\n    <;> try { omega }\n    <;> aesop\n  rw [h₂]\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω => ω ⟨(i, j), by\n    have h₂ : i < j := h\n    exact le_of_lt h₂⟩):= by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    (try { contradiction }) <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;> omega\n    }) <;>\n    (try {\n      split_ifs <;>\n      (try { contradiction }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> omega\n      })\n    })\n    <;>\n    (try {\n      exfalso\n      have h₃ : ¬(i < j) := by\n        intro h₄\n        have h₅ : j < i := by omega\n        omega\n      exact h₃ h\n    })\n    <;>\n    (try {\n      exfalso\n      have h₃ : ¬(i = j) := by\n        intro h₄\n        have h₅ : i < j := h\n        omega\n      exact h₃ (by simp_all [Fin.ext_iff])\n    })\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;> omega\n    })\n  rw [h₁]\n  have h₂ : (WignerMeasure μ ν n) = (Measure.pi (wignerMeasureDist μ ν n)) := rfl\n  rw [h₂]\n  have h₃ : ∃ (f : Index n → ℝ → ℝ), (∀ (x : Index n), HasFun (f x)) ∧ (fun ω => ω ⟨(i, j), by\n    have h₄ : i < j := h\n    exact le_of_lt h₄⟩) = (fun x => f x ⟨(i, j), by\n    have h₄ : i < j := h\n    exact le_of_lt h₄⟩) := by\n    use fun x ω => ω\n    constructor\n    · intro x\n      exact by\n        simpa [HasFun] using hasFun_id\n    · rfl\n  obtain ⟨f, hf, hf'⟩ := h₃\n  rw [hf']\n  have h₄ : HasFun (fun x => f x ⟨(i, j), by\n    have h₅ : i < j := h\n    exact le_of_lt h₅⟩) := by\n    simpa [hf.1 _] using hf.1 _\n  have h₅ : (Measure.pi (wignerMeasureDist μ ν n)) = (Measure.pi (wignerMeasureDist μ ν n)) := rfl\n  rw [h₅]\n  have h₆ : (fun x => f x ⟨(i, j), by\n    have h₇ : i < j := h\n    exact le_of_lt h₇⟩) = (fun x => f x ⟨(i, j), by\n    have h₇ : i < j := h\n    exact le_of_lt h₇⟩) := rfl\n  rw [h₆]\n  -- Now, we need to show that the function (fun x => f x ⟨(i, j), _⟩) has the distribution μ under the product measure.\n  -- This follows from the fact that the coordinate functions are independent and the corresponding factor is μ.\n  have h₇ : (Measure.pi (wignerMeasureDist μ ν n)) = (Measure.pi (wignerMeasureDist μ ν n)) := rfl\n  rw [h₇]\n  -- Use the property of the product measure to get the desired distribution.\n  have h₈ : (wignerMeasureDist μ ν n ⟨(i, j), by\n    have h₉ : i < j := h\n    exact le_of_lt h₉⟩) = μ := by\n    simp [wignerMeasureDist]\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      (try {\n        aesop\n      })\n    })\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      (try {\n        omega\n      })\n    })\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      (try {\n        norm_num\n      })\n    })\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      (try {\n        simp_all [Fin.ext_iff]\n      })\n    })\n  -- Now, we can use the fact that the product measure has the desired property.\n  have h₉ : HasFun (fun x => f x ⟨(i, j), by\n    have h₁₀ : i < j := h\n    exact le_of_lt h₁₀⟩) := h₄\n  have h₁₀ : (Measure.pi (wignerMeasureDist μ ν n)) = (Measure.pi (wignerMeasureDist μ ν n)) := rfl\n  rw [h₁₀]\n  -- Use the fact that the product measure has the desired property.\n  have h₁₁ : HasLaw (fun x => f x ⟨(i, j), by\n    have h₁₂ : i < j := h\n    exact le_of_lt h₁₂⟩) μ (Measure.pi (wignerMeasureDist μ ν n)) := by\n    have h₁₂ : (wignerMeasureDist μ ν n ⟨(i, j), by\n      have h₁₃ : i < j := h\n      exact le_of_lt h₁₃⟩) = μ := h₈\n    -- Use the property of the product measure to get the desired distribution.\n    have h₁₃ : HasLaw (fun x => f x ⟨(i, j), by\n      have h₁₄ : i < j := h\n      exact le_of_lt h₁₄⟩) μ (Measure.pi (wignerMeasureDist μ ν n)) := by\n      apply ProbabilityTheory.hasFun_iff_hasLaw.mpr\n      simp [h₁₂]\n      <;>\n      (try {\n        aesop\n      })\n      <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;>\n        (try {\n          aesop\n        })\n      })\n      <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;>\n        (try {\n          omega\n        })\n      })\n    exact h₁₃\n  exact h₁₁",
      "\n  have h₀ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    sorry\n  exact h₀",
