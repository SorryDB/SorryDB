      "\n  have h₁ : HasLaw (fun (ω : WignerSpace n) => (wignerMatrixMap n ω) i j) (wignerMeasureDist μ ν n (⟨(i, j), le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n    have h₁₁ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n => ω (⟨(i, j), le_of_lt h⟩ : Index n)) := by\n      funext ω\n      -- Prove that accessing the (i,j)-th entry of the matrix is the same as directly accessing the (i,j)-th entry in the WignerSpace\n      simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n      <;>\n      simp_all [Fin.ext_iff, le_of_lt]\n      <;>\n      (try { aesop }) <;>\n      (try { cases i <;> cases j <;> simp_all (config := {decide := true}) }) <;>\n      (try { omega })\n      <;>\n      (try {\n        by_cases h₂ : i = j <;> simp_all [h₂] <;>\n        (try { aesop }) <;>\n        (try { omega })\n      })\n      <;>\n      (try {\n        by_cases h₂ : i < j <;> simp_all [h₂] <;>\n        (try { aesop }) <;>\n        (try { omega })\n      })\n      <;>\n      (try {\n        by_cases h₂ : j < i <;> simp_all [h₂] <;>\n        (try { aesop }) <;>\n        (try { omega })\n      })\n      <;>\n      simp_all [Fin.ext_iff, le_of_lt]\n      <;>\n      (try { aesop }) <;>\n      (try { omega })\n    rw [h₁₁]\n    -- Use the fact that the measure is a product measure to get the law of the projection\n    have h₁₂ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, j), le_of_lt h⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n      have h₁₃ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, j), le_of_lt h⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n        -- Use the property of product measures to get the law of the projection\n        have h₁₄ : (WignerMeasure μ ν n) = Measure.pi (wignerMeasureDist μ ν n) := by rfl\n        rw [h₁₄]\n        apply MeasureTheory.hasLaw_measure_discrete_fst\n      exact h₁₃\n    exact h₁₂\n  have h₂ : (wignerMeasureDist μ ν n (⟨(i, j), le_of_lt h⟩ : Index n)) = μ := by\n    simp [wignerMeasureDist, Index]\n    <;>\n    simp_all [Fin.ext_iff]\n    <;>\n    (try {\n      norm_num at *\n      <;>\n      simp_all [Fin.ext_iff]\n      <;>\n      omega\n    })\n  rw [h₂] at h₁\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (wigramap (i,j)) := by\n    ext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    (try cases le_total i j <;> simp_all [lt_irrefl, lt_asymm]) <;>\n    (try {\n      have h₂ : i < j := by assumption\n      simp_all [h₂, le_of_lt]\n      <;>\n      (try contradiction) <;>\n      (try simp_all [Fin.ext_iff]) <;>\n      (try omega)\n    }) <;>\n    (try {\n      have h₂ : j < i := by\n        cases lt_or_gt_of_ne (by intro h₃; simp_all [Fin.ext_iff]) <;> simp_all [lt_irrefl, lt_asymm]\n        <;> omega\n      simp_all [h₂, le_of_lt]\n      <;>\n      (try contradiction) <;>\n      (try simp_all [Fin.ext_iff]) <;>\n      (try omega)\n    }) <;>\n    (try {\n      have h₂ : i = j := by\n        cases lt_or_gt_of_ne (by intro h₃; simp_all [Fin.ext_iff]) <;> simp_all [lt_irrefl, lt_asymm]\n        <;> omega\n      simp_all [h₂, le_of_lt]\n      <;>\n      (try contradiction) <;>\n      (try simp_all [Fin.ext_iff]) <;>\n      (try omega)\n    })\n\n  have h₂ : HasLaw (wigramap (i,j)) μ (WignerMeasure μ ν n) := by\n    have h₃ : (i,j) : Fin n × Fin n := by exact (i,j)\n    have h₄ : (i : ℕ) < n := Fin.val_mk i\n    have h₅ : (j : ℕ) < n := Fin.val_mk j\n    have h₆ : i < j := h\n    have h₇ : ¬(i = j) := by\n      intro h₇\n      rw [h₇] at h₆\n      exact lt_irrefl j h₆\n    have h₈ : (i,j) ∈ {p : Fin n × Fin n | p.1 < p.2} := by\n      simp_all [Prod.lt_iff]\n      <;> omega\n    -- Now we need to show that the law of wigramap (i,j) is μ.\n    -- This is by definition of the product measure and the way we constructed the Wigner measure.\n    -- We use the fact that the Wigner measure is constructed as a product of μ and ν.\n    -- Since (i,j) is in the upper triangular part, the law is μ.\n    have h₉ : HasLaw (wigramap (i,j)) μ (WignerMeasure μ ν n) := by\n      apply hasLaw_ofSusp\n      <;>\n      (try simp_all [wignerMeasureDist, WignerMeasure, MeasurableSpace, is_open_Iio, Real.instBorel,\n        Real.mem_Iio]) <;>\n      (try aesop) <;>\n      (try simp_all [h₈]) <;>\n      (try {\n        have h₁₀ : i < j := h\n        have h₁₁ : (i : ℕ) < (j : ℕ) := by exact_mod_cast h₁₀\n        simp_all [h₁₁]\n        <;>\n        aesop\n      }) <;>\n      (try {\n        have h₁₀ : i < j := h\n        have h₁₁ : (i : ℕ) < (j : ℕ) := by exact_mod_cast h₁₀\n        simp_all [h₁₁]\n        <;>\n        aesop\n      }) <;>\n      (try {\n        simp_all [h₈]\n        <;>\n        aesop\n      })\n    exact h₉\n\n  rw [h₁]\n  exact h₂",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω ⟨(i,j), by exact le_of_lt h⟩) := by\n    sorry\n  rw [h₁]\n  have h₂ : HasLaw (fun ω : (Index n → ℝ) ↦ ω ⟨(i, j), by exact le_of_lt h⟩) μ (WignerMeasure μ ν n) := by\n    sorry\n  exact h₂",
      "\n  have h₁ : HasLaw (fun ω : WignerSpace n => wignerMatrixMap n ω i j) μ (WignerMeasure μ ν n) := by\n    have h₂ : HasLaw (fun ω : WignerSpace n => wignerMatrixEntryFunction ω i j) μ (WignerMeasure μ ν n) := by\n      classical\n      -- We need to prove that the function extracting the (i,j)-th entry of the matrix follows the measure μ\n      -- This involves using the fact that the entries are independent and that the (i,j)-th entry is determined by the random variable associated to the pair (i,j)\n      -- Since i < j, the pair (i,j) is in the Index set, and the measure is μ\n      have h₃ : (⟨(i, j), by exact le_of_lt h⟩ : Index n) = ⟨(i, j), by exact le_of_lt h⟩ := rfl\n      -- Use the product measure to find the law of the (i,j)-th entry\n      have h₄ : HasLaw (fun ω : Index n → ℝ => ω ⟨(i, j), by exact le_of_lt h⟩) (wignerMeasureDist μ ν n ⟨(i, j), by exact le_of_lt h⟩) (WignerMeasure μ ν n) := by\n        apply MeasureTheory.pi_hasLaw (Finset.univ : Finset (Index n))\n        <;> simp_all [wignerMeasureDist]\n        <;> aesop\n      -- Since i < j, the pair (i,j) is in the Index set and wignerMeasureDist returns μ\n      have h₅ : wignerMeasureDist μ ν n ⟨(i, j), by exact le_of_lt h⟩ = μ := by\n        simp [wignerMeasureDist]\n        <;> simp_all [ne_eq, not_le]\n        <;> omega\n      -- Therefore, the law of the (i,j)-th entry is μ\n      rw [h₅] at h₄\n      have h₆ : (fun ω : Index n → ℝ => ω ⟨(i, j), by exact le_of_lt h⟩) = (fun ω : WignerSpace n => ω ⟨(i, j), by exact le_of_lt h⟩) := by rfl\n      rw [h₆] at h₄\n      -- Convert the WignerSpace to the function space\n      have h₇ : (fun ω : WignerSpace n => ω ⟨(i, j), by exact le_of_lt h⟩) = (fun ω : WignerSpace n => wignerMatrixEntryFunction ω i j) := by\n        ext ω\n        simp [wignerMatrixEntryFunction]\n        <;> split_ifs <;> simp_all [*, Fin.ext_iff, le_of_lt]\n        <;> try { contradiction }\n        <;> try { aesop }\n      rw [h₇] at h₄\n      exact h₄\n    -- Use the fact that the wigner matrix map and the entry function are related\n    have h₈ : (fun ω : WignerSpace n => wignerMatrixMap n ω i j) = (fun ω : WignerSpace n => wignerMatrixEntryFunction ω i j) := by\n      ext ω\n      simp [wignerMatrixMap', wignerMatrixEntryFunction]\n      <;> split_ifs <;> simp_all [*, Fin.ext_iff, le_of_lt]\n      <;> try { contradiction }\n      <;> try { aesop }\n    rw [h₈]\n    exact h₂\n  exact h₁",
      "\n  have h₁ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    have h₂ : HasLaw (fun ω : WignerSpace n ↦ (if h_eq : (i : ℕ) = (j : ℕ) then ω ⟨(i, i), le_refl i⟩ else if h_lt : (i : ℕ) < (j : ℕ) then ω ⟨(i, j), h_lt⟩ else ω ⟨(j, i), by\n      have h_gt : (j : ℕ) < (i : ℕ) := by\n        omega\n      exact h_gt⟩)) (if (i : ℕ) = (j : ℕ) then ν else if (i : ℕ) < (j : ℕ) then μ else μ) (WignerMeasure μ ν n) := by\n      have h₃ : (i : ℕ) < (j : ℕ) := by exact_mod_cast h\n      have h₄ : (i : ℕ) ≠ (j : ℕ) := by linarith\n      have h₅ : ¬(i : ℕ) = (j : ℕ) := by simp_all\n      have h₆ : (i : ℕ) < (j : ℕ) := by simp_all\n      have h₇ : (if h_eq : (i : ℕ) = (j : ℕ) then ν else if (i : ℕ) < (j : ℕ) then μ else μ) = μ := by\n        simp [h₅, h₆]\n      rw [h₇]\n      -- The law of the (i, j)-th entry is μ when i < j\n      have h₈ : HasLaw (fun ω : WignerSpace n ↦ (if h_eq : (i : ℕ) = (j : ℕ) then ω ⟨(i, i), le_refl i⟩ else if h_lt : (i : ℕ) < (j : ℕ) then ω ⟨(i, j), h_lt⟩ else ω ⟨(j, i), by\n        have h_gt : (j : ℕ) < (i : ℕ) := by\n          omega\n        exact h_gt⟩)) μ (WignerMeasure μ ν n) := by\n        -- Use the fact that the entries are independent and follow the given distributions\n        have h₉ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), h₃⟩) μ (WignerMeasure μ ν n) := by\n          -- The (i, j)-th entry follows the distribution μ\n          have h₁₀ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, j), h₃⟩) (wignerMeasureDist μ ν n ⟨(i, j), h₃⟩) (WignerMeasure μ ν n) := by\n            apply Measure.pi.measurable_space.fst.1.hasLaw_pi_dirichlet _ _\n          have h₁₁ : (wignerMeasureDist μ ν n ⟨(i, j), h₃⟩) = μ := by\n            -- Since i < j, the distribution is μ\n            simp [wignerMeasureDist]\n            <;> simp_all [Fin.ext_iff]\n            <;> omega\n          rw [h₁₁] at h₁₀\n          exact h₁₀\n        have h₁₂ : (fun ω : WignerSpace n ↦ (if h_eq : (i : ℕ) = (j : ℕ) then ω ⟨(i, i), le_refl i⟩ else if h_lt : (i : ℕ) < (j : ℕ) then ω ⟨(i, j), h_lt⟩ else ω ⟨(j, i), by\n          have h_gt : (j : ℕ) < (i : ℕ) := by\n            omega\n          exact h_gt⟩)) = (fun ω : WignerSpace n ↦ ω ⟨(i, j), h₃⟩) := by\n          funext ω\n          simp [h₅, h₆]\n          <;> aesop\n        rw [h₁₂]\n        exact h₉\n      exact h₈\n    have h₉ : (fun ω : WignerSpace n ↦ (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n ↦ (if h_eq : (i : ℕ) = (j : ℕ) then ω ⟨(i, i), le_refl i⟩ else if h_lt : (i : ℕ) < (j : ℕ) then ω ⟨(i, j), h_lt⟩ else ω ⟨(j, i), by\n      have h_gt : (j : ℕ) < (i : ℕ) := by\n        omega\n      exact h_gt⟩)) := by\n      funext ω\n      simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n      <;> split_ifs <;> simp_all [Fin.ext_iff]\n      <;> try { contradiction }\n      <;> try { omega }\n      <;> try { aesop }\n    rw [h₉] at *\n    simp_all [h]\n    <;>\n    (try { contradiction }) <;>\n    (try { omega }) <;>\n    (try { aesop })\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω (⟨(i, j), le_of_lt h⟩)) := by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n      (try { simp_all [Fin.ext_iff, Fin.val_mk] }) <;>\n      (try { split_ifs <;> simp_all [Fin.ext_iff, Fin.val_mk] <;>\n        (try { omega }) <;>\n        (try { aesop }) }) <;>\n      (try {\n        have h₂ : i < j := h\n        have h₃ : ¬(i > j) := by omega\n        simp_all [Fin.ext_iff, Fin.val_mk] <;>\n          (try { omega }) <;>\n          (try { aesop })\n      })\n  rw [h₁]\n  have h₂ : HasLaw (fun ω : Index n → ℝ => ω (⟨(i, j), le_of_lt h⟩)) μ (WignerMeasure μ ν n) := by\n    -- Use the fact that the projection to each coordinate has the corresponding measure\n    have h₃ : (wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩) = μ := by\n      dsimp [wignerMeasureDist]\n      split_ifs <;> simp_all [Fin.ext_iff, Fin.val_mk]\n      <;>\n        (try { omega }) <;>\n        (try { aesop }) <;>\n        (try {\n          have h₄ : i < j := h\n          have h₅ : i ≠ j := by intro h₆; omega\n          simp_all [Fin.ext_iff, Fin.val_mk] <;>\n            (try { omega }) <;>\n            (try { aesop })\n        })\n    -- Use the product measure property to get the law of the projection\n    have h₄ : HasLaw (fun ω : Index n → ℝ => ω (⟨(i, j), le_of_lt h⟩)) (wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩) (WignerMeasure μ ν n) := by\n      apply MeasureTheory.hasLaw_pi_left _ _ _\n    rw [h₃] at h₄\n    exact h₄\n  exact h₂",
      "\n  have h₁ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    classical\n    -- Use the fact that the measure is product and the entries are independent\n    have h₂ : HasLaw (fun ω ↦ ω ⟨(i, j), h.le⟩) μ (WignerMeasure μ ν n) := by\n      -- The entry (i,j) in WignerSpace is distributed according to μ\n      have h₃ : wignerMeasureDist μ ν n ⟨(i, j), h.le⟩ = μ := by\n        simp [wignerMeasureDist, h.ne']\n        <;>\n        (try decide) <;>\n        (try aesop)\n      -- Use the product measure property\n      have h₄ : HasLaw (fun ω ↦ ω ⟨(i, j), h.le⟩) (wignerMeasureDist μ ν n ⟨(i, j), h.le⟩) (WignerMeasure μ ν n) := by\n        apply Measure.pi_hasLaw\n        <;> simp [wignerMeasureDist]\n      -- Substitute the measure\n      rw [h₃] at h₄\n      exact h₄\n    -- The (i,j)-th entry of the matrix is the same as ω ⟨(i,j), h.le⟩\n    have h₅ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω ⟨(i, j), h.le⟩) := by\n      funext ω\n      simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n      <;> split_ifs <;> simp_all [Fin.ext_iff, Fin.val_mk]\n      <;>\n      (try contradiction) <;>\n      (try omega) <;>\n      (try aesop)\n    rw [h₅]\n    exact h₂\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (ω ⟨(min i j, max i j), by\n    have h₂ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n      apply le_total\n    exact h₂⟩)) := by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, h, Fin.ext_iff,\n      min_eq_left, max_eq_right, le_of_lt]\n    <;>\n    (try cases' le_total i j with h₃ h₃ <;> simp_all [min_eq_left, max_eq_right, h₃]) <;>\n    (try omega) <;>\n    (try aesop)\n    <;>\n    (try ring_nf at * <;> simp_all)\n    <;>\n    (try\n      {\n        simp_all [Fin.ext_iff]\n        <;>\n        omega\n      })\n    <;>\n    (try\n      {\n        simp_all [Fin.ext_iff]\n        <;>\n        omega\n      })\n    <;>\n    (try\n      {\n        simp_all [Fin.ext_iff]\n        <;>\n        omega\n      })\n    <;>\n    (try\n      {\n        simp_all [Fin.ext_iff]\n        <;>\n        omega\n      })\n  \n  rw [h₁]\n  have h₂ : HasLaw (fun ω : WignerSpace n => ω ⟨(min i j, max i j), by\n    have h₃ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n      apply le_total\n    exact h₃⟩) μ (WignerMeasure μ ν n) := by\n    -- Use the product measure properties to extract the law of the specific entry\n    have h₃ : (⟨(min i j, max i j), by\n      have h₄ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n        apply le_total\n      exact h₄⟩ : Index n) ∈ (Set.univ : Set (Index n)) := by simp\n    -- Since the product measure is built from the independent measures on each entry, we can extract the law of each entry\n    have h₄ : HasLaw (fun ω : WignerSpace n => ω ⟨(min i j, max i j), by\n      have h₅ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n        apply le_total\n      exact h₅⟩) (wignerMeasureDist μ ν n ⟨(min i j, max i j), by\n      have h₅ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n        apply le_total\n      exact h₅⟩) (WignerMeasure μ ν n) := by\n      -- Use the fact that the product measure gives the correct law to each entry\n      apply Measure.pi.hasLaw_of_coordinate\n      <;> simp [wignerMeasureDist]\n      <;> aesop\n    -- Simplify the law to μ since the entry is off-diagonal\n    have h₅ : (wignerMeasureDist μ ν n ⟨(min i j, max i j), by\n      have h₆ : (min i j : Fin n) ≤ (max i j : Fin n) := by\n        apply le_total\n      exact h₆⟩) = μ := by\n      simp [wignerMeasureDist]\n      <;>\n      (try\n        {\n          cases' lt_or_gt_of_ne (show (i : ℕ) ≠ (j : ℕ) by\n            intro h₆\n            simp_all [Fin.ext_iff]\n            <;> omega) with h₆ h₆ <;>\n          simp_all [min_eq_left, max_eq_right, h₆] <;>\n          (try omega) <;>\n          (try aesop)\n        }) <;>\n      (try\n        {\n          simp_all [min_eq_left, max_eq_right]\n          <;>\n          (try omega)\n          <;>\n          (try aesop)\n        })\n      <;>\n      (try\n        {\n          simp_all [Fin.ext_iff]\n          <;>\n          omega\n        })\n      <;>\n      (try\n        {\n          simp_all [Fin.ext_iff]\n          <;>\n          omega\n        })\n    rw [h₅] at h₄\n    exact h₄\n  exact h₂",
      "\n  have h₁ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    -- Step 1: Understand the structure of `wignerMatrixMap` and how it relates to `WignerMeasure`.\n    have h₂ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n => if i = j then ω ⟨(i, i), le_refl i⟩ else if i < j then ω ⟨(i, j), le_of_lt h⟩ else ω ⟨(j, i), le_of_lt (by omega)⟩) := by\n      ext ω\n      simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n      <;> by_cases h₃ : i = j <;> by_cases h₄ : i < j <;> simp_all [h₃, h₄] <;>\n        (try omega) <;>\n        (try { contradiction }) <;>\n        (try {\n          cases' lt_or_le i j with h₅ h₅ <;>\n          simp_all [h₅] <;>\n          (try omega)\n        }) <;>\n        (try {\n          have h₅ : j < i := by omega\n          simp_all [h₅]\n        })\n      <;>\n      (try omega)\n    rw [h₂]\n    -- Step 2: Since `i < j`, the expression simplifies to `ω ⟨(i, j), le_of_lt h⟩`.\n    have h₃ : (fun ω : WignerSpace n => if i = j then ω ⟨(i, i), le_refl i⟩ else if i < j then ω ⟨(i, j), le_of_lt h⟩ else ω ⟨(j, i), le_of_lt (by omega)⟩) = (fun ω : WignerSpace n => ω ⟨(i, j), le_of_lt h⟩) := by\n      funext ω\n      have h₄ : ¬(i = j) := by\n        intro h₅\n        have h₆ : i < j := h\n        have h₇ : i = j := h₅\n        omega\n      simp [h₄, h]\n      <;>\n      (try { contradiction }) <;>\n      (try omega)\n    rw [h₃]\n    -- Step 3: Use the fact that `WignerMeasure` is constructed using `pi` and `wignerMeasureDist`.\n    -- The measure on `WignerSpace n` is a product of measures, and each coordinate is independent.\n    -- Specifically, the measure on the coordinate `⟨(i, j), le_of_lt h⟩` is `μ`.\n    have h₄ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), le_of_lt h⟩) μ (WignerMeasure μ ν n) := by\n      -- Step 4: Use the property of product measures to extract the law of a single coordinate.\n      have h₅ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), le_of_lt h⟩) (wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩) (WignerMeasure μ ν n) := by\n        -- Step 5: Use the fact that the measure on `WignerSpace n` is the product measure.\n        apply Measure.map_snd _\n        <;>\n        (try simp [WignerMeasure, wignerMeasureDist]) <;>\n        (try simp_all [Product])\n        <;>\n        (try\n          {\n            exact inferInstance\n          })\n      -- Step 6: Simplify `wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩` to `μ`.\n      have h₆ : wignerMeasureDist μ ν n ⟨(i, j), le_of_lt h⟩ = μ := by\n        simp [wignerMeasureDist]\n        <;>\n        (try simp_all [h]) <;>\n        (try\n          {\n            have h₇ : i ≠ j := by\n              intro h₈\n              have h₉ : i < j := h\n              omega\n            simp_all [h₇]\n          })\n        <;>\n        (try\n          {\n            simp_all [ne_eq, not_false_iff]\n          })\n        <;>\n        (try omega)\n      rw [h₆] at h₅\n      exact h₅\n    exact h₄\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω ⟨(i, j), h.le⟩) := by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    (try cases i <;> cases j <;> simp_all [Fin.ext_iff]) <;>\n    (try { contradiction }) <;>\n    (try { aesop }) <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;> omega\n    }) <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;> aesop\n    }) <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;> omega\n    })\n  rw [h₁]\n  have h₂ : (fun ω : WignerSpace n => ω ⟨(i, j), h.le⟩) ∘ (fun ω : WignerSpace n => ω) = (fun ω : WignerSpace n => ω ⟨(i, j), h.le⟩) := by\n    funext\n    simp [Function.comp]\n  -- Use the fact that the measure is a product measure to get the desired law\n  have h₃ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), h.le⟩) μ (WignerMeasure μ ν n) := by\n    have h₄ : (WignerMeasure μ ν n : Measure (WignerSpace n)) = (Measure.pi (wignerMeasureDist μ ν n)) := rfl\n    rw [h₄]\n    have h₅ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, j), h.le⟩) (wignerMeasureDist μ ν n ⟨(i, j), h.le⟩) (Measure.pi (wignerMeasureDist μ ν n)) := by\n      apply MeasureTheory.hasLaw_pi\n      <;> simp [wignerMeasureDist]\n      <;>\n      (try cases i <;> cases j <;> simp_all [Fin.ext_iff]) <;>\n      (try { contradiction }) <;>\n      (try { aesop }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> omega\n      }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> aesop\n      }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> omega\n      })\n    have h₆ : wignerMeasureDist μ ν n ⟨(i, j), h.le⟩ = μ := by\n      simp [wignerMeasureDist]\n      <;>\n      (try cases i <;> cases j <;> simp_all [Fin.ext_iff]) <;>\n      (try { contradiction }) <;>\n      (try { aesop }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> omega\n      }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> aesop\n      }) <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;> omega\n      })\n    rw [h₆] at h₅\n    exact h₅\n  simpa [Function.comp] using h₃",
      "\n  have h₁ : HasLaw (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by\n    have h₂ : (fun ω : WignerSpace n => (wignerMatrixMap n ω) i j) = (fun ω : WignerSpace n => ω (⟨(i, j), h.le⟩)) := by\n      funext ω\n      rw [show (wignerMatrixMap n ω) i j = wignerMatrixEntryFunction ω i j by\n        simp [wignerMatrixMap, wignerMatrixMap']]\n      rw [wignerMatrixEntryFunction]\n      split_ifs <;> simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk, Fin.val_mk, Fin.val_mk] <;>\n        (try omega) <;>\n        (try {\n          exfalso\n          have h₃ : (i : ℕ) < (j : ℕ) := by simpa using h\n          omega\n        }) <;>\n        (try {\n          exfalso\n          have h₃ : (i : ℕ) < (j : ℕ) := by simpa using h\n          omega\n        }) <;>\n        (try {\n          simp_all [wignerMatrixEntryFunction]\n          <;>\n          simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk, Fin.val_mk, Fin.val_mk]\n          <;>\n          omega\n        })\n      <;>\n      (try {\n        simp_all [wignerMatrixEntryFunction]\n        <;>\n        simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk, Fin.val_mk, Fin.val_mk]\n        <;>\n        omega\n      })\n      <;>\n      (try {\n        simp_all [wignerMatrixEntryFunction]\n        <;>\n        simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk, Fin.val_mk, Fin.val_mk]\n        <;>\n        omega\n      })\n    rw [h₂]\n    have h₃ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, j), h.le⟩)) μ (WignerMeasure μ ν n) := by\n      have h₄ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, j), h.le⟩)) (wignerMeasureDist μ ν n ⟨(i, j), h.le⟩) (WignerMeasure μ ν n) := by\n        have h₅ : Measurable (fun ω : WignerSpace n => ω (⟨(i, j), h.le⟩)) := by\n          -- Prove that the function is measurable\n          apply measurable_fst.comp\n          exact measurable_subtype_val\n        -- Use the main theorem for product measures\n        exact (hasLaw_fst.comp _ _ _ _)\n      -- Simplify the measure using the definition\n      have h₆ : wignerMeasureDist μ ν n ⟨(i, j), h.le⟩ = μ := by\n        dsimp [wignerMeasureDist]\n        split_ifs <;>\n        (try {\n          simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk]\n          <;>\n          omega\n        }) <;>\n        (try {\n          simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk]\n          <;>\n          omega\n        })\n        <;>\n        (try {\n          simp_all [Fin.ext_iff, Fin.val_mk, Fin.val_mk]\n          <;>\n          omega\n        })\n      rw [h₆] at h₄\n      exact h₄\n    exact h₃\n  exact h₁",
      "\n  have h₁ : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ ω (⟨(i, j), by exact le_of_lt h⟩ : Index n)) := by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    (try cases' lt_or_le i j with h' h') <;>\n    (try { simp_all [wignerMatrixEntryFunction, lt_irrefl, lt_asymm] <;> aesop }) <;>\n    (try {\n      split_ifs at * <;>\n      simp_all [wignerMatrixEntryFunction, lt_irrefl, lt_asymm, index_val] <;>\n      try { aesop } <;>\n      try { simp_all [Fin.ext_iff] <;> omega }\n    }) <;>\n    (try {\n      simp_all [wignerMatrixEntryFunction, lt_irrefl, lt_asymm, index_val] <;>\n      try { aesop } <;>\n      try { simp_all [Fin.ext_iff] <;> omega }\n    }) <;>\n    aesop\n  \n  have h₂ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n    have h₃ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n      -- Use the fact that each coordinate has the corresponding measure\n      have h₄ : HasLaw (fun ω : WignerSpace n ↦ ω (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, j), by exact le_of_lt h⟩ : Index n)) (WignerMeasure μ ν n) := by\n        apply MeasureTheory.ProbabilityMeasure.indep_functions.comp_hasLaw\n        <;> simp_all [WignerMeasure]\n        <;>\n        (try {\n          infer_instance\n        })\n        <;>\n        (try {\n          simp_all [wignerMeasureDist]\n          <;>\n          aesop\n        })\n        <;>\n        (try {\n          simp_all [wignerMeasureDist]\n          <;>\n          aesop\n        })\n        <;>\n        (try {\n          simp_all [wignerMeasureDist]\n          <;>\n          aesop\n        })\n      exact h₄\n    exact h₃\n  \n  have h₃ : (wignerMeasureDist μ ν n (⟨(i, j), by exact le_of_lt