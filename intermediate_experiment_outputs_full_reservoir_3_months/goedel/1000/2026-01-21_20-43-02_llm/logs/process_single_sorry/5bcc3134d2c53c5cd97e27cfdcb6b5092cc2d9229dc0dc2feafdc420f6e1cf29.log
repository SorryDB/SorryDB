theorem Lean_workbook_plus_58168 : 
    ∃ (x : ℕ → ℕ), ∀ (n : ℕ), x n < x (n + 1) ∧ ∀ (m : ℕ), m < n → x m < x n := by
  have h_main : ∃ (x : ℕ → ℕ), ∀ (n : ℕ), x n < x (n + 1) ∧ ∀ (m : ℕ), m < n → x m < x n := by
    use fun n => n + 1
    intro n
    constructor
    · -- Prove that x n < x (n + 1)
      simp [Nat.add_assoc]
      <;> omega
    · -- Prove that for all m < n, x m < x n
      intro m hm
      simp [Nat.add_assoc] at hm ⊢
      <;> omega
  
  exact h_main
