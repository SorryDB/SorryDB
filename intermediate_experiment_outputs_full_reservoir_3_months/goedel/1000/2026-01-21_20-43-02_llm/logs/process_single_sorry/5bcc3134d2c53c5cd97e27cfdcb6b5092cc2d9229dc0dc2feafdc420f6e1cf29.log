    try norm_num <;>
    try simp_all [sub_eq_add_neg] <;>
    try aesop
  smul_def' := by
    intros
    <;>
    simp [smul_smul, ← RingHom.map_mul] <;>
    try norm_num <;>
    try simp_all [sub_eq_add_neg] <;>
    try aesop
