lemma IsMatching.encard_le (hM : G.IsMatching M) : M.encard ≤ ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    apply le_trans _ (le_of_eq (by simp [hM]))
    <;>
    (try
      simp_all [Graph.isMaxMatching_iff])
    <;>
    (try
      omega)
    <;>
    (try
      aesop)
  exact h₁

lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard = ν(G) := by
    apply Eq.symm
    apply Eq.symm
