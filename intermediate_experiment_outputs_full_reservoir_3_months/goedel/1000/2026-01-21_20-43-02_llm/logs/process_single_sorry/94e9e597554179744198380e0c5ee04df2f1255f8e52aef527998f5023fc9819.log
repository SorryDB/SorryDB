def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, ?_, ?_⟩ <;> simp [is_empty]
    <;> infer_instance
  
  indep_subset := by
    intro S hS T hST
    obtain ⟨M, hM, hSm⟩ := hS
    refine ⟨M, hM, ?_⟩
    exact hSm.trans hST.subset
  
  indep_aug := by
    intro S T hS hS'
    have h₁ : S ⊆ T := hS'
    have h₂ : ∃ M, G.IsMatching M ∧ T ⊆ V(G, M) := hS
    obtain ⟨M, hM, hT⟩ := h₂
    refine ⟨M, hM, ?_⟩
    <;> simpa [h₁] using hT
  
