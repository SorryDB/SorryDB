def rollup [Inhabited (Tree a)] : List (Tree a) → Tree a :=
  Chapter6.foldl1 .node

def spine {a : Type} : Tree a → List (Tree a)
 | .leaf x   => [.leaf x]
 | .node u v => spine u ++ [v]

