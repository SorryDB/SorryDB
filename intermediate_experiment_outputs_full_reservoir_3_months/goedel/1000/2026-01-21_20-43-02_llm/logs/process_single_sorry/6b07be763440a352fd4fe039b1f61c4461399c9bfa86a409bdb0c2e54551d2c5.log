theorem DynamicProof {
  (p : ℕ)
  (p! : ℕ)
  (p' : ℕ)
  (intersections : Set ℕ)
  (allowed : (ℕ → ℕ → ℕ → ℕ → Set ℕ))
  (direct : (ℕ → ℕ → ℕ → ℕ → Set ℕ)) :
  ∀ (sp : ℕ) (hp : sp ∈ intersections) (sa : ℕ) (ha : ha ∈ intersections)
    (i : ℕ) (j : ℕ),
    sa ∈ allowed sp ha i j →
    ha ∈ direct sp sa i j →
    ∀ (k : ℕ) (l : ℕ), ha ∈ allowed sp ha k l → sp ∈ direct ha sp k l →
    p! ∈ direct ha ha 1 1 →
    p' ∈ intersections → p' ∈ allowed ha ha 1 1 →
    p' ∈ direct ha ha 1 1
  :=
  by
  intros
  <;>
  (try
    simp_all [allowed, direct, intersections]
    <;>
    norm_num
    <;>
    aesop)
  <;>
  (try
    aesop)
  <;>
  (try
    simp_all [allowed, direct, intersections]
    <;>
    norm_num
    <;>
    aesop)
  <;>
  (try
    aesop)
