theorem branchOnL (h : ℤ) (k : ℕ) : ℤ × ℕ := by
  have h₁ : h * 2 ≥ 0 := by
    -- Prove that h * 2 ≥ 0 using the fact that h ^ 2 is non-negative
    have h₁ : h * 2 ≥ 0 := by
      by_contra h₁
      -- If h * 2 < 0, then h is negative
      have h₂ : h * 2 < 0 := by linarith
