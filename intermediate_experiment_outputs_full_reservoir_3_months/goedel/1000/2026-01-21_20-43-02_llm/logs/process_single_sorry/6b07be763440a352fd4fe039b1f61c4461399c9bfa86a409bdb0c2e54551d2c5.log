theorem OMR_problem_24332_1 :
    (P ∧ Q) ∨ (R ∧ S) → (P ∨ R) ∧ (Q ∨ S) := by
  intro h
  have h₁ : P ∨ R := by
    cases h with
    | inl h₂ =>
      -- Case: P ∧ Q
      exact Or.inl h₂.1
    | inr h₂ =>
      -- Case: R ∧ S
      exact Or.inr h₂.1
  
  have h₂ : Q ∨ S := by
    cases h with
    | inl h₃ =>
      -- Case: P ∧ Q
      exact Or.inl h₃.2
    | inr h₃ =>
      -- Case: R ∧ S
      exact Or.inr h₃.2
  
  have h₃ : (P ∨ R) ∧ (Q ∨ S) := by
    exact ⟨h₁, h₂⟩
  
  exact h₃
```
