    rw [h₂]
  have h₂ : (n : ℚ) ^ k / (k.factorial : ℚ) ≤ (n : ℚ) ^ k / (2 : ℚ) ^ (k - 1) := by
    have h₃ : (k.factorial : ℚ) ≥ (2 : ℚ) ^ (k - 1) := by
      have h₄ : (k.factorial : ℕ) ≥ 2 ^ (k - 1) := by
        have h₅ : ∀ n : ℕ, n ≥ 1 → n.factorial ≥ 2 ^ (n - 1) := by
