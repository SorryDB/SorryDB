      "\n  have h₁ : (Nat.choose n k : ℚ) ≤ (n : ℚ) ^ k / (k.factorial : ℚ) := by\n    have h₂ : (Nat.choose n k : ℚ) = (n : ℚ) ^ k / (k.factorial : ℚ) := by\n      -- Use the identity for binomial coefficients\n      field_simp [Nat.cast_ne_zero, Nat.factorial_ne_zero, pow_ne_zero, Nat.cast_ne_zero]\n      <;>\n      norm_cast\n      <;>\n      simp [Nat.choose_eq_factorial_div_factorial, Nat.factorial_mul_factorial_dvd_factorial]\n      <;>\n      ring_nf\n      <;>\n      norm_num\n      <;>\n      field_simp [Nat.cast_ne_zero, Nat.factorial_ne_zero, pow_ne_zero, Nat.cast_ne_zero]\n      <;>\n      norm_cast\n      <;>\n      simp [Nat.choose_eq_factorial_div_factorial, Nat.factorial_mul_factorial_dvd_factorial]\n      <;>\n      ring_nf\n      <;>\n      norm_num\n      <;>\n      field_simp [Nat.cast_ne_zero, Nat.factorial_ne_zero, pow_ne_zero, Nat.cast_ne_zero]\n      <;>\n      norm_cast\n      <;>\n      simp [Nat.choose_eq_factorial_div_factorial, Nat.factorial_mul_factorial_dvd_factorial]\n      <;>\n      ring_nf\n      <;>\n      norm_num\n    rw [h₂]\n  have h₂ : (n : ℚ) ^ k / (k.factorial : ℚ) ≤ (n : ℚ) ^ k / (2 : ℚ) ^ (k - 1) := by\n    have h₃ : (k.factorial : ℚ) ≥ (2 : ℚ) ^ (k - 1) := by\n      have h₄ : (k.factorial : ℕ) ≥ 2 ^ (k - 1) := by\n        have h₅ : ∀ n : ℕ, n ≥ 1 → n.factorial ≥ 2 ^ (n - 1) := by\n          intro n hn\n          induction' hn with n hn IH\n          · norm_num\n          · cases n with\n            | zero => contradiction\n            | succ n =>\n              simp_all [Nat.factorial_succ, pow_succ]\n              <;> nlinarith [pow_pos (by norm_num : 0 < 2) n]\n        by_cases hk : k ≥ 1\n        · exact h₅ k hk\n        · have h₆ : k = 0 := by omega\n          rw [h₆]\n          norm_num\n      norm_cast at h₄ ⊢\n      <;>\n      simp_all [Nat.cast_le]\n      <;>\n      norm_num\n      <;>\n      linarith\n    have h₄ : 0 < (n : ℚ) ^ k := by\n      norm_cast\n      <;>\n      positivity\n    have h₅ : 0 < (2 : ℚ) ^ (