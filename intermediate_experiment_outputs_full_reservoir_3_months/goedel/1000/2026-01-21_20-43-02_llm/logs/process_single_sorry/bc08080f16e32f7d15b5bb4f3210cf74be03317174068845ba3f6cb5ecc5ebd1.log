          -- Benenne z₂'s Eigenschaften sinnvoll
          have z_eq_z₂ := by sorry
          have z₂_mem := h_z₂.1
          -- Erlange die Existenz einer Ableitung nach z₂ in cfg
          unfold ContextFreeGrammar.GeneratedLanguage at z₂_mem
          have h_inhabited : Inhabited ((cfg_CNF.val).ContextFreeDerivation (List.map Sum.inl [cfg_CNF.val.start]) (z₂.map Sum.inr)) := by sorry
