theorem PumpingLemma :
  ∀ language : ContextFreeLanguage α, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
  intro language
  by_cases ε ∈ language.1
  case pos =>
    sorry
  case neg h_eps_not_in_language =>
    have property := language.2
    simp [Language.is_context_free] at property
    cases property
    case intro nt property =>
      cases property
      case intro cg h_cg_gen_is_lang =>
        have nt₂ : Type := Empty
        have h_eps_not_gen : ε ∉ ContextFreeGrammar.GeneratedLanguage cg := by
          rw [h_cg_gen_is_lang.symm] at h_eps_not_in_language
          have eps_coe : @Word.epsilon α = coerceWord (@Word.epsilon cg.Z) := by rfl
          rw [eps_coe, ← coerceLang_not_mem] at h_eps_not_in_language
          exact h_eps_not_in_language
        let cng := @generate_equivalent_CNF α nt nt₂ ⟨cg, h_eps_not_gen⟩
        have h_cg_cng_gen_is_lang : coerceLang (cg.GeneratedLanguage) = coerceLang (cng.1.GeneratedLanguage) := by
          apply generate_equivalent_CNF_is_eq _ _ _ ⟨cg, h_eps_not_gen⟩
        use 2 ^ cng.val.V.card
        intro z
        have z₂ : ∀ {p : Prop}, (∀ (a : Inhabited (cng.1.ContextFreeDerivation [Sum.inl cng.1.start] (Sum.inr <$> (z.1 : Word α)))), p) → p := by
          apply z.prop.right.imp
          <;> simp_all [h_cg_cng_gen_is_lang]
          <;> try aesop
        have h_exists_deriv_z : ∃ (a : cng.1.ContextFreeDerivation [Sum.inl cng.1.start] (Sum.inr <$> (z.1 : Word α))), True := by
          by_cases h : Nonempty (cng.1.ContextFreeDerivation [Sum.inl cng.1.start] (Sum.inr <$> (z.1 : Word α)))
          · exact ⟨Classical.choice h, by trivial⟩
          · exfalso
            have h₂ : z.1 ∈ language.1 := z.prop.left
            have h₃ : z.1 ∈ coerceLang cng.1.GeneratedLanguage := by
              rw [h_cg_cng_gen_is_lang] at *
              exact h₂
            simp [coerceLang_mem] at h₃
            obtain ⟨w, hw⟩ := h₃
            have h₄ : w ∈ cng.1.GeneratedLanguage := hw.1
            have h₅ : coerceWord w = z.1 := hw.2
            have h₆ : Nonempty (cng.1.ContextFreeDerivation [Sum.inl cng.1.start] (Sum.inr <$> (w : Word cng.1.Z))) := by
              exact cng.1.NonemptyDerivation w h₄
            simp_all [Inhabited]
            <;> aesop
        have h_main : ∃ u v w x y : Word α, z.1 = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ 2 ^ cng.val.V.card ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.1) := by
          sorry
        obtain ⟨u, v, w, x, y, h₁, h₂, h₃, h₄⟩ := h_main
        refine' ⟨u, v, w, x, y, h₁, h₂, h₃, _⟩
        intro k
        have h₅ : u * (v^k) * w * (x^k) * y ∈ language.1 := h₄ k
        exact h₅
    <;> simp_all [Inhabited]
    <;> try aesop
