theorem PumpingLemma :
  ∀ language : ContextFreeLanguage α, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
  intro language
  by_cases ε ∈ language.1
  case pos =>
    use 1
    intro z
    have h₁ : z.val ∈ language.val := z.prop.left
    have h₂ : z.val.length ≥ 1 := by
      have h₃ : z.val.length ≥ 1 := by
        have h₄ : z.val.length ≥ 1 := by
          by_contra h
          have h₅ : z.val.length = 0 := by
            omega
          have h₆ : z.val = ε := by
            have h₇ : z.val.length = 0 := by
              omega
            have h₈ : z.val = ε := by
              rw [eq_comm]
              simp [h₇, Word.length_eq_zero]
            exact h₈
          have h₉ : ε ∈ language.val := by
            rw [h₆] at h₁
            exact h₁
          have h₁₀ : ε ∈ language.1 := by simpa using h₉
