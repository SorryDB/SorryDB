theorem l_iff
 (P : WithBot Type u_1)
 (Q : WithBot Type u_1) (x : P)
 (y : Q) : x = y ↔ Is TRUE ( x = y) := ⟨fun h => by
   simp_all [ipaginate], fun h => by
