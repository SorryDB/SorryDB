```lean
structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

example {p q : MyProd α β} : p = q := by
  have h₁ : p.fst = q.fst := by sorry
  have h₂ : p.snd = q.snd := by sorry
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;> aesop

example {p q : MyProd α (MyProd β γ)} : p = q := by
  have h₁ : p.fst = q.fst := by sorry
  have h₂ : p.snd.fst = q.snd.fst := by sorry
  have h₃ : p.snd.snd = q.snd.snd := by sorry
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;> aesop

example {p q : MyProd (α → β) γ} : p = q := by
  have h₁ : p.fst = q.fst := by sorry
  have h₂ : p.snd = q.snd := by sorry
  have h₃ : ∀ x, p.fst x = q.fst x := by sorry
  cases p
  cases q
  simp_all [MyProd.ext_iff]
  <;> aesop

example {p q : (α → β) × (γ → δ → ι)} : p = q := by
  have h₁ : p.1 = q.1 := by sorry
  have h₂ : p.2 = q.2 := by sorry
  have h₃ : ∀ x, p.1 x = q.1 x := by sorry
  have h₄ : ∀ x y, p.2 x y = q.2 x y := by sorry
  cases p
  cases q
  simp_all [Prod.ext_iff]
  <;> aesop

axiom T : Type
axiom U : Type
axiom u : U
axiom v : U

@[ext (iff := false)]
