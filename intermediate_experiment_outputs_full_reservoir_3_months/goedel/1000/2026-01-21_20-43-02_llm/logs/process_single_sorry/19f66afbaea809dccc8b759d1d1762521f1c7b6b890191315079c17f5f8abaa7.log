lemma lemma2 :
    ∃ f : Set.Icc 1 8 → Fin 2, ¬coloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
  dsimp [coloring_of_eight] at *
  have h₁ : i = 1 := by
    match i with
    | 0 => contradiction -- i cannot be 0 since i ≥ 1
    | 1 => rfl
    | i + 2 =>
      have h₂ := hi1
      have h₃ := hi2
      simp_all [Set.Icc, Nat.lt_succ_iff]
      <;> omega
  have h₂ : j = 7 := by
    match j with
    | 0 => contradiction -- j cannot be 0 since j ≥ 1
    | 1 => contradiction -- i < j and i = 1 implies j ≥ 2
    | 2 => contradiction -- i < j and i = 1 implies j ≥ 2; but 2j - i = 4 - 1 = 3 ≤ 8 and color 2 ≠ color 3
    | 3 => contradiction -- similarly, check that no j < 7 works
    | 4 => contradiction
    | 5 => contradiction
    | 6 => contradiction
    | 7 => rfl
    | j + 8 =>
      have h₃ := hj1
      have h₄ := hj2
      simp_all [Set.Icc, Nat.lt_succ_iff]
      <;> omega
  subst_vars
  -- Now i = 1, j = 7. Check the conditions.
  simp_all [Set.Icc, Fin.ext_iff, Fin.val_zero, Fin.val_one]
  <;> norm_num at *
  <;>
    (try contradiction) <;>
    (try
      {
        simp_all [Fin.ext_iff]
        <;> omega
      }) <;>
    (try
      {
        rcases hij2 with ⟨h₁, h₂⟩
        simp_all [Set.Icc, Fin.ext_iff, Fin.val_zero, Fin.val_one]
        <;> norm_num at *
        <;> omega
      })
  <;>
    simp_all [Fin.ext_iff]
  <;>
    norm_num at *
  <;>
    omega
