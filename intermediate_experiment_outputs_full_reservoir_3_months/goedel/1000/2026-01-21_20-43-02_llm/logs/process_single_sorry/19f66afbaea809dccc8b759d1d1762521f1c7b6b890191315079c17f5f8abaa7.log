        <;>
        (try omega)
      })
    -- Contradiction arises as the coloring is not good but all colorings are supposed to be good
    have h₅ : coloring_is_good coloring := h₃ coloring
    exact h₄ h₅
  
  exact ⟨h₁, h₂⟩
