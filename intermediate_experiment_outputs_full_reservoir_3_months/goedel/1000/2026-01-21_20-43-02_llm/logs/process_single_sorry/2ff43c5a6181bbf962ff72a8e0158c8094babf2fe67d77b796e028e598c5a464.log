  )
  )
  <;>
  ( try
  ( 
    simp_all [ProjectivePoint.double]
    <;> try norm_num
    <;> try ring_nf at *
    <;> try omega
  )
 )
  <;>
  ( try
  ( 
    use goff
    <;> simp_all [ProjectivePoint.double]
    <;> try norm_num
    <;> try ring_nf at *
    <;> try omega
  )
 )
  <;>
  ( try omega )
  <;>
