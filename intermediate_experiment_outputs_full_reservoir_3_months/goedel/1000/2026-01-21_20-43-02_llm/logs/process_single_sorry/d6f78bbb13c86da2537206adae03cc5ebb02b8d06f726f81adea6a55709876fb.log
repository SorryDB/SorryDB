inductive Matroid.IsGood : Matroid α → Prop
| graphic {M : Matroid α} (hM : M.IsGraphic) : M.IsGood
| cographic {M : Matroid α} (hM : M.IsCographic) : M.IsGood
| isomorphicR10 {M : Matroid α} {e : α ≃ Fin 10} (hM : M.mapEquiv e = matroidR10.toMatroid) : M.IsGood
| is1sum {M Mₗ Mᵣ : Matroid α} (hMMM : M.IsSum1of Mₗ Mᵣ) (hM : M.RankFinite) (hMₗ : Mₗ.IsGood) (hMᵣ : Mᵣ.IsGood) : M.IsGood
| is2sum {M Mₗ Mᵣ : Matroid α} (hMMM : M.IsSum2of Mₗ Mᵣ) (hM : M.RankFinite) (hMₗ : Mₗ.IsGood) (hMᵣ : Mᵣ.IsGood) : M.IsGood
| is3sum {M Mₗ Mᵣ : Matroid α} (hMMM : M.IsSum3of Mₗ Mᵣ) (hM : M.RankFinite) (hMₗ : Mₗ.IsGood) (hMᵣ : Mᵣ.IsGood) : M.IsGood

theorem Matroid.IsGood.isRegular {M : Matroid α} (hM : M.IsGood) : M.IsRegular := by
  induction hM with
  | graphic hM => exact hM.isRegular
  | cographic hM =>
    have h₁ : M.IsRegular := by
      have h₂ : M.IsCographic := hM
      have h₃ : M.IsRegular := h₂.isRegular
      exact h₃
    exact h₁
  | isomorphicR10 hM =>
    have h₁ : M.IsRegular := by
      have h₂ : M.IsRegular := by
        -- Prove that R10 is regular and use the isomorphism to transfer the property
        have h₃ : matroidR10.toMatroid.IsRegular := by
          -- R10 is a known regular matroid
          exact matroidR10.isRegular
        -- Since M is isomorphic to R10, it is also regular
        have h₄ : M.IsRegular := by
          -- Use the fact that isomorphism preserves regularity
          have h₅ : M.mapEquiv (e := (e : α ≃ Fin 10)) = matroidR10.toMatroid := hM
          have h₆ : M.IsRegular := by
            -- Use the isomorphism to transfer the regularity property
            apply IsRegular.of_mapEquiv
            <;> simp_all [h₅]
            <;> try aesop
          exact h₆
        exact h₄
      exact h₂
    exact h₁
  | is1sum hMMM hM hMₗ hMᵣ =>
    have h₁ : M.IsRegular := by
      have h₂ : M.IsRegular := by
        -- Use the fact that 1-sums of regular matroids are regular
        have h₃ : M.IsSum1of Mₗ Mᵣ := hMMM
        have h₄ : M.RankFinite := hM
        have h₅ : Mₗ.IsRegular := hMₗ.isRegular
        have h₆ : Mᵣ.IsRegular := hMᵣ.isRegular
        -- Use the property that 1-sums of regular matroids are regular
        have h₇ : M.IsRegular := by
          apply IsRegular.of_sum1
          <;> simp_all [h₃]
          <;> try aesop
        exact h₇
      exact h₂
    exact h₁
  | is2sum hMMM hM hMₗ hMᵣ =>
    have h₁ : M.IsRegular := by
      have h₂ : M.IsRegular := by
        -- Use the fact that 2-sums of regular matroids are regular
        have h₃ : M.IsSum2of Mₗ Mᵣ := hMMM
        have h₄ : M.RankFinite := hM
        have h₅ : Mₗ.IsRegular := hMₗ.isRegular
        have h₆ : Mᵣ.IsRegular := hMᵣ.isRegular
        -- Use the property that 2-sums of regular matroids are regular
        have h₇ : M.IsRegular := by
          apply IsRegular.of_sum2
          <;> simp_all [h₃]
          <;> try aesop
        exact h₇
      exact h₂
    exact h₁
