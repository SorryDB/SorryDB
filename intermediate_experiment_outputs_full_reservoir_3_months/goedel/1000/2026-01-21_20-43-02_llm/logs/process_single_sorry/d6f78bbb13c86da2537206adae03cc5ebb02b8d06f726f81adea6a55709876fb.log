        have h₃ : (M.dual).IsGraphic := by
          exact hM.dual_is_graphic
        -- Use the property of duals of regular matroids.
        have h₄ : (M.dual).IsRegular := h₃.isRegular
        -- Since M and M.dual are duals, M must also be regular.
        exact Dual.map_isRegular.mpr (h₄)
      exact h₂
    exact h₁
