structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

instance [DecidableEq α] [DecidableEq β] : DecidableEq (MyProd α β) where
  decidableEq p q := by
    by_cases h : p.fst = q.fst <;> by_cases h' : p.snd = q.snd <;>
