```lean
inductive Group : Type where
  | trivial
  | nontrivial
  | infinite
  | finite

def isTrivial (G : Group) : Bool :=
  if G = Group.trivial then true else false

def isFinite (G : Group) : Bool :=
  if G = Group.finite then true else false

def isNontrivial (G : Group) : Bool :=
  if G = Group.nontrivial then true else false

def isInfinite (G : Group) : Bool :=
  if G = Group.infinite then true else false

example : Group.trivial ≠ Group.nontrivial := by
  intro h
  contradiction

example : Group.trivial ≠ Group.infinite := by
  intro h
  contradiction

example : Group.trivial ≠ Group.finite := by
  intro h
  contradiction

example : Group.nontrivial ≠ Group.finite := by
  intro h
  contradiction

example : Group.nontrivial ≠ Group.infinite := by
  intro h
  contradiction

example : Group.finite ≠ Group.infinite := by
  intro h
  contradiction

-- The proof of the original statement using the structure above
def determineGroupType (G : Group) : String :=
  if isTrivial G then "trivial"
  else if isFinite G then "finite"
  else if isNontrivial G then "nontrivial and infinite"
  else "infinite"

-- Now we can prove the original statement using pattern matching
example (G : Group) : String :=
  match G with
  | Group.trivial => "trivial"
  | Group.nontrivial => "nontrivial and infinite"
  | Group.infinite => "infinite"
  | Group.finite => "finite"
```
