              <;> simp [sub_eq_add_neg]
              <;> ring_nf
              <;> simp_all [smul_smul]
              <;> norm_num
            have h7 : HasDerivAt (fun (t : ℝ) => t • y) y 0 := by
              -- Differentiate t • y
              simpa using (hasDerivAt_id (0 : ℝ)).smul_const y
            have h8 : HasDerivAt (fun (t : ℝ) => (1 - t) • x + t • y) (-x + y) 0 := h6.add h7
            convert h8 using 1 <;> simp [sub_eq_add_neg, add_assoc]
