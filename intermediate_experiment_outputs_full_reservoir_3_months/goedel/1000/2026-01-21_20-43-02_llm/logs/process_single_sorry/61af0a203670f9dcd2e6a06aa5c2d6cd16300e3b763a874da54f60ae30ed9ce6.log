        -- Use the fact that the derivative is unique
        have h₃₉ : deriv (f ∘ interpolator x y) t = interpolated_deriv x y f := by
          sorry
        rw [h₃₉]
      rw [h₃₈]
    rw [h₃]
  exact h₁
