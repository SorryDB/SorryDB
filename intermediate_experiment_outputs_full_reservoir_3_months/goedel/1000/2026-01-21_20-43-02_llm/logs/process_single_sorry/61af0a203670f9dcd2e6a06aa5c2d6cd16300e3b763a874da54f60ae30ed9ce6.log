      "\n  have h₁ : ∀ t : ℝ, deriv (interpolated x y f) t = interpolated_deriv x y f t := by\n    intro t\n    have h₂ : HasDerivAt (interpolated x y f) (interpolated_deriv x y f t) t := by\n      -- Prove that the derivative of interpolated x y f at t is interpolated_deriv x y f t\n      have h₃ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (y - x) t := by\n        -- Derivative of the interpolator\n        have h₄ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x) (-x) t := by\n          -- Derivative of (1 - t) • x\n          have h₅ : HasDerivAt (fun t : ℝ => (1 - t : ℝ)) (-1 : ℝ) t := by\n            simpa using (hasDerivAt_const t (1 : ℝ)).sub (hasDerivAt_id t)\n          have h₆ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x) (-1 : ℝ) • x t := by\n            apply HasDerivAt.smul h₅\n          convert h₆ using 1 <;> simp [smul_smul, neg_smul]\n          <;> ring_nf <;> simp_all\n          <;> aesop\n        have h₇ : HasDerivAt (fun t : ℝ => (t : ℝ) • y) y t := by\n          -- Derivative of t • y\n          have h₈ : HasDerivAt (fun t : ℝ => (t : ℝ)) 1 t := by simpa using hasDerivAt_id t\n          have h₉ : HasDerivAt (fun t : ℝ => (t : ℝ) • y) (1 : ℝ) • y t := by\n            apply HasDerivAt.smul h₈\n          convert h₉ using 1 <;> simp [smul_smul] <;> ring_nf <;> simp_all <;> aesop\n        -- Combine the derivatives\n        have h₁₀ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (-x + y) t := by\n          apply HasDerivAt.add h₄ h₇\n        convert h₁₀ using 1 <;> simp [sub_eq_add_neg, add_assoc] <;>\n          (try ring_nf) <;> (try simp_all [smul_smul, neg_smul]) <;> aesop\n      -- Use the chain rule to get the derivative of f ∘ interpolator x y\n      have h₁₁ : HasFDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ)) t := by\n        -- Convert the derivative to FDeriv\n        have h₁₂ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (y - x) t := h₃\n        have h₁₃ : HasFDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ)) t := by\n          convert h₁₂.hasFDerivAt using 1\n          <;> simp [ContinuousLinearMap.smulRight_apply]\n          <;> ext <;> simp [smul_smul]\n          <;> ring_nf\n          <;> simp_all [E, smul_smul]\n          <;> aesop\n        exact h₁₃\n      -- Apply the chain rule\n      have h₁₄ : HasFDerivAt (interpolated x y f) (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))) t := by\n        have h₁₅ : HasFDerivAt (fun t : ℝ => (1 - t : ℝ) • x + (t : ℝ) • y) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ)) t := h₁₁\n        have h₁₆ : HasFDerivAt (interpolated x y f) (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))) t := by\n          apply HasFDerivAt.comp t (f.continuousAt.hasFDerivAt) h₁₅\n        exact h₁₆\n      -- Simplify the FDeriv to get the derivative\n      have h₁₇ : deriv (interpolated x y f) t = interpolated_deriv x y f t := by\n        -- Show that the derivative is as expected\n        have h₁₈ : deriv (interpolated x y f) t = (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt).toLinearMap (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))).toFun 1 := by\n          -- Use the fact that the derivative is the FDeriv applied to 1\n          have h₁₉ : deriv (interpolated x y f) t = (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt).toLinearMap (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))).toFun 1 := by\n            apply HasDerivAt.deriv\n            -- Use the fact that the FDeriv is the derivative\n            have h₂₀ : HasDerivAt (interpolated x y f) ((ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt).toLinearMap (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))).toFun 1) t := by\n              -- Convert the FDeriv to a derivative\n              have h₂₁ : HasFDerivAt (interpolated x y f) (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt) (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))) t := h₁₄\n              have h₂₂ : HasDerivAt (interpolated x y f) ((ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt).toLinearMap (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))).toFun 1) t := by\n                convert h₂₁.hasDerivAt using 1 <;>\n                  simp [ContinuousLinearMap.toFun_smulRight, ContinuousLinearMap.toFun_comp]\n                <;>\n                  simp_all [E, Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ]\n                <;>\n                  ring_nf\n                <;>\n                  aesop\n              exact h₂₂\n            exact h₂₀\n          exact h₁₉\n        have h₂₀ : (ContinuousLinearMap.comp (f.continuousAt.hasFDerivAt).toLinearMap (ContinuousLinearMap.smulRight (y - x : E n) (1 : ℝ))).toFun 1 = interpolated_deriv x y f t := by\n          -- Compute the derivative using the chain rule\n          simp [ContinuousLinearMap.comp_apply, ContinuousLinearMap.smulRight_apply, interpolated_deriv, E]\n          <;>\n            simp_all [Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ, mul_comm]\n          <;>\n            congr 1 <;>\n              ext i <;>\n                simp [Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ, mul_comm]\n          <;>\n            ring_nf\n          <;>\n            simp_all [E, Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ, mul_comm]\n          <;>\n            aesop\n        rw [h₁₈, h₂₀]\n      -- Use the derivative to get the desired result\n      have h₂₁ : deriv (interpolated x y f) t = interpolated_deriv x y f t := h₁₇\n      have h₂₂ : HasDerivAt (interpolated x y f) (interpolated_deriv x y f t) t := by\n        apply HasDerivAt.deriv\n        <;> simp_all\n        <;>\n          (try ring_nf)\n        <;>\n          (try simp_all [E, Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ, mul_comm])\n        <;>\n          aesop\n      exact h₂₂\n    -- Use the fact that the derivative is unique to get the result\n    have h₂₃ : deriv (interpolated x y f) t = interpolated_deriv x y f t := by\n      apply HasDerivAt.deriv\n      exact h₂\n    exact h₂₃\n  -- Use the fact that the derivatives are equal at every point to get the functions are equal\n  have h₂ : deriv (interpolated x y f) = interpolated_deriv x y f := by\n    funext t\n    exact h₁ t\n  exact h₂",
