def deriv_interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) :
    deriv (interpolated x y f) = interpolated_deriv x y f := by
  have h₁ : deriv (interpolated x y f) = interpolated_deriv x y f := by
    have h₂ : interpolated x y f = f ∘ interpolator x y := rfl
    rw [h₂]
    have h₃ : deriv (f ∘ interpolator x y) = interpolated_deriv x y f := by
      -- Use the chain rule to differentiate the composition of f and the interpolator
      have h₄ : HasDerivAt (f ∘ interpolator x y) (interpolated_deriv x y f) 0 := by
        -- Compute the derivative of the interpolator
        have h₅ : HasDerivAt (interpolator x y) (y - x) 0 := by
          -- The derivative of the interpolator is y - x
          have h₆ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + t • y) (y - x) 0 := by
            -- Differentiate the interpolator with respect to t
            have h₇ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + t • y) (0 • x + 1 • y - 1 • x) 0 := by
              -- Use the sum rule and constant multiple rule
              have h₈ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x) (-1 • x) 0 := by
                -- Differentiate (1 - t) • x
                have h₉ : HasDerivAt (fun t : ℝ => (1 - t : ℝ)) (-1 : ℝ) 0 := by
                  simpa using (hasDerivAt_id (0 : ℝ)).const_sub 1
                have h₁₀ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x) (-1 • x) 0 := by
                  convert h₉.smul x using 1 <;> simp [sub_smul]
                  <;> ring_nf
                  <;> simp [sub_smul]
                exact h₁₀
              have h₁₁ : HasDerivAt (fun t : ℝ => (t : ℝ) • y) (1 • y) 0 := by
                -- Differentiate t • y
                have h₁₂ : HasDerivAt (fun t : ℝ => (t : ℝ)) 1 0 := by
                  simpa using (hasDerivAt_id (0 : ℝ))
                have h₁₃ : HasDerivAt (fun t : ℝ => (t : ℝ) • y) (1 • y) 0 := by
                  convert h₁₂.smul y using 1 <;> simp
                exact h₁₃
              -- Combine the derivatives using the sum rule
              have h₁₄ : HasDerivAt (fun t : ℝ => (1 - t : ℝ) • x + t • y) (-1 • x + 1 • y) 0 := by
                convert h₈.add h₁₁ using 1 <;> simp [add_smul]
              convert h₁₄ using 1 <;>
                simp [sub_smul, one_smul, add_smul]
              <;> abel
            convert h₇ using 1 <;>
              simp [sub_smul, one_smul, add_smul]
            <;> abel
          convert h₆ using 1 <;>
            simp [sub_smul, one_smul, add_smul]
          <;> abel
        -- Use the chain rule to differentiate f ∘ interpolator
        have h₁₅ : HasFDerivAt interpolator (continuousLinearMap_smulRight (1 : ℝ)) 0 := by
          have h₁₆ : HasFDerivAt (interpolator x y) (continuousLinearMap_smulRight (y - x)) 0 := by
            -- The derivative of the interpolator is y - x
            have h₁₇ : HasFDerivAt (fun t : ℝ => (1 - t : ℝ) • x + t • y) (continuousLinearMap_smulRight (y - x)) 0 := by
