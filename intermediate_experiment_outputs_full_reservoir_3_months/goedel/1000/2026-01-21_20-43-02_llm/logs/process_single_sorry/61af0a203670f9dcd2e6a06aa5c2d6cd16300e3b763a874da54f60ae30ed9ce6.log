                  simpa using (hasDerivAt_id (0 : ℝ)).const_sub 1
                have h₂₀ : HasFDerivAt (fun t : ℝ => (1 - t : ℝ) • x) (continuousLinearMap_smulRight (-x)) 0 := by
                  convert h₁₉.smul x using 1 <;> simp [sub_smul]
                  <;> ring_nf
                  <;> simp [sub_smul]
                exact h₂₀
              have h₂₁ : HasFDerivAt (fun t : ℝ => (t : ℝ) • y) (continuousLinearMap_smulRight y) 0 := by
                -- Differentiate t • y
                have h₂₂ : HasFDerivAt (fun t : ℝ => (t : ℝ)) (1 : ℝ) 0 := by
                  simpa using (hasDerivAt_id (0 : ℝ))
                have h₂₃ : HasFDerivAt (fun t : ℝ => (t : ℝ) • y) (continuousLinearMap_smulRight y) 0 := by
