theorem abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  have h₁ : ∀ (l : List (Sym2 V)) (e : (l.toFinset : Finset (Sym2 V))), countP (· = ↑e) l = 1 := by
    intro l e
    have h₂ : ↑e ∈ l := by
      simp only [Finset.mem_coe, List.mem_toFinset] at *
      <;> simp_all
    simp_all [countP_eq_card_filter, List.filter_eq']
    <;>
    (try decide) <;>
    (try omega) <;>
    (try aesop)
  
  have h₂ : ∑ (e : edgeSet p), edgeCount p e = ∑ (e : edgeSet p), 1 := by
    apply Finset.sum_congr rfl
    intro e he
    rw [show edgeCount p e = countP (· = e) p.edges by rfl]
    have h₃ := h₁ p.edges e
    simpa [e] using h₃
  
  have h₃ : ∑ (e : edgeSet p), (1 : ℕ) = (edgeSet p).card := by
    simp [Finset.sum_const]
    <;>
    (try decide) <;>
    (try omega) <;>
    (try aesop)
  
  have h₄ : (edgeSet p).card = p.edges.length := by
    have h₅ : (edgeSet p : Finset (Sym2 V)) = (p.edges.toFinset : Finset (Sym2 V)) := by
      simp [edgeSet]
    rw [h₅]
    simp [List.toFinset_card_of_nodup, List.nodup_map, List.nodup_darts]
    <;>
    (try decide) <;>
    (try omega) <;>
    (try aesop)
  
  have h₅ : p.edges.length = p.length := by
    have h₆ : ∀ (w : G.LoopWalk u v), w.edges.length = w.length := by
      intro w
      induction w with
      | nil => simp [edges]
      | cons h p ih =>
        simp_all [edges, darts, length, List.map, List.append]
        <;>
        (try decide) <;>
        (try omega) <;>
        (try aesop)
      | loop p ih =>
        simp_all [edges, darts, length, List.map, List.append]
        <;>
        (try decide) <;>
        (try omega) <;>
        (try aesop)
    exact h₆ p
  
  have h₆ : ∑ (e : edgeSet p), edgeCount p e = ∑ (e : edgeSet p), (1 : ℕ) := by
    rw [h₂]
  
  have h₇ : ∑ (e : edgeSet p), (1 : ℕ) = (edgeSet p).card := by
    rw [h₃]
  
  have h₈ : (edgeSet p).card = p.edges.length := by
    rw [h₄]
  
  have h₉ : p.edges.length = p.length := by
    rw [h₅]
  
  have h₁₀ : ∑ (e : edgeSet p), edgeCount p e = p.length := by
    calc
      ∑ (e : edgeSet p), edgeCount p e = ∑ (e : edgeSet p), (1 : ℕ) := h₆
      _ = (edgeSet p).card := h₇
      _ = p.edges.length := h₈
      _ = p.length := h₉
  exact h₁₀
