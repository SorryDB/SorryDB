have : 0 ∉ [[a, b]] := by
  have h₁ : 0 < a := ha
  have h₂ : 0 < b := hb
  have h₃ : a ≤ b ∨ b ≤ a := by by_cases h : a ≤ b <;> [left; right] <;> linarith
  cases h₃ with
  | inl h₃ =>
    -- Case: a ≤ b
    have h₄ : [[a, b]] = Set.Icc a b := by
      simp [uIcc, h₃]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try simp_all [Set.Icc, Set.Icc, Set.Icc]) <;>
      (try norm_num) <;>
      (try linarith)
    rw [h₄]
    intro h₅
    -- If 0 is in [a, b], then a ≤ 0 ≤ b, but a > 0, so contradiction.
    have h₆ : a ≤ (0 : ℝ) := h₅.1
    linarith
  | inr h₃ =>
    -- Case: b ≤ a
    have h₄ : [[a, b]] = Set.Icc b a := by
      simp [uIcc, h₃]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try simp_all [Set.Icc, Set.Icc, Set.Icc]) <;>
      (try norm_num) <;>
      (try linarith)
    rw [h₄]
    intro h₅
    -- If 0 is in [b, a], then b ≤ 0 ≤ a, but b > 0, so contradiction.
    have h₆ : b ≤ (0 : ℝ) := h₅.1
    linarith
