    (F : Functor D C) (G : Functor E C) :
    let CommaType := Σ (d : D) (e : E), Hom (F.F d) (G.F e)
    letI : Category CommaType := Comma_category F G
    NaturalTransformation
      (Functor.comp (Comma_category_cod F G) G)
      (Functor.comp (Comma_category_dom F G) F) where
  let CommaType := Σ (d : D) (e : E), Hom (F.F d) (G.F e)
  letI : Category CommaType := Comma_category F G
  arrow := fun X => {
    letI : Category C := by exact inferInstance
    letI : Category D := by exact inferInstance
    letI : Category E := by exact inferInstance
    have h₁ : Π (X : (d : D) × (e : E) × Hom (F.F d) (G.F e)), (Comma_category_cod F G).homF (Subtype.val X) |>.val = (X.2.1 : E) := by
      intro X
      rfl
    have h₂ : Π (X : (d : D) × (e : E) × Hom (F.F d) (G.F e)), (Comma_category_dom F G).homF (Subtype.val X) |>.val = (X.1 : D) := by
      intro X
