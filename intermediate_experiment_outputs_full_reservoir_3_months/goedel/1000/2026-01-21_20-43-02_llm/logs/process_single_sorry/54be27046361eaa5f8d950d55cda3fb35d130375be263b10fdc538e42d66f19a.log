  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y, hy, ⟨z, hz, rfl⟩⟩ := hy
  by_cases h : Reversible x y p
  · -- Case: Reversible x y p is true
    have h₁ : unreverse z ∈ (x.unreverse).moves p := by
      simp_all [unreverse_def]
      <;>
      (try {
        tauto
      }) <;>
      (try {
        exact Set.mem_iUnion₂.mpr ⟨y, ⟨z, hz, rfl⟩, unreverse z⟩
      }) <;>
      (try {
        aesop
      })
    have h₂ : ¬ Reversible x.unreverse (unreverse z) p := by
      by_contra h₃
      have h₄ := h₃.choose_spec
      have h₅ : h₃.choose ∈ (unreverse z).moves p := h₃.choose_mem_moves
      simp_all [unreverse_def, moves_ofSets, moves_left_unreverse, moves_right_unreverse,
