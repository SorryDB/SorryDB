      · exact lf_of_right_le (unreverse_equiv z).le (mem_moves_unreverse_of_reversible h hy hz)
    · grw [← unreverse_equiv y]
      exact lf_right (mem_moves_unreverse_of_not_reversible hy h)
termination_by x
decreasing_by igame_wf

