  intro x ε hε
  let δ : ℝ := min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
  have δle1 : δ ≤ 1 := by
    exact min_le_left _ _
  
  have δle2 : δ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
    exact min_le_right _ _
  
  have δpos : 0 < δ := by
    have h₁ : 0 < 1 := by norm_num
    have h₂ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by
      nlinarith [abs_nonneg x, sq_nonneg (x + 1)]
    have h₃ : 0 < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
      apply div_pos
      · exact hε
      · exact h₂
    have h₄ : 0 < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := by
      -- Use the fact that the minimum of two positive numbers is positive.
      exact lt_min (by norm_num) h₃
    exact h₄
  
  -- Use the δ to prove continuity
  use δ
  constructor
  · exact δpos
  · intro y hy
    have h₁ : |y - x| < δ := by simpa using hy
    have h₂ : |y - x| < 1 := by linarith
    have h₃ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
      linarith
    have h₄ : |y ^ 3 - x ^ 3| < ε := by
      -- Use the fact that |y - x| < δ to bound |y^3 - x^3|
      have h₅ : |y ^ 3 - x ^ 3| = |y - x| * |y ^ 2 + y * x + x ^ 2| := by
        -- Factor y^3 - x^3 and use the absolute value property
        calc
          |y ^ 3 - x ^ 3| = |(y - x) * (y ^ 2 + y * x + x ^ 2)| := by
            ring_nf
            <;> simp [abs_mul]
          _ = |y - x| * |y ^ 2 + y * x + x ^ 2| := by
            rw [abs_mul]
      rw [h₅]
      have h₆ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := h₃
      have h₇ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by
        nlinarith [abs_nonneg x, sq_nonneg (x + 1)]
      have h₈ : |y ^ 2 + y * x + x ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
        -- Use the triangle inequality and bounds on |y|
        cases' le_total 0 x with hx hx <;>
          cases' le_total 0 y with hy hy <;>
            simp_all [abs_of_nonneg, abs_of_nonpos, le_of_lt] <;>
              nlinarith [sq_nonneg (y - x), sq_nonneg (y + x)]
      calc
        |y - x| * |y ^ 2 + y * x + x ^ 2| < (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * |y ^ 2 + y * x + x ^ 2| := by
          gcongr
        _ ≤ (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by
          gcongr
          <;>
          nlinarith [abs_nonneg (y ^ 2 + y * x + x ^ 2)]
        _ = ε := by
          field_simp [h₇.ne']
          <;>
          ring_nf
          <;>
          field_simp [h₇.ne']
          <;>
          linarith
    exact h₄
