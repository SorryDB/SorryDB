instance (n : ℕ) [hn : NeZero n] : SampleableType (Fin n) where
  selectElem := congr_arg Fin (Nat.succ_pred (NeZero.ne n)).symm ▸ $ᵗ (Fin (n - 1 + 1))
  mem_support_selectElem x := by
    have h : x ∈ Set.univ := Set.mem_univ x
    simp_all [support_uniformSample]
    <;> aesop
  
  probOutput_selectElem_eq x y := by
    have h : ∀ (x y : Fin (n - 1 + 1)), Pr[=x | ($ᵗ (Fin (n - 1 + 1))) ] = Pr[=y | ($ᵗ (Fin (n - 1 + 1))) ] := by
      intro x y
      rw [probOutput_uniformSample]
      <;>
      simp [Finset.card_fin]
      <;>
      field_simp
      <;>
      ring_nf
      <;>
      norm_cast
    have h₁ : Pr[=x | ⋯ ▸ ($ᵗ (Fin (n - 1 + 1))) ] = Pr[=y | ⋯ ▸ ($ᵗ (Fin (n - 1 + 1))) ] := by
      have h₂ : (x : ℕ) < n := by
        have h₃ : x.val < n := by
          have h₄ : x.val < n := Fin.is_lt x
          exact h₄
        exact_mod_cast h₃
      have h₃ : (y : ℕ) < n := by
        have h₄ : y.val < n := Fin.is_lt y
        exact_mod_cast h₄
      have h₄ : (x : Fin (n - 1 + 1)) = ⟨x.val, by
        have h₅ : x.val < n - 1 + 1 := by
          have h₆ : x.val < n := Fin.is_lt x
          have h₇ : n - 1 + 1 ≥ n := by
            have h₈ : n ≥ 1 := by
              have h₉ : NeZero n := hn
              have h₁₀ : n ≠ 0 := NeZero.ne n
              omega
            omega
          omega
        omega
      ⟩ := by
        rfl
      have h₅ : (y : Fin (n - 1 + 1)) = ⟨y.val, by
        have h₆ : y.val < n - 1 + 1 := by
          have h₇ : y.val < n := Fin.is_lt y
