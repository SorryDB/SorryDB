    by_cases h₃ : biasedLocalField net x i = 0
    · -- Case: biasedLocalField net x i = 0
      have h₄ : biasedUpdateState net x i = x := by
        apply eq_of_heq
        have h₅ : biasedLocalField net x i = 0 := h₃
        simp_all [biasedUpdateState, localField, Finset.sum_ite, Finset.filter_eq', Finset.filter_ne']
