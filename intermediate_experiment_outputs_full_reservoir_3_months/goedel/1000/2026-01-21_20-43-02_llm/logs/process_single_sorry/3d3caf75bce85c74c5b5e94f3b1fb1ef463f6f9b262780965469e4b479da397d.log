      have h₆ : biasedUpdateState net x i = x := by
        apply eq_of_heq
        have h₇ : (biasedUpdateState net x i i) = x i := by
          -- Prove that biasedUpdateState net x i i = x i
          have h₈ : (biasedUpdateState net x i i).toReal = (x i).toReal := h₅
          cases x i <;> cases (biasedUpdateState net x i i) <;> simp [toReal] at h₈ ⊢ <;>
            (try contradiction) <;> (try simp_all) <;> (try linarith)
        simp_all [biasedUpdateState, localField, Finset.sum_ite, Finset.filter_eq', Finset.filter_ne']
        <;>
          (try aesop) <;>
          (try simp_all [Finset.sum_ite, Finset.filter_eq', Finset.filter_ne']) <;>
          (try norm_num) <;>
          (try linarith)
      exact h₆
  · -- Prove the reverse direction: if biasedUpdateState net x i = x, then -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i = 0
    intro h
    have h₂ : biasedUpdateState net x i = x := h
    have h₃ : (biasedUpdateState net x i i).toReal = (x i).toReal := by
      rw [h₂]
      <;> simp
    have h₄ : -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i = 0 := by
