        <;>
        (try omega)
      }) <;>
      (try {
        simp_all [Fin.ext_iff, Nat.lt_succ_iff]
        <;>
        (try omega)
      })

    theorem fin_cast {sz sz' : Nat} (h : sz = sz' := by rfl) :
      Fin sz = Fin sz' := by subst h; rfl

  end fin_range

