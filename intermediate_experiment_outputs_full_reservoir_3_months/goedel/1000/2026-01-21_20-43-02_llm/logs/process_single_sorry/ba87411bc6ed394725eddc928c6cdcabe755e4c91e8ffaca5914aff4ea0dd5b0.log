theorem as_montgomery_ne_zero (u : Scalar52) (h : u ≠ ZERO) :
    ∃ m, as_montgomery u = ok m ∧
    Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] ∧ m ≠ ZERO := by
  -- We know that the as_montgomery function returns an `Ok` value for any input.
  have h₁ : as_montgomery u = ok (u.as_montgomery_get) := by rfl
  have h₂ : Scalar52_as_Nat (u.as_montgomery_get) ≡ (Scalar52_as_Nat u * R) [MOD L] := by
    -- Prove the congruence using the properties of the Montgomery form.
    have h₃ : (u.as_montgomery_get : ℕ) = (u.val : ℕ) * R % L := by
      simp [Scalar52.as_montgomery_get]
      <;> rfl
    have h₄ : Scalar52_as_Nat (u.as_montgomery_get) = (u.val : ℕ) * R % L := by
      rw [show Scalar52_as_Nat (u.as_montgomery_get) = (u.as_montgomery_get : ℕ) by rfl]
      <;> simp [h₃]
    have h₅ : Scalar52_as_Nat u = (u.val : ℕ) := by
      rfl
    rw [h₄, h₅]
    -- Establish the congruence modulo L.
    have h₆ : ((u.val : ℕ) * R % L : ℕ) ≡ (u.val : ℕ) * R [MOD L] := by
      simp [Nat.ModEq, Nat.mod_mod]
    exact h₆
  have h₃ : u.as_montgomery_get ≠ ZERO := by
    -- Prove that the Montgomery form is non-zero if u is non-zero.
    intro h₄
    have h₅ : u.as_montgomery_get = ZERO := h₄
    have h₆ : u = ZERO := by
      -- If the Montgomery form is zero, then u must be zero.
      apply Eq.symm
      apply Eq.symm
      simp_all [Scalar52.ext_iff, Scalar52.as_montgomery_get]
      <;>
      (try decide) <;>
      (try {
        simp_all [Scalar52.val_zero]
        <;>
        omega
      }) <;>
      (try {
        omega
      })
    contradiction
  refine' ⟨u.as_montgomery_get, by simp_all [h₁], h₂, _⟩
  -- Prove that m is not zero.
  exact h₃
