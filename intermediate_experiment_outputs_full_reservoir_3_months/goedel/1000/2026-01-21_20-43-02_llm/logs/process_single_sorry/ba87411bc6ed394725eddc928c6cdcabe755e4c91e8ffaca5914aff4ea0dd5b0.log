theorem as_montgomery_ne_zero (u : Scalar52) (h : u ≠ ZERO) :
    ∃ m, as_montgomery u = ok m ∧
    Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] ∧ m ≠ ZERO := by
  have h₁ : as_montgomery u ≠ error := by
    intro h₁
    have h₂ : as_montgomery u = error := h₁
    have h₃ : u = ZERO := by
      have h₄ : as_montgomery u = error := h₂
      have h₅ : as_montgomery u = error ↔ u = ZERO := by
        rfl
      rw [h₅] at h₄
      exact h₄
    contradiction
  have h₂ : ∃ m, as_montgomery u = ok m := by
    cases as_montgomery u with
    | ok m => exact ⟨m, rfl⟩
    | error => contradiction
  obtain ⟨m, hm⟩ := h₂
  have h₃ : as_montgomery u = ok m := hm
  have h₄ : Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] := by
    have h₅ : as_montgomery u = ok m := h₃
    have h₆ : Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] := by
      have h₇ : as_montgomery u = ok m := h₅
      have h₈ : Scalar52_as_MONTGOMERY u = m := by
        simpa [h₇] using rfl
      have h₉ : Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] := by
        have h₁₀ : Scalar52_as_MONTGOMERY u = m := h₈
        have h₁₁ : Scalar52_as_Nat (Scalar52_as_MONTGOMERY u) ≡ (Scalar52_as_Nat u * R) [MOD L] := by
          rfl
        have h₁₂ : Scalar52_as_Nat m = Scalar52_as_Nat (Scalar52_as_MONTGOMERY u) := by
          rw [h₁₀]
        rw [h₁₂] at *
        exact h₁₁
      exact h₉
    exact h₆
  have h₅ : m ≠ ZERO := by
    intro h₅
    have h₆ : m = ZERO := h₅
    have h₇ : as_montgomery u = ok m := h₃
    have h₈ : as_montgomery u = ok ZERO := by rw [h₇, h₆]
    have h₉ : u = ZERO := by
      have h₁₀ : as_montgomery u = ok ZERO := h₈
      have h₁₁ : as_montgomery u = ok ZERO ↔ u = ZERO := by
        rfl
      rw [h₁₁] at h₁₀
      exact h₁₀
    contradiction
  exact ⟨m, h₃, h₄, h₅⟩
