      "rfl",
      "\n  have h₁ : as_montgomery u ≠ error := by\n    intro h₂\n    have h₃ := u.ne_zero_iff_as_montgomery_ne_zero.mp h₂\n    contradiction\n  -- Since as_montgomery u is not error, it must be ok m for some m\n  rcases as_montgomery u with (⟨m, hm⟩ | ⟨⟩) <;> simp_all [as_montgomery]\n  <;>\n  (try { contradiction }) <;>\n  (try {\n    use m\n    <;>\n    (try { aesop })\n  })\n  <;>\n  (try {\n    simp_all [as_montgomery, Scalar52_as_Nat, Nat.ModEq]\n    <;>\n    (try { norm_num at * }) <;>\n    (try { ring_nf at * }) <;>\n    (try { omega })\n  })",
      "\n  have h₁ : u.val ≠ 0 := by\n    intro h₁\n    have h₂ : u = ZERO := by\n      apply Scalar52.ext\n      <;> simp_all [Scalar52.val_zero]\n      <;> rfl\n    contradiction\n  \n  have h₂ : as_montgomery u = ok (to_montgomery u) := by\n    simp [to_montgomery]\n    <;>\n    (try decide) <;>\n    (try simp_all) <;>\n    (try omega)\n  \n  have h₃ : Scalar52_as_Nat (to_montgomery u) ≡ (Scalar52_as_Nat u * R) [MOD L] := by\n    have h₄ : (to_montgomery u : ℕ) = (u.val * R) % L := by\n      rfl\n    have h₅ : (to_montgomery u : ℕ) % L = (u.val * R) % L := by\n      rw [h₄]\n      <;>\n      simp [Nat.mod_mod]\n    have h₆ : Scalar52_as_Nat (to_montgomery u) ≡ (Scalar52_as_Nat u * R) [MOD L] := by\n      -- Use the property of modular arithmetic to show the congruence\n      have h₇ : Scalar52_as_Nat u = u.val := by rfl\n      have h₈ : Scalar52_as_Nat (to_montgomery u) = (to_montgomery u : ℕ) := by rfl\n      simp [h₈, h₇, h₄, Nat.ModEq]\n      <;>\n      (try omega) <;>\n      (try\n        {\n          norm_num [R, L] at *\n          <;>\n          ring_nf at *\n          <;>\n          omega\n        }) <;>\n      (try\n        {\n          rw [← Nat.mod_add_div (u.val) L]\n          ring_nf\n          <;>\n          norm_num [R, L] at *\n          <;>\n          ring_nf at *\n          <;>\n          omega\n        })\n      <;>\n      (try omega)\n    exact h₆\n  \n  have h₄ : to_montgomery u ≠ ZERO := by\n    intro h₄\n    have h₅ : (to_montgomery u : ℕ) = 0 := by\n      simp_all [Scalar52.ext_iff]\n    have h₆ : (u.val * R) % L = 0 := by\n      simp_all [to_montgomery]\n      <;>\n      norm_num [R, L] at *\n      <;>\n      ring_nf at *\n      <;>\n      omega\n    have h₇ : u.val = 0 := by\n      have h₈ : (u.val * R) % L = 0 := h₆\n      have h₉ : L > 0 := by norm_num [L]\n      have h₁₀ : R > 0 := by norm_num [R]\n      have h₁₁ : u.val < L := by\n        -- Prove that u.val < L using the properties of Scalar52\n        have h₁₂ : u.val < 2^52 := by\n          -- Since Scalar52 is a 52-bit integer, u.val < 2^52\n          have h₁₃ : u.val < 2^52 := by\n            -- This is a property of Scalar52\n            have h₁₄ : u.val < 2^52 := by\n              -- Use the fact that Scalar52 is a 52-bit integer\n              have h₁₅ : u.val < 2^52 := by\n                -- Use the fact that Scalar52 is a 52-bit integer\n                norm_num [Scalar52.val, Scalar52.size, Nat.pow_succ] at *\n                <;> omega\n              exact h₁₅\n            exact h₁₄\n          exact h₁₃\n        have h₁₂ : 2^52 ≤ L := by norm_num [L]\n        omega\n      -- Use the fact that R and L are coprime to deduce that u.val = 0\n      have h₁₂ : Nat.Coprime R L := by\n        unfold R L Nat.Coprime\n        <;> norm_num\n      have h₁₃ : (u.val * R) % L = 0 := h₆\n      have h₁₄ : L ∣ u.val * R := by\n        rw [Nat.dvd_iff_mod_eq_zero]\n        exact h₁₃\n      have h₁₅ : L ∣ u.val * R := h₁₄\n      have h₁₆ : L ∣ u.val * R := h₁₅\n      have h₁₇ : L ∣ u.val := by\n        -- Since R and L are coprime, L must divide u.val\n        have h₁₈ : Nat.Coprime R L := h₁₂\n        have h₁₉ : L ∣ u.val * R := h₁₆\n        have h₂₀ : L ∣ u.val := by\n          -- Use the fact that if a prime divides a product, it divides one of the factors\n          have h₂₁ : Nat.Coprime L R := by\n            rw [Nat.coprime_comm]\n            exact h₁₈\n          exact (Nat.Coprime.dvd_of_dvd_mul_right h₂₁ h₁₉)\n        exact h₂₀\n      have h₂₁ : L ∣ u.val := h₁₇\n      have h₂₂ : u.val < L := h₁₁\n      have h₂₃ : u.val = 0 := by\n        -- Since u.val < L and L divides u.val, u.val must be 0\n        have h₂₄ : L > 0 := by norm_num [L]\n        have h₂₅ : u.val = 0 := by\n          by_contra h₂₅\n          have h₂₆ : u.val ≥ 1 := by\n            omega\n          have h₂₇ : L ≤ u.val := by\n            exact Nat.le_of_dvd (by omega) h₂₁\n          omega\n        exact h₂₅\n      exact h₂₃\n    have h₈ : u = ZERO := by\n      apply Scalar52.ext\n      <;> simp_all [Scalar52.val_zero]\n      <;> rfl\n    contradiction\n  \n  refine' ⟨to_montgomery u, h₂, h₃, h₄⟩",
      "\n  have h₁ : as_montgomery u = ok (to_montgomery u) := by\n    rfl\n  have h₂ : Scalar52_as_Nat (to_montgomery u) ≡ (Scalar52_as_Nat u * R) [MOD L] := by\n    rfl\n  have h₃ : to_montgomery u ≠ ZERO := by\n    intro h₄\n    have h₅ : to_montgomery u = 0 := by simpa using h₄\n    have h₆ : u = 0 := by\n      have h₇ : to_montgomery u = 0 := h₅\n      have h₈ : to_montgomery u = (u.val * (R : ℕ)) % L := rfl\n      rw [h₈] at h₇\n      have h₉ : (u.val * (R : ℕ)) % L = 0 := h₇\n      have h₁₀ : u.val * R % L = 0 := h₉\n      have h₁₁ : u.val % L = 0 := by\n        have h₁₂ : Nat.Coprime R L := by\n          unfold R L Nat.Coprime\n          <;> norm_num\n        have h₁₃ : R * u.val % L = 0 := by\n          omega\n        have h₁₄ : u.val % L = 0 := by\n          have h₁₅ : R * u.val % L = 0 := h₁₃\n          have h₁₆ : Nat.Coprime R L := h₁₂\n          have h₁₇ : u.val % L = 0 := by\n            -- Use the fact that R and L are coprime to cancel R from the equation R * u.val ≡ 0 mod L\n            have h₁₈ : R * u.val ≡ 0 [MOD L] := by\n              simpa [Nat.ModEq] using h₁₅\n            have h₁₉ : u.val ≡ 0 [MOD L] := by\n              -- Use the fact that R and L are coprime to cancel R from the congruence\n              have h₂₀ : Nat.Coprime R L := h₁₂\n              have h₂₁ : u.val ≡ 0 [MOD L] := by\n                -- Use the fact that R and L are coprime to cancel R from the congruence\n                simp_all [Nat.ModEq, Nat.coprime_iff_gcd_eq_one]\n                <;>\n                  (try omega) <;>\n                  (try {\n                    have h₂₂ : L = 2^255 - 19 := by rfl\n                    have h₂₃ : R = 2^192 := by rfl\n                    norm_num [h₂₂, h₂₃, Nat.gcd_eq_right] at *\n                    <;>\n                    (try omega)\n                  }) <;>\n                  (try {\n                    omega\n                  })\n                <;>\n                  (try {\n                    aesop\n                  })\n              exact h₂₁\n            simpa [Nat.ModEq] using h₁₉\n          exact h₁₇\n        exact h₁₄\n      have h₁₂ : u.val % L = 0 := h₁₁\n      have h₁₃ : u = 0 := by\n        -- Since u.val % L = 0, we have u.val = 0\n        have h₁₄ : u.val = 0 := by\n          have h₁₅ : u.val % L = 0 := h₁₂\n          have h₁₆ : u.val < L := by\n            have h₁₇ : u.val < L := by\n              -- Prove that u.val < L\n              have h₁₈ : u.val < L := by\n                -- Use the fact that u.val < L\n                have h₁₉ : u.val < L := by\n                  -- Use the fact that u.val < L\n                  have h₂₀ : u.val < L := by\n                    -- Use the fact that u.val < L\n                    simp [Scalar52.val, L]\n                    <;> norm_num\n                    <;>\n                    (try omega)\n                  exact h₂₀\n                exact h₁₉\n              exact h₁₈\n            exact h₁₇\n          have h₂₀ : u.val % L = 0 := h₁₅\n          have h₂₁ : u.val = 0 := by\n            -- Since u.val < L and u.val % L = 0, we have u.val = 0\n            omega\n          exact h₂₁\n        -- Since u.val = 0, we have u = 0\n        simp [Scalar52.ext_iff] at h ⊢ <;> simp_all [h₁₄]\n      exact h₁₃\n    -- Since u = 0, we have a contradiction with the assumption u ≠ 0\n    exfalso\n    apply h\n    simpa [h₆] using h₆\n  refine' ⟨to_montgomery u, _, h₂, _⟩\n  · rfl\n  · simpa [h₃] using h₃",
      "\n  have h₁ : as_montgomery u = ok (u.as_montgomery_val) := by\n    simp [as_mongomerry]\n    <;> aesop\n  have h₂ : Scalar52_as_Nat (u.as_montgomery_val : Scalar52) ≡ (Scalar52_as_Nat u * R) [MOD L] := by\n    have h₃ : Scalar52_as_Nat (u.as_montgomery_val : Scalar52) = (Scalar52_as_Nat u * R) % L := by\n      rfl\n    have h₄ : (Scalar52_as_Nat u * R) % L ≡ Scalar52_as_Nat u * R [MOD L] := by\n      simp [Nat.ModEq, Nat.mod_eq_of_lt]\n      <;>\n      (try norm_num) <;>\n      (try omega) <;>\n      (try simp_all [Scalar52_as_Nat, Scalar52])\n      <;>\n      (try omega)\n    rw [h₃]\n    exact h₄\n  have h₃ : (u.as_montgomery_val : Scalar52) ≠ ZERO := by\n    by_contra h₄\n    have h₅ : as_mongomerry u = ok (u.as_montgomery_val : Scalar52) := by\n      simp [as_mongomerry]\n      <;> aesop\n    simp_all [as_mongomerry, unpackedArray_eq_zero]\n    <;>\n    (try norm_num at *) <;>\n    (try contradiction) <;>\n    (try omega)\n  refine' ⟨u.as_montgomery_val, _⟩\n  <;> simp_all [as_mongomerry]\n  <;>\n  (try norm_num at *) <;>\n  (try contradiction) <;>\n  (try omega)",
      "\n  have h₁ : ∃ m, as_montgomery u = ok m ∧ Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] ∧ m ≠ ZERO := by\n    obtain ⟨m, hm⟩ := u.as_montgomery\n    have h₂ : m ≠ 0 := by\n      by_contra h₃\n      have h₄ : m = 0 := by simpa using h₃\n      have h₅ : as_montgomery u = ok 0 := by simp [hm, h₄]\n      have h₆ : Scalar52_as_Nat u * R % L = 0 := by\n        have h₇ : as_montgomery u = ok 0 := by simpa using h₅\n        have h₈ := hm\n        have h₉ : Scalar52_as_Nat m % L = (Scalar52_as_Nat u * R) % L := by\n          simp [h₇] at h₈ ⊢\n          <;>\n          (try cases h₈ <;> simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]) <;>\n          (try omega) <;>\n          (try simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]) <;>\n          (try omega)\n          <;>\n          (try ring_nf at * <;> omega)\n        simp [h₄, Scalar52_as_Nat, as_montgomery, Scalar52_zero] at h₉ ⊢\n        <;>\n        (try omega) <;>\n        (try simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]) <;>\n        (try omega)\n        <;>\n        (try ring_nf at * <;> omega)\n      have h₁₀ : (Scalar52_as_Nat u : ℕ) % L = 0 := by\n        have h₁₁ : (Scalar52_as_Nat u : ℕ) < L := by\n          norm_num [Scalar52_as_Nat, Scalar52_val]\n          <;>\n          (try omega)\n        have h₁₂ : (Scalar52_as_Nat u : ℕ) * R % L = 0 := by simpa using h₆\n        have h₁₃ : (Scalar52_as_Nat u : ℕ) % L = 0 := by\n          have h₁₄ : L = 53 := by\n            norm_num [L]\n          rw [h₁₄] at *\n          have h₁₅ : (Scalar52_as_Nat u : ℕ) < 53 := by\n            norm_num [Scalar52_as_Nat, Scalar52_val]\n            <;>\n            (try omega)\n          have h₁₆ : (Scalar52_as_Nat u : ℕ) * 29 % 53 = 0 := by simpa using h₁₂\n          interval_cases (Scalar52_as_Nat u : ℕ) <;> norm_num at h₁₆ ⊢ <;> omega\n        exact h₁₃\n      have h₁₄ : u = ZERO := by\n        have h₁₅ : (Scalar52_as_Nat u : ℕ) % L = 0 := by simpa using h₁₀\n        have h₁₆ : u = ZERO := by\n          norm_num [Scalar52_as_Nat, Scalar52_val, ZERO] at h₁₅ ⊢\n          <;>\n          (try omega)\n          <;>\n          (try {\n            cases u <;> norm_num at h₁₅ ⊢ <;>\n            (try omega) <;>\n            (try {\n              simp_all [Scalar52_as_Nat, Scalar52_val, ZERO]\n              <;>\n              (try omega)\n            })\n          })\n        exact h₁₆\n      contradiction\n    refine' ⟨m, hm, _⟩\n    have h₃ : m ≠ 0 := h₂\n    have h₄ : m ≠ ZERO := by\n      intro h₅\n      have h₆ : m = 0 := by\n        simp_all [Scalar52_eq_zero]\n        <;>\n        (try omega)\n        <;>\n        (try {\n          cases m <;> norm_num at * <;>\n          (try omega)\n        })\n      contradiction\n    constructor\n    · -- Prove the congruence\n      have h₅ := hm\n      simp [h₅] at *\n      <;>\n      (try cases h₅ <;> simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]) <;>\n      (try omega) <;>\n      (try simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]) <;>\n      (try omega)\n      <;>\n      (try ring_nf at * <;> omega)\n      <;>\n      (try {\n        simp_all [Scalar52_as_Nat, as_montgomery, Scalar52_zero]\n        <;>\n        (try omega)\n        <;>\n        (try ring_nf at * <;> omega)\n      })\n    · -- Prove m ≠ ZERO\n      exact h₄\n  exact h₁",
      "\n  have h₁ : u ≠ ZERO := h\n  have h₂ : u.unpacked.val ≠ 0 := by\n    intro h₃\n    apply h₁\n    simp_all [Scalar52.ext_iff, unpacked_zero]\n    <;>\n    (try decide) <;>\n    (try simp_all [Scalar52.ext_iff, unpacked_zero]) <;>\n    (try norm_num) <;>\n    (try ring_nf at *) <;>\n    (try omega)\n  -- Extract the extra information from as_montgomery\n  have h₃ : as_montgomery u ≠ error := by\n    intro h₄\n    have h₅ : as_montgomery u = error := h₄\n    have h₆ : u = ZERO := by\n      have h₇ : (as_montgomery u : Option Scalar52) = none := by\n        simp [h₅]\n      have h₈ : u = ZERO := by\n        have h₉ := as_montgomery_eq_zero.mp\n        simp_all [h₉]\n        <;>\n        (try decide) <;>\n        (try simp_all [Scalar52.ext_iff, unpacked_zero]) <;>\n        (try norm_num) <;>\n        (try ring_nf at *) <;>\n        (try omega)\n      exact h₈\n    contradiction\n  -- We know that as_montgomery u is ok m, and we can proceed to find m\n  obtain ⟨m, hm⟩ := (as_montgomery u).ok\n  refine' ⟨m, _, _, _⟩\n  <;> simp_all\n  <;>\n  (try {\n    have h₄ := Check_as_montgomery\n    simp_all [h₄]\n    <;>\n    (try decide) <;>\n    (try simp_all [Scalar52.ext_iff, unpacked_zero]) <;>\n    (try norm_num) <;>\n    (try ring_nf at *) <;>\n    (try omega)\n  })\n  <;>\n  (try {\n    have h₄ : m ≠ 0 := by\n      intro h₅\n      have h₆ : m = 0 := h₅\n      have h₇ : m = 0 := by simp_all\n      have h₈ : m ≠ 0 := by\n        simp_all [Scalar52.ext_iff, unpacked_zero]\n        <;>\n        (try decide) <;>\n        (try simp_all [Scalar52.ext_iff, unpacked_zero]) <;>\n        (try norm_num) <;>\n        (try ring_nf at *) <;>\n        (try omega)\n      contradiction\n    simp_all [h₄]\n  })\n  <;>\n  (try {\n    simp_all [Scalar52.ext_iff, unpacked_zero]\n    <;>\n    (try decide) <;>\n    (try simp_all [Scalar52.ext_iff, unpacked_zero]) <;>\n    (try norm_num) <;>\n    (try ring_nf at *) <;>\n    (try omega)\n  })\n  <;>\n  (try {\n    aesop\n  })",
      "\n   Alternatively, perhaps Lean's `MResult` is like `Option` and can always be pattern-matched to get some value.",
      "\n  have h₁ : u.as_montgomery.isOk := u.isOk\n  have h₂ : as_montgomery u = ok u.as_montgomery.get := by\n    simp [h₁]\n  refine' ⟨u.as_montgomery.get, h₂, _, _⟩\n  · -- Prove that Scalar52_as_Nat m ≡ Scalar52_as_Nat u * R [MOD L]\n    have h₃ : (Scalar52_as_Nat u.as_montgomery.get : ℕ) ≡ (Scalar52_as_Nat u * R) [MOD L] := by\n      -- Use the theorem from_scalar_monty which states that converting from to and from monty preserves the value modulo L\n      have h₄ : (Scalar52_as_Nat u.as_montgomery.get : ℕ) ≡ (Scalar52_as_Nat u * R) [MOD L] :=\n        by\n          have h₅ := u.from_monty\n          have h₆ := u.to_monty\n          -- Use the properties of the modular equivalence to prove the statement\n          simp_all [Nat.ModEq, L, R]\n          <;>\n            (try omega) <;>\n            (try ring_nf at * <;> omega) <;>\n            (try\n              {\n                norm_num at *\n                <;>\n                  (try omega) <;>\n                  (try ring_nf at * <;> omega)\n              })\n          <;>\n            (try\n              {\n                simp_all [Nat.ModEq, Nat.mod_eq_of_lt]\n                <;>\n                  (try omega) <;>\n                  (try ring_nf at * <;> omega)\n              })\n          <;>\n            (try\n              {\n                norm_num at *\n                <;>\n                  (try omega) <;>\n                  (try ring_nf at * <;> omega)\n              })\n        )\n      exact h₄\n    exact h₃\n  · -- Prove that m ≠ ZERO\n    intro h₃\n    have h₄ : u.as_montgomery.get = 0 := by\n      simp_all [Scalar52.ext_iff]\n    have h₅ : u = 0 := by\n      have h₆ := u.to_monty\n      simp_all [Scalar52.ext_iff, as_montgomery, L, R, Nat.ModEq, Nat.mod_eq_of_lt]\n      <;>\n        (try omega) <;>\n        (try ring_nf at * <;> omega) <;>\n        (try\n          {\n            norm_num at *\n            <;>\n              (try omega) <;>\n              (try ring_nf at * <;> omega)\n          })\n      <;>\n        (try\n          {\n            simp_all [Nat.ModEq, Nat.mod_eq_of_lt]\n            <;>\n              (try omega) <;>\n              (try ring_nf at * <;> omega)\n          })\n      <;>\n        (try\n          {\n            norm_num at *\n            <;>\n              (try omega) <;>\n              (try ring_nf at * <;> omega)\n          })\n    simp_all [Scalar52.ext_iff]",
