theorem as_montgomery_ne_zero (u : Scalar52) (h : u ≠ ZERO) :
    ∃ m, as_montgomery u = ok m ∧
    Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] ∧ m ≠ ZERO := by
  have h_main : ∃ (m : Scalar52), as_montgomery u = ok m ∧ Scalar52_as_Nat m ≡ (Scalar52_as_Nat u * R) [MOD L] ∧ m ≠ ZERO := by
    have h₁ : as_montgomery u = ok u := by
      simp [as_montgomery]
    have h₂ : Scalar52_as_Nat u ≡ (Scalar52_as_Nat u * R) [MOD L] := by
      have h₃ : Scalar52_as_Nat u ≡ 0 [MOD L] → False := by
        intro h₄
        have h₅ : u = ZERO := by
          -- If u ≡ 0 mod L, then u is the zero scalar.
          have h₆ := congr_arg (fun x => x.val) h₄
          simp [Nat.ModEq, Scalar52_as_Nat] at h₆
          -- Since L is a prime and u is a Scalar52, u must be zero if its value is 0 mod L.
          simp_all [Scalar52.ext_iff, Fin.val_zero]
          <;> norm_num at *
          <;> aesop
        -- If u is zero, it contradicts the assumption that u ≠ 0.
        contradiction
      -- We need to show that u ≡ u * R mod L.
      -- This is equivalent to showing u * (R - 1) ≡ 0 mod L.
      -- Since R ≡ 1 mod L, this holds.
      have h₄ : Scalar52_as_Nat u ≡ (Scalar52_as_Nat u * R) [MOD L] := by
        have h₅ : Scalar52_as_Nat u * R ≡ Scalar52_as_Nat u * 1 [MOD L] := by
          -- Since R ≡ 1 mod L, multiplying both sides by u gives u * R ≡ u * 1 mod L.
          have h₆ : R ≡ 1 [MOD L] := by
            norm_num [Nat.ModEq, L, R]
          calc
            Scalar52_as_Nat u * R ≡ Scalar52_as_Nat u * 1 [MOD L] := by
              -- Using the fact that R ≡ 1 mod L, we can multiply both sides by u.
              exact Nat.ModEq.mul_left (Scalar52_as_Nat u) h₆
            _ = Scalar52_as_Nat u * 1 := by rfl
        -- Simplifying u * 1 to u, we get u * R ≡ u mod L.
        calc
          Scalar52_as_Nat u ≡ Scalar52_as_Nat u [MOD L] := by rfl
          _ ≡ Scalar52_as_Nat u * 1 [MOD L] := by
            simp [Nat.ModEq]
          _ ≡ Scalar52_as_Nat u * R [MOD L] := by
            -- Since u * R ≡ u * 1 mod L, we can reverse the congruence.
            exact h₅.symm
      exact h₄
    have h₃ : u ≠ ZERO := h
    refine' ⟨u, _⟩
    constructor
    · -- Prove as_montgomery u = ok u
      simp [as_montgomery]
    · constructor
      · -- Prove Scalar52_as_Nat u ≡ (Scalar52_as_Nat u * R) [MOD L]
        exact h₂
      · -- Prove u ≠ ZERO
        exact h₃
  
  obtain ⟨m, hm₁, hm₂, hm₃⟩ := h_main
  refine' ⟨m, _, _, _⟩
  <;> simp_all
  <;> aesop
