          -- Use the fact that the set of all finitely supported functions is finite and the condition is a subset.
          have h₃ : Set.Finite {a : Si →₀ ℤ | True} := by
            -- The set of all finitely supported functions Si →₀ ℤ is finite because Si is finite.
            have h₄ : Fintype (Si →₀ ℤ) := by
              -- Since Si is finite, the type Si →₀ ℤ is finite.
