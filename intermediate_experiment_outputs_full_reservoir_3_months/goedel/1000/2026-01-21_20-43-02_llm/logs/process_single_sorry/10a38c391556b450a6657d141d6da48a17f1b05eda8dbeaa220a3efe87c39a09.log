```lean
theorem reduce_sum {α : Type*} [DecidableEq α] (s : Finset α) (f g : α → ℕ) :
    (∑ a in s, (f a + g a)) ≥ ∑ a in s, f a + ∑ a in s, g a := by
  have h_sum_add_le : (∑ a in s, (f a + g a)) ≥ ∑ a in s, f a + ∑ a in s, g a := by
    calc
      (∑ a in s, (f a + g a)) = ∑ a in s, (f a + g a) := rfl
      _ ≥ ∑ a in s, f a + ∑ a in s, g a := by
        -- Use the fact that the sum of sums is less than or equal to the sum of the sums
        have h₁ : ∑ a in s, (f a + g a) = ∑ a in s, f a + ∑ a in s, g a := by
          rw [Finset.sum_add_distrib]
        rw [h₁]
        <;>
        simp_all [add_assoc, add_comm, add_left_comm]
        <;>
        linarith
  exact h_sum_add_le
```
