      "\n  have h₁ : ContinuousOn (fun x : ℝ => Φ₄ r x) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n  have h₂ : ((fun x : ℝ => Φ₄ r x) : ℝ → ℝ) = Φ₄ r := rfl\n  have h₃ : IntegrableOn (Φ₄ r : ℝ → ℝ) (Icc (0 : ℝ) 1) volume := by\n    -- Use the fact that the function is continuous on a compact interval to deduce integrability\n    refine' ContinuousOn.integrableOn_Icc _ _\n    · exact h₁\n    · -- Prove that the interval [0, 1] has finite volume\n      exact by\n        norm_num [Real.volume_Icc]\n  simpa [h₂] using h₃",
      "\n  have h₁ : (Icc (0 : ℝ) 1 : Set ℝ).IsCompact := isCompact_Icc\n  have h₂ : ContinuousOn (fun x : ℝ => ‖Φ₄ r x‖) (Icc (0 : ℝ) 1) := by\n    apply ContinuousOn.norm\n    exact Φ₄_contDiffOn.continuousOn.comp (continuousOn_id) (fun x hx => by simp_all)\n  have h₃ : BddAbove ( ‖Φ₄ r‖ '' (Icc (0 : ℝ) 1) ) := by\n    apply h₂.bddAbove'\n    <;> simp_all [isCompact_Icc]\n  have h₄ : BddBelow ( ‖Φ₄ r‖ '' (Icc (0 : ℝ) 1) ) := by\n    apply h₂.bddBelow'\n    <;> simp_all [isCompact_Icc]\n  have h₅ : IntegrableOn (fun x : ℝ => ‖Φ₄ r x‖) (Icc (0 : ℝ) 1) volume := by\n    apply ContinuousOn.integrableOn_Icc\n    <;> (try simp_all)\n    <;> (try continuity)\n    <;> (try exact Φ₄_contDiffOn.continuousOn.comp (continuousOn_id) (fun x hx => by simp_all))\n  refine' (MeasureTheory.IntegrableOn.of_norm_le h₅ ?_) <;>\n    simp_all [Function.comp]\n  <;>\n  (try norm_num) <;>\n  (try linarith)",
