      "\n  have h₁ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n    -- Prove that Φ₄ r is continuous and bounded on [0, 1]\n    have h₂ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n    -- Use the fact that the interval [0, 1] is compact and Φ₄ r is continuous to show it is bounded\n    have h₃ : BddAbove (Φ₄ r '' (Icc 0 1)) := by\n      apply isCompact_Icc.bddAbove_image\n      exact h₂\n    have h₄ : BddBelow (Φ₄ r '' (Icc 0 1)) := by\n      apply isCompact_Icc.bddBelow_image\n      exact h₂\n    -- Use the boundedness and continuity to conclude the integral is finite\n    have h₅ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n      apply ContinuousOn.hasFiniteIntegral\n      <;>\n      (try simp_all [measurableSet_Icc, Real.volume_Icc])\n      <;>\n      (try norm_num)\n      <;>\n      (try assumption)\n      <;>\n      (try exact h₂)\n      <;>\n      (try exact isCompact_Icc)\n    exact h₅\n  -- Use the finite integral to conclude integrability on the interval\n  have h₂ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := h₁\n  simpa [IntegrableOn, Real.volume_Icc] using h₂",
      "\n  have h₀ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n    -- Use the fact that Φ₄ is continuous on [0, 1] to prove integrability\n    have h₁ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n    have h₂ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n    -- Use the fact that a continuous function on a compact set is bounded\n    have h₃ : BddAbove (Set.range (fun x : ℝ => (Φ₄ r) x)) := by\n      -- Since Φ₄ is continuous on [0, 1], it attains its maximum\n      have h₄ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n      have h₅ : ∃ M, ∀ x ∈ (Icc (0 : ℝ) 1), (Φ₄ r) x ≤ M := by\n        -- Use the fact that a continuous function on a compact set is bounded\n        have h₆ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n        have h₇ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n        -- Use the extreme value theorem to find the maximum\n        have h₈ : ∃ M, ∀ x ∈ (Icc (0 : ℝ) 1), (Φ₄ r) x ≤ M := by\n          -- Use the fact that a continuous function on a compact set is bounded\n          have h₉ : ∃ M, ∀ x ∈ (Icc (0 : ℝ) 1), (Φ₄ r) x ≤ M := by\n            -- Use the fact that a continuous function on a compact set is bounded\n            exact Metric.exists_bounded_continuousImage h₇ (by\n              -- Prove that [0, 1] is a subset of itself\n              simpa using subset_univ (Icc (0 : ℝ) 1))\n          exact h₉\n        exact h₈\n      -- Obtain the bound M\n      obtain ⟨M, hM⟩ := h₅\n      -- Show that M is an upper bound for the range of Φ₄ r\n      refine' ⟨M, _⟩\n      intro y\n      -- Since y is in the range of Φ₄ r, there exists an x such that y = Φ₄ r x\n      rcases y with ⟨x, rfl⟩\n      -- If x is in [0, 1], then Φ₄ r x ≤ M\n      by_cases hx : x ∈ (Icc (0 : ℝ) 1)\n      · exact hM x hx\n      · -- If x is not in [0, 1], then Φ₄ r x is not relevant for the integral\n        have h₉ : (Φ₄ r) x ≤ M := by\n          -- Use the fact that Φ₄ r is continuous and the set is compact\n          have h₁₀ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n          -- Since x is not in [0, 1], we can use the fact that Φ₄ r is bounded outside [0, 1]\n          -- However, in this case, we can directly use the bound M\n          simp_all [Set.mem_Icc]\n          <;>\n          (try norm_num) <;>\n          (try linarith) <;>\n          (try\n            {\n              cases' le_or_lt 0 x with hx' hx' <;>\n              cases' le_or_lt x 1 with hx'' hx'' <;>\n              simp_all [Set.mem_Icc] <;>\n              linarith\n            })\n          <;>\n          (try\n            {\n              norm_num at *\n              <;>\n              linarith\n            })\n          <;>\n          (try\n            {\n              linarith\n            })\n        exact h₉\n    -- Use the fact that a bounded function on a finite measure set is integrable\n    have h₄ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n      -- Use the fact that Φ₄ is continuous on [0, 1]\n      have h₅ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n      -- Use the fact that [0, 1] is a compact set\n      have h₆ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n      -- Use the fact that a continuous function on a compact set is bounded\n      have h₇ : BddAbove (Set.range (fun x : ℝ => (Φ₄ r) x)) := h₃\n      -- Use the fact that a bounded function on a finite measure set is integrable\n      have h₈ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n        -- Use the fact that Φ₄ is continuous on [0, 1]\n        have h₉ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n        -- Use the fact that [0, 1] is a compact set\n        have h₁₀ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n        -- Use the fact that a continuous function on a compact set is bounded\n        have h₁₁ : BddAbove (Set.range (fun x : ℝ => (Φ₄ r) x)) := h₃\n        -- Use the fact that a bounded function on a finite measure set is integrable\n        apply ContinuousOn.hasFiniteIntegral\n        <;> simp_all [measurableSet_Icc]\n        <;>\n        (try norm_num) <;>\n        (try linarith) <;>\n        (try\n          {\n            apply ContinuousOn.mono h₉\n            <;>\n            simp_all [Set.subset_def]\n            <;>\n            (try norm_num) <;>\n            (try linarith)\n          })\n      exact h₈\n    exact h₄\n  -- Use the fact that a function with a finite integral is integrable\n  have h₁ : IntegrableOn (Φ₄ r) (Icc (0 : ℝ) 1) volume := by\n    exact h₀.integrableOn\n  exact h₁",
      "\n  have h₁ : ContinuousOn (Φ₄ r) (Icc (0 : ℝ) 1) := Φ₄_contDiffOn.continuousOn\n  have h₂ : IntegrableOn (Φ₄ r) (Icc (0 : ℝ) 1) volume := by\n    apply MeasureTheory.integrableOn_Icc_of_continuous\n    exact h₁\n  exact h₂",
      "\n   have h₄ : BddAbove ((Φ₄ r) '' Set.Icc (0 : ℝ) 1) := h₃.bddAbove\n   have h₅ : BddBelow ((Φ₄ r) '' Set.Icc (0 : ℝ) 1) := h₃.bddBelow",
      "\n  have h₁ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n    -- Use the fact that the function is continuous on a compact interval to show it is bounded\n    have h₃ : BddAbove (Set.range (fun x : ℝ => (Φ₄ r) x)) := by\n      -- Since Φ₄ r is continuous on [0,1], it attains its maximum\n      have h₄ : IsCompact (Icc 0 1) := isCompact_Icc\n      have h₅ : ContinuousOn (Φ₄ r) (Icc 0 1) := Φ₄_contDiffOn.continuousOn\n      have h₆ : BddAbove ((Φ₄ r) '' (Icc 0 1)) := by\n        apply isCompact_bddAbove_image\n        <;> simp_all [continuousOn_iff_continuous_restrict]\n        <;> exact h₄\n        <;> exact h₅\n      -- The range of Φ₄ r is the same as its image on [0,1] because we're restricting to [0,1]\n      have h₇ : (Φ₄ r) '' (Icc 0 1) = Set.range (fun x : ℝ => (Φ₄ r) x) := by\n        ext y\n        simp [Set.mem_image]\n        <;>\n        (try { aesop }) <;>\n        (try {\n          constructor <;> intro h <;>\n          (try { cases' h with x hx }) <;>\n          (try { use x <;> aesop }) <;>\n          (try { simp_all [Set.mem_Icc] <;> aesop })\n        })\n      rw [h₇] at h₆\n      exact h₆\n    -- Use the fact that the function is bounded and the interval has finite measure to show it has finite integral\n    have h₈ : HasFiniteIntegral (Φ₄ r) (volume.restrict (Icc 0 1)) := by\n      apply ContinuousOn.hasFiniteIntegral\n      <;> simp_all [continuousOn_iff_continuous_restrict]\n      <;> try { exact Φ₄_contDiffOn.continuousOn }\n      <;> try { exact isCompact_Icc }\n    exact h₈\n  -- Use the fact that the function has a finite integral to conclude it is integrable\n  have h₂ : IntegrableOn (Φ₄ r) (Icc 0 1) volume := by\n    exact h₁.integrableOn\n  exact h₂",
