theorem exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  have h₁ : n - 1 < S.length := by
    by_contra! h₂
    have h₃ : S.length ≤ n - 1 := by omega
    have h₄ : (S : List (Call n)).length ≤ n - 1 := by simpa using h₃
    have h₅ : ¬isBest G (after S).knows := by
      have h₆ : isBest G (initialState n).knows := by
        rw [isBest]
        <;> simp [initialState]
        <;>
          (try decide) <;>
            (try cases n <;> simp_all [Fin.ext_iff, InitialState]) <;>
              (try omega) <;>
                (try aesop)
      have h₇ : ¬(after S).knows.Incl (initialState n).knows := by
        -- Use the fact that the number of calls is less than n-1 to show that (after S).knows is not a superset of (initialState n).knows
        sorry
      -- Use the fact that (after S).knows is not a superset of (initialState n).knows to show that it is not the best
      sorry
    -- Use the fact that (after S).knows is not the best to show a contradiction
    sorry
  exact h₁
