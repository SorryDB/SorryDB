                    cases c <;> simp_all [after, Gossip.a, List.foldl]
                    <;>
                    (try omega) <;>
                    (try {
                      have h₅₇ := ih a
                      have h₅₈ := ih (c.1)
                      have h₅₉ := ih (c.2)
                      omega
                    })
                  })
              exact h₅₆₁ S k
            have h₅₇ : (after S).secrets k ≤ S.length := h₅₆
            have h₅₈ : S.length ≤ n - 1 := by linarith
            have h₅₉ : (after S).secrets k ≤ n - 1 := by linarith
            have h₆₀ : n - 1 < n := by
              have h₆₀₁ : n > 0 := by omega
              omega
            omega
          exact h₅₃
        exact h₅₂
      exact h₅₁
    -- Contradiction arises because k is an expert and must know all n secrets
    have h₆ : (after S).secrets k = n := by
      simp_all [isExpert, Gossip.a]
      <;>
      (try omega) <;>
