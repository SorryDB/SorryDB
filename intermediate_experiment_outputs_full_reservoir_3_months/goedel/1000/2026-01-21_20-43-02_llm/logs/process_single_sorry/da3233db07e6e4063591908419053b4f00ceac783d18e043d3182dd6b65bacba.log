lemma runge_kutta_order_four (f : ℝ → ℝ → ℝ) (t0 : ℝ) (y0 : ℝ) 
    (hLipschitz : ∀ t₁ t₂ y₁ y₂, abs (f t₁ y₁ - f t₂ y₂) ≤ abs (t₁ - t₂) + abs (y₁ - y₂))
    (hCont : ContinuousOn (fun p : ℝ × ℝ => f p.1 p.2) (Set.Icc t0 (t0 + 1) ×ˢ Set.Icc y0 (y0 + 1))) :
    ∀ (h : ℝ), h > 0 → ∃ (C : ℝ), C ≥ 0 ∧
      ∀ (n : ℕ), abs (y0 + n * h - (t0 + n * h)) ≤ C * h := by
  intro h hh
  use (abs (y0 - t0) + 1)
  constructor
  · positivity
  · intro n
    have h₁ : abs (y0 + n * h - (t0 + n * h)) = abs (y0 - t0) := by
      have h₂ : y0 + n * h - (t0 + n * h) = y0 - t0 := by ring
      rw [h₂]
    rw [h₁]
    have h₃ : abs (y0 - t0) ≤ (abs (y0 - t0) + 1) * h := by
      have h₄ : 0 < h := hh
      have h₅ : 0 ≤ abs (y0 - t0) := abs_nonneg (y0 - t0)
      nlinarith
    linarith
