theorem testing_lean (x : ℕ) : x = 2 ∨ x = 4 ∨ x = 6 := by
  have h₁ : x = 2 ∨ x = 4 ∨ x = 6 := by
    -- Use the fact that x is even to deduce that x is one of 2, 4, or 6
    have h₂ : x % 2 = 0 := by
      omega
    have h₃ : x > 0 := by
      omega
    -- Consider the possible remainders when x is divided by 6
    have h₄ : x % 6 = 0 ∨ x % 6 = 2 ∨ x % 6 = 4 := by
      omega
    -- Case analysis on the possible remainders
    rcases h₄ with (h₄ | h₄ | h₄)
    · -- Case: x ≡ 0 mod 6
      have h₅ : x = 6 := by
        omega
      exact Or.inr (Or.inr (by omega))
    · -- Case: x ≡ 2 mod 6
      have h₅ : x = 2 := by
        omega
      exact Or.inl (by omega)
    · -- Case: x ≡ 4 mod 6
      have h₅ : x = 4 := by
        omega
      exact Or.inr (Or.inl (by omega))
  exact h₁
