      | succ n ih =>
        intro v1 v2 h
        have : ∀ (v1 v2 : Vector α (n + 1)), (∀ (idx : Fin (n + 1)), v1[↑idx] = v2[↑idx]) → v1 = v2 := by
          intro v1 v2 h
