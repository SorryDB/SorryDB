theorem in_list_idx {α} {l : List α} {x : α} (H : x ∈ l) :
    ∃ i : Fin (List.length l), l[i] = x := by
      induction l with
      | nil => contradiction
      | cons hd tl HR =>
        rw [List.mem_cons] at H
        cases H <;> rename_i H
        · -- Case: x is the head of the list
          apply Exists.intro ⟨0, by simp [List.length_cons]⟩
          simp [H]
        · -- Case: x is in the tail of the list
          obtain ⟨i, hi⟩ := HR H
          apply Exists.intro ⟨i + 1, by
            simp only [List.length_cons] at *
            omega
          ⟩
          simp [hi, List.get?]
          <;> simp_all [Fin.val_succ]
          <;> omega
``` 

