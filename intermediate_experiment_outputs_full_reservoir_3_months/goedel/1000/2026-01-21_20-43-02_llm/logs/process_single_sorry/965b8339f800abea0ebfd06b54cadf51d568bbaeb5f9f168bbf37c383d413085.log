theorem vec_point_eq {v1 v2 : Vector α n} :
  (∀ (idx : Fin n), v1[↑idx] = v2[↑idx]) → v1 = v2 := by
  intros h
  obtain ⟨⟨l1⟩, sz1⟩ := v1
  obtain ⟨⟨l2⟩, sz2⟩ := v2
  congr
  dsimp at h
  dsimp [Array.size] at sz1 sz2
  induction l1 generalizing n l2 with
  | nil =>
    induction l2 with
    | nil => rfl
    | cons hd2 tl2 =>
      simp_all [List.length]
      <;> omega
  | cons hd1 tl1 =>
    induction l2 with
    | nil =>
      simp_all [List.length]
      <;> omega
    | cons hd2 tl2 =>
      congr
      · apply h ⟨0, by
          simp_all [List.length]
          <;> omega⟩
