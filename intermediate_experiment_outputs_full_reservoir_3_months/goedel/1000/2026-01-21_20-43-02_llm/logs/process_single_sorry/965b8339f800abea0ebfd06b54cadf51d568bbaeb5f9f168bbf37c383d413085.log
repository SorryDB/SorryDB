theorem in_list_idx {α} {l : List α} {x : α} (H : x ∈ l) :
    ∃ i : Fin (List.length l), l[i] = x := by
  have h₁ : ∀ {α} {l : List α} {x : α}, x ∈ l → ∃ i : Fin (List.length l), l[i] = x := by
    intro α l x H
    induction l with
    | nil =>
      -- If the list is empty, x cannot be in it, so this case is impossible.
      exfalso
      simp_all
    | cons hd tl ih =>
      -- If the list is non-empty, check if x is the head or in the tail.
      simp only [List.mem_cons] at H
      cases H with
      | inl H =>
        -- Case: x is the head of the list.
        -- The index of the head is 0.
        refine' ⟨⟨0, by simp [List.length_cons]⟩, _⟩
        simp [H]
      | inr H =>
        -- Case: x is in the tail of the list.
        -- Use the induction hypothesis on the tail.
        have h₂ : ∃ i : Fin (List.length tl), tl[i] = x := ih H
        obtain ⟨i, hi⟩ := h₂
        -- The index in the full list is i + 1.
        refine' ⟨⟨i + 1, by
          -- Prove that i + 1 is a valid index in the full list.
          have h₃ : i.val < List.length tl := i.is_lt
          have h₄ : List.length (hd :: tl) = List.length tl + 1 := by simp [List.length_cons]
          omega
          ⟩, _⟩
        -- Prove that the element at index i + 1 is x.
        simp [hi, List.get?]
        <;> cases i <;> simp_all [Fin.val_succ, List.get?]
        <;> try omega
        <;> try simp_all [List.get?]
        <;> try omega
  -- Apply the general lemma to the specific case.
  exact h₁ H
```
