lemma IsMatching.disjoint_inter_of_isCycleGraph_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (C.edgeSet ∩ M) (C.edgeSet ∩ M') := by
  have h₁ : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=
    by
      have h₂ : ∀ (e : β), e ∈ E(C) ∩ M → ∀ (f : β), f ∈ E(C) ∩ M' → e = f → False := by
        intro e he f hf hef
        have h₃ : e ∈ E(C) := by exact Set.mem_of_mem_inter_left he
        have h₄ : e ∈ M := by exact Set.mem_of_mem_inter_right he
        have h₅ : f ∈ E(C) := by exact Set.mem_of_mem_inter_left hf
        have h₆ : f ∈ M' := by exact Set.mem_of_mem_inter_right hf
        have h₇ : e = f := by exact hef
