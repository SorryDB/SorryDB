lemma IsMatching.disjoint_inter_of_isCycleGraph_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (C.edgeSet ∩ M) (C.edgeSet ∩ M') := by
  have h₁ : Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
    refine' disjoint_of_subset_left _ hC.coe_inclusions
    -- We need to show that the intersection of C's edges with M is disjoint from the intersection with M'.
    -- This can be done by showing that for any edge e in C, either e ∈ M or e ∈ M', but not both.
    -- This follows from the fact that C is a cycle in the graph obtained by symmetric difference of M and M',
    -- and the symmetric difference removes edges common to both M and M'.
    have h₂ : ∀ e ∈ E(C), e ∈ M ∆ M' := by
      intro e he
      have h₃ : e ∈ E(hM.restrict₂ hM') := by
        have h₄ : C ≤ hM.restrict₂ hM' := hCG
        exact h₄.coe_adj e he
      simp [hM.restrict₂, SymmDiff] at h₃ ⊢
      aesop
    -- Now, we know that for every edge e in C, e ∈ M ∆ M', meaning e is in exactly one of M or M'.
    -- Therefore, no edge can be in both M and M', so the intersections are disjoint.
    have h₃ : Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
      apply disjoint_left.mpr
      intro e he
      simp only [Set.mem_inter_iff] at he ⊢
      -- If e is in both E(C) ∩ M and E(C) ∩ M', then e ∈ M and e ∈ M', which contradicts e ∈ M ∆ M'.
      have h₄ : e ∈ E(C) := by tauto
      have h₅ : e ∈ M := by tauto
      have h₆ : e ∈ M' := by tauto
      have h₇ : e ∈ M ∆ M' := h₂ e h₄
      simp [SymmDiff, h₅] at h₇
      <;> aesop
    exact h₃
  simpa [C.edgeSet] using h₁
