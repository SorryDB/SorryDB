    <;> simp [Set.mem_setOf_eq]
  have h₄ : x.val ∈ val_image A X2 := by
    rw [h] at h₃
    exact h₃
  obtain ⟨y, hy, hy'⟩ := h₄
  have h₅ : y ∈ X2 := hy
  have h₆
