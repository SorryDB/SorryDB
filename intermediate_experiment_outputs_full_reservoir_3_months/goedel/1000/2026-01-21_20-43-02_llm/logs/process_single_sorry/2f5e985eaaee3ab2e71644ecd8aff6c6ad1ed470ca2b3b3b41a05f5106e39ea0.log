theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : A ∼ B) : 𝒫 A ∼ 𝒫 B := by
  have h1 : Set A ∼ Set B := by
    apply Exercise_8_1_5_1
    <;> exact h
  -- We already have the equinum of sets A and B, now we need to use this to prove the equinum of their powersets.
  -- Since h1 gives us the equinum of sets, and we have already established Set_equinum_powerset for any set,
  -- we can compose these two equivalences to get the desired result.
  have h2 : Set A ∼ 𝒫 A := by
    apply Set_equinum_powerset
  have h3 : Set B ∼ 𝒫 B := by
    apply Set_equinum_powerset
  -- Now we can use the transitivity of the equinum relation to combine these equivalences.
  have h4 : 𝒫 A ∼ 𝒫 B := by
    calc
      𝒫 A ∼ Set A := by
        -- We need to show that the powerset of A is equinumerous with the set of subsets of A.
        -- This is straightforward because the powerset of A is exactly the set of subsets of A.
        apply Equiv.symm
        apply Set_equinum_powerset
      _ ∼ Set B := h1
      _ ∼ 𝒫 B := by
        -- Similarly, the set of subsets of B is equinumerous with the powerset of B.
        apply Equiv.symm
        apply Set_equinum_powerset
  exact h4
