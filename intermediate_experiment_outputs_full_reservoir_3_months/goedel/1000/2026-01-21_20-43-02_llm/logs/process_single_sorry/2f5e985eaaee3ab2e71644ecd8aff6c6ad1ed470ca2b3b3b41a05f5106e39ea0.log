theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · intro h
    obtain ⟨f, hf⟩ := h
    refine' ⟨f, hf.symm, _⟩
    constructor <;> simp_all [Function.funext_iff, Function.comp_apply]
    <;>
    (try
