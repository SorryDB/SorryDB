theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : ↑A ∼ ↑B) : ↑(𝒫 A) ∼ ↑(𝒫 B) := by
  have h₁ : Set A ∼ Set B := by
    -- Use the fact that A and B are equivalent to show that their powersets are equivalent
    have h₂ : A ∼ B := by simpa using h
    -- Use the previously established equivalence between the powersets of equivalent sets
    have h₃ : Set A ∼ Set B := by
      -- Apply the theorem that states that the powersets of equivalent sets are equivalent
      apply Set_equinum_powerset.congr_arg (fun X => X)
      -- Confirm the equivalence between A and B
      exact h₂
    -- The result follows directly from the above steps
    exact h₃
  -- Convert the equivalence of the powersets to the desired form
  simpa [SetLike.coe_set] using h₁
