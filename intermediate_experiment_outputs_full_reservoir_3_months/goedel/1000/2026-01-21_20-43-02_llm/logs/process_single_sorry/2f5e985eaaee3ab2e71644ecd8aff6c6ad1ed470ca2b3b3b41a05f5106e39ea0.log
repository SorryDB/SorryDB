        simp_all [Function.comp_apply]
      })

-- 10.
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h₁ : (image g) ∘ (image f) = id := by
    ext S
    have h₂ : (image g) ((image f) S) = S := by
      apply Set.Subset.antisymm
      · -- Prove that (image g) ((image f) S) ⊆ S
        intro x hx
        have h₃ : x ∈ (image g) ((image f) S) := hx
        obtain ⟨y, hy, rfl⟩ := h₃
        have h₄ : y ∈ (image f) S := hy
        obtain ⟨z, hz, rfl⟩ := h₄
        have h₅ : g (f z) = z := by
          have h₆ : (g ∘ f) z = z := by
            have h₇ : (g ∘ f) = id := h
            rw [h₇]
            <;> simp
          simpa [Function.comp_apply] using h₆
        simp_all [Set.mem_image]
      · -- Prove that S ⊆ (image g) ((image f) S)
        intro x hx
        have h₃ : x ∈ S := hx
        have h₄ : f x ∈ (image f) S := by
          exact Set.mem_image_of_mem f h₃
        have h₅ : g (f x) = x := by
          have h₆ : (g ∘ f) x = x := by
            have h₇ : (g ∘ f) = id := h
            rw [h₇]
            <;> simp
          simpa [Function.comp_apply] using h₆
        have h₆ : x ∈ (image g) ((image f) S) := by
          refine' ⟨f x, h₄, _⟩
          simp [h₅]
        exact h₆
    exact h₂
  exact h₁

