lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  have h : (2 * k + 1 : ℕ) = 2 * k + 1 := rfl
  simp [h, fnz, Int.emod_eq_of_lt]
  <;> induction k <;> simp_all [Nat.mul_succ, pow_succ]
  <;> ring_nf at *
  <;> norm_num at *
  <;> omega

-- 2.
lemma fnz_fzn : fnz ∘ fzn = id := by
  funext x
  simp [fnz, fzn]
  <;>
  cases' le_or_lt x 0 with h h <;>
  simp_all [abs_of_nonneg, abs_of_neg, abs_of_nonpos, abs_of_pos, le_of_lt] <;>
  linarith

-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  simp [tri]
  <;> ring_nf
  <;> simp [mul_add, add_mul, mul_one, mul_zero, add_assoc, add_comm, add_left_comm]
  <;> ring_nf
  <;> omega

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ (n : ℕ), tri n = (n * (n + 1)) / 2 := by
    intro n
    simp [tri]
    <;> ring_nf
    <;> simp [Nat.mul_add, Nat.add_mul, Nat.mul_one, Nat.mul_zero, Nat.add_assoc]
  have h3 : tri j = (j * (j + 1)) / 2 := h2 j
  have h4 : tri k = (k * (k + 1)) / 2 := h2 k
  rw [h3, h4]
  have h5 : (j : ℕ) ≤ k := h1
  have h6 : (j * (j + 1) : ℕ) ≤ (k * (k + 1) : ℕ) := by
    have h7 : j ≤ k := h1
    have h8 : (j : ℕ) * (j + 1) ≤ (k : ℕ) * (k + 1) := by
      nlinarith
    exact h8
  have h7 : (j * (j + 1) : ℕ) / 2 ≤ (k * (k + 1) : ℕ) / 2 := by
    apply Nat.div_le_div_right
    <;> nlinarith
  exact h7

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  congr 1 <;>
  ext <;>
  simp [graph, range, Ran, Set.mem_setOf_eq] <;>
  (try aesop) <;>
  (try tauto) <;>
  (try
    {
      constructor <;>
      intro h <;>
      simp_all [exists_prop] <;>
      tauto
    })

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · intro h
    have h₁ : range f = Univ V := by
      apply Set.eq_univ_of_forall
      intro v
      have h₂ : ∃ u : U, f u = v := h v
      obtain ⟨u, hu⟩ := h₂
      exact ⟨u, by simp_all [Set.mem_range]⟩
    exact h₁
  · intro h
    have h₁ : onto f := by
      intro v
      have h₂ : v ∈ (Univ : Set V) := Set.mem_univ v
      rw [h] at h₂
      obtain ⟨u, hu⟩ := h₂
      exact ⟨u, by simp_all [Set.mem_range]⟩
    exact h₁

