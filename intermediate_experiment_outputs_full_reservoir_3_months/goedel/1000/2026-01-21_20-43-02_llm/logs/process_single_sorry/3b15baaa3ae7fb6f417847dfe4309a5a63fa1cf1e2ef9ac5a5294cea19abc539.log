      "\n  have h₂ : 0 < a := h₀.1\n  have h₃ : 0 < b := h₀.2.1\n  have h₄ : 0 < c := h₀.2.2.1\n  have h₅ : 0 < d := h₀.2.2.2\n  have h₆ : 0 < a + b + d := by linarith\n  have h₇ : 0 < a + b + c := by linarith\n  have h₈ : 0 < b + c + d := by linarith\n  have h₉ : 0 < a + c + d := by linarith\n  have h₁₀ : 0 < a * b := by positivity\n  have h₁₁ : 0 < a * c := by positivity\n  have h₁₂ : 0 < a * d := by positivity\n  have h₁₃ : 0 < b * c := by positivity\n  have h₁₄ : 0 < b * d := by positivity\n  have h₁₅ : 0 < c * d := by positivity\n  constructor\n  · -- Prove that 1 < s\n    have h₁₆ : 1 < s := by\n      have h₁₇ : s = a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) := h₁\n      rw [h₁₇]\n      have h₁₈ : a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) > 1 := by\n        -- Use the fact that each term is positive and the sum is greater than 1\n        have h₁₉ : 0 < a * (a + b + c) := by positivity\n        have h₂₀ : 0 < b * (a + b + d) := by positivity\n        have h₂₁ : 0 < c * (a + c + d) := by positivity\n        have h₂₂ : 0 < d * (b + c + d) := by positivity\n        field_simp\n        rw [← sub_pos]\n        field_simp\n        ring_nf\n        nlinarith [sq_nonneg (a - b), sq_nonneg (a - c), sq_nonneg (a - d), sq_nonneg (b - c), sq_nonneg (b - d), sq_nonneg (c - d)]\n      linarith\n    exact h₁₆\n  · -- Prove that s < 2\n    have h₁₆ : s < 2 := by\n      have h₁₇ : s = a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) := h₁\n      rw [h₁₇]\n      have h₁₈ : a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) < 2 := by\n        -- Use the fact that each term is less than 1 and their sum is less than 2\n        have h₁₉ : a / (a + b + d) < 1 := by\n          rw [div_lt_one (by positivity)]\n          nlinarith\n        have h₂₀ : b / (a + b + c) < 1 := by\n          rw [div_lt_one (by positivity)]\n          nlinarith\n        have h₂₁ : c / (b + c + d) < 1 := by\n        