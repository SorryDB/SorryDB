theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: if U ∼ V, then there exist f and g such that f ∘ g = id and g ∘ f = id
    intro h
    rcases h with ⟨f, hf⟩
    refine' ⟨f, hf.symm, _, _⟩
    · -- Prove f ∘ g = id
      rw [Function.comp_def]
      funext x
      simp [hf.right_inv]
    · -- Prove g ∘ f = id
      rw [Function.comp_def]
      funext x
      simp [hf.left_inv]
  · -- Prove the reverse direction: if there exist f and g such that f ∘ g = id and g ∘ f = id, then U ∼ V
    rintro ⟨f, g, hfg, hgf⟩
    refine' ⟨f, _⟩
    constructor
    · -- Prove that f is injective
      intro x y h
      have h1 : g (f x) = g (f y) := by rw [h]
      have h2 : g ∘ f = id := hgf
      have h3 : (g ∘ f) x = x := by simp [h2]
      have h4 : (g ∘ f) y = y := by simp [h2]
      have h5 : g (f x) = x := by simp_all [Function.comp_apply]
      have h6 : g (f y) = y := by simp_all [Function.comp_apply]
      simp_all
    · -- Prove that f is surjective
      intro y
      have h1 : f (g y) = y := by
        have h2 : f ∘ g = id := hfg
        have h3 : (f ∘ g) y = y := by simp [h2]
        simp [Function.comp_apply] at h3 ⊢
        exact h3
      exact ⟨g y, h1⟩
