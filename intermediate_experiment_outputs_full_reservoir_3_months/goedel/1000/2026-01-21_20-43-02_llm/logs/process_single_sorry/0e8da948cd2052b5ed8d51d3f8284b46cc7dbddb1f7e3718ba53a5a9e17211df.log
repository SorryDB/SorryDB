              rw [h₇]
            simp [id] at h₁₁ ⊢
            exact h₁₁
          simp_all
        -- Prove that f is surjective
        have h₆ : Function.Surjective f := by
          intro y
          have h₇ : f (g y) = y := by
            have h₈ : f ∘ g = id := h₁
            have h₉ : (f ∘ g) y = y := by
