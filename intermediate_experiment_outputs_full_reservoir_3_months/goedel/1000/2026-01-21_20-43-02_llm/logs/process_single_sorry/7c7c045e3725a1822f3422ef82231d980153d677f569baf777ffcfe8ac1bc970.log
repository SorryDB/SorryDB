      "by\n  constructor\n  · -- Prove the forward direction: if U is countable, then there exists a one-to-one function from U to ℕ\n    intro h\n    have h₁ : Nonempty (U ≃ ℕ) := by\n      -- Use the fact that U is countable to get a bijection with ℕ\n      have h₂ : ctble U := h\n      exact h₂.bijection\n    -- Obtain the bijection from the nonempty type\n    obtain ⟨e⟩ := h₁\n    -- The forward direction of the bijection is a one-to-one function from U to ℕ\n    refine' ⟨e.toFun, _⟩\n    -- Prove that the function is one-to-one\n    exact fun a b h₃ => by\n      have h₄ : e.toFun a = e.toFun b := h₃\n      have h₅ : a = b := by\n        apply e.injective\n        exact h₄\n      exact h₅\n  · -- Prove the reverse direction: if there exists a one-to-one function from U to ℕ, then U is countable\n    intro h\n    -- Obtain the one-to_one function from U to ℕ\n    obtain ⟨f, hf⟩ := h\n    -- Use the fact that there is an injection from U to ℕ to show that U is countable\n    have h₁ : ctble U := by\n      -- Use the fact that there is an injection from U to ℕ to show that U is countable\n      have h₂ : Nonempty (U ≃ ℕ) := by\n        -- Use the fact that there is an injection from U to ℕ to construct a bijection\n        classical\n        -- Use the fact that there is an injection from U to ℕ to construct a bijection\n        have h₃ : Nonempty (U ≃ ℕ) := by\n          -- Use the fact that there is an injection from U to ℕ to construct a bijection\n          have h₄ : ∃ (g : ℕ → U), Function.Surjective g := by\n            -- Use the fact that there is an injection from U to ℕ to construct a surjection from ℕ to U\n            classical\n            -- Use the fact that there is an injection from U to ℕ to construct a surjection from ℕ to U\n            have h₅ : ∃ (g : ℕ → U), Function.Surjective g := by\n              -- Use the fact that there is an injection from U to ℕ to construct a surjection from ℕ to U\n              have h₆ : ∃ (g : ℕ → U), Function.Surjective g := by\n                -- Use the fact that there is an injection from U to ℕ to construct a surjection from ℕ to U\n                exact\n                  Classical.choose_spec (exists_surjection_of_injective Function.Embedding.ofInjective hf)\n              exact h₆\n            exact h₅\n          -- Use the fact that there is an injection from U to ℕ to construct a bijection\n          obtain ⟨g, hg⟩ := h₄\n          -- Use the fact that there is an injection from U to ℕ to construct a bijection\n          have h₅ : Nonempty (U ≃ ℕ) := by\n            -- Use the fact that there is an injection from U to ℕ to construct a bijection\n            classical\n            -- Use the fact that there is an injection from U to ℕ to construct a bijection\n            have h₆ : Nonempty (U ≃ ℕ) := by\n              -- Use the fact that there is an injection from U to ℕ to construct a bijection\n              refine' ⟨Equiv.ofBijective (Function.Embedding.ofInjective hf) _⟩\n              -- Prove that the embedding is bijective\n              constructor\n              · -- Prove that the embedding is injective\n                exact hf\n              · -- Prove that the embedding is surjective\n                have h₇ : Function.Surjective (Function.Embedding.ofInjective hf) := by\n                  -- Prove that the embedding is surjective\n                  intro n\n                  -- Use the surjection from ℕ to U to find a preimage\n                  have h₈ : ∃ (u : U), f u = n := by\n                    -- Use the surjection from ℕ to U to find a preimage\n                    have h₉ : Function.Surjective g := hg\n                    -- Use the surjection from ℕ to U to find a preimage\n                    have h₁₀ : ∃ (m : ℕ), g m = Classical.choose (h₉ n) := by\n                      -- Use the surjection from ℕ to U to find a preimage\n                      exact ⟨Classical.choose (h₉ n), by\n                        have h₁₁ : g (Classical.choose (h₉ n)) = n := by\n                          apply Classical.choose_spec (h₉ n)\n                        simp_all⟩\n                    -- Use the surjection from ℕ to U to find a preimage\n                    obtain ⟨m, hm⟩ := h₁₀\n                    use Classical.choose (h₉ n)\n                    <;> simp_all [Function.Embedding.coeFn_mk]\n                    <;> aesop\n                  -- Use the surjection from ℕ to U to find a preimage\n                  obtain ⟨u, hu⟩ := h₈\n                  -- Use the surjection from ℕ to U to find a preimage\n                  use u\n                  <;> simp_all [Function.Embedding.coeFn_mk]\n                  <;> aesop\n                -- Prove that the embedding is surjective\n                exact h₇\n            -- Use the fact that there is an injection from U to ℕ to construct a bijection\n            exact h₆\n          -- Use the fact that there is an injection from U to ℕ to construct a bijection\n          exact h₅\n        -- Use the fact that there is an injection from U to ℕ to construct a bijection\n        exact h₃\n      -- Use the fact that there is an injection from U to ℕ to construct a bijection\n      exact ⟨Classical.choose h₂⟩\n    -- Conclude that U is countable\n    exact h₁",
      "by\n  apply Iff.intro\n  · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ\n    intro h\n    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by\n      -- Use the fact that U is countable to get an equivalence with ℕ\n      rcases h with ⟨f⟩\n      -- Use the injective part of the equivalence\n      refine' ⟨fun x => Classical.choose (f x), _⟩\n      intro x y hxy\n      have h₂ := Classical.choose_spec (f x)\n      have h₃ := Classical.choose_spec (f y)\n      have h₄ : (Classical.choose (f x) : ℕ) = (Classical.choose (f y) : ℕ) := by simpa using hxy\n      have h₅ : (Classical.choose (f x) : ℕ) ∈ f x := by\n        exact Classical.choose_spec (f x) |>.1\n      have h₆ : (Classical.choose (f y) : ℕ) ∈ f y := by\n        exact Classical.choose_spec (f y) |>.1\n      have h₇ : x = y := by\n        have h₈ : (Classical.choose (f x) : ℕ) ∈ f x := h₅\n        have h₉ : (Classical.choose (f y) : ℕ) ∈ f y := h₆\n        have h₁₀ : (Classical.choose (f x) : ℕ) = (Classical.choose (f y) : ℕ) := h₄\n        have h₁₁ : (Classical.choose (f y) : ℕ) ∈ f x := by\n          rw [h₁₀] at h₈\n          exact h₈\n        have h₁₂ : f x = f y := by\n          apply Set.ext\n          intro z\n          have h₁₃ : z ∈ f x ↔ z ∈ f y := by\n            constructor <;> intro hz <;>\n              (try simp_all) <;>\n              (try aesop) <;>\n              (try omega)\n          exact h₁₃\n        -- Use the fact that the sets are equal to deduce x = y\n        have h₁₃ : x = y := by\n          -- Since f x = f y and f is injective, x = y\n          simp_all [Set.ext_iff]\n          <;> aesop\n        exact h₁₃\n      exact h₇\n    -- Obtain the injective function\n    rcases h₁ with ⟨f, hf⟩\n    -- Provide the injective function\n    refine' ⟨f, _⟩\n    exact hf\n  · -- Prove the backward direction: if there exists an injective function from U to ℕ, then U is countable\n    intro h\n    rcases h with ⟨f, hf⟩\n    -- Use the injective function to show that U is countable\n    have h₁ : ctble U := by\n      -- Use the fact that there is an injective function from U to ℕ\n      -- to show that U is countable\n      refine' ⟨fun x => ⟨f x, _⟩⟩\n      intro x\n      exact ⟨x, by simp_all⟩\n    exact h₁",
