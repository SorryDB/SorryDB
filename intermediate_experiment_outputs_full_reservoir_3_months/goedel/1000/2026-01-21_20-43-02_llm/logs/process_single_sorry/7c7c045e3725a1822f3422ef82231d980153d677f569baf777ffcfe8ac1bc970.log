      "by\n  have h1 : ctble U ↔ ∃ (f : U → Nat), one_to_one f := by\n    apply Iff.intro\n    · -- Prove the forward direction: ctble U implies ∃ f : U → Nat, one_to_one f\n      intro h\n      -- Use the fact that if U is countable, there exists a bijection with Nat\n      have h2 : ctble U := h\n      -- Extract the function from the countable set to Nat\n      obtain ⟨f, hf⟩ := h2\n      -- Use this function as the desired injective function\n      refine' ⟨f, _⟩\n      -- Verify that the function is injective\n      have h3 : one_to_one f := by\n        intro a b hab\n        -- Since f is injective, f a = f b implies a = b\n        exact hf.1 hab\n      exact h3\n    · -- Prove the reverse direction: ∃ f : U → Nat, one_to_one f implies ctble U\n      intro h\n      -- Use the existence of an injective function to Nat to show U is countable\n      obtain ⟨f, hf⟩ := h\n      -- Use the fact that if there is an injective function from U to Nat, U is countable\n      have h2 : ctble U := by\n        -- Use the countable typeclass to show U is countable\n        exact ⟨f, ⟨hf, by\n          -- Since Nat is countable, there exists a surjective function from Nat to U\n          have h3 : ctble ℕ := by\n            exact ⟨(fun n : ℕ => n), ⟨fun _ _ h => by simpa using h, by\n              intro n\n              exact ⟨n, rfl⟩⟩⟩\n          -- Use the fact that if there is an injective function from U to Nat and a surjective function from Nat to U, then U is countable\n          exact ⟨fun n => 0, by simp⟩⟩⟩\n      exact h2\n  -- Use the established equivalence to prove the theorem\n  exact h1",
      "by\n  constructor\n  · intro h\n    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by\n      have h₂ : Nonempty (U ≃ (Set.Iio (0 : ℕ))) := by\n        exact Set.countable_iff_subset_of_paramap (Classical.decEq U) |>.mp h (Set.univ : Set ℕ)\n      dsimp at h₂\n      cases' h₂ with h₂\n      exact ⟨h₂.mpr, by simpa [Function.Injective] using h₂.injective⟩\n    cases' h₁ with f hf\n    refine' ⟨f, _⟩\n    simpa [Function.Injective] using hf\n  · intro h\n    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by\n      cases' h with f hf\n      refine' ⟨f, _⟩\n      simpa [Function.Injective] using hf\n    have h₂ : Set.Countable (Set.univ : Set U) := by\n      obtain ⟨f, hf⟩ := h₁\n      have h₃ : Set.Countable (Set.range f) := Set.countable_range f\n      have h₄ : Set.Countable (Set.univ : Set U) := by\n        have h₅ : Set.Countable (Set.univ : Set U) :=\n          Set.Countable.mono (fun x _ => by\n            have : x ∈ Set.univ := Set.mem_univ x\n            have : f x ∈ Set.range f := Set.mem_range_self x\n            simp_all [Set.Countable]\n          ) h₃\n        exact h₅\n      exact h₄\n    exact Set.countable_univ.mp h₂",
      "by\n  have h₁ : ctble U ↔ ∃ (f : U → Nat), one_to_one f := by\n    constructor\n    · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ\n      intro h\n      have h₂ : Nonempty (U ↪ ℕ) := by\n        -- Use the fact that U is countable to get an injection into ℕ\n        have h₃ : ctble U := h\n        simpa [ctble] using h₃\n      -- Obtain the injection\n      obtain ⟨f⟩ := h₂\n      refine' ⟨f, _⟩\n      -- Show that the injection is one-to-one\n      exact f.injective\n    · -- Prove the reverse direction: if there exists an injective function from U to ℕ, then U is countable\n      intro h\n      -- Use the injective function to show that U is countable\n      have h₂ : Nonempty (U ↪ ℕ) := by\n        obtain ⟨f, hf⟩ := h\n        refine' ⟨Embedding.ofInjective f hf⟩\n      -- Use the fact that the existence of an injection implies countability\n      simpa [ctble] using h₂\n  -- The final result follows from the established equivalence\n  exact h₁",
