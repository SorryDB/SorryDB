-- 18.
theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · intro h
    -- If U is countable, then there exists an injective function from U to ℕ.
    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by
      -- Use the fact that U is countable to get an equivalence with a subset of ℕ.
      have h₂ : Nonempty (U ≃ (Set.Iio (0 : ℕ))) := by
        exact Set.countable_iff_subset_of_paramap (Classical.decEq U) |>.mp h (Set.univ : Set ℕ)
      -- Simplify the equivalence to get an injective function.
      dsimp at h₂
      -- Use the injectivity of the function to get the required injective function.
      cases' h₂ with h₂
      exact ⟨h₂.mpr, by simpa [Function.Injective] using h₂.injective⟩
    -- Obtain the injective function from the previous step.
    cases' h₁ with f hf
    -- Show that this function is injective.
    refine' ⟨f, _⟩
    -- Use the injectivity of f to prove the required property.
    simpa [Function.Injective] using hf
  · intro h
    -- If there exists an injective function from U to ℕ, then U is countable.
    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by
      cases' h with f hf
      refine' ⟨f, _⟩
      simpa [Function.Injective] using hf
    -- Use the injective function to show that U is countable.
    have h₂ : Set.Countable (Set.univ : Set U) := by
      -- Use the fact that there is an injective function from U to ℕ.
      obtain ⟨f, hf⟩ := h₁
      -- Use the countability of the image of U under f.
      have h₃ : Set.Countable (Set.range f) := Set.countable_range f
      -- Use the fact that U is equivalent to the range of f.
      have h₄ : Set.Countable (Set.univ : Set U) := by
        -- Use the injectivity of f to show that U is countable.
        have h₅ : Set.Countable (Set.univ : Set U) :=
          Set.Countable.mono (fun x _ => by
            -- Show that each element of U is in the range of f.
            have : x ∈ Set.univ := Set.mem_univ x
            have : f x ∈ Set.range f := Set.mem_range_self x
            simp_all [Set.Countable]
          ) h₃
        exact h₅
      exact h₄
    -- Use the countability of U to conclude that U is countable.
    exact Set.countable_univ.mp h₂
