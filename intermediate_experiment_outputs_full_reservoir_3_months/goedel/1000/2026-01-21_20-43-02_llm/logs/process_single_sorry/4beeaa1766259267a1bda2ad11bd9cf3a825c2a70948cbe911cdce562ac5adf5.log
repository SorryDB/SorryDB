```lean
def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intros x y
      have h₁ : kerLift f (x * y) = (kerLift f x) * (kerLift f y) := by
        -- Since kerLift f is a ring homomorphism, it preserves multiplication.
        -- We need to show that the multiplication property holds in the quotient ring.
        -- However, the actual proof is straightforward because kerLift f is constructed as a ring homomorphism.
        -- The multiplication property is inherited from the fact that it is a ring homomorphism.
        simp [Ideal.Quotient.lift.map_mul]
      exact h₁
    map_add' := by
      intros x y
      have h₁ : kerLift f (x + y) = (kerLift f x) + (kerLift f y) := by
        -- Similarly, for addition, we use the fact that kerLift f is a ring homomorphism.
        -- This means that the addition property is also inherited.
        simp [Ideal.Quotient.lift.map_add]
      exact h₁
  }
