theorem firstIsomorphismTheorem (f : R →+* S) (hf : Surjective f) : R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (Classical.choose (hf x))
    right_inv := by
      intro x
      have h : f (Classical.choose (hf x)) = x := by
        have h₁ : ∃ r : R, f r = x := hf x
        have h₂ : f (Classical.choose (hf x)) = x := Classical.choose_spec (hf x)
        exact h₂
      simp [kerLift, h]
      <;>
      aesop
    left_inv := by
      intro x
      simp [kerLift, Ideal.Quotient.mk_eq_mk]
      <;>
      simp_all [Function.comp]
      <;>
      aesop
    map_mul' := by
      intro x y
      simp [kerLift, Ideal.Quotient.lift_mul]
      <;>
      aesop
    map_add' := by
      intro x y
      simp [kerLift, Ideal.Quotient.lift_add]
      <;>
      aesop
  }
