def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      have h₁ : (kerLift f (x * y) : S) = (kerLift f x) * (kerLift f y) := by
        rw [show (x * y : R ⧸ ker f) = x * y by rfl]
        rw [kerLift_mk, kerLift_mk, kerLift_mk]
        <;> simp_all [RingHom.map_mul]
      exact h₁
    map_add' := by
      intro x y
      have h₁ : (kerLift f (x + y) : S) = (kerLift f x) + (kerLift f y) := by
        rw [show (x + y : R ⧸ ker f) = x + y by rfl]
        rw [kerLift_mk, kerLift_mk, kerLift_mk]
        <;> simp_all [RingHom.map_add]
      exact h₁
  }
