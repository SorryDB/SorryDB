theorem GSum_const {ι : Type*} [AddCommMonoid M] [Fintype ι]
  (m : ℕ) : ∑ i : ι, (m : M) = (Fintype.card ι : ℕ) • m := by
  have h : ∑ i : ι, (m : M) = ∑ i : ι, (m : M) := rfl
  have h₁ : ∑ i : ι, (m : M) = (Fintype.card ι : ℕ) • m := by
    calc
      ∑ i : ι, (m : M) = ∑ i : ι, (m : M) := rfl
      _ = (Fintype.card ι : ℕ) • (m : M) := by
        simp [Finset.sum_const, nsmul_eq_mul, mul_comm]
        <;> simp_all [Fintype.card_fin]
        <;> ring_nf
        <;> simp_all [Fintype.card_fin]
        <;> try norm_cast
        <;> try simp_all [Fintype.card_fin]
        <;> try ring_nf
        <;> try norm_cast
      _ = (Fintype.card ι : ℕ) • m := by
        simp_all [add_smul, one_nsmul]
        <;> try simp_all [Fintype.card_fin]
        <;> try ring_nf
        <;> try norm_cast
  exact h₁
```
