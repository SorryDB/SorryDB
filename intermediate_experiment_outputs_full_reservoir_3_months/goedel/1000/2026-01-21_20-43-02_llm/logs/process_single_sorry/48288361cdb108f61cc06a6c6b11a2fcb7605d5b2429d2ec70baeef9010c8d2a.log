theorem EEDPD : ∀ (a : ℕ), (a = 0 ∨ 0 < a) → (
  ∃ (c : ℕ), (∀ (b : ℕ), b < a → b < c) ∧
  (∀ (b : ℕ), b < a → b ≤ c) ∧
  (∀ (b : ℕ), b < a → b ≤ c)) := by
  intro a h
  use a
  constructor
  · -- Prove that for all b < a, b < a
    intro b hb
    exact hb
  constructor
  · -- Prove that for all b < a, b ≤ a
    intro b hb
    omega
  · -- Prove that for all b < a, b ≤ a
    intro b hb
    omega
