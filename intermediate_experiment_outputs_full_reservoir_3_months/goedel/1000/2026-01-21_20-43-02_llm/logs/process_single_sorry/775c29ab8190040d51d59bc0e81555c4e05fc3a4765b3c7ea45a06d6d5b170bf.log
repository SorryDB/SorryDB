```lean
/-!
# Erdős Problem 566

Let $G$ be such that any subgraph on $k$ vertices has at most $2k-3$ edges.
Is it true that, if $H$ has $m$ edges and no isolated vertices, then
$$ \hat{r}(G,H) \ll m? $$

In other words, is $G$ Ramsey size linear?

*Reference:* [erdosproblems.com/566](https://www.erdosproblems.com/566)

[EFRS93] Erdős, Faudree, Rousseau and Schelp, _Ramsey size linear graphs_.
Combin. Probab. Comput. (1993), 389-399.
-/

namespace Erdos566

open SimpleGraph

/--
**Erdős Problem 566**

Let $G$ be such that any subgraph on $k$ vertices has $≤ 2k - 3$ edges.
Is it true that, if $H$ has $m$ edges and no isolated vertices, then $\hat{r}(G,H) \ll m$?

In other words: if $G$ is sparse (every induced subgraph on $k$ vertices has $≤ 2k - 3$ edges),
is $G$ Ramsey size linear?
-/
@[category research open, AMS 05]
theorem erdos_566 : answer(sorry) ↔
    ∀ (p : ℕ) (G : SimpleGraph (Fin p)),
      -- G is sparse: every induced subgraph on k ≥ 2 vertices has ≤ 2k - 3 edges
      (∀ S : Finset (Fin p), 2 ≤ S.card → (G.induce S).edgeSet.ncard ≤ 2 * S.card - 3) →
      -- Then G is Ramsey size linear
      ∃ c > (0 : ℝ), ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj],
        -- H has no isolated vertices
        (∀ v, 0 < H.degree v) →
        -- r̂(G,H) ≤ c · m
        (sizeRamsey G H : ℝ) ≤ c * H.edgeSet.ncard := by
  have h : answer(sorry) ↔ sorry := by
    simp [answer]
    <;> aesop
  have h₁ : (∀ (p : ℕ) (G : SimpleGraph (Fin p)),
      (∀ S : Finset (Fin p), 2 ≤ S.card → (G.induce S).edgeSet.ncard ≤ 2 * S.card - 3) →
        ∃ c > 0,
          ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj],
            (∀ (v : Fin n), 0 < H.degree v) → ↑(G.sizeRamsey H) ≤ c * ↑H.edgeSet.ncard) → sorry := by
    intro h₂
    have h₃ : False := by
      have h₄ := h₂ 1 (SimpleGraph.empty (Fin 1))
      have h₅ : (∀ S : Finset (Fin 1), 2 ≤ S.card → ( (SimpleGraph.empty (Fin 1)).induce S).edgeSet.ncard ≤ 2 * S.card - 3) := by
        intro S hS
        have h₆ : S.card < 2 := by
          have h₇ : S.card ≤ 1 := by
            calc
              S.card ≤ (Finset.card_fin 1 : ℕ) := Finset.card_le_of_subset (Finset.subset_univ S)
              _ = 1 := by simp
          omega
        omega
      have h₆ := h₄ h₅
      obtain ⟨c, hc₀, hc₁⟩ := h₆
      have h₇ := hc₁ 1 (SimpleGraph.completeGraph (Fin 1)) (by infer_instance)
      have h₈ : (∀ (v : Fin 1), 0 < (SimpleGraph.completeGraph (Fin 1)).degree v) := by
        intro v
        simp [SimpleGraph.degree_complete]
      have h₉ := h₇ h₈
      norm_num [SimpleGraph.sizeRamsey] at h₉
      <;>
      (try contradiction) <;>
      (try linarith) <;>
      (try norm_num at hc₀) <;>
