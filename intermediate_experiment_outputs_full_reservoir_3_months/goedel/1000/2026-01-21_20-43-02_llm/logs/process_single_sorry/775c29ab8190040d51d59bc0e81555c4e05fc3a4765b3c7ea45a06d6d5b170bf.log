      "\n  have h_main : (∀ (p : ℕ) (G : SimpleGraph (Fin p)), (∀ S : Finset (Fin p), 2 ≤ S.card → (G.induce S).edgeSet.ncard ≤ 2 * S.card - 3) → ∃ c > (0 : ℝ), ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj], (∀ v, 0 < H.degree v) → (sizeRamsey G H : ℝ) ≤ c * H.edgeSet.ncard) → (answer(sorry) ↔ ∀ (p : ℕ) (G : SimpleGraph (Fin p)), (∀ S : Finset (Fin p), 2 ≤ S.card → (G.induce S).edgeSet.ncard ≤ 2 * S.card - 3) → ∃ c > (0 : ℝ), ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj], (∀ v, 0 < H.degree v) → (sizeRamsey G H : ℝ) ≤ c * H.edgeSet.ncard) := by\n    intro h\n    constructor <;> intro <;>\n    (try simp_all) <;>\n    (try aesop) <;>\n    (try\n      {\n        have h₁ := h 0 ⊥\n        have h₂ := h 1 (⊥ : SimpleGraph (Fin 1))\n        have h₃ := h 2 (⊤ : SimpleGraph (Fin 2))\n        norm_num [SimpleGraph.induce, Finset.card_fin, Finset.card_range] at h₁ h₂ h₃ <;>\n        (try contradiction) <;>\n        (try aesop)\n      }) <;>\n    (try\n      {\n        exfalso\n        have h₁ := h 0 ⊥\n        have h₂ := h 1 (⊥ : SimpleGraph (Fin 1))\n        have h₃ := h 2 (⊤ : SimpleGraph (Fin 2))\n        norm_num [SimpleGraph.induce, Finset.card_fin, Finset.card_range] at h₁ h₂ h₃ <;>\n        (try contradiction) <;>\n        (try aesop)\n      })\n    <;>\n    (try\n      {\n        simp_all [answer]\n        <;>\n        aesop\n      })\n  -- Use the main lemma to conclude the proof\n  have h₂ : (∀ (p : ℕ) (G : SimpleGraph (Fin p)), (∀ S : Finset (Fin p), 2 ≤ S.card → (G.induce S).edgeSet.ncard ≤ 2 * S.card - 3) → ∃ c > (0 : ℝ), ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj], (∀ v, 0 < H.degree v) → (sizeRamsey G H : ℝ) ≤ c * H.edgeSet.ncard) := by\n    intro p G hG\n    have h₃ : ∃ c > (0 : ℝ), ∀ (n : ℕ) (H : SimpleGraph (Fin n)) [DecidableRel H.Adj], (∀ v, 0 < H.degree v) → (sizeRamsey G H : ℝ) ≤ c * H.edgeSet.ncard := by\n      use 1, by norm_num\n      intro n H _ hH\n      simp_all [sizeRamsey]\n      <;>\n      (try norm_num) <;>\n  