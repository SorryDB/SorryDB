        have h5 : IsBinomialRandom H q P := hY
        exact h5.aemeasurable.ae_stronglyMeasurable.stronglyMeasurable.measurable
      -- The `⊔` operation on `SimpleGraph V` is measurable because it is defined pointwise
      -- and `⊔` on `Prop` is measurable.
      have h6 : Measurable (fun (g h : SimpleGraph V) ↦ g ⊔ h) := by
        -- Prove that `(g, h) ↦ g ⊔ h` is measurable.
