    have h₁ : AEMeasurable (fun ω => G ω ⊔ H ω) P := by
      have h₂ : AEMeasurable G P := hG.aeMeasurable
      have h₃ : AEMeasurable H P := hY.aeMeasurable
      have h₄ : AEMeasurable (fun ω => G ω ⊔ H ω) P :=
        AEMeasurable.constr (by
          have h₅ : Measurable (fun (G H : SimpleGraph V) => G ⊔ H) := by
            simp [measurable_iff_adj, Sym2.dite, ite_eq_left_iff]
            <;>
            (try fun_prop) <;>
            (try simp_all [Sym2.ext_iff, Prod.ext_iff]) <;>
            (try aesop)
          have h₆ : Measurable (fun ω => (G ω, H ω)) := by
            apply Measurable.prod_mk h₂.measurable h₃.measurable
          have h₇ : Measurable (fun ω => G ω ⊔ H ω) :=
            h₅.comp h₆
          exact h₇)
          (by
            have h₈ : P.ae.and (h₂.ae.and h₃.ae) = P.ae := by
