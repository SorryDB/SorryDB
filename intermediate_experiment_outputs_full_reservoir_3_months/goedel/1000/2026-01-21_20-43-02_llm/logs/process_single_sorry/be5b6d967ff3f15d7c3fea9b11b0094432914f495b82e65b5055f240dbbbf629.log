              (try filter_upwards [h₂.eventually, h₃.eventually] with a ha₁ ha₂
                <;> simp_all)
              <;>
              (try simp_all [AEMeasurable])
            have h₉ : (fun ω => G ω ⊔ H ω)ᵐ* P = (fun ω => G ω ⊔ H ω)ᵐ* P := rfl
            filter_upwards [h₈] with ω a₁ a₂
            <;> simp_all [AEMeasurable]
            <;> aesop)
      exact h₄
    exact h₁
  <;> simp_all
  <;> aesop
