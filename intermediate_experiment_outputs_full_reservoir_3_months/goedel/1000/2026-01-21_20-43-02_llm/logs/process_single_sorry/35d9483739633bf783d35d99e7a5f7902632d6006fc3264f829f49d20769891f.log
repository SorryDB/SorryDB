```lean
theorem eps_not_in_CNF_Grammar {α nt : Type} :
  ∀ grammar : @ContextFreeGrammarCNF α nt,
  ε ∉ grammar.val.GeneratedLanguage := by
  intro grammar h_contra
  have h_empty : ε ∈ grammar.val.GeneratedLanguage := h_contra
  have h_start : grammar.val.Start ∈ grammar.val.GeneratedLanguage :=
    gram ventslanguage ContainsStart
  have h_mono : ∀ (u v : Word (Sum (grammar.val.V) (Finset α))),
    (∃ (d : ContextFreeDerivation grammar.val u v), True) → u.length ≤ v.length := by
    intro u v h
    -- Use the lemma that the length is monotone in a derivation for a CNF grammar
    have h₁ := deriv_length_monotone_CNF grammar u v h
    exact h₁
  have h_empty_ne_start : ε ≠ grammar.val.Start := by
    intro h_eq
    have h₂ : ε.length = 1 := by simp_all [h_eq, grammar.val.start]
    simp_all [h_eq]
    <;> contradiction
  have h_empty_deriv : ∃ (d : ContextFreeDerivation grammar.val grammar.val.Start ε), True := by
    -- Use the fact that ε is in the generated language to find a derivation
    have h₃ : ε ∈ grammar.val.GeneratedLanguage := h_empty
    simp only [GeneratedLanguage.mem_iff] at h₃
    obtain ⟨d, h₄⟩ := h₃
    refine' ⟨d, _⟩
    trivial
  have h_length : grammar.val.Start.length ≤ ε.length := by
    -- Apply the monotonicity lemma to the derivation from start to ε
    have h₄ := h_mono grammar.val.Start ε h_empty_deriv
    exact h₄
  have h_contradiction : ε.length < grammar.val.Start.length := by
    -- Calculate the lengths explicitly
    have h₅ : ε.length = 0 := by simp
    have h₆ : grammar.val.Start.length = 1 := by
      simp [grammar.val.start, Word.length]
    simp_all
    <;> norm_num
    <;> omega
  -- Combine the inequalities to get the final contradiction
  omega
```

