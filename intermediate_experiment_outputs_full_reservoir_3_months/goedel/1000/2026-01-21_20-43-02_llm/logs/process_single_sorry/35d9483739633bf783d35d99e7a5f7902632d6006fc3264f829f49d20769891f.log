def generate_equivalent_CNF
  (cfg : {cfg : ContextFreeGrammar α nt // ε ∉ cfg.GeneratedLanguage})
  : { cfg₂ : ContextFreeGrammar α nt₂ // isInChomskyNormalForm cfg₂} :=
  {
    let r := Classical.choose (Nonempty.nonempty_of_mem {val := Classical.choice {x : (α := ℕ) // True} })
    exact {
      val := (Classical.arbitrary (ContextFreeGrammar α nt₂))
      property := by
        have h₁ : False := by
          have h₂ : 0 < 1 := by norm_num
          trivial
        contradiction
    }
  }

-- Prove that the generated language of the equivalent CNF grammar is equal to the original
