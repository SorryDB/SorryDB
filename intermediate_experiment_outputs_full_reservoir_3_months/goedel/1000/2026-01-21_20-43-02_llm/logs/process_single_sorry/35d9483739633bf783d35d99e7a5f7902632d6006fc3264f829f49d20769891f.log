                    simp [List.tail] at h₁ ⊢
                    <;> aesop
                  }
            have h₈ : (a : Word Z).toList = (b : Word Z).toList := by
              have h₉ : (a : Word Z).toList.map (fun t => t.val) = (b : Word Z).toList.map (fun t => t.val) := by
                simp_all
              have h₁₀ : ∀ {α β : Type} (f : α → β), ∀ (l₁ l₂ : List α), l₁.map f = l₂.map f → l₁ = l₂ := by
