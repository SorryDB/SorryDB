theorem derive_equivalent_CNF_is_eq :
  ∀ (α nt nt₂ : Type) (cfg : {cfg : ContextFreeGrammar α nt // ε ∉ cfg.GeneratedLanguage}),
   @coerceLang α _ (↑cfg).Z (↑cfg).GeneratedLanguage = @coerceLang α (↑(generate_equivalent_CNF α nt nt₂ cfg)).Z (↑(generate_equivalent_CNF α nt nt₂ cfg)).GeneratedLanguage := by
