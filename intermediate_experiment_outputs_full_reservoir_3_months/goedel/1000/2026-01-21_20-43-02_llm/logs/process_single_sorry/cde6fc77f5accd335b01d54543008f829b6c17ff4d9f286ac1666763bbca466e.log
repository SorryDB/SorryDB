      by
      have : e / n * n + e % n - (b / n * n + b % n) = e / n * n + e % n - b / n * n - b % n := by omega
      rw [this]
      have : e / n * n + e % n - b / n * n = ((e / n) - (b / n)) * n + e % n :=
        by
        have : e / n * n + e % n - b / n * n = (e / n * n - b / n * n) + e % n :=
          Nat.sub_add_comm (Nat.mul_le_mul (Nat.div_le_div_right h₁') (by rfl))
        rw [this, ← Nat.sub_mul]
      rw [this]
      have : e / n - b / n = (e / n - b / n - 1) + 1 :=
        by
        refine Eq.symm (Nat.sub_add_cancel ?_)
        rw [Nat.one_le_iff_ne_zero]
        intros h
        have h := Nat.le_of_sub_eq_zero h
        nlinarith
      rw (occs := .pos [1]) [this]
      rw [right_distrib, one_mul, add_assoc,
