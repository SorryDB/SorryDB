    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  have h3 : ctble V := by
    have h4 : U ≃ V := by
      exact h1
    -- Use the fact that the existence of a bijection between U and V implies V is countable if U is countable
    have h5 : ctble U → ctble V := by
      intro hU
      -- Since U is countable and there is a bijection between U and V, V must also be countable
      have h6 : ctble V := (h4).symm.countable_iff.mpr hU
      exact h6
    -- Apply the above to h2
    exact h5 h2
  exact h3
``` 

