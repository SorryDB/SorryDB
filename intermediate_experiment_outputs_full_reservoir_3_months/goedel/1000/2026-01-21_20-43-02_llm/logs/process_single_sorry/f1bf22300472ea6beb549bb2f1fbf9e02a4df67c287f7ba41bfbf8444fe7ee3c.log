            {
              rfl
            }
          )
        }
  <;>
    (try decide)
  <;>
    (try
      {
        simp_all [Circuit.eval,Clap.Simulation.s_val,Clap.Simulation.s_bisim]
        <;>
          aesop
      }
    )
