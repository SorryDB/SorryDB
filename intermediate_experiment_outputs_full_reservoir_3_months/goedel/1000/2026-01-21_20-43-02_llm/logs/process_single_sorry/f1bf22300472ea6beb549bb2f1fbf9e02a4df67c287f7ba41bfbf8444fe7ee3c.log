  case p =>
    use ({ .eq0 (fun i => Clap.Simulation.s_val i)
      (hs)
      (fun i =>
        hs
        (gn))
      (fun i _
          => hs
            (some (i)
              (by
                exact
                  (by
                    simp_all [ZMod.val_zero]
                    <;>
                    omega)
                )
            )
        )
      }
      : Circuit p (ZMod p))
    <;>
      try simp_all [Circuit.eval,Clap.Simulation.s_val,Clap.Simulation.s_bisim]
    <;>
      try aesop
    <;>
      try
        {
          (try decide)
          <;>
          (try
            {
              rfl
            }
          )
        }
    <;>
      try
        {
          (try decide)
          <;>
