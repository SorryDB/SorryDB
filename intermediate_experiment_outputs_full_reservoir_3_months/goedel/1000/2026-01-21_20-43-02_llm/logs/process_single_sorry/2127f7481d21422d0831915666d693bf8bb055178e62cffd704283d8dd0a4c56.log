    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by
  have h₁ : Integrable f (μ i) := hf
  have h₂ : ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by
    -- Use the fact that the integral over the product space can be decomposed into integrals over each component
    calc
      ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ := rfl
      _ = ∫ x, f x ∂μ i := by
        -- Use the Fubini-Tonelli theorem to integrate over each component
        rw [← MeasureTheory.integral_fst]
