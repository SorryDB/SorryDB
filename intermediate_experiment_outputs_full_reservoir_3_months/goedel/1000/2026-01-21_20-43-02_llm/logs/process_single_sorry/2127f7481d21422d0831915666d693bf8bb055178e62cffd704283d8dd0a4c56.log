    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  have h₁ : Var[L; stdGaussianMulti E] = ∑ i : Fin (Module.finrank ℝ E), L (stdOrthonormalBasis ℝ E i) ^ 2 := by
    rw [show (stdGaussianMulti E) = (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i) by rfl]
    rw [show (fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i) = (fun x ↦ ∑ i : Fin (Module.finrank ℝ E), x i • stdOrthonormalBasis ℝ E i) by rfl]
    -- Use the fact that the variance of the sum is the sum of the variances for independent variables
    have h₂ : Var[L; (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i : Fin (Module.finrank ℝ E), x i • stdOrthonormalBasis ℝ E i)] = ∑ i : Fin (Module.finrank ℝ E), L (stdOrthonormalBasis ℝ E i) ^ 2 := by
      -- Compute the variance of the mapped measure
      have h₃ : Var[L; (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i : Fin (Module.finrank ℝ E), x i • stdOrthonormalBasis ℝ E i)] = ∑ i : Fin (Module.finrank ℝ E), L (stdOrthonormalBasis ℝ E i) ^ 2 := by
        -- Use the fact that the variance of the sum is the sum of the variances for independent variables
        simp [h₁, Var.map_add, Var.map_smul, GaussianReal, Real.norm_eq_abs, abs_mul, abs_of_nonneg,
          Real.exp_pos, Real.sqrt_eq_iff_sq_eq, sq_nonneg, add_nonneg, mul_self_nonneg]
