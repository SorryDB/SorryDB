  rw [h₂]
  have h₃ : (sSup (SetLike.coe D : Set (PersistenceSubmodule M))).x = ⊤ := by
    have h₄ : sSup (SetLike.coe D : Set (PersistenceSubmodule M)) = ⊤ := h₁
    simp [h₄]
  rw [h₃]
