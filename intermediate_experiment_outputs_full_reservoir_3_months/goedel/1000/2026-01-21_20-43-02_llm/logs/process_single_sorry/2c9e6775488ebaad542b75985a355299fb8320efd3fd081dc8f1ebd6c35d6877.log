lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  calc
    ⨆ p ∈ D, p x = ⨆ p ∈ (SetLike.coe D : Set (PersistenceSubmodule M)), (p x : Submodule K (M x)) := rfl
    _ = (⨆ p ∈ (SetLike.coe D : Set (PersistenceSubmodule M)), p) x := by
      rw [iSup_const]
      <;> simp [Submodule.eq_top_of_isBot]
      <;> aesop
    _ = (sSup (SetLike.coe D)) x := by
      simp [iSup]
    _ = ⊤ x := by
      rw [D.sSup_eq_top']
    _ = ⊤ := by simp
