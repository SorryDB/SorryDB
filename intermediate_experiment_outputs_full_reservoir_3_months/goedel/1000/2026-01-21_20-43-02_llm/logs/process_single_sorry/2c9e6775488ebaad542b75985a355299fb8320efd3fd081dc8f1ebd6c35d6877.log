  have h : (⨆ p ∈ D, p x) = ⊤ := by
    have h₁ : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
    have h₂ : sSup (SetLike.coe D) x = ⊤ x := by rw [h₁]
    have h₃ : (⨆ p ∈ D, p x) = sSup (SetLike.coe D) x := by
      simp [iSup_def, SetLike.coe_eq, Set.supₛ]
      <;>
      rfl
    have h₄ : sSup (SetLike.coe D) x = sSup (SetLike.coe D) x := rfl
    have h₅ : (⨆ p ∈ D, p x) = sSup (SetLike.coe D) x := by rw [h₃]
    have h₆ : sSup (SetLike.coe D) x = ⊤ x := by
      rw [h₂]
      <;>
