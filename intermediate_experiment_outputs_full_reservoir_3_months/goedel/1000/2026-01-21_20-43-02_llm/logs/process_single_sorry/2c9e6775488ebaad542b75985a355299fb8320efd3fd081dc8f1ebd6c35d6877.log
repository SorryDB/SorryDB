lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h : (⨆ p ∈ D, p x) = (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) := rfl
  rw [h]
  have h₁ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
  have h₂ : ForallOnSubmodule.map_SSup (M := M x) (fun m : PersistenceSubmodule M => m x) (Set.univ : Set (Stalk x M)) (sSupIndep (D : DirectSumDecomposition M)) = (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) := by
    simp [SetLike.coe_coe, Set.univ_insert]
    <;>
    (try simp_all [sSupIndep]) <;>
    (try rfl)
  have h₃ : ForallOnSubmodule.map_SSup (M := M x) (fun m : PersistenceSubmodule M => m x) (Set.univ : Set (Stalk x M)) (sSupIndep (D : DirectSumDecomposition M)) = (⊤ : Submodule K (M x)) := by
    have h₄ : ForallOnSubmodule(map    (fun m : ctwood/PersistenceSubmodule M => m x)    )    (⨆ p : p ∈ (D : Set (ctwood/PersistenceSubmodule M)), p)    (set.univ : set (M x)) = ⊤ := by
      -- Use the fact that the supremum of the decomposition is the entire space
      have h₅ : (⨆ p : p ∈ (D : Set (ctwood/PersistenceSubmodule M)), p) = ⊤ := by
        simpa [sSup_eq_top D] using h₁
      -- Map the supremum to the pointwise supremum
      have h₆ : ForallOnSubmodule.map_SSup (M := M x) (fun m : ctwood/PersistenceSubmodule M => m x) (set.univ : set (M x)) (sSupIndep (D : DirectSumDecomposition M)) = ⊤ := by
        rw [sSup_eq_iSup]
        <;> simp_all [h₅]
        <;> try rfl
        <;> try simp_all [iSup]
      exact h₆
    exact h₄
  have h₄ : (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) = ⊤ := by
    calc
      (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) = ForallOnSubmodule.map_SSup (M := M x) (fun m : PersistenceSubmodule M => m x) (Set.univ : Set (Stalk x M)) (sSupIndep (D : DirectSumDecomposition M)) := by
        rw [h₂]
      _ = ⊤ := by
        rw [h₃]
  exact h₄
