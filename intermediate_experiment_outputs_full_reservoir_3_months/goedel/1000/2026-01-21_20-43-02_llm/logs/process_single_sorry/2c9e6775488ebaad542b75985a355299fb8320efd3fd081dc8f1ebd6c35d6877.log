lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h : ⨆ p ∈ (SetLike.coe D), (p : (C ⥤ Module K)) x = ⊤ := by
    have h₁ : sSup (SetLike.coe D : Set (PersistenceSubmodule M)) = ⊤ := D.sSup_eq_top'
    have h₂ : (sSup (SetLike.coe D : Set (PersistenceSubmodule M)) : (C ⥤ Module K)) = ⊤ := by
      rw [h₁]
    -- Use the fact that the supremum of the direct sum decomposition is the entire module M
    -- and then take the pointwise supremum at each point x to get the whole module at that point.
    have h₃ : (⨆ p ∈ (SetLike.coe D), (p : (C ⥤ Module K)) x) =
      (sSup (SetLike.coe D : Set (PersistenceSubmodule M)) : (C ⥤ Module K)) x := by
      -- The pointwise supremum of the decomposition is the same as the supremum of the decomposition as a whole.
      simp [iSup_same]
      <;>
      simp_all [iSup_comp]
      <;>
      congr 1
      <;>
      ext
      <;>
      simp [Set.mem_setOf_eq]
      <;>
      aesop
    rw [h₃]
    -- Since the supremum is the whole module M, its value at x is the whole module at x.
    have h₄ : (sSup (SetLike.coe D : Set (PersistenceSubmodule M)) : (C ⥤ Module K)) x = ⊤ := by
      have h₅ : (sSup (SetLike.coe D : Set (PersistenceSubmodule M)) : (C ⥤ Module K)) = ⊤ := by
        simpa using h₂
      rw [h₅]
      <;>
      simp [Pi.top_apply]
    rw [h₄]
    <;>
    simp [Pi.top_apply]
  -- Since (p : (C ⥤ Module K)) x = p x, the desired result follows.
  simpa [SetLike.mem_coe] using h
