lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h : sSupIndep D := D.sSupIndep'
  have h₁ : sSup D = ⊤ := D.sSup_eq_top'
  have h₂ : ⨆ p ∈ D, p x = ⊤ := by
    have h₃ : ∀ (p : PersistenceSubmodule M), p ∈ D → p x ≤ ⨆ p ∈ D, p x := by
      intro p hp
      exact le_iSup₂_of_le p x (by aesop)
    -- We need to show that ⨆ p ∈ D, p x = ⊤, i.e., that it is equal to the top element of the lattice.
    -- Since sSup D = ⊤, we can use the fact that for any p ∈ D, p x is a subset of the supremum.
    have h₄ : (⨆ p ∈ D, p x) = (sSup D) x := by
