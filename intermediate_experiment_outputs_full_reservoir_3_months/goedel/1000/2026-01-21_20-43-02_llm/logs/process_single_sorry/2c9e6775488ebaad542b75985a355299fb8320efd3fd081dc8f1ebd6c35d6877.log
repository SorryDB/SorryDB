    (try simp_all [SetLike.coe_iSup, iSup_comm])
  have h₃ : ⨆ (p : PersistenceSubmodule M) (hp : p ∈ D.carrier), p x = ⨆ p ∈ D, p x := by
    -- The two sides are definitionally equal because D is coerced to its carrier set.
    simp [SetLike.coe_iSup]
