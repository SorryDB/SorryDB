lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  have h₁ : ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
    have h₂ : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P := hX
    have h₃ : ∃ (τ : ℕ → Ω → WithTop ι), IsLocalizingSequence 𝓕 τ P ∧ ∀ n, ∀ ω, Function.RightContinuous (fun x : ι => (X ⨅[τ n ω] x) ω) := by
      -- Extract the localizing sequence and the property from h₂
      refine ⟨h₂.localSeq, h₂.IsLocalizingSequence, fun n ω => _⟩
      -- Use the property of the stopped process
      have h₄ : (fun (X : ι → Ω → E) ↦ ∀ (ω : Ω), Function.RightContinuous (X · ω)) (stoppedProcess 𝓕 (fun i ω => X i ω) (τ := fun ω => h₂.localSeq n ω)) := by
        -- Apply the locally property to the stopped process
        exact h₂.stoppedProcess n
      -- Simplify the expression to get the desired property
      have h₅ : ∀ (ω : Ω), Function.RightContinuous (fun x : ι => (X ⨅[h₂.localSeq n ω] x) ω) := by
        simpa [stoppedProcess_indicator_comm] using h₄
      exact h₅ ω
    -- Obtain the localizing sequence and the property
    obtain ⟨τ, hτ, h₃⟩ := h₃
    -- Use the fact that the property holds for the stopped process to deduce it for the original process
    have h₄ : ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
      filter_upwards [hτ.tendsto_top] with ω hω
      have h₅ : tendsto (fun n : ℕ => τ n ω) atTop (nhdsAtTop ⊤) := by
        convert hω.liminf_eq le_rfl using 1
      have h₆ : ∀ n : ℕ, Function.RightContinuous (fun x : ι => (X ⨅[τ n ω] x) ω) := by
        intro n
        exact h₃ n ω
      -- Use the fact that the stopped process converges to the original process to deduce the property
      have h₇ : Function.RightContinuous (X · ω) := by
        have h₈ : ∀ n : ℕ, (X · ω) = (fun x : ι => (X ⨅[τ n ω] x) ω) := by
          intro n
          funext x
          simp [tau]
          <;>
          (try norm_num) <;>
          (try simp_all [hω]) <;>
          (try aesop)
          <;>
          (try
            {
              simp_all [hω]
              <;>
              aesop
            })
          <;>
          (try
            {
              simp_all [hω]
              <;>
              aesop
            })
          <;>
          (try
            {
              simp_all [hω]
              <;>
              aesop
            })
          <;>
          (try
            {
              simp_all [hω]
              <;>
              aesop
            })
        -- Use the fact that the stopped process converges to the original process to deduce the property
        have h₉ : Function.RightContinuous (X · ω) := by
          have h₁₀ : ∀ n : ℕ, Function.RightContinuous (fun x : ι => (X ⨅[τ n ω] x) ω) := by
            intro n
            exact h₃ n ω
          have h₁₁ : Function.RightContinuous (X · ω) := by
            -- Use the fact that the stopped process converges to the original process to deduce the property
            have h₁₂ : (X · ω) = (fun x : ι => (X ⨅[τ 0 ω] x) ω) := by
              exact h₈ 0
            rw [h₁₂]
            exact h₁₀ 0
          exact h₁₁
        exact h₉
      exact h₇
    exact h₄
  exact h₁
