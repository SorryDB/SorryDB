    let Y' := Field51_as_Nat proj.Y;
    let Z' := Field51_as_Nat proj.Z;
    X' % p = (X * T) % p ∧ Y' % p = (Y * Z) % p ∧ Z' % p = (Z * T) % p := by
    -- We know as_projective never fails, so we get a projective point directly.
    obtain ⟨proj, h_eq⟩ := q.as_projective_property
    -- We need to check that the returned projective point satisfies the conditions.
