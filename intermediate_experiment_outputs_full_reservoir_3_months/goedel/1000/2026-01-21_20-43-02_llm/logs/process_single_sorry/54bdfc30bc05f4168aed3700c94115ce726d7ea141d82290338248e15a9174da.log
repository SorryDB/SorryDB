let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let T := Field51_as_Nat q.T
let X' := Field51_as_Nat proj.X
let Y' := Field51_as_Nat proj.Y
let Z' := Field51_as_Nat proj.Z
X' % p = (X * T) % p ∧
Y' % p = (Y * Z) % p ∧
Z' % p = (Z * T) % p
:= by
  -- The as_projective function should return a projective point directly, so we can take the result as given.
  have h_main : ∃ (proj : ProjectivePoint), as_projective q = ok proj ∧
    let X := Field51_as_Nat q.X;
    let Y := Field51_as_Nat q.Y;
    let Z := Field51_as_Nat q.Z;
    let T := Field51_as_Nat q.T;
