theorem bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
  intro w args e h_not_lt
  intro h
  have h₁ : assert_bits args := h.1
  have h₂ : e = bits2num args := h.2
  have h₃ : e.eval.val < 2 ^ w := by
    have h₄ : e.eval.val = (bits2num args : ZMod p).val := by
      rw [h₂]
      <;> simp [Exp.eval]
    have h₅ : (bits2num args : ZMod p).val < 2 ^ w := by
      have h₆ : ∀ (b : ZMod p), b ∈ (Vector.toFinset args) → b = 0 ∨ b = 1 := by
        intro b hb
        have h₇ : assert_bits args = true := h₁
        simp [Vector.all, Finset.mem_coe] at h₇
        simp_all [assert_bits]
        <;>
        (try contradiction) <;>
        (try aesop)
      have h₇ : (bits2num args : ZMod p).val < 2 ^ w := by
        -- Use the fact that each bit is 0 or 1 to bound the value of bits2num
        have h₈ : ∀ (i : Fin w), (args i : ZMod p) = 0 ∨ (args i : ZMod p) = 1 := by
          intro i
          have h₉ : assert_bits args = true := h₁
          simp [Vector.all] at h₉
          simp_all [assert_bits]
          <;>
          (try contradiction) <;>
