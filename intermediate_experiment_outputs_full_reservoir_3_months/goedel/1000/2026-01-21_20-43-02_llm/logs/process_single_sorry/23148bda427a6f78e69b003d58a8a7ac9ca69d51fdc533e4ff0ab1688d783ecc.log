theorem H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by sorry
      _ ≤ (∑' m : (S₁ x), (m : ℝ)⁻¹) := by sorry
      _ ≤ (∏ p ∈ ⌊x⌋.natAbs.primesBelow, ∑' (k : ℕ), (↑p ^ k)⁻¹) := by
        have h₁ : (∑' (m : ↑(S₁ x)), (↑↑m : ℝ)⁻¹) ≤ ∏ p in ⌊x⌋.natAbs.primesBelow, ∑' (k : ℕ), (↑p ^ k : ℝ)⁻¹ := by
          calc
            (∑' (m : ↑(S₁ x)), (↑↑m : ℝ)⁻¹) = 0 := by
              have h₂ : ∀ m : ℕ, m ∈ S₁ x → (m : ℝ)⁻¹ = 0 := by
                intro m hm
                have h₃ : m ∈ S₁ x := hm
                simp only [Set.mem_setOf_eq] at h₃
                by_cases h₄ : m = 0
                · simp_all
                · exfalso
                  have h₅ := h₃ 2 (by decide)
                  have h₆ : 2 ∣ m → 2 ≤ x := h₅
                  have h₇ : m ≠ 0 := h₄
                  have h₈ : 2 ∣ 0 := by simp
                  have h₉ : ¬(2 : ℕ) ∣ m := by
                    have h₁₀ : m ≠ 0 := h₄
                    have h₁₁ : m ∈ S₁ x := h₃
                    simp only [Set.mem_setOf_eq] at h₁₁
                    have h₁₂ := h₁₁ 2 (by decide)
                    have h₁₃ : 2 ∣ m → 2 ≤ x := h₁₂
                    by_contra h₁₄
                    have h₁₅ : 2 ∣ m := by simpa using h₁₄
                    have h₁₆ : (2 : ℕ) ≤ x := h₁₃ h₁₅
                    norm_num at hxlt hxge ⊢
                    <;>
                    (try norm_num) <;>
                    (try linarith) <;>
                    (try omega) <;>
                    (try
                      {
                        cases n <;>
                        (try norm_num at hxge hxlt ⊢) <;>
                        (try linarith) <;>
                        (try omega)
                      })
                  exfalso
                  apply h₉
                  <;>
                  (try omega) <;>
                  (try
                    {
                      simp_all [Nat.dvd_iff_mod_eq_zero]
                      <;>
                      norm_num <;>
                      linarith
                    })
              have h₃ : ∀ m : ↑(S₁ x), (↑↑m : ℝ)⁻¹ = 0 := by
                intro m
                have h₄ : (m : ℕ) ∈ S₁ x := by
                  exact Set.mem_setOf_eq.mpr m.prop
                have h₅ : (m : ℕ) ≠ 0 := by
                  intro h₆
                  have h₇ : (m : ℕ) = 0 := h₆
                  have h₈ : (m : ℕ) ∈ S₁ x := h₄
                  have h₉ : ∀ p : ℕ, Nat.Prime p → p ∣ (m : ℕ) → p ≤ x := by
                    intro p hp hpdvd
                    exact Set.mem_setOf_eq.mp h₈ p hp hpdvd
                  have h₁₀ := h₉ 2 (by decide)
                  have h₁₁ : ¬(2 : ℕ) ∣ (m : ℕ) := by
                    simp_all [h₇]
                    <;>
                    norm_num <;>
                    omega
                  have h₁₂ : 2 ∣ (m : ℕ) → 2 ≤ x := h₁₀
                  have h₁₃ : ¬(2 : ℕ) ∣ (m : ℕ) := h₁₁
                  simp_all
                  <;>
                  omega
                have h₆ : ((m : ℕ) : ℝ)⁻¹ = 0 := h₂ (m : ℕ) (by
                  exact Set.mem_setOf_eq.mpr m.prop)
                simpa using h₆
              have h₄ : ∑' (m : ↑(S₁ x)), (↑↑m : ℝ)⁻¹ = 0 := by
                have h₅ : ∀ m : ↑(S₁ x), (↑↑m : ℝ)⁻¹ = 0 := h₃
                simp_all [tsum_congr]
                <;>
                simp_all [tsum_zero]
              exact h₄
            _ ≤ ∏ p in ⌊x⌋.natAbs.primesBelow, ∑' (k : ℕ), (↑p ^ k : ℝ)⁻¹ := by
              have h₂ : ∏ p in ⌊x⌋.natAbs.primesBelow, ∑' (k : ℕ), (↑p ^ k : ℝ)⁻¹ ≥ 0 := by
                apply Finset.prod_nonneg
                intro p _
                apply tsum_nonneg
                intro k
                positivity
              linarith
        exact h₁
