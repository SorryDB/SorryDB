                        linarith)]
                  linarith
                linarith
              linarith
            have h₁₁ : (k : ℝ)⁻¹ ≥ Real.log (1 + (1 : ℝ) / k) := by
              have h₁₂ : (k : ℝ)⁻¹ = (1 : ℝ) / k := by
                field_simp
                <;> norm_cast
              rw [h₁₂]
