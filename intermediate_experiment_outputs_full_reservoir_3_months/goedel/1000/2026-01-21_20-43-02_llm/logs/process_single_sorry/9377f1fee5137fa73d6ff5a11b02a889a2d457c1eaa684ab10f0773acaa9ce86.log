      "\n  refine' (measurable_const.smul _)\n  -- The first factor `1 / Real.sqrt (n : ℝ)` is a constant, so it is measurable.\n  -- We need to prove that `wignerMatrixMap n` is measurable.\n  have : Measurable (wignerMatrixMap n) := by\n    classical\n    apply measurable_of_isOpen\n    intro s\n    have h : IsOpen s := by\n      infer_instance\n    simp_all [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, Matrix.of_apply]\n    <;>\n    (try decide) <;>\n    (try clear *) <;>\n    (try simp_all [measurable_of_isOpen]) <;>\n    (try aesop) <;>\n    (try norm_num) <;>\n    (try\n      {\n        refine' isOpen_pi.2 fun i => _\n        exact h\n      }) <;>\n    (try\n      {\n        cases n <;> simp_all [Fin.ext_iff, Fin.val_zero, Fin.val_succ]\n        <;>\n        (try aesop) <;>\n        (try norm_num) <;>\n        (try decide)\n      })\n  -- Since `wignerMatrixMap n` is measurable, the scaled version is also measurable.\n  <;> simp_all [wignerMatrixMapScaled]\n  <;>\n  (try aesop) <;>\n  (try norm_num) <;>\n  (try decide)",
