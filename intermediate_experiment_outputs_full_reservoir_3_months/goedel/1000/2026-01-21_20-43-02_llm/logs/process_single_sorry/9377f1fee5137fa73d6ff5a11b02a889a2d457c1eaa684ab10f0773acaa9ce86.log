        {\n                        simp_all [Fin.ext_iff, Fin.val_mk]\n                        <;>\n                        omega\n                      }) : Index n) : ℝ) := by\n              -- The projection is measurable because the space is measurable.\n              apply measurable_fst\n            -- The rest of the function is measurable because it is a combination of measurable functions.\n            have h₅₂ : Measurable (fun (ω : WignerSpace n) ↦ (if i = j then ω ⟨(i, i), by simp [Fin.ext_iff, le_rfl]⟩ else if i < j then ω ⟨(i, j), by\n                  have h₅₃ : i < j := by assumption\n                  exact le_of_lt h₅₃⟩ else have h₅₄ : j < i := by\n                    by_cases h₅₅ : i < j\n                    · exfalso\n                      linarith\n                    · -- If i ≥ j and i ≠ j, then j < i\n                      have h₅₆ : ¬(i < j) := h₅₅\n                      have h₅₇ : i ≠ j := by\n                        intro h₅₈\n                        simp_all\n                      have h₅₈ : (i : ℕ) < n := i.is_lt\n                      have h₅₉ : (j : ℕ) < n := j.is_lt\n                      have h₆₀ : (i : ℕ) ≠ (j : ℕ) := by\n                        intro h₆₁\n                        apply h₅₇\n                        simp_all [Fin.ext_iff]\n                      have h₆₁ : (i : ℕ) > (j : ℕ) := by\n                        omega\n                      have h₆₂ : j < i := by\n                        simpa [Fin.ext_iff] using lt_of_not_ge (fun h₆₃ => by\n                          simp_all [Fin.ext_iff]\n                          <;> omega)\n                      exact h₆₂\n                  have : (j, i) ∈ Set.Iio (i) ×ˢ Set.Ioi (j) := by\n                    simp_all [Set.mem_Iio, Set.mem_Ioi]\n                    <;>\n                    (try omega) <;>\n                    (try\n                      {\n                        simp_all [Fin.ext_iff, Fin.val_mk]\n                        <;>\n                        omega\n               