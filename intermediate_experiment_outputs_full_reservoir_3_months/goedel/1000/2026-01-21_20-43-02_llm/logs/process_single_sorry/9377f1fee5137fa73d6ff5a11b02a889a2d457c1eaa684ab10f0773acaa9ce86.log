           <;>\n                      (try omega) <;>\n                      (try\n                        {\n                          simp_all [Fin.ext_iff, Fin.val_mk]\n                          <;>\n                          omega\n                        })\n                      <;>\n                      (try\n                        {\n                          simp_all [Fin.ext_iff, Fin.val_mk]\n                          <;>\n                          omega\n                        }) : Set (Fin n × Fin n)) Then ω ⟨(j, i), by\n                  have h₅₄ : j < i := by assumption\n                  exact le_of_lt h₅₄⟩ else ω ⟨(j, i), by\n                  have h₅₄ : j < i := by assumption\n                  exact le_of_lt h₅₄⟩) : ℝ) := by\n                -- Use the fact that each case is measurable and the conditions are measurable.\n                split_ifs <;>\n                (try {\n                  -- Case: i = j\n                  have h₅₆ : i = j := by assumption\n                  simp_all [h₅₆]\n                  <;>\n                  apply measurable_fst\n                }) <;>\n                (try {\n                  -- Case: i < j\n                  have h₅₆ : i < j := by assumption\n                  simp_all [h₅₆]\n                  <;>\n                  apply measurable_fst\n                }) <;>\n                (try {\n                  -- Case: j < i\n                  have h₅₆ : j < i := by assumption\n                  simp_all [h₅₆]\n                  <;>\n                  apply measurable_fst\n                }) <;>\n                (try {\n                  -- Default case\n                  simp_all\n                  <;>\n                  apply measurable_fst\n                })\n              exact h₅₃\n            -- Since all cases are measurable, the entire function is measurable.\n            simp_all [wignerMatrixEntryFunction]\n            <;>\n            aesop\n          -- Each entry is measurable, so the matrix is