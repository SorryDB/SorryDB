      "\n  have h₁ : Measurable (wignerMatrixMap n) := by\n    -- Prove that wignerMatrixMap n is measurable\n    have h₂ : Measurable (wignerMatrixMap n) := by\n      -- Use the fact that the Wigner matrix entries are measurable\n      have h₃ : ∀ (i j : Fin n), Measurable fun ω : WignerSpace n ↦ (wignerMatrixEntryFunction ω i j : ℝ) := by\n        intro i j\n        apply Measurable.if <;>\n        (try decide) <;>\n        (try\n          {\n            apply Measurable.if <;>\n            (try decide) <;>\n            (try\n              {\n                simp [wignerMatrixEntryFunction]\n                <;>\n                (try\n                  {\n                    apply Measurable.comp (inferInstance : Measurable (WignerSpace n)) (measurable_pi (fun _ => measurable_id))\n                    <;>\n                    simp [wignerMeasureDist]\n                    <;>\n                    (try aesop)\n                  })\n                <;>\n                (try\n                  {\n                    apply Measurable.comp (inferInstance : Measurable (WignerSpace n)) (measurable_pi (fun _ => measurable_id))\n                    <;>\n                    simp [wignerMeasureDist]\n                    <;>\n                    (try aesop)\n                  })\n              })\n          }) <;>\n        (try\n          {\n            simp [wignerMatrixEntryFunction]\n            <;>\n            (try\n              {\n                apply Measurable.comp (inferInstance : Measurable (WignerSpace n)) (measurable_pi (fun _ => measurable_id))\n                <;>\n                simp [wignerMeasureDist]\n                <;>\n                (try aesop)\n              })\n          }) <;>\n        (try\n          {\n            simp_all [wignerMatrixEntryFunction]\n            <;>\n            (try\n              {\n                apply Measurable.comp (inferInstance : Measurable (WignerSpace n)) (measurable_pi (fun _ => measurable_id))\n                <;>\n                simp [wignerMeasureDist]\n                <;>\n                (try aesop)\n              })\n          })\n      -- Use the fact that the matrix is measurable if all its entries are measurable\n      have h₄ : Measurable (wignerMatrixMap n) := by\n        -- Use the fact that the matrix is measurable if all its entries are measurable\n        have h₅ : Measurable (wignerMatrixMap n) := by\n          -- Use the fact that the matrix is measurable if all its entries are measurable\n          apply Matrix.measurable\n          intro i j\n          have h₆ := h₃ i j\n          simpa [wignerMatrixMap, wignerMatrixMap'] using h₆\n        exact h₅\n      exact h₄\n    exact h₂\n  \n  -- Use the fact that scaling a measurable function by a constant is measurable\n  have h₂ : Measurable fun ω : WignerSpace n ↦ (1 / Real.sqrt (n : ℝ) : ℝ) • (wignerMatrixMap n ω) := by\n    -- Scale the matrix by the scalar (1 / Real.sqrt (n : ℝ))\n    have h₃ : Measurable (fun x : Matrix (Fin n) (Fin n) ℝ ↦ (1 / Real.sqrt (n : ℝ) : ℝ) • x) := by\n      -- The scalar multiplication by a constant is measurable\n      apply Continuous.measurable\n      continuity\n    -- Compose the measurable functions to get the final result\n    have h₄ : Measurable (wignerMatrixMap n) := h₁\n    apply Measurable.comp h₃ h₄\n  -- Relate the scaled matrix to the original scaled matrix map\n  have h₅ : (fun ω : WignerSpace n ↦ (1 / Real.sqrt (n : ℝ) : ℝ) • (wignerMatrixMap n ω)) = wignerMatrixMapScaled n := by\n    funext ω\n    rfl\n  rw [h₅] at h₂\n  exact h₂",
