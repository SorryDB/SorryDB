      "\n  have h : Measurable (wignerMatrixMap n) := wignerMatrixMapMeasurable n\n  have h₁ : Measurable (fun (ω : WignerSpace n) => (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) := by\n    -- Use the fact that scalar multiplication and matrix construction are measurable\n    have h₂ : Measurable (fun (ω : WignerSpace n) => (wignerMatrixMap' ω)) := h\n    -- Show that scalar multiplication is measurable\n    have h₃ : Measurable (fun (ω : WignerSpace n) => (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) := by\n      -- Use the fact that scalar multiplication is measurable\n      apply Measurable.smul _\n      <;>\n      (try simp_all [wignerMatrixMap, wignerMatrixMap']) <;>\n      (try exact continuous_const.measurable) <;>\n      (try exact h₂)\n    exact h₃\n  -- Combine the above results to get the final measurability\n  simp_all [wignerMatrixMapScaled]\n  <;>\n  (try aesop)\n  <;>\n  (try exact h₁)",
