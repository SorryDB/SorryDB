by\n          simpa using h₈\n      -- Use the fact that the function is bounded above by another function to apply the integral comparison.\n      exact h₅\n    -- Use the fact that the function is bounded above by another function to apply the integral comparison.\n    exact h₄\n  -- Use the fact that the function is bounded above by another function to apply the integral comparison.\n  exact h₂",
