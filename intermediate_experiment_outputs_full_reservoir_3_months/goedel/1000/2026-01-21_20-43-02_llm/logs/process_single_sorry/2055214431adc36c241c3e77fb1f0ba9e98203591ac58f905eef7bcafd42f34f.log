      "\n    -- Use the fact that the integral of the absolute value is less than or equal to the integral of the function\n    refine' calc\n      _ = ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| := rfl\n      _ ≤ ∫ (t : ℝ) in 0..1, (∫ (s : ℝ) in 0..t, |g'' s|) := by\n        -- Apply the lemma that each term in the integral satisfies the inequality\n        have h₁ : ∀ (t : ℝ) (_ : t ∈ Set.Icc 0 1), |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n          intro t ht\n          have h₂ : 0 ≤ t := by\n            exact le_of_mem_Icc ht.1\n          have h₃ : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := abs_int_le_int_abs h₂\n          exact h₃\n        -- Use the comparison property of integrals\n        exact intervalIntegral.integral_mono_on (by\n          -- Prove that the function is integrable\n          apply Continuous.intervalIntegrable\n          continuity) (by\n          apply Continuous.intervalIntegrable\n          continuity) (by\n            intro t ht\n            exact h₁ t ⟨by\n              -- Prove that t is in [0,1]\n              linarith [ht.1, ht.2],\n              linarith [ht.1, ht.2]⟩)\n      _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := rfl",
      "\n    -- For any t ∈ [0, 1], we have |∫₀ᵗ g''(s) ds| ≤ ∫₀ᵗ |g''(s)| ds by abs_int_le_int_abs\n    -- Since t ∈ [0, 1] implies t ≥ 0, we can use the previous lemma directly\n    -- Apply the monotonicity of the integral over [0, 1]\n    calc\n      ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n        -- Use intervalIntegral.integral_mono_on with h₁ := Continuous.intervalIntegrable g''_cont 0 1 and h₂ := Continuous.intervalIntegrable (fun t => ∫ s in 0..t, |g'' s|) 0 1\n        intervalIntegral.integral_mono_on (by\n          -- Prove that t ↦ |∫₀ᵗ g''(s) ds| is continuous\n          continuity\n          ) (by\n          -- Prove that t ↦ ∫₀ᵗ |g''(s)| ds is continuous\n          continuity) (Set.Icc 0 1) (fun t ht => by\n          -- For t ∈ [0, 1], we have t ≥ 0\n          have ht' : 0 ≤ t := by exact ht.1\n          -- Using abs_int_le_int_abs, we get |∫₀ᵗ g''(s) ds| ≤ ∫₀ᵗ |g''(s)| ds\n          exact abs_int_le_int_abs ht'\n          )\n      _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by rfl",
      "\n  have h₁ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n    intro t ht\n    have h₂ : 0 ≤ t := by exact ht.1\n    exact abs_int_le_int_abs h₂\n  -- Use the monotonicity of integration to compare the integrals\n  calc\n    ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      -- Apply the inequality to each t in [0,1] and integrate\n      refine' intervalIntegral.integral_mono_on (by continuity) (by continuity) (Set.Icc_subset_Icc_left (by norm_num)) _\n      intro t ht\n      exact h₁ t ht\n    _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by rfl",
      "\n    have h₀ : ∀ (t : ℝ), 0 ≤ t → |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      exact abs_int_le_int_abs ht\n    have h₁ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      refine' intervalIntegral.integral_mono_on _ _ _\n      · intro t ht\n        have h₂ : 0 ≤ t := by\n          norm_num at ht ⊢\n          <;> linarith\n        exact abs_nonneg _\n      · intro t ht\n        have h₂ : 0 ≤ t := by\n          norm_num at ht ⊢\n          <;> linarith\n        exact h₀ t h₂\n      · apply Continuous.intervalIntegrable\n        have h₃ : Continuous (fun (t : ℝ) ↦ |∫ (s : ℝ) in 0..t, g'' s|) := by\n          have h₄ : Continuous (fun (t : ℝ) ↦ ∫ (s : ℝ) in 0..t, g'' s) := by\n            apply Continuous.intervalIntegral\n            <;> (try simp_all)\n            <;> (try continuity)\n            <;> (try apply Continuous.intervalIntegrable)\n            <;> (try apply Continuous.continuousOn)\n            <;> (try apply g''_cont)\n          exact h₄.abs\n        exact h₃\n      · apply Continuous.intervalIntegrable\n        have h₃ : Continuous (fun (t : ℝ) ↦ ∫ (s : ℝ) in 0..t, |g'' s|) := by\n          have h₄ : Continuous (fun (s : ℝ) ↦ |g'' s|) := by\n            apply Continuous.abs\n            exact g''_cont\n          apply Continuous.intervalIntegral\n          <;> (try simp_all)\n          <;> (try continuity)\n          <;> (try apply Continuous.intervalIntegrable)\n          <;> (try apply Continuous.continuousOn)\n          <;> (try apply h₄)\n        exact h₃\n      <;> norm_num\n    exact h₁\n\n  sorry",
      "\n    have h₁ : ∀ t ∈ Set.Ioc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      have ht' : 0 ≤ t := by\n        norm_num at ht ⊢\n        linarith [ht.1]\n      have h₂ : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := abs_int_le_int_abs ht'\n      exact h₂\n    -- Use the fact that the integral of the absolute value is greater than or equal to the\n    -- absolute value of the integral to bound the integral from 0 to 1\n    have h₂ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      -- Use the fact that the function is continuous to apply the integral comparison\n      have h₃ : ContinuousOn (fun t : ℝ => |∫ (s : ℝ) in 0..t, g'' s|) (Set.Icc 0 1) := by\n        apply ContinuousOn.abs\n        apply ContinuousOn.intervalIntegral _ continuousOn_const\n        <;> (try continuity) <;> (try apply g''_cont.continuousOn)\n        <;> simp_all\n        <;> norm_num\n      have h₄ : ContinuousOn (fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s|) (Set.Icc 0 1) := by\n        apply ContinuousOn.intervalIntegral _ continuousOn_const\n        <;> (try continuity) <;> (try apply (continuous_abs.comp g''.continuous).continuousOn)\n        <;> simp_all\n        <;> norm_num\n      -- Use the fact that the function is continuous to apply the integral comparison\n      refine' (intervalIntegral.integral_mono_on _ _ (by norm_num) (by norm_num)).trans _\n      <;> (try simp_all [h₁])\n      <;> (try\n        {\n          refine' (by\n            intro x hx\n            specialize h₁ x ⟨by linarith [hx.1], by linarith [hx.2]⟩\n            linarith) |>.trans (by simp_all [h₁]))\n        })\n      <;> (try\n        {\n          refine' le_of_eq _\n          <;> simp_all [h₁]\n          <;> aesop\n        })\n      <;>\n      (try\n        {\n          refine' (by\n            simp_all [h₁]\n            <;> norm_num\n            ) |>.trans (by simp_all [h₁]))\n        })\n    exact h₂\n  sorry",
      "\n    have h₁ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      have h₂ : 0 ≤ t := by exact ht.1\n      exact abs_int_le_int_abs h₂\n    -- Use the fact that the integral of a smaller function is smaller\n    have h₂ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      -- Use the fact that the integral of a smaller function is smaller\n      refine' intervalIntegral.integral_mono_on (by continuity) (by\n        intro t ht\n        have h₃ : 0 ≤ t := by exact (Set.mem_Icc.mp ht).1\n        have h₄ : t ≤ 1 := by exact (Set.mem_Icc.mp ht).2\n        have h₅ : ContinuousOn (fun s : ℝ => |g'' s|) (Set.Icc 0 t) := by\n          apply ContinuousOn.abs\n          exact g''_cont.continuousOn\n        -- Use the fact that the integral of a smaller function is smaller\n        have h₆ : ContinuousOn (fun s : ℝ => g'' s) (Set.Icc 0 t) := by\n          exact g''_cont.continuousOn\n        -- Use the fact that the integral of a smaller function is smaller\n        exact h₁ t ⟨by linarith, by linarith⟩) (Set.Icc 0 1)\n      <;> simp_all [Set.Icc, le_of_lt]\n      <;> norm_num\n      <;> linarith\n    exact h₂",
      "\n    have h₁ : ∀ t ∈ Set.Icc 0 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      have ht' : 0 ≤ t := by exact ht.1\n      exact abs_int_le_int_abs ht'\n    -- Use the fact that the integral of the absolute value is bounded by the integral of the function\n    calc\n      ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s|\n        = ∫ (t : ℝ) in (0 : ℝ)..(1 : ℝ), |∫ (s : ℝ) in 0..t, g'' s| := by rfl\n      _ ≤ ∫ (t : ℝ) in (0 : ℝ)..(1 : ℝ), ∫ (s : ℝ) in 0..t, |g'' s| := by\n        -- Apply the integral monotonicity to the function and its absolute value\n        refine' intervalIntegral.integral_mono_on (by\n          -- Prove that the function is continuous on [0, 1]\n          have h₂ : Continuous (fun t : ℝ => |∫ (s : ℝ) in 0..t, g'' s|) := by\n            apply Continuous.abs\n            exact Continuous.intervalIntegral_of_continuous_of_le (continuous_const) g''_cont (by norm_num)\n          exact h₂) (by\n          -- Prove that the absolute value is continuous on [0, 1]\n          have h₃ : Continuous (fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s|) := by\n            apply Continuous.intervalIntegral_of_continuous_of_le\n            · exact continuous_const\n            · exact Continuous.abs g''_cont\n            · norm_num\n          exact h₃) (Set.Icc 0 1) h₁\n      _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by rfl",
      "\n    have h₁ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      have h₂ : 0 ≤ t := by\n        exact ht.1\n      exact abs_int_le_int_abs h₂\n    -- Use the fact that the integral of the absolute value is greater than or equal to the absolute value of the integral\n    have h₂ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      -- Apply the integral comparison\n      have h₃ : ContinuousOn (fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s|) (Set.Icc 0 1) := by\n        -- The function is continuous on [0,1]\n        have h₄ : Continuous (fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s|) := by\n          -- The function is continuous\n          apply Continuous.intervalIntegral_comp_right\n          <;> (try norm_num)\n          <;> (try exact g''_cont)\n          <;> (try continuity)\n          <;> (try\n            {\n              apply Continuous.intervalIntegrable\n              <;>\n              (try continuity)\n              <;>\n              (try simp_all [g''_cont])\n              <;>\n              (try norm_num)\n            })\n          <;> (try\n            {\n              norm_num\n            })\n          <;> (try\n            {\n              linarith\n            })\n        exact h₄.continuousOn\n      have h₄ : ContinuousOn (fun t : ℝ => |∫ (s : ℝ) in 0..t, g'' s|) (Set.Icc 0 1) := by\n        -- The function is continuous on [0,1]\n        have h₅ : Continuous (fun t : ℝ => |∫ (s : ℝ) in 0..t, g'' s|) := by\n          -- The function is continuous\n          apply Continuous.abs\n          apply Continuous.intervalIntegral_comp_right\n          <;> (try norm_num)\n          <;> (try exact g''_cont)\n          <;> (try continuity)\n          <;> (try\n            {\n              apply Continuous.intervalIntegrable\n              <;>\n              (try continuity)\n              <;>\n              (try simp_all [g''_cont])\n              <;>\n              (try norm_num)\n            })\n          <;> (try\n            {\n              norm_num\n            })\n          <;> (try\n            {\n              linarith\n            })\n        exact h₅.continuousOn\n      -- Use the fact that the integral of the absolute value is greater than or equal to the absolute value of the integral\n      have h₅ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n        -- Apply the integral comparison\n        calc\n          ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n            -- Use the fact that the integral of the absolute value is greater than or equal to the absolute value of the integral\n            have h₆ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n              intro t ht\n              have h₇ : 0 ≤ t := by\n                exact ht.1\n              exact abs_int_le_int_abs h₇\n            -- Use the fact that the integral of the absolute value is greater than or equal to the absolute value of the integral\n            exact intervalIntegral.integral_mono_on (by\n              -- The function is continuous on [0,1]\n              apply Continuous.intervalIntegrable\n              <;>\n              (try continuity)\n              <;>\n              (try simp_all [g''_cont])\n              <;>\n              (try norm_num)) (by\n              -- The function is continuous on [0,1]\n              apply Continuous.intervalIntegrable\n              <;>\n              (try continuity)\n              <;>\n              (try simp_all [g''_cont])\n              <;>\n              (try norm_num)) (by\n              -- The function is continuous on [0,1]\n              intro x hx\n              exact h₆ x ⟨by linarith [hx.1, hx.2], by linarith [hx.1, hx.2]⟩) (by\n              -- The interval is [0,1]\n              norm_num)\n          _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by rfl\n      exact h₅\n    exact h₂\n  \n  sorry",
      "\n    have h₃ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in (0 : ℝ)..t, g'' s| ≤ ∫ (s : ℝ) in (0 : ℝ)..t, |g'' s| := by\n      intro t ht\n      have h₄ : 0 ≤ t := by exact ht.1\n      have h₅ : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := abs_int_le_int_abs h₄\n      simpa using h₅\n    have h₄ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      calc\n        _ = ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| := rfl\n        _ ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n          -- Use the fact that the integrand on the LHS is less than or equal to the integrand on the RHS\n          refine' intervalIntegral.integral_mono_on (by norm_num) (by norm_num) _\n          intro t ht\n          have h₅ : t ∈ Set.Icc (0 : ℝ) 1 := by\n            constructor <;> linarith [ht.1, ht.2]\n          exact h₃ t h₅\n        _ = ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := rfl\n    exact h₄\n  exact int_abs_int_le_int_int_abs",
      "\n    have h₁ : (∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s|) ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      have h₂ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n        intro t ht\n        have ht' : 0 ≤ t := by\n          simp [Set.mem_Icc] at ht\n          linarith\n        exact abs_int_le_int_abs ht'\n      have h₃ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n        -- Use the fact that the integral of a smaller function is smaller\n        have h₄ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n          -- Use the fact that the integral of a smaller function is smaller\n          refine' intervalIntegral.integral_mono_on (by continuity) (by\n            have h₅ : Continuous fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s| := by\n              sorry\n            continuity) (Set.Icc 0 1) _\n          intro t ht\n          exact h₂ t ht\n        exact h₄\n      exact h₃\n    exact h₁\n\n  sorry",
      "\n      apply intervalIntegral.integral_mono_on (by norm_num) (by norm_num) (fun t ht => ?_)\n      · -- Prove that the function is integrable\n        refine' Continuous.intervalIntegrable _ 0 1 _\n        exact Continuous.comp (continuous_abs) (Continuous.intervalIntegrable (by\n          -- Prove that the inner integral is continuous\n          have h₁ : Continuous fun (t : ℝ) => ∫ (s : ℝ) in 0..t, g'' s := by\n            -- Use the fact that g'' is continuous and the integral of a continuous function is continuous\n            have h₂ : Continuous g'' := by assumption\n            have h₃ : Continuous (fun (t : ℝ) => ∫ (s : ℝ) in 0..t, g'' s) := by\n              apply Continuous.intervalIntegral\n              <;> simp_all [continuous_const]\n              <;> try continuity\n              <;> try exact continuous_id\n            exact h₃\n          -- Compose with abs to get continuity of |∫ g'' s|\n          exact Continuous.abs h₁) 0 1)\n      · -- Prove that the function is integrable\n        refine' Continuous.intervalIntegrable _ 0 1 _\n        -- Prove that the double integral is continuous\n        have h₁ : Continuous (fun (t : ℝ) => ∫ (s : ℝ) in 0..t, |g'' s|) := by\n          -- Use the fact that |g'' s| is continuous and the integral of a continuous function is continuous\n          have h₂ : Continuous (fun s : ℝ => |g'' s|) := by\n            exact Continuous.abs (by assumption)\n          have h₃ : Continuous (fun (t : ℝ) => ∫ (s : ℝ) in 0..t, |g'' s|) := by\n            apply Continuous.intervalIntegral\n            <;> simp_all [continuous_const]\n            <;> try continuity\n            <;> try exact continuous_id\n          exact h₃\n        exact h₁\n      · -- Prove that |∫ g'' s| ≤ ∫ |g'' s|\n        intro t ht\n        have h₁ : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n          apply abs_int_le_int_abs\n          <;> (try norm_num at ht ⊢) <;>\n            (try linarith) <;>\n            (try\n              {\n                simp_all [intervalIntegral.integral_const]\n                <;>\n                linarith\n              })\n        exact h₁",
      "\n    refine' intervalIntegral.integral_mono_on (by norm_num) (by norm_num) (fun t ht => _)\n    have h₁ : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := abs_int_le_int_abs (by linarith [ht.1, ht.2])\n    simpa using h₁\n\n  sorry",
      "\n    have h₁ : ∀ (t : ℝ), 0 ≤ t → |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := abs_int_le_int_abs\n    have h₂ : (∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ) ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      have h₃ : ∀ (t : ℝ), t ∈ Set.Icc 0 1 → |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n        intro t ht\n        exact h₁ t (by exact ht.1)\n      have h₄ : (∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ) ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n        -- Use the fact that each term is less than or equal to apply the integral inequality\n        refine' intervalIntegral.integral_mono_on (by\n          -- Prove that the function is integrable\n          apply Continuous.intervalIntegrable\n          exact Continuous.abs (by\n            -- Prove that the inner integral is continuous\n            have h₅ : Continuous fun t : ℝ => ∫ (s : ℝ) in 0..t, g'' s := by\n              apply Continuous.intervalIntegral_comp_right\n              exact g''_cont.continuousOn\n            exact h₅\n          )\n        ) (by\n          -- Prove that the function is integrable\n          apply Continuous.intervalIntegrable\n          intro t ht\n          apply Continuous.intervalIntegrable\n          exact Continuous.abs g''_cont\n        ) (Set.Icc 0 1) (by\n          -- Prove that each term is less than or equal to within the interval\n          intro t ht\n          exact h₃ t ht\n        )\n      exact h₄\n    exact h₂\n  sorry",
      "\n    have h₁ : ∀ t ∈ Set.Icc (0 : ℝ) 1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by\n      intro t ht\n      have h₂ : 0 ≤ t := by exact ht.1\n      have h₃ : t ≤ 1 := by exact ht.2\n      exact abs_int_le_int_abs h₂\n    -- Apply the monotonicity of integration\n    have h₂ : ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by\n      apply intervalIntegral.integral_mono_on (by continuity) (by\n        -- Show that the integral of |g''| is continuous\n        have h₃ : Continuous (fun t : ℝ => ∫ (s : ℝ) in 0..t, |g'' s|) := by\n          -- Since g'' is continuous, |g''| is continuous, and thus the integral is continuous\n          have h₄ : Continuous g'' := by sorry\n          have h₅ : Continuous (fun s : ℝ => |g'' s|) := by sorry\n          -- Use the fact that the integral of a continuous function is continuous\n          apply Continuous.intervalIntegral_comp_continuous\n          <;> continuity\n        continuity\n      ) (Set.Icc 0 1)\n      -- Use the fact that for each t, |∫ g''| ≤ ∫ |g''|\n      intro t ht\n      exact h₁ t ht\n    exact h₂\n\n  sorry",
