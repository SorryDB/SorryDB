          _ = G(V, σ p) := by
            have h₄ : (map (fun ω : Ω => (G ω)ᶜ) P) = G(V, σ p) := by
              -- Use the fact that the complement of a binomial random graph with parameter p
              -- is a binomial random graph with parameter 1 - p
              have h₅ : (map (fun ω : Ω => (G ω)ᶜ) P) = map (fun G : SimpleGraph V => Gᶜ) (G(V, p)) := by
                calc
                  (map (fun ω : Ω => (G ω)ᶜ) P) = map (fun ω : Ω => (G ω)ᶜ) P := rfl
                  _ = map (fun G : SimpleGraph V => Gᶜ) (map G P) := by
