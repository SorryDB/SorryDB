theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have h_main : ∀ n : ℕ, 4 ≤ n → n ^ 2 ≤ n ! := by
    intro n hn
    induction' hn with n hn IH
    · -- Base case: n = 4
      norm_num [Nat.factorial]
    · -- Inductive step: assume true for n, prove for n + 1
      cases n with
      | zero => contradiction -- n cannot be zero since hn : 4 ≤ n
      | succ n =>
        cases n with
        | zero => contradiction -- n cannot be one since hn : 4 ≤ n
        | succ n =>
          cases n with
          | zero => contradiction -- n cannot be two since hn : 4 ≤ n
          | succ n =>
            cases n with
            | zero => contradiction -- n cannot be three since hn : 4 ≤ n
            | succ n =>
              simp_all [Nat.factorial, Nat.pow_succ, Nat.mul_assoc]
              <;>
                ring_nf at *
              <;>
                nlinarith [Nat.mul_le_mul_left (n + 4) (by nlinarith : (n + 4 : ℕ) ≤ (n + 4 : ℕ)),
                  Nat.mul_le_mul_left (n + 4) (Nat.zero_le (n + 4))]
  have h₁ : n ^ 2 ≤ n ! := h_main n h₀
  exact h₁
``` 

