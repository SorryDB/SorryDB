```lean
theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have h_base : 4 ^ 2 ≤ 4 ! := by
    norm_num [Nat.factorial]
    <;> decide
  
  have h_inductive_step : ∀ k : ℕ, 4 ≤ k → k ^ 2 ≤ k ! → (k + 1) ^ 2 ≤ (k + 1) ! := by
    intro k hk hk_ineq
    have h₁ : k + 1 ≤ k ^ 2 := by
      have h₂ : k ≥ 4 := by linarith
      have h₃ : k ^ 2 ≥ k + 1 := by
        cases k with
        | zero => contradiction -- k cannot be zero as hk : 4 ≤ k
        | succ k' =>
          cases k' with
          | zero => contradiction -- k cannot be one as hk : 4 ≤ k
          | succ k'' =>
            cases k'' with
            | zero => contradiction -- k cannot be two as hk : 4 ≤ k
            | succ k''' =>
              cases k''' with
              | zero => contradiction -- k cannot be three as hk : 4 ≤ k
              | succ k'''' =>
                simp [Nat.pow_succ, Nat.mul_add, Nat.add_mul] at hk_ineq ⊢
                <;> ring_nf at hk_ineq ⊢ <;>
                  nlinarith
      linarith
    have h₂ : (k + 1) ^ 2 ≤ (k + 1) * k ^ 2 := by
      have h₃ : k + 1 ≤ k ^ 2 := h₁
      have h₄ : (k + 1) ^ 2 = (k + 1) * (k + 1) := by ring
      rw [h₄]
      have h₅ : (k + 1) * (k + 1) ≤ (k + 1) * k ^ 2 := by
        have h₆ : k + 1 ≤ k ^ 2 := h₁
        nlinarith
      exact h₅
    have h₃ : (k + 1) * k ^ 2 ≤ (k + 1) * k ! := by
      have h₄ : k ^ 2 ≤ k ! := hk_ineq
      have h₅ : (k + 1) * k ^ 2 ≤ (k + 1) * k ! := by
        exact Nat.mul_le_mul_left (k + 1) h₄
      exact h₅
    have h₄ : (k + 1) ^ 2 ≤ (k + 1) * k ! := by
      calc
        (k + 1) ^ 2 ≤ (k + 1) * k ^ 2 := h₂
        _ ≤ (k + 1) * k ! := h₃
    have h₅ : (k + 1) * k ! = (k + 1) ! := by
      simp [Nat.factorial_succ, mul_comm]
      <;> ring_nf
      <;> simp_all [Nat.factorial]
      <;> linarith
    calc
      (k + 1) ^ 2 ≤ (k + 1) * k ! := h₄
      _ = (k + 1) ! := by rw [h₅]
  
  have h_main : n ^ 2 ≤ n ! := by
    have h₁ : ∀ n : ℕ, 4 ≤ n → n ^ 2 ≤ n ! := by
      intro n hn
      induction' hn with k hk IH
      · -- Base case: k = 4
        exact h_base
      · -- Inductive step: assume the statement holds for k, prove for k + 1
        exact h_inductive_step k hk IH
    exact h₁ n h₀
  
  exact h_main
