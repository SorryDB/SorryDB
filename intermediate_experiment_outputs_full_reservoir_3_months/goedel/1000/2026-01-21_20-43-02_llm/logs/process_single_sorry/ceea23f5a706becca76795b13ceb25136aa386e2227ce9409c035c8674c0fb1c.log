/-- Every D-smooth map from a boundaryless manifold to another manifold is also smooth.
This could probably be proven in quite a lot greater generality. -/
theorem IsOpen.dsmooth_iff_smoothOn {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [FiniteDimensional ℝ E] {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E'] [NormedSpace ℝ E'] [FiniteDimensional ℝ E']
    {H' : Type*} [TopologicalSpace H'] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_,ContMDiffOn.dsmooth_restrict⟩
  have h₁ : ContMDiffWithinAt I I' ∞ f s x :=
    (dsimp only at hf ⊢
    -- Use the fact that f is D-smooth on s to show that f is smooth on s
    have h₂ : DSmooth (s.restrict f) := hf
    have h₃ : ContMDiffWithinAt I I' ∞ f s x := by
      -- Use the definition of D-smoothness to get the required smoothness
      have h₄ : DContDiffAt (I'.target.toDiffeology) ((s.restrict f).toDiffeology) ((discPred s x) : ℕ) (f x) (x : M) :=
        (h₂ _ (x : n) (isPlot_discPred (x : ℕ))) (by simp_all [isOpen_pred, isOpen_iff_mem_nhds])
      -- Simplify the conditions to match the required form
      simp_all [DContDiffAt, isPlot_discPred]
      <;>
      (try norm_num) <;>
      (try aesop) <;>
      (try simp_all [ContMDiffAt]) <;>
      (try simp_all [ContMDiffWithinAt])
    exact h₃
  ) <;>
  (try aesop)
  <;>
  (try simp_all [ContMDiffOn, ContMDiffWithinAt])
  <;>
  (try simp_all [Ioi, Icc, Set.Ioc])
  <;>
  (try aesop)
  <;>
  (try norm_num)
  <;>
  (try linarith)
  <;>
  (try simp_all [hI])
