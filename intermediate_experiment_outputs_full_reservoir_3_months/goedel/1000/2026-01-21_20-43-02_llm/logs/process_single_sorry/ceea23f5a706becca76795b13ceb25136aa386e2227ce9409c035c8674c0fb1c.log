      "\n    have h₄ : x ∈ s := hxs\n    -- Use the DSmooth property to get the required smoothness\n    have h₅ : DSmooth (s.restrict f) := hf\n    -- Use the definition of DSmooth to get the required smoothness\n    have h₆ : ∀ (n : ℕ) (p : Eucl n → M), IsPlot p → (s.restrict f) ∘ p = (s.restrict (f ∘ p)) := by\n      intro n p hp\n      simp [Function.comp]\n      <;> ext x <;> simp [Set.mem_preimage, Set.mem_setOf_eq]\n      <;> aesop\n    -- Use the fact that the set s is open to reduce the problem to the global case\n    have h₇ : ContMDiffWithinAt I I' ∞ f s x := by\n      -- Use the definition of DSmooth to get the required smoothness\n      have h₈ : ∀ (n : ℕ), ∀ (p : Eucl n → M), IsPlot p → ContMDiffOn (𝓡 n) I' ∞ (s.restrict f ∘ p) Set.univ := by\n        intro n p hp\n        have h₉ : DSmooth (s.restrict f) := hf\n        have h₁₀ : IsPlot p := hp\n        have h₁₁ : ContMDiffOn (𝓡 n) I' ∞ (s.restrict f ∘ p) Set.univ := by\n          -- Use the definition of DSmooth to get the required smoothness\n          have h₁₂ : contMDiffOn_univ (𝓝[Set.univ] 0) := by\n            exact contMDiffOn_univ\n          -- Use the fact that the set s is open to reduce the problem to the global case\n          simp_all [IsPlot, DSmooth]\n          <;> aesop\n        exact h₁₁\n      -- Use the fact that the set s is open to reduce the problem to the global case\n      have h₉ : ContMDiffWithinAt I I' ∞ f s x := by\n        -- Use the definition of DSmooth to get the required smoothness\n        have h₁₀ : ∀ (n : ℕ), ∀ (p : Eucl n → M), IsPlot p → ContMDiffOn (𝓡 n) I' ∞ (s.restrict f ∘ p) Set.univ := h₈\n        -- Use the fact that the set s is open to reduce the problem to the global case\n        have h₁₁ : ContMDiffWithinAt I I' ∞ f s x := by\n          -- Use the definition of DSmooth to get the required smoothness\n          have h₁₂ : ∀ (n : ℕ), ∀ (p : Eucl n → M), IsPlot p → ContMDiffOn (𝓡 n) I' ∞ (s.restrict f ∘ p) Set.univ := h₈\n          -- Use the fact that the