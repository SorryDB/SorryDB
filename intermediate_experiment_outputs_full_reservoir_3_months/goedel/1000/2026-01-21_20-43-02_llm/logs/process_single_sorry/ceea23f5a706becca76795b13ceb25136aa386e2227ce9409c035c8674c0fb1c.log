      "\n      have h₄ : DSmoothWithinAt s f (x : M) := by\n        simpa [Set.mem_univ, iff_true_iff] using hf x\n      -- Since x is in s and s is open, f is D-smooth within s at x\n      have h₅ : DSmoothWithinAt (Set.univ : Set M) f x := by\n        -- Use the fact that s is open and f is D-smooth on s\n        apply DSmoothWithinAt.of_superset h₄ (by simp [hxs]) (by simp_all [hs.mem_nhds])\n      exact h₅\n    -- Convert the D-smoothness to the corresponding smoothness in the manifold\n    have h₆ : ContMDiffWithinAt I I' (⊤ : ℕ) f (Set.univ : Set M) x := by\n      -- Use the fact that the identity map is smooth\n      have h₇ : DSmoothAt f x := by\n        -- Use the fact that f is D-smooth on s and s is open\n        have h₈ : DSmoothWithinAt (Set.univ : Set M) f x := h₃\n        have h₉ : DSmoothAt f x := h₈.of_mem_nhds (by\n          -- Use the fact that the set univ is a neighborhood of x\n          have h₁₀ : (Set.univ : Set M) ∈ nhds x := by\n            apply isOpen_univ.mem_nhds\n          exact h₁₀)\n        exact h₉\n      -- Convert the D-smoothness to the corresponding smoothness in the manifold\n      have h₁₀ : ContMDiffAt I I' (⊤ : ℕ) f x := by\n        convert h₇ using 1\n        <;> simp [isPlot_iff_contMDiff]\n      -- Use the fact that the set univ is a superset of s\n      have h₁₁ : ContMDiffWithinAt I I' (⊤ : ℕ) f (Set.univ : Set M) x := by\n        apply h₁₀.continuous.continuousWithinAt.contMDiffWithinAt\n      exact h₁₁\n    -- Use the fact that s is a subset of univ\n    have h₁₂ : ContMDiffWithinAt I I' (⊤ : ℕ) f s x := by\n      apply h₆.mono (by tauto)\n    exact h₁₂\n  exact h₁",
      "\n  have h1 : ContMDiffOn I I' ∞ f s := by\n    have h2 : DSmooth (s.restrict f) := hf\n    have h3 : x ∈ s := hxs\n    -- Use the definition of D_smooth to get the necessary condition\n    have h4 : ContMDiffWithinAt I I' ∞ f s x := by\n      -- Use the D_smooth condition to get the smoothness on the subset\n      have h5 : ∀ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), IsPlot[m.toDiffeology] p → ContMDiffWithinAt I I' ∞ (f ∘ p) (p ⁻¹' s) (Classical.arbitrary (p ⁻¹' s)) := by\n        intro n p hp\n        have h6 : DContDiffWithinAt (↑⊤ : Filter ℕ) (s.restrict f) (p ⁻¹' s) (Classical.arbitrary (p ⁻¹' s)) := by\n          apply h2\n          <;> simp_all [IsPlot]\n          <;> aesop\n        -- Convert the D_smooth condition to the ContMDiffWithinAt condition\n        convert h6 using 1\n        <;> simp_all [IsPlot, Function.comp]\n        <;> aesop\n      -- Apply the above result to a specific plot\n      have h7 : ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), IsPlot[m.toDiffeology] p ∧ x ∈ p '' Set.univ := by\n        -- Use the fact that the manifold is locally modeled by Euclidean space\n        have h8 : ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), IsPlot[m.toDiffeology] p ∧ x ∈ p '' Set.univ := by\n          -- Use the definition of IsManifold to get the necessary plot\n          have h9 : ∀ (x : M), ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), IsPlot[m.toDiffeology] p ∧ x ∈ p '' Set.univ := by\n            intro x\n            -- Use the fact that the manifold is locally modeled by Euclidean space\n            have h10 : ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), IsPlot[m.toDiffeology] p ∧ x ∈ p '' Set.univ := by\n              -- Use the definition of IsManifold to get the necessary plot\n              have h11 : ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M), ContMDiff (𝓡 n) I ∞ p := by\n                -- Use the fact that the manifold is locally modeled by Euclidean space\n                have h12 : ∃ (n : ℕ) (p : EuclideanSpace ℝ (Fin n) → M