      "\n    have h₂ : (s.restrict f).contDiffAt (⊤ : ℕ) x := by\n      -- Since `s` is open, the restriction is equivalent to `f` being smooth at `x`.\n      have h₃ : x ∈ s := hxs\n      have h₄ : (s.restrict f).contDiffAt (⊤ : ℕ) x := by\n        -- Use the fact that `s` is open to deduce `contDiffAt`.\n        have h₅ : DSmooth (s.restrict f) := hf\n        have h₆ : ∀ n : ℕ, (s.restrict f).contDiffAt (↥(n : ℕ)) x := by\n          intro n\n          exact hf n x\n        simpa using h₆ ⊤\n      exact h₄\n    -- Use the equivalence between `contDiffAt` and `ContMDiffWithinAt` to conclude.\n    have h₅ : ContMDiffWithinAt I I' (⊤ : ℕ) f s x := by\n      simpa [s.restrict_apply, contDiffAt_iff] using h₂\n    exact h₅\n  simpa using h₁",
