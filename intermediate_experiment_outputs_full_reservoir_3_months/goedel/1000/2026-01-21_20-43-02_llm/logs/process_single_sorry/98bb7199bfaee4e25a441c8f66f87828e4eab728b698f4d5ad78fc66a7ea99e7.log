def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, _⟩
    have h₁ : G.IsMatching (∅ : Set β) := by
      constructor
      · simp [IsMatching]
      · simp [IsMatching]
    have h₂ : (∅ : Set α) ⊆ V(G, (∅ : Set β)) := by simp
    exact ⟨h₁, h₂⟩
  indep_subset := by
    intro I J hJ hIJ
    obtain ⟨M, hM, hJ'⟩ := hJ
    refine ⟨M, hM, _⟩
    have h₁ : J ⊆ V(G, M) := hJ'
    have h₂ : I ⊆ J := hIJ
    have h₃ : I ⊆ V(G, M) := h₂.trans h₁
    exact h₃
