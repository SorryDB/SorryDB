def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, ?_⟩
    <;> simp [IsMatching]
    <;> aesop
  
  indep_subset := by
    intro I J hJ hIJ
    obtain ⟨M, hM, hJ⟩ := hJ
    refine ⟨M, hM, _⟩
    -- We already have J ⊆ V(G, M) from hJ, and I ⊆ J by hIJ.
    -- Since ⊆ is transitive, I ⊆ V(G, M).
    have hI : I ⊆ V(G, M) := hIJ.trans hJ
    exact hI
