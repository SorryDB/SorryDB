      (s := measurableSpace β)
      (t := MetricSpace.toUniformSpace β)
      (ss := MeasurableSpace.of ∅)
      (s₁ := s) (s₂ := s₁)
      (m₁ := mα) (m₂ := mα)
      (u₁ := m₁) (u₂ := m₂)
