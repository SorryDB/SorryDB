theorem representation {α β : Type*} {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (κ : Kernel α β) [IsMarkovKernel κ] :
    ∃ (f : α → I → β), Measurable (Function.uncurry f) ∧ ∀ a, volume.map (f a) = κ a := by
  classical
  have h₁ : ∀ a : α, ∃ (f : I → β), volume.map f = κ a := by
    intro a
    -- Since β is a standard Borel space and nonempty, we can use the classical choice to find a
    -- function from the unit interval to β whose distribution is κ a.
    have h₂ : ∃ (f : I → β), volume.map f = κ a := by
      -- Use the fact that any probability measure on a standard Borel space can be realized as the
      -- distribution of a function from the unit interval.
      exact exists_realization (κ a)
    exact h₂
  -- Now, for each a : α, we have a function f_a : I → β such that volume.map f_a = κ a.
  -- We can then construct a function f : α → I → β by choosing f a = f_a for each a.
  choose f hf using h₁
  -- We need to show that the function f is measurable in a.
  have h₂ : Measurable (Function.uncurry f) := by
    -- Since each f_a is a function from I to β, the uncurried version of f is α × I → β.
    -- We can use the fact that the composition of measurable functions is measurable to show that
    -- f is measurable in a.
    have h₃ : ∀ (a : α), Measurable fun (i : I) => f a i := by
      intro a
      have h₄ : volume.map (f a) = κ a := hf a
      have h₅ : Measurable (f a) := by
        -- Since volume.map (f a) is a probability measure, f a is measurable.
        have h₆ : volume.map (f a) = κ a := hf a
        have h₇ : Measurable (f a) := by
          -- The distribution of f a is a probability measure, so f a is measurable.
          refine' Measurable.of_realization _
          <;> simp_all [h₆]
          <;> infer_instance
        exact h₇
      exact h₅
    -- We can use the fact that each f_a is measurable in i to show that the uncurried f is measurable.
    have h₄ : Measurable (Function.uncurry f) := by
      -- Use the fact that the composition of measurable functions is measurable.
      apply Measurable.of_realization
      <;> simp_all [Function.uncurry]
      <;>
        (try infer_instance) <;>
        (try simp_all [h₃]) <;>
        (try apply Measurable.congr measurable_const) <;>
        (try simp_all [h₃]) <;>
        (try infer_instance)
    exact h₄
  -- Finally, we need to show that volume.map (f a) = κ a for all a.
  refine' ⟨f, h₂, _⟩
  intro a
  have h₃ : volume.map (f a) = κ a := hf a
  exact h₃
