theorem representation {α β : Type*} {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (κ : Kernel α β) [IsMarkovKernel κ] :
    ∃ (f : α → I → β), Measurable (Function.uncurry f) ∧ ∀ a, volume.map (f a) = κ a := by
  -- Use the fact that [0,1] is a standard Borel space to obtain a measurable function f
  -- such that the pushforward of the Lebesgue measure under f is the given Markov kernel.
  have h₁ : ∀ a : α, ∃ (f : I → β), Measurable f ∧ map f volume = κ a := by
    intro a
    have h₂ : IsProbabilityMeasure (κ a) := by
      exact IsMarkovKernel.isProbabilityMeasure _ (IsMarkovKernel.of <| inferInstance) a
    -- Use the fact that every probability measure on a standard Borel space is the pushforward of the Lebesgue measure.
    have h₃ : ∃ (f : I → β), Measurable f ∧ map f volume = κ a := by
      -- Use the fact that [0,1] is a standard Borel space to obtain a measurable function f
      -- such that the pushforward of the Lebesgue measure under f is the given Markov kernel.
      have h₄ : Nonempty β := inferInstance
      have h₅ : StandardBorelSpace β := inferInstance
      -- Use the fact that every probability measure on a standard Borel space is the pushforward of the Lebesgue measure.
      exact exists measurable_injective_trans_measure h₂
    exact h₃
  -- Use the axiom of choice to obtain a function f : α → I → β such that for each a : α,
  -- f a : I → β is measurable and the pushforward of the Lebesgue measure under f a is κ a.
  choose f hf₁ hf₂ using h₁
  -- Show that the function (a, t) ↦ f a t is measurable.
  have h₂ : Measurable (Function.uncurry f) := by
    have h₃ : ∀ a : α, Measurable (f a) := by
      intro a
      exact hf₁ a
    -- Use the fact that each f a is measurable and the space β is standard Borel.
    have h₄ : Measurable (fun p : α × I => f p.1 p.2) := by
      have h₅ : ∀ a : α, Measurable (fun t : I => f a t) := by
        intro a
        exact hf₁ a
      -- Use the fact that each f a is measurable and the space β is standard Borel.
      have h₆ : Measurable (fun p : α × I => f p.1 p.2) := by
        apply Measurable.prod_mk (f := fun p : α × I => p.1) (g := fun p : α × I => p.2)
        · exact measurable_fst
        · exact measurable_snd
        · intro a
          exact h₅ a
      exact h₆
    simpa [Function.uncurry] using h₄
  -- Conclude the proof.
  refine' ⟨f, h₂, _⟩
  intro a
  have h₃ := hf₂ a
  have h₄ : map (f a) volume = κ a := by
    rw [h₃]
  exact h₄
