    rw [hC]
    simp
    use F, (d :: ╬┤s), _in_H
    rw [split_def]
    simp
      -- Rest based on non-empty ╬┤ case in `dia` above; changed to work with `loadMulti`.
                  -- A non-empty ╬┤ came from ╬▒, so we have not actually made the step to `u` yet.
                  -- Again we prepare to use IH, but now for `d` and `╬┤s` instead.
      
  specialize @IH _ in_B v u ?_ w_n╬ż d ╬┤s ?_ ?_ ?_
  ┬Ě intro f f_in; clear IH
    simp only [Option.map_some, Sum.elim_inl, negUnload, unload_loadMulti, Option.toList_some, List.mem_union_iff,
      List.mem_append, List.mem_cons, List.not_mem_nil, or_false] at f_in
    rcases f_in with (((f_in | f_in) | f_in) | f_def)
    ┬Ě apply v_t; simp_all
    ┬Ě exact v_F _ f_in
    ┬Ě apply v_t; simp_all
    ┬Ě subst f_def
      rw [ÔćÉ @boxes_last, splitLast_undo_of_some split_def]
      simp only [evaluate, Formula.boxes_cons, evalBoxes, not_forall]
      refine ÔčĘx, v_d_x, ÔčĘu, x_╬┤s_u, ?_ÔčęÔčę
      exact w_n╬ż
  ┬Ě simp_rw [relateSeq_cons]
    exact ÔčĘx, v_d_x, x_╬┤s_uÔčę
  ┬Ě clear IH next
    cases side
    ┬Ě simp [AnyNegFormula.in_side]
      exact loadMulti_of_splitLast_cons split_def
    ┬Ě exfalso
      simp_all [AnyNegFormula.in_side]
  ┬Ě exact Sequent.without_loadMulti_isFree_of_splitLast_cons_inl split_def
  rcases IH with ÔčĘY, Y_in, v_Y, (Y_free | ÔčĘG, ╬│s, in_Y, v_╬│s_w, dist_eq, v_G, in_Hl, Y_almost_freeÔčę)Ôčę
  ┬Ě
    refine
      ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inl Y_freeÔčęÔčę -- free'n'easy
        
  ┬Ě refine ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inr ?_ÔčęÔčę
    refine ÔčĘF, _, in_Y, v_╬│s_w, ?_, v_F, ?_, Y_almost_freeÔčę
    ┬Ě
      rw [dist_eq, same_dist, distance_list_singleton]
        -- Now show that `d` is atomic, because it resulted from `H ╬▒`.
        
    have ÔčĘa, d_atomÔčę : Ôłâ a, d = ((┬Ěa) : Program) :=
