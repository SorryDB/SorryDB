info: Pdl/Soundness.lean:1535:2: 'case neg not_free =>
  simp [Sequent.isFree] at not_free
  rcases O_def : (tabAt t).2.1.2.2 with _ | snlf
  ┬Ě -- "none" case is impossible because t is not free:
    exfalso; simp_all [nodeAt, Sequent.isLoaded];
    split at not_free <;>
      simp_all
        -- two goals remaining, but left and right case are almost the same :-)
        
  let _theSide := sideOf snlf
  rcases snlf with (nlf | nlf)
  all_goals
    ┬Ě clear not_free
      rcases nlf with
        ÔčĘlfÔčę
          -- Now we take apart the loaded formula to get all loaded boxes from the front at once,
                -- so that we can do induction on ╬┤ for multiple `loadedDiamondPaths` applications.
          
      rcases LoadFormula.exists_loadMulti lf with ÔčĘ╬┤, ╬▒, ¤ć, lf_defÔčę
      cases ╬┤
      case nil =>
        simp only [loadMulti, List.foldr_nil] at lf_def
        have in_t : (~''(ÔîŐ╬▒Ôîő¤ć)).in_side _theSide (nodeAt t) := by simp_all [nodeAt];
          aesop
            -- Let C be the cluster to which `t` belongs.
                    -- We claim that any ÔŚâ-path of satisfiable nodes starting at t must remain in C.
            
        have claim : ÔłÇ s, t ÔŚâÔü║ s Ôćĺ satisfiable (nodeAt s) Ôćĺ s ÔëíßÂť t :=
          by
          intro s t_to_s s_sat
          rw [cEquiv.symm]
          apply Classical.by_contradiction
          intro hyp
          absurd s_sat
          apply IH
          exact ePropB.g s t t_to_s hyp
        rintro ÔčĘW, M, v, v_Ôčę
        have := v_ (~(loadMulti [] ╬▒ ¤ć).unload) (by simp; right; aesop)
        rw [unload_loadMulti] at this
        simp [Formula.boxes_nil, evaluate, not_forall, Classical.not_imp] at this
        rcases this with ÔčĘw, v_╬▒_w, not_w_¤ćÔčę
        have := loadedDiamondPaths ╬▒ [] tab Root_isFree t v_ ¤ć in_t (by simp; exact v_╬▒_w) (not_w_¤ć)
        rcases this with ÔčĘs, t_to_s, (ÔčĘs_sat, notequiÔčę | ÔčĘin_s, w_s, rest_s_freeÔčę)Ôčę
        ┬Ě -- "Together wit the observation ..."
          
          absurd notequi
          apply claim _ t_to_s s_sat
        ┬Ě -- We now claim that we have a contradiction with the outer IH as we left the cluster:
          
          absurd IH s ?_
          exact
            ÔčĘW, M, w, w_sÔčę
              -- simp only [Sequent.without_normal_isFree_iff_isFree] at rest_s_free
                        -- Remains to show that s is simpler than t. We use ePropB.
              
          constructor
          ┬Ě exact t_to_s
          ┬Ě have : (nodeAt t).isLoaded := by
              unfold Sequent.isLoaded
              simp [AnyNegFormula.in_side] at in_t
              aesop
            apply ePropB.e_help _ _ this rest_s_free t_to_s
      case cons ╬▓ ╬┤ =>
        rintro ÔčĘW, M, v, v_Ôčę
        have :=
          v_ (~(loadMulti (╬▓ :: ╬┤) ╬▒ ¤ć).unload)
            (by
              simp
              right
              rw [O_def]
                -- the following is needed because we are in "all_goals"
                
              try (left; use (~'loadMulti (╬▓ :: ╬┤) ╬▒ ¤ć); simp_all; done)
              try (right; use (~'loadMulti (╬▓ :: ╬┤) ╬▒ ¤ć); simp_all))
        simp only [unload_loadMulti] at this
        rw [Formula.boxes_cons] at this
        simp [evaluate, not_forall, Classical.not_imp] at this
        rw [ÔćÉ @boxes_last] at this
        simp_rw [evalBoxes] at this
        push_neg at this
        rcases this with ÔčĘw, v_╬▓_w, u, w_╬┤╬▒_u, u_not_¤ćÔčę
        have v_╬▓╬┤╬▒_u : relateSeq M (╬▓ :: (╬┤ ++ [╬▒])) v u :=
          by
          rw [@relateSeq_cons]
          use w
        have in_t : (~''((ÔîŐ╬▓ÔîőAnyFormula.loadBoxes (╬┤ ++ [╬▒]) ¤ć))).in_side _theSide (nodeAt t) :=
          by
          unfold _theSide
          try apply LoadFormula.in_side_of_lf_inl
          try apply LoadFormula.in_side_of_lf_inr
          simp_all [nodeAt, loadMulti_cons]
          apply loadMulti_eq_loadBoxes
        have := loadedDiamondPaths ╬▓ (╬┤ ++ [╬▒]) tab Root_isFree t v_ ¤ć in_t v_╬▓╬┤╬▒_u u_not_¤ć
        rcases this with ÔčĘs, t_to_s, s_propertyÔčę
        rcases s_property with ÔčĘs_sat, notequiÔčę | ÔčĘnot_af_in_s, w_s, rest_s_freeÔčę
        ┬Ě -- We left the cluster, use outer IH to get contradiction.
          
          absurd
            IH s
              (ePropB.g s t t_to_s (by rw [cEquiv.symm]; exact notequi))
                -- need that `s` is satisfiable
                
          exact s_sat
        ┬Ě -- Here is the case where s is still loaded and in the same cluster.
          
          absurd IH s ?_
          exact
            ÔčĘW, M, u, w_sÔčę
              -- simp only [Sequent.without_normal_isFree_iff_isFree] at rest_s_free
                        -- Remains to show that s is simpler than t. We use ePropB.
              
          constructor
          ┬Ě exact t_to_s
          ┬Ě have : (nodeAt t).isLoaded := by
              unfold Sequent.isLoaded
              simp [AnyNegFormula.in_side] at in_t
              aesop
            apply ePropB.e_help _ _ this rest_s_free t_to_s' uses 'IH'!
