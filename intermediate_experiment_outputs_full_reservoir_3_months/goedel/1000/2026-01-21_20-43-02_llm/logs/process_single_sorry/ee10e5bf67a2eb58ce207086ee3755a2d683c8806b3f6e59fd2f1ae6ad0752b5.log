    | some this => this
    | none => by exfalso; simp_all [splitLast]
  have split_def : splitLast (d :: ╬┤s) = some ╬┤_╬▓ := by
    rfl
      -- This F,╬┤ pair is also used for one result in `B`:
      
  have in_B : (L ++ F, R, some (Sum.inl (~'loadMulti ╬┤_╬▓.1 ╬┤_╬▓.2 ¤ć))) Ôłł C :=
    by
