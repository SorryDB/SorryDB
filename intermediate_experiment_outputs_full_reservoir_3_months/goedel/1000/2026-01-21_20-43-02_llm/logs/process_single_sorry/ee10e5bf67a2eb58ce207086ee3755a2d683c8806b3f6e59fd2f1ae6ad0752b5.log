info: Pdl/LocalSoundness.lean:503:8: 'case dia ╬▒' ¤ç' ╬▒'_not_atomic =>
  -- The rule application has its own ╬▒' that must be ╬▒, and ¤ç' must be ÔîŐ╬▒sÔîő¤ć.
  
  have ÔčĘ╬▒_same, ¤ç_defÔčę : ╬▒ = ╬▒' Ôłž ¤ç' = (AnyFormula.loadBoxes ╬▒s (AnyFormula.normal ¤ć)) :=
    by
    simp [AnyNegFormula.in_side] at negLoad_in
    have := precons.2.2
    simp at this
    rw [ÔćÉ this] at negLoad_in
    cases side <;> aesop
  subst ╬▒_same
  have in_B : (L, R ++ F, some (Sum.inr (~'ÔîŐÔîŐ╬┤ÔîőÔîő¤ç'))) Ôłł C :=
    by
    simp [applyLocalRule, unfoldDiamondLoaded, YsetLoad] at hC
    rw [hC]
    simp
    use ╬┤
  cases ╬┤
  case nil => -- ╬┤ is empty, is this the easy or the hard case? ;-)
    
    simp at v_╬┤_u v_F
    subst v_╬┤_u
    cases ╬▒s
    ┬Ě exfalso; simp_all
    case cons new_╬▒ new_╬▒s =>
      -- Let's prepare the IH application now.
      
      specialize @IH _ in_B v w ?_ w_n╬ż new_╬▒ new_╬▒s u_╬▒s_w ?_ ?_
      ┬Ě intro f f_in; clear IH
        simp only [LoadFormula.boxes_nil, Option.map_some, Sum.elim_inr, negUnload, Option.toList_some,
          List.mem_union_iff, List.mem_append, List.mem_cons, List.not_mem_nil, or_false] at f_in
        rcases f_in with ((f_in | (f_in | f_in)) | f_def)
        ┬Ě apply v_t; simp_all
        ┬Ě apply v_t; simp_all
        ┬Ě exact v_F _ f_in
        ┬Ě subst f_def
          rw [loaded_eq_to_unload_eq ¤ç' _ _ ¤ç_def]
          simp only [evaluate, Formula.boxes_cons, not_forall]
          rcases u_╬▒s_w with ÔčĘx, v_╬▒_x, blaÔčę
          use x, v_╬▒_x; rw [evalBoxes]
          push_neg; use w; tauto
      ┬Ě clear IH next
        cases side <;> simp_all [AnyNegFormula.in_side, LoadFormula.boxes]
      ┬Ě clear IH next
        simp_all [Sequent.without, LoadFormula.boxes]
          -- Now actually get the IH result.
          
      rcases IH with ÔčĘY, Y_in, v_Y, (Y_free | ÔčĘG, ╬│s, in_Y, v_╬│s_w, dist_eq, v_G, in_Hl, Y_almost_freeÔčę)Ôčę
      ┬Ě
        refine
          ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inl Y_freeÔčęÔčę -- free'n'easy
            
      ┬Ě -- Not fully sure here.
        
        refine ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inr ?_ÔčęÔčę
        refine ÔčĘF Ôł¬ G, ╬│s, in_Y, v_╬│s_w, ?_, ?_, ?_, Y_almost_freeÔčę
        ┬Ě rw [dist_eq]
          rw [u_picked_minimally]
          have : distance M ╬▒ v v = 0 := by
            -- Here ╬┤ is [] and thus ╬▒ can have distance 0
            
            rw [distance_list_nil_self] at same_dist
            exact same_dist.symm
          aesop
        ┬Ě intro f f_in
          simp at f_in; cases f_in
          ┬Ě apply v_F; assumption
          ┬Ě apply v_G; assumption
        simp [Hl]
        refine ÔčĘ_, _, _in_H, ?_Ôčę
        simp
        refine ÔčĘG, in_Hl, rflÔčę
  case cons d ╬┤s =>
    -- A non-empty ╬┤ came from ╬▒, so we have not actually made the step to `u` yet.
                -- Again we prepare to use IH, but now for `d` and `╬┤s ++ ╬▒s` instead.
    
    specialize @IH _ in_B v w ?_ w_n╬ż d (╬┤s ++ ╬▒s) ?_ ?_ ?_
    ┬Ě intro f f_in
      simp only [Option.map_some, Sum.elim_inr, negUnload, unload_boxes, Formula.boxes_cons, Option.toList_some,
        List.mem_union_iff, List.mem_append, List.mem_cons, List.not_mem_nil, or_false] at f_in
      rcases f_in with ((f_in | (f_in | f_in)) | f_def)
      ┬Ě apply v_t; simp_all
      ┬Ě apply v_t; simp_all
      ┬Ě exact v_F _ f_in
      ┬Ě subst f_def
        simp only [evaluate, evalBoxes, not_forall]
        rw [@relateSeq_cons] at v_╬┤_u
        rcases v_╬┤_u with ÔčĘx, v_d_x, x_╬┤s_uÔčę
        refine ÔčĘx, v_d_x, ÔčĘu, x_╬┤s_u, ?_ÔčęÔčę
        rw [loaded_eq_to_unload_eq ¤ç' _ _ ¤ç_def, evalBoxes]
        push_neg; use w; tauto
    ┬Ě simp_rw [relateSeq_cons, relateSeq_append]
      rw [relateSeq_cons] at v_╬┤_u
      rcases v_╬┤_u with ÔčĘx, v_d_x, x_╬┤_uÔčę
      refine ÔčĘx, v_d_x, ÔčĘu, x_╬┤_u, u_╬▒s_wÔčęÔčę
    ┬Ě clear IH next
      cases side
      ┬Ě exfalso
        simp_all [AnyNegFormula.in_side, LoadFormula.boxes]
      ┬Ě simp only [AnyNegFormula.in_side]
        convert rfl
        apply box_loadBoxes_append_eq_of_loaded_eq_loadBoxes ¤ç_def
    ┬Ě exact Sequent.without_loadBoxes_isFree_of_eq_inr ¤ç_def
    rcases IH with ÔčĘY, Y_in, v_Y, (Y_free | ÔčĘG, ╬│s, in_Y, v_╬│s_w, dist_eq, v_G, in_Hl, Y_almost_freeÔčę)Ôčę
    ┬Ě
      refine
        ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inl Y_freeÔčęÔčę -- free'n'easy
          
    ┬Ě refine ÔčĘY, ÔčĘ_, in_B, Y_inÔčę, ÔčĘv_Y, Or.inr ?_ÔčęÔčę
      refine ÔčĘF, _, in_Y, v_╬│s_w, ?_, v_F, ?_, Y_almost_freeÔčę
      ┬Ě rw [dist_eq]
          -- was: TRICKY PROBLEM - how do we know that `u` is chosen to minimze distance?
          
        rw [ÔćÉ List.cons_append, u_picked_minimally] -- now we DO have that :-)
          
        rw [ÔćÉ same_dist, distance_list_append]
        apply iInf_of_min
