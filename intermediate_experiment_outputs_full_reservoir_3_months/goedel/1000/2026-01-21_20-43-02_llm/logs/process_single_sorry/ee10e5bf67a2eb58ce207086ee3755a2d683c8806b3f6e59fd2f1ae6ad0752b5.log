  have h_main : (PathIn_type_flip_flip ÔľŞ s.flip) Ôłł exitsOf tab := by
    have hÔéü : ÔłÇ (x : PathIn tab), x Ôłł exitsOf tab Ôćĺ x.length < x.length Ôćĺ x Ôłł exitsOf tab := by
      intro x hx hlen
      exfalso
      omega
    -- Use the fact that the length of the path is not less than itself to handle the termination
    induction s using PathIn.recOn
    <;> simp_all [exitsOf, Tableau.flip, PathIn.length]
