instance : SampleableType Bool where
  selectElem := $! #v[true, false]
  mem_support_selectElem x := by
    have : support ($! ([true, false] : Vector Bool 2)) = {true, false} := by
      -- Prove that the support is {true, false}
      rw [support_eq_erase_univ (by
