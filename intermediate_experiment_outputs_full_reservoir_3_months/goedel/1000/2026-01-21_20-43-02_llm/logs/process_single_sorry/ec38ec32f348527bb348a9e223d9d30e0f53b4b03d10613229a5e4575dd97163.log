      Pr[=y | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] := by
  have h₁ : Pr[=x | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] = (1 : ℝ≥0∞) / 2 := by sorry
  have h₂ : Pr[=y | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] = (1 : ℝ≥0∞) / 2 := by sorry
  have h₃ : Pr[=x | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] = Pr[=y | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] := by sorry
  exact h₃
