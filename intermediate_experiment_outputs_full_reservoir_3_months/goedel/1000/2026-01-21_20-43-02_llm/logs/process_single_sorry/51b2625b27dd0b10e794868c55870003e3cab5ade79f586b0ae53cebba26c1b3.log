```lean
theorem RelInt.liftFinf_in {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
      rule ∈ (RelInt.liftFinf n f)
      → ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
  have h₁ : ∀ {α : Type} {n : ℕ} {L : List α} (f : Fin n → List α) (i : Fin n),
      rule ∈ (fin_range n).map f |>.flatten →
      ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
    intro α n L f i
    intro h
    simp_all [List.mem_map, List.mem_flatten]
    <;>
      (try decide) <;>
      (try {
        aesop
      }) <;>
      (try {
        simp_all [List.mem_map, List.mem_flatten]
        <;>
          aesop
      }) <;>
      (try {
        simp_all [Fin.ext_iff, List.get]
        <;>
          aesop
      })
  have h₂ : (RelInt.liftFinf n f) = (fin_range n).map f |>.flatten := by
    simp [RelInt.liftFinf]
  intro h
  rw [h₂] at h
  have h₃ : ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
    apply h₁
    <;> assumption
  exact h₃
