```lean
theorem RelInt.liftFinf_in {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
      rule ∈ (RelInt.liftFinf n f)
      → ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
  intro h
  have h₁ : ∃ (l' : List (RelInt S)), l' ∈ (fin_range n).map f ∧ rule ∈ l' := by
    have h₂ : rule ∈ ((fin_range n).map f).flatten := by simpa [RelInt.liftFinf] using h
    have h₃ : ∃ (l' : List (RelInt S)), l' ∈ (fin_range n).map f ∧ rule ∈ l' := by
      rw [List.mem_flatten] at h₂
      obtain ⟨l', hl', hrule⟩ := h₂
      refine' ⟨l', hl', hrule⟩
    exact h₃
  
  have h₂ : ∃ (i : Fin n), rule ∈ f i := by
    obtain ⟨l', hl', hrule⟩ := h₁
    have h₃ : l' ∈ (fin_range n).map f := hl'
    have h₄ : ∃ (i : Fin n), f i = l' := by
      rw [List.mem_map] at h₃
      obtain ⟨i, hi, rfl⟩ := h₃
      refine' ⟨i, _⟩
      <;> simp_all
    obtain ⟨i, hi⟩ := h₄
    have h₅ : rule ∈ f i := by
      rw [hi] at hrule
      exact hrule
    exact ⟨i, h₅⟩
  
  have h₃ : ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
    obtain ⟨i, hi⟩ := h₂
    have h₄ : ∃ (j : Fin (f i).length), rule = (f i).get j := by
      have h₅ : rule ∈ f i := hi
      have h₆ : ∃ (j : Fin (f i).length), rule = (f i).get j := by
        rw [List.mem_iff_get] at h₅
        obtain ⟨j, hj⟩ := h₅
        refine' ⟨j, _⟩
        <;> simp_all [List.get]
        <;> aesop
      exact h₆
    obtain ⟨j, hj⟩ := h₄
    exact ⟨i, j, by simp_all [hj]⟩
  
  exact h₃
```
