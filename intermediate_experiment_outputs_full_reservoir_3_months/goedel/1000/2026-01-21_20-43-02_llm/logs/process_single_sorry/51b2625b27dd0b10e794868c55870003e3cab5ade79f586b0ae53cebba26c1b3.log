      "\n  intro h\n  have h₁ : rule ∈ (fin_range n).map f |>.flatten := by\n    dsimp [RelInt.liftFinf] at h ⊢\n    exact h\n  -- Extract the index i : Fin n and the index j : Fin (f i).length such that rule = (f i).get j\n  have h₂ : ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by\n    -- We need to show that if rule is in the flattened list, then it is in one of the sublists\n    have h₃ : ∀ (l : List (List (RelInt S))), rule ∈ l.flatten → ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by\n      intro l h₄\n      -- Use the fact that rule is in the flattened list to find the corresponding indices\n      induction l with\n      | nil => contradiction\n      | cons hd tl ih =>\n        -- If the list is empty, we get a contradiction because rule cannot be in an empty list\n        by_cases h₅ : rule ∈ hd\n        · -- If rule is in the head of the list, we can find the index j in hd\n          have h₆ : ∃ (j : Fin hd.length), rule = hd.get j := by\n            classical\n            -- Use the fact that rule is in hd to find the index j\n            have h₇ : rule ∈ hd := h₅\n            have h₈ : ∃ (j : Fin hd.length), rule = hd.get j := by\n              -- Use the property of lists to find the index j\n              classical\n              have h₉ : ∃ j, hd.get ⟨j, by\n                have h₁₀ : j < hd.length := by\n                  have h₁₁ : ∃ j, hd.get ⟨j, by\n                    -- Use the fact that rule is in hd to find the index j\n                    simp_all [List.mem_iff_get]\n                    <;>\n                    (try omega) <;>\n                    (try\n                      {\n                        aesop\n                      }) <;>\n                    (try\n                      {\n                        simp_all [List.mem_iff_get]\n                        <;>\n                        omega\n                      })\n                  simp_all [List.mem_iff_get]\n                  <;>\n                  omega\n                simp_all [List.mem_iff_get]\n                <;>\n                omega\n              ⟩ = rule := by\n                -- Use the fact that rule is in hd to find the index j\n                simp_all [List.mem_iff_get]\n                <;>\n                (try omega) <;>\n                (try\n                  {\n                    aesop\n                  }) <;>\n                (try\n                  {\n                    simp_all [List.mem_iff_get]\n                    <;>\n                    omega\n                  })\n              obtain ⟨j, hj⟩ := h₉\n              refine' ⟨⟨j, _⟩, _⟩ <;> simp_all [List.mem_iff_get] <;>\n                (try omega) <;>\n                (try\n                  {\n                    aesop\n                  }) <;>\n                (try\n                  {\n                    simp_all [List.mem_iff_get]\n                    <;>\n                    omega\n                  })\n            exact h₈\n          obtain ⟨j, hj⟩ := h₆\n          -- Now we have the index j in hd, we need to find the index i in Fin n\n          have h₇ : hd = f (⟨0, by\n            cases n <;> simp_all [Fin.ext_iff]\n            <;>\n            (try omega) <;>\n            (try aesop)\n          ⟩ : Fin n) := by\n            simp_all [RelInt.liftFinf, fin_range]\n            <;>\n            (try omega) <;>\n            (try aesop)\n          -- Use the index i = 0 and j to find the required indices\n          refine' ⟨⟨0, by\n            cases n <;> simp_all [Fin.ext_iff]\n            <;>\n            (try omega) <;>\n            (try aesop)\n          ⟩, ⟨j.1, _⟩, _⟩ <;>\n            simp_all [List.get]\n          <;>\n          (try omega) <;>\n          (try aesop)\n          <;>\n          (try\n            {\n              aesop\n            })\n          <;>\n          (try\n            {\n              simp_all [List.mem_iff_get]\n              <;>\n              omega\n            })\n          <;>\n          (try