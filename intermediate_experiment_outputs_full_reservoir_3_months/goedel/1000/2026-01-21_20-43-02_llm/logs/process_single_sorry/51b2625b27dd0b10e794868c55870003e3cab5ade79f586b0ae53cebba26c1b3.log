```lean
theorem RelInt.liftFinf_in {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
      rule ∈ (RelInt.liftFinf n f)
      → ∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j := by
  intro h
  have h₁ : rule ∈ (fin_range n |>.map f |>.flatten) := by
    simpa [RelInt.liftFinf] using h
  have h₂ : ∃ (i : Fin n), rule ∈ f i := by
    simp only [List.mem_map, List.mem_flatten, exists_prop] at h₁
    obtain ⟨i, hi⟩ := h₁
    refine' ⟨i, _⟩
    aesop
  obtain ⟨i, hi⟩ := h₂
  have h₃ : ∃ (j : Fin (f i).length), rule = (f i).get j := by
    have h₄ : rule ∈ f i := hi
    have h₅ : ∃ (j : Fin (f i).length), rule = (f i).get j := by
      have h₆ : rule ∈ f i := hi
      have h₇ : ∃ (j : Fin (f i).length), (f i).get j = rule := by
        -- Use the fact that rule is in f i to find the index j
        have h₈ : ∃ (j : Fin (f i).length), (f i).get j = rule := by
          -- Use the property of lists to find the index
          classical
          have h₉ : rule ∈ f i := hi
          have h₁₀ : ∃ (j : Fin (f i).length), (f i).get j = rule := by
            -- Use the fact that rule is in f i to find the index j
            have h₁₁ : ∃ (j : ℕ), j < (f i).length ∧ (f i).get ⟨j, by omega⟩ = rule := by
              -- Use the property of lists to find the index
              have h₁₂ : ∃ (j : ℕ), j < (f i).length ∧ (f i)[j] = rule := by
                -- Use the fact that rule is in f i to find the index j
                simpa [List.get] using h₉
              obtain ⟨j, hj₁, hj₂⟩ := h₁₂
              refine' ⟨j, hj₁, _⟩
              simp_all [List.get]
            obtain ⟨j, hj₁, hj₂⟩ := h₁₁
            refine' ⟨⟨j, hj₁⟩, _⟩
            simp_all [List.get]
          exact h₁₀
        exact h₈
      obtain ⟨j, hj⟩ := h₇
      refine' ⟨j, _⟩
      simp_all [eq_comm]
    exact h₅
  obtain ⟨j, hj⟩ := h₃
  refine' ⟨i, j, _⟩
  simp_all [eq_comm]
