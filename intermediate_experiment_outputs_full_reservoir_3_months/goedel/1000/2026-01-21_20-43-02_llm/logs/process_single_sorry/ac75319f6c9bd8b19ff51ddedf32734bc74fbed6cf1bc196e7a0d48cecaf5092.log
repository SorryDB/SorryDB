lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  intro x hx
  have h₁ : x ∈ V(G, M ∆ E(P)) := by
    -- Since x is in V(G, M), we need to show it is also in V(G, M ∆ E(P))
    -- x is in V(G, M) implies x is in V(G) and there exists an edge in M incident to x
    -- We need to show that x is in V(G) and there exists an edge in M ∆ E(P) incident to x
    -- Since x is in V(G, M), it is already in V(G)
    -- We need to find an edge in M ∆ E(P) incident to x
    have h₂ : x ∈ V(G) := by
      -- x is in V(G, M), so it is in V(G)
      have h₃ : x ∈ V(G, M) := hx
      simp only [VGM] at h₃ ⊢
      aesop
    -- We need to show that there exists an edge in M ∆ E(P) incident to x
    -- Since x is in V(G, M), there exists an edge in M incident to x
    -- We need to check if this edge is in M ∆ E(P)
    simp only [VGM] at hx ⊢
    aesop
  exact h₁
