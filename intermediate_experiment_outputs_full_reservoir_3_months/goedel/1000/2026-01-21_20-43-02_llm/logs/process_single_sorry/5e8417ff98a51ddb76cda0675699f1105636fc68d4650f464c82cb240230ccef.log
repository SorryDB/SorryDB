      "\n  have h₁ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length ≤ i := by\n    have h₂ : (L.map length).partialSums.findIdx (· > i) > 0 := by\n      have h₃ : (L.map length).partialSums.length > 0 := by\n        simp [partialSums_nil]\n        <;> induction L <;> simp_all [partialSums_cons, List.length]\n        <;> omega\n      have h₄ : ∃ x ∈ (L.map length).partialSums, x > i := by\n        have h₅ : (L.map length).partialSums.getLast? = some ((L.map length).sum) := by\n          simp [partialSums_getLast?]\n        have h₆ : (L.map length).sum ≥ 0 := by\n          have h₇ : ∀ (x : ℕ), x ∈ L.map length → x ≥ 0 := by\n            intro x hx\n            simp only [List.mem_map] at hx\n            obtain ⟨a, _, rfl⟩ := hx\n            simp\n          have h₈ : (L.map length).sum ≥ 0 := by\n            have h₉ : ∀ (l : List ℕ), l.sum ≥ 0 := by\n              intro l\n              induction l with\n              | nil => simp\n              | cons a as ih =>\n                simp_all [List.sum_cons]\n                <;> omega\n            exact h₉ (L.map length)\n          exact h₈\n        have h₉ : (L.map length).sum ≥ i + 1 ∨ (L.map length).sum ≤ i := by\n          by_cases h : (L.map length).sum ≥ i + 1\n          · exact Or.inl h\n          · exact Or.inr (by omega)\n        cases h₉ with\n        | inl h₉ =>\n          have h₁₀ : (L.map length).sum > i := by omega\n          have h₁₁ : (L.map length).getLast? = some ((L.map length).sum) := by\n            simp [partialSums_getLast?]\n          have h₁₂ : (L.map length).sum ∈ (L.map length).partialSums := by\n            have h₁₃ : (L.map length).partialSums.getLast? = some ((L.map length).sum) := by\n              simp [partialSums_getLast?]\n            have h₁₄ : (L.map length).sum ∈ (L.map length).partialSums := by\n              have h₁₅ : (L.map length).partialSums.getLast? = some ((L.map length).sum) := by\n                simp [partialSums_getLast?]\n              have h₁₆ :