theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil =>
    simp
  | cons l L ih =>
    simp only [List.take_cons, List.take_nil, List.take_append, List.take_cons, List.take_nil]
    by_cases h : i < l.length
    · -- Case: i < l.length
      have h₁ : (L.map length).partialSums.findIdx (· > i) = 0 := by
        have h₂ : (L.map length).partialSums.findIdx (· > i) = 0 := by
          have h₃ : (L.map length).partialSums = [0] := by
            simp [List.partialSums, List.scanl]
            <;> cases L <;> simp_all [List.map, List.foldl]
            <;> norm_num
          rw [h₃]
          simp [List.findIdx]
          <;> omega
        exact h₂
      simp [h₁, List.get?, List.take, List.append_assoc]
      <;>
      (try omega) <;>
      (try simp_all [List.take, List.append_assoc]) <;>
