n                <;> induction L <;> simp_all [partialSums_cons, List.length]\n                <;> omega\n              have h₂₃ : (L.map length).partialSums.length * i ≥ i := by\n                have h₂₄ : (L.map length).partialSums.length ≥ 1 := h₂₂\n                nlinarith\n              have h₂₄ : (L.map length).sum ≥ i + 1 := by\n                by_contra h₂₄\n                have h₂₅ : (L.map length).sum ≤ i := by omega\n                omega\n              omega\n            exact h₁₄\n          obtain ⟨x, hx, hx'⟩ := h₁₁\n          exact ⟨x, hx, hx'⟩\n      have h₅ : (L.map length).partialSums.findIdx (· > i) > 0 := by\n        have h₆ : ∃ x ∈ (L.map length).partialSums, x > i := h₄\n        have h₇ : (L.map length).partialSums.findIdx (· > i) > 0 := by\n          have h₈ : (L.map length).partialSums.findIdx (· > i) ≠ 0 := by\n            intro h₈\n            have h₉ : (L.map length).partialSums.findIdx (· > i) = 0 := h₈\n            have h₁₀ : ∀ x ∈ (L.map length).partialSums, ¬x > i := by\n              intro x hx\n              have h₁₁ : (L.map length).partialSums.findIdx (· > i) = 0 := h₉\n              have h₁₂ : ¬x > i := by\n                by_contra h₁₂\n                have h₁₃ : x > i := h₁₂\n                have h₁₄ : (L.map length).partialSums.findIdx (· > i) = 0 := h₉\n                have h₁₅ : (L.map length).partialSums.findIdx (· > i) ≤ 0 := by simp_all\n                have h₁₆ : (L.map length).partialSums.findIdx (· > i) = 0 := by omega\n                have h₁₇ : (L.map length).partialSums.findIdx (· > i) = 0 := by omega\n                simp_all [List.findIdx_eq_iff]\n                <;>\n                (try omega) <;>\n                (try simp_all [List.mem_cons, List.mem_singleton]) <;>\n                (try {\n                  cases L <;> simp_all [List.map, List.partialSums, List.length]\n                  <;> omega\n                })\n              exact h₁₂\n            have h₁₁ : ∀ x ∈ (L.map length).partialSums, ¬x > i := h₁₀\n            have h₁₂ : ∃ x ∈ (L.map length).partialSums, x > i := h₆\n            obtain ⟨x, hx, hx'⟩ := h₁₂\n            have h₁₃ : ¬x > i := h₁₁ x hx\n            have h₁₄ : x > i := hx'\n            contradiction\n          have h₉ : (L.map length).partialSums.findIdx (· > i) ≠ 0 := h₈\n          have h₁₀ : (L.map length).partialSums.findIdx (· > i) > 0 := by\n            by_contra h₁₀\n            have h₁₁ : (L.map length).partialSums.findIdx (· > i) ≤ 0 := by omega\n            have h₁₂ : (L.map length).partialSums.findIdx (· > i) = 0 := by\n              have h₁₃ : (L.map length).partialSums.findIdx (· > i) ≥ 0 := by\n                apply Nat.zero_le\n              omega\n            contradiction\n          exact h₁₀\n        exact h₇\n      exact h₅\n    have h₃ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length ≤ i := by\n      have h₄ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length ≤ i := by\n        have h₅ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length < i + 1 := by\n          have h₆ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length < i + 1 := by\n            have h₇ : (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).flatten.length ≤ (L.take ((L.map length).partialSums.findIdx (· > i) - 1)).sum (fun x => x.length) := by\n              have h₈ : ∀ (L : List (List α)), (L.take k).flatten.length ≤ (L.take k).sum (fun x => x.length) := by\n                intro L\n                induction' L with a L ih generalizing k\n                · simp\n                · cases k with\n                  | zero =>\n                    simp_all [List.take, List.sum]\n                  | succ k' =>\n                    simp_all [List.take, List.sum, List.flatten]\n                    <;>\n                    (try omega) <;>\n                    (try simp_all [List.length_append, List.length_cons]) <;>\n                    (try nlinarith)\n              e