      "\n  have h : (L.map length).partialSums.findIdx (· > i) - 1 < L.length → True := by\n    intro h₁\n    trivial\n  by_cases h₁ : (L.map length).partialSums.findIdx (· > i) - 1 < L.length\n  <;> simp_all [List.get?]\n  <;>\n    (try {\n      exfalso\n      have h₂ := getElem_flatten_aux₁ L i (by\n        have h₃ : i < L.flatten.length := by\n          cases L <;> simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n          <;>\n          (try omega)\n          <;>\n          (try {\n            have h₄ := Nat.find_spec (Exists.intro (L.length + 1) (by\n              simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n              <;> omega))\n            simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;> omega\n          })\n          <;>\n          (try {\n            simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;> omega\n          })\n        exact h₃)\n      simp_all\n    })\n  <;>\n    (try {\n      have h₂ := getElem_flatten_aux₁ L i (by\n        have h₃ : i < L.flatten.length := by\n          cases L <;> simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n          <;>\n          (try omega)\n          <;>\n          (try {\n            have h₄ := Nat.find_spec (Exists.intro (L.length + 1) (by\n              simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n              <;> omega))\n            simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;> omega\n          })\n          <;>\n          (try {\n            simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;> omega\n          })\n        exact h₃)\n      simp_all\n    })\n  <;>\n    (try {\n      simp_all [List_take_append]\n    })\n  <;>\n    (try {\n      simp_all [List.get?]\n      <;>\n      (try {\n        cases L <;> simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n        <;>\n        (try omega)\n        <;>\n        (try {\n          have h₄ := Nat.find_spec (Exists.intro (L.length + 1) (by\n            simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;> omega))\n          simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n          <;> omega\n        })\n        <;>\n        (try {\n          simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n          <;> omega\n        })\n      })\n    })\n  <;>\n    (try {\n      simp_all [List.get?]\n      <;>\n      (try {\n        have h₂ := getElem_flatten_aux₁ L i (by\n          have h₃ : i < L.flatten.length := by\n            cases L <;> simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n            <;>\n            (try omega)\n            <;>\n            (try {\n              have h₄ := Nat.find_spec (Exists.intro (L.length + 1) (by\n                simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n                <;> omega))\n              simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n              <;> omega\n            })\n            <;>\n            (try {\n              simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n              <;> omega\n            })\n          exact h₃)\n        simp_all\n      })\n    })\n  <;>\n    (try {\n      have h₂ : i < L.flatten.length := by\n        cases L <;> simp_all [List.length, List.take, List.append, List.map, List.flatten, List.partialSums]\n        <;>\n        (try omega)\n        <;>\n        (try {\n          have h₃ := Nat.find_spec (Exists.intro (L.len