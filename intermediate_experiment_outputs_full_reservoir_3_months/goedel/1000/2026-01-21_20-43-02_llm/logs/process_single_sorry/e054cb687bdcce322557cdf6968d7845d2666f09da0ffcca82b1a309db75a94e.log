lemma indepFun_rewardByCount_Iic [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) (a : α)
    (n : ℕ) :
    (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] fun ω (i : Iic n) ↦ rewardByCount A R a i ω := by
  have hA := h.measurable_A
  have hR := h.measurable_R
  have h₁ : (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) := by
    -- Use the fact that the reward at time n+1 is independent of the rewards at times up to n
    have h₂ : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (n + 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ (IsAlgEnvSeq.hist A R n ω, A (n + 1) ω.1)) 𝔓' := by
      -- This is derived from the properties of the algorithm and the environment
      have h₃ : IndepFun (fun ω : Ω ↦ R (n + 1) ω) (fun ω : Ω ↦ (IsAlgEnvSeq.hist A R n ω, A (n + 1) ω)) P :=
        h.ind_diffiable_fun (n + 1)
      -- Convert the independence statement to the product space
      have h₄ : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (n + 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ (IsAlgEnvSeq.hist A R n ω, A (n + 1) ω.1)) 𝔓' := by
        exact h₃.prod_right (by fun_prop)
      exact h₄
    -- Use the independence of the reward and the history to show the required independence
    have h₃ : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (n + 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ (fun i : Iic n ↦ rewardByCount A R a (i : ℕ) ω)) 𝔓' := by
      -- Show that the function (fun i : Iic n ↦ rewardByCount A R a (i : ℕ) ω) is measurable and can be related to the history
      have h₄ : (fun ω : Ω × (ℕ → α → ℝ) ↦ (fun i : Iic n ↦ rewardByCount A R a (i : ℕ) ω)) ≤
          (fun ω : Ω × (ℕ → α → ℝ) ↦ (IsAlgEnvSeq.hist A R n ω, A (n + 1) ω.1)) := by
        intro ω
        -- Prove that the function is less than or equal to the history function
        refine' fun i ↦ _
        -- Use the fact that rewardByCount is part of the history
        simp [rewardByCount, IsAlgEnvSeq.hist]
        <;>
        (try decide) <;>
        (try simp_all [hA, hR, measurable_fst, measurable_snd, MeasurableExists]) <;>
        (try aesop)
      -- Use the fact that the reward is independent of the history to show the required independence
      exact h₂.of_right_le h₄
    -- Convert the independence statement to the required form
    calc
      (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) := by
        have h₅ : (rewardByCount A R a (n + 1)) = (fun ω : Ω × (ℕ → α → ℝ) ↦ R (n + 1) ω.1) := by
          ext ω
          simp [rewardByCount, stepsUntil, Nat.find_eq_iff]
          <;>
          (try aesop)
        rw [h₅]
        have h₆ : (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) = (fun ω : Ω × (ℕ → α → ℝ) ↦ (fun i : Iic n ↦ rewardByCount A R a (i : ℕ) ω)) := by
          ext ω i
          <;>
          (try simp_all [rewardByCount])
          <;>
          (try aesop)
        rw [h₆]
        exact h₃
      _ = (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) := by rfl
  exact h₁
