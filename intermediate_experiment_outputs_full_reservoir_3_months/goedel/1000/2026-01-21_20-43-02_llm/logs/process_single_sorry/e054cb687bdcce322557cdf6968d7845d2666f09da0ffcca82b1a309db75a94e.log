lemma indepFun_rewardByCount_Iic [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) (a : α)
    (n : ℕ) :
    (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] fun ω (i : Iic n) ↦ rewardByCount A R a i ω := by
  have h₁ : (rewardByCount A R a (n + 1)) ⟂ᵢ[Bandit.trajMeasure alg ν] (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) := by
    classical
    have h₂ : ∀ i : Iic n, (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) i = rewardByCount A R a (i : ℕ) := by simp
    have h₃ : (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) = fun ω i => rewardByCount A R a (i : ℕ) ω := by
      funext ω i
      <;> simp
    rw [h₃]
    have h₄ : (rewardByCount A R a (n + 1)) ⟂ᵢ[Bandit.trajMeasure alg ν] (fun ω (i : Iic n) ↦ rewardByCount A R a (i : ℕ) ω) := by
      have h₅ : IsAlgEnvSeq A R alg (stationaryEnv ν) P := h
      have h₆ : (rewardByCount A R a (n + 1)) ⟂ᵢ[Bandit.trajMeasure alg ν] (fun ω (i : Iic n) ↦ rewardByCount A R a (i : ℕ) ω) := by
        -- Use the fact that the algorithm is independent of the environment to establish the independence of the reward by count
        classical
        apply IsAlgEnvSeq.indepFun_rewardByCount_Iic
        <;> assumption
      exact h₆
    exact h₄
  -- Lift the independence from the trajectory measure to the product measure
  have h₂ : (rewardByCount A R a (n + 1)) ⟂ᵢ[𝑃] (fun ω (i : Iic n) ↦ rewardByCount A R a i ω) := by
    simpa [Measure.prod] using h₁
  simpa [Measure.prod] using h₂
