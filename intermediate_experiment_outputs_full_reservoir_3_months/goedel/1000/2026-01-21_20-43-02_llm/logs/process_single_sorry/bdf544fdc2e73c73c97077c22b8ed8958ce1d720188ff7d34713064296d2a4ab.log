₁₀ : (Finset.Icc (m + 1) n).card = (n - m : ℕ).toNat := by\n              have h₁₁ : (Finset.Icc (m + 1) n).card = (n - m : ℕ).toNat := by\n                simp [Finset.Icc_eq_empty, Finset.card_range, Nat.sub_add_cancel, Nat.lt_succ_iff]\n                <;>\n                  (try omega) <;>\n                  (try\n                    {\n                      cases m <;> cases n <;> simp_all [PNat.one_coe, PNat.coe_lt_coe, Nat.succ_le_iff]\n                      <;>\n                      ring_nf at *\n                      <;>\n                      omega\n                    })\n                <;>\n                  (try\n                    {\n                      norm_num at *\n                      <;>\n                      simp_all [PNat.one_coe, PNat.coe_lt_coe, Nat.succ_le_iff]\n                      <;>\n                      ring_nf at *\n                      <;>\n                      omega\n                    })\n              exact h₁₁\n            have h₁₁ : (n - m : ℕ).toNat ≤ (n - m : ℕ+) := by\n              cases m <;> cases n <;> simp_all [PNat.one_coe, PNat.coe_lt_coe, Nat.succ_le_iff]\n              <;>\n                (try omega) <;>\n                (try\n                  {\n                    ring_nf at *\n                    <;>\n                    norm_cast at *\n                    <;>\n                    simp_all [Nat.toNat_of_nonneg]\n                    <;>\n                    omega\n                  })\n              <;>\n                (try\n                  {\n                    norm_num at *\n                    <;>\n                    simp_all [PNat.one_coe, PNat.coe_lt_coe, Nat.succ_le_iff]\n                    <;>\n                    ring_nf at *\n                    <;>\n                    omega\n                  })\n            have h₁₂ : (Finset.Icc (m + 1) n).card * (2014 : ℤ) ≤ (n - m : ℕ+) * 2014 := by\n              have h₁₃ : (Finset.Icc (m + 1) n).card ≤ (n - m : ℕ+) := by\n                have h₁₄ 