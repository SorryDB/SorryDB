             linarith\n            })\n      exact h₁₂\n    exact h₉\n  have h₆ : lim a = La := by\n    apply Eq.symm\n    apply Eq.symm\n    <;> simp_all [SeqLim]\n    <;> linarith\n  have h₇ : a n ≤ La := by linarith\n  exact h₇",
