have a_le_L : ∀ n, a n ≤ La := by
  intro n
  have h₁ : a n ≤ a n := le_refl (a n)
  have h₂ : Monotone a := aMono
  have h₃ : IsCauchy a := aCauchy
  have h₄ : SeqLim a La := hLa
  have h₅ : ∀ m ≥ n, a n ≤ a m := by
    intro m hm
    exact aMono hm
  have h₆ : a n ≤ La := by
    by_contra h
    have h₇ : La < a n := by linarith
    have h₈ : ∃ (ε : ℝ), 0 < ε ∧ a n - ε > La := by
      use (a n - La) / 2
      constructor
      · linarith
      · linarith
    obtain ⟨ε, hε_pos, hε⟩ := h₈
    have h₉ : ∃ (N : ℕ), ∀ m ≥ N, |a m - La| < ε := by
      have h₁₀ : Filter.Tendsto a Filter.atTop (nhds La) := by
        simpa [SeqLim] using hLa.tendsto
      have h₁₁ : ∀ ε > 0, ∃ (N : ℕ), ∀ m ≥ N, |a m - La| < ε := by
        intro ε hε_pos
        have h₁₂ : Filter.Tendsto a Filter.atTop (nhds La) := h₁₀
        have h₁₃ : ∀ ε > 0, ∃ (N : ℕ), ∀ m ≥ N, |a m - La| < ε := by
          intro ε hε_pos
          have h₁₄ : Metric.tendsto_atTop (fun n : ℕ => a n) (La : ℝ) :=
            h₁₂Metric.tendsto_atTop
          specialize h₁₄ ε hε_pos
          obtain ⟨N, hN⟩ := h₁₄
          refine' ⟨N, _⟩
          intro m hm
          specialize hN m hm
          simp [Real.dist_eq] at hN ⊢
          <;> linarith
        exact h₁₃ ε hε_pos
      exact hε_pos |>.imp fun N hN => ⟨N, hN⟩
    obtain ⟨N, hN⟩ := h₉
    have h₁₀ : ∀ m ≥ N, |a m - La| < ε := hN
    have h₁₁ : ∀ m ≥ N, a m < a n := by
      intro m hm
      have h₁₂ : |a m - La| < ε := h₁₀ m hm
      have h₁₃ : a m - La < ε := by
        linarith [abs_lt.mp h₁₂]
      have h₁₄ : a n - ε > La := hε
      have h₁₅ : a m < a n := by linarith
      exact h₁₅
    have h₁₆ : a (N + n) < a n := h₁₁ (N + n) (by linarith)
    have h₁₇ : a n ≤ a (N + n) := aMono (by linarith)
    linarith
  exact h₆
