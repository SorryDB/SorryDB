lemma eq_zero_of_I_zero_equinum {n : Nat} (h : I 0 ∼ I n) : n = 0 := by
  match n with
  | 0 => rfl
  | (n + 1) =>
    have h₁ : Fintype.card (I 0) = Fintype.card (I (n + 1)) := by
      apply h
    simp [Fintype.card_fin, I] at h₁
    <;>
    (try omega) <;>
    (try simp_all [Nat.succ_eq_add_one]) <;>
    (try omega)
