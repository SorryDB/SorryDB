theorem eq_zero_of_I_zero_equinum {n : Nat} (h : I 0 ∼ I n) : n = 0 := by
  have h₁ : n = 0 := by
    -- Use the fact that the cardinality of I 0 is 0 and I n is n
    have h₂ : Fintype.card (I 0) = 0 := by simp [Fintype.card_fin]
    have h₃ : Fintype.card (I n) = n := by simp [Fintype.card_fin]
    -- Since I 0 ∼ I n, their cardinalities must be equal
    have h₄ : Fintype.card (I 0) = Fintype.card (I n) := by
      apply Fintype.card_congr
      exact h
    -- Substitute the cardinalities into the equality
    rw [h₂] at h₄
    rw [h₃] at h₄
    -- Solve for n
    simp at h₄
    <;> omega
  exact h₁
