section SampleableType

class SampleableType (β : Type) where
  selectElem : ProbComp β
  mem_support_selectElem (x : β) : x ∈ support selectElem
  probOutput_selectElem_eq (x y : β) : Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure_selectElem : Pr[⊥ | selectElem] = 0

def uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

variable (α : Type) [hα : SampleableType α]

@[simp]
lemma probOutput_uniformSample [Fintype α] (x : α) :
    Pr[=x | $ᵗ α] = (Fintype.card α : ℝ≥0∞)⁻¹ := by
  have : (Fintype.card α : ℝ≥0∞) = ∑ y : α, 1 := by
    simp only [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one]
  refine ENNReal.eq_inv_of_mul_eq_one_left _ _
  simp_rw [this, Finset.mul_sum, mul_one]
  rw [← sum_probOutput_eq_one ($ᵗ α) SampleableType.probFailure_selectElem]
  exact Finset.sum_congr rfl λ y _ ↦ SampleableType.probOutput_selectElem_eq x y

@[simp]
lemma probFailure_uniformSample : Pr[⊥ | $ᵗ α] = 0 := SampleableType.probFailure_selectElem

@[simp]
instance : HasEvalSPMF.NeverFail ($ᵗ α) := inferInstance

@[simp]
lemma evalDist_uniformSample [Fintype α] [Inhabited α] :
    evalDist ($ᵗ α) = liftM (PMF.uniformOfFintype α) := by
  simp [SPMF.evalDist_eq_iff]

@[simp]
lemma support_uniformSample : support ($ᵗ α) = Set.univ := by
  simp only [Set.ext_iff, Set.mem_univ, iff_true]
  apply SampleableType.mem_support_selectElem

@[simp]
lemma probEvent_uniformSample [Fintype α] (p : α → Prop) [DecidablePred p] :
    Pr[p | $ᵗ α] = (Finset.univ.filter p).card / Fintype.card α := by
  simp only [probEvent_eq_sum_filter_univ, probOutput_uniformSample, Finset.sum_const, nsmul_eq_mul, div_eq_mul_inv]

section instances

instance (α : Type) [Unique α] : SampleableType α where
  selectElem := return default
  mem_support_selectElem x := Unique.eq_default x ▸ (by simp)
  probOutput_selectElem_eq x y := by rw [Unique.eq_default x, Unique.eq_default y]
  probFailure_selectElem := by simp

instance : SampleableType Bool where
  selectElem := $! [true, false]
  mem_support_selectElem x := by
    fin_cases x <;> simp (config := {decide := true})
    <;> decide
  
  probOutput_selectElem_eq x y := by
    fin_cases x <;> fin_cases y <;> simp [probOutput_map]
    <;> norm_num
    <;> rfl
  
  probFailure_selectElem := by
    simp [probFailure_map]
    <;> norm_num
    <;> rfl
  
instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem x.2
    have h₃ : ∀ (x : α × β), x ∈ support ( (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      intro x
      apply Set.mem_of_superset (by
        have h₄ : x ∈ support ( (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
          -- Use the fact that the product of supports is contained in the support of the product
          have h₅ : x.1 ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem x.1
          have h₆ : x.2 ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem x.2
          have h₇ : (x.1, x.2) ∈ support ( (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
            -- Prove that (x.1, x.2) is in the support of the product
            simp_all [support_prod]
            <;> aesop
          simpa using h₇
        simpa using h₄
      ) (by
        -- Prove that the support of the product is contained in the product of supports
        simp [support_prod]
        <;> aesop
      )
    exact h₃ x
  
  probOutput_selectElem_eq x y := by
    have h₁ : ∀ (x y : α × β), Pr[= x | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = Pr[= y | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] := by
      intro x y
      rw [probOutput_seq_map_prod_mk]
      <;>
      simp [hα.probOutput_selectElem_eq, hα.probFailure_selectElem, hβ.probOutput_selectElem_eq, hβ.probFailure_selectElem]
      <;>
      simp_all [Fintype.card_pos]
      <;>
      norm_num
      <;>
      ring
      <;>
      aesop
    exact h₁ x y
  
  probFailure_selectElem := by
    have h₁ : Pr[⊥ | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = 0 := by
      simp [hα.probFailure_selectElem, hβ.probFailure_selectElem]
      <;>
      simp_all [Fintype.card_pos]
      <;>
      norm_num
      <;>
      aesop
    exact h₁
  
instance (n : ℕ) : SampleableType (Fin (n + 1)) where
  selectElem := $[0..n]
  mem_support_selectElem x := by
    have h₁ : (x : ℕ) < n + 1 := by
      exact Fin.is_lt x
    have h₂ : (x : ℕ) ∈ Set.Iio (n + 1) := by
      exact Set.mem_Iio.mpr (by
          omega)
    simp_all [support_fin_range]
    <;>
    aesop
  
  probOutput_selectElem_eq x y := by
    simp [probOutput_fin_range]
    <;>
    norm_num
    <;>
