def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      have h₁ : u ≠ v := by
        intro h_uv_eq
        have h₂ : dstep.prod.val.lhs ∈ (G.V : Type) := by
          exact dstep.prod.val.lhs.prop
        simp_all [ContextFreeDerivation.exhaustiveCondition, ContextFreeDerivation.startsIn1Condition]
        <;> aesop
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive by tauto)[0]'by
        -- Use the fact that u ≠ v to deduce that the derivation tree is non-empty
        have h₂ : cfd ≠ [] := by
          intro h
          simp_all [cfd]
          <;> aesop
        simp_all [List.length_eq_zero]
        <;> aesop).fst
