theorem parserProof {G : ContextFreeGrammar α nt} {u v : Word (G.V ⊕ G.Z)} 
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G := 
  let h1 : False := by
    have h2 := h_exhaustive
    have h3 := h_starts_in_1
    cases cfd with
    | same h_same =>
      -- If u = v, then the exhaustive condition cannot be satisfied because there are no more steps to take
      exfalso
      simp [h_same] at h2 h3
      <;>
      (try contradiction) <;>
      (try simp_all [exhaustiveCondition, startsIn1Condition]) <;>
      (try omega)
    | step u' u'' dstep derivation sound =>
      -- If it's a step, we can analyze further, but in this case, we are assuming the derivation is already complete (exhaustive)
      exfalso
      simp_all [exhaustiveCondition, startsIn1Condition]
      <;>
      (try contradiction) <;>
      (try aesop)
  -- Since we have derived a contradiction, we can use the principle of explosion to get the desired result
  exfalso
  exact h1
