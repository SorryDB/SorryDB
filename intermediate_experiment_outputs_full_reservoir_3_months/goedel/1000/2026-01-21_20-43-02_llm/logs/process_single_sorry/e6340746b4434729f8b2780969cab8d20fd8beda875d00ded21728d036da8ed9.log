theorem is_filter_complete_pi_left {k M ι : Type*} [Ring k] [AddCommGroup M] [Module k M] [LE ι]
  (M_ : ι → Submodule k M) [IsFilterComplete M_] (α : Type*) :
  IsFilterComplete fun i => Submodule.pi Set.univ fun x => M_ i := by
  have h_main : IsFilterComplete fun i => Submodule.pi Set.univ fun x => M_ i := by
    refine' ⟨fun i => by
      -- We need to show that the submodule is a set of submodules that are filtered.
      -- This is straightforward since we are using the same filtered set of submodules M_.
      exact Set.Nonempty.intro (fun x => M_ i)⟩
  -- The main part of the proof is already done by h_main, so we just use it to conclude.
  exact h_main
