namespace IsFilterComplete

instance subrepToSubmodule {k G : Type u} [CommRing k] [Monoid G] (M : Rep k G)
    {ι : Type*} [LE ι] (M_ : ι → Subrep M) [IsFilterComplete M_] :
    IsFilterComplete fun i ↦ (M_ i).toSubmodule :=
  inferInstance

instance piLeft {k M ι : Type*} [Ring k] [AddCommGroup M] [Module k M]
    [LE ι] (M_ : ι → Submodule k M) [IsFilterComplete M_] (α : Type*) :
    IsFilterComplete fun i ↦ Submodule.pi Set.univ fun x => M_ i :=
  {
    isFilter := by
      infer_instance
    -- Prove that the intersection of any two sets in the filter is in the filter.
    inter : ∀ {i j : ι}, ↑(Submodule.pi Set.univ fun x => M_ i) ⊓ ↑(Submodule.pi Set.univ fun x => M_ j) ≤ ↑(Submodule.pi Set.univ fun x => M_ (i ⊓ j))
      := by
      intro i j
      simp [Submodule.inf_def, Submodule.pi, Set.univ, le_def]
      <;>
      (try apply iInf_le_of_le) <;>
      (try simp_all [Submodule.mem_carrier, Set.mem_univ])
      <;>
      (try aesop)
      <;>
      (try
        {
          intros
          simp_all [Submodule.mem_carrier, Set.mem_univ]
          <;>
          aesop
        })
      <;>
      (try
        {
          intros
          simp_all [Submodule.mem_carrier, Set.mem_univ]
          <;>
          aesop
        })
    }
