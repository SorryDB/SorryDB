    -- We need to show that the intersection of any decreasing sequence of submodules is 0.
    -- For each component, the intersection is 0 because M_ is IsFilterComplete.
    -- Hence, the product of these intersections is 0, and the product of the submodules is also 0.
    refine' ⟨fun s hs => _⟩
    have h : (⋂ i ∈ s, Submodule.pi Set.univ (fun _ : α ↦ M_ i)) = Submodule.pi Set.univ (fun x : α ↦ ⋂ i ∈ s, M_ i) := by
      -- The intersection of products is the product of intersections.
      congr with x
      <;> simp [Set.mem_univ]
      <;>
      simp_all [Submodule.mem_pi, Submodule.mem_iInf]
