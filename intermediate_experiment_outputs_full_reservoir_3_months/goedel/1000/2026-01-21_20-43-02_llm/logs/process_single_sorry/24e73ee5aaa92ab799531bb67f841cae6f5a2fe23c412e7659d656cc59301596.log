theorem all_pow_self_eq_one {G : Type*} [CommMonoid G]
  (h : ∀ x : G, x ^ 2 = 1) :
  ∀ x : G, x = 1 := by
  intro x
  have h₁ : x ^ 2 = 1 := h x
  have h₂ : x * x = 1 := by simpa [pow_two] using h₁
  have h₃ : x = 1 := by
    have h₄ : x⁻¹ = x := by
      apply inv_eq_of_mul_eq_one_right
      simpa [mul_comm] using h₂
    calc
      x = x * 1 := by simp
      _ = x * (x * x) := by rw [h₂]
      _ = (x * x) * x := by simp [mul_assoc]
      _ = 1 * x := by rw [h₂]
      _ = x := by simp
      _ = 1 := by
        -- Using the fact that x * x = 1, we can deduce x = 1 by multiplying both sides by x⁻¹
        have h₅ : x * x = 1 := h₂
        have h₆ : x⁻¹ = x := by
          apply inv_eq_of_mul_eq_one_right
          simpa [mul_comm] using h₂
        calc
          x = x * 1 := by simp
          _ = x * (x * x) := by rw [h₂]
          _ = (x * x) * x := by simp [mul_assoc]
          _ = 1 * x := by rw [h₂]
          _ = x := by simp
          _ = 1 := by
            -- Since x * x = 1, x must be its own inverse, and thus x^2 = 1 implies x = 1
            have h₇ : x ^ 2 = 1 := h₁
            have h₈ : x⁻¹ = x := by
              apply inv_eq_of_mul_eq_one_right
              simpa [mul_comm] using h₂
            simp_all [pow_two, mul_assoc]
            <;>
            (try simp_all [mul_assoc]) <;>
            (try simp_all [mul_comm]) <;>
            (try simp_all [mul_left_comm]) <;>
            (try simp_all [pow_two]) <;>
            (try simp_all [inv_eq_one]) <;>
            (try simp_all [mul_inv_self]) <;>
            (try simp_all [one_mul]) <;>
            (try simp_all [mul_one]) <;>
            (try simp_all [inv_inv]) <;>
            (try simp_all [inv_mul_cancel_left]) <;>
            (try simp_all [inv_mul_cancel_right])
            <;>
            (try aesop)
  exact h₃
