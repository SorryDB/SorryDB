def r : Sequence := by
  /-
  The sequence is defined as:
  - The first character is '0' (base case).
  - For each subsequent character, if the current character is '0', the next character is '1'.
    If the current character is '1', the next character is '0'.
  
  This results in the sequence: 0, 1, 0, 1, 0, 1, ...
  -/
  exact
    Sequence.tuple ("01" : String).toList |>
    Sequence.range [0] |>
    (fun i => (i + 1) % 2) |>
    (fun v => if v = 0 then '0' else '1')
  
example (r : Sequence) :
 (Sequence.mem r "111" → false) := by
  intro h
  have h₁ := h
  simp [Sequence.mem] at h₁
  <;>
  (try contradiction) <;>
  (try {
    have h₂ := h₁
    simp [Sequence.get] at h₂ <;>
    (try contradiction) <;>
    (try omega)
  }) <;>
  (try {
    rcases h₁ with ⟨i, hi⟩
    have h₂ := hi
    simp [Sequence.get] at h₂ <;>
    (try contradiction) <;>
    (try omega)
  })
  <;>
  (try {
    have h₂ := h₁
    simp [Sequence.get] at h₂ <;>
    (try contradiction) <;>
    (try omega)
  })
```
