class SampleableType (β : Type) where
  selectElem : ProbComp β
  mem_support_selectElem (x : β) : x ∈ support selectElem
  probOutput_selectElem_eq (x y : β) : Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure_selectElem : Pr[⊥ | selectElem] = 0

def uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

instance (α : Type) [Fintype α] [Inhabited α] : SampleableType α :=
  ⟨ return default,
    Fintype.card_pos_iff.mpr (inferInstance : Nonempty α) |>.imp (fun ⟨x, hx⟩ => ⟨x, by simp⟩),
    fun x y => by
      have h₁ : (Fintype.card α : ℕ) ≠ 0 := Fintype.card_pos_iff.mpr ⟨default, inferInstance⟩
      have h₂ : (Fintype.card α : ℕ) ≠ 0 := by simpa using h₁
      simp [h₁, h₂, Fintype.card_pos_iff]
      <;>
      (try simp_all)
      <;>
      (try {
        simp_all [Fintype.card_pos_iff]
        <;>
        (try {
          exfalso
          <;>
          simp_all [Fintype.card_pos_iff]
        })
      })
      <;>
      (try {
        simp_all [Fintype.card_pos_iff]
        <;>
        (try {
          omega
        })
      })
    , by simp⟩

def evalDist (dir : ProbComp α) : OptionT PMF α :=
  (dir : OptionT PMF α)

def memory : ProbC α :=
  3 + 2

def independent : PropC :=
  False

def evalDist_eq_iff (dir₁ dir₂ : ProbComp α) :
    evalDist dir₁ = evalDist dir₂ ↔
    ∀ (x : Option α), (evalDist dir₁).eval x = (evalDist dir₂).eval x := by
  have h₁ : ∀ {a b : OptionT PMF α}, a = b ↔ ∀ (x : Option α), a.eval x = b.eval x := by
    intro a b
    constructor
    · intro h
      intro x
      rw [h]
    · intro h
      apply OptionT.ext
      intro x
      exact h x
  exact h₁.trans (congr_arg (· = ·) (rfl : evalDist dir₁ = evalDist dir₂))
