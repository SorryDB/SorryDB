def select : Fin (n + 1) → α := fun i => i.val

lemma mem_support (x : α) : x ∈ support (sample select) := by
  -- Use the fact that the sample function is surjective to show that every element of α is in the support
  have h₁ : ∀ y : α, ∃ (i : Fin (n + 1)), y = select i := by
    intro y
    have h₂ : y ∈ Set.range select := by
      -- Since the sample function is surjective, y is in the range of select
      apply Function.surjective y
    -- Therefore, there exists an i such that y = select i
    obtain ⟨i, hi⟩ := h₂
    exact ⟨i, by simp_all⟩
  -- For any x : α, there exists an i such that x = select i
  have h₂ : x ∈ support (sample select) := by
    obtain ⟨i, hi⟩ := h₁ x
    -- Since sample select is the distribution of select, and x = select i, x is in the support
    have h₃ : x = select i := by simp_all
    have h₄ : select i ∈ support (sample select) := by
      apply support_sample
    -- Therefore, x is in the support
    rw [h₃] at *
    exact h₄
  exact h₂

lemma probOutput_eq (x y : α) : Pr[=x|sample select] = Pr[=y|sample select] := by
  -- Since the sample function is uniform, the probability of selecting any element is the same
  have h₁ : ∀ x y : α, Pr[=x|sample select] = Pr[=y|sample select] := by
    intro x y
    -- Use the fact that the sample function is uniform and the probabilities are equal
    have h₂ : Pr[=x|sample select] = 1 / (n + 1 : ℝ≥0∞) := by
      -- Calculate the probability of selecting x
      have h₃ : sample select = sample select := rfl
      simp [h₃, sample_eq_sample, select_eq]
      <;> field_simp [Nat.cast_add_one_ne_zero] <;>
        simp_all [ENNReal.ofReal_div, ENNReal.ofReal_one]
      <;> ring_nf
      <;> norm_num
    have h₃ : Pr[=y|sample select] = 1 / (n + 1 : ℝ≥0∞) := by
      -- Calculate the probability of selecting y
      have h₄ : sample select = sample select := rfl
      simp [h₄, sample_eq_sample, select_eq]
      <;> field_simp [Nat.cast_add_one_ne_zero] <;>
        simp_all [ENNReal.ofReal_div, ENNReal.ofReal_one]
      <;> ring_nf
      <;> norm_num
    -- Since both probabilities are the same, they are equal
    linarith
  -- Apply the general result to x and y
  exact h₁ x y

lemma probFailure : Pr[⊥|sample select] = 0 := by
  -- Since the sample function never fails, the probability of failure is 0
  have h₁ : Pr[⊥|sample select] = 0 := by
    simp [sample_eq_sample, select_eq]
    <;>
    simp_all [ENNReal.ofReal_zero]
    <;>
    norm_num
