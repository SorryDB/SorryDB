  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsCompact (closure S) := by
    apply Iff.intro
    · intro h_tight
      -- Use the fact that a tight set of probability measures is precompact in the weak* topology
      -- and then take the closure to get a compact set.
      have h₂ : IsPrecompact S := by
        -- Use the Prokhorov's theorem to show that S is precompact
        have h₃ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := h_tight
        have h₄ : IsPrecompact S := by
          -- Apply the Prokhorov's theorem
          have h₅ : IsTight S := by
            -- Convert the tightness of the set of measures to the tightness of S
            simpa [Set.ext_iff] using h₃
          -- Use the fact that a tight set of probability measures is precompact
          exact isPrecompact_of_tight h₅
        exact h₄
      -- Since S is precompact, its closure is compact
      have h₃ : IsCompact (closure S) := by
        -- Use the fact that the closure of a precompact set is compact
        have h₄ : IsCompact (closure S) := h₂.isCompact_closure
        exact h₄
      exact h₃
    · intro h_compact
      -- Use the fact that a compact set of probability measures is tight
      -- and then show that the set of measures is tight.
      have h₂ : IsTight S := by
        -- Since the closure of S is compact, S is precompact
        have h₃ : IsPrecompact S := by
          -- Use the fact that a subset of a compact set is precompact
          have h₄ : S ⊆ closure S := by
            -- A set is a subset of its closure
            exact subset_closure
          -- Since closure S is compact, it is precompact
          have h₅ : IsCompact (closure S) := h_compact
          -- A subset of a precompact set is precompact
          exact IsPrecompact.mono h₄ h₅.isPrecompact
        -- Use the fact that a precompact set of probability measures is tight
        exact isTight_of_precompact h₃
      -- Convert the tightness of S to the tightness of the set of measures
      have h₃ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
        simpa [Set.ext_iff] using h₂
      exact h₃
  exact h₁
