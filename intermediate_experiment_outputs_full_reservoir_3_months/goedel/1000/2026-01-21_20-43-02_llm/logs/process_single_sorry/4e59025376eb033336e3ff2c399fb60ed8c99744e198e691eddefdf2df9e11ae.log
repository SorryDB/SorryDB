              refine' ⟨s, hs, _⟩
              intro μ hμ
              have h₁₀ : ∃ ν ∈ s, dist ν μ < ε := by
                have h₁₁ : μ ∈ closure S := hμ
                have h₁₂ : ∃ ν ∈ s, dist ν μ < ε := by
                  have h₁₃ := h₉ μ h₁₁
                  obtain ⟨ν, hν, hνμ⟩ := h₁₃
                  exact ⟨ν, hν, by simpa [dist_eq_norm] using hνμ⟩
                exact h₁₂
              exact h₁₀
            obtain ⟨s, hs, h₉⟩ := h₇
            refine' ⟨s, hs, _⟩
            intro μ hμ
            have h₁₀ : μ ∈ S := hμ
            have h₁₁ : μ ∈ closure S := by
              exact subset_closure h₁₀
            have h₁₂ : ∃ ν ∈ s, dist ν μ < ε := h₉ μ h₁₁
            exact h₁₂
          -- Use the fact that the set of probability measures is totally bounded
          exact isTight_iff.totallyBounded.mpr (by
            -- Use the fact that the set of probability measures is totally bounded
            have h₈ : ∀ ε > 0, ∃ (s : Set (ProbabilityMeasure E)), s.Finite ∧ ∀ μ ∈ S, ∃ ν ∈ s, dist ν μ < ε := h₆
            -- Use the fact that the set of probability measures is totally bounded
            exact Metric.totallyBounded_iff.mpr h₈
          )
        exact h₅
      exact h₃
    -- Convert the tightness condition from the set of probability measures to the set of measures
    have h₂ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
      simpa [ProbabilityMeasure.coe_le_coe] using h₁
    exact h₂
