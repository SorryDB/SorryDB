theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h_main : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsCompact (closure S) := by
    have h1 : {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} = {x : Measure E | ∃ μ : ProbabilityMeasure E, μ ∈ S ∧ (x : Measure E) = (μ : Measure E)} := by
      ext x
      simp [Set.mem_setOf_eq]
      <;> aesop
    rw [h1]
    have h2 : IsTightMeasureSet {x : Measure E | ∃ μ : ProbabilityMeasure E, μ ∈ S ∧ (x : Measure E) = (μ : Measure E)} ↔ IsCompact (closure S) := by
      -- Use the fact that the set of probability measures is Prokhorov and the implication between tightness and compactness.
      have h3 : IsTightMeasureSet {x : Measure E | ∃ μ : ProbabilityMeasure E, μ ∈ S ∧ (x : Measure E) = (μ : Measure E)} ↔ IsCompact (closure S) := by
        -- Use the Prokhorov theorem to establish the equivalence.
        have h4 : IsTightMeasureSet {x : Measure E | ∃ μ : ProbabilityMeasure E, μ ∈ S ∧ (x : Measure E) = (μ : Measure E)} ↔ IsCompact (closure S) := by
          -- Use the fact that the set of probability measures is Prokhorov and the implication between tightness and compactness.
          rw [isTightMeasureSet_iff_isCompact_closure]
          <;>
          (try aesop) <;>
          (try simp_all [MetricSpace, CompleteSpace, SecondCountableTopology, BorelSpace]) <;>
          (try norm_num) <;>
          (try aesop)
        exact h4
      exact h3
    exact h2
  exact h_main
