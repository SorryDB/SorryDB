  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  apply Iff.intro
  · intro h
    have h₁ : IsTight S := by
      -- Convert the tightness condition from the set of measures to the set of probability measures
      simpa [ProbabilityMeasure.coe_le_coe] using h
    -- Use the fact that S is tight to show that its closure is compact
    have h₂ : IsCompact (closure S) := by
      apply Metric.totallyBounded_subset_of_isClosed
      · -- Show that the set of probability measures is totally bounded
        exact (totallyBounded_closure_iff.mpr (by
          -- Use the fact that the set of probability measures is totally bounded
          have h₃ : ∀ ε > 0, ∃ (s : Set (ProbabilityMeasure E)), s.Finite ∧ ∀ μ ∈ S, ∃ ν ∈ s, dist ν μ < ε := by
            intro ε εpos
            -- Use the fact that the set of probability measures is totally bounded
            have h₄ := h₁.totallyBounded ε εpos
            obtain ⟨s : Set (Measure E), hs, h₅⟩ := h₄
            -- Construct a finite set of probability measures
            refine' ⟨{μ : ProbabilityMeasure E | (μ : Measure E) ∈ s}, _, _⟩
            · -- Show that the set is finite
              have h₆ : ({μ : ProbabilityMeasure E | (μ : Measure E) ∈ s} : Set (ProbabilityMeasure E)).Finite := by
                -- Use the fact that s is finite
                have h₇ : Set.Finite s := hs
                -- Use the fact that the coercion from ProbabilityMeasure to Measure is injective
                have h₈ : Set.InjOn (fun (μ : ProbabilityMeasure E) => (μ : Measure E)) {μ : ProbabilityMeasure E | (μ : Measure E) ∈ s} := by
                  intro μ hμ ν hν hμν
                  simp_all [Subtype.ext_iff]
                  <;> aesop
                -- Use the fact that the coercion is injective to show that the set is finite
                exact Set.Finite.subset h₇ (fun μ hμ => by
                  simp_all [Set.mem_setOf_eq]
                  <;> aesop)
              exact h₆
            · -- Show that for any μ in S, there exists a ν in the finite set such that dist ν μ < ε
              intro μ hμ
              have h₆ : (μ : Measure E) ∈ closure (S : Set (Measure E)) := by
                -- Use the fact that μ is in S to show that it is in the closure of S
                have h₇ : (μ : Measure E) ∈ (S : Set (Measure E)) := by
                  exact Set.mem_setOf.mpr hμ
                exact Subset.mem_closure h₇
              -- Use the fact that s is a nonempty finite set to find a ν in s such that dist ν μ < ε
              have h₇ : ∃ (ν : (ProbabilityMeasure E)), (ν : Measure E) ∈ s ∧ dist (ν : Measure E) (μ : Measure E) < ε := by
                have h₈ := Metric.totallyBounded_iff.mp h₄ (closure (S : Set (Measure E))) (by
                  -- Show that closure(S) is compact
                  have h₉ : IsCompact (closure (S : Set (Measure E))) := by
