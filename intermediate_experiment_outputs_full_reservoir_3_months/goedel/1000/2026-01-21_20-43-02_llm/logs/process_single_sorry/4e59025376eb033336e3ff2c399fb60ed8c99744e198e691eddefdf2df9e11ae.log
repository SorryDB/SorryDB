                    have h₁₀ : S ⊆ {μ : Measure E | μ.totalVolume = 1} := by
                      intro μ hμ
                      -- Use the fact that μ is a probability measure
                      have h₁₁ : μ.totalVolume = 1 := by
                        simp [μ.2]
                        <;> aesop
                      simp_all [Set.mem_setOf_eq]
                      <;> aesop
                    -- Use the fact that the set of probability measures is compact
                    have h₁₁ : IsCompact {μ : Measure E | μ.totalVolume = 1} := by
                      -- Use the fact that the set of probability measures is compact
                      have h₁₂ : IsCompact {μ : Measure E | μ.totalVolume = 1} := by
                        -- Use the fact that the set of probability measures is compact
