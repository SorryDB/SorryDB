  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h_main : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsCompact (closure S) := by
    -- Use the fact that the space of probability measures is compact iff it is tight
    have h1 : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTight S := by
      -- Convert the set of measures to a set of probability measures
      simp [IsTightMeasureSet, Set.mem_setOf_eq]
      <;>
      congr 1 <;>
      ext μ <;>
      simp [ProbabilityMeasure.coe_eq_coe]
      <;>
      aesop
    have h2 : IsTight S ↔ IsCompact (closure S) := by
      -- Use Prokhorov's theorem to relate tightness to compactness
      have h3 : IsTight S ↔ IsCompact (closure S) := by
        -- Apply Prokhorov's theorem
        apply Iff.intro
        · -- Prove the forward direction: tight implies compact closure
          intro h
          have h4 : IsCompact (closure S) := by
            -- Use the fact that S is tight to show that its closure is compact
            have h5 : IsTight S := h
            -- Use Prokhorov's theorem to get compactness
            have h6 : IsCompact (closure S) := by
              apply Metric.isCompact_closure
              <;>
              (try simp_all [IsTight, Metric.tendsto_nhdsWithin_nhds, tendsto_const_nhds]) <;>
              (try exact Metric.tight_iff_isCompact_closure.mp h5) <;>
              (try aesop)
            exact h6
          exact h4
        · -- Prove the reverse direction: compact closure implies tight
          intro h
          have h4 : IsTight S := by
            -- Use the fact that the closure is compact to show that S is tight
            have h5 : IsCompact (closure S) := h
            -- Use Prokhorov's theorem to get tightness
            have h6 : IsTight S := by
              have h7 : IsTight (closure S) := by
                -- Use the fact that the closure is compact to show it is tight
                have h8 : IsCompact (closure S) := h5
                -- Use the fact that compact sets are tight
                have h9 : IsTight (closure S) := by
                  -- Use the fact that compact sets are tight
                  simpa [IsTight] using Metric.isCompact_iff_isTight.mp h8
                exact h9
              -- Use the fact that S is a subset of its closure to get tightness
              have h10 : S ⊆ closure S := by
                apply subset_closure
              -- Use the fact that tightness is preserved under subsets
              have h11 : IsTight S := by
                -- Use the fact that S is a subset of a tight set
                exact IsTight.mono h10 h7
              exact h11
            exact h6
          exact h4
      exact h3
    -- Combine the two equivalences to get the final result
    rw [h1]
    rw [h2]
  -- Use the main result to conclude the proof
  exact h_main
