theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTightMeasureSet S := by
    constructor <;> intro h <;> simp_all [IsTightMeasureSet, Set.mem_setOf_eq]
    <;>
    (try
      aesop) <;>
    (try
      {
        refine' h.subset _
        intro μ hμ
        aesop
      }) <;>
    (try
      {
        refine' h.subset _
        intro μ hμ
        aesop
      })
  have h₂ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
    -- Use the theorem from the library that directly relates tightness to compactness
    have h₃ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
      apply Iff.intro
      · -- Prove the forward direction: if S is tight, then closure S is compact
        intro h_tight
        have h₄ : IsCompact (closure S) := by
          -- Use the fact that a tight set of probability measures is relatively compact
          have h₅ : IsCompact (closure S) := by
            -- Use the theorem from the library that directly relates tightness to compactness
            apply isCompact_closure_iff.mpr
            -- Use the fact that a tight set of probability measures is relatively compact
            exact
              Metric.tendsto_nhdsWithin_nhds_of_complete_of_discrete _ _ (by infer_instance)
                (by
                  aesop
                  <;>
                  simp_all [IsTightMeasureSet, Set.mem_setOf_eq]
                  <;>
                  aesop)
          exact h₅
        exact h₄
      · -- Prove the reverse direction: if closure S is compact, then S is tight
        intro h_compact
        have h₄ : IsTightMeasureSet S := by
          -- Use the fact that a compact set of probability measures is tight
          exact
            isTight_iff_isCompact_closure.mpr (by
              simpa using h_compact)
        exact h₄
    exact h₃
  -- Combine the two implications to get the final result
  rw [h₁]
  rw [h₂]
  <;>
  aesop
