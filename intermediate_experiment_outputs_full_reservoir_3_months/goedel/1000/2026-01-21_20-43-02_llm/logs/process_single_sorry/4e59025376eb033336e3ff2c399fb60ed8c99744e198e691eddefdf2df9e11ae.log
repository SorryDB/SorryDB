theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsCompact (closure S) := by
    have h₂ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTight S := by
      constructor
      · -- Prove the forward direction: if the set of measures is tight, then S is tight
        intro h
        have h₃ : IsTight S := by
          -- Use the fact that the set of measures is tight to show that S is tight
          rw [isTight_iff_forall_exists_compact] at h ⊢
          intro ε εpos
          -- Obtain the compact set from the tightness of the set of measures
          rcases h ε εpos with ⟨K, hK₁, hK₂⟩
          -- Use the same compact set to show tightness of S
          refine' ⟨K, _⟩
          intro μ hμ
          have h₄ : ((μ : ProbabilityMeasure E) : Measure E) ∈ {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
            simp [hμ]
          have h₅ : (μ : Measure E) (E \ K) < ε := by
            specialize hK₂ h₄
            simpa using hK₂
          simpa using h₅
        exact h₃
      · -- Prove the reverse direction: if S is tight, then the set of measures is tight
        intro h
        have h₃ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
          -- Use the fact that S is tight to show that the set of measures is tight
          rw [isTightMeasureSet_iff]
          intro ε εpos
          -- Obtain the compact set from the tightness of S
          rcases h ε εpos with ⟨K, hK₁, hK₂⟩
          -- Use the same compact set to show tightness of the set of measures
          refine' ⟨K, _⟩
          intro μ hμ
          rcases hμ with ⟨μ', hμ', rfl⟩
          have h₄ : (μ' : Measure E) (E \ K) < ε := by
            have h₅ : μ' ∈ S := hμ'
            have h₆ : (μ' : Measure E) (E \ K) < ε := by
              specialize hK₂ h₅
              simpa using hK₂
            exact h₆
          simpa using h₄
        exact h₃
    have h₃ : IsTight S ↔ IsCompact (closure S) := by
      -- Use the fact that the space of probability measures is metrizable and the set is closed to show the equivalence
      have h₄ : IsTight S ↔ IsCompact (closure S) := by
        -- This is a known result in probability theory, so we use it directly
        exact Metric.tight_iff_closure_compact S
      exact h₄
    -- Combine the two equivalences to get the final result
    calc
      IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTight S := h₂
      _ ↔ IsCompact (closure S) := h₃
  exact h₁
