theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTightMeasureSet S := by
    constructor
    · -- Prove the forward direction: if the set is tight as a set of measures, then S is tight
      intro h
      simpa [Set.ext_iff] using h
    · -- Prove the reverse direction: if S is tight, then the set is tight as a set of measures
      intro h
      simpa [Set.ext_iff] using h
  have h₂ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
    have h₃ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
      -- Use the fact that in complete metric spaces, tightness is equivalent to compactness of the closure
      have h₄ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
        -- Prove that S is tight if and only if the closure of S is compact
        have h₅ : IsTightMeasureSet S ↔ IsCompact (closure S) := by
          -- Use the known result about tight families and compactness in metric spaces
          apply Iff.intro
          · -- Prove the forward direction: if S is tight, then the closure of S is compact
            intro h₆
            -- Use the fact that tightness implies compactness in complete metric spaces
            have h₇ : IsCompact (closure S) := by
              -- Use the known theorem about tight families of probability measures
              have h₈ : IsTight (S : Set (ProbabilityMeasure E)) := by
                -- Convert the tightness condition to the appropriate form
                simpa [IsTightMeasureSet] using h₆
              -- Apply the known theorem to conclude compactness of the closure
              exact isCompact_closure (isTight_iff_compact_closure.mp h₈)
            exact h₇
          · -- Prove the reverse direction: if the closure of S is compact, then S is tight
            intro h₆
            -- Use the fact that compactness implies tightness in complete metric spaces
            have h₇ : IsTight (S : Set (ProbabilityMeasure E)) := by
              -- Apply the known theorem about tight families of probability measures
              have h₈ : IsCompact (closure S) := h₆
              have h₉ : IsTight (S : Set (ProbabilityMeasure E)) := by
                -- Convert the compactness condition to the appropriate form
                exact isTight_iff_compact_closure.mpr ⟨h₈, by simp [closure_eq_iff_isClosed]⟩
              exact h₉
            -- Convert the tightness condition to the appropriate form
            simpa [IsTightMeasureSet] using h₇
        exact h₅
      exact h₄
    exact h₃
  -- Combine the two equivalences using the fact that the set of measures is tight if and only if S is tight, which in turn is equivalent to the closure of S being compact
  rw [h₁]
  rw [h₂]
  <;> simp_all
