theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  have h₁ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} ↔ IsTight S := by
    constructor
    · -- Prove the forward direction: if the set of measures is tight, then S is tight.
      intro h
      have h₂ : IsTight S := by
        -- Use the fact that the set of measures is tight to deduce that S is tight.
        simpa [ProbabilityMeasure.isTight_iff] using h
      exact h₂
    · -- Prove the reverse direction: if S is tight, then the set of measures is tight.
      intro h
      have h₂ : IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S} := by
        -- Use the fact that S is tight to deduce that the set of measures is tight.
        simpa [ProbabilityMeasure.isTight_iff] using h
      exact h₂
  have h₂ : IsTight S ↔ IsCompact (closure S) := by
    -- Use the fact that the space of probability measures is compact if and only if it is tight.
    have h₃ : IsTight S ↔ IsCompact (closure S) := by
      -- Use the appropriate lemma to establish the equivalence.
      apply (isTight_iff_isCompact_closure
        (secondCountable := ‹_›)
        (complete := ‹_›))
    exact h₃
  -- Combine the two equivalences to get the final result.
  rw [h₁, h₂]
  <;> aesop
