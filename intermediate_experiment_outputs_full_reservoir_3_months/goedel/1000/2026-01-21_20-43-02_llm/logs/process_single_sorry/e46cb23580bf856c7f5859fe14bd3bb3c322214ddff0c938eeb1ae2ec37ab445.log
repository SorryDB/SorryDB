      "\n  have h₁ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n    have h₂ : ∀ x ∈ Set.Ioc (0 : ℝ) 1, ‖Φ₅ r x‖ ≤ r + 7 := by\n      intro x hx\n      have h₃ : 0 < x := by exact hx.1\n      have h₄ : x ≤ 1 := by exact hx.2\n      have h₅ : ‖Φ₅ r x‖ ≤ r + 7 := by\n        -- Use the bound on Φ₅ from the problem statement\n        have h₆ : ‖Φ₅ r x‖ ≤ r + 7 := by\n          -- This is a placeholder for the actual bound derivation\n          -- In a real proof, we would use the specific form of Φ₅ and its properties\n          -- For example, if Φ₅ r x = r * x + 7, then ‖Φ₅ r x‖ = |r * x + 7| ≤ r + 7\n          -- since 0 < x ≤ 1 and r ≥ 0.\n          -- Here, we assume the bound is given or can be derived similarly.\n          have h₇ : ‖Φ₅ r x‖ ≤ r + 7 := by\n            -- Placeholder for actual bound derivation\n            norm_num [Φ₅, Complex.norm_eq_abs] at *\n            <;>\n            (try norm_num) <;>\n            (try linarith) <;>\n            (try\n              {\n                cases' le_total 0 (r * x + 7 : ℝ) with h h <;>\n                cases' le_total 0 (r * x - 7 : ℝ) with h' h' <;>\n                simp_all [abs_of_nonneg, abs_of_nonpos, add_assoc] <;>\n                nlinarith [hr, h₃.le, h₄]\n              }) <;>\n            (try\n              {\n                cases' le_total 0 (r * x + 7 : ℝ) with h h <;>\n                cases' le_total 0 (r * x - 7 : ℝ) with h' h' <;>\n                simp_all [abs_of_nonneg, abs_of_nonpos, add_assoc] <;>\n                nlinarith [hr, h₃.le, h₄]\n              })\n            <;>\n            (try\n              {\n                cases' le_total 0 (r * x + 7 : ℝ) with h h <;>\n                cases' le_total 0 (r * x - 7 : ℝ) with h' h' <;>\n                simp_all [abs_of_nonneg, abs_of_nonpos, add_assoc] <;>\n                nlinarith [hr, h₃.le, h₄]\n              })\n          exact h₇\n        exact h₆\n      exact h₅\n    -- Use the bound to show that the integral is finite\n    have h₃ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n      -- Apply the dominated convergence theorem or similar\n      -- Here, we use the fact that the function is bounded by an integrable function\n      have h₄ : HasFiniteIntegral (fun x : ℝ => (r + 7 : ℝ)) (volume.restrict (Ioc 0 1)) := by\n        -- The constant function is integrable on a finite interval\n        have h₅ : HasFiniteIntegral (fun x : ℝ => (r + 7 : ℝ)) (volume.restrict (Ioc 0 1)) := by\n          -- Use the fact that the interval is finite and the function is constant\n          have h₆ : MeasureTheory.Measure (volume.restrict (Ioc (0 : ℝ) 1)) (Set.univ : Set ℝ) < ∞ := by\n            -- The measure of the interval is finite\n            have h₇ : MeasureTheory.Measure (volume.restrict (Ioc (0 : ℝ) 1)) (Set.univ : Set ℝ) = 1 := by\n              -- Calculate the measure\n              simp [MeasureTheory.Measure.restrict, Real.volume_Ioc]\n              <;> norm_num\n            rw [h₇]\n            <;> norm_num\n          -- Use the fact that the function is constant and the measure is finite\n          have h₈ : HasFiniteIntegral (fun x : ℝ => (r + 7 : ℝ)) (volume.restrict (Ioc 0 1)) := by\n            -- Use the fact that the function is constant and the measure is finite\n            have h₉ : (fun x : ℝ => (r + 7 : ℝ)) = fun x : ℝ => (r + 7 : ℝ) := rfl\n            rw [h₉]\n            -- Use the fact that the function is constant and the measure is finite\n            have h₁₀ : HasFiniteIntegral (fun x : ℝ => (r + 7 : ℝ)) (volume.restrict (Ioc 0 1)) := by\n              -- Use the fact that the function is constant and the measure is finite\n              apply hasFiniteIntegral_const\n              <;>\n              (try simp_all) <;>\n              (try norm_num) <;>\n              (try linarith)\n            exact h₁₀\n          exact h₈\n        exact h₅\n      -- Use the fact that the function is bounded by an integrable function\n      have h₅ : ∀ x ∈ Set.Ioc (0 : ℝ) 1, ‖Φ₅ r x‖ ≤ (r + 7 : ℝ) := by\n        intro x hx\n        have h₆ : ‖Φ₅ r x‖ ≤ r + 7 := h₂ x hx\n        simpa using h₆\n      -- Use the fact that the function is bounded by an integrable function\n      have h₆ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n        -- Use the fact that the function is bounded by an integrable function\n        refine' (HasFiniteIntegral.of_norm_bounded _ h₄ _)\n        -- Show that the norm of the function is bounded by the constant function\n        intro x hx\n        have h₇ : ‖Φ₅ r x‖ ≤ (r + 7 : ℝ) := h₅ x hx\n        simpa using h₇\n      exact h₆\n    exact h₃\n  -- Use the fact that the function has a finite integral to conclude integrability\n  refine' h₁.integrableOn",
