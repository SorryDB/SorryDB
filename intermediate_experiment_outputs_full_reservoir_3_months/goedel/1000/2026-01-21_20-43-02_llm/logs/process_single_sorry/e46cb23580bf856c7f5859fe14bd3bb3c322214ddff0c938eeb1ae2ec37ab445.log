    -- Use the fact that the function is continuous on [0, 1] and the interval [0, 1] has finite measure to deduce that the integral is finite.
    have h₃ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r) x) (volume.restrict (Ioc 0 1)) := by
      -- Use the fact that the function is continuous on [0, 1] and the interval [0, 1] has finite measure to deduce that the integral is finite.
