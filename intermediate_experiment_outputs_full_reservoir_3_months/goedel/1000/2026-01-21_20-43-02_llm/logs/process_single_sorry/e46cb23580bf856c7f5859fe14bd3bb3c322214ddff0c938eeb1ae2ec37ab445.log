        exact h₈
      -- Use the fact that g is bounded above by C to conclude the proof
      have h₈ : HasFiniteIntegral g (volume.restrict (Ioc 0 1)) := by
        have h₉ : ∀ x ∈ (Ioc 0 1 : Set ℝ), g x ≤ C := by
