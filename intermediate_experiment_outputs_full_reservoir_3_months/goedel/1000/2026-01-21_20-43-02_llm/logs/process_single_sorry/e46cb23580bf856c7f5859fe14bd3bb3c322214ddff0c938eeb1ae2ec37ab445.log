    <;>\n          norm_num\n          <;>\n          linarith\n        -- Use the fact that the interval is bounded and hence has finite volume\n        exact h₄\n      -- Use the fact that the interval is bounded and hence has finite volume\n      exact h₃\n    -- Use the fact that the interval (0,1] has finite volume to conclude the proof\n    have h₃ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n      -- Use the fact that the function is continuous on the interval (0,1] and the interval is compact\n      -- to conclude that the integral is finite.\n      apply ContinuousOn.hasFiniteIntegral\n      <;> simp_all [h₁, h₂]\n      <;>\n      (try norm_num) <;>\n      (try simp_all [Measure.finite]) <;>\n      (try norm_num [volume_Ioc]) <;>\n      (try linarith)\n    -- Use the fact that the interval (0,1] has finite volume to conclude the proof\n    exact h₃\n  exact this.hasFiniteIntegral",
