      "\n  have h₁ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₅ r) (Ioc 0 1) := Φ₅_contDiffOn.continuousOn\n    have h₃ : ∃ (g : ℝ → ℝ), ContinuousOn g (Ioc 0 1) ∧ 0 ≤ g ∧ (∀ x ∈ Ioc 0 1, |(Φ₅ r) x| ≤ g x) := by\n      refine' ⟨fun x => max (0 : ℝ) (|(Φ₅ r) x|), _, _, _⟩\n      · -- Prove continuity of g\n        apply ContinuousOn.max\n        · exact continuousOn_const\n        · exact ContinuousOn.abs (h₂)\n      · -- Prove 0 ≤ g\n        intro x\n        exact le_max_left _ _\n      · -- Prove |(Φ₅ r) x| ≤ g x for x ∈ Ioc 0 1\n        intro x hx\n        have h₄ : 0 ≤ max (0 : ℝ) (|(Φ₅ r) x|) := by positivity\n        have h₅ : |(Φ₅ r) x| ≤ max (0 : ℝ) (|(Φ₅ r) x|) := by\n          apply le_max_right\n        exact h₅\n    -- Use the dominated convergence theorem to conclude the proof\n    obtain ⟨g, hg_cont, hg_nonneg, hg_bound⟩ := h₃\n    have h₄ : HasFiniteIntegral g (volume.restrict (Ioc 0 1)) := by\n      have h₅ : ContinuousOn g (Ioc 0 1) := hg_cont\n      have h₆ : ∃ (C : ℝ), ∀ x ∈ Ioc 0 1, g x ≤ C := by\n        -- Use the fact that g is continuous on a compact set to find an upper bound\n        have h₇ : IsCompact (Icc 0 1) := isCompact_Icc\n        have h₈ : ContinuousOn g (Ioc 0 1) := hg_cont\n        have h₉ : BddAbove (g '' (Ioc 0 1 : Set ℝ)) := by\n          apply ContinuousOn.bddAbove_of_isCompact\n          <;> simp_all [Ioc_subset_Icc_self]\n          <;>\n          (try\n            norm_num) <;>\n          (try\n            linarith)\n        obtain ⟨C, hC⟩ := h₉\n        refine' ⟨C, _⟩\n        intro x hx\n        have h₁₀ : g x ≤ C := by\n          have h₁₁ : g x ∈ g '' (Ioc 0 1 : Set ℝ) := by\n            exact ⟨x, hx, rfl⟩\n          exact hC h₁₁\n        exact h₁₀\n      obtain ⟨C, hC⟩ := h₆\n      have h₇ : HasFiniteIntegral (fun x : ℝ => C) (volume.restrict (Ioc 0 1)) := by\n        -- The constant function C has finite integral on (0, 1]\n        have h₈ : HasFiniteIntegral (fun x : ℝ => C) (volume.restrict (Ioc 0 1)) := by\n          convert hasFiniteIntegral_const.mono (volume.restrict_mono (by\n            simp [Ioc_subset_Icc_self]\n            <;>\n            norm_num\n            <;>\n            linarith)) using 1 <;>\n            simp [volume_Ioc]\n          <;>\n          norm_num\n          <;>\n          linarith\n        exact h₈\n      -- Use the fact that g is bounded above by C to conclude the proof\n      have h₈ : HasFiniteIntegral g (volume.restrict (Ioc 0 1)) := by\n        have h₉ : ∀ x ∈ (Ioc 0 1 : Set ℝ), g x ≤ C := by\n          intro x hx\n          exact hC x hx\n        have h₁₀ : HasFiniteIntegral g (volume.restrict (Ioc 0 1)) := by\n          apply HasFiniteIntegral.of_nonneg_of_le hg_nonneg (fun x hx => h₉ x hx) h₇\n          <;> simp_all [volume.restrict_apply]\n          <;>\n          (try\n            norm_num) <;>\n          (try\n            linarith)\n        exact h₁₀\n      exact h₈\n    -- Use the dominated convergence theorem to conclude the proof\n    have h₅ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n      refine' HasFiniteIntegral.of_abs_le (by\n        -- Show that |(Φ₅ r) x| ≤ g x for x ∈ Ioc 0 1\n        filter_upwards [self_mem_ae_restrict (measurableSet_Ioc : MeasurableSet (Ioc 0 1))] with x hx using\n          by\n            have h₆ : x ∈ Ioc 0 1 := hx\n            have h₇ : |(Φ₅ r) x| ≤ g x := hg_bound x h₆\n            linarith [hg_nonneg x]\n      ) h₄\n    exact h₅\n  -- Use the fact that the function has a finite integral to conclude the proof\n  exact h₁.integrableOn",
      "\n  have h₁ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n    -- Use the fact that the function is continuous and the interval is compact to show that it is integrable.\n    have h₂ : ContinuousOn (Φ₅ r) (Icc 0 1) := by\n      -- Prove that Φ₅ r is continuous on [0, 1]\n      have h₃ : ContinuousOn (Φ₅ r) (Icc 0 1) := by\n        -- Use the continuity of the function Φ₅ r\n        apply ContinuousOn.mono (Φ₅_contDiffOn.continuousOn)\n        intro x hx\n        simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢\n        constructor <;> linarith\n      exact h₃\n    -- Use the fact that a continuous function on a compact interval is integrable\n    have h₃ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n      have h₄ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Icc 0 1)) :=\n        ContinuousOn.hasFiniteIntegral h₂ (by norm_num)\n      have h₅ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n        -- Use the fact that the integral over [0, 1] is the same as the integral over (0, 1]\n        have h₆ : volume.restrict (Ioc 0 1) = volume.restrict (Ioc 0 1) := rfl\n        have h₇ : volume.restrict (Icc 0 1) = volume.restrict (Icc 0 1) := rfl\n        -- Use the fact that the function is continuous and the measure of the difference is zero\n        have h₈ : (volume.restrict (Icc 0 1)).restrict (Ioc 0 1) = volume.restrict (Ioc 0 1) := by\n          apply Measure.restrict_eq_restrict\n          <;> simp [Ioc, Icc]\n          <;>\n            (try norm_num) <;>\n            (try linarith) <;>\n            (try\n              {\n                intros\n                <;>\n                  (try norm_num) <;>\n                  (try linarith)\n              })\n          <;>\n            (try\n              {\n                cases' le_total 0 1 with h h <;>\n                  simp_all [Ioc, Icc] <;>\n                  (try norm_num) <;>\n                  (try linarith)\n              })\n        -- Use the fact that the integral over [0, 1] is the same as the integral over (0, 1]\n        have h₉ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n          have h₁₀ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Icc 0 1)) := h₄\n          have h₁₁ : (volume.restrict (Icc 0 1)).restrict (Ioc 0 1) = volume.restrict (Ioc 0 1) := h₈\n          have h₁₂ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) :=\n            h₁₀.mono_set (by\n              intro x hx\n              simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢\n              <;>\n                (try norm_num at hx ⊢) <;>\n                (try linarith)) h₁₁\n          exact h₁₂\n        exact h₉\n      exact h₅\n    exact h₃\n  exact h₁",
