se the fact that the function is continuous and bounded to show that it has a finite integral\n              apply hasFiniteIntegral_of_hasIntegral\n              -- Use the fact that the function is continuous and bounded to show that it has a finite integral\n              have h₁₃ : HasIntegral (fun x : ℝ => (42 / 3 * (r : ℝ) ^ 2 * (1 - x : ℝ) * x * (1 - x : ℝ) * (x : ℝ))) (42 / 3 * (r : ℝ) ^ 2 * (1 / 5 - 1 / 6 + 1 / 30)) (Ioc 0 1) := by\n                -- Use the fact that the function is continuous and bounded to show that it has a finite integral\n                have h₁₄ : HasIntegral (fun x : ℝ => (42 / 3 * (r : ℝ) ^ 2 * (1 - x : ℝ) * x * (1 - x : ℝ) * (x : ℝ))) (42 / 3 * (r : ℝ) ^ 2 * (1 / 5 - 1 / 6 + 1 / 30)) (Ioc 0 1) := by\n                  -- Use the fact that the function is continuous and bounded to show that it has a finite integral\n                  have h₁₅ : HasIntegral (fun x : ℝ => (42 / 3 * (r : ℝ) ^ 2 * (1 - x : ℝ) * x * (1 - x : ℝ) * (x : ℝ))) (42 / 3 * (r : ℝ) ^ 2 * (1 / 5 - 1 / 6 + 1 / 30)) (Ioc 0 1) := by\n                    -- Compute the integral of the polynomial\n                    have h₁₆ : (42 / 3 * (r : ℝ) ^ 2 : ℝ) ≥ 0 := by positivity\n                    -- Use the fact that the integral of a polynomial",
      "\n  have h₁ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₅ r) (Ioc 0 1) := Φ₅_contDiffOn.continuousOn\n    have h₃ : IsCompact (Ioc 0 1).closure := isCompact_Icc\n    have h₄ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by\n      apply HasFiniteIntegral.of_isCompact_of_continuousOn_of_isCompact\n      <;> (try norm_num)\n      <;> (try exact Ioc_subset_Icc_self)\n      <;> (try exact h₂)\n      <;> (try exact isCompact_Icc)\n      <;> (try exact Icc_subset_Icc_left (by norm_num))\n      <;> (try exact isCompact_Icc)\n    exact h₄\n  simpa using h₁",
