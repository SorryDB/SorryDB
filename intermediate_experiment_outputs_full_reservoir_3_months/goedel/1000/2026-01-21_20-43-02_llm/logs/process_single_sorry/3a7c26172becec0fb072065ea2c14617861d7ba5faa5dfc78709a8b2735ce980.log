lemma foo_of_forall_inessential (h : ∀ x, G.inessential x) :
    ∃ M, G.IsMatching M ∧ ∀ H : Graph α β, H.IsCompOf G → ∃! x, x ∈ V(H) ∧ x ∉ V(G, M) := by
  -- We can take M to be the empty matching since G is inessential.
  refine ⟨∅, _, _⟩
  · -- Prove that the empty set is a matching.
    exact ⟨by simp, by simp⟩
  · -- For each component H of G, we need to find a unique vertex x in H not in V(G, ∅).
    intro H hH
    have h₁ : V(H) = ∅ := by
      have h₂ : H.IsCompOf G := hH
      have h₃ : V(H) ⊆ V(G) := h₂.subset
      have h₄ : V(G) = ∅ := by
        by_contra h₅
        -- If V(G) is not empty, then there exists a vertex x in V(G).
        -- But G is inessential, so x ∉ V(G, M) for some maximal matching M.
        -- However, since M is maximal, V(G, M) = V(G) (because all vertices are matched), leading to a contradiction.
        obtain ⟨x, hx⟩ := Set.nonempty_iff_ne_empty.mpr h₅
        have h₆ : G.inessential x := h x
        obtain ⟨M, hM, hM'⟩ := h₆
        have h₇ : x ∈ V(G) := hx
        have h₈ : x ∉ V(G, M) := hM'
        have h₉ : G.IsMaxMatching M := hM
        have h₁₀ : V(G) ⊆ V(G, M) := by
          intro v hv
          have h₁₁ := h₉.subset(v)
          simp_all [V]
          <;> aesop
        have h₁₁ : x ∈ V(G, M) := h₁₀ h₇
        contradiction
      have h₅ : V(H) = ∅ := by
        rw [h₃]
        rw [h₄]
        <;> simp
      exact h₅
    -- Since V(H) is empty, the unique vertex x satisfying x ∈ V(H) is trivially unique.
    aesop
