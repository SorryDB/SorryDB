theorem locally_left_limit
    (hX : Locally (fun X ↦ ∀ ω, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l)) 𝓕 X P) :
    ∀ᵐ ω ∂P, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l) := by
  have hL := hX.tendsto_top
  filter_upwards [hL] with ω hω
  intro x
  refine (hω x).imp fun l hlt _ ↦ ?_ |>.imp (by simp) fun hlt l hlt' ↦ ⟨l, hlt'⟩
  <;> simp_all [hω]
  <;> aesop
```
