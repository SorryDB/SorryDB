def noHo (σ : List (Call n)) : Prop :=
  ∀ i : Fin σ.length,
      ¬ (after (σ.take (i - 1))) σ[i].1 σ[i].2
    ∧ ¬ (after (σ.take (i - 1))) σ[i].2 σ[i].1

