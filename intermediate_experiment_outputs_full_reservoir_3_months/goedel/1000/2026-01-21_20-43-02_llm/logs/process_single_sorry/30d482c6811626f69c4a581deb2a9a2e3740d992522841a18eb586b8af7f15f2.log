lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  have h₁ : 2 * n - 2 - (v S k : ℕ) ≤ S.length := by
    -- Use the fact that each call increases the number of calls by 1 and the properties of noHo to bound the length.
    have h₂ : ∀ (T : List (Call n)), (2 * n - 2 : ℕ) - (v T k : ℕ) ≤ T.length := by
      intro T
      have h₃ : (2 * n - 2 : ℕ) - (v T k : ℕ) ≤ T.length := by
        have h₄ : (v T k : ℕ) ≤ (v T k : ℕ) := le_refl _
        -- Use the fact that each call increases the number of calls by 1 and the properties of noHo to bound the length.
        have h₅ : (2 * n - 2 : ℕ) - (v T k : ℕ) ≤ T.length := by
          have h₆ : (2 * n - 2 : ℕ) ≤ (v T k : ℕ) + T.length := by
            -- Use the fact that each call increases the number of calls by 1 and the properties of noHo to bound the length.
            have h₇ : ∀ (T : List (Call n)), (2 * n - 2 : ℕ) ≤ (v T k : ℕ) + T.length := by
              intro T
              induction T using List.induction with
              | nil =>
                -- Base case: when T is empty, 2 * n - 2 ≤ 0 + 0
                cases n with
                | zero =>
                  simp_all [v, List.indexes]
                  <;> simp_all [List.countP]
                  <;> linarith
                | succ n =>
                  cases n with
                  | zero =>
                    simp_all [v, List.indexes]
                    <;> simp_all [List.countP]
                    <;> linarith
                  | succ n =>
                    simp_all [v, List.indexes]
                    <;> simp_all [List.countP]
                    <;> linarith
              | cons t L ih =>
                -- Inductive step: assume the statement holds for L, prove for t::L
                simp_all [v, List.countP, List.cons, Fin.ext_iff]
                <;>
                (try omega) <;>
                (try
                  {
                    cases n <;>
                    simp_all [v, List.countP, List.cons, Fin.ext_iff]
                    <;>
                    (try omega) <;>
                    (try
                      {
                        aesop
                      })
                  })
                <;>
                (try
                  {
                    ring_nf at *
                    omega
                  })
                <;>
                (try
                  {
                    simp_all [v, List.countP, List.cons, Fin.ext_iff]
                    <;>
                    omega
                  })
            exact h₇ T
          omega
        exact h₅
      exact h₃
    exact h₂ S
  -- Combine the inequalities to get the final result.
  have h₂ : (2 * n - 2 : ℕ) - (v S k : ℕ) ≤ S.length := by
    simpa using h₁
  have h₃ : 2 * n - 2 - v S k ≤ S.length := by
    simpa [Nat.sub_eq_zero_iff_le] using h₂
  exact h₃
