   simp_all [Fin.ext_iff]\n      <;> norm_num\n      <;> aesop\n    }) (by {\n      have h₂₅₁ : x ⟨1, by decide⟩ + y {⟨1, by decide⟩} ∈ C := by simp_all [Fin.ext_iff]\n      simp_all [Fin.ext_iff]\n      <;> norm_num\n      <;> aesop\n    })\n    simp_all [Fin.ext_iff]\n    <;> norm_num at *\n    <;> aesop\n  }) <;>\n  (try {\n    have h₂₅ := hC.smul_mem (1/2 : ℝ) (by {\n      have h₂₅₁ : x ⟨0, by decide⟩ + y {⟨0, by decide⟩} ∈ C := by simp_all [Fin.ext_iff]\n      simp_all [Fin.ext_iff]\n      <;> norm_num\n      <;> aesop\n    }) (by {\n      have h₂₅₁ : x ⟨2, by decide⟩ + y {⟨2, by decide⟩} ∈ C := by simp_all [Fin.ext_iff]\n      simp_all [Fin.ext_iff]\n      <;> norm_num\n      <;> aesop\n    })\n    simp_all [Fin.ext_iff]\n    <;> norm_num at *\n    <;> aesop\n  }) <;>\n  (try {\n    have h₂₅ := hC.smul_mem (1/2 : ℝ) (by {\n      have h₂₅₁ : x ⟨0, by decide⟩ + y {⟨0, by decide⟩} ∈ C := by simp_all [Fin.ext_iff]\n      simp_all [Fin.ext_iff]\n      <;> norm_num",
