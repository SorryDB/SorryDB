lemma IsBernoulliOn.iIndepFun_mem (hX : IsBernoulliOn X u p P) :
    iIndepFun (fun i ω ↦ i ∈ X ω) P := by
  have h₁ : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
    have h₂ : HasLaw (fun ω => (fun i => i ∈ X ω)) (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) P := by
      -- The law of the random variable (fun i => i ∈ X ω) is the product of Bernoulli measures on u
      simpa [hX] using hX.map fun ω => (fun i => i ∈ X ω)
    -- The product of Bernoulli measures on u is independent for each i ∈ ι
    have h₃ : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
      simpa [h₂] using h₂.iIndepFun
    exact h₃
  exact h₁
