```lean
theorem iIndepFun_mem (hX : IsBernoulliOn X u p P) : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
  have h₁ : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
    have hY : HasLaw X (infinitePi fun i => toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) P := by
