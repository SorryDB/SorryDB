variable (X u p P) in
lemma IsBernoulliOn.iIndepFun_mem (hX : IsBernoulliOn X u p P) :
    iIndepFun (fun i ω ↦ i ∈ X ω) P := by
  have h₁ : HasLaw (fun ω ↦ (fun i ↦ i ∈ X ω)) (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) P := by
    have h₂ : HasLaw X Ber(u, p) P := hX
    have h₃ : HasLaw (fun ω ↦ (fun i ↦ i ∈ X ω)) (Ber(u, p).pushforward (fun s : Set ι ↦ (fun i ↦ i ∈ s))) P := by
      apply MeasurableEquiv.hasLaw_of_pullback h₂
      exact MeasurableEquiv.setOf.symm
    have h₄ : Ber(u, p).pushforward (fun s : Set ι ↦ (fun i ↦ i ∈ s)) = (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) := by
      rw [bernoulliOn_eq_map]
      <;> simp [SetOf]
      <;> congr <;> funext <;> ext <;> simp
    rw [h₄] at h₃
    exact h₃
  have h₂ : iIndepFun (fun i ω ↦ i ∈ X ω) P := by
    exact h₁.iIndepFun
  exact h₂
