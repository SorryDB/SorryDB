theorem length_lt_length_init {a : Type}
 (sl : SymList a) (h : sl ≠ nil)
 : sl.lengthSL > sl.initSL.lengthSL := by
 have ⟨xs, ys, h₁⟩ := sl
 cases xs with
 | nil =>
   cases ys with
   | nil =>
     contradiction
   | cons b bs =>
     simp_all [SymList.nil, SymList.lengthSL, SymList.initSL, splitInTwoSL]
     <;>
     (try omega) <;>
     (try decide) <;>
     (try simp_all [List.length_cons, List.length_nil, Nat.succ_pos]) <;>
     (try omega)
 | cons b bs =>
   cases ys with
   | nil =>
