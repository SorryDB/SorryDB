theorem hasAtLeastTwoElements {S : Set ℕ} (h : Set.Infinite S) : ∃ (x : ℕ), ∃ (y : ℕ), x ∈ S ∧ y ∈ S ∧ x ≠ y := by
  have h₁ : ∃ (x : ℕ), x ∈ S := by
    by_contra h₁
    push_neg at h₁
    have h₂ : S = ∅ := by
      apply Set.eq_empty_of_forall_not_mem
      intro x hx
      have h₃ : x ∉ S := h₁ x
      exact h₃ hx
    rw [h₂] at h
    exact Set.not_infinite.mpr (Set.finite_empty) h
  obtain ⟨x, hx⟩ := h₁
  have h₂ : ∃ (y : ℕ), y ∈ S ∧ y ≠ x := by
    by_contra h₂
    push_neg at h₂
    have h₃ : S ⊆ {x} := by
      intro y hy
      by_cases hyx : y = x
      · simp_all
      · have h₄ : y ≠ x := hyx
        have h₅ : y ∈ S := hy
        have h₆ : ¬(y ∈ S ∧ y ≠ x) := by simpa [h₄] using h₂ y
