theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  have h₁ : ∀ (x : α), F.homF (X := ()) (Y := ()) x = F.homF (X := ()) (Y := ()) x := by
    intro x
    rfl
  -- Define the group homomorphism f using the map on morphisms of F
  have h₂ : ∃ f : α →* β, ∀ (x : α), F.homF (X := ()) (Y := ()) x = f x := by
    -- Use the fact that F is a functor between monoid categories to extract the group homomorphism
    refine' ⟨{ toFun := fun x => F.homF (X := ()) (Y := ()) x, map_one' := _, map_mul' := _ }, _⟩
    · -- Prove that F maps the identity element to the identity element
      have h₃ := F.map_id ()
      simp [MonoidHom.id_apply] at h₃ ⊢
      <;> simp_all [F.map_id]
      <;> try simp_all
      <;> aesop
    · -- Prove that F preserves multiplication
      intro a b
      have h₄ := F.map_comp (arbitrary := MonoidHom.mul (a := a) (b := b)) (arbitrary' := MonoidHom.id)
      simp [MonoidHom.id_apply, MonoidHom.mul_apply] at h₄ ⊢
      <;> simp_all [F.map_comp]
      <;> try simp_all
      <;> aesop
    · -- Prove that the homomorphism f matches the action of F on morphisms
      intro x
      rfl
  exact h₂
