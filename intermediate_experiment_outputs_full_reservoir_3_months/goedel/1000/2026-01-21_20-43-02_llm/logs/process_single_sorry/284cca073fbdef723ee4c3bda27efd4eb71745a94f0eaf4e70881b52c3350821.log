        (try simp_all [F.one_mul, F.mul_one]) <;>
        (try simp_all [F.mul_assoc]) <;>
        (try simp_all [F.one_mul, F.mul_one, F.mul_assoc]) <;>
        (try simp_all [F.one_mul, F.mul_one, F.mul_assoc])
    }
  intro x
  rfl
