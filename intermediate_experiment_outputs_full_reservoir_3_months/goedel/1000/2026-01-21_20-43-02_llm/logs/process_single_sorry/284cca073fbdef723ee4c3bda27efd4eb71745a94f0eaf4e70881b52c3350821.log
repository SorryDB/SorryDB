theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  use { toFun := fun x => F.homF (X := ()) (Y := ()) x,
        map_mul' := by
          intro x y
          have h := F.map_comp (x : Hom () ()) (y : Hom () ()) 
          -- Simplify the composition of homomorphisms in the monoid
          simp [MonoidHom.map_mul] at h ⊢
          <;>
          simp_all [MonoidHom.map_mul, Hom.ext_iff]
          <;>
          try { aesop }
          <;>
          try { simp_all [MonoidHom.map_mul, Hom.ext_iff] }
          <;>
          try { aesop }
          <;>
          try { simp_all [MonoidHom.map_mul, Hom.ext_iff] }
          <;>
          try { aesop }
        }
  intro x
  rfl
