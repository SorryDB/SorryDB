theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  let f : α → β := fun x => F.homF (X := ()) (Y := ()) x
  refine' ⟨{ toFun := f, map_one' := _, map_mul' := _ }, _⟩
  · -- Prove that f(1) = 1
    have h₁ : F.homF (X := ()) (Y := ()) (1 : α) = (1 : β) := by
      have h₂ : (F.homF (X := ()) (Y := ()) : (Unit →* Unit) → (α → β)) (Monoid.one : (Unit →* Unit)) = (1 : β) := by
        simp [Monoid.one, F.map_id]
        <;>
        aesop
      simpa [Monoid.one] using h₂
    simpa using h₁
  · -- Prove that f(xy) = f(x)f(y)
    intro x y
    have h₁ : F.homF (X := ()) (Y := ()) (x * y : α) = (f x * f y : β) := by
      have h₂ : (F.homF (X := ()) (Y := ()) : (Unit →* Unit) → (α → β)) (Monoid.mul (x : α) (y : α)) = (F.homF (X := ()) (Y := ()) (x : α) * F.homF (X := ()) (Y := ()) (y : α) : β) := by
        have h₃ : F.homF (X := ()) (Y := ()) (Monoid.mul (x : α) (y : α)) = F.homF (X := ()) (Y := ()) (x : α) * F.homF (X := ()) (Y := ()) (y : α) := by
          have h₄ := congr_arg (F.homF (X := ()) (Y := ())) (show (Monoid.mul (x : α) (y : α)) = (x : α) ≫ (y : α) by
            simp [Monoid.instMulOneClass]
            <;>
            rfl
