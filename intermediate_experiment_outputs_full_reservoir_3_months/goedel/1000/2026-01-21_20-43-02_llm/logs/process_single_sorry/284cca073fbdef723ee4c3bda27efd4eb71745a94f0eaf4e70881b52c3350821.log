          <;>
          aesop
        simpa [Monoid.mul] using h₃
      simpa [Monoid.mul] using h₂
    simpa [f] using h₁
  · -- Prove that F.homF (X := ()) (Y := ()) x = f x
    intro x
    simp [f]
