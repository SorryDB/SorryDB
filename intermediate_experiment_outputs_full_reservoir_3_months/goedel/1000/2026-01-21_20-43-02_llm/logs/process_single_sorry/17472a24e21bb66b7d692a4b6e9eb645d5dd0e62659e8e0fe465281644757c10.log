```lean
theorem le_induction {P : Nat → Prop} {m}
    (h0 : P m) (h1 : ∀ n, m ≤ n → P n → P (n + 1)) :
    ∀ n, m ≤ n → P n := by
  have h_main : ∀ n, m ≤ n → P n := by
    intro n hn
    have h₂ : ∀ k : ℕ, P (m + k) := by
      intro k
      induction k with
      | zero => simpa using h0
      | succ k ih =>
        have h₃ : m + k + 1 = m + k + 1 := rfl
        have h₄ : m ≤ m + k := by
          omega
        have h₅ : P (m + k) := ih
        have h₆ : P (m + k + 1) := h1 (m + k) (by omega) h₅
        simpa [add_assoc] using h₆
    have h₃ : ∃ k : ℕ, n = m + k := by
      use n - m
      have h₄ : m ≤ n := hn
      have h₅ : n - m + m = n := by
        have h₆ : m ≤ n := hn
        omega
      omega
    rcases h₃ with ⟨k, rfl⟩
    exact h₂ k
  exact h_main
```
