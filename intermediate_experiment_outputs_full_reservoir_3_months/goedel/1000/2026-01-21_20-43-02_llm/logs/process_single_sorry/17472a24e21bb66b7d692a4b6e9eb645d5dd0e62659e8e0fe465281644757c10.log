    intro h
    have h₁ : a + b * n + d = 41 := by
      -- Add 37 to both sides of the equation to isolate a + b * n + d
      have h₂ : a + b * n + d - 37 + 37 = 4 + 37 := by
        rw [h]
      -- Simplify the equation to find a + b * n + d = 41
      ring_nf at h₂ ⊢
      <;> linarith
    exact h₁
  
  have h_backward : a + b * n + d = 41 → a + b * n + d - 37 = 4 := by
    intro h
    have h₁ : a + b * n + d - 37 = 4 := by
      -- Subtract 37 from both sides of the equation to get a + b * n + d - 37 = 4
      have h₂ : a + b * n + d - 37 = 4 := by
        linarith
      exact h₂
    exact h₁
  
  constructor
  · -- Prove the forward direction: if a + b * n + d - 37 = 4, then a + b * n + d = 41
    intro h
    exact h_forward h
  · -- Prove the backward direction: if a + b * n + d = 41, then a + b * n + d - 37 = 4
    intro h
    exact h_backward h
