    [Algebra R S] [Group G] [MulSemiringAction G S] [IsGaloisGroup G R S] :
    Rep ℤ G :=
  letI : MulDistribMulAction G Sˣ := Units.instMulDistribMulAction_right G S
  Rep.ofMulDistribMulAction G Sˣ

