theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  classical
  obtain ⟨g, hg⟩ := he
  have h : IsIso f := ⟨g, hg, by
    have h₁ :Mono f := hm
    have h₂ : g ≫ f = id X := by
      calc
        g ≫ f = g ≫ f := rfl
        _ = id X := by
          -- Use the fact that f is a split epimorphism to find a right inverse g
          -- such that f * g = id(Y). However, we need to prove g * f = id(X).
          -- Since f is a monomorphism, we can use the fact that f * g * f = f * id(Y) = f
          -- to deduce that g * f = id(X).
          have h₃ := Category.ext_iff.mpr (fun z => by
            have h₄ : f ≫ g ≫ f = f ≫ (id Y) := by
              calc
                f ≫ g ≫ f = f ≫ g ≫ f := rfl
                _ = f ≫ (id Y) := by
                  have h₅ : g ≫ f = id Y := by simpa [id_comp] using hg
                  simp [h₅, comp_id]
            have h₆ : (f ≫ g ≫ f : Hom Y Y) = (f ≫ (id Y) : Hom Y Y) := by simpa using h₄
            have h₇ := congr_arg (fun x => x z) h₆
            simp [Function.comp_apply] at h₇ ⊢
            <;> aesop)
          have h₈ := h₃
          simp [Function.comp_apply, id] at h₈ ⊢
          <;>
          (try aesop) <;>
          (try simp_all [Mono, Function.Injective]) <;>
          (try aesop)
          <;>
          (try simp_all [Epi, Function.Surjective]) <;>
          (try aesop)
          <;>
          (try
            {
              have h₉ := hm
              have h₁₀ := h₉
              simp_all [Mono, Function.Injective]
              <;>
              aesop
            })
          <;>
          (try
            {
              have h₉ := he
              obtain ⟨g₁, h₁₀⟩ := h₉
              simp_all [Function.Surjective]
              <;>
              aesop
            })
          <;>
          (try
            {
              simp_all [Function.Surjective]
              <;>
              aesop
            })
          <;>
          (try
            {
              simp_all [Mono, Function.Injective]
              <;>
              aesop
            })
      
          <;>
          aesop
      )
    simp [h₂, id_comp]
    ⟩
  exact h
