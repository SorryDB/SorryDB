theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  refine' ⟨⟨f, g, _, _⟩, rfl⟩
  · -- Prove that f ≫ g = id X
    exact hg
  · -- Prove that g ≫ f = id Y
    have h₁ : g ≫ f = id Y := by
      apply hm
      calc
        g ≫ f ≫ f = g ≫ f ≫ f := by rfl
        _ = g ≫ (f ≫ f) := by rw [assoc]
        _ = g ≫ (id Y ≫ f) := by rw [hg]
        _ = (g ≫ id Y) ≫ f := by rw [assoc]
        _ = g ≫ f := by simp [id_comp]
        _ = g ≫ f := by rfl
    exact h₁
