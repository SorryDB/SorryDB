theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  rcases he with ⟨g, hfg⟩
  have h1 : g ≫ f = id X := by
    have h2 : f ≫ g = id X := hfg
    have h3 : f ≫ g = id X := h2
    apply Eq.symm
    apply Eq.symm
    <;> simp_all [id_comp]
  -- Use the fact that g ≫ f = id X to show that g is a left inverse for f, hence f is iso
  have h2 : IsIso f := by
    apply isIso_iff_has_left_inverse.mpr
    refine' ⟨g, _⟩
    simp_all [id_comp]
  exact h2
