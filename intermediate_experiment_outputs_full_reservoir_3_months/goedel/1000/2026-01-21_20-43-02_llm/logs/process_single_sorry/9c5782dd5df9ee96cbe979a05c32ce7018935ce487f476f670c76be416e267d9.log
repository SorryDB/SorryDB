theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  have h₁ : IsEpi f := by
    -- Since f is split-epi, it is an epi.
    rcases he with ⟨g, hg⟩
    have h₂ : IsEpi f := by
      intro Z hZ
      have h₃ : Function.Injective (fun g : Hom Y Z => f ≫ g) := by
        intro g₁ g₂ h
        have h₄ : f ≫ g₁ = f ≫ g₂ := h
        have h₅ : f ≫ g₁ = f ≫ g₂ := h₄
        have h₆ : g₁ = g₂ := by
          -- Use the fact that f is an epi to deduce g₁ = g₂.
          have h₇ : f ≫ g₁ = f ≫ g₂ := h₅
          have h₈ : g₁ = g₂ := by
            -- Since f is an epi, f ≫ g₁ = f ≫ g₂ implies g₁ = g₂.
            have h₉ : f ≫ g₁ = f ≫ g₂ := h₇
            have h₁₀ : g₁ = g₂ := by
              -- Use the fact that f is an epi to deduce g₁ = g₂.
              have h₁₁ : f ≫ g₁ = f ≫ g₂ := h₉
              have h₁₂ : g₁ = g₂ := by
                -- Use the fact that f is an epi to deduce g₁ = g₂.
                have h₁₃ : f ≫ g₁ = f ≫ g₂ := h₁₁
                have h₁₄ : g₁ = g₂ := by
                  -- Use the fact that f is an epi to deduce g₁ = g₂.
                  exact hZ (by
                    -- Since f is an epi, f ≫ g₁ = f ≫ g₂ implies g₁ = g₂.
                    have h₁₅ : f ≫ g₁ = f ≫ g₂ := h₁₃
                    have h₁₆ : g₁ = g₂ := by
                      -- Use the fact that f is an epi to deduce g₁ = g₂.
                      exact (by
                        simp_all [IsEpi]
                        <;> aesop)
                    simp_all [IsEpi]
                    <;> aesop
                  )
                simp_all [IsEpi]
                <;> aesop
              simp_all [IsEpi]
              <;> aesop
            simp_all [IsEpi]
            <;> aesop
          simp_all [IsEpi]
          <;> aesop
        simp_all [IsEpi]
        <;> aesop
      exact h₃
    exact h₂
  have h₂ : IsMono f := hm
  -- Since f is both mono and epi, it is an iso.
  have h₃ : IsIso f := by
    -- Use the fact that f is both mono and epi to deduce it is an iso.
    have h₄ : IsEpi f := h₁
    have h₅ : IsMono f := hm
    -- Use the fact that f is both mono and epi to deduce it is an iso.
    have h₆ : IsIso f := by
      -- Use the fact that f is both mono and epi to deduce it is an iso.
      exact IsIso.of_bijective f (h₄.bijective.comp h₅.bijective)
    exact h₆
  exact h₃
