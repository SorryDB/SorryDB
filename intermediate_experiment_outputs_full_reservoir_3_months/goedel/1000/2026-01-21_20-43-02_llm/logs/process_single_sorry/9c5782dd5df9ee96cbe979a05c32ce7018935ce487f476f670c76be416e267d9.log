```lean
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  have h₁ : IsIso f := by
    refine' ⟨g, _, _, _⟩
    · -- f ∘ g = id
      simpa [hg] using hg
    · -- g ∘ f = g ∘ f
      rfl
    · -- g ∘ f = g ∘ f
      -- We need to show that g ∘ f is idempotent, which follows from hm and hg
      have h₂ : g ≫ f = g ≫ f := rfl
      have h₃ : g ≫ f = g ≫ f := rfl
      -- Use the injectivity of f to show that g ∘ f is idempotent
      have h₄ : g ≫ f ≫ g ≫ f = g ≫ f := by
        calc
          g ≫ f ≫ g ≫ f = g ≫ (f ≫ g) ≫ f := by
            simp [comp_assoc]
          _ = g ≫ (id X) ≫ f := by rw [hg]
          _ = g ≫ f := by simp [comp_id]
      -- Use the injectivity of f to conclude that g ∘ f is idempotent
      have h₅ : g ≫ f ≫ g ≫ f = g ≫ f := h₄
      have h₆ : g ≫ f = id X := by
        apply hm
        -- Show that g ≫ f is the identity
        simp_all [comp_assoc]
        <;> aesop
      simp_all [comp_assoc]
      <;> aesop
  exact h₁
