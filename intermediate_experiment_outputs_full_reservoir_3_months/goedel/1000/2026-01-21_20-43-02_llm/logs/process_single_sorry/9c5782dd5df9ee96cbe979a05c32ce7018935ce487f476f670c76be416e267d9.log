theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g', hg'⟩ := he
  have h₁ : f ≫ g' = id X := hg'
  have h₂ : g' ≫ f = id Y := by
    have h₃ : f ≫ (g' ≫ f) = f := by
      calc
        f ≫ (g' ≫ f) = (f ≫ g') ≫ f := by rw [assoc]
        _ = id X ≫ f := by rw [h₁]
        _ = f := by simp [id_comp]
        _ = f := by rfl
    have h₄ : f ≫ (id Y : Hom Y Y) = f := by simp [comp_id]
    have h₅ : g' ≫ f = id Y := by
      apply hm
      calc
        f ≫ (g' ≫ f) = f := h₃
        _ = f ≫ (id Y : Hom Y Y) := by rw [h₄]
    exact h₅
  exact ⟨g', h₂, h₁⟩
```

