theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  have h₂ : f ≪ g ≈ 1 := hg
  have h₃ : g ≪ f ≈ 1 := by
    have h₄ : @Mono α C Y X g := by
      -- Show that g is monic using the fact that f is monic and the composition is invertible.
      intro Z h₅ h₆ h₇
      have h₈ : h₅ ≪ f ≈ h₆ ≪ f := by
        calc
          h₅ ≪ f ≈ h₅ ≪ f ≪ (g ≪ f) := by
            simp [h₇]
          _ ≈ (h₅ ≪ f) ≪ g ≪ f := by
            simp [assoc]
          _ ≈ (h₆ ≪ f) ≪ g ≪ f := by
            simp [h₇]
          _ ≈ h₆ ≪ f ≪ (g ≪ f) := by simp [assoc]
          _ ≈ h₆ ≪ f := by simp [h₇]
      have h₉ : h₅ ≪ f ≈ h₆ ≪ f := h₈
      have h₁₀ : h₅ ≈ h₆ := hm h₉
      exact h₁₀
    -- Show that g ≪ f ≈ 1 using the fact that g is monic and the composition is invertible.
    have h₅ : (g ≪ f) ≪ g ≈ g := by
      calc
        (g ≪ f) ≪ g ≈ g ≪ (f ≪ g) := by simp [assoc]
        _ ≈ g ≪ 1 := by simp [h₂]
        _ ≈ g := by simp
    have h₆ : g ≪ 1 ≈ g := by simp
    have h₇ : (g ≪ f) ≪ g ≈ g ≪ 1 := by
      calc
        (g ≪ f) ≪ g ≈ g := h₅
        _ ≈ g ≪ 1 := by simp [h₆]
        _ ≈ g ≪ 1 := by simp [h₆]
    have h₈ : g ≪ f ≈ 1 := by
      apply h₄
      simpa [assoc] using h₇
    exact h₈
  -- Prove that f is an isomorphism using the inverses f⁻¹ = g and g⁻¹ = f.
  refine' ⟨g, _, _⟩
  <;> simp_all [Inverse]
  <;>
  (try simp_all [assoc]) <;>
  (try simp_all [h₂, h₃]) <;>
  (try simp_all [hm]) <;>
