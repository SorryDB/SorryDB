  · -- Show f ≫ g = id X
    have h₁ := hg
    exact h₁
  · -- Show g ≫ f = id Y
    have h₂ : Mono f := hm
    have h₃ : g ≫ f = id Y := by
      have h₄ : f ≫ g = id X := hg
      have h₅ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := h₂
      have h₆ : (g ≫ f) ≫ f = (id Y) ≫ f := by
        have h₇ : (g ≫ f) ≫ f = g ≫ (f ≫ f) := by
          simp [comp_assoc]
        have h₈ : (id Y) ≫ f = f := by simp [id_comp]
        have h₉ : g ≫ (f ≫ f) = f := by
          calc
            g ≫ (f ≫ f) = (g ≫ f) ≫ f := by simp [comp_assoc]
            _ = (id Y) ≫ f := by simp [h₄]
            _ = f := by simp [id_comp]
        calc
          (g ≫ f) ≫ f = g ≫ (f ≫ f) := by simp [comp_assoc]
          _ = f := by rw [h₉]
          _ = f := by rfl
          _ = (id Y) ≫ f := by simp [id_comp]
      have h₁₀ : (g ≫ f) ≫ f = (id Y) ≫ f := h₆
      have h₁₁ : g ≫ f = id Y := by
        apply h₂
        simpa [comp_assoc] using h₁₀
      exact h₁₁
    exact h₃
