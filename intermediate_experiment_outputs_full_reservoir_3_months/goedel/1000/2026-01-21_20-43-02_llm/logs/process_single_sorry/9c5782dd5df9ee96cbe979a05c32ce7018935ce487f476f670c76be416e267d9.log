```lean
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  classical
  have h₁ : ∃ (g : Hom Y X), f ≫ g = id X := by
    obtain ⟨g, hg⟩ := he
    exact ⟨g, hg⟩
  obtain ⟨g, hg⟩ := h₁
  have h₂ : IsEquiv f := {
    left_inv := by
      intro x
      have h₃ : g ≫ f = g ≫ f := rfl
      have h₄ : g ≫ f = id X := by
        have h₅ : f ≫ g = id X := hg
        have h₆ : g ≫ f = id X := by
          have h₇ := hm
          have h₈ : g ≫ f = g ≫ f := rfl
          -- Use the fact that `f` is mono and `g ≫ f ≫ g = g` to show `g ≫ f = id X`
          have h₉ : g ≫ f ≫ g = g := by
            calc
              g ≫ f ≫ g = g ≫ (f ≫ g) := by simp [Composition.comp]
              _ = g ≫ id X := by rw [hg]
              _ = g := by simp [Composition.comp]
          have h₁₀ : g ≫ f ≫ g = g := h₉
          have h₁₁ : g ≫ f = id X := by
            have h₁₂ := h₇
            have h₁₃ : (g ≫ f ≫ g) = g := h₉
            have h₁₄ : (g ≫ f) ≫ g = g := by simpa [Composition.comp] using h₁₃
            have h₁₅ : g ≫ f = id X := by
              apply h₇
              simp_all [Composition.comp]
              <;> try simp_all [Composition.comp]
              <;> try simp_all [Composition.comp]
              <;> try simp_all [Composition.comp]
            exact h₁₅
          exact h₁₁
        exact h₆
      simp_all [Composition.comp]
    right_inv := by
      intro y
      have h₃ : f ≫ g = id X := hg
      have h₄ : f ≫ g = id X := by simpa using h₃
      have h₅ : f ≫ g = id X := h₄
      -- Use the fact that `g ≫ f = id X` to show `f ≫ g = id X`
      -- and thus deduce that `f` is a right inverse of `g`
      have h₆ : f ≫ g = id X := h₅
      simp_all [Composition.comp]
      <;> try simp_all [Composition.comp]
      <;> try simp_all [Composition.comp]
      <;> try simp_all [Composition.comp]
  }
  have h₃ : IsIso f := by
    refine' ⟨g, _⟩
    exact h₂
  exact h₃
