```lean
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  have h : IsIso f := by
    -- We need to find an inverse for `f`. We already have `g` such that `f ≫ g = id`.
    -- Since `f` is a monomorphism, we can use this to show that `g ≫ f = id`.
    have h1 : f ≫ g = id := hg
    refine' ⟨g, _, _⟩ <;>
    (try simp_all [h1, id_comp, comp_id]) <;>
    (try {
      have h2 : g ≫ f = id := by
        have h3 : f ≫ g ≫ f = id ≫ f := by rw [h1]
        have h4 : f ≫ g ≫ f = f := by
          simp [h3, id_comp]
        have h5 : mono f := hm
        have h6 : g ≫ f = id := by
          -- Use the fact that `f` is a monomorphism to cancel it out
          have h7 : f ≫ (g ≫ f) = f ≫ (id : Hom Y Y) := by
            calc
              f ≫ (g ≫ f) = (f ≫ g) ≫ f := by rw [← assoc]
              _ = id ≫ f := by rw [h1]
              _ = f := by simp [id_comp]
              _ = f ≫ (id : Hom Y Y) := by simp [comp_id]
          exact hm (by
            -- Use the cancellation property of monomorphisms to deduce `g ≫ f = id`
            have h8 : f ≫ (g ≫ f) = f ≫ (id : Hom Y Y) := h7
            have h9 : f ≫ (g ≫ f) = (f ≫ g) ≫ f := by rw [← assoc]
            have h10 : (f ≫ g) ≫ f = id ≫ f := by rw [h1]
            have h11 : id ≫ f = f := by simp [id_comp]
            simp_all [assoc, h11]
            <;>
            try simp_all [comp_assoc]
          )
          <;>
          try simp_all [comp_assoc]
          <;>
          try simp_all [assoc]
        exact h6
      simp_all [comp_assoc]
    }) <;>
    (try {
      simp_all [comp_assoc]
      <;>
      try simp_all [assoc]
    })
  exact h
