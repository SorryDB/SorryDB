theorem multiple_params_introduce (x y z : ℕ) : x + y + z = x + y + z := by
  have h : x + y + z = x + y + z := by
    rfl
  have h₂ : x + y + z = x + y + z := by
    rfl
  have h₃ : x + y + z = x + y + z := by
    rfl
  exact h₃
``` 

