theorem soundness_of_add {F : Type} [Field F] {Input Output : TypeMap} [ProvableType Input] [ProvableType Output]
    (circuit : ElaboratedCircuit F Input Output) (Assumptions : Input F → Prop)
    (Spec : Input F → Output F → Prop) :
    Soundness F circuit Assumptions Spec := by
  intro i₀ env input_var input h_input h_assumptions h_holds
  have h₁ : ConstraintsHold.Soundness env (ElaboratedCircuit.main input_var i₀).2 := h_holds
  have h₂ : eval env (ElaboratedCircuit.output input_var i₀) = eval env (circuit.getOutput i₀) := by
    have h₃ := congr_arg (fun x => x) (ElaboratedCircuit.circuit_eq_circuit' circuit)
    simp at h₃
    <;> simp_all [ElaboratedCircuit.getOutput]
    <;> aesop
  have h₃ : Spec input (eval env (ElaboratedCircuit.output input_var i₀)) := by
    have h₄ := h_holds
    simp_all [ConstraintsHold.Soundness, Spec]
    <;>
    (try aesop) <;>
    (try {
      exfalso
      simp_all [ConstraintsHold.Soundness]
      <;> aesop
    }) <;>
    (try {
      aesop
    })
  simpa [h₂] using h₃
