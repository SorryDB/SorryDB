      "by\n  apply Set.Subset.antisymm\n  · -- Prove that range (val_image A) ⊆ 𝒫 A\n    rintro S ⟨X, rfl⟩\n    -- For any S in the range of val_image A, there exists X : Set A such that S = val_image A X\n    -- We need to show that S ⊆ A\n    intro y hy\n    -- For any y ∈ S = val_image A X, there exists x : A such that x ∈ X and x.val = y\n    rcases hy with ⟨x, hx, rfl⟩\n    -- Since x : A, x.val ∈ A\n    exact x.prop\n  · -- Prove that 𝒫 A ⊆ range (val_image A)\n    intro B hB\n    -- For any B ⊆ A, we need to find X : Set A such that val_image A X = B\n    -- Define X = {x : A | x.val ∈ B}\n    have h₁ : B ∈ range (val_image A) := by\n      use {x : A | x.val ∈ B}\n      -- Show that val_image A {x : A | x.val ∈ B} = B\n      ext y\n      simp only [val_image, Set.mem_setOf_eq, Set.mem_range]\n      constructor\n      · -- Prove that if y ∈ val_image A {x : A | x.val ∈ B}, then y ∈ B\n        rintro ⟨x, hx, rfl⟩\n        exact hx\n      · -- Prove that if y ∈ B, then y ∈ val_image A {x : A | x.val ∈ B}\n        intro hy\n        -- Since B ⊆ A, y ∈ A\n        have hyA : y ∈ A := hB hy\n        -- Consider x = ⟨y, hyA⟩ : A\n        refine' ⟨⟨y, hyA⟩, _⟩\n        -- Check that ⟨y, hyA⟩ ∈ {x : A | x.val ∈ B} and (⟨y, hyA⟩ : A).val = y\n        simp_all [Subtype.ext_iff]\n        <;> aesop\n    exact h₁",
