lemma range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  have h_subset : range (val_image A) ⊆ 𝒫 A := by
    intro T hT
    obtain ⟨X, rfl⟩ := hT
    intro y hy
    obtain ⟨x, hx, rfl⟩ := hy
    -- Since x : A, we have x.val ∈ A by definition of subtype.
    exact x.prop
  
  have h_superset : 𝒫 A ⊆ range (val_image A) := by
    intro S hS
    -- Define X as {x : A | x.val ∈ S}
    have h₁ : ∃ (X : Set A), val_image A X = S := by
      use {x : A | (x : U) ∈ S}
      apply Set.Subset.antisymm
      · -- Prove val_image A X ⊆ S
        intro y hy
        obtain ⟨x, hx, rfl⟩ := hy
        simpa using hx
      · -- Prove S ⊆ val_image A X
        intro y hy
        have hy' : y ∈ A := hS hy
        -- Since y ∈ A, we can form ⟨y, hy'⟩ : A
        have h₂ : (⟨y, hy'⟩ : A) ∈ {x : A | (x : U) ∈ S} := by
          simpa using hy
        -- Now, y = (⟨y, hy'⟩ : A).val and ⟨y, hy'⟩ ∈ X
        refine' ⟨⟨y, hy'⟩, h₂, _⟩
        <;> simp
    -- Now we have X such that val_image A X = S, so S ∈ range (val_image A)
    obtain ⟨X, hX⟩ := h₁
    refine' ⟨X, _⟩
    simp [hX]
  
  have h_main : range (val_image A) = 𝒫 A := by
    apply Set.Subset.antisymm
    · exact h_subset
    · exact h_superset
  
  exact h_main
