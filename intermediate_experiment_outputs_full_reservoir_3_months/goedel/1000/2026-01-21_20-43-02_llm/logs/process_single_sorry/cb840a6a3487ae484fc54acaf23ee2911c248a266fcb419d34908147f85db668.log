def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  apply Set.ext
  intro S
  simp only [Set.mem_range, Set.mem_setOf_eq, Set.mem_powerset]
  constructor
  · -- Prove the forward direction: if S is in the range of val_image, then S ⊆ A
    rintro ⟨X, rfl⟩
    intro y hy
    simp only [val_image, Set.mem_setOf_eq] at hy
    rcases hy with ⟨⟨x, hx⟩, hX, rfl⟩
    exact hx
  · -- Prove the reverse direction: if S ⊆ A, then S is in the range of val_image
    intro hS
    use {x : A | x.val ∈ S}
    ext y
    simp only [val_image, Set.mem_setOf_eq, Set.mem_setOf_eq]
    constructor
    · -- Prove the forward direction: if y is in val_image {x : A | x.val ∈ S}, then y ∈ S
      rintro ⟨⟨x, hx⟩, hx', rfl⟩
      exact hx'
    · -- Prove the reverse direction: if y ∈ S, then y is in val_image {x : A | x.val ∈ S}
      intro hy
      have h : y ∈ A := hS hy
      refine' ⟨⟨y, h⟩, _⟩
      <;> simp_all
      <;> aesop
