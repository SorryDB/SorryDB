```lean
lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · -- Prove the forward direction: if U ∼ V, then there exist f and g such that f ∘ g = id and g ∘ f = id
    intro h
    have h₁ : U ≃ V := h
    refine' ⟨h₁.toFun, h₁.invFun, _, _⟩
    · -- Prove f ∘ g = id
      ext x
      simp [Equiv.apply_invFun]
    · -- Prove g ∘ f = id
      ext x
      simp [Equiv.invFun_apply]
  · -- Prove the reverse direction: if there exist f and g such that f ∘ g = id and g ∘ f = id, then U ∼ V
    rintro ⟨f, g, h₁, h₂⟩
    have h₃ : U ≃ V := by
      refine' { toFun := f, invFun := g, left_inv := _, right_inv := _ }
      · -- Prove g ∘ f = id
        ext x
        have h₄ := congr_fun h₂ x
        simp at h₄ ⊢
        <;> aesop
      · -- Prove f ∘ g = id
        ext x
        have h₄ := congr_fun h₁ x
        simp at h₄ ⊢
        <;> aesop
    exact h₃
