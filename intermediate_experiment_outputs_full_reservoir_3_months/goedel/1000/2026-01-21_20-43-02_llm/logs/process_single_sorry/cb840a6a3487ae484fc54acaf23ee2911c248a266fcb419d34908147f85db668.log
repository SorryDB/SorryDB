theorem range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  apply Set.Subset.antisymm
  · intro S hS
    rw [Set.mem_range] at hS
    rcases hS with ⟨X, rfl⟩
    have h₁ : val_image A X = (X : Set U) := by
      ext u
      simp [val_image, Set.mem_setOf_eq]
      <;> aesop
    rw [h₁]
    simp [Set.subset_def]
    <;> intro u hu <;> exact ⟨u, hu, rfl⟩
  · intro S hS
    rw [Set.mem_pow_iff] at hS
    have h₁ : S ⊆ A := hS
    have h₂ : ∃ (X : Set (↥A)), (X : Set U) = S := by
      classical
      use ⟨S, h₁⟩
      <;> simp [Set.ext_iff]
      <;> aesop
    rcases h₂ with ⟨X, hX⟩
    have h₃ : (val_image A X : Set U) = S := by
      have h₄ : (val_image A X : Set U) = (X : Set U) := by
        ext u
        simp [val_image, Set.mem_setOf_eq]
        <;> aesop
      rw [h₄]
      <;> simp_all [Set.ext_iff]
      <;> aesop
    have h₄ : val_image A X ∈ range (val_image A) := by
      exact Set.mem_range_self X
    rw [h₃] at h₄
    exact h₄
