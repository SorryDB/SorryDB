```lean
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h₁ : (image g) ∘ (image f) = id := by
    funext s
    have h₂ : (image g) (image f s) = s := by
      have h₃ : ∀ x, x ∈ (image g) (image f s) ↔ x ∈ s := by
        intro x
        simp only [image, Set.mem_setOf_eq, exists_prop]
        constructor
        · -- Prove the forward direction: if x ∈ (image g) (image f s), then x ∈ s
          rintro ⟨y, hy, rfl⟩
          have h₄ : ∃ (a : U), a ∈ s ∧ f a = y := by
            aesop
          rcases h₄ with ⟨a, ha, ha'⟩
          have h₅ : g (f a) = a := by
            have h₆ := congr_fun h a
            simp at h₆ ⊢
            <;> aesop
          have h₆ : g y = a := by
            rw [ha'] at *
            exact h₅
          simp_all
        · -- Prove the reverse direction: if x ∈ s, then x ∈ (image g) (image f s)
          intro hx
          have h₄ : f x ∈ image f s := by
            refine' ⟨x, hx, _⟩
            <;> simp
          have h₅ : g (f x) = x := by
            have h₆ := congr_fun h x
            simp at h₆ ⊢
            <;> aesop
          refine' ⟨f x, h₄, _⟩
          simp [h₅]
      -- Use the established equivalence to show the sets are equal
      ext x
      exact h₃ x
    simp_all
  exact h₁
