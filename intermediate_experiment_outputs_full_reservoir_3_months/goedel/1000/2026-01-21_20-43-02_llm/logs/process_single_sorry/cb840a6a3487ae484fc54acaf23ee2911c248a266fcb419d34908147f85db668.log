theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := 
  by
    classical
    -- Use the fact that there exists a bijection between U and V to construct a bijection between Set U and Set V
    have h1 : Set U ≃ Set V := by
      -- Use the equivalence of types to construct an equivalence of their powersets
      obtain ⟨f, g, h2, h3⟩ := h
      refine' ⟨fun (s : Set U) => Set.image f s, fun (t : Set V) => Set.image g t, _, _⟩
      -- Show that the composition of images is the identity function on Set U
      · intro s
        ext x
        simp [h3]
        <;> aesop
      -- Show that the composition of images is the identity function on Set V
      · intro t
        ext y
        simp [h2]
        <;> aesop
    -- Use the constructed equivalence to prove the statement
    exact h1
