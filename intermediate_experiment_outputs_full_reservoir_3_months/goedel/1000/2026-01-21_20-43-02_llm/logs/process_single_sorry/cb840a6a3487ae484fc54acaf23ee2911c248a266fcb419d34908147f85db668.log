```lean
def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

theorem range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  apply Set.ext
  intro s
  simp only [Set.mem_range, Set.mem_setOf_eq, Set.mem_pow]
  constructor
  · -- Prove that if s is in the range of val_image A, then s is a subset of A
    intro h
    obtain ⟨X, rfl⟩ := h
    intro y hy
    have h₂ : ∃ (x : A), x ∈ X ∧ (x : U) = y := by
      simpa [val_image] using hy
    obtain ⟨⟨x, hx⟩, hX, rfl⟩ := h₂
    exact hx
  · -- Prove that if s is a subset of A, then s is in the range of val_image A
    intro h
    let X : Set A := {⟨x, hx⟩ | x ∈ s}
    have h₂ : ∀ x : U, x ∈ val_image A X ↔ x ∈ s := by
      intro x
      simp only [val_image, Set.mem_setOf_eq]
      constructor
      · -- Forward direction
        intro h₃
        obtain ⟨⟨y, hy⟩, hX, rfl⟩ := h₃
        exact hy
      · -- Backward direction
        intro h₃
        refine' ⟨⟨x, h x⟩, _⟩
        simp_all [Set.mem_setOf_eq]
        <;> aesop
    have h₃ : val_image A X = s := by
      apply Set.ext
      intro x
      rw [h₂ x]
    refine' ⟨X, _⟩
    rw [h₃]
