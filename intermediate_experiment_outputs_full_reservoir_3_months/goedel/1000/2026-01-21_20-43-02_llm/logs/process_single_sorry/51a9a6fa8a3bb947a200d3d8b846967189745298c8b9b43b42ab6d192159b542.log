  have h₁ : @cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x (m • x_1) =
      (RingHom.id ℂ) m • @cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x x_1 := by
    have h₂ : (toLinearFunctional x (m • x_1) : (H →L[ℂ] H) →ₗ[ℂ] ℂ) =
        (RingHom.id ℂ : ℂ →ₗ[ℂ] ℂ) m • (toLinearFunctional x x_1 : (H →L[ℂ] H) →ₗ[ℂ] ℂ) := by
      ext b
