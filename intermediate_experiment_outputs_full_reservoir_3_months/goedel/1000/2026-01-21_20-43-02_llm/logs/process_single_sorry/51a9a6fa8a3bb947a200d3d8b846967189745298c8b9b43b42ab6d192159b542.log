  --(hf_bounded : ∀ x, ‖f x‖ ≤ C) (hf_measurable : @Measurable _ _ (borel (spectrum ℂ a)) _ f)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := sorry
                map_smul' := by
                  intro m x_1
                  have h₁ : ComplexMeasure.integral (@cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x (m • x_1)) f =
                      (RingHom.id ℂ) m • ComplexMeasure.integral (@cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x x_1) f := by
                    -- Extract the definition of `cfc_toComplexMeasure` to simplify.
                    simp [cfc_toComplexMeasure]
                    <;>
                    -- Use the linearity property of the integral to factor out the scalar multiplication.
                    simp_all [ComplexIntegrate.integral_smul]
                  -- The result follows directly from the above equality.
                  exact h₁
              }
