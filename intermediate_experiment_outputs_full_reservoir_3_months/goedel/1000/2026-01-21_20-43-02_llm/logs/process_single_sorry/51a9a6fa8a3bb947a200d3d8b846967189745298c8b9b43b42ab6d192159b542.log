    ∃ (μ : H →L⋆[ℂ] H →L[ℂ] ℂ),
    ∀ (x : H) (y : H) (S : BorelSet (spectrum ℂ a)),
        ‖μ x y‖ ≤ ‖x‖ * ‖y‖ ∧
        (μ x y) (S) = ∫ (z : ↑(spectrum ℂ a)) in S, f z := by
  use fun x y => 0
  intro x y S
  have h₁ : ‖(0 : (H →L⋆[ℂ] H →L[ℂ] ℂ))‖ ≤ ‖x‖ * ‖y‖ := by
