          ComplexRMK.rieszMeasure (compSL _ _ _ _ (toLinearFunctional x (m • x_1)) _) :=
            rfl
      _ = ComplexRMK.rieszMeasure (compSL _ _ _ _ ((RingHom.id ℂ : ℂ →ₗ[ℂ] ℂ) m • (toLinearFunctional x x_1)) _) := by
        congr 1 <;> rw [h₂]
