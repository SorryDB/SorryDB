        rw [ComplexRMK.rieszMeasure_smul]
      _ = (RingHom.id ℂ : ℂ →ₗ[ℂ] ℂ) m • @cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x x_1 := by
        simp [cfc_toComplexMeasure]
  calc
    ComplexMeasure.integral (@cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x (m • x_1)) f =
