theorem statedPreservesLimitsOfSize {α : Type*} [Size α] (f : α → α) :
    ∀ {n : ℕ}, n < Cardinal.ord α →
      ∀ {a : α}, a < Cardinal.ord α →
        f a < Cardinal.ord α → Cardinal.lift (f a) = Cardinal.lift (a) := by
  intro n hn a ha hf
  <;> simp_all [Cardinal.lift_inj]
  <;> try { aesop }
  <;> try { linarith }
  <;> try { omega }
