theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · -- Prove the forward direction: if w ∈ l, then coerceWord w ∈ coerceLang l
    intro h
    -- Use the definition of coerceLang and coerceWord to show the membership
    refine' ⟨w, h, _⟩
    <;> simp [coerceWord]
  · -- Prove the backward direction: if coerceWord w ∈ coerceLang l, then w ∈ l
    intro h
    -- Extract the witness from the hypothesis
    obtain ⟨w', hw', hw''⟩ := h
    -- Since w' is the same as w, we can directly use the membership
    have h₁ : w = w' := by
      -- Prove that w and w' are the same word
      have h₂ : coerceWord w = coerceWord w' := by
        -- Use the given equality coerceWord w = coerceWord w'
        simp_all [coerceWord]
      -- Since the coercion is injective, w = w'
      have h₃ : (w : Word α) = (w' : Word α) := by simpa [coerceWord] using h₂
      -- Convert back to the original type
      exact Word.ext (fun i => by
        have h₄ := congr_arg (fun w => w.get i) h₃
        simp [coerceWord] at h₄ ⊢
        <;> simp_all [Finset.mem_coe]
        <;> aesop)
    -- Substitute w' with w and use the membership of w' in l
    rw [h₁] at hw'
    exact hw'

theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
