        have h₄ := congr_arg (fun w => w.get i) h₃
        simp [coerceWord] at h₄ ⊢
        <;> simp_all [Finset.mem_coe]
        <;> aesop)
    -- Substitute w' with w and use the non-membership of w in l
    rw [h₁] at hw'
    exact h hw'
  · -- Prove the backward direction: if coerceWord w ∉ coerceLang l, then w ∉ l
    intro h
    intro h'
    -- Use the forward direction to derive a contradiction
    have h₁ : coerceWord w ∈ coerceLang l := by
      -- Use the definition of coerceLang and coerceWord to show the membership
      refine' ⟨w, h', _⟩
      <;> simp [coerceWord]
    -- Contradiction arises as coerceWord w ∉ coerceLang l
    exact h h₁

