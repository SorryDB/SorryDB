    simp only [WList.cons_edge, List.isChain_cons_cons]
    obtain ‚ü®hor, -‚ü© := by simpa using h.mem_matching
    obtain ‚ü®‚ü®hef, -‚ü©, -, -‚ü© := by simpa using h.isTrail.edge_nodup
    obtain ‚ü®‚ü®-, hfvwf, -‚ü©, heuv, -, -‚ü© := by simpa using h.toIsPath
    use ‚ü®fun heM hfM ‚Ü¶ ?_, hor.resolve_right‚ü©, by simpa using h.of_cons.mem_matching_iff
    exact hM.disjoint heM hfM hef |>.notMem_of_mem_left heuv.inc_right hfvwf.inc_left

