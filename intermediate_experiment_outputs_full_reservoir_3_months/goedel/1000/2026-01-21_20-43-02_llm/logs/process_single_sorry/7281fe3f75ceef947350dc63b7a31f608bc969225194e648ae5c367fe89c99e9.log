-- Matroid exercise 4 Q2

/-
\subsection{Part (a)}
Show that, if $S \subseteq E(M)$ is a set of size at least $2$ whose two-element subsets are
all series pairs of $M$, then $r_M(E(M) - S) = r(M) - |S| + 1$.

\begin{proof}
  Consider $r_{M^*}(S)$. In $M^*$, $S$ is subset of a parallel class so $r_{M^*}(S) = 1$.
  Simultaneously, $r_{M^*}(S) = r_M(E(M) - S) + |S| - r(M)$.
  By rearranging and substituting, we have $r_M(E(M) - S) = r(M) - |S| + 1$.
\end{proof}-/
lemma _root_.Matroid.eRk_pos_of_mem_nonloop {M : Matroid őĪ} {e : őĪ} (heX : e ‚ąą X)
    (he : M.IsNonloop e) : 0 < M.eRk X := by
  refine Order.one_le_iff_pos.mp ?_
  rw [‚Üź he.eRk_eq]
  apply M.eRk_mono
  simpa

lemma _root_.Matroid.fooA {M : Matroid őĪ} (hS : S ‚äÜ M.E) (hnt : S.Nontrivial)
    (h : ‚ąÄ a ‚ąą S, ‚ąÄ b ‚ąą S, a ‚Č† b ‚Üí M.Series a b) : M.eRk (M.E \ S) + S.encard = M.eRank + 1 := by
  obtain ‚ü®s, hs, t, ht, hne‚ü© := hnt
  have hnls := (h s hs t ht hne).isNonloop_left
  suffices M.dual.eRk S = 1 by
    rw [‚Üź this, add_comm M.eRank, M.eRk_dual_add_eRank S hS]
  refine le_antisymm ?_ (Order.one_le_iff_pos.mpr <| M‚ú∂.eRk_pos_of_mem_nonloop hs hnls)
  rw [‚Üź hnls.eRk_eq, ‚Üź M‚ú∂.eRk_closure_eq {s}]
  apply M‚ú∂.eRk_mono
  intro x hxS
  obtain rfl | hxs := eq_or_ne x s
  ¬∑ exact M‚ú∂.subset_closure _ (by simpa using hnls.mem_ground) (by rfl)
  exact (h x hxS s hs hxs).mem_closure

