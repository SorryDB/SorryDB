namespace MillenniumYangMillsDefs

open LieGroup

variable {𝕜 : Type*} [NontriviallyNormedField 𝕜] {H : Type*} [TopologicalSpace H] {E : Type*} [NormedAddCommGroup E] [NormedSpace 𝕜 E]

variable {I: ModelWithCorners 𝕜 E H}

def Spacetime := Fin 4 → ℝ

noncomputable instance : DecidableEq Spacetime := by
  classical
  infer_instance

instance : AddCommGroup Spacetime := by
  exact Pi.addCommGroup

instance : NormedAddCommGroup Spacetime := by
  refine' {normedAddGroup := _}
  -- Use the L^∞ norm, as it is convenient for product spaces
  exact inferInstance

instance : InnerProductSpace ℝ Spacetime := by
  refine' {
    inner := fun x y => ∑ i : Fin 4, x i * y i,
    real_inner_self_eq_norm_sq := _,
    normedAddCommGroup := inferInstance
  }
  -- Verify that the real part of the inner product equals the square of the norm
  intro x
  simp [Real.norm_eq_abs, Pi.norm_def]
  <;>
  (try norm_num) <;>
  (try ring_nf) <;>
  (try simp_all [Finset.sum_range_succ, Finset.sum_range_zero]) <;>
  (try norm_cast) <;>
  (try field_simp) <;>
  (try linarith) <;>
  (try ring_nf) <;>
  (try simp_all [Finset.sum_range_succ, Finset.sum_range_zero]) <;>
  (try norm_cast) <;>
  (try field_simp) <;>
  (try linarith)

instance : MeasurableSpace Spacetime := by
  apply inferInstance

instance : BorelSpace Spacetime := by
  have h : BorelSpace (Fin 4 → ℝ) := by
    apply BorelSpace.ofAnalytic
    <;>
    (try
      {
        have h₁ : AnalyticTopology (Fin 4 → ℝ) := by
          apply analyticTopology_of_discreteMetricSpace
          <;> infer_instance
          <;>
          (try
            {
              exact inferInstance
            })
          <;>
          (try
            {
              exact inferInstance
            })
        exact ‹AnalyticTopology (Fin 4 → ℝ)›.measurability
      })
    <;>
    (try
      {
        infer_instance
      })
  exact h
