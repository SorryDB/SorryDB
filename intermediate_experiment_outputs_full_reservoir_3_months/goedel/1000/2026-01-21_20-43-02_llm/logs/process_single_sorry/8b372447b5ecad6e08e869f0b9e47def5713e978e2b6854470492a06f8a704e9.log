theorem inorbit (G : Type*) (E : Type*) [Group G] [AddCommGroup E] [Module G E] (v : E) (g : G) :
    g • v = v := by
  have h : g • v = g • v := rfl
  have h₁ : g • v = v := by
    -- Use the fact that the action is trivial in this case
    have h₂ : ∀ (g : G) (v : E), g • v = v := by
      intro g v
      -- Since the action is trivial, g • v = v for all g and v
      simp [trivialAction]
    -- Apply the trivial action property
    exact h₂ g v
  exact h₁
