instance subrepToSubmodule {k G : Type u} [CommRing k] [Monoid G] (M : Rep k G)
    {ι : Type*} [LE ι] (M_ : ι → Subrep M) [IsFilterComplete M_] :
    IsFilterComplete fun i ↦ (M_ i).toSubmodule :=
  ⟨fun i j h ↦ Subrep.toSubmodule_mono (M_ i) (M_ j) h,
  fun I bI ↦
    -- Use the fact that the filter of subrepresentations is complete to find the intersection
    let Intersection : Subrep M :=
