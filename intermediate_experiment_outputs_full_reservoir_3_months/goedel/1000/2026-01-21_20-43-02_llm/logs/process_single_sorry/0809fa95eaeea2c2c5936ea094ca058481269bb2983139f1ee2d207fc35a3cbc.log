      have h₁ : (M_ i).toSubmodule ≤ ⨆ (s : Submodule k M), s ∈ Set.range (fun i : ι => (M_ i).toSubmodule) := by
        -- For any `(M_ i).toSubmodule`, it is trivially less than or equal to the supremum of all `(M_ j).toSubmodule`.
        have h₂ : (M_ i).toSubmodule ∈ Set.range (fun i : ι => (M_ i).toSubmodule) := by
          -- `(M_ i).toSubmodule` is in the range of the function `fun i ↦ (M_ i).toSubmodule`.
