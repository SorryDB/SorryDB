        have h' : ∀ (i : ι), x ∈ (M_ i) := by
          intro i
          simpa using h i
        -- Use the fact that the intersection of subrepresentations is a subrepresentation
        exact fun i ↦ h' i
      )
    -- Show that the intersection of submodules is the submodule of the intersection of subrepresentations
    refine' ⟨Intersection, _⟩
