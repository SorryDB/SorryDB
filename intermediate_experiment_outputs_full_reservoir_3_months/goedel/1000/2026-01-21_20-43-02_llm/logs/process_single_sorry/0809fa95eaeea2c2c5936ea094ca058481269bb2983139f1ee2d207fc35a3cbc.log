instance subrepToSubmodule {k G : Type u} [CommRing k] [Monoid G] (M : Rep k G)
    {ι : Type*} [LE ι] (M_ : ι → Subrep M) [IsFilterComplete M_] :
    IsFilterComplete fun i ↦ (M_ i).toSubmodule :=
  {
    le_total := by
      intro i j
      have h₁ : M_ i ≤ M_ j ∨ M_ j ≤ M_ i := by
        apply M_.le_total
      cases h₁ with
      | inl h₁ =>
        -- If M_i ≤ M_j, then (M_i).toSubmodule ≤ (M_j).toSubmodule
        have h₂ : (M_ i).toSubmodule ≤ (M_ j).toSubmodule := by
          exact Submodule.map_le _ h₁
        exact h₂
      | inr h₁ =>
        -- If M_j ≤ M_i, then (M_j).toSubmodule ≤ (M_i).toSubmodule
        have h₂ : (M_ j).toSubmodule ≤ (M_ i).toSubmodule := by
          exact Submodule.map_le _ h₁
        exact h₂
    exists_union_eq := by
      intro S hS
      -- Use the fact that M_ is a filter-complete family of subrepresentations
      have h₁ : ∃ (i : ι), S ⊆ (M_ i).toSubmodule := by
        -- Since M_ is filter-complete, there exists an i such that S ⊆ (M_ i).toSubmodule
        have h₂ : ∃ (i : ι), (S : Set M) ⊆ (M_ i : Subobject M).val := by
          -- This is the filter-complete property of M_
          have h₃ : ∃ (i : ι), (S : Set M) ⊆ (M_ i : Subobject M).val := by
            classical
            apply hS
          exact h₃
        obtain ⟨i, hi⟩ := h₂
        refine' ⟨i, _⟩
        -- Show that S ⊆ (M_ i).toSubmodule
        have h₃ : (S : Set M) ⊆ (M_ i : Subobject M).val := hi
        have h₄ : (S : Set M) ⊆ (M_ i).toSubmodule := by
          intro x hx
          have h₅ : x ∈ (M_ i : Subobject M).val := h₃ hx
          simpa [Submodule.mem_coe] using h₅
        exact h₄
      obtain ⟨i, hi⟩ := h₁
      refine' ⟨i, _⟩
      -- Verify that S ⊆ (M_ i).toSubmodule implies S ∪ (M_ i).toSubmodule = (M_ i).toSubmodule
      have h₂ : S ⊆ (M_ i).toSubmodule := hi
      have h₃ : S ∪ (M_ i).toSubmodule = (M_ i).toSubmodule := by
        apply Set.Subset.antisymm
        · -- Prove S ∪ (M_i).toSubmodule ⊆ (M_i).toSubmodule
          intro x hx
          cases hx with
          | inl hx =>
            -- If x ∈ S, then x ∈ (M_i).toSubmodule by h₂
            exact h₂ hx
          | inr hx =>
            -- If x ∈ (M_i).toSubmodule, then x ∈ (M_i).toSubmodule
            exact hx
        · -- Prove (M_i).toSubmodule ⊆ S ∪ (M_i).toSubmodule
          intro x hx
          exact Or.inr hx
      -- Use the union property to conclude the proof
      simpa [h₃] using h₃
  }
