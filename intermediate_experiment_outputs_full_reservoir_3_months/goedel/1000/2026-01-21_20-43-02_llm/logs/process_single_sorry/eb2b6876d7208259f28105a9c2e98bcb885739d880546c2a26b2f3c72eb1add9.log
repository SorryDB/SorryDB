theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro h₂
      have h₃ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that scalar multiplication is continuous and the properties of integral.
        have h₄ :.intervalIntegrableOn f μ (Set.Icc a b) := h₂.intervalIntegrableOn
        have h₅ : IntervalIntegrableOn (r • f) μ (Set.Icc a b) := by
          -- Use the boundedness of scalar multiplication to preserve integrability.
          refine' IntervalIntegrableOn.of_isOpen_subset h₄.isIntervalIntegrableOn h₄.isOpen_subset _
          <;> simp_all [IsOpen]
          <;> aesop
        exact h₅.intervalIntegrable
      exact h₃
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro h₂
      have h₃ : IntervalIntegrable f μ a b := by
        -- Use the fact that scalar multiplication is continuous and the properties of integral.
        have h₄ : IntervalIntegrableOn (r • f) μ (Set.Icc a b) := h₂.intervalIntegrableOn
        have h₅ : IntervalIntegrableOn f μ (Set.Icc a b) := by
          -- Use the boundedness of scalar multiplication to preserve integrability.
          refine' IntervalIntegrableOn.of_isOpen_subset h₄.isIntervalIntegrableOn h₄.isOpen_subset _
          <;> simp_all [IsOpen]
          <;> aesop
        exact h₅.intervalIntegrable
      exact h₃
  exact h₁
```
