```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro h₁
      refine' h₁.mul_right _
      <;> simp_all [intervalIntegral.integral_smul]
      <;>
      (try simp_all [intervalIntegral.integral_smul]) <;>
      (try norm_num) <;>
      (try aesop) <;>
      (try exact inferInstance) <;>
      (try simp_all [intervalIntegral.integral_smul]) <;>
      (try norm_num) <;>
      (try aesop) <;>
      (try exact inferInstance)
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro h₁
      -- This direction is more involved because we need to cancel r from r • f.
      -- Since r is arbitrary, we cannot directly use the same trick as above.
      -- Instead, we use the fact that if r ≠ 0, we can multiply by r⁻¹ to get f back.
      -- If r = 0, then r • f = 0, and we can directly use the interval integrability of 0.
      by_cases hr : r = 0
      · -- Case: r = 0
        have h₂ : r • f = fun _ => 0 := by
          ext x
          simp [hr]
        rw [h₂] at h₁
        have h₃ : IntervalIntegrable (fun _ : ℝ => (0 : E)) μ a b := by
          -- Zero function is always interval integrable.
          exact intervalIntegrable_zero _ _ _
        simpa using h₃
      · -- Case: r ≠ 0
        have h₂ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
          -- Use the fact that r⁻¹ • (r • f) = f when r ≠ 0.
          have h₃ : r⁻¹ • (r • f) = f := by
            ext x
            simp [hr, smul_smul]
            <;> field_simp [hr]
            <;> simp_all
          rw [h₃]
          exact h₁
        -- Use the fact that r⁻¹ • (r • f) is interval integrable to conclude that f is interval integrable.
        have h₃ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := h₂
        have h₄ : IntervalIntegrable f μ a b := by
          simpa [smul_smul, hr] using h₃
        exact h₄
