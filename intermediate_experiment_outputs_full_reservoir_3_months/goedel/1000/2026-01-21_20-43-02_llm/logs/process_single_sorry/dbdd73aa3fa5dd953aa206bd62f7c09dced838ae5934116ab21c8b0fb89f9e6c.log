lemma cfc_toLinearFunctional_bound (x y : H) : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
    calc
      ‖cfc_toLinearFunctional ha x y‖ = ‖compSL C((spectrum ℂ a), ℂ) _ _ _ _ (toLinearFunctional x y) (cfcCLM ha)‖ := rfl
      _ ≤ ‖toLinearFunctional x y‖ * ‖cfcCLM ha‖ := by
        apply ContinuousLinearMap.norm_comp_le
      _ ≤ ‖toLinearFunctional x y‖ * 1 := by
        have h₂ : ‖cfcCLM ha‖ = 1 := by
          have h₃ : ‖cfcCLM ha‖ = 1 := by
            -- Prove that the norm of cfcCLM ha is 1
            have h₄ : ‖cfcCLM ha‖ = 1 := by
              -- Use the fact that the norm of the continuous functional calculus map is 1
              simp [cfcCLM]
