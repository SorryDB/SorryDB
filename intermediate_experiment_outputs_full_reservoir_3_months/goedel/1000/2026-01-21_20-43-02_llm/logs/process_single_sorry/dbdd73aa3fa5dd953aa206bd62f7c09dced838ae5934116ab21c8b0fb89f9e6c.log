      classical
      have h₆ : Set.Pairwise Disjoint (Set.range w) := by
        -- Convert the pairwise disjointness condition from the function w to its range
        have h₇ : Pairwise (fun (i : ℕ) (j : ℕ) => Disjoint (w i) (w j)) := h₂
        have h₈ : Set.Pairwise Disjoint (Set.range w) := by
          intro s hs t ht disj
          obtain ⟨i, rfl⟩ := hs
          obtain ⟨j, rfl⟩ := ht
          simpa [Disjoint] using h₂ i j (by aesop)
        exact h₈
      -- Use the properties of the measure and the pairwise disjoint sets to conclude the sum
      have h₉ : HasSum (fun i : ℕ => (measureOf (w i)).x) ((measureOf (⋃ i : ℕ, w i)).x) := by
        -- Apply the measure's countable additivity to the pairwise disjoint sets
        have h₁₀ : (.measureOf (⋃ i : ℕ, w i)).x = (..measureOf (⋃ i : ℕ, w i)).x := rfl
        have h₁₁ : HasSum (fun i : ℕ =>(..measureOf (w i)).x) ((..measureOf (⋃ i : ℕ, w i)).x) := by
