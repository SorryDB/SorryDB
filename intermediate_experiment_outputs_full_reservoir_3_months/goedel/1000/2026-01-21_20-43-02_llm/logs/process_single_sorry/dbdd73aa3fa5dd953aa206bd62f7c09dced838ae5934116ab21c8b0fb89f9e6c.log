lemma set_theory_strong (sq : ℕ → Set α) (ha : ∀ (i : ℕ), Measurable (sq i))
    (hd : Pairwise (fun i j => Disjoint (sq i) (sq j)))
    (h : ∀ (i : ℕ), sq i ⊆ s) :
    Measurable s := by
  have h₁ : Measurable s := by
    -- Use the fact that the union of measurable sets is measurable
    have h₂ : Measurable (⋃ i : ℕ, sq i) := by
      -- The union of countably many measurable sets is measurable
      apply measurable_iUnion
      intro i
      exact ha i
    -- Since each sq i is a subset of s, their union is also a subset of s
    have h₃ : (⋃ i : ℕ, sq i) ⊆ s := by
      intro x hx
      -- For any x in the union, there exists an i such that x is in sq i
      rcases hx with ⟨i, hi⟩
      -- Since sq i is a subset of s, x must also be in s
      exact h i hi
    -- If the union is measurable and is a subset of s, then s is measurable
    have h₄ : Measurable s := by
      -- Use the fact that the union is measurable and a subset of s
      have h₅ : Measurable (⋃ i : ℕ, sq i) := h₂
      have h₆ : (⋃ i : ℕ, sq i) ⊆ s := h₃
      -- Since the union is measurable and a subset of s, s is measurable
      exact h₅.mono h₆
    exact h₄
  exact h₁
