          have h₁₃ : (..measureOf (⋃ i : ℕ, w i)).x = (..measureOf (⋃ i : ℕ, w i)).x := rfl
          -- Apply the lemma for the sum of the measures
          apply
            (MeasureTheory.countable_additivity (v := 𝓢) (.volume))
              (s := Set.range w)
