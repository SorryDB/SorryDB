lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
    -- Use the fact that the integral of a measurable function is bounded by its constant times the norm of the measure
    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
      -- Use the previously established bound for the complex measure
      have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
        have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
          -- Use the previously established bound for the complex measure
          simpa [Complex.norm_eq_abs] using cfc_toComplexMeasure_bounded x y f
        exact h₄
      -- Relate the norm of f to the constant C
      have h₅ : ‖f‖ ≤ C := by
        -- Since f is bounded by C, its norm is also bounded by C
        refine' le_of_forall_lt_of_dense fun r hr => _
        -- Use the fact that f is measurable and bounded to show that its norm is bounded by C
        have h₆ : ‖f‖ < r := by
          -- Use the definition of norm and the boundedness of f to show that it is less than r
          have h₇ : ‖f‖ = 0 := by
            simp [Complex.norm_eq_abs, norm_eq_abs]
            <;>
            simp_all [hf_bounded]
            <;>
            norm_num
          rw [h₇]
          linarith
        linarith
      -- Combine the inequalities to get the final bound
      calc
        ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := h₃
        _ ≤ ‖x‖ * ‖y‖ * C := by gcongr
    exact h₂
  exact h₁
