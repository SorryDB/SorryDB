lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by
    simp [cfc_toComplexMeasure, ComplexRMK.integral, ContinuousLinearMap.map_apply]
    <;>
    simp_all [compSL_apply]
    <;>
    rfl
  rw [h₁]
  have h₂ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
    calc
      ‖cfc_toLinearFunctional ha x y f‖ = ‖cfc_toLinearFunctional ha x y f‖ := rfl
      _ ≤ ‖x‖ * ‖y‖ := by
        -- Use the previously established bound for the linear functional
        have h₃ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
        have h₄ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
          -- Use the property of continuous linear maps
          calc
            ‖cfc_toLinearFunctional ha x y f‖ = ‖cfc_toLinearFunctional ha x y f‖ := rfl
            _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
              apply ContinuousLinearMap.le_opNorm
        calc
          ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₄
          _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr
          _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring
      _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
        -- This step is trivial since the right side is the same
        simp [mul_assoc]
  exact h₂
