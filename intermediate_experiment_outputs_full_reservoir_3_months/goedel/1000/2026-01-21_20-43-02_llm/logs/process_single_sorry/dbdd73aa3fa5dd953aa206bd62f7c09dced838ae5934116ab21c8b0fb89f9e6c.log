lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h₁ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
    -- Use the fact that the variation of the measure is bounded by the norm of the linear functional
    have h₂ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖cfc_toLinearFunctional ha x y‖ := by
      -- Apply the property of the Riesz-Markov-Kakutani representation
      calc
        (cfc_toComplexMeasure ha x y).variation Set.univ = (ComplexRMK.rieszMeasure (compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (ZeroAtInftyContinuousMap.continuousMapOnC₀))).variation Set.univ := rfl
        _ ≤ ‖cfc_toLinearFunctional ha x y‖ := by
          -- Use the fact that the variation of the measure is bounded by the norm of the linear functional
          apply ComplexRMK.rieszMeasure_variation_le
          <;>
          simp [cfc_toLinearFunctional]
          <;>
          try norm_num
          <;>
          try simp_all [ContinuousLinearMap.continuous]
          <;>
          try continuity
          <;>
          try exact inferInstance
    -- Use the previously established bound for the linear functional
    have h₃ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
    calc
      (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖cfc_toLinearFunctional ha x y‖ := h₂
      _ ≤ ‖x‖ * ‖y‖ := h₃
      _ = ‖x‖ * ‖y‖ := by rfl
  -- Convert the norm to the extended norm
  calc
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := h₁
    _ ≤ ‖x‖ₑ * ‖y‖ₑ := by
      -- Use the fact that the norm is less than or equal to the extended norm
      have h₄ : (‖x‖ : ℝ) ≤ ‖x‖ₑ := by
