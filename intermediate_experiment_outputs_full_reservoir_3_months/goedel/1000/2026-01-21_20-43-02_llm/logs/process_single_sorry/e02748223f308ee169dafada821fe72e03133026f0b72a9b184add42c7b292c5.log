theorem pos_of_pos_of_nonneg {a : ℝ} (h₀ : 0 < a) (h₁ : 0 ≤ a) : 0 < a := by
  -- This is a trivial case because `h₀` already directly implies `0 < a`.
  -- However, since we need to use `by_cases`, we can simply use `h₀` to conclude the proof.
  by_cases h : 0 < a
  · -- Case: 0 < a is true
    exact h
  · -- Case: 0 < a is false
    -- This case is impossible because `h₀` directly contradicts `¬(0 < a)`.
    exfalso
    linarith
```
