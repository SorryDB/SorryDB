(0 : ℤ) < 2) d]\n      -- Check all possible values of a, b, c\n      interval_cases a <;> norm_num at h₅ h₈ h₉ h₁₀ h₁₁ h₁₂ ⊢ <;>\n        (try omega) <;>\n        (try {\n          rcases d with (_ | _ | _ | _ | _ | _ | _ | d) <;>\n          rcases e with (_ | _ | _ | _ | _ | _ | _ | e) <;>\n          rcases f with (_ | _ | _ | _ | _ | _ | _ | f) <;>\n          norm_num at h₁₀ h₁₁ h₁₂ ⊢ <;>\n          (try omega) <;>\n          (try {\n            have h₂₄ : b ≤ 40 := by\n              by_contra! h₂₅\n              have h₂₆ : b ≥ 41 := by linarith\n              have h₂₇ : (b : ℤ) * c ≥ b * b := by\n                have h₂₈ : (c : ℤ) ≥ b := by exact_mod_cast h₉\n                nlinarith\n              have h₂₉ : (b : ℤ) * c - a ≥ b * b - a := by linarith\n              have h₃₀ : (b : ℤ) * b - a > (2 : ℤ) ^ e := by\n                have h₃₁ : (b : ℤ) * c - a = (2 : ℤ) ^ e := by exact_mod_cast h₃\n                have h₃₂ : (b : ℤ) * b - a ≤ (b : ℤ) * c - a := by\n                  have h₃₃ : (b : ℤ) ≤ c := by exact_mod_cast h₉\n                  nlinarith [h₇]\n                nlinarith [pow_pos (by norm_num : (0 : ℤ) < 2) e]\n              nlinarith [pow_pos (by norm_num : (0 : ℤ) < 2) e]\n            interval_cases b <;> norm_num at h₆ h₈ h₉ h₁₀ h₁₁ h₁₂ ⊢ <;>\n              (try omega) <;>\n              (try {\n                rcases d with (_ | _ | _ | _ | _ | _ | _ | d) <;>\n                rcases e with (_ | _ | _ | _ | _ | _ | _ | e) <;>\n                rcases f with (_ | _ | _ | _ | _ | _ | _ | f) <;>\n                norm_num at h₁₀ h₁₁ h₁₂ ⊢ <;>\n                (try omega) <;>\n                (try {\n                  have h₃₄ : c ≤ 100 := by\n                    by_contra! h₃₅\n                    have h₃₆ : c ≥ 101 := by linarith\n                    have h₃₇ : (c : ℤ) * a ≥ c * a := by nlinarith\n                    have h₃₈ : (c : ℤ) * a - b ≥ c * a - b := by nlinarith\n                    have h₃₉ : (c : ℤ) * a - b > (2 : ℤ) ^ f := by\n          