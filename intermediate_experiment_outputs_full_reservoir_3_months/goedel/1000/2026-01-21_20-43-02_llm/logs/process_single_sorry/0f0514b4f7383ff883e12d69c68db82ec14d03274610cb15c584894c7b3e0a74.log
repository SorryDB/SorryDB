theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  have h : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by
    intro l
    induction l using List.induction_on with
    | nil =>
      intro x
      simp [quickSort]
    | cons y ys ih =>
      intro x
      have h₁ := ih
      simp_all [quickSort, smaller, larger, List.count_cons, List.count_eq_zero_of_not_mem]
      <;>
      (try
        {
          cases' le_total x y with h₂ h₂ <;>
          cases' le_total y x with h₃ h₃ <;>
          simp_all [List.mem_filter, List.mem_cons, List.count_cons, List.count_eq_zero_of_not_mem] <;>
          (try { contradiction }) <;>
          (try { ring_nf at * <;> omega }) <;>
          (try { linarith })
        }) <;>
      (try
        {
          simp_all [List.count_cons, List.count_eq_zero_of_not_mem]
          <;>
          (try { ring_nf at * <;> omega }) <;>
          (try { linarith })
        }) <;>
      (try
        {
          aesop
        }) <;>
      (try
        {
          norm_num at *
          <;>
          aesop
        })
  exact h l x
