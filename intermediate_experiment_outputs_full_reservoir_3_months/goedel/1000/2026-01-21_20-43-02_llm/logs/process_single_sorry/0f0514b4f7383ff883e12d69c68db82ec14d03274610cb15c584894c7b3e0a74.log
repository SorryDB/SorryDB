      "\n  have h₁ : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by\n    intro l x\n    induction l using List.length_induction_on with\n    | hnil =>\n      simp [quickSort]\n    | hcons l h ih =>\n      cases l with\n      | nil =>\n        simp [quickSort, smaller, larger]\n        <;>\n        (try decide) <;>\n        (try simp_all [List.count_cons, List.count_eq_zero_of_not_mem]) <;>\n        (try omega) <;>\n        (try\n          {\n            by_cases h : x = a\n            <;> simp_all [List.count_cons, List.count_eq_zero_of_not_mem]\n            <;> omega\n          })\n      | cons pivot l =>\n        simp_all [quickSort, smaller, larger, List.count_append, List.count_cons, List.count_eq_zero_of_not_mem]\n        <;>\n        (try\n          {\n            split_ifs at *\n            <;>\n            (try simp_all [List.count_cons, List.count_eq_zero_of_not_mem])\n            <;>\n            (try omega)\n            <;>\n            (try\n              {\n                by_cases h : x = a <;>\n                simp_all [List.count_cons, List.count_eq_zero_of_not_mem]\n                <;>\n                (try omega)\n              })\n          }) <;>\n        (try\n          {\n            simp_all [List.count_cons, List.count_eq_zero_of_not_mem]\n            <;>\n            (try omega)\n            <;>\n            (try\n              {\n                by_cases h : x = a <;>\n                simp_all [List.count_cons, List.count_eq_zero_of_not_mem]\n                <;>\n                (try omega)\n              })\n          })\n  exact h₁ l x",
