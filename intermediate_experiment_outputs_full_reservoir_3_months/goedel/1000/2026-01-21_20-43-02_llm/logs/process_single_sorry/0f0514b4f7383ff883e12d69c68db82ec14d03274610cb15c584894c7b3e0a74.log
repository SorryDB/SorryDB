theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  induction l using List.length_induction with
  | h l ih =>
    cases l with
    | nil =>
      simp
    | cons pivot l =>
      have h₁ : (smaller pivot l).length < (pivot :: l).length := by
        simp [smaller, List.filter]
        <;>
          (try simp_all) <;>
          (try omega)
      have h₂ : (larger pivot l).length < (pivot :: l).length := by
        simp [larger, List.filter]
        <;>
          (try simp_all) <;>
          (try omega)
      simp_all [quickSort, List.count_append, List.count_cons, count_sum_above_below_pivot]
      <;>
        (try cases (x ≤ pivot) <;>
          simp_all [smaller, larger, List.filter, List.count]) <;>
        (try omega)
      <;>
        (try
          {
            cases x <;>
            simp_all [smaller, larger, List.filter, List.count] <;>
            (try omega)
          }
        )
      <;>
        (try
          {
            simp_all [smaller, larger, List.filter, List.count]
            <;>
            (try omega)
          }
        )
      <;>
        (try
          {
            simp_all [smaller, larger, List.filter, List.count]
            <;>
            (try
              {
                simp_all [List.count]
                <;>
                (try omega)
              }
            )
          }
        )
      <;>
        (try
          {
            omega
          }
        )
