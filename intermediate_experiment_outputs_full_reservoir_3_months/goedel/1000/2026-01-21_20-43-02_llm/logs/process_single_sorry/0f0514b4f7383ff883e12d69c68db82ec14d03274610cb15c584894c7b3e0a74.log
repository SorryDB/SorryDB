      "\n  have h₁ : ∀ (l : List α), l.count x = (quickSort l).count x := by\n    intro l\n    induction l using List.induction_on with\n    | nil =>\n      simp [quickSort]\n    | cons a l ih =>\n      have h₂ : quickSort (a :: l) = (quickSort (smaller a l)) ++ a :: (quickSort (larger a l)) := by\n        simp [quickSort_cons]\n      rw [h₂]\n      have h₃ : (a :: l).count x = (smaller a l).count x + (larger a l).count x + (if x = a then 1 else 0) := by\n        have h₄ : (a :: l).count x = (smaller a l).count x + (larger a l).count x + (if x = a then 1 else 0) := by\n          calc\n            (a :: l).count x = ((smaller a l) ++ (if x = a then [x] else []) ++ (larger a l)).count x := by\n              have h₅ : a :: l = (smaller a l) ++ (if x = a then [x] else []) ++ (larger a l) := by\n                have h₆ : ∀ (a : α), a ∈ (a :: l) ↔ a ∈ (smaller a l) ∨ a ∈ (larger a l) := by\n                  intro a\n                  exact mem_iff_below_or_above_pivot a l a\n                have h₇ : a :: l = (smaller a l) ++ (if x = a then [x] else []) ++ (larger a l) := by\n                  apply List.ext_get\n                  intro i hi\n                  have h₈ := h₆ (a :: l).get ⟨i, hi⟩\n                  simp [smaller, larger, List.mem_filter, List.mem_append] at h₈ ⊢\n                  <;>\n                  (try { aesop }) <;>\n                  (try {\n                    split_ifs at * <;>\n                    simp_all [List.get_append, List.get, List.get_cons, List.get_singleton]\n                    <;>\n                    (try { omega }) <;>\n                    (try {\n                      by_cases h₉ : (a :: l).get ⟨i, hi⟩ ≤ a <;>\n                      by_cases h₁₀ : a < (a :: l).get ⟨i, hi⟩ <;>\n                      simp_all [le_of_lt] <;>\n                      (try { omega }) <;>\n                      (try { aesop })\n                    })\n                  })\n                exact h₇\n              rw [h₅]\n              <;>\n              simp [List.count_append]\n            _ = ((smaller a l) ++ (if x = a then [x] else []) ++ (larger a l)).count x := by rfl\n            _ = ((smaller a l) ++ (if x = a then [x] else [])).count x + (larger a l).count x := by\n              simp [List.count_append]\n            _ = ((smaller a l).count x + (if x = a then [x] else []).count x) + (larger a l).count x := by\n              simp [List.count_append]\n            _ = (smaller a l).count x + (if x = a then [x] else []).count x + (larger a l).count x := by\n              ring\n            _ = (smaller a l).count x + (if x = a then 1 else 0) + (larger a l).count x := by\n              split_ifs <;> simp_all [List.count_singleton]\n              <;>\n              (try { aesop }) <;>\n              (try { simp_all [if_pos, if_neg] })\n            _ = (smaller a l).count x + (larger a l).count x + (if x = a then 1 else 0) := by\n              ring\n          <;>\n          (try { aesop }) <;>\n          (try { simp_all [if_pos, if_neg] })\n        exact h₄\n      have h₄ : ((quickSort (smaller a l)) ++ a :: (quickSort (larger a l))).count x = (quickSort (smaller a l)).count x + (if x = a then 1 else 0) + (quickSort (larger a l)).count x := by\n        calc\n          ((quickSort (smaller a l)) ++ a :: (quickSort (larger a l))).count x =\n              ((quickSort (smaller a l)) ++ [a] ++ (quickSort (larger a l))).count x := by\n            simp [List.cons_append]\n          _ = ((quickSort (smaller a l)) ++ [a]).count x + (quickSort (larger a l)).count x := by\n            simp [List.count_append]\n          _ = (quickSort (smaller a l)).count x + [a].count x + (quickSort (larger a l)).count x := by\n            simp [List.count_append]\n          _ = (quickSort (smaller a l)).count x + (if x = a then 1 else 0) + (quickSort (larger a l)).count x := by\n            simp [List.count_singleton]\n            <;>\n            (try { aesop }) <;>\n            (try { simp_all [if_pos, if_neg] })\n          _ = (quickSort