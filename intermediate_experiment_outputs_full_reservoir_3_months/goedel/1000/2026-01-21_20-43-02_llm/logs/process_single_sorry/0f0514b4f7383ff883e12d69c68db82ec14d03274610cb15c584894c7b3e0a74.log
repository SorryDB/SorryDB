```lean
theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  have h : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by
    intro l x
    have h₁ : ∀ (l : List α) (x : α), l.count x = (quickSort l).count x := by
      intro l
      induction l using List.recOn with
      | nil =>
        intro x
        simp [quickSort]
      | cons pivot l ih =>
        intro x
        have h₂ := ih
        simp_all [quickSort, smaller, larger, List.count_append, List.count_cons, List.mem_filter]
        <;>
        (try cases (x ≤ pivot) <;> cases (pivot < x) <;> simp_all [List.filter] <;> omega) <;>
        (try
          {
            have h₃ := count_sum_above_below_pivot pivot l x
            simp_all [List.count_append, List.count_cons, List.mem_filter]
            <;>
            (try omega)
          }) <;>
        (try
          {
            split_ifs at * <;>
            (try simp_all [List.count_append, List.count_cons, List.mem_filter]) <;>
            (try omega)
          }) <;>
        (try
          {
            have h₃ := count_sum_above_below_pivot pivot l x
            simp_all [List.count_append, List.count_cons, List.mem_filter]
            <;>
            (try omega)
          })
    exact h₁ l x
  exact h l x
