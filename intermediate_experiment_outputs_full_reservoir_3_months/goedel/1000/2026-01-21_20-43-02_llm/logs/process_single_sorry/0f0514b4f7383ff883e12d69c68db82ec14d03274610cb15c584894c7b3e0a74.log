  simp [quickSort]

@[simp, grind .]
theorem quickSort_cons (pivot : α) (l : List α) :
    quickSort (pivot :: l) = (quickSort (smaller pivot l)) ++
    pivot :: (quickSort (larger pivot l)) := by
  simp [quickSort]

@[grind .]
theorem mem_iff_below_or_above_pivot (pivot : α)
  (l : List α)(x : α) :
    x ∈ l ↔ x ∈ smaller pivot l ∨ x ∈ larger pivot l := by
  constructor
  · intro h
    have h₁ : x ∈ l := h
    have h₂ : x ≤ pivot ∨ pivot < x := by
      by_cases h₃ : x ≤ pivot
      · exact Or.inl h₃
      · have h₄ : pivot < x := lt_of_not_ge h₃
        exact Or.inr h₄
    cases h₂ with
    | inl h₂ =>
      have h₃ : x ∈ smaller pivot l := by
        apply List.mem_filter.mpr
        exact ⟨h₁, by simpa [h₂] using h₂⟩
      exact Or.inl h₃
    | inr h₂ =>
      have h₃ : x ∈ larger pivot l := by
        apply List.mem_filter.mpr
        exact ⟨h₁, by simpa [h₂] using h₂⟩
      exact Or.inr h₃
  · intro h
    cases h with
    | inl h =>
      have h₁ : x ∈ smaller pivot l := h
      have h₂ : x ∈ l := by
        have h₃ : x ∈ smaller pivot l := h₁
        have h₄ : x ∈ l := by
          have h₅ : x ∈ l.filter (fun x => x ≤ pivot) := h₃
          have h₆ : x ∈ l := by
            simp only [List.mem_filter] at h₅
            exact h₅.1
          exact h₆
        exact h₄
      exact h₂
    | inr h =>
      have h₁ : x ∈ larger pivot l := h
      have h₂ : x ∈ l := by
        have h₃ : x ∈ larger pivot l := h₁
        have h₄ : x ∈ l := by
          have h₅ : x ∈ l.filter (fun x => pivot < x) := h₃
          have h₆ : x ∈ l := by
            simp only [List.mem_filter] at h₅
            exact h₅.1
          exact h₆
        exact h₄
      exact h₂

@[grind =_]
theorem mem_iff_mem_quickSort (l: List α)(x : α) :
    x ∈ l ↔ x ∈ quickSort l := by
  cases l with
  | nil => simp
  | cons pivot l =>
    have : (smaller pivot l).length < (pivot :: l).length := by
      grind
    have : (larger pivot l).length < (pivot :: l).length := by
      grind
    have ih₁ := mem_iff_mem_quickSort (smaller pivot l)
    have ih₂ := mem_iff_mem_quickSort (larger pivot l)
    grind
termination_by l.length

