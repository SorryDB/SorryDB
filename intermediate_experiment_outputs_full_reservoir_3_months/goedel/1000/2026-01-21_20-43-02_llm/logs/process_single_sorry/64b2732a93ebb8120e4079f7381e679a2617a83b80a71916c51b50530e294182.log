      "\n    funext ω\n    rw [wignerMatrixMap]\n    rw [wignerMatrixMap']\n    simp [wignerMatrixEntryFunction]\n    <;>\n    (try cases n <;> simp_all [Fin.ext_iff]) <;>\n    (try decide) <;>\n    (try {\n      aesop\n    }) <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      omega\n    })\n    <;>\n    (try {\n      simp_all [Fin.ext_iff]\n      <;>\n      omega\n    })\n  rw [h₁]\n  have h₂ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by\n    have h₃ : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (WignerMeasure μ ν n) := by\n      have h₄ : (fun ω : WignerSpace n ↦ ω ⟨(i, i), le_refl i⟩) = Proj.fst (⟨(i, i), le_refl i⟩ : Index n) : WignerSpace n → ℝ := by\n        ext ω\n        rfl\n      rw [h₄]\n      apply MeasurableSpace.mapMeasurableMeasurability\n      <;>\n      (try simp [wignerMeasureDist]) <;>\n      (try aesop) <;>\n      (try {\n        apply MeasureTheory.projMeasurable\n      })\n      <;>\n      (try {\n        simp_all [WignerMeasure]\n      })\n      <;>\n      (try {\n        aesop\n      })\n    have h₅ : (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) = ν := by\n      simp [wignerMeasureDist]\n      <;>\n      simp_all [Fin.ext_iff]\n      <;>\n      (try { aesop })\n      <;>\n      (try {\n        simp_all [Fin.ext_iff]\n        <;>\n        aesop\n      })\n    rw [h₅] at h₃\n    exact h₃\n  exact h₂",
      "\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    simp_all [Fin.ext_iff, Prod.ext_iff]\n    <;>\n    norm_num\n    <;>\n    aesop\n  \n  have h_main : HasLaw (fun ω : WignerSpace n => (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by\n    rw [h]\n    have h₁ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, i), by simp [le_refl]⟩) ν (WignerMeasure μ ν n) := by\n      -- Use the fact that the measure on the product space is the product of the measures on each component\n      -- and that the diagonal entries are assigned the measure ν.\n      have h₂ : HasLaw (fun ω : WignerSpace n => ω ⟨(i, i), by simp [le_refl]⟩) (wignerMeasureDist μ ν n ⟨(i, i), by simp [le_refl]⟩) (WignerMeasure μ ν n) := by\n        -- Use the property of the product measure to get the law of each component\n        apply hasLaw_fst\n      -- Simplify the measure assigned to the diagonal entry\n      have h₃ : wignerMeasureDist μ ν n ⟨(i, i), by simp [le_refl]⟩ = ν := by\n        simp [wignerMeasureDist]\n        <;>\n        simp_all [Fin.ext_iff]\n        <;>\n        norm_num\n        <;>\n        aesop\n      -- Conclude that the law is ν\n      rw [h₃] at h₂\n      exact h₂\n    exact h₁\n  \n  exact h_main",
