      "\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;>\n    simp_all [Fin.ext_iff]\n    <;>\n    aesop\n  \n  have h₂ : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by\n    rw [h₁]\n    have h₃ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, i), le_refl i⟩ : Index n)) ν (WignerMeasure μ ν n) := by\n      have h₄ : (Measure.pi (wignerMeasureDist μ ν n)) = WignerMeasure μ ν n := rfl\n      -- Use the fact that the projection has the law of the corresponding measure in the product\n      have h₅ : HasLaw (fun ω : WignerSpace n => ω (⟨(i, i), le_refl i⟩ : Index n)) (wignerMeasureDist μ ν n (⟨(i, i), le_refl i⟩ : Index n)) (Measure.pi (wignerMeasureDist μ ν n)) := by\n        apply Measure.hasLaw_pi\n      -- Simplify the measure for the diagonal element\n      have h₆ : wignerMeasureDist μ ν n (⟨(i, i), le_refl i⟩ : Index n) = ν := by\n        simp [wignerMeasureDist]\n        <;>\n        simp_all [Fin.ext_iff]\n        <;>\n        aesop\n      -- Rewrite the law using the simplified measure\n      rw [h₆] at h₅\n      -- Use the fact that the product measure is the Wigner measure\n      simpa [h₄] using h₅\n    exact h₃\n  \n  apply h₂",
      "\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixEntryFunction]\n    <;>\n    by_cases h : i = i <;>\n    simp_all [h]\n    <;>\n    aesop\n  \n  rw [h₁]\n  have h₂ : HasLaw (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by\n    have h₃ : (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) = (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) := rfl\n    rw [h₃]\n    -- Use the fact that the measure on the product space assigns the measure ν to the diagonal entries\n    have h₄ : (WignerMeasure μ ν n) = Measure.pi (wignerMeasureDist μ ν n) := rfl\n    rw [h₄]\n    -- The pi measure assigns the measure ν to each coordinate\n    have h₅ : (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) = (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) := rfl\n    rw [h₅]\n    -- Use the property of the product measure to get the law of the coordinate\n    have h₆ : (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) = ν := by\n      simp [wignerMeasureDist]\n      <;>\n      simp_all [Fin.ext_iff]\n      <;>\n      aesop\n    -- The law of the coordinate is ν\n    have h₇ : HasLaw (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (Measure.pi (wignerMeasureDist μ ν n)) := by\n      apply MeasureTheory.hasLaw_pi_fst\n    rw [h₆] at h₇\n    exact h₇\n  exact h₂",
