      "\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n    <;> simp_all [Fin.ext_iff, Fin.val_mk]\n    <;> aesop\n  rw [h₁]\n  have h₂ : HasLaw (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by\n    have h₃ : HasLaw (fun ω : Index n → ℝ ↦ ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (WignerMeasure μ ν n) := by\n      apply Measure.pi_hasLaw\n      <;> simp\n    have h₄ : wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩ = ν := by\n      simp [wignerMeasureDist]\n      <;> aesop\n    rw [h₄] at h₃\n    exact h₃\n  exact h₂",
      "\n    funext ω\n    dsimp [wignerMatrixMap, wignerMatrixMap', Matrix.of_apply, wignerMatrixEntryFunction]\n    <;> simp [if_pos, eq_self_iff_true, and_true]\n    <;> rfl\n  \n  have h2 : HasLaw (fun ω : WignerSpace n ↦ ω ⟨(i, i), by simp [Fin.ext_iff]⟩) ν (WignerMeasure μ ν n) := by\n    rw [show (WignerMeasure μ ν n) = (Measure.pi fun (p : Index n) => if p.val.1 = p.val.2 then ν else μ) by rfl]\n    -- Use the fact that the coordinate function has the same distribution as the corresponding measure in the product\n    have h : HasLaw (fun (ω : Index n → ℝ) => ω ⟨(i, i), by\n        simp [Fin.ext_iff]\n        <;>\n        omega⟩) (if (⟨(i, i), by simp [Fin.ext_iff]⟩ : Index n).val.1 = (⟨(i, i), by simp [Fin.ext_iff]⟩ : Index n).val.2 then ν else μ) (Measure.pi fun (p : Index n) => if p.val.1 = p.val.2 then ν else μ) := by\n      -- Use the basic property of product measures\n      apply hasLaw_pi\n      <;> simp_all [Index]\n      <;> aesop\n    -- Simplify the condition for the diagonal element\n    have h₁ : (⟨(i, i), by simp [Fin.ext_iff]⟩ : Index n).val.1 = (⟨(i, i), by simp [Fin.ext_iff]⟩ : Index n).val.2 := by\n      simp [Index, Fin.ext_iff]\n      <;>\n      aesop\n    -- Conclude the proof by simplifying the if-then-else condition\n    convert h using 1 <;> simp_all\n  \n  have h3 : HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by\n    rw [h1]\n    exact h2\n  \n  exact h3",
      "\n    ext1 ω\n    -- Simplify the expression using the definition of wignerMatrixEntryFunction and wignerMatrixMap\n    simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, Matrix.of_apply]\n    <;> aesop\n  rw [h₁]\n  -- Use the fact that the projection function has law ν\n  have h₂ : HasLaw (fun ω : (Index n → ℝ) ↦ ω ⟨(i, i), le_refl i⟩) ν (WignerMeasure μ ν n) := by\n    -- Use the definition of WignerMeasure and pi_measurability to get the law of the projection\n    have h₃ : (WignerMeasure μ ν n) = Measure.pi (wignerMeasureDist μ ν n) := rfl\n    rw [h₃]\n    -- Use the fact that the projection function has law (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩)\n    have h₄ : (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) = ν := by\n      simp [wignerMeasureDist]\n      <;> simp_all [Index.mk.injEq]\n      <;> aesop\n    -- Use the HasLaw.prod_mk to get the law of the projection\n    have h₅ : HasLaw (fun ω : (Index n → ℝ) ↦ ω ⟨(i, i), le_refl i⟩) (wignerMeasureDist μ ν n ⟨(i, i), le_refl i⟩) (Measure.pi (wignerMeasureDist μ ν n)) := by\n      apply hasLaw_mk\n    rw [h₄] at h₅\n    exact h₅\n  exact h₂",
