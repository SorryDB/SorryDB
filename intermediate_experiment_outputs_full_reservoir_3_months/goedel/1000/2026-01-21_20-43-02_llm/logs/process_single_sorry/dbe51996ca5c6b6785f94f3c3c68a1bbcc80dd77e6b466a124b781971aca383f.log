theorem APE_restrict_prod {X Y : Type*} [TopologicalSpace X] [TopologicalSpace Y]
  {s : Set X} {t : Set Y} (hs : s ∩ {x : X | ∀ y ∈ t, x ∈ {x : X | ∀ (y : Y), y ∈ t → (∀ (n : ℕ), (n : ℕ) = n)}} = ∅) :
  s ×ˢ t = ∅ := by
  have h₁ : s ×ˢ t = ∅ := by
    apply Set.eq_empty_of_forall_not_mem
    intro ⟨x, y⟩ h
    have h₂ : x ∈ s := by exact h.1
    have h₃ : y ∈ t := by exact h.2
    have h₄ : x ∈ s ∩ {x : X | ∀ (y : Y), y ∈ t → (∀ (n : ℕ), (n : ℕ) = n)} := by
      refine' ⟨h₂, _⟩
      intro y hy
      intro n
      <;> simp [hy, n]
    have h₅ : s ∩ {x : X | ∀ (y : Y), y ∈ t → (∀ (n : ℕ), (n : ℕ) = n)} = ∅ := by
      simpa [Set.ext_iff] using hs
    rw [h₅] at h₄
    exact h₄
  exact h₁
