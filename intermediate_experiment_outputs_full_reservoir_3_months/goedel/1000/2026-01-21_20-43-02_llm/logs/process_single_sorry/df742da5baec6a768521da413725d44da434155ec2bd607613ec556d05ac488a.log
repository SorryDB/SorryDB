def Request.equivalent (r₁ r₂ : Request) : Bool :=
  if r₁.isFence then r₁.basic_type == r₂.basic_type
  else r₁.address? == r₂.address? && r₁.value? == r₂.value? && r₁.thread == r₂.thread &&
