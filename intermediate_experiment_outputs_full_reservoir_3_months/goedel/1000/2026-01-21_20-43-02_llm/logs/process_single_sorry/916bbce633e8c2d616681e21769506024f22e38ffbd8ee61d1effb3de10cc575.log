  have h_main : ∀ (f : α → 𝕜), MemLorentz f p 1 μ → ∀ (G : Set α'), MeasurableSet G → ν G < ∞ → eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal := by sorry
  have h_final : HasLorentzType T p 1 p ∞ μ ν (4 * c / p) := by sorry
  exact h_final
