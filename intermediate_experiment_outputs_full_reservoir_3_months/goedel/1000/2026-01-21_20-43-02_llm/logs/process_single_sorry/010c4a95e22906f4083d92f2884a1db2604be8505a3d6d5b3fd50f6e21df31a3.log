def opReqId? : Option (Request) Ôćĺ Option RequestId := Option.map ╬╗ r => r.id

def valConsistent (vals :  Array (Option (Request))) : Bool :=
  let valOpIds := vals.map opReqId?
  let valConsistent := ╬╗ idx opVal => match opVal with
    | none => true
    | some val => val == idx
  let consistentVals := valOpIds.mapIdx valConsistent
  consistentVals.foldl (init:= true) (. && .)

structure RequestArray where
  val : Array (Option (Request))
  coherent : valConsistent val = true

instance : BEq (RequestArray) where beq := ╬╗ arrÔéü arrÔéé => arrÔéü.val == arrÔéé.val

def RequestArray.getReq? : RequestArray Ôćĺ RequestId Ôćĺ Option (Request)
  | arr, rId => match arr.val[rId.toNat]? with
    | some (some req) => some req
    | _ => none

def RequestArray.getReq! : RequestArray Ôćĺ RequestId Ôćĺ Request
  | arr, rId => arr.val[rId.toNat]?.get!.get!

def RequestArray.printReq : RequestArray Ôćĺ RequestId Ôćĺ String
  | arr, rId => match arr.getReq? rId with
    | none => ""
    | some r => r.toShortString

def RequestArray.seen : RequestArray Ôćĺ List RequestId
  | arr => List.range arr.val.size

def RequestArray.map {╬▓ : Type} : RequestArray Ôćĺ (Request Ôćĺ ╬▓) Ôćĺ Array ╬▓
 | rarr, f => filterNonesArr $ rarr.val.map ╬╗ opreq => Option.map f opreq
