```lean
lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have : ↑(Γ ∪ Δ) ⊆ construction T hT m := by
    have h₁ : ↑(Γ ∪ Δ) ⊆ ↑Γ ∪ ↑Δ := by
      intro x hx;
      simp only [Finset.mem_union, Set.mem_union] at hx ⊢;
      aesop
    have h₂ : ↑Γ ⊆ construction T hT (encode φ) := hΓ₁
    have h₃ : ↑Δ ⊆ construction T hT (encode ψ) := hΔ₁
    have h₄ : (encode φ ≤ m) := by
      have h₄₁ : encode φ ≤ max (encode φ) (encode ψ) := le_max_left _ _
      <;> simp [m] at h₄₁ ⊢ <;> assumption
    have h₅ : (encode ψ ≤ m) := by
      have h₅₁ : encode ψ ≤ max (encode φ) (encode ψ) := le_max_right _ _
      <;> simp [m] at h₅₁ ⊢ <;> assumption
    have h₆ : construction T hT (encode φ) ⊆ construction T hT m := by
      have h₆₁ : encode φ ≤ m := h₄
      exact monotone_construction h₆₁
    have h₇ : construction T hT (encode ψ) ⊆ construction T hT m := by
      have h₇₁ : encode ψ ≤ m := h₅
