lemma iIndepFun_rewardByCount (alg : Algorithm α ℝ) (ν : Kernel α ℝ) [IsMarkovKernel ν] :
    iIndepFun (fun (p : α × ℕ) ↦ rewardByCount p.1 p.2) 𝔓 := by
  have h₁ : iIndepFun (fun p : α × ℕ ↦ rewardByCount p.1 p.2) 𝔓 := by
    -- Use the fact that for each a, the sequences (rewardByCount a n) are iIndepFun
    have h₂ : ∀ (a : α), iIndepFun (fun n : ℕ ↦ rewardByCount a n) 𝔓 := by
      intro a
      have h₃ : iIndepFun (rewardByCount a) 𝔓 := iIndepFun_rewardByCount' alg ν a
      exact h₃
    -- Combine the independence for all a using the product σ-algebra
    have h₃ : iIndepFun (fun p : α × ℕ ↦ rewardByCount p.1 p.2) 𝔓 := by
      -- Use the general fact that if each coordinate is iIndepFun, then the vector is iIndepFun
      have h₄ : Pairwise (fun (a₁ a₂ : α) ↦ iIndepFun (fun n ↦ rewardByCount a₁ n) 𝔓 ⊓ iIndepFun (fun n ↦ rewardByCount a₂ n) 𝔓) := by
        intro a₁ a₂
        exact ⟨by simp, by simp⟩
      -- Use the product of independent sequences to get independence in the product σ-algebra
      convert iIndepFun_pi_iff.mpr (fun a ↦ h₂ a) using 1
      <;> ext p
      <;> simp [Prod.fst, Prod.snd]
    exact h₃
  exact h₁
