theorem WNot42_theorem (n : ℕ) (hn : n ≥ 2) :
    ∀ (a b : ℕ), a ≤ n → b ≤ n → a ≥ 2 ∧ b ≥ 2 → Nat.div (Nat.pow a b) 2 ≥ 4 := by
  intro a b ha hb hab
  have h₁ : a ≥ 2 := hab.1
  have h₂ : b ≥ 2 := hab.2
  have h₃ : a ≤ n := ha
  have h₄ : b ≤ n := hb
  have h₅ : a ^ b ≥ 4 := by
    have h₅₁ : a ≥ 2 := h₁
    have h₅₂ : b ≥ 2 := h₂
    have h₅₃ : a ^ b ≥ 2 ^ b := by
      exact Nat.pow_le_pow_of_le_left h₅₁ b
    have h₅₄ : 2 ^ b ≥ 4 := by
      have h₅₄₁ : b ≥ 2 := h₂
      have h₅₄₂ : 2 ^ b ≥ 2 ^ 2 := by
        exact Nat.pow_le_pow_of_le_right (by decide) h₅₄₁
      norm_num at h₅₄₂ ⊢
      <;> linarith
    linarith
  have h₆ : a ^ b / 2 ≥ 4 := by
    have h₆₁ : a ^ b ≥ 8 := by
      by_contra h₆₁
      have h₆₂ : a ^ b < 8 := by
        omega
      have h₆₃ : a = 2 ∧ b = 2 := by
        have h₆₃₁ : a ^ b < 8 := h₆₂
        have h₆₃₂ : a ≥ 2 := h₁
        have h₆₃₃ : b ≥ 2 := h₂
        have h₆₃₄ : a ≤ n := ha
        have h₆₃₅ : b ≤ n := hb
        have h₆₃₆ : a = 2 := by
          by_contra h₆₃₆
          have h₆₃₇ : a ≥ 3 := by
            omega
          have h₆₃₈ : a ^ b ≥ 3 ^ b := by
            exact Nat.pow_le_pow_of_le_left h₆₃₇ b
          have h₆₃₉ : 3 ^ b ≥ 3 ^ 2 := by
            exact Nat.pow_le_pow_of_le_right (by norm_num) (by omega)
          have h₆₄₀ : 3 ^ 2 = 9 := by norm_num
          have h₆₄₁ : a ^ b ≥ 9 := by
            omega
          omega
        have h₆₃₁₀ : b = 2 := by
          by_contra h₆₃₁₀
          have h₆₃₁₁ : b ≥ 3 := by
            omega
          have h₆₃₁₂ : a ^ b ≥ 2 ^ b := by
            exact Nat.pow_le_pow_of_le_left (by omega) b
          have h₆₃₁₃ : 2 ^ b ≥ 2 ^ 3 := by
            exact Nat.pow_le_pow_of_le_right (by norm_num) (by omega)
          have h₆₃₁₄ : 2 ^ 3 = 8 := by norm_num
          have h₆₃₁₅ : a ^ b ≥ 8 := by
            omega
          omega
        exact ⟨h₆₃₆, h₆₃₁₀⟩
      have h₆₄ : a = 2 := h₆₃.1
      have h₆₅ : b = 2 := h₆₃.2
      have h₆₆ : a ^ b = 4 := by
        rw [h₆₄, h₆₅]
        <;> norm_num
      omega
    have h₆₂ : a ^ b / 2 ≥ 4 := by
      have h₆₃ : a ^ b ≥ 8 := h₆₁
      have h₆₄ : a ^ b / 2 ≥ 4 := by
        omega
      exact h₆₄
    exact h₆₂
  exact h₆
