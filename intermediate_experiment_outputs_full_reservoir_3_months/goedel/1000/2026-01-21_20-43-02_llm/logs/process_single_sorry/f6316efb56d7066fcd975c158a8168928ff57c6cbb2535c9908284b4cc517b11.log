  have h : (some q : ENNReal) ‚Č† 0 := hpqr.1.2.1
  by_contra hq
  -- If q = 0, then (some q : ENNReal) = 0, contradicting h.
  simp [hq] at h
  <;> simp_all [ENNReal.some_eq_zero]
```

