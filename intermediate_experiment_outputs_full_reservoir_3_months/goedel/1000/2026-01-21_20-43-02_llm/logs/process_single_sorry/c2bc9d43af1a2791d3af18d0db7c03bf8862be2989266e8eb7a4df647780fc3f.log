instance : AddMonoidWithOne EmptySemiring :=
  toAddMonoidWithOne (inferInstance : AddMonoidWithOne (EmptySemiring := Empty))

def add_zero : ∀ (a : EmptySemiring), a + 0 = a := by
  intro a
  have h : False := by
    cases a
  contradiction

def add_assoc : ∀ (a b c : EmptySemiring), a + b + c = a + (b + c) := by
  intro a b c
  have h : False := by
    cases a
  contradiction

def zero_add : ∀ (a : EmptySemiring), 0 + a = a := by
  intro a
  have h : False := by
    cases a
  contradiction

def mul_zero : ∀ (a : EmptySemiring), a * 0 = 0 := by
  intro a
  have h : False := by
    cases a
  contradiction

def zero_mul : ∀ (a : EmptySemiring), 0 * a = 0 := by
  intro a
  have h : False := by
    cases a
  contradiction

def mul_one : ∀ (a : EmptySemiring), a * 1 = a := by
  intro a
  have h : False := by
    cases a
  contradiction

def one_mul : ∀ (a : EmptySemiring), 1 * a = a := by
  intro a
  have h : False := by
    cases a
  contradiction

def mul_assoc : ∀ (a b c : EmptySemiring), a * b * c = a * (b * c) := by
  intro a b c
  have h : False := by
    cases a
  contradiction

def add_mul : ∀ (a b c : EmptySemiring), a * (b + c) = a * b + a * c := by
  intro a b c
  have h : False := by
    cases a
  contradiction

