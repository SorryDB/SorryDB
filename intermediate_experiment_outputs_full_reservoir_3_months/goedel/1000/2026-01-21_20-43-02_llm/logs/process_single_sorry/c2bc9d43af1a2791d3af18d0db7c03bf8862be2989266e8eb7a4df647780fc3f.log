instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      haveI : ValuativeRel K := ‹_›
      haveI : ValuativeRel L := ‹_›
      haveI : Algebra K L := ‹_›
      haveI : ValuativeExtension K L := ‹_›
      obtain ⟨r, hr⟩ := r
      have h₁ : valuation L (algebraMap K L r) = valuation K r := by
        apply ValuativeExtension.valuation_map_eq
      have h₂ : valuation K r ≥ 0 := by
        exact hr
      have h₃ : valuation L (algebraMap K L r) ≥ 0 := by
        rw [h₁]
        exact_mod_cast h₂
      rw [Valuation.mem_integer_iff]
      <;> simp_all [h₃]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try exact le_of_lt (by
        norm_num at h₃ ⊢ <;>
        linarith))⟩
    map_add' := by
      intro x y
      simp [Subtype.ext_iff]
      <;>
      (try ring_nf) <;>
      (try simp_all [Algebra.algebraMap_add]) <;>
      (try norm_cast) <;>
      (try aesop)
    map_mul' := by
      intro x y
      simp [Subtype.ext_iff]
      <;>
      (try ring_nf) <;>
      (try simp_all [Algebra.algebraMap_mul]) <;>
      (try norm_cast) <;>
      (try aesop)
    map_one' := by
      simp [Subtype.ext_iff]
      <;>
      (try simp_all [Algebra.algebraMap_one]) <;>
      (try norm_cast) <;>
      (try aesop)
  }
