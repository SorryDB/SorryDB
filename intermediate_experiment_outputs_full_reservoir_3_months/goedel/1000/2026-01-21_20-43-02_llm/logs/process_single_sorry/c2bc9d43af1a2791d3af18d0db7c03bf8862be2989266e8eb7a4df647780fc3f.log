have h_main : ∀ (x y : ↥(valuation K).integer), ⟨(algebraMap K L) ↑(x + y), _⟩ = ⟨(algebraMap K L) ↑x, _⟩ + ⟨(algebraMap K L) ↑y, _⟩ := by
  intro x y
  -- Use the properties of the algebra map and the valuation to show that the algebra map preserves addition.
  have h₁ : algebraMap K L ↑(x + y) = algebraMap K L ↑x + algebraMap K L ↑y := by
    -- Since the algebra map is a ring homomorphism, it preserves addition.
    have h₂ : ringHomClass.algebraMap _ _ L = ringHomClass.algebraMap _ _ L := rfl
    have h₃ : algebraMap K L ↑(x + y) = algebraMap K L (↑x + ↑y) := by
      simp [Subtype.val_add]
    rw [h₃]
    -- Use the fact that the algebra map is a ring homomorphism to distribute over addition.
    have h₄ : algebraMap K L (↑x + ↑y) = algebraMap K L ↑x + algebraMap K L ↑y := by
      apply ring_hom.map_add
    rw [h₄]
  -- Use the fact that the algebra map is a ring homomorphism to show that the subtype respects addition.
  ext <;> simp_all [Subtype.ext_iff]
  <;>
  (try norm_num) <;>
  (try ring_nf at *) <;>
  (try simp_all [Subtype.ext_iff]) <;>
  (try norm_num) <;>
  (try ring_nf) <;>
  (try simp_all [Subtype.ext_iff]) <;>
  (try norm_num) <;>
  (try linarith)
  <;>
  aesop
