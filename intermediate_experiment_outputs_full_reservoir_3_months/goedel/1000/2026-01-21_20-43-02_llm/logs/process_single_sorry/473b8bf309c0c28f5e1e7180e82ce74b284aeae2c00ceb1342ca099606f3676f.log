          calc
            (∑ i : α, (f i) * (g i) : ℝ) ≤ ∑ i : α, ‖(f i : ℝ) * (g i : ℝ)‖ := by
              -- Use the fact that the sum of the absolute values is greater than or equal to the sum of the products
