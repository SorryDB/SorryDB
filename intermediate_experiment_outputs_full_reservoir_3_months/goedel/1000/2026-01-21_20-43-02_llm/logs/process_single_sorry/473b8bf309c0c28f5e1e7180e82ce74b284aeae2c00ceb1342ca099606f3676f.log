                exact by
                  calc
                    ((f i : ℝ) * (g i : ℝ)) ≤ ‖(f i : ℝ) * (g i : ℝ)‖ := by
                      -- The product is less than or equal to its absolute value
                      exact le_abs_self _
                    _ = ‖(f i : ℝ) * (g i : ℝ)‖ := by rfl
            _ = ∑ i : α, ‖(f i : ℝ)‖ * ‖(g i : ℝ)‖ := by
              -- Use the property of norms for products
