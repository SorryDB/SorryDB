  have h₃ : (1 : ℝ) ≤ (A.qChoose + A.qRespond : ℝ) * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) ∨ (A.qChoose + A.qRespond : ℝ) * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) = 0 := by
    by_cases h : (Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y)) = 0
