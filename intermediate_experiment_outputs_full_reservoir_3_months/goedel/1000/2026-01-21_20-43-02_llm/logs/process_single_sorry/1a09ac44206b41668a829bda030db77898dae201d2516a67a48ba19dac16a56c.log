    ([= () | TCRGameROM (w:=w) (v:=v) (M:=M) (R:=R) (X:=X) ψ A]).toReal ≤
      (t : Real) * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) := by
  intro t
  simp only [t]
  -- Since the probability of winning the TCR game is always less than or equal to 1
  -- and the sum of squares of μhat is non-negative, we can directly use these facts.
  have h₁ : ([= () | TCRGameROM (w:=w) (v:=v) (M:=M) (R:=R) (X:=X) ψ A]).toReal ≤ 1 := by
    norm_num [ProbabilityTheory.Probability]
