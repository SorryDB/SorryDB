        have h₈ : (A.qChoose + A.qRespond : ℝ) * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) ≥ 1 * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) := by
          have h₉ : (A.qChoose + A.qRespond : ℝ) ≥ 1 := by assumption_mod_cast
          nlinarith
        have h₉ : 1 * ((Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y))) = (Finset.univ : Finset (HcV w v)).sum (fun y => (μhat y) * (μhat y)) := by ring
