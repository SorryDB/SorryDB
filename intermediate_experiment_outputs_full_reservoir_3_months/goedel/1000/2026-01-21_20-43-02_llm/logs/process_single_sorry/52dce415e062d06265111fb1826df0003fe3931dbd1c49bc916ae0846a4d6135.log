  have h₁ : ∃ (WS : Finset (Finset Formula)) (mg : ModelGraph WS), ∃ Z ∈ WS, X.toFinset ⊆ Z := by
    classical
    -- Use the root state to show that X is in the set of formulas
    use {X.toFinset}
    use {
      val := fun (w : Finset Formula) (p : Prop) => p ∈ w
      Rel := fun (a : PMAA) (w₁ w₂ : Finset Formula) => ∃ (φ : Formula), (⌈a⌉φ : Formula) ∈ w₁ ∧ (projection a (w₁.toList)).toFinset ⊆ w₂
      wellF := fun a w₁ w₂ hw => by
        aesop
      isInv := by
        intro a w₁ w₂
        simp [Rel]
        <;>
        (try decide) <;>
        (try aesop) <;>
        (try simp_all [projection, List.bind, List.mem_map]) <;>
        (try tauto) <;>
