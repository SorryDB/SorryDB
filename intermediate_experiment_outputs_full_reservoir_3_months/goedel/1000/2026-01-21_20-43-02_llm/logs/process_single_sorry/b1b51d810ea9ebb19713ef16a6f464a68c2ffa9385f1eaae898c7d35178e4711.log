```lean
theorem length_lt_of_cons_split {α : Type} (xs ys zs : List α)
  (h : (ys, zs) ∈ splits xs) : zs.length < xs.length := by
  induction xs generalizing ys zs with
  | nil =>
    simp [splits] at h
  | cons x xs ih =>
    simp only [splits, List.mem_cons, List.mem_map] at h
    cases h with
    | inl h' =>
      simp at h'
      cases h'; simp_all [List.length]
      <;> omega
    | inr h'' =>
      rcases h'' with ⟨⟨ys', zs'⟩, hin, heq⟩
      have h₁ : (ys', zs') ∈ splits xs := hin
      have h₂ : (x :: ys', zs') = (ys, zs) := by simpa using heq
      have h₃ : ys = x :: ys' := by
        simp [Prod.ext_iff] at h₂
        tauto
      have h₄ : zs = zs' := by
        simp [Prod.ext_iff] at h₂
        tauto
      have h₅ : zs'.length < xs.length := by
        have h₅₁ : (ys', zs') ∈ splits xs := hin
        have h₅₂ : zs'.length < xs.length := ih ys' zs' h₅₁
        exact h₅₂
      have h₆ : zs.length < (x :: xs).length := by
        rw [h₄]
        have h₆₁ : zs'.length < xs.length := h₅
        have h₆₂ : xs.length < (x :: xs).length := by
          simp [List.length]
          <;> omega
        omega
      simpa [List.length] using h₆
```

