```lean
namespace Option

inductive IsSome : Option α → Prop where
  | of_some : ∀ {a : α}, IsSome (some a)

inductive _root_.Sum.IsRight {β : Type _} : α ⊕ β → Prop where
  | of_right : ∀ {b : β}, IsRight (.inr b)

/-- A none is not a some -/
theorem neg_is_some_none : ¬IsSome (α := α) none := by
  intro h
  -- We use the fact that the only way to construct an IsSome is to have a 'some' value
  -- Since none is not a some value, we derive a contradiction
  cases h
  <;> simp_all
  <;> aesop
