lemma Example_17 (U V : Type) (A : Set U) (f : A → V) (v : V) :
    func_restrict (func_extend f v) A = f := by
  have h_main : ∀ (x : A), (func_restrict (func_extend f v) A) x = f x := by
    intro x
    have h₁ : x.val ∈ A := x.prop
    have h₂ : (func_extend f v) x.val = f x := by
      have h₃ : x.val ∈ A := h₁
      have h₄ : (func_extend f v) x.val = (if h : x.val ∈ A then f ⟨x.val, h⟩ else v) := rfl
      rw [h₄]
      have h₅ : (if h : x.val ∈ A then f ⟨x.val, h⟩ else v) = f ⟨x.val, h₃⟩ := by
        simp [h₃]
      rw [h₅]
      have h₆ : ⟨x.val, h₃⟩ = x := by
        cases x with
        | mk val prop =>
          simp_all [Subtype.mk.injEq]
          <;> aesop
      rw [h₆]
    have h₃ : (func_restrict (func_extend f v) A) x = (func_extend f v) x.val := rfl
    rw [h₃]
    rw [h₂]
  
  have h_final : func_restrict (func_extend f v) A = f := by
    funext x
    apply h_main
  
  apply h_final
