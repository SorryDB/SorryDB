lemma equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · intro h
    obtain ⟨e⟩ := h
    refine' ⟨e, e.symm, _, _⟩
    · -- Prove that e ∘ e.symm = id
      ext x
      simp [Equiv.symm_apply_apply]
    · -- Prove that e.symm ∘ e = id
      ext x
      simp [Equiv.apply_symm_apply]
  · rintro ⟨f, g, hfg, hgf⟩
    refine' ⟨Equiv.ofBijective f ⟨_, _⟩⟩
    · -- Prove that f is injective
      intro a b h
      have h₁ : g (f a) = g (f b) := by rw [h]
      have h₂ : (g ∘ f) a = (g ∘ f) b := by simpa using h₁
      have h₃ : (g ∘ f) a = a := by simp [hgf]
      have h₄ : (g ∘ f) b = b := by simp [hgf]
      simp_all
    · -- Prove that f is surjective
      intro b
      have h₁ : (f ∘ g) b = b := by simp [hfg]
      have h₂ : f (g b) = b := by simpa using h₁
      exact ⟨g b, by simp [h₂]⟩

lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext s
  have h₁ : (image g) (image f s) = s := by
    apply Set.Subset.antisymm
    · -- Prove that (image g) (image f s) ⊆ s
      intro x hx
      simp only [Set.mem_image, Set.mem_image] at hx ⊢
      obtain ⟨y, hy, rfl⟩ := hx
      obtain ⟨z, hz, hy'⟩ := hy
      have h₂ : g (f z) = z := by
        have h₃ : (g ∘ f) z = z := by
          have h₄ : (g ∘ f) = id := h
          simp [h₄]
        simpa using h₃
      simp_all
      <;> aesop
    · -- Prove that s ⊆ (image g) (image f s)
      intro x hx
      simp only [Set.mem_image, Set.mem_image]
      have h₂ : x ∈ s := hx
      have h₃ : f x ∈ Set.univ := Set.mem_univ _
      have h₄ : g (f x) = x := by
        have h₅ : (g ∘ f) x = x := by
          have h₆ : (g ∘ f) = id := h
          simp [h₆]
        simpa using h₅
      refine' ⟨f x, Set.mem_univ _, _⟩
      refine' ⟨x, h₂, _⟩
      simp [h₄]
  simp_all [Function.comp_apply]
  <;>
  aesop

