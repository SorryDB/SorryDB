theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  have h1 : U ∼ V := h
  have h2 : Set U ∼ Set V := by
    -- Establish a bijection between the powersets using the bijection between U and V
    have h3 : U ≃ V := by exact h.equiv
    -- Use the fact that the powerset of a type is equivalent to the set of all subsets of that type
    have h4 : Set U ≃ Set V := by
      -- Define the equivalence between Set U and Set V using the bijection between U and V
      classical
      exact Set.Equiv.ofBijective (fun (s : Set U) => Set.image h3 s)
        (by
          constructor
          -- Prove that the function is injective
          · intro s t hst
            have h5 : Set.image h3 s = Set.image h3 t := hst
            have h6 : s = t := by
              apply Set.ext
              intro x
              have h7 : x ∈ s ↔ x ∈ t := by
                constructor
                · intro hx
                  have h8 : h3 x ∈ Set.image h3 s := by
                    exact Set.mem_image_of_mem h3 hx
                  have h9 : h3 x ∈ Set.image h3 t := by
                    rw [h5] at h8
                    exact h8
                  have h10 : ∃ (y : U), h3 y = h3 x ∧ y ∈ t := by
                    simpa [Set.mem_image] using h9
                  obtain ⟨y, hy1, hy2⟩ := h10
                  have h11 : y = x := by
                    have h12 : h3 y = h3 x := hy1
                    have h13 : y = x := by
                      apply h3.injective
                      exact h12
                    exact h13
                  rw [h11] at hy2
                  exact hy2
                · intro hx
                  have h8 : h3 x ∈ Set.image h3 t := by
                    exact Set.mem_image_of_mem h3 hx
                  have h9 : h3 x ∈ Set.image h3 s := by
                    rw [h5] at *
                    exact h8
                  have h10 : ∃ (y : U), h3 y = h3 x ∧ y ∈ s := by
                    simpa [Set.mem_image] using h9
                  obtain ⟨y, hy1, hy2⟩ := h10
                  have h11 : y = x := by
                    have h12 : h3 y = h3 x := hy1
                    have h13 : y = x := by
                      apply h3.injective
                      exact h12
                    exact h13
                  rw [h11] at hy2
                  exact hy2
              exact h7
            exact h6
          -- Prove that the function is surjective
          · intro t
            use Set.preimage h3 t
            have h5 : Set.image h3 (Set.preimage h3 t) = t := by
              apply Set.ext
              intro y
              simp [Set.mem_image, Set.mem_preimage]
              <;>
              (try { aesop }) <;>
              (try {
                constructor <;> intro h6 <;>
                (try { aesop }) <;>
                (try {
                  obtain ⟨x, hx1, hx2⟩ := h6
