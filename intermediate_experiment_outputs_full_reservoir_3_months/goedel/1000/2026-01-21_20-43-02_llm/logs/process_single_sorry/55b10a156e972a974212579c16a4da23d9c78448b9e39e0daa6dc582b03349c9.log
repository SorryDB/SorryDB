theorem wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
  have h : i = j ∨ i < j ∨ j < i := by
    by_cases h_eq : i = j
    · exact Or.inl h_eq
    · -- If i ≠ j, then either i < j or j < i
      have h_lt : i < j ∨ j < i := by
        cases' lt_or_gt_of_ne h_eq with h_lt h_lt
        · exact Or.inl h_lt
        · exact Or.inr h_lt
      cases' h_lt with h_lt h_lt
      · exact Or.inr (Or.inl h_lt)
      · exact Or.inr (Or.inr h_lt)
  rcases h with (h | h | h)
  · -- Case i = j
    simp [h]
    <;>
    (try cases i <;> simp_all [Fin.ext_iff]) <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try aesop)
  · -- Case i < j
    have h1 : ¬(j < i) := by
      intro h'
      have h2 := lt_asymm h h'
      exact h2
    have h2 : j ≠ i := by
      intro h'
      have h3 := lt_irrefl i
      have h4 : i < j := h
      have h5 : j < i := by
        simp_all [lt_iff_le_and_ne]
      exact absurd (lt_trans h4 h5) (lt_irrefl i)
    simp [h, h1, h2]
    <;>
    (try cases i <;> cases j <;> simp_all [Fin.ext_iff, Fin.val_succ]) <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try omega) <;>
    (try aesop)
  · -- Case j < i
    have h1 : ¬(i < j) := by
      intro h'
      have h2 := lt_asymm h h'
      exact h2
    have h2 : i ≠ j := by
      intro h'
      have h3 := lt_irrefl i
      have h4 : j < i := h
      have h5 : i < j := by
        simp_all [lt_iff_le_and_ne]
      exact absurd (lt_trans h5 h4) (lt_irrefl i)
    simp [h, h1, h2]
