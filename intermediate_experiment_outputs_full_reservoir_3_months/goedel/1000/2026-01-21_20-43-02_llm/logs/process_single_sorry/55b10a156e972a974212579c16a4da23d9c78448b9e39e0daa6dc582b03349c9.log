lemma wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
  split_ifs <;>
    (try { contradiction }) <;>
    (try { simp_all [Fin.ext_iff, Prod.ext_iff] <;>
      (try {
        have h₁ : i = j := by omega
        simp_all
      }) <;>
      (try {
        have h₁ : j < i := by omega
        simp_all
      }) <;>
      (try {
        have h₁ : i < j := by omega
        simp_all
      }) <;>
      (try {
        simp_all [wignerMatrixEntryFunction]
        <;>
        try omega
      })
    }) <;>
    (try {
      have h₁ : i = j := by omega
      simp_all
    }) <;>
    (try {
      have h₁ : i < j := by omega
      simp_all
      <;>
      try {
        simp_all [wignerMatrixEntryFunction]
        <;>
        try omega
      }
    }) <;>
    (try {
      have h₁ : j < i := by omega
      simp_all
      <;>
      try {
        simp_all [wignerMatrixEntryFunction]
        <;>
        try omega
      }
    }) <;>
    (try {
      simp_all [wignerMatrixEntryFunction]
      <;>
      try omega
    })
  <;>
  try {
    exfalso
    omega
  }
