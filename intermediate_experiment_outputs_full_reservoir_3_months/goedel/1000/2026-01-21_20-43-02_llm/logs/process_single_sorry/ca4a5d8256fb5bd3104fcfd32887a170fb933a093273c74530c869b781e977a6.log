      "\n  have h₀ : (n : ℝ) ≥ 2 := by\n    norm_cast\n    <;> omega\n  have h₁ : (n : ℝ) ^ (n : ℕ) > 0 := by positivity\n  -- Using the inequality n! > (n / e)^n\n  have h₂ : (n.factorial : ℝ) > (n : ℝ) / e ^ (n : ℕ) * (n : ℝ) ^ (n : ℕ) := by\n    -- Use Stirling's approximation and properties of the factorial\n    have h₃ : (n.factorial : ℝ) > (n : ℝ) / e ^ (n : ℕ) * (n : ℝ) ^ (n : ℕ) := by\n      -- Use the fact that n! > (n / e)^n\n      have h₄ : Real.log ((n.factorial : ℝ)) > (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) := by\n        -- Use the inequality for the logarithm of the factorial\n        have h₅ : Real.log ((n.factorial : ℝ)) = Real.log (∏ k in Finset.range n, (k + 1 : ℝ)) := by\n          simp [Nat.factorial_succ, Finset.prod_range_succ]\n          <;> field_simp [Real.log_mul, Real.log_pow]\n          <;> ring_nf\n          <;> simp_all [Real.log_mul, Real.log_pow]\n          <;> field_simp [Real.log_mul, Real.log_pow]\n          <;> linarith\n        rw [h₅]\n        have h₆ : Real.log (∏ k in Finset.range n, (k + 1 : ℝ)) = ∑ k in Finset.range n, Real.log ((k + 1 : ℝ)) := by\n          rw [Real.log_prod _ _ fun k _ => by positivity]\n        rw [h₆]\n        have h₇ : ∑ k in Finset.range n, Real.log ((k + 1 : ℝ)) > (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) := by\n          have h₈ : ∀ (k : ℕ), k ∈ Finset.range n → Real.log ((k + 1 : ℝ)) ≥ Real.log ((k + 1 : ℝ)) := by\n            intro k _\n            linarith\n          have h₉ : ∑ k in Finset.range n, Real.log ((k + 1 : ℝ)) > (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) := by\n            -- Use the fact that the sum of logarithms is greater than the integral\n            have h₁₀ : ∑ k in Finset.range n, Real.log ((k + 1 : ℝ)) ≥ ∑ k in Finset.range n, (Real.log ((k + 1 : ℝ))) := by\n              simp\n            have h₁₁ : ∑ k in Finset.range n, (Real.log ((k + 1 : ℝ))) > (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) := by\n              -- Use the integral test for the sum of logarithms\n              have h₁₂ : ∑ k i