      "\n  have h : (n : ℝ) ≥ 2 := by norm_num at hn ⊢ <;> norm_cast <;> omega\n  have h₁ : Real.log (n!) > Real.log (e * (n / e) ^ n) := by\n    have h₂ : Real.log (n!) > Real.log (e * (n / e) ^ n) := by\n      have h₃ : Real.log (n!) > n * (Real.log n - 1) + 1 := by\n        have h₄ : ∀ (n : ℕ), 1 < n → Real.log (n!) > n * (Real.log n - 1) + 1 := by\n          intro n hn\n          have h₆ : (n : ℝ) ≥ 2 := by norm_num at hn ⊢ <;> norm_cast <;> omega\n          -- Use the fact that the logarithm of the factorial can be bounded below by the integral of log(x)\n          have h₇ : Real.log (n!) ≥ (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) + 1 := by\n            have h₈ : ∀ (n : ℕ), 1 < n → Real.log (n!) ≥ (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) + 1 := by\n              intro n hn\n              induction' hn with n hn IH\n              · norm_num [Nat.factorial_succ, Real.log_mul, Real.log_pow]\n              · cases n with\n                | zero => contradiction\n                | succ n =>\n                  cases n with\n                  | zero => contradiction\n                  | succ n =>\n                    simp_all [Nat.factorial_succ, Real.log_mul, Real.log_pow]\n                    <;>\n                    (try norm_num) <;>\n                    (try linarith) <;>\n                    (try\n                      {\n                        nlinarith [Real.log_pos (by norm_num : (1 : ℝ) < 2),\n                          Real.log_le_sub_one_of_pos (by positivity : (0 : ℝ) < (n.succ + 1 : ℝ))]\n                      }) <;>\n                    (try\n                      {\n                        nlinarith [Real.log_pos (by norm_num : (1 : ℝ) < 2),\n                          Real.log_le_sub_one_of_pos (by positivity : (0 : ℝ) < (n.succ + 1 : ℝ))]\n                      }) <;>\n                    (try\n                      {\n                        nlinarith [Real.log_pos (by norm_num : (1 : ℝ) < 2),\n                          Real.log_le_sub_one_of_pos (by positivity : (0 : ℝ) < (n.succ + 1 : ℝ))]\n                      })\n            exact h₈ n hn\n          -- Use the inequality to prove the desired result\n          have h₉ : Real.log (n!) > n * (Real.log n - 1) + 1 := by\n            have h₁₀ : (n : ℝ) ≥ 2 := by norm_num at hn ⊢ <;> norm_cast <;> omega\n            have h₁₁ : Real.log (n!) ≥ (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) + 1 := by\n              exact h₇\n            have h₁₂ : (n : ℝ) * Real.log (n : ℝ) - (n : ℝ) + 1 > (n : ℝ) * (Real.log (n : ℝ) - 1) + 1 := by\n              have h₁₃ : (n : ℝ) > 0 := by positivity\n              nlinarith\n            linarith\n          exact h₉\n        exact h₄ n hn\n      have h₅ : Real.log (e * (n / e) ^ n) = n * (Real.log n - 1) + 1 := by\n        have h₆ : Real.log (e * (n / e) ^ n) = Real.log e + Real.log ((n / e : ℝ) ^ n) := by\n          have h₇ : e > 0 := by positivity\n          have h₈ : (n / e : ℝ) > 0 := by positivity\n          have h₉ : Real.log (e * (n / e) ^ n) = Real.log e + Real.log ((n / e : ℝ) ^ n) := by\n            rw [Real.log_mul (by positivity) (by\n              have h₁₀ : (n : ℝ) > 0 := by positivity\n              positivity)]\n          exact h₉\n        rw [h₆]\n        have h₇ : Real.log e = 1 := by\n          have h₈ : Real.log e = 1 := by\n            simp [e]\n            <;>\n            norm_num\n          exact h₈\n        rw [h₇]\n        have h₈ : Real.log ((n / e : ℝ) ^ n) = n * Real.log (n / e : ℝ) := by\n          have h₉ : Real.log ((n / e : ℝ) ^ n) = n * Real.log (n / e : ℝ) := by\n            rw [Real.log_pow]\n            <;>\n            field_simp\n            <;>\n            ring_nf\n            <;>\n            norm_num\n            <;>\n            linarith\n          exact h₉\n        rw [h₈]\n        have h₉ : Real.log (n / e : ℝ) = Real.log n - 1 := by\n          have h₁₀ : Real.log (n / e : ℝ) = Real.log n - Real.log e := by\n            rw [Real.log_div (by positivity) (by positivity)]\n            <;>\n            sim