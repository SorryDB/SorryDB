    intro hf
    have h₁ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
      -- Use the fact that the integral of r • f is r • integral of f
      have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
        -- Use the boundedness of the scalar multiplication to show integrability
        apply hf.smul_left r
      exact h₂
    exact h₁
  · -- Prove the reverse direction: IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b
    intro hf
    have h₁ : IntervalIntegrable f μ a b := by
      -- Use the fact that the integral of r • f is r • integral of f
