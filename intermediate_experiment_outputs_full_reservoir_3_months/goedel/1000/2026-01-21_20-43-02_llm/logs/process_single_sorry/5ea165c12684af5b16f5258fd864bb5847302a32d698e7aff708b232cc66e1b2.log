    intro hf
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that the integral of a scalar multiple is the scalar multiple of the integral
      have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
        -- Apply the interval integrable property to the scalar multiple
        exact hf.smul_left r
      exact h₂
    exact h₁
  have h₁ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- Use the fact that the scalar multiple is interval integrable to deduce that the original function is interval integrable
    have h₂ : IntervalIntegrable (fun x : ℝ => (r⁻¹ : R) • (r • f x)) μ a b := by
      -- Apply the interval integrable property to the scalar multiple
