lemma ExpLeftInverse (a : ℝ) : Real.exp (Real.log a) = a :=
  by
  -- Use the property that the exponential function is the inverse of the logarithm for positive real numbers
  have h : 0 < a := by
    by_contra h₁
    -- If a is not positive, then it must be less than or equal to 0
    have h₂ : a ≤ 0 := by linarith
    -- The logarithm function is only defined for positive real numbers, so this case is a contradiction
    have h₃ : a = 0 := by
      by_contra h₄
      -- If a is not zero, then it must be negative
      have h₅ : a < 0 := by
        cases' lt_or_gt_of_ne h₄ with h₅ h₅
        · linarith
        · exfalso
          linarith
      -- The logarithm function is not defined for negative real numbers, so this case is a contradiction
      have h₆ : Real.log a = 0 := by
        exfalso
        exact Real.log_neg_eq_log (by linarith) (by linarith)
      -- This leads to a contradiction because the exponential function is always positive
      simp_all [Real.exp_pos]
      <;>
      linarith
    -- If a is zero, the logarithm function is not defined, so this case is a contradiction
    simp_all [Real.exp_pos]
    <;>
    linarith
  -- Use the left inverse property of the exponential and logarithm functions
  rw [Real.exp_log h]
