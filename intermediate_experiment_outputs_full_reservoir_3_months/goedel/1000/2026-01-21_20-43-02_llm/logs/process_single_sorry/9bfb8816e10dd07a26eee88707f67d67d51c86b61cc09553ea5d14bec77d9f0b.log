instance [Nonempty d₁] [Nonempty d₂] : Nonempty (CPTPMap d₁ d₂) := by
  have h₁ : ∃ (x : d₁), True := ⟨Classical.arbitrary d₁, by trivial⟩
  have h₂ : ∃ (y : d₂), True := ⟨Classical.arbitrary d₂, by trivial⟩
  -- Use the existence of elements in d₁ and d₂ to construct a trivial CPTP map
  have h₃ : Nonempty (CPTPMap d₁ d₂ ℂ) := by
    -- Construct the trivial CPTP map using classical.choose
    use CPTPMap.mk fun _ _ ↦ 0
    <;> simp_all [CPTPMap.mk]
    <;>
    (try { classical }) <;>
    (try { exact ⟨Classical.arbitrary _⟩ }) <;>
    (try { aesop })
  -- Use the fact that the trivial CPTP map exists to conclude the proof
  exact h₃
