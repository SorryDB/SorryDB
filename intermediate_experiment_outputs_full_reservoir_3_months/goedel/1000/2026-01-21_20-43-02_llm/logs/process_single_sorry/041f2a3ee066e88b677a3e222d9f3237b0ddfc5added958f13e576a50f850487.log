theorem list_perm_in {l1 l2 : List α} (hPerm : l1.Perm l2) :
  ∀ x, x ∈ l1 → x ∈ l2 := by
  intro x hx
  have h : x ∈ l2 := by
    have h₁ : l1.Perm l2 := hPerm
    have h₂ : x ∈ l1 := hx
    have h₃ : x ∈ l2 := by
      -- Use the fact that if two lists are permutations of each other, they have the same elements.
      have h₄ : ∀ (l : List α), x ∈ l → ∀ (l' : List α), l.Perm l' → x ∈ l' := by
        intro l h₅ l' h₆
        -- Use the property of permutations to show that if x is in l, it is also in l'.
        induction h₆ with
        | nil => contradiction
        | cons a l₁ l₂ ih =>
          simp_all [List.mem_cons]
          <;> aesop
        | swap a b l ih =>
          simp_all [List.mem_cons]
          <;> aesop
        | trans l₁ l₂ l₃ ih₁ ih₂ =>
          simp_all [List.mem_cons]
          <;> aesop
      -- Apply the above property to our case.
      exact h₄ l1 hx l2 hPerm
    exact h₃
  exact h
