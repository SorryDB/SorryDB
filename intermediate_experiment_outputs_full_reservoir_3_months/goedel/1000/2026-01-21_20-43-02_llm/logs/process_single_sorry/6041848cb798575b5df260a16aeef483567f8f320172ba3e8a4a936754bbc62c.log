theorem bayesTheorem (hB : ℙ B ≠ 0) : ℙ(A|B) = ℙ A * ℙ(B|A) / ℙ B := by
  by_cases h : ℙ A = 0
  · -- Case: ℙ A = 0
    have h₁ : ℙ(A|B) = 0 := by
      -- Since ℙ A = 0, ℙ (A ∩ B) = 0, so ℙ(A|B) = 0
      have h₂ : ℙ (A ∩ B) = 0 := by
        calc
          ℙ (A ∩ B) ≤ ℙ A := by
            -- The measure of the intersection is less than or equal to the measure of A
            apply measure_mono (Set.inter_subset_left)
          _ = 0 := by rw [h]
      -- Using the definition of conditional probability
      simp_all [condProb, div_eq_mul_inv]
      <;> simp_all [ENNReal.mul_eq_zero]
      <;> simp_all [ENNReal.ext_iff]
      <;> norm_num
      <;> aesop
    have h₂ : ℙ A * ℙ(B|A) / ℙ B = 0 := by
      -- Since ℙ A = 0, the product ℙ A * ℙ(B|A) = 0
      calc
        ℙ A * ℙ(B|A) / ℙ B = 0 * ℙ(B|A) / ℙ B := by rw [h]
        _ = 0 := by
          simp [div_eq_mul_inv, mul_assoc]
          <;>
          (try simp_all [ENNReal.mul_eq_zero]) <;>
          (try simp_all [ENNReal.ext_iff]) <;>
          (try norm_num) <;>
          (try aesop)
    -- Combining the two results
    simp_all [h₁, h₂]
  · -- Case: ℙ A ≠ 0
    sorry
