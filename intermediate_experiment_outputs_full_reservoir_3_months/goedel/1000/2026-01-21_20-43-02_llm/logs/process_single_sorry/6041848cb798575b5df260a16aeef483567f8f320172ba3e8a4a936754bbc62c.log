theorem bayesTheorem (hB : ℙ B ≠ 0) : ℙ(A|B) = ℙ A * ℙ(B|A) / ℙ B := by
  by_cases h : ℙ A = 0 -- this tactic perfoms a case disjunction.
  -- Observe the goals that are created, and specifically the `h` assumption in both goals
  · have h₁ : ℙ (A ∩ B) = 0 := by
      have h₂ : ℙ (A ∩ B) ≤ ℙ A := by
        apply measure_mono
        exact Set.inter_subset_left
      have h₃ : ℙ A = 0 := h
      calc
        ℙ (A ∩ B) ≤ ℙ A := h₂
        _ = 0 := h₃
        _ ≤ 0 := le_refl 0
      have h₄ : ℙ (A ∩ B) = 0 := by
        exact le_antisymm h₂ (by simp [h₃])
      exact h₄
    have h₂ : ℙ (A | B) = 0 := by
      simp [condProb, h₁]
      <;>
      (try simp_all) <;>
      (try norm_num) <;>
      (try field_simp [hB]) <;>
      (try simp_all)
    have h₃ : ℙ A * ℙ (B | A) / ℙ B = 0 := by
      have h₄ : ℙ A = 0 := h
      rw [h₄]
      simp [condProb]
      <;>
      (try simp_all) <;>
      (try norm_num) <;>
      (try field_simp [hB]) <;>
      (try simp_all)
    rw [h₂, h₃]
