lemma IndepSet.symm : IndepSet A B → IndepSet B A := by
  intro h
  have h₁ : ℙ (A ∩ B) = ℙ A * ℙ B := h
  have h₂ : ℙ (B ∩ A) = ℙ A * ℙ B := by
    have h₃ : B ∩ A = A ∩ B := by
      apply Set.ext
      intro x
      simp [Set.mem_inter_iff]
      <;> tauto
    rw [h₃]
    <;> linarith
  -- Since B ∩ A = A ∩ B, we have ℙ (B ∩ A) = ℙ (A ∩ B) = ℙ A * ℙ B
  -- But we need to show ℙ (B ∩ A) = ℙ B * ℙ A
  -- Since multiplication in ℝ≥0∞ is commutative, ℙ A * ℙ B = ℙ B * ℙ A
  -- Therefore, ℙ (B ∩ A) = ℙ B * ℙ A
  have h₃ : IndepSet B A := by
    have h₄ : ℙ (B ∩ A) = ℙ B * ℙ A := by
      calc
        ℙ (B ∩ A) = ℙ A * ℙ B := h₂
        _ = ℙ B * ℙ A := by
          simp [mul_comm]
          <;>
          simp_all [IndepSet, mul_comm]
          <;>
          aesop
    simpa [Set.inter_comm B A] using h₄
  exact h₃
