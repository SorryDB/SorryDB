      have h₅ : ℙ (A ∩ B) = 0 := by
        have h₆ : (0 : ENNReal) ≤ ℙ (A ∩ B) := by positivity
        have h₇ : ℙ (A ∩ B) ≤ (0 : ENNReal) := by simpa using h₄
        -- In ENNReal, if x ≤ 0 then x = 0 because 0 is the smallest element.
