      "\n  have h₁ : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by\n    classical\n    use List.map (fun _ => 0) a\n    constructor\n    · simp\n    constructor\n    · intro a' b' h\n      have h₂ := h\n      simp [List.mem_zip] at h₂\n      <;> simp_all [Batteries.AssocList.contains]\n      <;>\n      (try contradiction) <;>\n      (try simp_all [List.mem_map]) <;>\n      (try aesop)\n    · simp [List.nodup_map]\n      <;>\n      (try aesop)\n  exact h₁",
