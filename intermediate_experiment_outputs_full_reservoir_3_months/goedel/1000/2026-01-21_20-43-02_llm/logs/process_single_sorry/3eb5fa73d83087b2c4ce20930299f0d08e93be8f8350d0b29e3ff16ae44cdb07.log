def ExprLow.well_formed_wrt {α} (ε : Env String (String × α)) : ExprLow String (String × α) → Prop
| product e1 e2 =>
  e1.well_formed_wrt ε ∧ e2.well_formed_wrt ε
| connect c e => e.well_formed_wrt ε
| base inst t => ε.well_formed' t

