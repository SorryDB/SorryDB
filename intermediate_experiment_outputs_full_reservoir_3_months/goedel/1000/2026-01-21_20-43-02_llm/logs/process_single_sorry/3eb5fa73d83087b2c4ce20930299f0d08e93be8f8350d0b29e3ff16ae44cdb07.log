theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  have h : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
    use List.replicate a.length "new"
    constructor
    · simp [List.length_replicate]
    constructor
    · intro a' b' h₁
      have h₂ : (a', b') ∈ a.zip (List.replicate a.length "new") := h₁
      simp [List.mem_replicate] at h₂
      <;>
      (try contradiction) <;>
      (try simp_all [List.mem_replicate, FinEnv.contains]) <;>
      (try aesop)
      <;>
      (try
        {
          simp_all [List.mem_replicate, FinEnv.contains]
          <;>
          aesop
        })
    · have h₁ : (a.zip (List.replicate a.length "new")).Nodup := by
        -- The list of pairs (a_i, "new") has no duplicates because it is a list of pairs with the same second element and distinct first elements (assuming a has no duplicates).
        -- However, if a has duplicates, we need a more refined approach.
        -- One way is to use the fact that List.zip is injective if the second list has no duplicates.
        -- Alternatively, we can use a different strategy to ensure uniqueness of pairs by choosing "new" such that no pair is repeated.
        -- Here, we use the fact that List.replicate produces a list of the same element, and thus the second component of each pair is the same, ensuring no duplicates.
        simp [List.nodup_zip]
        <;>
        (try aesop) <;>
        (try simp_all [List.nodup_replicate]) <;>
        (try
          {
            simp_all [List.nodup_replicate]
            <;>
            aesop
          })
      exact h₁
  exact h
