```lean
theorem set_bij_on_range_comp (e : M ≃ₗ[R] N) (f : M →ₗ[R] M) :
    Set.BijOn (e : M → N) (Set.range f) (Set.range (e.comp f)) := by
  refine' ⟨fun a ha => _, fun a ha => _, _⟩
  · -- Injectivity
    rcases ha with ⟨m, rfl⟩
    refine' ⟨e (f m), _⟩
    simp [LinearMap.comp_apply]
  · -- Surjectivity
    rcases ha with ⟨n, rfl⟩
    have h : ∃ m, e (f m) = e n := by
      have h₁ : e (f e⁻¹ n) = e n := by
        have h₂ : e (f e⁻¹ n) = e (f e⁻¹ n) := rfl
        simp_all [LinearEquiv.symm_apply_apply]
        <;> simp_all [LinearEquiv.symm_apply_apply]
        <;> simp_all [LinearEquiv.symm_apply_apply]
      refine' ⟨e⁻¹ n, _⟩
      simp_all [LinearEquiv.symm_apply_apply]
    rcases h with ⟨m, hm⟩
    refine' ⟨m, _⟩
    simp_all [LinearMap.comp_apply]
  · -- Composition
    intro a ha b hb
    have h₁ : a ∈ Set.range f := ha
    have h₂ : b ∈ Set.range f := hb
    rcases h₁ with ⟨m, rfl⟩
    rcases h₂ with ⟨m', rfl⟩
    simp_all [LinearMap.comp_apply]
    <;> aesop

-- We use the above lemma to complete the proof
lemma set_bij_on_range_comp' (e : M ≃ₗ[R] N) (f : M →ₗ[R] M) :
    Set.BijOn (e : M → N) (Set.range f) (Set.range (e.comp f)) := by
  apply set_bij_on_range_comp

