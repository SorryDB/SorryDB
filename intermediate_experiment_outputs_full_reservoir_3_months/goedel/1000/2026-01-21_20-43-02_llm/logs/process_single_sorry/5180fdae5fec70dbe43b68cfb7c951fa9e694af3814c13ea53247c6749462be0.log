      rcases h_mem with ⟨h₁, _⟩
      rcases h₁ with ⟨a, h_a, h_le⟩
      exact le_sSup_of_le h_a h_le
    · intro A h_A_mem
      have h_A_mem' : ∃ (C : Set (PersistenceSubmodule M)), C ⊆ B ∧ A.val ≤ sSup C := by
        have h' := h A.prop
        rcases h' with ⟨B', hB', hB'_sup⟩
        refine ⟨B', _⟩
        constructor
