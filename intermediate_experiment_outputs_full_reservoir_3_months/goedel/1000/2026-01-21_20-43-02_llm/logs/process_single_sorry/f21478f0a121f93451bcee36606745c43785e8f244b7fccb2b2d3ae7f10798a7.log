    -- Use the Archimedean property to find such a k
    use ⌊a⌋
    have h₂ : (⌊a⌋ : ℝ) ≤ a := by exact Int.floor_le a
    have h₃ : a < (⌊a⌋ : ℝ) + 1 := by exact Int.lt_floor_add_one a
    constructor <;> norm_num at h₂ h₃ ⊢ <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try
        {
          cases' le_or_lt 0 (a - ⌊a⌋ : ℝ) with h h <;>
            simp_all [abs_of_nonneg, abs_of_neg, sub_nonneg, sub_nonpos] <;>
            (try linarith) <;>
            (try nlinarith)
        })
  obtain ⟨k, hk₁, hk₂⟩ := h₁
  use (k : ℝ), (a - (k : ℝ))
  constructor
  · -- Prove |a - k| < 1/2
    rw [abs_lt]
    constructor <;> norm_num at hk₁ hk₂ ⊢ <;>
      (try norm_num) <;>
      (try linarith)
  · constructor
    · -- Prove |a - (k + c)| < 1/2
      have h₂ : a - (k : ℝ) = a - (k : ℝ) := rfl
      have h₃ : a - ((k : ℝ) + (a - (k : ℝ))) = 0 := by ring
      have h₄ : abs (a - ((k : ℝ) + (a - (k : ℝ)))) < 1 / 2 := by
        rw [h₃]
        norm_num [abs_of_nonneg]
      simpa [h₂, sub_eq_add_neg, add_assoc] using h₄
    · -- Prove |c| < 1
      have h₅ : abs (a - (k : ℝ)) < 1 := by
        rw [abs_lt]
        constructor <;> norm_num at hk₁ hk₂ ⊢ <;>
