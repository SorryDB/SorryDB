example :
    lex.IsRemainder (X 0 ^ 2 + X 1 ^ 3 + X 2 ^ 4 + X 3 ^ 5: MvPolynomial (Fin 4) ℚ)
      {X 0, X 1, X 2, X 3} 0 := by
  have h₁ : {X 0, X 1, X 2, X 3} = Set.range ([X 0, X 1, X 2, X 3] : List (MvPolynomial (Fin 4) ℚ)).get := by
    simp [Set.ext_iff, List.get]
    <;> aesop
  have h₂ : lex.IsRemainder (X 0 ^ 2 + X 1 ^ 3 + X 2 ^ 4 + X 3 ^ 5: MvPolynomial (Fin 4) ℚ)
      {X 0, X 1, X 2, X 3} 0 := by
    rw [h₁]
    rw [isRemainder_range_fin]
    <;>
    (try decide) <;>
    (try
      {
        use [X 0, X 1 ^ 2, X 2 ^ 3, X 3 ^ 4]
