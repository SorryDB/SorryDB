theorem centralAlgebra_of_central_algebra {k A B : Type*} [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B] [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) := by
  refine' { comap_right := _ }
  intro x y
  have h : ∀ (a : A) (b : B), a ⊗ (1 : B) * (1 ⊗ b) = 1 ⊗ b * a ⊗ (1 : B) := by
    intro a b
    calc
      a ⊗ (1 : B) * (1 ⊗ b) = a * 1 ⊗ (1 : B) * b := by
        simp [mul_smul, smul_mul, mul_assoc]
        <;>
        simp_all [TensorProduct.ext_iff, mul_assoc]
        <;>
        ring_nf
        <;>
        simp_all [Algebra.IsCentral]
      _ = a ⊗ (1 * b) := by simp [one_mul]
      _ = a ⊗ b := by simp [one_mul]
      _ = a ⊗ b := rfl
      _ = 1 ⊗ b * a ⊗ (1 : B) := by
        have h₁ : (a : B) = a := by
          simp [Algebra.IsCentral]
        have h₂ : (a : B) = a := by
          simp [Algebra.IsCentral]
        simp_all [mul_smul, smul_mul, mul_assoc, one_mul, mul_one]
        <;>
        simp_all [TensorProduct.ext_iff, mul_assoc]
        <;>
        ring_nf
        <;>
        simp_all [Algebra.IsCentral]
        <;>
        aesop
        <;>
        simp_all [Algebra.IsCentral]
        <;>
        aesop
  have h₂ : (x : A ⊗[k] B) * (1 : A ⊗[k] B) = (1 : A ⊗[k] B) * (x : A ⊗[k] B) := by
    simp [one_mul, mul_one]
  -- Use the given property of central algebras to show the required commutativity
  simp_all [mul_assoc, mul_comm, mul_left_comm, Algebra.IsCentral]
  <;>
  simp_all [TensorProduct.ext_iff, mul_assoc]
  <;>
  ring_nf at *
  <;>
  simp_all [Algebra.IsCentral]
  <;>
  aesop
