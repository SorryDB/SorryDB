class Algebra.IsCentral (R A : Type*) [Semiring R] [Ring A] [Algebra R A] : Prop where
  /-- The algebra `A` is `R`-central, i.e., multiplication by elements of `R` commutes with all elements of `A`. -/
  comm : ∀ ⦃x : R⦄, ∀ ⦃y : A⦄, x • y = y * x

theorem isCentral_of_isCentral_ae (R A : Type*) [Semiring R] [CommSemiring A] [Algebra R A] [IsCentralRing A] (h : ∀ (x : R), ∀ (y : A), x • y = y * x) : IsCentral R A :=
  ⟨fun x y ↦ by simpa [mul_comm, mul_assoc, mul_left_comm] using h x y⟩

@[to_additive]
instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) := by
  have h₁ : ∀ (x : A) (y : A ⊗[k] B), x ⊗ 1 * y = y * (x ⊗ 1) := by
    intro x y
    have h₂ : ∀ (a : A) (b : A ⊗[k] B), a ⊗ 1 * b = b * (a ⊗ 1) := by
      intro a b
      have h₃ : ∀ (z : A ⊗[k] B), a ⊗ 1 * z = z * (a ⊗ 1) := by
        intro z
        -- Use the fact that B is k-central to show that a ⊗ 1 commutes with any element in A ⊗[k] B
        have h₄ : ∀ (y : B), (a : A) ⊗ (1 : B) * (1 : A) ⊗ (y : B) = (1 : A) ⊗ (y : B) * (a : A) ⊗ (1 : B) := by
          intro y
          simp [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          ring_nf
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          try norm_num
          <;>
          linarith
        -- Extend the result to the entire tensor product using linearity
        simp_all [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
        <;>
        ring_nf
        <;>
        simp_all [Algebra.IsCentral.comm]
        <;>
        try norm_num
        <;>
        linarith
      exact h₃ b
    exact h₂ x y
  have h₂ : ∀ (x : A) (y : A ⊗[k] B), x ⊗ 1 * y = y * (x ⊗ 1) := by
    intro x y
    have h₃ : ∀ (a : A) (b : A ⊗[k] B), a ⊗ 1 * b = b * (a ⊗ 1) := by
      intro a b
      have h₄ : ∀ (z : A ⊗[k] B), a ⊗ 1 * z = z * (a ⊗ 1) := by
        intro z
        -- Use the fact that B is k-central to show that a ⊗ 1 commutes with any element in A ⊗[k] B
        have h₅ : ∀ (y : B), (a : A) ⊗ (1 : B) * (1 : A) ⊗ (y : B) = (1 : A) ⊗ (y : B) * (a : A) ⊗ (1 : B) := by
          intro y
          simp [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          ring_nf
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          try norm_num
          <;>
          linarith
        -- Extend the result to the entire tensor product using linearity
        simp_all [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
        <;>
        ring_nf
        <;>
        simp_all [Algebra.IsCentral.comm]
        <;>
        try norm_num
        <;>
        linarith
      exact h₄ b
    exact h₃ x y
  -- Use the above results to show that A is central in A ⊗[k] B
  have h₃ : ∀ (a : A) (b : A ⊗[k] B), a ⊗ 1 * b = b * (a ⊗ 1) := by
    intro a b
    have h₄ : ∀ (a : A) (b : A ⊗[k] B), a ⊗ 1 * b = b * (a ⊗ 1) := by
      intro a b
      have h₅ : ∀ (z : A ⊗[k] B), a ⊗ 1 * z = z * (a ⊗ 1) := by
        intro z
        -- Use the fact that B is k-central to show that a ⊗ 1 commutes with any element in A ⊗[k] B
        have h₆ : ∀ (y : B), (a : A) ⊗ (1 : B) * (1 : A) ⊗ (y : B) = (1 : A) ⊗ (y : B) * (a : A) ⊗ (1 : B) := by
          intro y
          simp [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          ring_nf
          <;>
          simp_all [Algebra.IsCentral.comm]
          <;>
          try norm_num
          <;>
          linarith
        -- Extend the result to the entire tensor product using linearity
        simp_all [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
        <;>
        ring_nf
        <;>
        simp_all [Algebra.IsCentral.comm]
        <;>
        try norm_num
        <;>
        linarith
      exact h₅ b
    exact h₄ a b
  -- Since the tensor product is generated by elements of the form a ⊗ 1, we can conclude that A is central in A ⊗[k] B
  refine' ⟨fun a b => _⟩
  have h₄ : ∀ (a : A) (b : A ⊗[k] B), a ⊗ 1 * b = b * (a ⊗ 1) := h₃
  simp_all [TensorProduct.ext_iff, mul_assoc, mul_comm, mul_left_comm]
