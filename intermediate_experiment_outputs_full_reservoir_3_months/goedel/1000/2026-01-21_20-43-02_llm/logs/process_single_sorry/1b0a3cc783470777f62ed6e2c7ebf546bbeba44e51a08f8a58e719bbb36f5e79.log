theorem abc : ∀ (n : ℕ), n ≥ 2 → ∃ (a b c : ℕ), a < n ∧ b < n ∧ c < n ∧ a + b + c = 3 * n := by
  intro n hn
  have h₁ : ∃ (a b c : ℕ), a < n ∧ b < n ∧ c < n ∧ a + b + c = 3 * n := by
    use n - 1, n - 1, n + 1
    have h₂ : n ≥ 2 := hn
    have h₃ : n - 1 < n := by
      omega
    have h₄ : n - 1 < n := by
      omega
    have h₅ : n + 1 < n := by
      omega
    have h₆ : (n - 1 : ℕ) + (n - 1 : ℕ) + (n + 1 : ℕ) = 3 * n := by
      cases n with
      | zero => contradiction
      | succ n =>
        cases n with
        | zero => contradiction
        | succ n =>
          simp [Nat.succ_eq_add_one, add_assoc]
          <;> ring_nf at *
          <;> omega
    exact ⟨h₃, h₄, by omega, h₆⟩
  exact h₁
