namespace HTPI.Exercises

-- The missing proof in the original file was for the statement:
-- "If U and V are equinumerous types, then their power types Set U and Set V are also equinumerous."

-- We will use the fact that the correspondence between U and V can be lifted to a correspondence between their subsets.
-- Specifically, if f : U ≃ V is a bijection between U and V, then for any subset S of U, the image f(S) is a subset of V,
-- and vice versa. The inverse of this correspondence is given by f⁻¹(T) for any subset T of V.
-- The key observation is that this lifting preserves the bijection property.

theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  have h₁ : Nonempty (U ≃ V) := by
    -- Since U and V are equinumerous, there exists a bijection between them.
    exact h
  -- Use the bijection to construct a bijection between their power types.
  cases' h₁ with f
  refine' ⟨fun s => (s ∘ f.symm : Set V), fun t => (t ∘ f : Set U), _, _⟩
  <;> simp [Function.funext_iff]
  <;> aesop
