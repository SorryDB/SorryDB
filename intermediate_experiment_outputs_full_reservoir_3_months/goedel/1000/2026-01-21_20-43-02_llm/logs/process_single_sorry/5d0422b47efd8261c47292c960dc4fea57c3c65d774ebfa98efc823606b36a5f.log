namespace Erdos567

open SimpleGraph
open scoped Finset

/-- $Q_3$ is the 3-dimensional hypercube graph (8 vertices, 12 edges).
Vertices are 3-bit vectors. Two vertices are adjacent iff they differ in exactly one bit. -/
def Q3 : SimpleGraph (Fin 3 → Bool) where
  Adj u v := #{i | u i ≠ v i} = 1
  symm _ _ := by simp [eq_comm]
  loopless _ := by simp

/-- $K_{3,3}$ is the complete bipartite graph with partition sizes 3, 3 (6 vertices, 9 edges). -/
def K33 : SimpleGraph (Fin 3 ⊕ Fin 3) := completeBipartiteGraph (Fin 3) (Fin 3)

/-- $H_5$ is $C_5$ with two vertex-disjoint chords (5 vertices, 7 edges).
Also known as $K_4^*$ (the graph obtained from $K_4$ by subdividing one edge). -/
def H5 : SimpleGraph (Fin 5) :=
  .cycleGraph 5 ⊔ .edge 0 2 ⊔ .edge 1 3

/-- A graph `G` is Ramsey size linear if there exists a constant `c_G` such that for any simple
graph `H` with `m` edges and no isolated vertices, `r(G, H) ≤ c_G * m`. -/
class IsRamseySizeLinear (G : SimpleGraph α) : Prop where
  c : ℕ
  m : ℕ → ℕ
  -- For any graph H with m edges and no isolated vertices, r(G, H) ≤ c_G * m.
  argument : ∀ (H : SimpleGraph β) {l : Type*} [DecidableRel H.Adj] (f : β → l) (m : ℕ),
    (H.hasNoIsolatedVertices) → (H.numEdges = m) →
    (ramsey G H ≤ c * m)

/-- The Ramsey number `r(G, H)` is the smallest number `n` such that any
graph on `n` vertices either contains `G` as a subgraph or the complement contains `H`. -/
noncomputable def ramsey {G H : SimpleGraph α} : ℕ :=
