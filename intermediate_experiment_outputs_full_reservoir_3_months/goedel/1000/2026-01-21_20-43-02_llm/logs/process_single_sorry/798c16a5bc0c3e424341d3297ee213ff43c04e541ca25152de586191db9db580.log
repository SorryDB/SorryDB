theorem sixty_four {V : Type u} [DecidableEq V] {G : SimpleGraph V} {u : V} (p : G.LoopWalk u u) :
    p.supportSet.card = p.loop_count + 1 := by
  have h_main : ∀ {V : Type u} [DecidableEq V] {G : SimpleGraph V} {u v : V} (p : G.LoopWalk u v), p.supportSet.card = p.loop_count + 1 := by
    intro V hV G u v p
    have h₁ : p.supportSet.card = p.loop_count + 1 := by
      induction' p with u v w h p ih
      · -- Base case: p = nil
        simp [SimpleGraph.LoopWalk.supportSet, SimpleGraph.LoopWalk.loop_count]
      · -- Inductive step: p = cons h p
        simp_all [SimpleGraph.LoopWalk.supportSet, SimpleGraph.LoopWalk.loop_count,
          SimpleGraph.LoopWalk.support, Finset.card_insert_of_not_mem, Finset.mem_singleton]
        <;> aesop
      · -- Inductive step: p = loop p
        simp_all [SimpleGraph.LoopWalk.supportSet, SimpleGraph.LoopWalk.loop_count,
          SimpleGraph.LoopWalk.support, Finset.card_insert_of_not_mem, Finset.mem_singleton]
        <;> aesop
    exact h₁
  
  have h_final : p.supportSet.card = p.loop_count + 1 := by
    apply h_main
  
  exact h_final
