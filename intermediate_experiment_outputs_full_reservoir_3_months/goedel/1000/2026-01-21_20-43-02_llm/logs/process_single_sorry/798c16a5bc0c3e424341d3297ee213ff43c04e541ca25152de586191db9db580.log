      have h_support : (SimpleGraph.LoopWalk.cons ‹_› ‹_›).supportSet = {v} ∪ (‹_› : G.LoopWalk p ih).supportSet := by
        -- The support set of the cons walk is the union of {v} and the support set of the rest of the walk.
