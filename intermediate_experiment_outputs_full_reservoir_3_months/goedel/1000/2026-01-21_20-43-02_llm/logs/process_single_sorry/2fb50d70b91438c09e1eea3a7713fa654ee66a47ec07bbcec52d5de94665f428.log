### Lean Code (Proof of Theorem `intervalIntegrable_iff_intervalIntegrable_smul`)

```lean
variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℂ E]

theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
    intro hf
    have h1 : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that scalar multiplication by a bounded linear operator preserves integrability.
      have h2 : IntervalIntegrable (r • f) μ a b := by
        -- Apply the property of interval integrability under scalar multiplication.
        refine' hf.smul r
        <;>
        (try simp_all)
        <;>
        (try exact inferInstance)
        <;>
        (try norm_num)
      exact h2
    exact h1
  · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
    intro hf
    have h1 : IntervalIntegrable f μ a b := by
      -- Use the fact that scalar multiplication by a bounded linear operator preserves integrability.
      have h2 : IntervalIntegrable f μ a b := by
        -- Apply the property of interval integrability under scalar multiplication.
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, which is trivially integrable.
          subst hr
          simp_all [IntervalIntegrable]
          <;>
          (try simp_all [MeasureTheory.integrable_zero])
          <;>
          (try exact inferInstance)
          <;>
          (try norm_num)
        · -- If r ≠ 0, use the fact that scalar multiplication by a bounded linear operator preserves integrability.
          have h3 : IsBoundedSMul R E := inferInstance
          have h4 : (r : R) ≠ 0 := hr
          have h5 : IntervalIntegrable (r • f) μ a b := hf
          have h6 : IntervalIntegrable f μ a b := by
            -- Use the property of interval integrability under scalar multiplication.
            refine' h5.smul (r⁻¹ : R)
            <;>
            (try simp_all [smul_smul])
            <;>
            (try field_simp [h4])
            <;>
            (try exact inferInstance)
            <;>
            (try norm_num)
          exact h6
      exact h2
    exact h1
