theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro hf
    -- Use the fact that the smul of an interval integrable function is interval integrable
    have h₂ : IntervalIntegrable (r • f) μ a b := by
      -- Apply the boundedness of the scalar multiplication to preserve integrability
      refine' hf.smul r
    exact h₂
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro hf
    -- Use the fact that the inverse of the scalar multiplication is bounded to preserve integrability
    have h₃ : IntervalIntegrable f μ a b := by
      -- Use the boundedness of the inverse scalar multiplication
      by_cases h₃ : r = 0
      · -- If r = 0, then r • f = 0, which is trivially interval integrable
        subst h₃
        simp_all [IntervalIntegrable]
        <;>
        (try simp_all [smul_zero]) <;>
        (try norm_num) <;>
        (try
          {
            refine' ⟨0, _⟩
            simp_all [MeasureTheory.integral_zero]
          }) <;>
        (try
          {
            refine' ⟨0, _⟩
            simp_all [MeasureTheory.integral_zero]
          })
      · -- If r ≠ 0, then we can find the inverse scalar and use its boundedness
        have h₄ : IsBoundedSMul R E := inferInstance
        have h₅ : IsBoundedSMul R E := inferInstance
        -- Use the fact that the inverse of the scalar multiplication is bounded
        have h₆ : IsBoundedSMul R E := inferInstance
        -- Use the fact that the inverse of the scalar multiplication is bounded
        refine' hf.smul (r⁻¹)
        <;>
        (try simp_all [smul_smul, inv_smul_cancel_left]) <;>
        (try norm_num) <;>
        (try
          {
            simp_all [h₃]
            <;>
            aesop
          })
    exact h₃
  exact ⟨h₁, h₂⟩
