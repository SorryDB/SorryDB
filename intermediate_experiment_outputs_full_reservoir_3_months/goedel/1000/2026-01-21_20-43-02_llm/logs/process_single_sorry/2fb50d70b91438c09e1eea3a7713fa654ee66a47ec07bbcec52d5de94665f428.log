        have h₅ : IntervalIntegrable (r • f) μ a b := by
          refine' (intervalIntegrable_of_norm_lt_one _ (‖r‖₊) (by
            -- Prove that `‖r‖₊ < 1`
            have h₆ : ‖r‖₊ < 1 := by
              by_contra h₇
              -- If `‖r‖₊ ≥ 1`, then we get a contradiction
