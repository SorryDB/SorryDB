      "\n    have h‚āĀ : Pr[= x | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = Pr[= y | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] := by\n      have h‚āā : Pr[= x | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = (Fintype.card őĪ : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ * (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ := by\n        simp [probOutput_fst, probOutput_snd, probOutput_uniformSample]\n        <;>\n        (try simp_all [mul_comm, mul_assoc, mul_left_comm]) <;>\n        (try ring_nf) <;>\n        (try field_simp) <;>\n        (try norm_cast) <;>\n        (try simp_all [Fintype.card_pos_iff])\n      have h‚āÉ : Pr[= y | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = (Fintype.card őĪ : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ * (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ := by\n        simp [probOutput_fst, probOutput_snd, probOutput_uniformSample]\n        <;>\n        (try simp_all [mul_comm, mul_assoc, mul_left_comm]) <;>\n        (try ring_nf) <;>\n        (try field_simp) <;>\n        (try norm_cast) <;>\n        (try simp_all [Fintype.card_pos_iff])\n      simp_all\n    exact h‚āĀ\n  \n  probFailure_selectElem : Pr[‚ä• | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = 0 := by\n    have h‚āĀ : Pr[‚ä• | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = 0 := by\n      simp [sampleDistType, SampleableType.probFailure_selectElem]\n      <;>\n      (try simp_all [mul_comm, mul_assoc, mul_left_comm])\n      <;>\n      (try ring_nf)\n      <;>\n      (try field_simp)\n      <;>\n      (try norm_cast)\n      <;>\n      (try simp_all [Fintype.card_pos_iff])\n    exact h‚āĀ",
