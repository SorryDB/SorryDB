      })
    <;>
    (try
      {
        simp_all [support_product]
        <;>
        (try tauto) <;>
        (try aesop)
      })
  
  probOutput_selectElem_eq x y := by
    have hőĪ : ‚ąÄ (a‚āĀ a‚āā : őĪ), Pr[=a‚āĀ | $ŠĶó őĪ] = Pr[=a‚āā | $ŠĶó őĪ] := by
      intro a‚āĀ a‚āā
      have h‚āĀ : Pr[=a‚āĀ | $ŠĶó őĪ] = Pr[=a‚āā | $ŠĶó őĪ] := by
