(Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)) := h‚āÉ\n          _ = (1 / (Fintype.card őĪ : ‚ĄĚ‚Č•0‚ąě)) * (1 / (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)) := by rfl\n          _ = Pr[=q | (¬∑, ¬∑) <$ ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] := by rw [h‚āĄ]\n      -- Apply the general statement to the specific cases of x and y.\n      have h‚āÖ := h‚āā x y\n      exact h‚āÖ\n    exact h‚āĀ\n  \n  probFailure_selectElem := by\n    have h‚āĀ : Pr[‚ä• | (¬∑, ¬∑) <$> ($ŠĶó őĪ) *< ($ŠĶó ő≤)] = 0 := by\n      have h‚āā : Pr[‚ä• | (¬∑, ¬∑) <$> ($ŠĶó őĪ) *< ($ŠĶó ő≤)] = 0 := by\n        simp [probFailure_seqMap]\n        <;>\n        simp_all [SampleableType.probFailure_selectElem]\n        <;>\n        aesop\n      exact h‚āā\n    exact h‚āĀ",
