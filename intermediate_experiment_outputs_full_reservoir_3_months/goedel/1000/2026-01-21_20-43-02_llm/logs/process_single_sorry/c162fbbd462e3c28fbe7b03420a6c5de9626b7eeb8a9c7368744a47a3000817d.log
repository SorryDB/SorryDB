    have h‚āĄ : Pr[= (y.1, y.2) | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[=y.1 | $ŠĶó őĪ] * Pr[=y.2 | $ŠĶó ő≤] := by
