    by simp only [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one]
  refine ENNReal.eq_inv_of_mul_eq_one_left ?_
  simp_rw [this, Finset.mul_sum, mul_one]
  rw [‚Üź sum_probOutput_eq_one ($ŠĶó őĪ) SampleableType.probFailure_selectElem]
  exact Finset.sum_congr rfl őĽ y _ ‚Ü¶ SampleableType.probOutput_selectElem_eq x y

@[simp] lemma probFailure_uniformSample : Pr[‚ä• | $ŠĶó őĪ] = 0 :=
  SampleableType.probFailure_selectElem

@[simp] instance : HasEvalSPMF.NeverFail ($ŠĶó őĪ) := inferInstance

-- open Classical in
@[simp] lemma evalDist_uniformSample [Fintype őĪ] [Inhabited őĪ] :
    evalDist ($ŠĶó őĪ) = liftM (PMF.uniformOfFintype őĪ) := by
  simp [SPMF.evalDist_eq_iff]

@[simp] lemma support_uniformSample : support ($ŠĶó őĪ) = Set.univ := by
  simp only [Set.ext_iff, Set.mem_univ, iff_true]
