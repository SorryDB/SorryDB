<;> simp_all [Finset.card_eq_zero]\n      exact h‚āÉ‚āā‚āā\n    have h‚āÉ‚āÉ : (Pr[= y.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) = (1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card őĪ‚āĀ : ‚ĄĚ‚Č•0‚ąě) := by\n      have h‚āÉ‚āÉ‚āĀ : (Fintype.card őĪ‚āĀ : ‚ĄĚ‚Č•0‚ąě) ‚Č† 0 := by\n        have h‚āÉ‚āÉ‚āā : 0 < Fintype.card őĪ‚āĀ := by\n          have h‚āÉ‚āÉ‚āÉ : 0 < Fintype.card őĪ‚āĀ := by\n            apply Fintype.card_pos_iff.mpr\n            exact ‚ü®default‚ü©\n          linarith\n        positivity\n      have h‚āÉ‚āÉ‚āā : (Pr[= y.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) = (1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card őĪ‚āĀ : ‚ĄĚ‚Č•0‚ąě) := by\n        simp [probOutput_uniformSample]\n        <;> field_simp [h‚āÉ‚āÉ‚āĀ]\n        <;> ring_nf\n        <;> simp_all [Finset.card_eq_zero]\n      exact h‚āÉ‚āÉ‚āā\n    have h‚āÉ‚āĄ : (Pr[= y.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) = (1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě) := by\n      have h‚āÉ‚āĄ‚āĀ : (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě) ‚Č† 0 := by\n        have h‚āÉ‚āĄ‚āā : 0 < Fintype.card ő≤ := by\n          have h‚āÉ‚āĄ‚āÉ : 0 < Fintype.card ő≤ := by\n            apply Fintype.card_pos_iff.mpr\n            exact ‚ü®default‚ü©\n          linarith\n        positivity\n      have h‚āÉ‚āĄ‚āā : (Pr[= y.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) = (1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě) := by\n        simp [probOutput_uniformSample]\n        <;> field_simp [h‚āÉ‚āĄ‚āĀ]\n        <;> ring_nf\n        <;> simp_all [Finset.card_eq_zero]\n      exact h‚āÉ‚āĄ‚āā\n    calc\n      (Pr[= x.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) * (Pr[= x.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) = ((1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card őĪ‚āĀ : ‚ĄĚ‚Č•0‚ąě)) * ((1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)) := by\n        rw [h‚āÉ‚āĀ, h‚āÉ‚āā]\n      _ = ((1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card őĪ‚āĀ : ‚ĄĚ‚Č•0‚ąě)) * ((1 : ‚ĄĚ‚Č•0‚ąě) / (Fintype.card ő≤ : ‚ĄĚ‚Č•0‚ąě)) := by rfl\n      _ = (Pr[= y.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) * (Pr[= y.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) := by\n        rw [h‚āÉ‚āÉ, h‚āÉ‚āĄ]\n  calc\n    Pr[= x | (fun x1 x2 => (x1, x2)) <$> $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ <*> $ŠĶó ő≤inst‚úĚ] = (Pr[= x.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) * (Pr[= x.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) := by rw [h‚āĀ]\n    _ = (Pr[= y.1 | $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ] : ‚ĄĚ‚Č•0‚ąě) * (Pr[= y.2 | $ŠĶó ő≤inst‚úĚ] : ‚ĄĚ‚Č•0‚ąě) := by rw [h‚āÉ]\n    _ = Pr[= y | (fun x1 x2 => (x1, x2)) <$> $ŠĶó őĪ‚āĀ inst‚úĚ¬Ļ <*> $ŠĶó ő≤inst‚úĚ] := by rw [h‚āā]",
      "\n    have hőĪ : ‚ąÄ (a‚āĀ a‚āā : őĪ), Pr[=a‚āĀ | $ŠĶó őĪ] = Pr[=a‚āā | $ŠĶó őĪ] := by\n      intro a‚āĀ a‚āā\n      have h‚āĀ : Pr[=a‚āĀ | $ŠĶó őĪ] = Pr[=a‚āā | $ŠĶó őĪ] := by\n        apply SampleableType.probOutput_selectElem_eq\n      exact h‚āĀ\n    have hő≤ : ‚ąÄ (b‚āĀ b‚āā : ő≤), Pr[=b‚āĀ | $ŠĶó ő≤] = Pr[=b‚āā | $ŠĶó ő≤] := by\n      intro b‚āĀ b‚āā\n      have h‚āĀ : Pr[=b‚āĀ | $ŠĶó ő≤] = Pr[=b‚āā | $ŠĶó ő≤] := by\n        apply SampleableType.probOutput_selectElem_eq\n      exact h‚āĀ\n    have h‚āĀ : Pr[=x | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[= (x.1, x.2) | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] := rfl\n    have h‚āā : Pr[=y | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[= (y.1, y.2) | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] := rfl\n    rw [h‚āĀ, h‚āā]\n    have h‚āÉ : Pr[= (x.1, x.2) | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[=x.1 | $ŠĶó őĪ] * Pr[=x.2 | $ŠĶó ő≤] := by\n      simp [probOutput_seq_map_prod_mk_eq_mul]\n      <;>\n      simp_all [prod.mk.injEq]\n      <;>\n      aesop\n    have h‚āĄ : Pr[= (y.1, y.2) | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[=y.1 | $ŠĶó őĪ] * Pr[=y.2 | $ŠĶó ő≤] := by\n      simp [probOutput_seq_map_prod_mk_eq_mul]\n      <;>\n      simp_all [prod.mk.injEq]\n      <;>\n      aesop\n    rw [h‚āÉ, h‚āĄ]\n    have h‚āÖ : Pr[=x.1 | $ŠĶó őĪ] = Pr[=y.1 | $ŠĶó őĪ] := hőĪ x.1 y.1\n    have h‚āÜ : Pr[=x.2 | $ŠĶó ő≤] = Pr[=y.2 | $ŠĶó ő≤] := hő≤ x.2 y.2\n    rw [h‚āÖ, h‚āÜ]\n    <;>\n    simp_all [mul_assoc]\n    <;>\n    aesop\n  \n  probFailure_selectElem : Pr[‚ä• | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = 0 := by\n    have h‚āĀ : Pr[‚ä• | (¬∑, ¬∑) <$> $ŠĶó őĪ <*> $ŠĶó ő≤] = Pr[‚ä• | $ŠĶó őĪ] * Pr[‚ä• | $ŠĶó ő≤] := by\n      simp [probFailure_seq_map_prod_mk_eq_mul]\n      <;> aesop\n    have h‚āā : Pr[‚ä• | $ŠĶó őĪ] = 0 := SampleableType.probFailure_selectElem\n    have h‚āÉ : Pr[‚ä• | $ŠĶó ő≤] = 0 := SampleableType.probFailure_selectElem\n    rw [h‚āĀ, h‚āā, h‚āÉ]\n    <;> simp\n    <;> aesop",
