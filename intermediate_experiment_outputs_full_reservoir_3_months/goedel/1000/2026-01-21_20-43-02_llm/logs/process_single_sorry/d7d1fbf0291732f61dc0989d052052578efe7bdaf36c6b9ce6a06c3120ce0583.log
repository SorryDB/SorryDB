    -- First, we find the modular inverse of 30 modulo 47.
    -- The inverse of 30 modulo 47 is 39 because 30 * 39 ≡ 1 [MOD 47].
    -- Then, we multiply both sides of the congruence by 39 to get x ≡ 39 * 42 [MOD 47].
    -- Simplifying, x ≡ 1638 [MOD 47], and 1638 % 47 = 39.
    -- Therefore, x ≡ 39 [MOD 47], and the smallest non-negative solution is x = 39.
    -- For any other solution x, x must be at least 39.
    have h₃ : x ≥ 39 := by
      by_contra h
      -- Assume x < 39 and derive a contradiction.
      have h₄ : x ≤ 38 := by linarith
      interval_cases x <;> norm_num [Nat.ModEq] at h₂ ⊢ <;>
        (try omega) <;> (try contradiction)
    exact h₃
  exact h₁
