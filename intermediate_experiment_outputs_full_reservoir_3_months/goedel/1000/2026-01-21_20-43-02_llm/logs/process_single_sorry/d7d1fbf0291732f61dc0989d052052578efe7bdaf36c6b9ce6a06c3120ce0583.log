theorem mathd_numbertheory_64 : IsLeast { x : ℕ | 30 * x ≡ 42 [MOD 47] } 39 := by
  refine' ⟨by
    -- Prove that 39 is in the set
    norm_num [Nat.ModEq, Nat.mod_eq_of_lt]
    <;> rfl, _⟩
  rintro y ⟨h⟩
  -- Prove that 39 is the least element in the set
  have h₁ : 30 * y ≡ 42 [MOD 47] := h
  have h₂ : y ≥ 39 := by
    by_contra h₃
    -- If y < 39, then y ≤ 38
    have h₄ : y ≤ 38 := by linarith
    -- Check all possible values of y from 0 to 38
    interval_cases y <;> norm_num [Nat.ModEq, Nat.mod_eq_of_lt] at h₁ ⊢ <;>
      (try omega) <;> (try contradiction)
  exact h₂
