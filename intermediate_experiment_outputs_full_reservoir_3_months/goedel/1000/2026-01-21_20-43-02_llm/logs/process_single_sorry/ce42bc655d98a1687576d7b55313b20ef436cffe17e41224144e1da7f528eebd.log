/-- The inclusion of `LinSols` into `charges`. -/
def linSolsIncl (χ : ACCSystemLinear) : χ.LinSols →ₗ[ℚ] χ.Charges where
  toFun S := S.val
  map_add' _ _ := rfl
  map_smul' _ _ := rfl

@[simp]
lemma linSolsIncl_injective (χ : ACCSystemLinear) :
    Function.Injective χ.linSolsIncl := by
  intro S₁ S₂ h
  have h₁ : (χ.linSolsIncl S₁ : χ.Charges) = (χ.linSolsIncl S₂ : χ.Charges) := by exact h
  simp only [linSolsIncl] at h₁
  have h₂ : S₁.val = S₂.val := by exact h₁
  apply LinSols.ext
  <;> simp_all [h₂]
