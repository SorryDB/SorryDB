theorem preserves_limits_of_congr (A : Type*) {F GC : A → Type*} [ForAll {a : A}, Preadditive (F a)] [ForAll {a : A}, Preadditive (GC a)] (h : ∀ (a : A), F a = GC a) (D : ∀ a : A, F a) (D' : ∀ a : A, GC a) (hD : ∀ (a : A), D a = D' a) (u : ∀ (a b : A), (F a → F b) ≃ (F a → F b)) (h' : ∀ (a b : A), (D a → D b) ≃ (D a → D b)) : (Pi.hasLimits.ofHasLimits (fun a => inferInstanceOf HasLimits) : HasLimits) → HasLimits := by
  intro hL
  have h₁ : ∀ (a : A), F a = GC a := h
  have h₂ : ∀ (a : A), D a = D' a := hD
  have h₃ : ∀ (a b : A), (F a → F b) ≃ (F a → F b) := u
  have h₄ : ∀ (a b : A), (D a → D b) ≃ (D a → D b) := h'
  -- Use the given limits to deduce the required limits.
  have h₅ : HasLimits := by
    -- Use the fact that the type families are equal and the limits exist.
    simpa [h₁, h₂, h₃, h₄] using hL
  exact h₅
