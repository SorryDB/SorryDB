instance : IsSolid ((discrete (ModuleCat ℤ)).obj (ModuleCat.of ℤ ℤ)) := by sorry

instance : Inhabited Solid := ⟨Solid.of ((discrete (ModuleCat ℤ)).obj (ModuleCat.of ℤ ℤ))⟩

@[simps!]
def solidToCondensed : Solid ⥤ LightCondAb := inducedFunctor _

instance : HasLimitsOfSize.{0, 0} Solid := by sorry

instance : HasColimitsOfSize.{0, 0} Solid := by sorry

