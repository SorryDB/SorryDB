theorem knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ
  case nil =>
    sorry
  case cons C σ IH =>
