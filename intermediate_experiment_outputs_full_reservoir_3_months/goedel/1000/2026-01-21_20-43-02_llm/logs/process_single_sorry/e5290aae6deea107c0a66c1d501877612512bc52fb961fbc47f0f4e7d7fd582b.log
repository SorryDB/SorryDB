theorem headSL_none_iff_nilSL {sl : SymList a} : headSL sl = none ↔ sl = nil := by
  apply Iff.intro <;> intro h
  <;> simp_all [headSL, nil, fromSL]
  <;> (try {
    cases sl with
    | mk lhs rhs h =>
      by_cases h₁ : lhs = []
      <;> by_cases h₂ : rhs = []
      <;> simp_all [h₁, h₂, List.isEmpty_iff]
      <;> (try { contradiction })
