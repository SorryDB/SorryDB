          have h₃ : (m : ℕ∞) ≤ (n : ℕ∞) := by
            simpa [add_comm] using le_of_add_le_add_right h₂ 0
          exact h₃
        exact h₁
      _ = (n : ℕ∞) := by rfl
    , ?_⟩
