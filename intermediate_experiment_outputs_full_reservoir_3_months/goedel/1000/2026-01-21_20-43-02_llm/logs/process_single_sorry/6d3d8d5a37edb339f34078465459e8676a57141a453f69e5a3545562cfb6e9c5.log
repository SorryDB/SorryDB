theorem contMDiffAt_tangentMap (x₀ : TangentBundle I M)
    (hf : ContMDiffAt I I' n f x₀.proj) (hmn : m + 1 ≤ n) :
    ContMDiffAt I.tangent I'.tangent m (tangentMap I I' f) x₀ := by
  rw [contMDiffAt_totalSpace]
  refine ⟨(hf.comp x₀ (contMDiffAt_proj (TangentSpace I))).of_le <| by
    -- Use the fact that `m ≤ m + 1 ≤ n` to show that the smoothness of `f` implies the smoothness of its tangent map.
    calc
      (↑m : ℕ∞) ≤ (n : ℕ∞) := by
        -- Since `m + 1 ≤ n`, we have `m ≤ n`.
        have h₁ : (m : ℕ∞) ≤ (n : ℕ∞) := by
          -- Use the given inequality `m + 1 ≤ n`.
          have h₂ : (m : ℕ∞) + 1 ≤ (n : ℕ∞) := by exact_mod_cast hmn
