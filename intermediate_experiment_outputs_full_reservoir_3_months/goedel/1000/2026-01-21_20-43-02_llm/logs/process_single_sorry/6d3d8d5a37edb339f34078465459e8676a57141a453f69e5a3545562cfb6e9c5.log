    have h₁ : m ≤ n := by
      have h₂ : m + 1 ≤ n := hmn
      have h₃ : m ≤ n := by
        -- Use the fact that `m + 1 ≤ n` implies `m ≤ n`
        have h₄ : (m : ℕ∞) + 1 ≤ n := hmn
        have h₅ : (m : ℕ∞) ≤ n := by
          -- Since `m + 1 ≤ n`, we have `m ≤ n - 1`, but in `ℕ∞`, subtraction is tricky.
          -- Instead, we use the property of `ℕ∞` that if `a + 1 ≤ b`, then `a ≤ b`.
          -- This is because `ℕ∞` is a type with elements `0, 1, 2, ..., ∞` and order extended naturally.
          -- For `a + 1 ≤ b`, if `a` or `b` is `∞`, the statement is trivial.
          -- Otherwise, `a < b` in `ℕ`, so `a ≤ b - 1`, but in `ℕ∞`, `a ≤ b`.
          -- However, we can use the fact that `m + 1 ≤ n` implies `m ≤ n` directly.
          -- This is because `m + 1 ≤ n` implies that `m < n`, but in `ℕ∞`, `m ≤ n`.
          -- To formalize this, we can consider cases:
          -- Case 1: `m = ∞`: Then `m + 1 = ∞`, so `n = ∞`, and `m ≤ n`.
          -- Case 2: `m < ∞`: Then `m + 1 ≤ n` implies that either `n = ∞` (so `m ≤ n`), or `n` is a natural number and `m < n` (so `m ≤ n`).
          -- Therefore, we can safely conclude that `m ≤ n`.
          -- Here, we use `le_trans` to deduce `m ≤ n` from `m + 1 ≤ n`.
          -- Specifically, we observe that in `ℕ∞`, `m ≤ m + 1`, so if `m + 1 ≤ n`, then `m ≤ n`.
          calc
            (m : ℕ∞) = (m : ℕ∞) + 0 := by simp [add_zero]
            _ ≤ (m : ℕ∞) + 1 := by simp [zero_le_one]
            _ ≤ n := h₄
