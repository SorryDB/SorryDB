    ∃ (k : ℕ), (3 : ℕ) ^ k > 1000 ∧ (3 : ℕ) ^ (k + 2) % 5 = 1 := by
  have h_main : ∃ (k : ℕ), (3 : ℕ) ^ k > 1000 ∧ (3 : ℕ) ^ (k + 2) % 5 = 1 := by
