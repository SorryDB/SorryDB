def Value : Type := String
class ToValue where
  toValue : Self → Value

def ConditionalValue : Type :=
  (Option Value × Option Value)

def ConditionalValue.update : ConditionalValue → Value → ConditionalValue
  | (none, none), v => (none, some v)
  | (none, some _), v => (none, some v)
  | (some v, none), v' => (some v, none)
  | (some _, some _), v => (some v, some v)

def ConditionalValue.isInvalid (v : ConditionalValue) : Bool :=
  match v with
  | (none, none) => true
  | (_, _) => false

def ConditionalValue.hasBoth : ConditionalValue → Bool :=
  match _ with
  | (some _, some _) => true
  | _ => false

def ConditionalValue.hasLeft : ConditionalValue → Bool :=
  match _ with
  | (some _, _) => true
  | _ => false

def ConditionalValue.hasRight : ConditionalValue → Bool :=
  match _ with
  | (_, some _) => true
  | _ => false

def ConditionalValue.determine : ConditionalValue → Value → Value → Option Value
  | (none, none), v₁, v₂ => none
  | (none, some v), _, _ => some v
  | (some v, none), _, _ => some v
  | (some v₁, some v₂), _, _ =>
    if v₁ = v₂ then some v₁ else none

def ConditionalValue.isDeterministic : ConditionalValue → Bool :=
  match _ with
  | (none, none) => false
  | (some v, none) => true
  | (none, some v) => true
  | (some v₁, some v₂) => v₁ == v₂

def ConditionalValue.isSame (v1 v2 : ConditionalValue) : Bool :=
  (v1.1 == v2.1 && v2.2 == v2.2) || (v1.1 == v2.2 && v2.1 == v2.1)

def ConditionalValue.toString : ConditionalValue → String
  | (none, none) => "??–??"
  | (none, some v) => "??–{v}"
  | (some v, none) => "{v}–??"
  | (some v₁, some v₂) => "{v₁}–{v₂}"

def ConditionalValue.validate : ConditionalValue → ConditionalValue :=
  match _ with
  | (none, none) => (none, none)
  | (none, some v) => (some v, some v)
  | (some v, none) => (some v, some v)
  | (some v₁, some v₂) =>
    if v₁ == v₂ then (some v₁, some v₂) else (some v₁, some v₂)

def Value.isSome : Value → Bool := λ v => v != ""

instance : ToString Value where
  toString := id

instance : ToString ConditionalValue where
  toString := ConditionalValue.toString

