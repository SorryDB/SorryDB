      aesop
    rw [MeasureTheory.addEquivAddHaarChar_restrictedProductCongrRight _ hφ]
    <;>
    simp_all [addEquivAddHaarChar, MeasureTheory.EquivAddHaarChar]
    <;>
    norm_num
    <;>
    ring_nf
    <;>
    unfold ContinuousLinearEquiv.toContinuousAddEquiv
    <;>
    simp_all [addEquivAddHaarChar]
    <;>
    norm_num
    <;>
