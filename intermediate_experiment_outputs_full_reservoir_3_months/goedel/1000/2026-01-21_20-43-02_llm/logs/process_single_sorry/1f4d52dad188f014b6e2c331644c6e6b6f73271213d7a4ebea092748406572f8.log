theorem my_workbook_plus_98087 :
  ∃ (p : ℕ → ℕ),
  (∀ n, 0 ≤ p n ∧ p n ≤ 1) ∧
  (p 0 = 0) ∧
  (p 1 = 1) ∧
  (∀ n, p (n + 2) = p (n + 1) + p n) := by
  have h_main : ∃ (p : ℕ → ℕ),
    (∀ n, 0 ≤ p n ∧ p n ≤ 1) ∧
    (p 0 = 0) ∧
    (p 1 = 1) ∧
    (∀ n, p (n + 2) = p (n + 1) + p n) := by
    classical
      -- We use a classical approach to define the sequence using function extensionality
      use fun n => if n % 2 = 1 then 1 else 0
      constructor
      · -- Prove that for all n, 0 ≤ p n ≤ 1
        intro n
        by_cases h : n % 2 = 1
        · -- Case: n is odd
          simp [h]
          <;> norm_num
        · -- Case: n is even
          have h₁ : n % 2 = 0 := by
            have h₂ : n % 2 = 0 ∨ n % 2 = 1 := by omega
            cases h₂ with
            | inl h₂ => exact h₂
            | inr h₂ =>
              exfalso
              apply h
              exact h₂
          simp [h₁]
          <;> norm_num
      · -- Prove the other conditions: p(0) = 0, p(1) = 1, and the recurrence relation
        constructor
        · -- p(0) = 0
          simp
          <;> norm_num
        · constructor
          · -- p(1) = 1
            simp
            <;> norm_num
          · -- Prove the recurrence relation for all n
            intro n
            have h₁ : (n + 2) % 2 = (n % 2) := by
              omega
            have h₂ : (n + 1) % 2 = (n % 2 + 1) % 2 := by
              omega
            by_cases h₃ : n % 2 = 0
            · -- Case: n is even
              have h₄ : n % 2 = 0 := h₃
              have h₅ : (n + 2) % 2 = 0 := by omega
              have h₆ : (n + 1) % 2 = 1 := by omega
              simp [h₄, h₅, h₆]
              <;> norm_num <;>
                (try omega) <;>
                (try
                  {
                    cases n <;>
                    simp_all [Nat.mod_eq_of_lt, Nat.add_assoc]
                    <;>
                    (try omega)
                  })
            · -- Case: n is odd
              have h₄ : n % 2 = 1 := by
                have h₅ : n % 2 = 0 ∨ n % 2 = 1 := by omega
                cases h₅ with
                | inl h₅ =>
                  exfalso
                  apply h₃
                  exact h₅
                | inr h₅ =>
                  exact h₅
              have h₅ : (n + 2) % 2 = 1 := by omega
              have h₆ : (n + 1) % 2 = 0 := by omega
              simp [h₄, h₅, h₆]
              <;> norm_num <;>
                (try omega) <;>
                (try
                  {
                    cases n <;>
                    simp_all [Nat.mod_eq_of_lt, Nat.add_assoc]
                    <;>
                    (try omega)
                  })
  exact h_main
