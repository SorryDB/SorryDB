          intro x
          exact h₂.elim x
        have h₅ : p.1 = q.1 := by
          funext x
          exfalso
          exact h₄ x
        exact h₅
      exact h₃
  
  have h₂ : p.2 = q.2 := by
    classical
    by_cases h : Nonempty γ
    · -- Case: γ is nonempty
