theorem partials_helper1 {pbar : Pose} {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε) :
    ‖pc.S‖ * nth_partial 1 pc.fu pbar.innerParams =
    ⟪pbar.rotR (pbar.rotM₁θ pc.S), pc.w⟫ := by
  simp only [nth_partial, GlobalTheoremPrecondition.fu, Fin.isValue]
  have h₁ : HasFDerivAt (fun x : ℝ³ => rotproj_inner_unit pc.S pc.w x) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by
    apply HasFDerivAt.rotproj_inner
  have h₂ : HasFDerivAt (fun x : ℝ³ => rotproj_inner_unit pc.S pc.w x) (fderiv ℝ (fun x : ℝ³ => rotproj_inner_unit pc.S pc.w x) pbar.innerParams) pbar.innerParams := by
    apply DifferentiableAt.hasFDerivAt
    exact fun_prop
  have h₃ : fderiv ℝ (fun x : ℝ³ => rotproj_inner_unit pc.S pc.w x) pbar.innerParams = (HasFDerivAt.fderiv h₁) := by
    apply HasFDerivAt.fderiv_unique h₁ h₂
  simp_all [HasFDerivAt.fderiv]
  <;>
  (try norm_num) <;>
  (try simp_all [rotproj_inner']) <;>
  (try ring_nf) <;>
  (try field_simp) <;>
  (try norm_num) <;>
  (try linarith [pc.norm_S_gt_zero])
  <;>
  (try simp_all [rotproj_inner', Fin.sum_univ_succ]) <;>
  (try ring_nf) <;>
  (try field_simp) <;>
  (try norm_num) <;>
  (try linarith [pc.norm_S_gt_zero])
