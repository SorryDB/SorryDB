theorem exists_orient_has_odd_neigh (h : ℕ → ℕ → Prop) (A B : NatOrZero) :
    (∀ n : ℕ, ¬h n 0) →
    (∀ n x, h n x → h n (x + 1)) →
    ∃ n : ℕ, A n ≠ B n := by
  intro h₁ h₂
  by_contra! h₃
  have h₄ := h₁ 0
  have h₅ := h₃ 0
  have h₆ := h₃ 1
  have h₇ := h₃ 2
  have h₈ := h₃ 3
