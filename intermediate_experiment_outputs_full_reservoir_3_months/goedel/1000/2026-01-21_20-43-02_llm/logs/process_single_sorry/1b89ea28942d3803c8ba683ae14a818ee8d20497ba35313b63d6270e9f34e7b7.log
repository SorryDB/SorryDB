\n        simpa using h14\n      have h17 : ((q.Y[i]!).val : ℕ) ^ 2 ≤ (2^52 : ℕ) ^ 2 := by\n        simpa using h15\n      have h18 : (q.X[i]!).val ≤ 2^52 := by simpa using hx\n      have h19 : (q.Y[i]!).val ≤ 2^52 := by simpa using hy\n      -- Use the fact that the squares are bounded to show that YY[i]! + XX[i]! ≤ U64.max\n      have h20 : (YY[i]!).val + (XX[i]!).val ≤ U64.max := by\n        -- Use the bounds to prove the inequality\n        have h21 : (YY[i]!).val = (q.Y[i]!).val ^ 2 := by\n          have h22 : YY = q.Y.square := by rfl\n          simp [h22, FieldElement51.square] at *\n          <;>\n          (try omega) <;>\n          (try ring_nf at *) <;>\n          (try norm_num at *) <;>\n          (try simp_all [Nat.mod_eq_of_lt]) <;>\n          (try omega)\n          <;>\n          (try\n            {\n              have h23 : (q.Y[i]!).val < 2^64 := by\n                omega\n              omega\n            })\n          <;>\n          (try\n            {\n              have h23 : (q.Y[i]!).val < 2^64 := by\n                omega\n              omega\n            })\n        have h22 : (XX[i]!).val = (q.X[i]!).val ^ 2 := by\n          have h23 : XX = q.X.square := by rfl\n          simp [h23, FieldElement51.square] at *\n          <;>\n          (try omega) <;>\n          (try ring_nf at *) <;>\n          (try norm_num at *) <;>\n          (try simp_all [Nat.mod_eq_of_lt]) <;>\n          (try omega)\n          <;>\n          (try\n            {\n              have h24 : (q.X[i]!).val < 2^64 := by\n                omega\n              omega\n            })\n          <;>\n          (try\n            {\n              have h24 : (q.X[i]!).val < 2^64 := by\n                omega\n              omega\n            })\n        have h23 : (q.Y[i]!).val ≤ 2^52 := by simpa using hy\n        have h24 : (q.X[i]!).val ≤ 2^52 := by simpa using hx\n        have h25 : (q.Y[i]!).val ^ 2 ≤ (2^52 : ℕ) ^ 2 := by\n          calc\n            (q.Y[i]!).val ^ 2 ≤ (2^52 : ℕ) ^ 2 := by\n              exact pow_le_pow_of_le_left (by positivity) (by simpa using hy) 2\n            _ = (2^52 : ℕ) ^ 2 := by rfl\n        have h26 : (q.X[i]!).val ^ 2 ≤ (2^52 : ℕ) ^ 2 := by\n          calc\n            (q.X[i]!).val ^ 2 ≤ (2^52 : ℕ) ^ 2 := by\n              exact pow_le_pow_of_le_left (by positivity) (by simpa using hx) 2\n            _ = (2^52 : ℕ) ^ 2 := by rfl\n        have h27 : (q.Y[i]!).val ^ 2 + (q.X[i]!).val ^ 2 ≤ (2^52 : ℕ) ^ 2 + (2^52 : ℕ) ^ 2 := by\n          omega\n        norm_num at *\n        <;>\n        (try omega) <;>\n        (try nlinarith) <;>\n        (try\n          {\n            have h28 : (q.Y[i]!).val < 2^64 := by\n              omega\n            omega\n          }) <;>\n        (try\n          {\n            have h28 : (q.X[i]!).val < 2^64 := by\n              omega\n            omega\n          })\n        <;>\n        (try\n          {\n            nlinarith\n          })\n      -- Convert the result to the required form\n      have h28 : (YY[i]!).val + (XX[i]!).val ≤ U64.max := by\n        exact h20\n      have h29 : ↑YY[i]! + ↑XX[i]! ≤ U64.max := by\n        simpa [U64.cast_add] using h28\n      exact h29\n    exact this",
