theorem recursive_list_sum : ∀ (l : List ℕ), (∀ (l : List ℕ), List.length l = 0 → List.sum l = 0) → (∀ (a : ℕ) (l : List ℕ), List.sum (a :: l) = a + List.sum l) → List.sum l = l.foldr (· + ·) 0 := by
  intro l h_nil h_cons
  have h : ∀ (l : List ℕ), List.sum l = l.foldr (· + ·) 0 := by
    intro l
    induction l with
    | nil =>
      -- Base case: the sum of an empty list is 0, which matches the foldr result
      simp [List.sum]
    | cons a l ih =>
      -- Inductive step: assume the statement holds for l, prove for a :: l
      simp_all [List.sum, List.foldr]
      <;> simp_all [add_assoc]
      <;> linarith
  -- Apply the general statement to the specific list l
  exact h l
```
