Lemma isOpen_compact_span (K : Type*) [Field K] [Fintype K] [TopologicalSpace K]
    (k : Set K) (hk : IsFinite k) (h : T0Space K) :
    IsOpen (Submodule.span K k) → False := by
  intro h₁
  have h₂ : IsFinite (Submodule.span K k : Set K) := by
    have h₃ : (Submodule.span K k : Set K) ⊆ Set.bot := by
      intro x hx
      have h₄ : x = 0 := by
        -- Since K is a field, any element in the span of k is zero.
        -- This is because k is a finite set in K, and Submodule.span K k is a subspace.
