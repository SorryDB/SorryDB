theorem t_contradiction {A : Type*} [DecidableEq A] (s : Finset A) (t : Finset A) (h₁ : s ⊆ t) (h₂ : t ⊆ s) : s = t := by
  classical
  apply Finset.Subset.antisymm h₁ h₂

theorem t_univ {A : Type*} : Finset.card (Finset.univ : Finset A) = Fintype.card A := by
  simp [Nat.strong_induction_on]
  <;>
  rfl

theorem t_findefined {Q : Type*} [Fintype Q] (s : Finset Q) : Finset.card s ≤ Fintype.card Q := by
  have h₃ : Finset.card s ≤ Finset.card (Finset.univ : Finset Q) := by
    apply Finset.card_le_card
    apply Finset.subset_univ
  have h₄ : Finset.card (Finset.univ : Finset Q) = Fintype.card Q := by
    apply t_univ
  linarith

theorem t_propagation {A : Type*} [Fintype A] (s t : Finset A) : s ⊆ t → Finset.card s ≤ Finset.card t := by
  intro h
  apply Finset.card_le_card h

theorem t_karins {A : Type*} [DecidableEq A] (s : Finset A) : s ∪ s = s := by
  ext
  simp [Finset.mem_union]
  <;>
  tauto

theorem t_union_assoc {A : Type*} [DecidableEq A] (s t u : Finset A) : s ∪ t ∪ u = s ∪ (t ∪ u) := by
  ext
  simp [Finset.mem_union]
  <;>
  tauto

theorem t_sides {A : Type*} [DecidableEq A] (s t : Finset A) : s ∪ t = t ∪ s := by
  ext
  simp [Finset.mem_union]
  <;>
  tauto

theorem t_inter_assoc {A : Type*} [DecidableEq A] (s t u : Finset A) : s ∩ t ∩ u = s ∩ (t ∩ u) := by
  ext
  simp [Finset.mem_inter]
  <;>
  tauto

theorem t_inter_sides {A : Type*} [DecidableEq A] (s t : Finset A) : s ∩ t = t ∩ s := by
  ext
  simp [Finset.mem_inter]
  <;>
  tauto

theorem t_bracte {A : Type*} [DecidableEq A] (s t : Finset A) : s \ t ⊆ s := by
  intro a ha
  simp only [Finset.mem_sdiff] at ha
  exact ha.1

theorem t_rnight {A : Type*} [DecidableEq A] (s t : Finset A) : s ⊆ t → t \ s = ∅ := by
  intro h
  apply Finset.eq_empty_of_forall_not_mem
  intro a ha
  simp only [Finset.mem_sdiff] at ha
  have h₁ : a ∈ s := by
    have h₂ : a ∈ t := by
      exact ha.1
    have h₃ : a ∈ s := by
      have h₄ : s ⊆ t := h
      exact h₄ h₂
    exact h₃
  tauto

theorem t_subid {A : Type*} [DecidableEq A] (s : Finset A) : s \ s = ∅ := by
  apply Finset.eq_empty_of_forall_not_mem
  intro a ha
  simp only [Finset.mem_sdiff] at ha
  tauto

theorem t_irheo {A : Type*} [DecidableEq A] (s t : Finset A) : s ∩ (t \ s) = ∅ := by
  apply Finset.eq_empty_of_forall_not_mem
  intro a ha
  simp only [Finset.mem_inter, Finset.mem_sdiff] at ha
  tauto

theorem t_decomp {A : Type*} [DecidableEq A] (s t : Finset A) : t ∪ (s ∩ (t \ s)) = t := by
  apply Finset.Subset.antisymm
  · -- Prove that `t ∪ (s ∩ (t \ s)) ⊆ t`
