/- Assume `CharZero K` if you want to work with a possible infinite extension of `ℚ`, and *not*
`Algebra ℚ K`.  -/

variable (L : Type*) [Field L] [Algebra ℚ L] [FiniteDimensional ℚ L]

example : NumberField L := by
  sorry -- This is annoying unfortunately (if you are interested we can discuss this later)

end

example (x y : K) : (x + y) ^ 2 = x ^ 2 + 2 * x * y + y ^ 2 := by
  ring

example (x : K) (hx : x ≠ 0) : x/x = 1 := by
  field_simp

example (x y z : K) (hz : z ≠ 0) : (x + y) * z⁻¹ * (z / (z⁻¹)^(-1 : ℤ)) = y/z + x/z := by
  field_simp
  ring

example (x y : K) (hy : y ≠ 0) : x / y * y = x := by
  exact div_mul_cancel₀ x hy

example (x y : K) (h : x ^ 3 + 3 * x ^ 2 * y + 4 * x * y ^ 2 + y ^ 3 ≠ x * y ^ 2) :
    (x ^ 2 - y ^ 2) / (x + y) = x - y := by
  by_cases hx : x + y = 0
  · have h₁ : x = -y := by
      apply eq_of_sub_eq_zero
      rw [← sub_eq_zero]
      apply mul_left_cancel₀ (sub_ne_zero.mpr hx)
      rw [← sub_eq_zero]
      ring_nf at hx ⊢
      <;> simp_all
      <;> ring_nf at *
      <;> linear_combination hx
    rw [h₁]
    simp_all [sub_eq_add_neg]
    <;> ring_nf at *
    <;> field_simp at *
    <;> ring_nf at *
    <;> simp_all
  · -- Case: x + y ≠ 0
    have h₁ : (x ^ 2 - y ^ 2) / (x + y) = x - y := by
      have h₂ : (x ^ 2 - y ^ 2 : K) = (x - y) * (x + y) := by
        ring
      rw [h₂]
      field_simp [hx]
      <;> ring
      <;> field_simp [hx]
      <;> ring
    rw [h₁]

/- The ring of integers is denoted `𝓞 K` (you need `open NumberField`) -/

open NumberField

#check 𝓞 K

#synth (CommRing (𝓞 K))

/- It is defined as the type given by elements `x : K` such that `IsIntegral ℤ x`.

We also have a predicate `IsAlgebraic`, but most of the library uses `IsIntegral`.

Beware that `𝓞 K` is *not* a subset of `K`, but there is a *coercion*. -/

variable (x : 𝓞 K) (y : K)

#check (x + y)

example (a b : 𝓞 K) : (↑(a + b) : K) = (a : K) + (b : K) := by
  norm_cast

example (a : 𝓞 K) (ha : a ≠ 0) : (a : K) * (a : K)⁻¹ = 1 := by
  refine mul_inv_cancel₀ ?_ --found by `apply?`
  exact_mod_cast ha

/- The units of `𝓞 K` (and of any other multiplicative monoid) are denoted `(𝓞 K)ˣ`  -/

#check (𝓞 K)ˣ

#synth (Group (𝓞 K)ˣ)

/- There is also a *predicate* `IsUnit`, saying that `u : 𝓞 K` is a unit.  -/

variable (u : 𝓞 K) (v : (𝓞 K)ˣ) (hu : IsUnit u)

#check IsUnit u

#check hu.unit

#check v.isUnit

