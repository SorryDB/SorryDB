have f_locInt : LocallyIntegrable (RCLike.ofReal ∘ NNReal.toReal ∘ f) μ := by
  haveI : UniformSpace α := inferInstance
  have h₀ : LocallyIntegrable f μ := by
    have h₁ : (L 1 (μ.restrict univ)).integrable f := by
      have h₂ : f ∈ L 1 (μ.restrict univ) := hf
      exact h₂.integrable
    have h₃ : LocallyIntegrable f μ := by
      simpa using h₁
    exact h₃
  have h₁ : (fun x : α => (1 : ℝ≥0∞)) = 1 := by simp
  have h₂ : LocallyIntegrable (f : α → ℝ≥0∞) μ := h₀
  have h₃ : LocallyIntegrable (RCLike.ofReal ∘ NNReal.toReal ∘ f) μ := by
    have h₄ : LocallyIntegrable (f : α → ℝ≥0∞) μ := h₂
    have h₅ : LocallyIntegrable (RCLike.ofReal ∘ NNReal.toReal ∘ (f : α → ℝ≥0∞)) μ := by
