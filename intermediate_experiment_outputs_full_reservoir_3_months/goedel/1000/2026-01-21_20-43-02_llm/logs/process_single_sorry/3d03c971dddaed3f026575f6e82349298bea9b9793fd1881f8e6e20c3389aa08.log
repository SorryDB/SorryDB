        have h₉ : Continuous (fun x : ℝ => RCLike.ofReal x) := by continuity
        have h₁₀ : Continuous (fun x : ℝ≥0∞ => (RCLike.ofReal ∘ NNReal.toReal) x) := by continuity
        -- Use the fact that the composition of locally integrable functions is locally integrable
        have h₁₁ : LocallyIntegrable (RCLike.ofReal ∘ NNReal.toReal ∘ (f : α → ℝ≥0∞)) μ :=
          (hf).locallyIntegrable.comp' (Continuous.comp (h₈.trans (continuous_id.comp (h₉))) h₁₀)
        exact h₁₁
      exact h₇
    exact h₅
  exact h₃
