instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨x, hx⟩ := r
      have h : valuation L (algebraMap K L x) ≤ 0 := by
        have h₁ : valuation L (algebraMap K L x) = valuation K x := by
          have h₂ : valuation L.comp (algebraMap K L) = valuation K := by
            rfl
          simp_all [h₂]
          <;>
          simp_all [ValuativeExtension.valuation_comp]
          <;>
          aesop
        rw [h₁]
        have h₂ : valuation K x ≥ 0 := by
          have h₃ : x ∈ (valuation K).integer := by
            exact hx
          have h₄ : valuation K x ≥ 0 := by
            have h₅ : (valuation K).integer = {x : K | valuation K x ≥ 0} := by
              simp [Set.ext_iff, Valuation.mem_integer_iff]
              <;>
              aesop
            rw [h₅] at h₃
            exact h₃
          exact h₄
        linarith
      have h₂ : valuation L (algebraMap K L x) ≤ 0 := h
      rw [Valuation.mem_integer_iff]
      <;>
      simpa using h₂
      ⟩
    map_add' := by
      intro x y
      simp [Subtype.ext_iff, Algebra.add_def]
      <;>
      ring_nf
      <;>
      simp_all [Subtype.ext_iff]
      <;>
      norm_num
      <;>
      aesop
    map_one' := by
      simp [Subtype.ext_iff, Algebra.one_def]
      <;>
      aesop
    map_mul' := by
      intro x y
      simp [Subtype.ext_iff, Algebra.mul_def]
      <;>
      ring_nf
      <;>
      simp_all [Subtype.ext_iff]
      <;>
      norm_num
      <;>
      aesop
  }
