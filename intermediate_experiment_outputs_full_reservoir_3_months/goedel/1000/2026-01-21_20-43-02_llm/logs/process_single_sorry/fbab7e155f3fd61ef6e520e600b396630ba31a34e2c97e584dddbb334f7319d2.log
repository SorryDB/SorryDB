-- Probably not how I'm supposed to be doing this (this is not specific to nonarch local fields)
instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨(algebraMap K L) r.1, by
      obtain ⟨a, ha⟩ := r
      have h : valuation K a ≤ 0 := ha
      have h₁ : valuation L (algebraMap K L a) ≥ 0 := by
        -- Use the fact that the valuation of the algebra map is non-negative
        have h₂ : valuation L (algebraMap K L a) ≥ 0 := by
          -- Since `a` has valuation ≤ 0, its algebra map has valuation ≥ 0
          have h₃ : valuation K a ≤ 0 := ha
          have h₄ : (valuation K).compatible (algebraMap K L) := by infer_instance
          have h₅ : valuation L (algebraMap K L a) ≥ 0 := by
            -- Use the compatibility of valuations to transfer the inequality
            have h₆ : valuation K a ≤ 0 := ha
            have h₇ : valuation L (algebraMap K L a) ≥ 0 := by
              have h₈ := h₄.le_iff.le.mpr (by
                -- Use the fact that the valuation of `a` is ≤ 0 to show that the valuation of its algebra map is ≥ 0
                simp_all [ValuativeRel.le_iff]
              )
              simp_all [ValuativeRel.le_zero]
            exact h₇
          exact h₅
        exact h₂
      have h₂ : valuation L (algebraMap K L a) ≥ 0 := h₁
      -- Use the property of integer elements in L
      have h₃ : valuation L (algebraMap K L a) ≥ 0 := h₁
      simp_all [Valuation.mem_integer_iff]
      <;>
      (try omega) <;>
      (try linarith) <;>
      (try nlinarith)
    ⟩
    map_add' := by
      intro x y
      simp [Algebra.algebraMap, Subtype.ext_iff]
      <;>
      simp_all [add_mul]
      <;>
      ring_nf at *
      <;>
      norm_num
      <;>
      simp_all [val_add]
      <;>
      linarith
    map_one' := by
      simp [Algebra.algebraMap, Subtype.ext_iff]
      <;>
      simp_all [one_mul]
      <;>
      ring_nf at *
      <;>
      norm_num
      <;>
      simp_all [val_one]
      <;>
      linarith
    map_mul' := by
      intro x y
      simp [Algebra.algebraMap, Subtype.ext_iff]
      <;>
      simp_all [mul_add, mul_comm, mul_left_comm, mul_assoc]
      <;>
      ring_nf at *
      <;>
      norm_num
      <;>
      simp_all [val_mul]
      <;>
      linarith
  }
