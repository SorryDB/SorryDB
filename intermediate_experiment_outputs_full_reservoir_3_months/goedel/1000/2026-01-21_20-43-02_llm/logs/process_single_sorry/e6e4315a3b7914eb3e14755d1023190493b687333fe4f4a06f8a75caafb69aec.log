      "\n  have hM : Martingale X 𝓕 P := hX.martingale\n  have hM_integrable : ∀ i, Integrable (X i) P := by\n    intro i\n    have h₁ : Integrable (X i) P := by\n      have h₂ : eLpNorm (X i) 2 P < ∞ := by\n        calc eLpNorm (X i) 2 P ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j => eLpNorm (X j) 2 P) i\n        _ < ∞ := hX.bounded\n      have h₃ : Integrable (fun ω => ‖X i ω‖ ^ 2) P := IsSquareIntegrable.integrable_sq hX i\n      -- Use the fact that the square of the norm is integrable to conclude that X_i is integrable\n      have h₄ : Integrable (X i) P := by\n        -- Since E is a normed space over ℝ and P is a measure on Ω, we can use the fact that the square of the norm is integrable\n        -- to conclude that X_i is integrable.\n        have h₅ : Integrable (fun ω => ‖X i ω‖) P := by\n          -- Use the fact that the square of the norm is integrable to conclude that the norm is integrable.\n          have h₆ : Integrable (fun ω => ‖X i ω‖ ^ 2) P := h₃\n          have h₇ : (fun ω => ‖X i ω‖) ≥ 0 := by\n            intro ω\n            exact norm_nonneg (X i ω)\n          have h₈ : (fun ω => ‖X i ω‖ ^ 2) = (fun ω => ‖X i ω‖) * (fun ω => ‖X i ω‖) := by\n            funext ω\n            ring_nf\n          have h₉ : Integrable (fun ω => ‖X i ω‖) P := by\n            -- Use the fact that the square of the norm is integrable to conclude that the norm is integrable.\n            apply L2.integrable_of_l2_sq_integrable h₆\n          exact h₉\n        -- Use the fact that the norm is integrable to conclude that X_i is integrable.\n        have h₁₀ : Integrable (X i) P := by\n          have h₁₁ : StronglyMeasurable (X i) P := (hM.adapted i).mono (Filtration.incr (i := i))\n          have h₁₂ : Integrable (X i) P := by\n            -- Use the fact that the norm is integrable to conclude that X_i is integrable.\n            have h₁₃ : Integrable (fun ω => ‖X i ω‖) P := h₅\n            -- Use the fact that the norm is integrable to conclude that X_i is integrable.