      "\n  have h : ∀ i : ι, Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by\n    intro i\n    exact IsSquareIntegrable.integrable_sq hX i\n  have h₁ : ∀ i : ι, ∀ ω, IsCadlag (X · ω) := by\n    intro i ω\n    exact hX.cadlag ω\n  have h₂ : Submartingale (fun i ω ↦ ‖X i ω‖ ^ 2) 𝓕 P := by\n    -- Use the fact that the square of the norm of a martingale is a submartingale\n    have h₃ : Martingale X 𝓕 P := hX.martingale\n    -- Use the inequality involving the square of the norm and the expectation\n    refine' submartingale_of_isLpConvex _ _ (by simp_all [h₃.adapted, IsLpConvex])\n  exact h₂",
      "\n  have h₁ : ∀ (i : ι), Integrable (fun ω => ‖X i ω‖ ^ 2) P := by\n    intro i\n    exact IsSquareIntegrable.integrable_sq hX i\n  \n  have h₂ : ∀ (i : ι), ae_strongly_measurable (fun ω => ‖X i ω‖ ^ 2) P := by\n    intro i\n    have h₃ : Adapted X 𝓕 P := hX.martingale.adapted\n    have h₄ : ae_strongly_measurable (X i) (P := P) := h₃ i |>.mono (fle_of_le (fmono h₃))\n    have h₅ : ae_strongly_measurable (fun ω => ‖X i ω‖) P := by\n      apply Measurable.c_ennnorm_measurable_aestrongly\n      exact h₄\n    have h₆ : ae_strongly_measurable (fun ω => ‖X i ω‖ ^ 2) P := by\n      -- The square of a real-valued function is measurable.\n      have h₇ : (fun r : ℝ => r ^ 2) = (fun r : ℝ => r ^ 2) := rfl\n      have h₈ : Continuous (fun r : ℝ => r ^ 2) := continuous_pow 2\n      have h₉ : (fun ω : Ω => ‖X i ω‖ ^ 2 : Ω → ℝ) = (fun r : ℝ => r ^ 2) ∘ (fun ω : Ω => ‖X i ω‖) := by\n        ext ω\n        <;> simp [comp_apply]\n      rw [h₉]\n      apply Continuous.ae_strongly_measurable h₈\n      exact h₅\n    exact h₆\n  \n  have h₃ : ∀ (s t : ι), s ≤ t → (fun ω => ‖X s ω‖ ^ 2) ≤ (fun ω => ‖X t ω‖ ^ 2) := by\n    intro s t hst\n    -- Use the fact that the square norm of a martingale is non-decreasing.\n    have h₄ : ∀ ω, ‖X s ω‖ ^ 2 ≤ ‖X t ω‖ ^ 2 := by\n      intro ω\n      have h₅ : IsCadlag (X · ω) := hX.cadlag ω\n      have h₆ : X s ω = X t ω := by\n        have h₇ : IsOptimalStop s ≤ t (X · ω) := by\n          -- Use the fact that s ≤ t and the cadlag property to get X s ω = X t ω\n          sorry\n        -- Since we are in a trivial case where s ≤ t, we can directly conclude X s ω = X t ω\n        sorry\n      rw [h₆]\n      <;> simp [pow_two]\n    -- Use the pointwise inequality to show the function inequality.\n    exact fun ω => h₄ ω\n  \n  refine{\n    submartingale_of_nonneg_of_le (by\n      intro i\n      have h₄ : 0 ≤ (fun ω => ‖X i ω‖ ^ 2) := by\n        intro ω\n        exact by positivity\n      exact h₄\n      ) (by\n      intro s t hst\n      have h₄ :