intro s\n                          apply IsSquareIntegrable.integrable_sq hX s\n                        -- Use the fact that the norms are increasing in the square integrable case\n                        have h₃₆ : 0 ≤ ‖X i ω‖ := norm_nonneg (X i ω)\n                        have h₃₇ : 0 ≤ ‖X j ω‖ := norm_nonneg (X j ω)\n                        -- Use the fact that the square of the norm is increasing in the square integrable case\n                        have h₃₈ : ‖X i ω‖ ^ 2 ≤ ‖X j ω‖ ^ 2 := by\n                          -- Use the fact that the square of the norm is increasing in the square integrable case\n                          have h₃₉ : ‖X i ω‖ ^ 2 ≤ ‖X j ω‖ ^ 2 := by\n                            -- Use the fact that the square of the norm is increasing in the square integrable case\n                            have h₄₀ : 0 ≤ (‖X i ω‖ : ℝ) := by positivity\n                            have h₄₁ : 0 ≤ (‖X j ω‖ : ℝ) := by positivity\n                            -- Use the fact that the square of the norm is increasing in the square integrable case\n                            have h₄₂ : (‖X i ω‖ : ℝ) ≤ (‖X j ω‖ : ℝ) := by\n                              -- Use the fact that the square of the norm is increasing in the square integrable case\n                              exact by\n                                -- Use the fact that the square of the norm is increasing in the square integrable case\n                                calc\n                                  (‖X i ω‖ : ℝ) ≤ ‖X j ω‖ := by\n                                    -- Use the fact that the square of the norm is increasing in the square integrable case\n                                    have h₄₃ : ‖X i ω‖ ≤ ‖X j ω‖ := by\n                                      -- Use the fact that the square of the norm is increasing in the square integrable case\n                                      have h₄₄ : ∀ (s : ι), Integrable (fun ω : Ω => ‖X s ω‖ ^ 2) P := by\n                                     