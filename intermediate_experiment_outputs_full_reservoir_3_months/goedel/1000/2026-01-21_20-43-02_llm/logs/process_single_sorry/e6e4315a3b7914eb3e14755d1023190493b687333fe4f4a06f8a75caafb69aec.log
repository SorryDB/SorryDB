      "\n  have hM : Submartingale (fun i ω => ‖X i ω‖ ^ 2) 𝓕 P := by\n    have h₁ : Martingale X 𝓕 P := hX.martingale\n    have h₂ : ∀ ω, IsCadlag (X · ω) := hX.cadlag\n    have h₃ : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded\n    -- Use the fact that the square of the norm of a martingale is a submartingale\n    have h₄ : Submartingale (fun i ω => ‖X i ω‖ ^ 2) 𝓕 P := by\n      -- Use the fact that the square of the norm of a martingale is a submartingale\n      refine ⟨_, _⟩\n      · -- Show that the square of the norm is adapted\n        have h₅ : ∀ i, Measurable (𝓕 i) (fun ω => ‖X i ω‖ ^ 2) := by\n          intro i\n          have h₆ : Measurable (𝓕 i) (X i) := by\n            -- X i is measurable with respect to 𝓕 i\n            have h₇ : ∀ i, Measurable (𝓕 i) (X i) := h₁.adapted.measurable\n            exact h₇ i\n          -- The norm of X i is measurable\n          have h₈ : Measurable (𝓕 i) (fun ω => ‖X i ω‖) :=\n            h₆.norm\n          -- The square of the norm is measurable\n          have h₉ : Measurable (𝓕 i) (fun ω => ‖X i ω‖ ^ 2) :=\n            h₈.pow 2\n          exact h₉\n        -- The square of the norm is adapted\n        exact fun i => h₅ i\n      · -- Show the submartingale property\n        intro i j h_ij\n        have h₅ : ∀ (i j : ι) (h : i ≤ j), Integ.normSqu (P := P) (X i) ≤ Integ.normSqu (P := P) (X j) := by\n          intro i j h\n          have h₆ : ∀ (i j : ι) (h : i ≤ j), Integ.normSqu (P := P) (X i) ≤ Integ.normSqu (P := P) (X j) := by\n            intro i j h\n            -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n            have h₇ : Submartingale (fun i => Integ.normSqu (P := P) (X i)) 𝓕 P := by\n              -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n              have h₈ : ConvexOn ℝ (Set.univ : Set E) fun x : E => ‖x‖ ^ 2 := by\n                -- The square of the norm is convex\n                exact ConvexOn.pow (norm_convexOn unitBall) 2 (by norm_num)\n              have h₉ : ∀ i j (h : i ≤ j), Integ.normSqu (P := P) (X i) ≤ Integ.normSqu (P := P) (X j) := by\n                intro i j h\n                -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                have h₁₀ : ∀ (s t : ι) (h : s ≤ t), Submartingale (fun i => Integ.normSqu (P := P) (X i)) 𝓕 P := by\n                  intro s t h\n                  -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                  exact fun i j h_ij => by\n                    -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                    have h₁₁ : ∀ (i j : ι) (h : i ≤ j), Integ.normSqu (P := P) (X i) ≤ Integ.normSqu (P := P) (X j) := by\n                      intro i j h\n                      -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                      exact by\n                        have h₁₂ : ∀ (i j : ι) (h : i ≤ j), Integ.normSqu (P := P) (X i) ≤ Integ.normSqu (P := P) (X j) := by\n                          intro i j h\n                          -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                          exact by\n                            have h₁₃ : ConvexOn ℝ (Set.univ : Set E) fun x : E => ‖x‖ ^ 2 := by\n                              -- The square of the norm is convex\n                              exact ConvexOn.pow (norm_convexOn unitBall) 2 (by norm_num)\n                            -- Use the fact that the square of the norm is convex and the difference of the process is integrable\n                            exact by\n                              simp_all [Integ.normSqu, X]\n                              <;>\n                                (try simp_all) <;>\n                                  