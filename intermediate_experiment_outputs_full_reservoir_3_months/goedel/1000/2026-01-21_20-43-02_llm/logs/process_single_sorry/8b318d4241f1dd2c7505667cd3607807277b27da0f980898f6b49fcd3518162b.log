theorem Factorization.card_bound {n : ℕ} (f : Factorization n) (L : ℕ) : ∃ f' :
    Factorization n, f'.total_imbalance = 0 ∧ (f'.a.card : ℝ) * (Real.log n)
      ≤ Real.log n.factorial + (f.score L) := by
  obtain ⟨f', hf'_bal, hf'_score⟩ := lowest_score f L
  refine' ⟨f', hf'_bal, _⟩
  have h₁ : (f'.a.card : ℝ) * Real.log n = (f'.waste : ℝ) := by
    have h₂ : f'.total_imbalance = 0 := hf'_bal
    rw [waste_eq f' h₂]
    <;> simp [h₂, Nat.cast_add, Nat.cast_one]
    <;> ring_nf
    <;> norm_cast
  rw [h₁]
  have h₂ : (f'.waste : ℝ) ≤ Real.log n.factorial + (f.score L) := by
    have h₃ : (f'.waste : ℝ) = (f'.waste : ℝ) := rfl
    rw [h₃]
    have h₄ : (f'.waste : ℝ) ≤ (f'.score L : ℝ) := by
      norm_cast
      <;> linarith [score_eq hf'_bal L]
    have h₅ : (f'.score L : ℝ) ≤ Real.log n.factorial + (f.score L) := by
      have h₆ : (f'.score L : ℕ) ≤ f.score L := by simpa [hf'_bal] using hf'_score
      have h₇ : Real.log (n.factorial : ℝ) ≥ 0 := by
        exact Real.log_nonneg (by
          norm_cast
          <;> exact Nat.factorial_pos n)
      have h₈ : (f'.score L : ℝ) ≤ (f.score L : ℝ) := by
        exact_mod_cast h₆
      linarith
    linarith
  linarith
