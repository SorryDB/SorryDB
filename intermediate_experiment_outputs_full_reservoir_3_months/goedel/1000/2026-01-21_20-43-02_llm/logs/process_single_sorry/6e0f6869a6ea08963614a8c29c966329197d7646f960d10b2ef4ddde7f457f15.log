    have h₁ : (x = y) ↔ x.beq y = true := by
      apply Iff.intro
      · intro h
        rw [h]
        <;> simp [beq, go]
        <;>
        (try decide) <;>
        (try {
          induction w with
          | zero => simp_all [BitVec.getLsbD]
          | succ w ih =>
            simp_all [BitVec.getLsbD, go, Nat.succ_eq_add_one, Nat.sub_add_comm]
            <;> aesop
        }) <;>
        (try {
          cases w <;> simp_all [BitVec.getLsbD, go, Nat.succ_eq_add_one, Nat.sub_add_comm]
          <;> aesop
        })
      · intro h
        have h₂ : x = y := by
          have h₃ : x.beq y = true := h
          have h₄ : ∀ (i : ℕ), i < w → x.getLsbD i = y.getLsbD i := by
            intro i hi
            have h₅ : x.beq y = true := h₃
            have h₆ : (w - 1) ≥ i := by
              have h₇ : i < w := hi
              have h₈ : w - 1 ≥ i := by
                have h₉ : i ≤ w - 1 := by
                  omega
                omega
              exact h₈
            -- Use the definition of beq to extract the equality of bits
            have h₇ : x.getLsbD i = y.getLsbD i := by
              -- Prove this by induction on w
              have h₈ : ∀ (w' : ℕ) (x y : BitVec w') (i : ℕ), i < w' → (w' - 1) ≥ i → (BitVec.beq w' x y = true) → x.getLsbD i = y.getLsbD i := by
                intro w' x y i hi hge hbeq
                induction' w' with w' ih
                · simp_all [BitVec.beq, go]
                · cases w' with
                  | zero =>
                    simp_all [BitVec.beq, go, BitVec.getLsbD]
                    <;>
                    aesop
                  | succ w' =>
                    simp_all [BitVec.beq, go, BitVec.getLsbD]
                    <;>
                    (try {
                      simp_all [Nat.succ_eq_add_one, Nat.sub_add_comm]
                      <;>
                      aesop
                    }) <;>
                    (try {
                      cases i <;> simp_all [Nat.succ_eq_add_one, Nat.sub_add_comm]
                      <;>
                      aesop
                    }) <;>
                    (try {
                      omega
                    }) <;>
                    (try {
                      simp_all [Nat.succ_eq_add_one, Nat.sub_add_comm]
                      <;>
                      aesop
                    })
              have h₉ : x.getLsbD i = y.getLsbD i := h₈ w x y i hi h₆ h₃
              exact h₉
            exact h₇
          -- Use the equality of bits to prove x = y
          have h₅ : x = y := by
            apply BitVec.ext
            intro i hi
            have h₆ : x.getLsbD i = y.getLsbD i := h₄ i (by simpa using hi)
            have h₇ : x.getLsb i = y.getLsb i := by
              have h₈ : i < w := by simpa using hi
              have h₉ : x.getLsbD i = x.getLsb i := by
                simp [BitVec.getLsbD]
                <;> simp_all [hi]
                <;> aesop
              have h₁₀ : y.getLsbD i = y.getLsb i := by
                simp [BitVec.getLsbD]
                <;> simp_all [hi]
                <;> aesop
              simp_all
            exact h₇
          exact h₅
        exact h₂
    exact h₁
  
  have h_final : (x = y) = x.beq y := by
    have h₁ : (x = y) ↔ x.beq y = true := h_main
    have h₂ : (x = y) = x.beq y := by
      have h₃ : x.beq y = true ∨ x.beq y = false := by
        cases x.beq y <;> simp
      cases h₃ with
      | inl h₃ =>
        have h₄ : x.beq y = true := h₃
        have h₅ : x = y := by
          have h₆ : x.beq y = true := h₄
          have h₇ : (x = y) ↔ x.beq y = true := h_main
          have h₈ : x.beq y = true := h₆
          have h₉ : x = y := by
            rw [h₇] at *
            tauto
          exact h₉
        simp [h₄, h₅]
      | inr h₃ =>
        have h₄ : x.beq y = false := h₃
        have h₅ : x ≠ y := by
          intro h₆
          have h₇ : x = y := h₆
          have h₈ : (x = y) ↔ x.beq y = true := h_main
          have h₉ : x.beq y = true := by
            rw [h₈] at *
            tauto
          simp_all
        simp [h₄, h₅]
        <;> simp_all [h₅]
        <;> aesop
    exact h₂
  
  exact h_final
