  by
  funext x y
  simp [beq, iunfoldr, getLsbD]
  <;>
  (try decide) <;>
  (try {
    induction w with
    | zero => simp_all [BitVec.ext_iff]
    | succ w ih =>
      cases w with
      | zero => simp_all [BitVec.ext_iff]
      | succ w =>
        simp_all [BitVec.ext_iff, Nat.succ_eq_add_one, Nat.add_assoc]
