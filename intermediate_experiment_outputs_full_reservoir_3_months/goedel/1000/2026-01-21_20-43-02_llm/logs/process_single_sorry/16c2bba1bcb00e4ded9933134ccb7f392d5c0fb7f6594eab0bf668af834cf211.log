  rw [s_def] at s_free
  simp only at s_free
  unfold nodeAt
  rw [s_def]
  simp only
  rw [def_Y] at IH
  rcases IH with ⟨θY, θY_ip_Y⟩
  have := freePdlRuleInterpolant r (by grind [Sequent.isFree]) ⟨θY, θY_ip_Y⟩
  rcases this with ⟨θX, θX_ipX⟩
  use θX' uses 's_free'!
