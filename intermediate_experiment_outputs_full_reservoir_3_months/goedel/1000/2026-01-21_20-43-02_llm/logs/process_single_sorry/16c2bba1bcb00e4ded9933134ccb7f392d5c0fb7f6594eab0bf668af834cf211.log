theorem path_weight_sum (w : Σ (n : ℕ), Fin n → ℕ) (P : List (Σ n : ℕ, Fin n)) :
    ∀ (p : List (Σ n : ℕ, Fin n)), p.Sublist P → p.sum (fun x => (w x).2 x.2) ≤ P.sum (fun x => (w x).2 x.2) := by
  have h_main : ∀ (p : List (Σ n : ℕ, Fin n)), p.Sublist P → p.sum (fun x => (w x).2 x.2) ≤ P.sum (fun x => (w x).2 x.2) := by
    intro p hp
    have h₁ : p.sum (fun x => (w x).2 x.2) ≤ P.sum (fun x => (w x).2 x.2) := by
      -- Use the fact that if p is a sublist of P, then each element of p is in P and the sum of p is less than or equal to the sum of P.
      have h₂ : p.sum (fun x => (w x).2 x.2) ≤ P.sum (fun x => (w x).2 x.2) := by
        -- Use the property of sublist to show that the sum of p is less than or equal to the sum of P.
        have h₃ : ∀ (l₁ l₂ : List (Σ n : ℕ, Fin n)), l₁.Sublist l₂ → l₁.sum (fun x => (w x).2 x.2) ≤ l₂.sum (fun x => (w x).2 x.2) := by
          intro l₁ l₂ h
          -- Prove by induction on the sublist relation.
          induction' h with a l₁ l₂ h ih
          · -- Case: Empty list sublist.
            simp
          · -- Case: List with head a and tail l₁ sublist of l₂.
            simp_all [List.sum_cons, add_assoc, add_comm, add_left_comm]
            <;>
            (try omega) <;>
            (try
              {
                -- Use the fact that the sum of the elements in the sublist is less than or equal to the sum of the elements in the full list.
                have h₄ : 0 ≤ (w a).2 a.2 := by
                  -- Prove that the weight is non-negative.
                  exact Nat.zero_le _
                omega
              }) <;>
            (try
              {
                -- Use the induction hypothesis to conclude the proof.
                omega
              })
        -- Apply the general property to the specific case of p and P.
        exact h₃ p P hp
      -- The result follows directly from h₂.
      exact h₂
    -- The final result is obtained.
    exact h₁
  -- Use the main lemma to conclude the proof.
  exact h_main
