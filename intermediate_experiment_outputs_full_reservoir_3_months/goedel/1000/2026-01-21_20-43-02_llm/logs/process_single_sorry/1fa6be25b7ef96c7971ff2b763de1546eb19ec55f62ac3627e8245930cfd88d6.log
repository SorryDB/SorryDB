theorem firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      simp [kerLift, Ideal.Quotient.lift_map_mul]
    map_add' := by
      simp [kerLift, Ideal.Quotient.lift_map_add]
    left_inv := by
      intro x
      have h₁ : kerLift f (Ideal.Quotient.mk (ker f) (surjInv hf (kerLift f x))) = kerLift f x := by
        rw [rightInverse_surjInv hf]
      have h₂ : (fun x => Ideal.Quotient.mk (ker f) (surjInv hf x)) (kerLift f x) = x := by
        have h₃ : Function.Surjective (kerLift f) := by
          apply Function.Surjective.comphf
        have h₄ : Function.LeftInverse (fun x => Ideal.Quotient.mk (ker f) (surjInv hf x))Rightarrow (kerLift f) := by
          intro x
          have h₅ : kerLift f (Ideal.Quotient.mk (ker f) (surjInv hf x)) = x := by
            rw [rightInverse_surjInv hf]
          simp_all [Function.LeftInverse]
          <;>
          aesop
        have h₅ : Function.LeftInverse (fun x => Ideal.Quotient.mk (ker f) (surjInv hf x)) kerLift f := by
          exact h₄
        exact h₅ x
      simp_all [LeftInverse]
      <;>
      aesop
}
