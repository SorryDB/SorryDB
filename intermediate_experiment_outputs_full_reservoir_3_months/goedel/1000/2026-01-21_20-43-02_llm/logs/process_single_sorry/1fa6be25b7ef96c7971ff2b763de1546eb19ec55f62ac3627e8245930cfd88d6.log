```lean
theorem left_inv : ∀ x : R ⧸ ker f, (fun x => (Ideal.Quotient.mk (ker f)) (surjInv hf x)) (kerLift f x) = x := by
  intro x
  have h1 : (Ideal.Quotient.mk (ker f)) (surjInv hf (kerLift f x)) = x := by
    -- Step 1: Show that there exists a y : R such that f y = kerLift f x
    have h2 : ∃ (y : R), f y = kerLift f x := by
      have h3 : Function.Surjective f := hf
      obtain ⟨y, hy⟩ := h3 (kerLift f x)
      exact ⟨y, hy⟩
    obtain ⟨y, hy⟩ := h2
    -- Step 2: Relate (surjInv hf (kerLift f x)) to y
    have h4 : f (surjInv hf (kerLift f x)) = kerLift f x := by
      apply surjInv_eq
      <;> simp_all [Function.Surjective]
    have h5 : (Ideal.Quotient.mk (ker f)) (surjInv hf (kerLift f x)) = (Ideal.Quotient.mk (ker f)) y := by
      -- Use the fact that kerLift f (Ideal.Quotient.mk (ker f) (surjInv hf (kerLift f x))) = kerLift f x
      have h6 : kerLift f (Ideal.Quotient.mk (ker f) (surjInv hf (kerLift f x))) = kerLift f x := by
        calc
          kerLift f (Ideal.Quotient.mk (ker f) (surjInv hf (kerLift f x))) = f (surjInv hf (kerLift f x)) := by
            simp [kerLift_mk]
          _ = kerLift f x := by rw [h4]
      -- Use injectivity of kerLift to compare (Ideal.Quotient.mk (ker f) (surjInv hf (kerLift f x))) and (Ideal.Quotient.mk (ker f) y)
      have h7 : kerLift f (Ideal.Quotient.mk (ker f) y) = kerLift f x := by
        calc
          kerLift f (Ideal.Quotient.mk (ker f) y) = f y := by simp [kerLift_mk]
          _ = kerLift f x := by rw [hy]
      have h8 : (Ideal.Quotient.mk (ker f)) (surjInv hf (kerLift f x)) = (Ideal.Quotient.mk (ker f)) y := by
        apply kerLift_injective f
        simp_all [Function.funext_iff]
        <;> aesop
      exact h8
    -- Step 3: Show that (Ideal.Quotient.mk (ker f)) y = x
    have h9 : (Ideal.Quotient.mk (ker f)) y = x := by
      -- Use injectivity of kerLift to deduce (Ideal.Quotient.mk (ker f) y) = x
      have h10 : kerLift f (Ideal.Quotient.mk (ker f) y) = kerLift f x := by
        calc
          kerLift f (Ideal.Quotient.mk (ker f) y) = f y := by simp [kerLift_mk]
          _ = kerLift f x := by rw [hy]
      have h11 : (Ideal.Quotient.mk (ker f) y : R ⧸ ker f) = x := by
        apply kerLift_injective f
        simp_all [Function.funext_iff]
        <;> aesop
      exact h11
    -- Combine the results to get the final equality
    calc
      (Ideal.Quotient.mk (ker f)) (surjInv hf (kerLift f x)) = (Ideal.Quotient.mk (ker f)) y := h5
      _ = x := h9
  -- Final step: Use h1 to conclude the proof
  calc
    (fun x => (Ideal.Quotient.mk (ker f)) (surjInv hf x)) (kerLift f x) = (Ideal.Quotient.mk (ker f)) (surjInv hf (kerLift f x)) := rfl
    _ = x := h1
