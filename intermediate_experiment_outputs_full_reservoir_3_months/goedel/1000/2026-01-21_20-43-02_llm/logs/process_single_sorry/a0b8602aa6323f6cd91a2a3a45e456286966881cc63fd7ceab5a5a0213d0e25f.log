section
open List (range head! tail zipWith and)

def leftmin  (xs : List Nat) := xs.all (head! xs ≤ ·)
def rightmax (xs : List Nat) := xs.all (· ≤ last xs)
def ordered  (xs : List Nat) := and $ zipWith (· ≤ ·) xs (tail xs)
def nmatch   (xs : List Nat) := and $ zipWith (· ≠ ·) xs (range xs.length)

def suffixClosed (p : List Nat → Bool) : Prop :=
    ∀ xs ys, p (xs ++ ys) → p ys

def prefixClosed (p : List Nat → Bool) : Prop :=
    ∀ xs ys, p (xs ++ ys) → p xs

example : suffixClosed leftmin := by
  unfold suffixClosed leftmin
  intro xs ys h
  have h₁ : ∀ x ∈ ys, (xs ++ ys).head! ≤ x := by
    intro x hx
    have h₂ : x ∈ xs ++ ys := by
      apply List.mem_append_right
      exact hx
    exact h x h₂
  have h₂ : (xs ++ ys).head! = (xs ++ ys).head! := rfl
  have h₃ : ∀ (x : ℕ), x ∈ ys → (xs ++ ys).head! ≤ x := h₁
  have h₄ : ∀ (x : ℕ), x ∈ ys → ys.head! ≤ x := by
    intro x hx
    have h₅ : ys.head! ≤ x := by
      have h₆ : ∀ (x : ℕ), x ∈ ys → (xs ++ ys).head! ≤ x := h₁
      have h₇ : (xs ++ ys).head! ≤ x := h₆ x hx
      by_cases h₈ : ys = []
      · simp_all [h₈]
      · have h₉ : ys.head! ∈ ys := by
          simp [h₈, List.mem_cons_self]
        have h₁₀ : (xs ++ ys).head! ≤ ys.head! := h₆ _ h₉
        have h₁₁ : ys.head! ≤ x := by
          have h₁₂ : (xs ++ ys).head! ≤ x := h₇
          have h₁₃ : (xs ++ ys).head! ≤ ys.head! := h₁₀
          have h₁₄ : ys.head! ≤ x := by
            by_cases h₁₅ : xs = []
            · simp_all [h₁₅, List.head!, List.append_assoc]
              <;>
              (try omega)
              <;>
              (try linarith)
            · simp_all [List.head!, List.append_assoc]
              <;>
              (try omega)
              <;>
              (try linarith)
          exact h₁₄
        exact h₁₁
    exact h₅
  simp_all
  <;>
  (try
    {
      cases ys <;>
      simp_all (config := {decide := true})
      <;>
      (try omega)
    })
  <;>
  (try
    {
      simp_all [List.all_nil]
      <;>
      (try omega)
    })
  <;>
  (try
    {
      aesop
    })
