theorem length_parts₁ (xs : List Nat) : (parts₁ xs).length = 2^(xs.length - 1) := by
  have h : ∀ (xs : List Nat), (parts₁ xs).length = 2 ^ (xs.length - 1) := by
    intro xs
    induction xs with
    | nil => 
      simp [parts₁]
    | cons x xs ih =>
      cases xs with
      | nil =>
        simp [parts₁]
      | cons y ys =>
        simp_all [parts₁, List.foldr, Function.comp, concatMap, List.bind, pow_succ, Nat.mul_sub_left_distrib]
        <;>
        (try ring_nf at * <;> simp_all [List.length]) <;>
        (try omega) <;>
        (try
          {
            norm_num at *
            <;>
            ring_nf at *
            <;>
            simp_all [List.length]
            <;>
            omega
          })
        <;>
        (try
          {
            omega
          })
        <;>
        (try
          {
            simp_all [List.length]
            <;>
            ring_nf at *
            <;>
            omega
          })
  exact h xs

