       have h₆ : (xs ++ ys).head! ≤ x := h₁ x hx
       have h₇ : xs.head! ≤ x := by
         rw [h₅] at h₆
         exact h₆
       have h₈ : ys.head! ≤ x := by
         by_cases h₉ : ys = []
         · -- Subcase: ys is empty
           simp_all [List.head!, List.append]
