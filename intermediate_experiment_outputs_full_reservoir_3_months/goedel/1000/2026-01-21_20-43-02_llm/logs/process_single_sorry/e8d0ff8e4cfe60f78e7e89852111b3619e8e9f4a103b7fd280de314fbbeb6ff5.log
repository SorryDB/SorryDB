@[reducible]
def bits2num {w : ℕ} (bits : Vector (ZMod p) w) : (ZMod p) :=
  Vector.foldl (fun acc b => b + 2 * acc) 0 bits

def assert_bits {w : ℕ} (args : Vector (ZMod p) w) : Bool :=
  Vector.all args (fun (x : ZMod p) => x.val % 2 = 0 ∨ x.val % 2 = 1)

lemma assert_bits_p (w : ℕ) (vs : Vector (ZMod p) w) :
  Vector.all vs (fun (x : ZMod p) => x.val % 2 = 0 ∨ x.val % 2 = 1) ↔ ∀ x ∈ vs, x.val % 2 = 0 ∨ x.val % 2 = 1 := by
  simp [Vector.all_iff]
  <;> rfl

lemma assert_bit {x : ZMod p} :
  x.val % 2 = 0 ∨ x.val % 2 = 1 := by
  have h₁ : x.val < p := by
    apply ZMod.val_lt
  haveI := Fact.mk (by exact Nat.Prime.ne_zero (by exact (p := p).infer_instance))
  have h₂ : x.val % 2 = 0 ∨ x.val % 2 = 1 := by
    omega
  exact h₂

lemma bits_exhaustive (w : ℕ) :
  ∀ (e : (ZMod p)) , e.val < 2 ^ w →
    ∃ (vs : Vector (ZMod p) w),
      (Vector.all vs (fun (x : ZMod p) => x.val % 2 = 0 ∨ x.val % 2 = 1)) ∧
        bits2num vs = e := by
  sorry

lemma bits_good : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  e.eval.val < 2 ^ w → Clap.assert_bits p inst✝ w args = true ∧ e = Exp.c (Clap.bits2num p inst✝ w args) := by
  intro w args e h
  haveI := Fact.mk (by exact (p := p).infer_instance)
  have h₁ : ∀ (x : ZMod p), x.val % 2 = 0 ∨ x.val % 2 = 1 := by
    intro x
    have h₂ : x.val < p := by
      apply ZMod.val_lt
    have h₃ : x.val % 2 = 0 ∨ x.val % 2 = 1 := by
      omega
    exact h₃
  have h₂ : assert_bits args = true := by
    have h₃ : Vector.all args (fun (x : ZMod p) => x.val % 2 = 0 ∨ x.val % 2 = 1) := by
      intro i _
      exact h₁ (args.get i)
    simp_all [assert_bits, assert_bit]
    <;> aesop
  have h₃ : e = Exp.c (bits2num args) := by
    have h₄ := bits_exhaustive w e.eval (by
      simpa [Exp.eval] using h)
    cases' h₄ with args' h₄
    have h₅ := h₄.2
    have h₆ := h₄.1
    simp_all [Exp.eval, bits2num]
    <;>
    (try
      simp_all [Vector.all_iff, Exp.eval, bits2num, ZMod.nat_cast_self] <;>
        norm_num <;>
          (try omega) <;>
            (try
              simp_all [Vector.all_iff, Exp.eval, bits2num, ZMod.nat_cast_self] <;>
                norm_num <;>
                  omega)) <;>
      (try
        {
          simp_all [Vector.all_iff, Exp.eval, bits2num, ZMod.nat_cast_self] <;>
            norm_num <;>
              (try omega) <;>
                (try
                  simp_all [Vector.all_iff, Exp.eval, bits2num, ZMod.nat_cast_self] <;>
                    norm_num <;>
                      omega)
        }) <;>
      (try
        {
          aesop
        })
    <;>
    (try
      {
        simp_all [Vector.all_iff, Exp.eval, bits2num, ZMod.nat_cast_self] <;>
          norm_num <;>
            omega
      })
    <;>
    (try
      {
        aesop
      })
  exact ⟨by simp_all [assert_bits, assert_bit], by
    simp_all [Exp.eval, bits2num]
    <;>
    (try
      aesop)⟩
