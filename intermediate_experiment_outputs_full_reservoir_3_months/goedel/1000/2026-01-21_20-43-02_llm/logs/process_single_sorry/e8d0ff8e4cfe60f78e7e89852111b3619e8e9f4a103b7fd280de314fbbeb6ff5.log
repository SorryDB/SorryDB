theorem m : ∀ (n : ℕ), (n : ℕ) % 2 = 1 → ∃ (k : ℕ), n = 2*k + 1 := by
  intro n h
  have h₁ : ∃ (k : ℕ), n = 2*k + 1 := by
    use n / 2
    have h₂ : n % 2 = 1 := h
    have h₃ : n = 2 * (n / 2) + 1 := by
      have h₄ := Nat.div_add_mod n 2
      omega
    exact h₃
  exact h₁
