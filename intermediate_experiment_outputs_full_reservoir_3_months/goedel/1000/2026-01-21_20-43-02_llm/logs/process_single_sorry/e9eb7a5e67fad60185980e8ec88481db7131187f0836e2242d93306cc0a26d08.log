-- The moment of inertia tensor of a solid sphere through its center of mass is
  -- `2/5 m R^2 * I`. 
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  have h₁ : (4 : ℝ) / 3 = (4 : ℝ) / 3 := by rfl
  have h₂ : (2 : ℝ) / 3 = (2 : ℝ) / 3 := by rfl
  -- Use the properties of the solid sphere to compute the inertia tensor
  have h₃ : (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
    -- Assume the inner product space has the property of symmetric integration for simplicity
    have h₄ : ∀ (i j : Fin 3), i = j := by
      intro i j
      fin_cases i <;> fin_cases j <;> simp (config := {decide := true})
    -- Use the fact that the integral of x^2 on the sphere is (4/5)*R^5 for each dimension
    -- and the integral of xy is 0 for i ≠ j
    simp_all [inertiaTensor, solidSphere, Matrix.one_apply, Fin.sum_univ_succ,
      Matrix.smul_apply, Finset.sum_ite, Finset.filter_eq', Finset.filter_ne']
    <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try simp_all) <;>
    (try field_simp) <;>
    (try norm_cast) <;>
    (try linarith)
    <;>
    (try
      {
        simp_all [MeasureTheory.integral_congr_ae]
        <;>
        norm_num
        <;>
        ring_nf
        <;>
        simp_all
        <;>
        field_simp
        <;>
        norm_cast
        <;>
        linarith
      })
    <;>
