    calc
      h₁ = h₁ ≫ 1 := by simp
      _ = h₁ ≫ (g ≫ f) := by rw [hGF]
      _ = (h₁ ≫ g) ≫ f := by rw [← assoc]
      _ = (h₂ ≫ g) ≫ f := by
        have h₁₂'' : (h₁ ≫ g) ≫ f = (h₂ ≫ g) ≫ f := by
          calc
            (h₁ ≫ g) ≫ f = h₁ ≫ (g ≫ f) := by rw [← assoc]
            _ = h₂ ≫ (g ≫ f) := by
              congr 1
              rw [← attackerComputer;
                simp_all [Monomorphism]
              ]
            _ = (h₂ ≫ g) ≫ f := by rw [← assoc]
        rw [h₁₂'']
      _ = h₂ ≫ (g ≫ f) := by rw [← assoc]
      _ = h₂ ≫ 1 := by rw [hGF]
      _ = h₂ := by simp
  have h_epi : @Epimorphism α C X Y f := by
    have : ∃ (g : Hom Y X), IsInverse f g := by
      rcases hf with ⟨g, hg⟩
      exact ⟨g, hg⟩
    obtain ⟨g, hg⟩ := this
    have h_fg : f ≫ g = 1 := hg.right
    intro {Z} h₁ h₂ h₁₂
    have h₁₂' : f ≫ h₁ = f ≫ h₂ := h₁₂
    calc
      h₁ = 1 ≫ h₁ := by simp
      _ = (f ≫ g) ≫ h₁ := by rw [h_fg]
      _ = f ≫ (g ≫ h₁) := by rw [← assoc]
      _ = f ≫ (g ≫ h₂) := by
        have h₁₂'' : f ≫ (g ≫ h₁) = f ≫ (g ≫ h₂) := by
          calc
            f ≫ (g ≫ h₁) = (f ≫ g) ≫ h₁ := by rw [← assoc]
            _ = (f ≫ g) ≫ h₂ := by
              congr 1
              rw [← attackerComputer;
                simp_all [Epimorphism]
