theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  refine' ⟨_, _⟩
  · -- Prove that f is monic
    intro W h k hf_eq
    have g : Hom Y X := hf.inv
    have h₁ : f ≫ g = id := hf.right_inv
    have h₂ : g ≫ f = id := hf.left_inv
    calc
      h = h ≫ id := by rw [id_right]
      _ = h ≫ (f ≫ g) := by rw [h₁]
      _ = (h ≫ f) ≫ g := by rw [assoc]
      _ = (k ≫ f) ≫ g := by rw [hf_eq]
      _ = k ≫ (f ≫ g) := by rw [assoc]
      _ = k ≫ id := by rw [h₁]
      _ = k := by rw [id_right]
  · -- Prove that f is epic
    intro Z h k hf_eq
    have g : Hom Y X := hf.inv
    have h₁ : f ≫ g = id := hf.right_inv
    have h₂ : g ≫ f = id := hf.left_inv
    calc
      h = id ≫ h := by rw [id_left]
      _ = (g ≫ f) ≫ h := by rw [h₂]
      _ = g ≫ (f ≫ h) := by rw [assoc]
      _ = g ≫ (f ≫ k) := by rw [hf_eq]
      _ = (g ≫ f) ≫ k := by rw [assoc]
      _ = id ≫ k := by rw [h₂]
      _ = k := by rw [id_left]
