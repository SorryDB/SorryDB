theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  have h_mono : Mono f := by
    obtain ⟨g, hg⟩ := hf
    intro W hWkW' hWkW'_f
    have h₁ := congr_arg (· ≫ g) hWkW'_f
    simp [hg, comp_assoc, id_comp] at h₁
    <;> simp_all [comp_assoc]
    <;> aesop
  have h_epi : Epi f := by
    obtain ⟨g, hg⟩ := hf
    intro Z hZmZ' hZmZ'_f
    have h₁ := congr_arg (· ≫ g) hZmZ'_f
    simp [hg, comp_assoc, id_comp] at h₁
    <;> simp_all [comp_assoc]
    <;> aesop
  exact ⟨h_mono, h_epi⟩
