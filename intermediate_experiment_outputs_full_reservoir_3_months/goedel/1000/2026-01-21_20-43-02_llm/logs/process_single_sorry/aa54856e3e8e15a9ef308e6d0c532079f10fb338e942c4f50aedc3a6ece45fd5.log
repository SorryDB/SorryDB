      "\n  -- Step 1: Use the inverse of the isomorphism to show that `f` is a retraction\n  have h1 : Epi f := by\n    obtain ⟨g, hg⟩ := hf\n    -- Since `f` has a right inverse, it is a retraction\n    have h2 : f ≫ g = id X := by simpa [hvisited] using hg.symm\n    -- Use the fact that `f ≫ g = id X` to show that `f` is an epimorphism\n    exact fun Z h k h' => by\n      have h3 := congr_arg (· ≫ g) h'\n      simp [h2, comp_assoc] at h3\n      <;>\n      (try simpa [h, k] using h3) <;>\n      (try simp_all [comp_assoc]) <;>\n      (try simp_all [hvisited]) <;>\n      (try simp_all [Hom.ext_iff]) <;>\n      (try simp_all [Function.funext_iff]) <;>\n      (try aesop)\n  \n  -- Step 2: Use the inverse of the isomorphism to show that `f` is a section\n  have h2 : Mono f := by\n    obtain ⟨g, hg⟩ := hf\n    -- Since `f` has a left inverse, it is a section\n    have h3 : g ≫ f = id Y := by simpa using hg\n    -- Use the fact that `g ≫ f = id Y` to show that `f` is a monomorphism\n    exact fun W h k h' => by\n      have h4 := congr_arg (g ≫ ·) h'\n      simp [h3, comp_assoc] at h4\n      <;>\n      (try simpa [h, k] using h4) <;>\n      (try simp_all [comp_assoc]) <;>\n      (try simp_all [hvisited]) <;>\n      (try simp_all [Hom.ext_iff]) <;>\n      (try simp_all [Function.funext_iff]) <;>\n      (try aesop)\n  \n  -- Combine the two results\n  exact ⟨h2, h1⟩",
      "\n  have h₁ : Mono f := by\n    have h₂ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by\n      intro W h k h_eq_k\n      have h₃ : IsIso f := hf\n      have h₄ : Function.Injective (fun g : Hom W X => g ≫ f) := by\n        intro g₁ g₂ h₁₂\n        have h₅ : g₁ ≫ f = g₂ ≫ f := h₁₂\n        have h₆ : IsIso f := hf\n        have h₇ : g₁ = g₂ := by\n          have h₈ : (g₁ ≫ f) = (g₂ ≫ f) := h₅\n          have h₉ : IsIso f := hf\n          have h₁₀ : g₁ ≫ f = g₂ ≫ f := h₈\n          have h₁₁ : g₁ = g₂ := by\n            -- Use the fact that `f` is an isomorphism to cancel it out\n            have h₁₂ : ∃ (g : Hom Y W), IsRetraction f g := by\n              have h₁₃ : IsIso f := hf\n              exact ⟨f⁻¹, by\n                have h₁₄ : f ≫ f⁻¹ = id Y := by\n                  apply hf.inv_mul\n                have h₁₅ : IsRetraction f f⁻¹ := by\n                  simpa [h₁₄] using h₁₄\n                exact h₁₅⟩\n            obtain ⟨g, hg⟩ := h₁₂\n            have h₁₃ : f ≫ g = id X := by\n              have h₁₄ : IsRetraction f g := hg\n              simpa [IsRetraction] using h₁₄\n            calc\n              g₁ = g₁ ≫ (id X : Hom X X) := by simp\n              _ = g₁ ≫ (f ≫ g) := by rw [h₁₃]\n              _ = (g₁ ≫ f) ≫ g := by rw [← comp_assoc]\n              _ = (g₂ ≫ f) ≫ g := by rw [h₈]\n              _ = g₂ ≫ (f ≫ g) := by rw [comp_assoc]\n              _ = g₂ ≫ (id X : Hom X X) := by rw [h₁₃]\n              _ = g₂ := by simp\n          exact h₁₁\n        exact h₇\n      exact h₄ h k h_eq_k\n    exact h₂\n  have h₂ : Epi f := by\n    have h₃ : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by\n      intro Z h k h_eq_k\n      have h₄ : IsIso f := hf\n      have h₅ : Function.Injective (fun g : Hom Y Z => f ≫ g) := by\n        intro g₁ g₂ h₁₂\n        have h₆ : f ≫ g₁ = f ≫ g₂ := h₁₂\n        have h₇ : IsIso f := hf\n        have h₈ : g₁ = g₂ := by\n          have h₉ : (f ≫ g₁) = (f ≫ g₂) := h₆\n          have h₁₀ : IsIso f := hf\n          have h₁₁ : f ≫ g₁ = f ≫ g₂ := h₉\n          have h₁₂ : g₁ = g₂ := by\n            -- Use the fact that `f` is an isomorphism to cancel it out\n            have h₁₃ : ∃ (g : Hom X Y), IsSection f g := by\n              have h₁₄ : IsIso f := hf\n              exact ⟨f⁻¹, by\n                have h₁₅ : f⁻¹ ≫ f = id X := by\n                  apply hf.mul_inv\n                have h₁₆ : IsSection f f⁻¹ := by\n                  simpa [h₁₅] using h₁₅\n                exact h₁₆⟩\n            obtain ⟨g, hg⟩ := h₁₃\n            have h₁₄ : g ≫ f = id Y := by\n              have h₁₅ : IsSection f g := hg\n              simpa [IsSection] using h₁₅\n            calc\n              g₁ = (id Y : Hom Y Y) ≫ g₁ := by simp\n              _ = (g ≫ f) ≫ g₁ := by rw [h₁₄]\n              _ = g ≫ (f ≫ g₁) := by rw [comp_assoc]\n              _ = g ≫ (f ≫ g₂) := by rw [h₆]\n              _ = (g ≫ f) ≫ g₂ := by rw [comp_assoc]\n              _ = (id Y : Hom Y Y) ≫ g₂ := by rw [h₁₄]\n              _ = g₂ := by simp\n          exact h₁₂\n        exact h₈\n      exact h₅ h k h_eq_k\n    exact h₃\n  exact ⟨h₁, h₂⟩",
      "\n  refine' ⟨_, _⟩\n  · exact hf.2.1\n  · exact hf.2.2",
      "\n  have h₁ : Mono f := by\n    have h₂ : IsIso f := hf\n    have h₃ : Mono f := by\n      -- Use the fact that if f is an isomorphism, then it is injective\n      have h₄ : Function.Injective (fun g : Hom X X => g ≫ f) := by\n        intro g₁ g₂ h₅\n        have h₆ := (IsIso.bijective hf).1\n        have h₇ := (IsIso.bijective hf).2\n        simp_all [Function.Bijective]\n        <;>\n        (try { aesop }) <;>\n        (try { simp_all [Function.comp] }) <;>\n        (try { simp_all [eq_comm] }) <;>\n        (try { aesop })\n      -- Simplify the goal using the injectivity\n      have h₅ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by\n        intro W h₁ h₂ h₃\n        have h₆ := h₄\n        simp_all [Function.Injective]\n        <;>\n        (try { aesop }) <;>\n        (try { simp_all [Function.comp] }) <;>\n        (try { simp_all [eq_comm] }) <;>\n        (try { aesop })\n      exact h₅\n    exact h₃\n  have h₂ : Epi f := by\n    have h₃ : IsIso f := hf\n    have h₄ : Epi f := by\n      -- Use the fact that if f is an isomorphism, then it is surjective\n      have h₅ : Function.Injective (fun g : Hom Y Y => f ≫ g) := by\n        intro g₁ g₂ h₆\n        have h₇ := (IsIso.bijective hf).1\n        have h₈ := (IsIso.bijective hf).2\n        simp_all [Function.Bijective]\n        <;>\n        (try { aesop }) <;>\n        (try { simp_all [Function.comp] }) <;>\n        (try { simp_all [eq_comm] }) <;>\n        (try { aesop })\n      -- Simplify the goal using the surjectivity\n      have h₆ : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by\n        intro Z h₁ h₂ h₃\n        have h₇ := h₅\n        simp_all [Function.Injective]\n        <;>\n        (try { aesop }) <;>\n        (try { simp_all [Function.comp] }) <;>\n        (try { simp_all [eq_comm] }) <;>\n        (try { aesop })\n      exact h₆\n    exact h₄\n  exact ⟨h₁, h₂⟩",
      "\n  have h_mono : Mono f := by\n    -- Use the fact that an isomorphism is a monomorphism\n    obtain ⟨g, hg⟩ := hf\n    -- Given the inverse g of f, we can prove that f is a monomorphism\n    refine' fun W h k h_eq => _\n    have h1 : g ≫ (h ≫ f) = g ≫ (k ≫ f) := by rw [h_eq]\n    have h2 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := by\n      calc\n        (g ≫ h) ≫ f = g ≫ (h ≫ f) := by rw [assoc]\n        _ = g ≫ (k ≫ f) := h1\n        _ = (g ≫ k) ≫ f := by rw [← assoc]\n    have h3 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := h2\n    have h4 : g ≫ h = g ≫ k := by\n      -- Since g ≫ f = id, we can cancel f on the right\n      have h5 : g ≫ f = id := by rw [hg]\n      have h6 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := h3\n      have h7 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := by rw [h6]\n      have h8 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := h7\n      -- Use the fact that g ≫ f = id to cancel f\n      have h9 : (g ≫ h) ≫ f = (g ≫ k) ≫ f := h8\n      have h10 : g ≫ h = g ≫ k := by\n        -- Use the fact that g ≫ f = id to cancel f\n        calc\n          g ≫ h = (g ≫ h) ≫ (f ≫ g) := by\n            rw [hg]\n            <;> simp [comp_id]\n          _ = ((g ≫ h) ≫ f) ≫ g := by rw [assoc]\n          _ = ((g ≫ k) ≫ f) ≫ g := by rw [h3]\n          _ = (g ≫ k) ≫ (f ≫ g) := by rw [assoc]\n          _ = (g ≫ k) ≫ (1 : Hom Y Y) := by\n            rw [hg]\n            <;> simp [comp_id]\n          _ = g ≫ k := by simp [id_comp]\n      exact h10\n    -- Now we have g ≫ h = g ≫ k, we can cancel g on the left\n    calc\n      h = (1 : Hom X X) ≫ h := by simp [id_comp]\n      _ = (f ≫ g) ≫ h := by\n        have h5 : f ≫ g = id := by\n          have h6 : g ≫ f = id := by rw [hg]\n          have h7 : IsIso f := hf\n          have h8 : IsIso g := by\n            exact ⟨f, by simp_all [IsIso]⟩\n          -- Use the fact that g ≫ f = id to prove that f ≫ g = id\n          have h9 : f ≫ g = id := by\n            have h10 : IsIso g := h8\n            have h11 : IsIso f := hf\n            -- Use the fact that g ≫ f = id to prove that