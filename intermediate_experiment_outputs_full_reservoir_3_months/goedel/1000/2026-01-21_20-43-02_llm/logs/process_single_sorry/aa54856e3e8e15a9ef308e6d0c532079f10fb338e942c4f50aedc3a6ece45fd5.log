theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  have h₁ : Mono f := by
    have h₂ : IsIso f := hf
    -- An isomorphism is monic because it has a left inverse.
    have h₃ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by
      intro W h k h_eq
      have h₄ : ∃ (g : Hom Y X), g ≫ f = id X := by
        -- Since f is an isomorphism, it has a right inverse.
        obtain ⟨g, hg⟩ := hf.symm
        refine' ⟨g, _⟩
        simp_all [IsIso.inv_def]
        <;> aesop
      obtain ⟨g, hg⟩ := h₄
      calc
        h = h ≫ (id X) := by simp
        _ = h ≫ (g ≫ f) := by rw [hg]
        _ = (h ≫ g) ≫ f := by simp [assoc]
        _ = (k ≫ g) ≫ f := by
          -- Since h ≫ f = k ≫ f, and g is a right inverse, we can use this to show h ≫ g = k ≫ g.
          have h₅ : h ≫ f = k ≫ f := h_eq
          have h₆ : (h ≫ g) ≫ f = (k ≫ g) ≫ f := by
            calc
              (h ≫ g) ≫ f = h ≫ (g ≫ f) := by simp [assoc]
              _ = h ≫ (id X) := by rw [hg]
              _ = h := by simp
              _ = h ≫ (g ≫ f) := by
                simp [hg]
              _ = h ≫ (id X) := by rw [hg]
              _ = h := by simp
              _ = k ≫ (g ≫ f) := by
                have h₇ : h ≫ f = k ≫ f := h_eq
                have h₈ : (h ≫ g) ≫ f = (k ≫ g) ≫ f := by
                  calc
                    (h ≫ g) ≫ f = h ≫ (g ≫ f) := by simp [assoc]
                    _ = h ≫ (id X) := by rw [hg]
                    _ = h := by simp
                    _ = k := by
                      have h₉ : IsIso f := hf
                      have h₁₀ : IsMono f := by
                        -- Since f is an isomorphism, it is monic.
                        exact isIso_iff_isMonicAndIsEpic.mp hf |>.1
                      have h₁₁ : h ≫ f = k ≫ f := h_eq
                      have h₁₂ : h = k := h₁₀ h₁₁
