      "\n  refine' ⟨_, _⟩\n  · -- Prove that f is monic\n    intro W h k hf_eq\n    have g : Hom Y X := hf.inv\n    have h₁ : f ≫ g = id := hf.right_inv\n    have h₂ : g ≫ f = id := hf.left_inv\n    calc\n      h = h ≫ id := by rw [id_right]\n      _ = h ≫ (f ≫ g) := by rw [h₁]\n      _ = (h ≫ f) ≫ g := by rw [assoc]\n      _ = (k ≫ f) ≫ g := by rw [hf_eq]\n      _ = k ≫ (f ≫ g) := by rw [assoc]\n      _ = k ≫ id := by rw [h₁]\n      _ = k := by rw [id_right]\n  · -- Prove that f is epic\n    intro Z h k hf_eq\n    have g : Hom Y X := hf.inv\n    have h₁ : f ≫ g = id := hf.right_inv\n    have h₂ : g ≫ f = id := hf.left_inv\n    calc\n      h = id ≫ h := by rw [id_left]\n      _ = (g ≫ f) ≫ h := by rw [h₂]\n      _ = g ≫ (f ≫ h) := by rw [assoc]\n      _ = g ≫ (f ≫ k) := by rw [hf_eq]\n      _ = (g ≫ f) ≫ k := by rw [assoc]\n      _ = id ≫ k := by rw [h₂]\n      _ = k := by rw [id_left]",
      "\n  refine' ⟨_, _⟩\n  · -- Prove that f is a monomorphism\n    have h1 : Function.Injective (fun g : Hom X X => g ≫ f) := by\n      -- Since f is an isomorphism, it is injective when composed with other morphisms\n      have h2 : IsCancellableOnLeft (fun g : Hom X X => g ≫ f) := by\n        -- Use the fact that f is an isomorphism to show cancellativity\n        have h3 : IsCancellableOnLeft f := by\n          -- Extract the left cancellativity from the isomorphism property\n          exact hf.1.1\n        -- Extend the cancellativity to the composition\n        intro g1 g2 h\n        exact h3 h\n      -- Use cancellativity to prove injectivity\n      have h4 : Function.Injective (fun g : Hom X X => g ≫ f) := by\n        intro g1 g2 h\n        apply h2\n        simpa using h\n      exact h4\n    -- Use the injectivity to prove that f is a monomorphism\n    have h5 : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by\n      intro W h k h6\n      have h7 : Function.Injective (fun g : Hom W X => g ≫ f) := by\n        -- Use the fact that f is injective in the composition\n        have h8 : IsCancellableOnLeft (fun g : Hom W X => g ≫ f) := by\n          have h9 : IsCancellableOnLeft f := hf.1.1\n          intro g1 g2 h\n          have h10 : g1 ≫ f = g2 ≫ f := by simpa using h\n          exact h9 h10\n        -- Convert cancellativity to injectivity\n        have h10 : Function.Injective (fun g : Hom W X => g ≫ f) := by\n          intro g1 g2 h11\n          apply h8\n          simpa using h11\n        exact h10\n      exact h7 h6\n    exact h5\n  · -- Prove that f is an epimorphism\n    have h1 : Function.Injective (fun g : Hom Y Y => f ≫ g) := by\n      -- Since f is an isomorphism, it is injective when composed with other morphisms\n      have h2 : IsCancellableOnRight (fun g : Hom Y Y => f ≫ g) := by\n        -- Use the fact that f is an isomorphism to show cancellativity\n        have h3 : IsCancellableOnRight f := by\n          -- Extract the right cancellativity from the isomorphism property\n          exact hf.1.2\n        -- Extend the cancellativity to the composition\n        intro g1 g2 h\n        exact h3 h\n      -- Use cancellativity to prove injectivity\n      have h4 : Function.Injective (fun g : Hom Y Y => f ≫ g) := by\n        intro g1 g2 h\n        apply h2\n        simpa using h\n      exact h4\n    -- Use the injectivity to prove that f is an epimorphism\n    have h5 : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by\n      intro Z h k h6\n      have h7 : Function.Injective (fun g : Hom Y Z => f ≫ g) := by\n        -- Use the fact that f is injective in the composition\n        have h8 : IsCancellableOnRight (fun g : Hom Y Z => f ≫ g) := by\n          have h9 : IsCancellableOnRight f := hf.1.2\n          intro g1 g2 h\n          have h10 : f ≫ g1 = f ≫ g2 := by simpa using h\n          exact h9 h10\n        -- Convert cancellativity to injectivity\n        have h10 : Function.Injective (fun g : Hom Y Z => f ≫ g) := by\n          intro g1 g2 h11\n          apply h8\n          simpa using h11\n        exact h10\n      exact h7 h6\n    exact h5",
