  have h₁ : Mono f := by
    have h₂ : ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k := by
      intro W h k h_eq_k
      -- Use the fact that f is an isomorphism to cancel it out
      have ⟨g, _, _⟩ := hf
      have hg : g ≫ f = id X := by simpa using _
      have hgf : h ≫ f = k ≫ f := h_eq_k
      have h₁ : h ≫ f ≫ g = k ≫ f ≫ g := by rw [hgf]
      have h₂ : h ≫ (f ≫ g) = k ≫ (f ≫ g) := by
        calc
          h ≫ (f ≫ g) = (h ≫ f) ≫ g := by rw [assoc]
          _ = (k ≫ f) ≫ g := by rw [hgf]
          _ = k ≫ (f ≫ g) := by rw [← assoc]
      have h₃ : f ≫ g = id X := by simpa using _
      have h₄ : h ≫ (id X) = k ≫ (id X) := by rw [h₃] at h₂; exact h₂
      have h₅ : h = k := by
        calc
          h = h ≫ id X := by simp
          _ = k ≫ id X := by rw [h₄]
          _ = k := by simp
      exact h₅
    exact h₂
  have h₂ : Epi f := by
    have h₃ : ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k := by
      intro Z h k h_eq_k
      -- Use the fact that f is an isomorphism to cancel it out
      have ⟨g, _, _⟩ := hf
      have hg : f ≫ g = id Y := by simpa using _
      have hgf : f ≫ h = f ≫ k := h_eq_k
      have h₁ : g ≫ (f ≫ h) = g ≫ (f ≫ k) := by rw [hgf]
      have h₂ : (g ≫ f) ≫ h = (g ≫ f) ≫ k := by
        calc
          (g ≫ f) ≫ h = g ≫ (f ≫ h) := by rw [assoc]
          _ = g ≫ (f ≫ k) := by rw [hgf]
          _ = (g ≫ f) ≫ k := by rw [← assoc]
      have h₃ : g ≫ f = id X := by simpa using _
      have h₄ : (id X) ≫ h = (id X) ≫ k := by rw [h₃] at h₂; exact h₂
      have h₅ : h = k := by
        calc
          h = id X ≫ h := by simp
          _ = id X ≫ k := by rw [h₄]
          _ = k := by simp
      exact h₅
    exact h₃
  exact ⟨h₁, h₂⟩
