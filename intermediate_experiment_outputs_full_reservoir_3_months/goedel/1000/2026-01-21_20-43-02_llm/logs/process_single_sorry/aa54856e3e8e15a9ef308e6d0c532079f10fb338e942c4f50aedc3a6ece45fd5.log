            _ = f ≫ (g ≫ h₂) := by rw [← assoc]
        rw [h₁₂'']
      _ = (f ≫ g) ≫ h₂ := by rw [← assoc]
      _ = 1 ≫ h₂ := by rw [h_fg]
      _ = h₂ := by simp
  exact ⟨h_mono, h_epi⟩
