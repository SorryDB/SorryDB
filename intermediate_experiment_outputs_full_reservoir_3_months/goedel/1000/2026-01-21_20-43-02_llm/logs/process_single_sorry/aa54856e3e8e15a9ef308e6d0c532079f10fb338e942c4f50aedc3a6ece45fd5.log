      "\n  have h₁ : Mono f := by\n    have h₂ : IsIso f := hf\n    -- If f is an isomorphism, then it is a monomorphism.\n    have h₃ : Mono f := by\n      -- Use the fact that an isomorphism is a monomorphism.\n      have h₄ : IsIso f := hf\n      -- Extract the inverse from the isomorphism.\n      obtain ⟨g, hg₁, hg₂⟩ := h₄\n      -- Show that f is a monomorphism.\n      intro W h k h_eq\n      -- Use the inverse to cancel f.\n      have h₅ : h = k := by\n        calc\n          h = h ≫ id X := by simp\n          _ = h ≫ (g ≫ f) := by rw [← hg₁]\n          _ = (h ≫ g) ≫ f := by simp [assoc]\n          _ = (k ≫ g) ≫ f := by\n            -- Use the fact that h ≫ f = k ≫ f to show h ≫ g = k ≫ g\n            apply congr_arg (fun x => x ≫ f)\n            -- Use the inverse to cancel f.\n            have h₆ : h ≫ f = k ≫ f := h_eq\n            calc\n              h ≫ g = (h ≫ g) ≫ id Y := by simp\n              _ = (h ≫ g) ≫ (f ≫ g) := by rw [← hg₂]\n              _ = ((h ≫ g) ≫ f) ≫ g := by simp [assoc]\n              _ = ((k ≫ g) ≫ f) ≫ g := by\n                -- Use the fact that h ≫ f = k ≫ f to show (h ≫ g) ≫ f = (k ≫ g) ≫ f\n                congr 1\n                calc\n                  (h ≫ g) ≫ f = h ≫ (g ≫ f) := by simp [assoc]\n                  _ = h ≫ id X := by rw [← hg₁]\n                  _ = h := by simp\n                  _ = k := by\n                    -- Use the fact that h ≫ f = k ≫ f to show h = k\n                    have h₇ : h ≫ f = k ≫ f := h_eq\n                    have h₈ : Function.Injective (fun x : Hom X Y => x ≫ f) := by\n                      intro x y hxy\n                      have h₉ : x ≫ f = y ≫ f := hxy\n                      have h₁₀ : x = y := by\n                        -- Use the inverse to cancel f.\n                        calc\n                          x = x ≫ id X := by simp\n                          _ = x ≫ (g ≫ f) := by rw [← hg₁]\n                          _ = (x ≫ g) ≫ f := by simp [assoc]\n                       