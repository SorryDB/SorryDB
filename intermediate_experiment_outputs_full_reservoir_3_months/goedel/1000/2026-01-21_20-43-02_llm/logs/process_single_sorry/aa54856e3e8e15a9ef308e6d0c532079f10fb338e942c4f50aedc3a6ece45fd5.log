      "\n  haveI : Invertible f := hf.invertible\n  constructor\n  · -- Prove `Mono f`\n    intro W h₁ h₂ h₃\n    calc\n      h₁ = h₁ ≫ id _ := by simp\n      _ = h₁ ≫ (f ≫ f⁻¹) := by rw [← mul_inv_cancel_right f]\n      _ = (h₁ ≫ f) ≫ f⁻¹ := by rw [comp_assoc]\n      _ = (h₂ ≫ f) ≫ f⁻¹ := by rw [h₃]\n      _ = h₂ ≫ (f ≫ f⁻¹) := by rw [comp_assoc]\n      _ = h₂ ≫ id _ := by rw [← mul_inv_cancel_right f]\n      _ = h₂ := by simp\n  · -- Prove `Epi f`\n    intro Z g₁ g₂ h₃\n    calc\n      g₁ = id _ ≫ g₁ := by simp\n      _ = (f⁻¹ ≫ f) ≫ g₁ := by rw [← mul_inv_cancel_left f]\n      _ = f⁻¹ ≫ (f ≫ g₁) := by rw [comp_assoc]\n      _ = f⁻¹ ≫ (f ≫ g₂) := by rw [h₃]\n      _ = (f⁻¹ ≫ f) ≫ g₂ := by rw [comp_assoc]\n      _ = id _ ≫ g₂ := by rw [← mul_inv_cancel_left f]\n      _ = g₂ := by simp",
      "\n  have h_mono : @CategoryInContext.Category.Mono α C X Y f := by\n    have h : ∃ (g : Hom Y X), g ≫ f = 1 ∧ f ≫ g = 1 := by\n      obtain ⟨g, hg⟩ := hf\n      refine' ⟨g, _, _⟩ <;> simp_all [IsIso]\n    obtain ⟨g, hg₁, hg₂⟩ := h\n    intro W hW kW hWf\n    have h₁ : hW ≫ f = kW ≫ f := hWf\n    calc\n      hW = hW ≫ 1 := by simp\n      _ = hW ≫ (f ≫ g) := by rw [hg₂]\n      _ = (hW ≫ f) ≫ g := by simp [Associative]\n      _ = (kW ≫ f) ≫ g := by rw [h₁]\n      _ = kW ≫ (f ≫ g) := by simp [Associative]\n      _ = kW ≫ 1 := by rw [hg₂]\n      _ = kW := by simp\n  \n  have h_epi : @CategoryInContext.Category.Epi α C X Y f := by\n    have h : ∃ (g : Hom Y X), g ≫ f = 1 ∧ f ≫ g = 1 := by\n      obtain ⟨g, hg⟩ := hf\n      refine' ⟨g, _, _⟩ <;> simp_all [IsIso]\n    obtain ⟨g, hg₁, hg₂⟩ := h\n    intro Z hZ kZ hfZ\n    have h₁ : f ≫ hZ = f ≫ kZ := hfZ\n    calc\n      hZ = 1 ≫ hZ := by simp\n      _ = (f ≫ g) ≫ hZ := by rw [hg₂]\n      _ = f ≫ (g ≫ hZ) := by simp [Associative]\n      _ = f ≫ (g ≫ kZ) := by\n        have h₂ : g ≫ hZ = g ≫ kZ := by\n          calc\n            g ≫ hZ = g ≫ hZ := rfl\n            _ = g ≫ kZ := by\n              have h₃ : f ≫ hZ = f ≫ kZ := hfZ\n              have h₄ : g ≫ (f ≫ hZ) = g ≫ (f ≫ kZ) := by rw [h₃]\n              calc\n                g ≫ hZ = (g ≫ (f ≫ g)) ≫ hZ := by\n                  simp [hg₂, Associative]\n                  <;>\n                  simp_all [Associative]\n                  <;>\n                  try simp_all [Associative]\n                  <;>\n                  try simp_all [Associative]\n                _ = g ≫ (f ≫ g) ≫ hZ := by simp [Associative]\n                _ = g ≫ (f ≫ (g ≫ hZ)) := by simp [Associative]\n                _ = g ≫ (f ≫ (g ≫ kZ)) := by\n                  have h₅ : f ≫ (g ≫ hZ) = f ≫ (g ≫ kZ) := by\n                    calc\n                      f ≫ (g ≫ hZ) = (f ≫ g) ≫ hZ := by simp [Associative]\n                      _ = 1 ≫ hZ := by rw [hg₂]\n                      _ = hZ := b