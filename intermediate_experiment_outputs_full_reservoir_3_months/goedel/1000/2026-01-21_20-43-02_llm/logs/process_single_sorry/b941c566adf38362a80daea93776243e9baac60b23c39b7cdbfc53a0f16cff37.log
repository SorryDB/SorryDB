        -- The degree of the extension is the dimension of L as a vector space over ℚ.
        have h : FiniteDimensional.finrank ℚ L ≠ 0 := by
          by_contra h₁
          have h₂ : FiniteDimensional.finrank ℚ L = 0 := by simpa using h₁
          have h₃ : L ≃ₚ[ℚ] (0 : Module ℚ) := by
