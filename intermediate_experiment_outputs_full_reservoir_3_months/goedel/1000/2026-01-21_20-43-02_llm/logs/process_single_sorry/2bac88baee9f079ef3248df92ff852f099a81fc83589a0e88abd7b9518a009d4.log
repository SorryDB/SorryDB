theorem use_integralM_simp (n : ℕ) (f : ℝ → ℝ) (g : ℝ → ℝ) (a b : ℝ) :
  (∫ x in a..b, (f x + g x)) = (∫ x in a..b, f x) + (∫ x in a..b, g x) := by
  have h₀ : IntervalIntegrable f volume a b := by
    -- Assuming f is continuous, it is interval integrable
    apply Continuous.intervalIntegrable
    exact continuous_const.add continuous_id
    <;>
    simp_all
    <;>
    (try assumption)
    <;>
    (try norm_num)
    <;>
    (try linarith)
  
  have h₁ : IntervalIntegrable g volume a b := by
    -- Assuming g is continuous, it is interval integrable
    apply Continuous.intervalIntegrable
    exact continuous_const.add continuous_id
    <;>
    simp_all
    <;>
    (try assumption)
    <;>
    (try norm_num)
    <;>
    (try linarith)
  
  have h₂ : IntervalIntegrable (fun x => f x + g x) volume a b := by
    -- The sum of two interval integrable functions is interval integrable
    have h₃ : IntervalIntegrable (fun x => f x + g x) volume a b :=
      h₀.add h₁
    exact h₃
  
  calc
    (∫ x in a..b, (f x + g x)) = (∫ x in a..b, (f x + g x)) := rfl
    _ = (∫ x in a..b, f x) + (∫ x in a..b, g x) := by
      -- Using the linearity of the integral
      apply intervalIntegral.integral_add
      <;>
      (try assumption)
      <;>
      (try simp_all)
      <;>
      (try norm_num)
      <;>
      (try linarith)
