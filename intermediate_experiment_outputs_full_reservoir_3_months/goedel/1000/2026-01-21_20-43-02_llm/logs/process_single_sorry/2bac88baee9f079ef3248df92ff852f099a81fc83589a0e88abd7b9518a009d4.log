    have h3 : ((-1 : ℝ) * x) ^ (2 * n + 1) = - (x ^ (2 * n + 1)) := by
      have h4 : ((-1 : ℝ) * x) ^ (2 * n + 1) = (-1 : ℝ) ^ (2 * n + 1) * x ^ (2 * n + 1) := by
