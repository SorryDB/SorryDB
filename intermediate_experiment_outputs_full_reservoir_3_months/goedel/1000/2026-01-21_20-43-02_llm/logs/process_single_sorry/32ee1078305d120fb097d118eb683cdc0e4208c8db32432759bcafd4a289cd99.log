theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ.
    intro h
    have h₁ : ∃ (f : U → ℕ), Function.Injective f := by
      -- Use the fact that U is countable to get an injective function to ℕ.
      have h₂ : Nonempty (U ↪ ℕ) := by
        -- Since U is countable, there exists an embedding from U to ℕ.
        have h₃ : ctble U := h
        exact h₃
      -- Obtain the injective function from the embedding.
      obtain ⟨f⟩ := h₂
      refine' ⟨f, _⟩
      exact f.injective
    -- Extract the injective function from the existence statement.
    obtain ⟨f, hf⟩ := h₁
    exact ⟨f, hf⟩
  · -- Prove the reverse direction: if there exists an injective function from U to ℕ, then U is countable.
    intro h
    -- Obtain the injective function from the existence statement.
    obtain ⟨f, hf⟩ := h
    -- Use the injective function to show that U is countable.
    have h₁ : ctble U := by
      -- Use the fact that an injective function to ℕ implies countability.
      have h₂ : Nonempty (U ↪ ℕ) := by
        -- Construct an embedding from U to ℕ using the injective function.
        refine' ⟨{ toFun := f, injective := _ }⟩
        -- Prove that the function is injective.
        intro a b h₃
        apply hf
        simpa using h₃
      -- Since there exists an embedding, U is countable.
      exact h₂
    -- Conclude that U is countable.
    exact h₁
