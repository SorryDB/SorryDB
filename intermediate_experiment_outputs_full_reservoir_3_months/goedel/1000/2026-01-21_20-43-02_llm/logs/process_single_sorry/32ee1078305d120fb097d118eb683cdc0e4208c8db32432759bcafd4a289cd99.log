theorem ctble_set_of_ctble_type {U : Type}
    (h : ctble U) (A : Set U) : ctble A := by
  have h₁ : Set.Inhabited (⊤ : Set U) := by
    exact ⟨Classical.choice (by
      -- Prove that the top set is inhabited.
      have h₂ : Nonempty U := by
        by_contra h₃
        have h₄ : IsEmpty U := by
          exact isEmpty_iff.mpr (by simpa using h₃)
        simp_all [ctble_iff_nonempty_fintype, h]
      cases' h₂ with x
      exact ⟨x⟩
    )⟩

  -- Use the fact that any subset of a countable set is countable.
  have h₂ : ctble A := by
    -- Since U is countable and A is a subset of U, A is also countable.
    have h₃ : A ⊆ (⊤ : Set U) := by
      intro x hx
      simp_all
    -- Use the fact that any subset of a countable set is countable.
    have h₄ : ctble (⊤ : Set U) := by
      simpa [ctble_iff_nonempty_fintype] using h
    -- Use the fact that any subset of a countable set is countable.
    exact h₄.mono h₃
  exact h₂
