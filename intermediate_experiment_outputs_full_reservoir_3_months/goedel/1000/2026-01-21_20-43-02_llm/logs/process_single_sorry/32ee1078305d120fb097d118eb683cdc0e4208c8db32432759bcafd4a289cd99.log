```lean
theorem ctble_set_of_ctble_type {U : Type}
    (h : ctble U) (A : Set U) : ctble A := by
  have h₁ : ctble (A : Set U) := by
    -- Since U is countable, A is a subset of U and hence also countable.
    have h₂ : (A : Set U) ⊆ (⊤ : Set U) := by simp [Set.subset_def]
    exact Set.countable.mono h₂ h
