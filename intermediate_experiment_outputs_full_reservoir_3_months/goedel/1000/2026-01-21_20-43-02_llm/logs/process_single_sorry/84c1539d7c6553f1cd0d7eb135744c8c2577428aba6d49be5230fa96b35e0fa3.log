namespace BST1

example {α : Type} (t : Tree α) :
  t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  apply And.intro
  {
   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     <;>
     (try omega)
     <;>
     (try omega)
     <;>
     (try
       {
         cases' le_total t₁.height t₂.height with h h <;>
         simp_all [max_eq_right, max_eq_left] <;>
         nlinarith
       })
  }
  {
  induction t with
  | null => simp [Tree.height, Tree.size]
  | node t₁ x t₂ ihl ihr =>
    simp [Tree.height, Tree.size]
    have h₁ : t₁.size < 2 ^ t₁.height := ihl
    have h₂ : t₂.size < 2 ^ t₂.height := ihr
    have h₃ : 2 ^ t₁.height + 2 ^ t₂.height + 1 ≤ 2 ^ (1 + max t₁.height t₂.height) := by
      cases' le_total t₁.height t₂.height with h h <;>
      simp_all [max_eq_right, max_eq_left, pow_add, pow_one, mul_comm, mul_assoc, mul_left_comm]
      <;>
      (try
        {
          have h₄ : 2 ^ t₁.height ≤ 2 ^ t₂.height := pow_le_pow_right (by norm_num) h
          nlinarith
        })
      <;>
      (try
        {
          have h₄ : 2 ^ t₂.height ≤ 2 ^ t₁.height := pow_le_pow_right (by norm_num) h
          nlinarith
        })
    have h₄ : 1 + t₁.size + t₂.size < 2 ^ (1 + max t₁.height t₂.height) := by
      calc
        1 + t₁.size + t₂.size < 1 + 2 ^ t₁.height + 2 ^ t₂.height := by
          gcongr <;>
          (try omega)
        _ ≤ 2 ^ (1 + max t₁.height t₂.height) := by
          linarith [h₃]
    exact h₄
  }
