  intro n f hf h₀ h₁
  have h₂ : f (n + 1) = n + 1 := h₁
  have h₃ : ∀ m : ℕ, f m = m := by
    intro m
    have h₄ : ∀ m : ℕ, f m = m := by
      intro m
      induction m with
      | zero => simp [h₀]
      | succ m ih =>
        have h₅ := hf (by linarith : m ≤ m + 1)
        simp [ih] at h₅
        have h₆ := hf (by linarith : m + 1 ≤ m + 1 + 1)
        simp [h₅] at h₆
