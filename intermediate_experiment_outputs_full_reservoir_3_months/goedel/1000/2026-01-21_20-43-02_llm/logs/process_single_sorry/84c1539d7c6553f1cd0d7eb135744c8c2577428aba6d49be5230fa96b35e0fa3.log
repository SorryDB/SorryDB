```lean
theorem size_bound : ∀ (t : Tree α), t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  intro t
  have h₁ : t.height ≤ t.size := by
    -- Prove that the height is less than or equal to the size of the tree
    induction t using Tree.induction with
    | empty => simp
    | node t₁ x t₂ ih₁ ih₂ =>
      simp_all [Tree.height, Tree.size, max_le_iff]
      <;>
      (try omega) <;>
      (try
        {
          cases t₁ <;> cases t₂ <;> simp_all [Tree.height, Tree.size, max_le_iff] <;> omega
        }) <;>
      (try
        {
          cases' le_total (t₁.height) (t₂.height) with h h <;>
          simp_all [max_eq_right, max_eq_left] <;>
          (try omega) <;>
          (try nlinarith)
        })
  have h₂ : t.size < 2 ^ t.height := by
    -- Prove that the size is less than 2 raised to the power of the height
    induction t using Tree.induction with
    | empty => simp
    | node t₁ x t₂ ih₁ ih₂ =>
      have h₃ : t₁.height < t₁.height + 1 := by
        omega
      have h₄ : t₂.height < t₂.height + 1 := by
        omega
      have h₅ : 2 ^ t₁.height > 0 := by
        apply pow_pos
        norm_num
      have h₆ : 2 ^ t₂.height > 0 := by
        apply pow_pos
        norm_num
      have h₇ : t₁.size < 2 ^ t₁.height := ih₁
      have h₈ : t₂.size < 2 ^ t₂.height := ih₂
      simp [Tree.size, Tree.height, max_lt_iff] at *
      <;>
      (try omega) <;>
      (try
        {
          cases' lt_or_le (t₁.height) (t₂.height) with h h <;>
          (try omega) <;>
          (try simp_all [max_eq_left, max_eq_right, pow_add, pow_one, mul_add, mul_one]) <;>
          (try
            {
              nlinarith [pow_pos (by norm_num : (0 : ℕ) < 2) t₁.height,
                pow_pos (by norm_num : (0 : ℕ) < 2) t₂.height]
            })
        }) <;>
      (try
        {
          nlinarith [pow_pos (by norm_num : (0 : ℕ) < 2) t₁.height,
            pow_pos (by norm_num : (0 : ℕ) < 2) t₂.height]
        })
  exact ⟨h₁, h₂⟩
end
``` 

