o re-express our goal to match this:\n                  -- We need to prove that 1 + 2^(h + 1) < 2^(1 + h + 1).\n                  -- Simplifying the right side: 2^(1 + h + 1) = 2^(h + 2) = 2^(h + 1) * 2 = 2^(h + 1) + 2^(h + 1).\n                  -- Now, since 2^(h + 1) > 1 for any h ≥ 0, we have 2^(h + 1) + 2^(h + 1) > 1 + 2^(h + 1).\n                  -- Thus, 1 + 2^(h + 1) < 2^(h + 2).\n                  -- Now we can adjust our proof to use this fact:\n                  have h₁₉ : 1 + 2 ^ (max t₁.height t₂.height + 1) < 2 ^ (1 + (max t₁.height t₂.height + 1)) := by\n                    have h₂₀ : 2 ^ (1 + (max t₁.height t₂.height + 1)) = 2 ^ (max t₁.height t₂.height + 2) := by\n                      ring_nf\n                      <;> simp [add_assoc]\n                      <;> ring_nf\n                    have h₂₁ : 2 ^ (max t₁.height t₂.height + 2) = 2 ^ (max t₁.height t₂.height + 1) + 2 ^ (max t₁.height t₂.height + 1) := by\n                      calc\n                        2 ^ (max t₁.height t₂.height + 2) = 2 ^ (max t₁.height t₂.height + 1 + 1) := by ring_nf\n                        _ = 2 ^ (max t₁.height t₂.height + 1) * 2 := by\n                          rw [pow_succ]\n                          <;> ring_nf\n                        _ = 2 ^ (max t₁.height t₂.height + 1) + 2 ^ (max t₁.height t₂.height + 1) := by\n                          have h₂₂ : 2 ^ (max t₁.height t₂.height + 1) * 2 = 2 ^ (max t₁.height t₂.height + 1) + 2 ^ (max t₁.height t₂.height + 1) := by\n                            ring\n                          rw [h₂₂]\n                    have h₂₂ : 1 + 2 ^ (max t₁.height t₂.height + 1) < 2 ^ (max t₁.height t₂.height + 1) + 2 ^ (max t₁.height t₂.height + 1) := by\n                      have h₂₃ : 1 < 2 ^ (max t₁.height t₂.height + 1) := by\n                        apply Nat.one_lt_pow\n                        <;> simp_all [Nat.zero_le]\n                        <;> omega\n                      omega\n                    linarith\n                  omega\n              <;> simp_all [Nat.add_assoc]\n              <;> linarith\n            linarith\n          <;> simp_all [Nat.add_assoc]\n          <;> linarith\n        omega\n    exact h₁",
