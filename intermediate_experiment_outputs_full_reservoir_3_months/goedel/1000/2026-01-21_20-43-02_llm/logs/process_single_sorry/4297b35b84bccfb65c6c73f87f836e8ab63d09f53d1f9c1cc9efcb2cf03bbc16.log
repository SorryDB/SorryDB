theorem zwane : ∀ (m : ℕ), m % 2 = 0 → m % 4 = 0 ∨ m % 4 = 2 := by
  intro m h
  have h₁ : m % 4 = 0 ∨ m % 4 = 2 := by
    have h₂ : m % 4 = 0 ∨ m % 4 = 1 ∨ m % 4 = 2 ∨ m % 4 = 3 := by
      have : m % 4 < 4 := Nat.mod_lt m (by norm_num)
      omega
    have h₃ : m % 4 = 0 ∨ m % 4 = 2 := by
      rcases h₂ with (h₂ | h₂ | h₂ | h₂)
      · exact Or.inl h₂
      · exfalso
        have h₄ : m % 2 = 1 := by
          have h₅ : m % 4 = 1 := h₂
          have h₆ : m % 2 = 1 := by
            omega
          exact h₆
        omega
      · exact Or.inr h₂
      · exfalso
        have h₄ : m % 2 = 1 := by
          have h₅ : m % 4 = 3 := h₂
          have h₆ : m % 2 = 1 := by
            omega
          exact h₆
        omega
    exact h₃
  exact h₁
```
