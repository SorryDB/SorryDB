      have h₅ : (S.filter (fun c => isInitialCall S c) ++ S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c)) ++ S.filter (fun c => isFinalCall S c)).length = S.length := by
        rw [h₄]
      have h₆ : (S.filter (fun c => isInitialCall S c) ++ S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c)) ++ S.filter (fun c => isFinalCall S c)).length = (S.filter (fun c => isInitialCall S c)).length + (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => isFinalCall S c)).length := by
