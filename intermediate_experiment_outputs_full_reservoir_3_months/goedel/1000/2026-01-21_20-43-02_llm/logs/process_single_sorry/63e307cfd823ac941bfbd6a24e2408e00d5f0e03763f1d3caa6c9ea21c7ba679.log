    have h₂ : initPart.length + midPart.length + finalPart.length = (S.filter (fun c => isInitialCall S c)).length + (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => isFinalCall S c)).length := by
      rfl
    have h₃ : (S.filter (fun c => isInitialCall S c)).length + (S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))).length + (S.filter (fun c => isFinalCall S c)).length = S.length := by
      have h₄ : S.filter (fun c => isInitialCall S c) ++ S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c)) ++ S.filter (fun c => isFinalCall S c) = S := by
        apply List.ext_get
