      "\n  have h₄ : x ^ 2 = (35 : ℝ) / 6 := by\n    norm_num at h₀ h₁ h₂ h₃ ⊢\n    <;>\n    (try norm_num at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try ring_nf at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try linarith) <;>\n    (try nlinarith) <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n    <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n    <;>\n    (try nlinarith)\n    <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n  \n  have h₅ : y ^ 2 = (35 : ℝ) / 6 := by\n    norm_num at h₀ h₁ h₂ h₃ ⊢\n    <;>\n    (try norm_num at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try ring_nf at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try linarith) <;>\n    (try nlinarith) <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n    <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n    <;>\n    (try nlinarith)\n    <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n  \n  have h₆ : z ^ 2 = (35 : ℝ) / 6 := by\n    norm_num at h₀ h₁ h₂ h₃ ⊢\n    <;>\n    (try norm_num at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try ring_nf at h₀ h₁ h₂ h₃ ⊢) <;>\n    (try linarith) <;>\n    (try nlinarith) <;>\n    (try\n      {\n        nlinarith [sq_nonneg (x ^ 2 - 35 / 6), sq_nonneg (y ^ 2 - 35 / 6),\n          sq_nonneg (z ^ 2 - 35 / 6), sq_nonneg (w ^ 2 - 35 / 6)]\n      })\n    <;>\n    (try\n      {\n        nlinarith [sq_non