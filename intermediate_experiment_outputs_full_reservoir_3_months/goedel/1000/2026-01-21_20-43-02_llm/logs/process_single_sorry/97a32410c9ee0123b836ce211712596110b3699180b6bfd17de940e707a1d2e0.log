theorem cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h₁ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
    calc
      (cfc_toComplexMeasure ha x y).variation Set.univ = ‖cfc_toLinearFunctional ha x y‖ := by
        -- The total variation of the measure is equal to the norm of the linear functional.
        rw [ComplexRMK.variation_rietzMeasure]
        <;> norm_cast
      _ ≤ ‖x‖ * ‖y‖ := by
        -- The norm of the linear functional is bounded by ‖x‖ * ‖y‖.
        exact cfc_toLinearFunctional_bound x y
      _ ≤ ‖x‖ₑ * ‖y‖ₑ := by
        -- Convert the norm bounds to extended non-negative real numbers.
        simp [ENNReal.ofReal_mul, ENNReal.ofReal_norm]
        <;>
        norm_cast
        <;>
        simp_all [norm_eq_abs]
        <;>
        linarith [norm_nonneg x, norm_nonneg y]
  exact h₁
