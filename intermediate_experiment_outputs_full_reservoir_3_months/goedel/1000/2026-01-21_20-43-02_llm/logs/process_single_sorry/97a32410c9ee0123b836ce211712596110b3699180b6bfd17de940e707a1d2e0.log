theorem cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h₁ : (cfc_toComplexMeasure ha x y).variation Set.univ = ‖cfc_toLinearFunctional ha x y‖ := by
    simp [ComplexRMK.rieszMeasure_variation]
  rw [h₁]
  have h₂ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
  have h₃ : ‖x‖ * ‖y‖ ≤ ‖x‖ₑ * ‖y‖ₑ := by
    simp [norm_eq_normEuclidean]
    <;>
    (try norm_cast) <;>
    (try simp_all [Real.norm_eq_abs, abs_mul, abs_of_nonneg, norm_nonneg]) <;>
    (try nlinarith) <;>
    (try ring_nf) <;>
    (try field_simp) <;>
    (try norm_num) <;>
    (try linarith)
  calc
    ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := h₂
    _ ≤ ‖x‖ₑ * ‖y‖ₑ := h₃
``` 

### Note
The above proof uses the fact that `‖x‖ * ‖y‖ ≤ ‖x‖ₑ * ‖y‖ₑ`, which follows from the definition of the norm in an inner product space and the properties of the Euclidean norm. The `simp` tactic is used to simplify expressions involving norms, and the inequalities are derived using basic arithmetic and properties of norms. The `calc` block is used to chain the inequalities together to reach the final result.
