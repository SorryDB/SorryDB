      -- Use the generalized Hölder's inequality for RCLike spaces
      have h₃ : ENNReal.HolderTriple p q r := h₁
      -- Simplify the expression using the properties of RCLike spaces
      simp_all [PiLp.norm_def, ENNReal.HolderTriple]
      <;>
      (try simp_all [ENNReal.le_ofReal])
