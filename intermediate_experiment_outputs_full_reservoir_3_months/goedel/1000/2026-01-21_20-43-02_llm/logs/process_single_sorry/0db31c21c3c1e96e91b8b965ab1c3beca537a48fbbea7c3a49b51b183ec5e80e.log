lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  have h : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
    have h₁ : HasLaw G G(V, p) P := hG
    have h₂ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
      -- Use the properties of the binomial random graph to show independence
      -- of edge membership for distinct edges.
      have h₃ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
        -- Since the graph is binomially random, the edge membership of different edges are independent.
        -- This follows directly from the product structure of the binomial measure.
        simp_all [IsBinomialRandom, HasLaw, binomialRandom_eq_map, Measure.map]
        <;>
