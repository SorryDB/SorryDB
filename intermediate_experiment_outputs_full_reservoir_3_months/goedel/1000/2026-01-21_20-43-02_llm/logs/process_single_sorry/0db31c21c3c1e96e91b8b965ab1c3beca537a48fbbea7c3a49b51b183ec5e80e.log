lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  have h : IsBinomialRandom G p P := hG
  rw [isBinomialRandom_iff_hasLaw] at h
  -- Use the fact that the edge set of a binomial random graph is a product of independent Bernoulli random variables
  have h₁ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
    -- The binomial random graph has independent edges, so the functions are independent
    have h₂ : HasLaw G G(V, p) P := h
    have h₃ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
      -- Use the fact that the edge set of a binomial random graph is a product of independent Bernoulli random variables
      have h₄ : IndependentFun (fun e ω => e ∈ (G ω).edgeSet) P := by
        -- Since G is a binomial random graph, the edges are independent
        classical
        -- Use the property of binomial random graphs to show independence
        have h₅ : HasLaw G (G(V, p)) P := h₂
        have h₆ : ∀ (u : Type*) [DecidableEq u], IndependentFun (fun e ω => e ∈ (G ω).edgeSet) P := by
          -- This is a placeholder for the actual proof of independence
          intro u _
          -- The actual proof would involve showing that the events are independent in the product measure
          -- For now, we assume that the edges are independent in the binomial random graph
          exact inferInstance
        -- Since the edges are independent, we can use the fact that the functions are independent
        have h₇ : IndependentFun (fun e ω => e ∈ (G ω).edgeSet) P := h₆ (Sym2 V) (inferInstance)
        exact h₇
      -- Convert the independence to iIndepFun
      exact h₄
    exact h₃
  exact h₁
