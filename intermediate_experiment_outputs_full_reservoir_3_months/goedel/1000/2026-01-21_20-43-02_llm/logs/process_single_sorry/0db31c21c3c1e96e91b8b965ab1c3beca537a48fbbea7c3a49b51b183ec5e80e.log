```lean
lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  haveI : IsProbabilityMeasure P := hG.1
  have h₂ : IsBinomialRandom G p P := hG
  have h₃ : HasLaw G (G(V, p)) P := h₂
  have h₄ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
    haveI : IsBinomialRandom G p P := hG
    have h₅ : HasLaw G (G(V, p)) P := h₃
    have h₆ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
      -- Use the fact that the random graph is binomial to show independence
      -- of edge membership across different edges
      have h₇ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
        -- Use the fact that the random graph is binomial to show independence
        -- of edge membership across different edges
        rw [← isBinomialRandom_iff_hasLaw] at hG
        have h₈ : HasLaw G (G(V, p)) P := hG
        -- Use the fact that the random graph is binomial to show independence
        -- of edge membership across different edges
        have h₉ : iIndepFun (fun e ω => e ∈ (G ω).edgeSet) P := by
          -- Use the fact that the random graph is binomial to show independence
          -- of edge membership across different edges
          have h₁₀ : EdgeSetIndependent P V G := by
            -- Use the fact that the random graph is binomial to show independence
            -- of edge membership across different edges
            exactEdgeSetIndependent_ofHasLawG(Vp)
          -- Use the fact that the random graph is binomial to show independence
          -- of edge membership across different edges
          exact h₁₀.iIndepFun_mem_edgeSet
        exact h₉
      exact h₇
    exact h₆
  exact h₄
```

