lemma IsBinomialRandom.iIndepFun_mem_edgeSet (hG : IsBinomialRandom G p P) :
    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  classical
  have h₁ : iIndepFun (fun e ω : Sym2 V ↦ e ∈ (G ω).edgeSet) P := by
    have h₂ : IsBernoulliOn edgeSet diagSetᶜ p G(V, p) := by
      exact isBernoulliOn_edgeSet_binomialRandom
    have h₃ : HasLaw G G(V, p) P := hG
    have h₄ : iIndepFun (fun e : Sym2 V => (fun ω => e ∈ (G ω).edgeSet)) P := by
      -- Use the property of the binomial random graph to show independence
      have h₅ : IsBernoulliOn edgeSet diagSetᶜ p G(V, p) := h₂
      have h₆ : HasLaw G G(V, p) P := h₃
      have h₇ : iIndepFun (fun e : Sym2 V => (fun ω => e ∈ (G ω).edgeSet)) P := by
        -- Use the fact that edgeSet is measurable and the binomial random graph property
        simpa using (iIndepFun.comp (h₅.iIndepFun) (h₆.mono fun x y hxy => by
          simp_all [Set.ext_iff, edgeSet_eq_iff]
          <;> aesop))
      exact h₇
    exact h₄
  -- Use the fact that the edgeSet is invariant under the choice of representation
  simpa using h₁.comp (by aesop)
