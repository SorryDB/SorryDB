    have h₄ : (w, w_1) ∈ @SimpleGraph.LoopWalk.darts V G w ih p_1 := left
    have h₅ : ∀ (d : V × V), d ∈ @SimpleGraph.LoopWalk.darts V G w ih p_1 → d.2 ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
      intro d h_d
