  intro n p h
  have h₁ : 0 ≤ n := by
    cases n <;> simp_all [Nat.le_succ]
    <;> omega
  have h₂ : p 0 := by
    have h₃ : 0 ≤ n := by omega
    specialize h 0 h₃
    exact h
  exact h₂
