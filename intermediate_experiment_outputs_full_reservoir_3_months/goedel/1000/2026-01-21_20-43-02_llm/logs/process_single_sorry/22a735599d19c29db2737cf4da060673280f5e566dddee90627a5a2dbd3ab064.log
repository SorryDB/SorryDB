    have h₄ : v = w_1 := h_u_v.2
    have h₅ : (w, w_1) ∈ @SimpleGraph.LoopWalk.darts V G w ih p_1 := h_darts
    have h₆ : ∀ (d : V × V), d ∈ @SimpleGraph.LoopWalk.darts V G w ih p_1 → d.1 ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
      intro d h_d
      have h₇ : d.1 ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
        have h₈ : d.1 ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
          -- Prove that the first element of each dart is in the support of the walk
          have h₉ : ∀ (p : @SimpleGraph.LoopWalk V G w ih) (d : V × V), d ∈ @SimpleGraph.LoopWalk.darts V G w ih p → d.1 ∈ @SimpleGraph.LoopWalk.support V G w ih p := by
            intro p d h_d
            induction p <;> simp_all [SimpleGraph.LoopWalk.support, SimpleGraph.LoopWalk.darts, List.mem_append, List.mem_singleton, List.mem_cons, Prod.fst]
            <;> aesop
          exact h₉ p_1 d h_d
