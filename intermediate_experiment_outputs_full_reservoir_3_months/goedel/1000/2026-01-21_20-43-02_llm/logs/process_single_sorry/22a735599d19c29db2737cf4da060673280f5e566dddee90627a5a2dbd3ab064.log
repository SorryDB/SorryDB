have h_support_lemma : w_1 ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
  have h_dart_in_darts : (w_1, w) ∈ @SimpleGraph.LoopWalk.darts V G w ih p_1 := by
    simp_all [SimpleGraph.LoopWalk.darts]
    <;>
    (try simp_all [SimpleGraph.LoopWalk.cons]) <;>
    (try aesop) <;>
    (try simp_all [List.cons, List.mem_cons]) <;>
    (try omega) <;>
    (try using in_lean_to_translating)
    <;>
    (try simp_all [List.cons, List.mem_cons])
  have h_dart_in_support : w ∈ @SimpleGraph.LoopWalk.support V G w ih p_1 := by
    induction p_1 with
    | nil => contradiction
    | cons _ p_1 => simp_all [SimpleGraph.LoopWalk.support, SimpleGraph.LoopWalk.darts]
      <;>
