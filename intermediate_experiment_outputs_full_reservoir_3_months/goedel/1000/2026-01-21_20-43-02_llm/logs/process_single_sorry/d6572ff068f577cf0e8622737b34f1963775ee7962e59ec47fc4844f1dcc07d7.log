/-- The map between products of isofibrations is an isofibration. -/
lemma binary_prod_map_fibrant {X Y X' Y' : K} {f : X ↠ Y} {g : X' ↠ Y'} :
    IsIsofibration (prod.map f.1 g.1) := by
  refine' (congr_arg (fun p : (X × X') ≃ (Y × Y') => p.val) (Equiv.prodCongr f.surjEq g.surjEq)).trans
    _
  -- Use the fact that the product of surjective equivalences is a surjective equivalence
  exact isIsofibration_congr'|(e : (Y × Y') ≃ (Y × Y'))⇒(by simpa using e.isEquiv.castToEquiv)|> e.congr_arg
    (inferInstance)
    (inferInstance)
``` 

