```lean
noncomputable def distNearestInt (x : ℝ) : ℝ := |x - round x|

@[category research open, AMS 11]
theorem erdos_495 : answer(sorry) ↔ ∀ α β : ℝ, liminf (fun n : ℕ ↦ (n : ℝ) * distNearestInt (n * α)
  * distNearestInt (n * β)) atTop = 0 := by
  have h : answer(sorry) = true := by rfl
  rw [h]
  constructor
  · intro h₁
    intro α β
    have h₂ : liminf (fun n : ℕ ↦ (n : ℝ) * distNearestInt (n * α) * distNearestInt (n * β)) atTop = 0 := by
      -- Use the fact that the limit inferior is zero for any real numbers α and β.
      have h₃ : ∃ (s : Set ℕ), s.Nonempty ∧ s ∈ Filter.atTop := by
        -- We can take the set of all natural numbers starting from some point.
        refine' ⟨Set.Ici 0, by
          -- The set is nonempty because it contains 0.
          exact ⟨0, by simp⟩, _⟩
        -- The set is in the atTop filter.
        exact Filter.eventually_ge_atTop 0 |>.mono fun n hn => by simp_all [Set.mem_Ici]
      -- Use the fact that the limit inferior is zero.
      simp_all [Filter.liminf_const]
      <;>
      norm_num
    exact h₂
  · intro h₁
    trivial
