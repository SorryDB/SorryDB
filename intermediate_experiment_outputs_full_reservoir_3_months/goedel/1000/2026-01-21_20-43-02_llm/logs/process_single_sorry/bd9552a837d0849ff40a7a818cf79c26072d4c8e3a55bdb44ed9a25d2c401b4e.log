theorem is_for_v_most {ι : Type*} [DecidableEq ι] {s : Set ι} [Infinite ι] :
    ∃ t : Set ι, t = {x} ∪ s ∧ t ≠ ∅ ∧ Filter.Tendsto (fun n : ℕ ↦ 1 : ℕ → ℕ) Filter.atTop (nhds 1) :=
  ⟨{x} ∪ s, by simp, by
    -- We need to show that {x} ∪ s is not empty.
    -- Since x is in {x} ∪ s, the union is not empty.
    have h : x ∈ ({x} : Set ι) := by simp
    have h₁ : x ∈ ({x} : Set ι) ∪ s := by simp [h]
    have h₂ : ({x} : Set ι) ∪ s ≠ ∅ := by
      intro h₃
      have h₄ : x ∈ ({x} : Set ι) ∪ s := h₁
      rw [h₃] at h₄
      exact Set.not_mem_empty x h₄
    exact h₂, by
    -- We need to show that the constant sequence 1 tends to 1 in the natural numbers.
    -- This is trivially true.
    simp [tendsto_const_nhds]
  ⟩
``` 

