variable {α nt : Type} {Prod : Finset α → Finset nt → Type} [Production α nt Prod]

def coerceWord {Z : Finset α} (w : Word Z) : Word α := w.map (fun t => t.val)

def coerceLang {Z : Finset α} (l : Language Z) : Language α := fun word => ∃ w, w ∈ l ∧ (coerceWord w = word)

instance {Z : Finset α} : CoeOut (Word Z) (Word α) where
  coe word := @coerceWord α Z word

instance {Z : Finset α} : CoeOut (Language Z) (Language α) where
  coe lang := @coerceLang α Z lang

theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  simp [coerceLang]
  <;>
  constructor <;>
  (try { intro h; exact ⟨w, h, rfl⟩ }) <;>
  (try { rintro ⟨w', h₁, h₂⟩; have h₃ : w' = w := by
      have h₄ : (coerceWord w' : Word α) = (coerceWord w : Word α) := by simpa [h₂] using h₂
      have h₅ : w' = w := by
        apply Word.ext
        intro i
        simp [coerceWord, Subtype.ext_iff] at h₄ ⊢
        <;>
        (try cases w' <;> cases w <;> simp_all [List.get]) <;>
        (try simp_all [List.get]) <;>
        (try aesop)
      exact h₅
    ; simp_all }) <;>
  aesop

theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∉ l ↔ coerceWord w ∉ coerceLang l := by
  have h₁ : w ∈ l ↔ coerceWord w ∈ coerceLang l := coerceLang_mem l
  have h₂ : w ∉ l ↔ coerceWord w ∉ coerceLang l := by
    constructor <;> intro h <;>
    (try { simp_all [not_iff_not] }) <;>
    (try { tauto }) <;>
    (try {
      by_contra h₃
      have h₄ : w ∈ l := by tauto
      contradiction
    }) <;>
    (try {
      by_contra h₃
      have h₄ : coerceWord w ∈ coerceLang l := by tauto
      have h₅ : w ∈ l := by
        have h₆ : coerceWord w ∈ coerceLang l := h₄
        have h₇ : w ∈ l := by
          simp [coerceLang] at h₆
          rcases h₆ with ⟨w', h₈, h₉⟩
          have h₁₀ : (coerceWord w' : Word α) = (coerceWord w : Word α) := by simpa [h₉] using h₉
          have h₁₁ : w' = w := by
            apply Word.ext
            intro i
            simp [coerceWord, Subtype.ext_iff] at h₁₀ ⊢
            <;>
            (try cases w' <;> cases w <;> simp_all [List.get]) <;>
            (try simp_all [List.get]) <;>
            (try aesop)
          simp_all
        exact h₇
      contradiction
    })
  exact h₂
