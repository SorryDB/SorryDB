```lean
def coerceWord {Z : Finset α} (w : Word Z) : Word α := w.map (fun t => t.val)

def coerceLang {Z : Finset α} (l : Language Z) : Language α := fun word => ∃ w, w ∈ l ∧ (coerceWord w = word)

instance {Z : Finset α} : CoeOut (Word Z) (Word α) where
  coe word := @coerceWord α Z word

instance {Z : Finset α} : CoeOut (Language Z) (Language α) where
  coe lang := @coerceLang α Z lang

theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · -- Prove the forward direction: if w ∈ l, then coerceWord w ∈ coerceLang l
    intro h
    -- Since w ∈ l, we can directly use it to show coerceWord w ∈ coerceLang l
    refine' ⟨w, h, _⟩
    <;> rfl
  · -- Prove the reverse direction: if coerceWord w ∈ coerceLang l, then w ∈ l
    intro h
    -- Extract the witness from the existential quantifier
    rcases h with ⟨w', hw', hword⟩
    -- Since coerceWord is injective, we can deduce w = w'
    have h : w = w' := by
      apply Word.ext
      intro i
      have h₁ := congr_arg (fun w => w.get i) hword
      simp [coerceWord, Word.get_map] at h₁ ⊢
      <;> aesop
    -- Substitute w' with w and use the fact that w' ∈ l to conclude w ∈ l
    rw [h] at hw'
    exact hw'

theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∉ l ↔ coerceWord w ∉ coerceLang l := by
  have h1 : w ∈ l ↔ coerceWord w ∈ coerceLang l := by
    apply coerceLang_mem
  constructor <;> intro h <;>
  (try cases h <;> simp_all) <;>
  (try tauto) <;>
  (try
    {
      simp_all [coerceLang, coerceWord, Language]
      <;> tauto
    })
``` 

### Explanation of `coerceLang_mem`
1. **Forward Direction (→)**:
   - Assume `w ∈ l`.
   - We need to show `coerceWord w ∈ coerceLang l`.
   - By definition of `coerceLang`, we need to find some `w' ∈ l` such that `coerceWord w' = coerceWord w`.
   - We can choose `w' = w` because `w ∈ l` and `coerceWord w = coerceWord w`.

2. **Reverse Direction (←)**:
   - Assume `coerceWord w ∈ coerceLang l`.
   - By definition of `coerceLang`, there exists `w' ∈ l` such that `coerceWord w' = coerceWord w`.
   - Since `coerceWord` is injective (as it is a map of words with injective character maps), we deduce `w = w'`.
   - Therefore, `w ∈ l` because `w' ∈ l`.

### Explanation of `coerceLang_not_mem`
