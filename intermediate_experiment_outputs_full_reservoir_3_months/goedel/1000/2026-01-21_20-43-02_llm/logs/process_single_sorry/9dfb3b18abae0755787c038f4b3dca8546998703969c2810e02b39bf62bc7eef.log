theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∉ l ↔ coerceWord w ∉ coerceLang l := by
  have h_injective : Function.Injective (coerceWord : Word Z → Word α) := by
    intro w₁ w₂ h
    have h₁ : (w₁ : Word α) = (w₂ : Word α) := by simpa [coerceWord] using h
    -- Since the coercion is injective on each symbol, the words must be equal
    have h₂ : w₁ = w₂ := by
      apply Word.ext
      intro i
      -- For each index i, the i-th symbol of w₁ and w₂ must be equal
      have h₃ : (w₁ : Word α).get i = (w₂ : Word α).get i := by
        rw [h₁]
      -- The coercion from Z to α is injective because Z is a subtype
      have h₄ : (w₁.get i : α) = (w₂.get i : α) := by simpa using h₃
      -- Since the coercion is injective, the original symbols are equal
      have h₅ : w₁.get i = w₂.get i := by
        cases w₁.get i with
        | mk x hx =>
          cases w₂.get i with
          | mk y hy =>
            simp_all [Subtype.ext_iff]
            <;> aesop
      -- Therefore, the words are equal
      exact h₅
    exact h₂
  
  have h_forward : w ∉ l → coerceWord w ∉ coerceLang l := by
    intro h_w_not_in_l
    -- Assume for contradiction that coerceWord w ∈ coerceLang l
    intro h_coerce_w_in_coerce_l
    -- By definition of coerceLang, there exists a word w' in l such that coerceWord w' = coerceWord w
    rcases h_coerce_w_in_coerce_l with ⟨w', h_w'_in_l, h_coerce_w'_eq_coerce_w⟩
    -- Since coerceWord is injective, w' = w
    have h_w'_eq_w : w' = w := by
      apply h_injective
      exact h_coerce_w'_eq_coerce_w
    -- Substitute w' = w into h_w'_in_l to get w ∈ l, which contradicts h_w_not_in_l
    rw [h_w'_eq_w] at h_w'_in_l
    exact h_w_not_in_l h_w'_in_l
  
  have h_backward : coerceWord w ∉ coerceLang l → w ∉ l := by
    intro h
    -- Assume for contradiction that w ∈ l
    intro h_w_in_l
    -- Then coerceWord w ∈ coerceLang l by definition of coerceLang
    have h_coerce_w_in_coerce_l : coerceWord w ∈ coerceLang l := by
      refine' ⟨w, h_w_in_l, _⟩
      <;> simp
    -- This contradicts the assumption that coerceWord w ∉ coerceLang l
    exact h h_coerce_w_in_coerce_l
  
  exact ⟨h_forward, h_backward⟩
