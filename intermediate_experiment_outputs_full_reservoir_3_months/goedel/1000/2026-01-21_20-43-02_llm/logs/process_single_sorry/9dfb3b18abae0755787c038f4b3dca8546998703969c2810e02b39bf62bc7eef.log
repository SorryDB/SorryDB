theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∉ l ↔ coerceWord w ∉ coerceLang l := by
  constructor
  · -- Prove the forward direction: if w ∉ l, then coerceWord w ∉ coerceLang l
    intro h
    intro h₂
    -- Assume for contradiction that coerceWord w ∈ coerceLang l
    obtain ⟨w', hw', hcoerce⟩ := h₂
    -- Since coerceWord w ∈ coerceLang l, there exists w' ∈ l such that coerceWord w' = coerceWord w
    have h₁ : w = w' := by
      -- Since the coercion function is injective, we have w = w'
      apply Word.ext
      intro i
      have h₃ := congr_arg (fun w => w.get i) hcoerce
      simp [coerceWord, Word.get_map] at h₃ ⊢
      <;> simp_all [Subtype.ext_iff]
      <;> aesop
    -- Substitute w = w' into the assumption w ∉ l to get a contradiction
    rw [h₁] at h
    exact h hw'
  · -- Prove the reverse direction: if coerceWord w ∉ coerceLang l, then w ∉ l
    intro h
    intro h₂
    -- Assume for contradiction that w ∈ l
    have h₃ : coerceWord w ∈ coerceLang l := by
      -- Since w ∈ l, coerceWord w ∈ coerceLang l by definition
      refine' ⟨w, h₂, _⟩
      rfl
    -- This contradicts the assumption coerceWord w ∉ coerceLang l
    exact h h₃
