```lean
theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  simp only [coerceLang, coerceWord, Set.mem_setOf_eq]
  constructor
  · -- Prove the forward direction: if w ∈ l, then coerceWord w ∈ coerceLang l
    intro h
    refine' ⟨w, h, _⟩
    rfl
  · -- Prove the backward direction: if coerceWord w ∈ coerceLang l, then w ∈ l
    rintro ⟨w', hw', h⟩
    have h₁ : w = w' := by
      -- Show that the coercion is injective, so w = w'
      have h₂ : (w : Word α) = (w' : Word α) := by
        simpa [coerceWord] using h
      -- Since the coercion is injective, w = w'
      exact by
        apply Word.ext
        intro i
        have h₃ := congr_arg (fun w => w.get? i) h₂
        simp [coerceWord] at h₃ ⊢
        <;>
        (try cases w.get? i <;> cases w'.get? i <;> simp_all [Option.injEq]) <;>
        (try aesop)
      <;>
      aesop
    -- Now we can conclude that w ∈ l
    rw [h₁] at *
    exact hw'
```

