instance {Z : Finset α} : CoeOut (Language Z) (Language α) where
  coe lang := @coerceLang α Z lang

/--Theorem: coerceWord and coerceLang respect the language membership relation.-/
theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor <;> intro h
  · -- Prove the forward direction: if w ∈ l, then coerceWord w ∈ coerceLang l
    refine' ⟨w, ⟨_, rfl⟩⟩ <;> simp_all [coerceLang, coerceWord]
    <;> aesop
  · -- Prove the backward direction: if coerceWord w ∈ coerceLang l, then w ∈ l
    rcases h with ⟨w', ⟨h₁, h₂⟩⟩
    simp_all [coerceWord, coerceLang]
    <;>
    (try aesop) <;>
    (try {
      have h₃ : w' = w := by
        simp_all [List.map]
        <;>
        (try aesop)
        <;>
        (try {
          induction w' <;> simp_all [List.map] <;> aesop
        })
        <;>
        (try {
          induction w <;> simp_all [List.map] <;> aesop
        })
      simp_all
    }) <;>
    (try {
      simp_all [List.map]
      <;>
      (try aesop)
      <;>
      (try {
        induction w' <;> simp_all [List.map] <;> aesop
      })
      <;>
      (try {
        induction w <;> simp_all [List.map] <;> aesop
      })
    }) <;>
    (try {
      simp_all [Finset.ext_iff]
      <;>
      aesop
    }) <;>
    (try {
      simp_all [Finset.mem_coe]
      <;>
      aesop
    }) <;>
    (try {
      simp_all [Subtype.ext_iff]
      <;>
      aesop
    })
    <;>
    aesop

theorem coerceLang_not_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∉ l ↔ coerceWord w ∉ coerceLang l := by
  constructor <;> intro h <;>
  (try simp_all [coerceLang_mem]) <;>
  (try tauto) <;>
  (try {
    by_contra h₁
    have h₂ : w ∈ l := by
      simp_all [coerceLang_mem]
      <;>
      tauto
    contradiction
  }) <;>
