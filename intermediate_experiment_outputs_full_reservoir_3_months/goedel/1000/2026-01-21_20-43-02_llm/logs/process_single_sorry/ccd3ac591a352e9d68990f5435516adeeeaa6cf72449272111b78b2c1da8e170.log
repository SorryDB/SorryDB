lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
  have h1 : biasedEnergyDiff net x i = biasedEnergy net (biasedUpdateState net x i) - biasedEnergy net x := rfl
  rw [h1]
  have h2 : biasedEnergy net (biasedUpdateState net x i) = biasedEnergy net (biasedUpdateState net x i) := rfl
  have h3 : biasedEnergy net x = biasedEnergy net x := rfl
  -- Compute the difference in energy
  simp only [biasedEnergy, localField, BiasedHopfieldNetwork.toHopfieldNetwork, toRealVector, Fin.sum_univ_succ]
  -- Simplify the expression using the definition of biasedUpdateState
  have h4 : (biasedUpdateState net x i i : SpinState) = if 0 < biasedLocalField net x i then ↑1 else if (biasedLocalField net x i : ℝ) < 0 then ↑(-1) else x i := by
    simp [biasedUpdateState, biasedLocalField]
    <;> split_ifs <;> simp_all [Fin.ext_iff]
    <;> norm_num
    <;> aesop
  -- Use the simplified expression to compute the energy difference
  have h5 : (biasedUpdateState net x i : HopfieldState n) = (Function.update x i (if 0 < biasedLocalField net x i then ↑1 else if (biasedLocalField net x i : ℝ) < 0 then ↑(-1) else x i)) := by
    simp [biasedUpdateState, biasedLocalField]
    <;> aesop
  -- Substitute the simplified expressions into the energy difference
  simp_all [h4, h5, Matrix.dotProduct, Finset.sum_sub_distrib, Finset.sum_add_distrib, Finset.mul_sum]
  <;> ring_nf
  <;> field_simp [Finset.sum_mul, Finset.mul_sum]
  <;> case_split (0 : ℝ) <;> simp_all [lt_irrefl, le_of_lt]
  <;> norm_num
  <;> linarith
