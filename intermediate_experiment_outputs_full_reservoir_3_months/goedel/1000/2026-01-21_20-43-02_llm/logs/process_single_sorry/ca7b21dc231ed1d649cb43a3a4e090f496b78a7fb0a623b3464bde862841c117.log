theorem is_dominant (k : ℕ) (h₁ : 0 < k) (h₂ : 0 < k) : IsDominant (n : ℕ) := by
  have h₃ : n > 0 := by linarith
  have h₄ : IsDominant(n) := by
    have h₅ : ∀ (a b : ℕ), a ≥ 1 → b ≥ 1 → (a : ℤ) ^ b ≥ 1 := by
      intro a b ha hb
      have h₅₁ : (a : ℤ) ≥ 1 := by exact_mod_cast ha
      have h₅₂ : (a : ℤ) ^ b ≥ 1 := by
        exact one_le_pow_of_one_le h₅₁ b
      exact h₅₂
    have h₆ : (n : ℤ) ^ n ≥ 1 := by
      have h₆₁ : n ≥ 1 := by linarith
      have h₆₂ : (n : ℤ) ^ n ≥ 1 := by
        exact one_le_pow_of_one_le (by exact_mod_cast h₆₁) n
      exact h₆₂
    have h₇ : (n : ℤ) ≥ 1 := by
      exact_mod_cast (by linarith)
    have h₈ : (n : ℕ) ≥ 1 := by linarith
    -- Use the fact that n^n ≥ 1 and n ≥ 1 to conclude that n is dominant.
    have h₉ : IsDominant(n) := by
      -- Prove that n is dominant by verifying the condition for n = 1 and n > 1.
      have h₁₀ : n ≥ 1 := by linarith
      have h₁₁ : n = 1 ∨ n > 1 := by
        omega
      cases h₁₁ with
      | inl h₁₁ =>
        -- If n = 1, then n is trivially dominant.
        simp_all [IsDominant]
        <;> norm_num
