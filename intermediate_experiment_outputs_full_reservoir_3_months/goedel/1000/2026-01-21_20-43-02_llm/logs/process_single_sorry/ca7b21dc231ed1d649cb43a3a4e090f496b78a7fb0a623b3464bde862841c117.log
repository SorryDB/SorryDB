    <;>
    ring_nf
    <;>
    norm_num
    <;>
    rfl
  
  have h_final : (a + b)^p % p = (a^p + b^p) % p := by
    have h₁ : (a + b) ^ p ≡ a ^ p + b ^ p [MOD p] := h_main
    have h₂ : (a + b) ^ p % p = (a ^ p + b ^ p) % p := by
      rw [Nat.ModEq] at h₁
      exact h₁
    exact h₂
  
  exact h_final
