theorem mod_prime_pow (a b : ℕ) (p : ℕ) (hp : Nat.Prime p) :
        (a + b)^p % p = (a^p + b^p) % p := by
  have h_main : (a + b)^p ≡ a^p + b^p [MOD p] := by
    haveI := Fact.mk hp
    simp [← ZMod.int_cast_eq_int_cast_iff, ← ZMod.eq_iff_modEq_nat]
    <;>
    norm_cast
    <;>
