theorem buildLayer_neverFails (α : Type) [inst : DecidableEq α]
    [inst_1 : SampleableType α] [(spec α).DecidableEq]
    (preexisting_cache : (spec α).QueryCache) (n : ℕ)
    (leaves : List.Vector α (2 ^ (n + 1))) : HasEvalSPMF.NeverFail
      ((simulateQ randomOracle (buildLayer α n leaves)).run preexisting_cache) := by
  simp_rw [buildLayer]
  simp only [range_def, eq_mp_eq_cast, cast_eq, bind_pure]
  -- We need to show that the `mmap` operation never fails because it applies `query` to each pair,
  -- and `query` is a never-failing operation.
  -- The `Vector.mmap` of a never-failing function is never-failing.
  induction n with
  | zero =>
    -- Base case: n = 0
    -- This case simplifies to checking a trivial operation.
    simp [Vector.get, List.Vector.ofFn, pow_one, pow_zero]
    <;>
    infer_instance
  | succ n ih =>
    -- Inductive step: assume the statement holds for n, prove for n + 1.
    simp_all [Vector.get, List.Vector.ofFn, pow_succ, mul_add, mul_one, mul_assoc]
    <;>
    infer_instance
