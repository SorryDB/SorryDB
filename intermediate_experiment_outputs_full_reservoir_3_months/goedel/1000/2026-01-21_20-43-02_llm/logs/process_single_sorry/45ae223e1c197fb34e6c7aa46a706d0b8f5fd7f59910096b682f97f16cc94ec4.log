      "\n      cases' le_or_lt 0 t with ht ht\n      · -- Case: t ≥ 0\n        have ht' : t ≥ 0 := ht\n        have h₅₁₁ : |t| = t := by rw [abs_of_nonneg ht']\n        have h₅₁₂ : |μ| ≥ 0 := abs_nonneg μ\n        have h₅₁₃ : t * x ≤ t * (μ + 2 * √v) := by\n          nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n        have h₅₁₄ : t * (μ + 2 * √v) ≤ t * (|μ| + 2 * √v) := by\n          cases' le_or_lt 0 μ with hμ hμ\n          · -- Subcase: μ ≥ 0\n            have hμ' : μ ≥ 0 := hμ\n            have hμ'' : |μ| = μ := abs_of_nonneg hμ'\n            rw [hμ'']\n            <;> nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n          · -- Subcase: μ < 0\n            have hμ' : μ < 0 := hμ\n            have hμ'' : |μ| = -μ := abs_of_neg hμ'\n            have h₅₁₆ : t * μ ≤ 0 := by\n              nlinarith [ht']\n            rw [hμ'']\n            <;> nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n        have h₅₁₅ : t * x ≤ t * (|μ| + 2 * √v) := by\n          linarith\n        have h₅₁₆ : |t| * (|μ| + 2 * √v) = t * (|μ| + 2 * √v) := by\n          rw [h₅₁₁]\n          <;> ring\n        linarith\n      · -- Case: t < 0\n        have ht' : t < 0 := ht\n        have h₅₁₁ : |t| = -t := by rw [abs_of_neg ht']\n        have h₅₁₂ : |μ| ≥ 0 := abs_nonneg μ\n        have h₅₁₃ : t * x ≤ t * (μ - 2 * √v) := by\n          nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n        have h₅₁₄ : t * (μ - 2 * √v) ≤ t * (-(|μ| + 2 * √v)) := by\n          cases' le_or_lt 0 μ with hμ hμ\n          · -- Subcase: μ ≥ 0\n            have hμ' : μ ≥ 0 := hμ\n            have hμ'' : |μ| = μ := abs_of_nonneg hμ'\n            have h₅₁₅ : t * μ ≤ 0 := by\n              nlinarith [ht']\n            have h₅₁₆ : t * (-μ) ≤ 0 := by\n              nlinarith [ht']\n            have h₅₁₇ : t * (μ - 2 * √v) ≤ t * (-μ) := by\n              nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n            have h₅₁₈ : t * (-μ) = t * (-(|μ| + 2 * √v) + 2 * √v) := by\n              rw [hμ'']\n              <;> ring\n            nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n          · -- Subcase: μ < 0\n            have hμ' : μ < 0 := hμ\n            have hμ'' : |μ| = -μ := abs_of_neg hμ'\n            have h₅₁₅ : t * μ > 0 := by\n              nlinarith [ht']\n            have h₅₁₆ : t * μ ≤ t * (-|μ|) := by\n              rw [hμ'']\n              <;> nlinarith [ht']\n            have h₅₁₇ : t * (μ - 2 * √v) ≤ t * (-|μ| - 2 * √v) := by\n              nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n            nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n        have h₅₁₅ : t * x ≤ t * (-(|μ| + 2 * √v)) := by\n          linarith\n        have h₅₁₆ : |t| * (|μ| + 2 * √v) = -t * (|μ| + 2 * √v) := by\n          rw [h₅₁₁]\n          <;> ring\n        have h₅₁₇ : t * x ≤ |t| * (|μ| + 2 * √v) := by\n          nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : (0 : ℝ) ≤ v)]\n        linarith\n    -- Use the fact that exp is increasing to conclude the inequality\n    have h₅₂ : Real.exp (t * x) ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by\n      apply Real.exp_le_exp.2\n      exact h₅₁\n    exact h₅₂\n  linarith\n  <;>\n  norm_num\n  <;>\n  linarith",
