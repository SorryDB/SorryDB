theorem integrable_exp_of_bounded
  (f : ℝ → ℝ) (X : Set ℝ) (M : ℝ)
  (hM : 0 < M)
  (hf : ∀ x ∈ X, |f x| ≤ M) :
  IntegrableOn f X :=
  calc
    IntegrableOn f X := by
      have h1 : ∀ x ∈ X, |f x| ≤ M := hf
      -- Apply the theorem that if the absolute value of a function is bounded, then the function is integrable on the set.
      refine' integrableOn_of_abs (hM.finite) _
      -- Use the fact that the absolute value of f is bounded by M to show that it is integrable.
      simpa [abs_of_nonneg (le_of_lt hM)] using h1
    _ = IntegrableOn f X := by rfl
```

