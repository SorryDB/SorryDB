      "\n  have h₁ : Measurable (fun (ω : WignerSpace n) ↦ (wignerMatrixMap' ω)) := by\n    apply Matrix.measurable_of\n    intro i j\n    have h₂ : Measurable (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) := by\n      by_cases h : i = j\n      · -- Case: i = j\n        have h₃ : (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) = (fun (ω : WignerSpace n) ↦ ω ⟨(i, i), le_refl i⟩) := by\n          funext ω\n          rw [wignerMatrixEntryFunction]\n          simp [h]\n          <;> aesop\n        rw [h₃]\n        exact measurable_pi (⟨(i, i), le_refl i⟩ : _)\n      · -- Case: i ≠ j\n        have h₃ : i < j ∨ j < i := by\n          cases' lt_or_gt_of_ne h with h₄ h₄\n          · exact Or.inl h₄\n          · exact Or.inr h₄\n        cases' h₃ with h₃ h₃\n        · -- Subcase: i < j\n          have h₄ : (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) = (fun (ω : WignerSpace n) ↦ ω ⟨(i, j), by exact le_of_lt h₃⟩) := by\n            funext ω\n            rw [wignerMatrixEntryFunction]\n            simp [h, h₃]\n            <;> aesop\n          rw [h₄]\n          exact measurable_pi (⟨(i, j), by exact le_of_lt h₃⟩ : _)\n        · -- Subcase: j < i\n          have h₄ : (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) = (fun (ω : WignerSpace n) ↦ ω ⟨(j, i), by exact le_of_lt h₃⟩) := by\n            funext ω\n            rw [wignerMatrixEntryFunction]\n            simp [h, h₃]\n            <;>\n            (try { contradiction }) <;>\n            (try { simp_all [lt_irrefl] }) <;>\n            (try { simp_all [lt_asymm] }) <;>\n            (try { aesop }) <;>\n            (try { omega })\n          rw [h₄]\n          exact measurable_pi (⟨(j, i), by exact le_of_lt h₃⟩ : _)\n    exact h₂\n  have h₂ : (wignerMatrixMap n) = (fun (ω : WignerSpace n) ↦ (wignerMatrixMap' ω)) := by\n    funext ω\n    rfl\n  rw [h₂]\n  exact h₁",
      "\n  have h : Continuous (wignerMatrixMap n) := by\n    -- Each entry is continuous because it's either a projection or a composition of projections with continuous functions.\n    sorry\n  exact h",
      "\n  have h₁ : Measurable (wignerMatrixMap n) := by\n    have h₂ : Continuous fun (m : Matrix (Fin n) (Fin n) ℝ) => m := by continuity\n    have h₃ : Continuous (fun (x : Matrix (Fin n) (Fin n) ℝ) => x) := by continuity\n    have h₄ : Measurable (wignerMatrixMap' : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) := by\n      apply Matrix.measurable_of\n      intro i j\n      by_cases h : i = j\n      · -- Case i = j\n        have h₅ : (fun (ω : WignerSpace n) => wignerMatrixEntryFunction ω i j) = fun ω => ω ⟨(i, i), by\n          exact le_refl i⟩ := by\n          funext ω\n          simp [wignerMatrixEntryFunction, h]\n          <;> aesop\n        rw [h₅]\n        apply measurable_pi\n        <;> simp\n      · -- Case i ≠ j\n        by_cases h₂ : i < j\n        · -- Subcase i < j\n          have h₃ : (fun (ω : WignerSpace n) => wignerMatrixEntryFunction ω i j) = fun ω => ω ⟨(i, j), by\n            exact le_of_lt h₂⟩ := by\n            funext ω\n            simp [wignerMatrixEntryFunction, h, h₂]\n            <;>\n            (try { contradiction }) <;>\n            (try { simp_all [lt_irrefl, lt_asymm] }) <;>\n            (try { aesop }) <;>\n            (try {\n              split_ifs at * <;>\n              simp_all [lt_irrefl, lt_asymm] <;>\n              (try { contradiction }) <;>\n              (try { aesop })\n            })\n          rw [h₃]\n          apply measurable_pi\n          <;> simp\n        · -- Subcase i ≥ j\n          have h₃ : j < i := by\n            have h₄ : ¬i < j := h₂\n            have h₅ : i ≠ j := h\n            have h₆ : j < i := by\n              omega\n            exact h₆\n          have h₄ : (fun (ω : WignerSpace n) => wignerMatrixEntryFunction ω i j) = fun ω => ω ⟨(j, i), by\n            exact le_of_lt h₃⟩ := by\n            funext ω\n            simp [wignerMatrixEntryFunction, h, h₂, h₃]\n            <;>\n            (try { contradiction }) <;>\n            (try { simp_all [lt_irrefl, lt_asymm] }) <;>\n            (try { aesop }) <;>\n            (try {\n              split_ifs at * <;>\n              simp_all [lt_irrefl, lt_asymm] <;>\n              (try { contradiction }) <;>\n              (try { aesop })\n            })\n          rw [h₄]\n          apply measurable_pi\n          <;> simp\n    -- Since the map from WignerSpace n to Matrix (Fin n) (Fin n) ℝ is measurable, and the identity map on Matrix (Fin n) (Fin n) ℝ is measurable, the composition is measurable.\n    have h₅ : (wignerMatrixMap n : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) = wignerMatrixMap' := by\n      funext ω\n      <;> rfl\n    rw [h₅]\n    exact h₄\n  exact h₁",
      "\n  -- We can use the fact that the matrix constructor is measurable\n  apply Measurable.of_ratio_le\n  <;> simp_all [WignerSpace, mefFiniteness, mefFinitenessMatrix]\n  <;>\n  (try\n    norm_num) <;>\n  (try\n    simp_all [Matrix.of_apply, mefFiniteness, mefFinitenessMatrix]) <;>\n  (try\n    norm_num) <;>\n  (try\n    simp_all [Matrix.of_apply, mefFiniteness, mefFinitenessMatrix]) <;>\n  (try\n    norm_num) <;>\n  (try\n    simp_all [Matrix.of_apply, mefFiniteness, mefFinitenessMatrix])\n  <;>\n  (try\n    aesop)",
      "\n   - In Lean, the measurable space on `WignerSpace n = Index n → ℝ` is the product space, so `ω ↦ ω p` is measurable for any `p`.\n\nBut Lean’s `Pi.measurable_iff_forall_measurable` expects a function `f : X → (i : I) → α i`, and we have `f : (Index n → ℝ) → (Fin n → Fin n → ℝ)`. \nTo apply this, we should fix `i j` and show that `ω ↦ (wignerMatrixMap' ω) i j` is measurable. \nBut we can use `Matrix.measurable`, which states that a function to `Matrix` is measurable iff all its entries are.\n\nAlternatively, we can see `Matrix (Fin n) (Fin n) ℝ` as `Fin n × Fin n → ℝ`, and use that a function to `Fin n × Fin n → ℝ` is measurable iff all its projections are measurable.\n\n**Alternative Approach:**\nSince `wignerMatrixMap' ω` is built from coordinate projections of `ω`, we can directly prove that each of its entries is measurable. \nWe will show that for any `i j : Fin n`, the function `(wignerMatrixMap' ω) i j` is measurable. \n\nLet’s break down `(wignerMatrixMap' ω) i j = wignerMatrixEntryFunction ω i j`:\n1. If `i = j`: it is `ω ⟨(i, i), le_refl i⟩`. \n   - The map `ω ↦ ω p` is measurable because it is a projection in the product space.\n2. If `i < j`: it is `ω ⟨(i, j), le_of_lt h_lt⟩`.\n   - Similarly, this is a projection.\n3. If `j < i`: it is `ω ⟨(j, i), le_of_lt h_gt⟩`.\n   - Again, a projection.\n\nBut the issue is that in Lean, `wignerMatrixEntryFunction ω i j` is defined with `if i = j then ... else if i < j then ... else ...`. \nTo prove that this is measurable, we need to consider the measurable sets where `i = j`, `i < j`, etc. \nHowever, in Lean, `i j : Fin n`, and `i = j`, `i < j`, etc. are just decidable conditions, so the `if` statements are fine. \n\nBut more importantly, in Lean, the function `wignerMatrixEntryFunction ω i j` is essentially `ω p` where `p` depends on `i` and `j`, because:\n1. If `i = j`, then `p = ⟨(i, i), le_refl i⟩`.\n2. If `i < j`, then `p = ⟨(i, j), le_of_lt h_lt⟩`.\n3. If `j < i`, then `p = ⟨(j, i), le_of_lt h_gt⟩`.\n\nBut in Lean, for `ω : Index n → ℝ`, the map `ω ↦ ω p` is measurable for any fixed `p`. \n\nHowever, the issue is that we cannot directly write `(wignerMatrixMap' ω) i j = ω p`, because the `p` depends on `i` and `j`. \n\nBut we can use the fact that `wignerMatrixEntryFunction ω i j` is equal to `ω p` for some `p`, and then use that the projections are measurable. \n\nBut perhaps a better way is to note that for any fixed `i j : Fin n`, the function `ω ↦ (wignerMatrixMap' ω) i j` is equal to `ω p` for some `p : Index n`, and thus is measurable.\n\nBut let’s think differently:\nThe `Matrix.measurable` lemma says that to prove that a function `f : X → Matrix n n ℝ` is measurable, it suffices to prove that for all `i j`, `fun x => f x i j` is measurable. \n\nTherefore, it suffices to show that for all `i j : Fin n`, the function `ω ↦ (wignerMatrixMap' ω) i j` is measurable. \n\nBut `(wignerMatrixMap' ω) i j = wignerMatrixEntryFunction ω i j`.\n\nSo, we need to show that for any fixed `i j`, the function `wignerMatrixEntryFunction ω i j : (Index n → ℝ) → ℝ` is measurable. \n\nBut `wignerMatrixEntryFunction ω i j` is equal to `ω p` for some `p : Index n`, depending on `i` and `j`. \n\nSpecifically:\n1. If `i = j`, then `p = ⟨(i, i), le_refl i⟩`.\n2. If `i < j`, then `p = ⟨(i, j), le_of_lt h_lt⟩`.\n3. If `j < i`, then `p = ⟨(j, i), le_of_lt h_gt⟩`.\n\nBut in all cases, there exists some `p : Index n` such that `wignerMatrixEntryFunction ω i j = ω p`. \n\nThus, the function `ω ↦ wignerMatrixEntryFunction ω i j` is just the projection map `ω ↦ ω p`, which is measurable. \n\nBut we can’t directly write this because the `p` depends on `i` and `j`. \n\nBut we can do a case analysis:\n- Case `i = j`: `wignerMatrixEntryFunction ω i j = ω ⟨(i, i), le_refl i⟩`, which is measurable as a projection.\n- Case `i < j`: `wignerMatrixEntryFunction ω i j = ω ⟨(i, j), le_of_lt h_lt⟩`, which is measurable as a projection.\n- Case `j < i`: `wignerMatrixEntryFunction ω i j = ω ⟨(j, i), le_of_lt h_gt⟩`, which is measurable as a projection.\n\nBut in Lean, the `if` statement is not a problem because `i` and `j` are fixed when considering `ω ↦ wignerMatrixEntryFunction ω i j`. \n\n**Formal Proof Sketch:**\n1. For each `i j : Fin n`, we need to prove that `fun ω => wignerMatrixEntryFunction ω i j` is measurable.\n   - This is because `Matrix.measurable` reduces the problem to checking entries.\n2. For each `i j`, we do a case distinction:\n   - If `i = j`, it’s a projection.\n   - If `i < j`, it’s a projection.\n   - If `j < i`, it’s a projection.\n   - The cases are exhaustive because `<` is a total order on `Fin n`.\n3. Projections are measurable because they are in the product σ-algebra.\n\nBut we don’t need to do a case distinction in Lean. Instead, we can note that for any `i j`, there exists some `p : Index n` such that `wignerMatrixEntryFunction ω i j = ω p`, because:\n- Either `i = j`, `i < j`, or `j < i`.\nBut Lean will not automatically find `p`, so it is better to use the `if` statement directly. \n\nBut in Lean, to prove that `fun ω => wignerMatrixEntryFunction ω i j` is measurable, we can:\n1. Note that `wignerMatrixEntryFunction ω i j` is either `ω p`, or a constant, or something else. But in our case, it is always `ω p` for some `p`.\n   - If `i = j`, then `wignerMatrixEntryFunction ω i j = ω ⟨(i, i), le_refl i⟩`.\n   - If `i < j`, then `wignerMatrixEntryFunction ω i j = ω ⟨(i, j), le_of_lt h_lt⟩`.\n   - If `j < i`, then `wignerMatrixEntryFunction ω i j = ω ⟨(j, i), le_of_lt h_gt⟩`.\n2. In each case, we get `ω p` for some `p`, hence measurable.\nBut to use this, we can do a case distinction on `i` and `j` in Lean, and use the fact that projections are measurable. \n\nAlternatively, perhaps we can use that the function is `ω p` for some `p`, and avoid case distinction by using classical logic. But it’s more straightforward to do the case distinction. \n\nAlternatively, we can use that `Finset.univ : Finset (Fin n × Fin n)` is finite and generate the σ-algebra by checking finitely many conditions. But this seems complicated. \n\nBut perhaps Lean’s `Matrix.measurable` is not directly applicable because `wignerMatrixMap'` is not of the form `X → Matrix n n ℝ`, but we can instead use the fact that `Matrix (Fin n) (Fin n) ℝ` is `(Fin n × Fin n) → ℝ`, and then use that `f : X → Y → Z` is measurable iff for each `y`, `x ↦ f x y` is measurable. \n\nBut perhaps better:\nIn Lean, the type `Matrix (Fin n) (Fin n) ℝ` is the same as `Fin n → Fin n → ℝ`. \nTo show that `f : X → (Fin n → Fin n → ℝ)` is measurable, it suffices to show that for all `i j : Fin n`, the function `x ↦",
      "\n  have h_main : Measurable (wignerMatrixMap n) := by\n    have h₁ : Measurable (fun ω : WignerSpace n => (Matrix.of (wignerMatrixEntryFunction ω))) := by\n      -- Prove that the function `wignerMatrixEntryFunction` is measurable\n      have h₂ : ∀ (i j : Fin n), Measurable (fun ω : WignerSpace n => wignerMatrixEntryFunction ω i j) := by\n        intro i j\n        -- Use the fact that each entry of the matrix is a measurable function\n        apply Measurable.piecewise _ _ _\n        · -- Case when i = j\n          apply Measurable.comp (measurable_pi_apply _ _) (by continuity)\n          -- Use the measurability of the function from WignerSpace to ℝ\n        · -- Case when i < j\n          apply Measurable.comp (measurable_pi_apply _ _) (by continuity)\n          -- Use the measurability of the function from WignerSpace to ℝ\n        · -- Case when i > j\n          apply Measurable.comp (measurable_pi_apply _ _) (by continuity)\n          -- Use the measurability of the function from WignerSpace to ℝ\n      -- Use the fact that each entry is measurable to prove that the matrix is measurable\n      apply Matrix.measurableMatrix (fun i j => h₂ i j)\n    -- Use the fact that the matrix is measurable to prove that the function is measurable\n    have h₃ : (wignerMatrixMap n) = (fun ω : WignerSpace n => (Matrix.of (wignerMatrixEntryFunction ω))) := by\n      funext ω\n      rfl\n    rw [h₃]\n    exact h₁\n  exact h_main",
      "\n  apply Measurable.of measurableSet_univ\n <;>\n  (try decide) <;>\n  (try\n    {\n      intros;\n      simp_all [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]\n      <;>\n      (try\n        {\n          apply Matrix.ext\n          intro i j\n          by_cases h : i = j <;> by_cases h' : i < j <;> simp_all [h, h']\n          <;>\n          (try\n            {\n              apply Continuous.measurable\n              continuity\n            })\n        })\n    }) <;>\n  (try\n    {\n      rfl\n    }) <;>\n  (try\n    {\n      aesop\n    })",
      "₁",
      "\n  rw [show (wignerMatrixMap n) = fun (x : WignerSpace n) ↦ Matrix.of (wignerMatrixEntryFunction x) from by\n    funext x\n    simp [wignerMatrixMap, wignerMatrixMap']]\n  have h : ∀ (i j : Fin n), (fun (x : WignerSpace n) ↦ wignerMatrixEntryFunction x i j) =\n      (fun (x : WignerSpace n) ↦ x (if h_eq : i = j then ⟨(i, i), le_refl i⟩ else if h_lt : i < j then ⟨(i, j), le_of_lt h_lt⟩ else ⟨(j, i), le_of_lt (lt_of_le_of_ne (le_of_not_gt (by intro h; simp_all [not_lt])) (by intro h; simp_all [not_lt]))⟩)) := by\n    intro i j\n    funext x\n    simp [wignerMatrixEntryFunction]\n    <;> split_ifs <;>\n    (try {exfalso; simp_all [not_lt] <;> omega}) <;>\n    (try {simp_all [lt_irrefl, lt_asymm] <;> aesop}) <;>\n    (try {simp_all [lt_irrefl, lt_asymm] <;> rfl})\n  have h1 : Measurable (fun (x : WignerSpace n) ↦ Matrix.of (wignerMatrixEntryFunction x)) := by\n    -- Use the fact that each entry is measurable to show the matrix is measurable\n    refine' (Matrix.ofMeasurable _ _)\n    intro i j\n    have h2 : Measurable (fun (x : WignerSpace n) ↦ x (if h_eq : i = j then ⟨(i, i), le_refl i⟩ else if h_lt : i < j then ⟨(i, j), le_of_lt h_lt⟩ else ⟨(j, i), le_of_lt (lt_of_le_of_ne (le_of_not_gt (by intro h; simp_all [not_lt])) (by intro h; simp_all [not_lt]))⟩)) := by\n      -- Each coordinate function is measurable because it is a projection\n      apply measurable_pi\n    rw [h i j] at *\n    exact h2\n  exact h1",
      "\n  apply Matrix.measurable_of\n  intro i j\n  have h₁ : Measurable (fun (ω : Index n → ℝ) => (wignerMatrixEntryFunction ω i j)) := by\n    have h₂ : ∀ (i j : Fin n), Measurable (fun (ω : Index n → ℝ) => (wignerMatrixEntryFunction ω i j)) := by\n      intro i j\n      have h₃ : Measurable (fun (ω : Index n → ℝ) => (if h_eq : i = j then ω (⟨(i, i), le_refl i⟩) else if h_lt : i < j then ω (⟨(i, j), le_of_lt h_lt⟩) else ω (⟨(j, i), le_of_lt (by\n        have h₄ : j < i := by\n          by_cases h : i = j\n          · exfalso\n            simp_all\n          · have h₅ : i ≠ j := h\n            have h₆ : ¬(i < j) := by\n              intro h₆\n              simp_all\n            have h₇ : ¬(j < i) → False := by\n              intro h₇\n              simp_all [lt_trichotomy]\n            simp_all [lt_trichotomy]\n            <;>\n            (try omega) <;>\n            (try contradiction) <;>\n            (try aesop)\n          <;>\n          simp_all [lt_trichotomy]\n          <;>\n          (try omega) <;>\n          (try contradiction) <;>\n          (try aesop)\n        exact h₄\n        )⟩))) := by\n        -- Prove that each entry is measurable by considering the cases\n        have h₄ : Measurable (fun (ω : Index n → ℝ) => (if h_eq : i = j then ω (⟨(i, i), le_refl i⟩) else if h_lt : i < j then ω (⟨(i, j), le_of_lt h_lt⟩) else ω (⟨(j, i), le_of_lt (by\n          have h₅ : j < i := by\n            by_cases h : i = j\n            · exfalso\n              simp_all\n            · have h₆ : i ≠ j := h\n              have h₇ : ¬(i < j) := by\n                intro h₇\n                simp_all\n              have h₈ : ¬(j < i) → False := by\n                intro h₈\n                simp_all [lt_trichotomy]\n              simp_all [lt_trichotomy]\n              <;>\n              (try omega) <;>\n              (try contradiction) <;>\n              (try aesop)\n            <;>\n            simp_all [lt_trichotomy]\n            <;>\n            (try omega) <;>\n            (try contradiction) <;>\n            (try aesop)\n          exact h₅\n          )⟩))) := by\n          -- Use the fact that each projection is measurable\n          have h₅ : Measurable (fun (ω : Index n → ℝ) => (ω : Index n → ℝ)) := by\n            exact measurable_id\n          -- Use the fact that each projection is measurable\n          have h₆ : Measurable (fun (ω : Index n → ℝ) => (if h_eq : i = j then ω (⟨(i, i), le_refl i⟩) else if h_lt : i < j then ω (⟨(i, j), le_of_lt h_lt⟩) else ω (⟨(j, i), le_of_lt (by\n            have h₇ : j < i := by\n              by_cases h : i = j\n              · exfalso\n                simp_all\n              · have h₈ : i ≠ j := h\n                have h₉ : ¬(i < j) := by\n                  intro h₉\n                  simp_all\n                have h₁₀ : ¬(j < i) → False := by\n                  intro h₁₀\n                  simp_all [lt_trichotomy]\n                simp_all [lt_trichotomy]\n                <;>\n                (try omega) <;>\n                (try contradiction) <;>\n                (try aesop)\n              <;>\n              simp_all [lt_trichotomy]\n              <;>\n              (try omega) <;>\n              (try contradiction) <;>\n              (try aesop)\n            exact h₇\n            )⟩))) := by\n            -- Use the fact that each projection is measurable\n            apply measurable_if\n            · -- Case i = j\n              apply measurable_decidable\n            · -- Case i < j\n              intro h₁₁\n              apply measurable_if\n              · -- Subcase i < j\n                apply measurable_decidable\n              · -- Subcase i ≥ j\n                intro h₁₂\n                -- Here we use the fact that ω is measurable and the index set is finite\n                have h₁₃ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(j, i), le_of_lt (by\n                  have h₁₄ : j < i := by\n                    by_cases h : i = j\n                    · exfalso\n                      simp_all\n                    · have h₁₅ : i ≠ j := h\n                      have h₁₆ : ¬(i < j) := by\n                        intro h₁₆\n                        simp_all\n                      have h₁₇ : ¬(j < i) → False := by\n                        intro h₁₇\n                        simp_all [lt_trichotomy]\n                      simp_all [lt_trichotomy]\n                      <;>\n                      (try omega) <;>\n                      (try contradiction) <;>\n                      (try aesop)\n                    <;>\n                    simp_all [lt_trichotomy]\n                    <;>\n                    (try omega) <;>\n                    (try contradiction) <;>\n                    (try aesop)\n                  exact h₁₄\n                  )⟩)) := by\n                  -- Use the fact that each projection is measurable\n                  have h₁₈ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(j, i), le_of_lt (by\n                    have h₁₉ : j < i := by\n                      by_cases h : i = j\n                      · exfalso\n                        simp_all\n                      · have h₂₀ : i ≠ j := h\n                        have h₂₁ : ¬(i < j) := by\n                          intro h₂₁\n                          simp_all\n                        have h₂₂ : ¬(j < i) → False := by\n                          intro h₂₂\n                          simp_all [lt_trichotomy]\n                        simp_all [lt_trichotomy]\n                        <;>\n                        (try omega) <;>\n                        (try contradiction) <;>\n                        (try aesop)\n                      <;>\n                      simp_all [lt_trichotomy]\n                      <;>\n                      (try omega) <;>\n                      (try contradiction) <;>\n                      (try aesop)\n                    exact h₁₉\n                    )⟩)) := by\n                    -- Use the fact that each projection is measurable\n                    have h₂₃ : Measurable (fun (ω : Index n → ℝ) => (ω : Index n → ℝ)) := by\n                      exact measurable_id\n                    -- Use the fact that each projection is measurable\n                    have h₂₄ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(j, i), le_of_lt (by\n                      have h₂₅ : j < i := by\n                        by_cases h : i = j\n                        · exfalso\n                          simp_all\n                        · have h₂₆ : i ≠ j := h\n                          have h₂₇ : ¬(i < j) := by\n                            intro h₂₇\n                            simp_all\n                          have h₂₈ : ¬(j < i) → False := by\n                            intro h₂₈\n                            simp_all [lt_trichotomy]\n                          simp_all [lt_trichotomy]\n                          <;>\n                          (try omega) <;>\n                          (try contradiction) <;>\n                          (try aesop)\n                        <;>\n                        simp_all [lt_trichotomy]\n                        <;>\n                        (try omega) <;>\n                        (try contradiction) <;>\n                        (try aesop)\n                      exact h₂₅\n                      )⟩)) := by\n                      -- Use the fact that each projection is measurable\n                      apply h₂₃.comp (measurable_fst (⟨(j, i), _⟩ : Index n))\n                      <;>\n                      simp_all [Index]\n                      <;>\n                      aesop\n                    exact h₂₄\n                  exact h₁₈\n                exact h₁₃\n              · -- Subcase i ≥ j\n                intro h₁₁\n                -- Here we use the fact that ω is measurable and the index set is finite\n                have h₁₂ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(i, j), le_of_lt (by\n                  have h₁₃ : i < j := by\n                    simp_all\n                  exact h₁₃\n                  )⟩)) := by\n                  -- Use the fact that each projection is measurable\n                  have h₁₄ : Measurable (fun (ω : Index n → ℝ) => (ω : Index n → ℝ)) := by\n                    exact measurable_id\n                  -- Use the fact that each projection is measurable\n                  have h₁₅ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(i, j), le_of_lt (by\n                    have h₁₆ : i < j := by\n                      simp_all\n                    exact h₁₆\n                    )⟩)) := by\n                    -- Use the fact that each projection is measurable\n                    apply h₁₄.comp (measurable_fst (⟨(i, j), _⟩ : Index n))\n                    <;>\n                    simp_all [Index]\n                    <;>\n                    aesop\n                  exact h₁₅\n                exact h₁₂\n            · -- Case i ≠ j\n              intro h₁₂\n              -- Here we use the fact that ω is measurable and the index set is finite\n              have h₁₃ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(i, i), le_refl i⟩)) := by\n                -- Use the fact that each projection is measurable\n                have h₁₄ : Measurable (fun (ω : Index n → ℝ) => (ω : Index n → ℝ)) := by\n                  exact measurable_id\n                -- Use the fact that each projection is measurable\n                have h₁₅ : Measurable (fun (ω : Index n → ℝ) => ω (⟨(i, i), le_refl i⟩)) := by\n                  -- Use the fact that each projection is measurable\n                  apply h₁₄.comp (measurable_fst (⟨(i, i), _⟩ : Index n))\n                  <;>\n                  simp_all [Index]\n                  <;>\n                  aesop\n                exact h₁₅\n              exact h₁₃\n          exact h₆\n        exact h₄\n      -- Use the fact that each projection is measurable\n      exact h₃\n    -- Use the fact that each projection is measurable\n    exact h₂ i j\n  -- Use the fact that each projection is measurable\n  have h₂ : Measurable (fun (ω : Index n → ℝ) => (wignerMatrixEntryFunction ω i j)) := h₁\n  -- Use the fact that each projection is measurable\n  have h₃ : (wignerMatrixMap n) = (fun (ω : Index n → ℝ) => (wignerMatrixEntryFunction ω)) := by\n    funext ω\n    simp [wignerMatrixMap, wignerMatrixMap', Matrix.ext_iff]\n    <;>\n    aesop\n  -- Use the fact that each projection is measurable\n  rw [h₃]\n  -- Use the fact that each projection is measurable\n  exact h₂",
      "\n  have h₁ : Measurable (wignerMatrixMap' : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) := by\n    have h₂ : ∀ (i j : Fin n), Measurable (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) := by\n      intro i j\n      classical\n      rw [show (fun (ω : WignerSpace n) ↦ wignerMatrixEntryFunction ω i j) = (fun (ω : WignerSpace n) ↦ if h_eq : i = j then ω (⟨(i, i), le_refl i⟩) else if h_lt : i < j then ω (⟨(i, j), le_of_lt h_lt⟩) else ω (⟨(j, i), le_of_lt (by\n         have h : j < i := by\n           cases lt_or_le i j with\n           | inl h_lt => exfalso; simp_all\n           | inr h_le =>\n             cases lt_or_eq_of_le h_le with\n             | inl h_lt => exact h_lt\n             | inr h_eq => exfalso; simp_all\n         exact h\n      )⟩)) by\n        funext ω\n        rfl]\n      -- The above line shows that the function is indeed of the form we want.\n      -- Now, we can use the fact that the measurable functions are closed under if-then-else\n      -- to conclude that the function is measurable.\n      apply Measurable.ite\n      ·\n        -- Case: i = j\n        -- We need to show that the function ω ↦ ω(⟨(i, i), le_refl i⟩) is measurable.\n        -- Since ω ↦ ω(⟨(i, i), le_refl i⟩) is a projection, it is measurable.\n        apply Measurable.ite\n        ·\n          -- Subcase: i < j\n          -- We need to show that the function ω ↦ ω(⟨(i, j), le_of_lt h_lt⟩) is measurable.\n          -- Since ω ↦ ω(⟨(i, j), le_of_lt h_lt⟩) is a projection, it is measurable.\n          apply measurable_pi\n        ·\n          -- Subcase: ¬(i < j)\n          -- We need to show that the function ω ↦ ω(⟨(j, i), le_of_lt (by ... )⟩) is measurable.\n          -- Since ω ↦ ω(⟨(j, i), le_of_lt (by ... )⟩) is a projection, it is measurable.\n          apply measurable_pi\n        ·\n          -- The condition i < j is measurable\n          exact Measurable.of_measurable_of_le (measurable_const) (measurable_const) (fun _ ↦ by simp_all)\n      ·\n        -- The condition i = j is measurable\n        exact Measurable.of_measurable_of_eq (measurable_const) (measurable_const) (fun _ ↦ by simp_all)\n      ·\n        -- Case: ¬(i = j)\n        -- We further split into the cases i < j and ¬(i < j)\n        apply Measurable.of_measurable_of_lt (measurable_const) (measurable_const) (fun _ ↦ by\n          -- Prove that the order is total\n          cases le_or_lt i j <;> simp_all [lt_irrefl]\n          <;> try { contradiction }\n          <;> try { linarith }\n          <;> try { simp_all [lt_irrefl] }\n          )\n    -- Now, we use the fact that the matrix is defined by its entries and that each entry is measurable.\n    -- Therefore, the entire matrix is measurable.\n    have h₃ : Measurable (wignerMatrixMap' : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) := by\n      apply Matrix.measurableHom\n      intro i j\n      exact h₂ i j\n    exact h₃\n  -- Now, we can conclude that the function wignerMatrixMap n is measurable because it is a scalar multiplication of a measurable function.\n  have h₄ : Measurable (wignerMatrixMap n) := by\n    have h₅ : (wignerMatrixMap n : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) = (fun ω ↦ (1 / Real.sqrt (n : ℝ)) • wignerMatrixMap' ω) := by\n      funext ω\n      rfl\n    rw [h₅]\n    -- Since wignerMatrixMap' is measurable and scalar multiplication is measurable, the result is measurable.\n    have h₆ : Measurable (wignerMatrixMap' : WignerSpace n → Matrix (Fin n) (Fin n) ℝ) := h₁\n    -- Use the fact that the scalar multiplication is measurable to conclude that the composition is measurable.\n    have h₇ : Measurable (fun (ω : WignerSpace n) ↦ (1 / Real.sqrt (n : ℝ)) • wignerMatrixMap' ω) := by\n      have h₈ : Measurable (fun (ω : WignerSpace n) ↦ wignerMatrixMap' ω) := h₆\n      -- Use the property that scalar multiplication is measurable.\n      apply Continuous.measurable.comp h₈ (continuous_const.smul continuous_id)\n    exact h₇\n  exact h₄",
      "\n  have h : Measurable (wignerMatrixMap n) := by\n    -- Show that the function from WignerSpace n to Matrix (Fin n) (Fin n) ℝ is measurable.\n    -- Use the fact that the matrix entries are measurable.\n    refine' (infi measurable_const _).measurable\n    universal i j\n    simp only [wignerMatrixMap, wignerMatrixMap', Matrix.of_apply, wignerMatrixEntryFunction]\n    split_ifs <;>\n    (try { simp_all }) <;>\n    (try { measurable }) <;>\n    (try { -- Case: i = j\n      exact Measurable.comp (measurable_pi) (measurable_fst) }) <;>\n    (try { -- Case: i < j\n      exact Measurable.comp (measurable_pi) (measurable_fst) }) <;>\n    (try { -- Case: j < i\n      exact Measurable.comp (measurable_pi) (measurable_fst) }) <;>\n    (try {\n      -- Use the fact that the measure is defined on the entire space\n      exact Measurable.comp (measurable_pi) (measurable_fst)\n    })\n  exact h",
      "\n  have h₁ : Measurable (fun (ω : WignerSpace n) => wignerMatrixMap' ω) := by\n    -- Use the fact that the matrix entries are measurable functions of the sample\n    apply Measurable.of_bit0\n    -- Prove that each entry of the matrix is measurable\n    intro i j\n    -- Consider the case where i = j, i < j, or j < i\n    by_cases h : i = j\n    · -- Case i = j\n      simp_all [wignerMatrixEntryFunction, wignerMatrixMap', h]\n      <;>\n      (try simp_all [Matrix.of_apply, MeasurableFunction.comp_apply, Prod.mk.injEq]) <;>\n      (try measurability) <;>\n      (try\n        {\n          refine' (measurable_fst.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n        }) <;>\n      (try\n        {\n          refine' (measurable_snd.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n        }) <;>\n      (try\n        {\n          simp_all [Prod.ext_iff]\n          <;>\n          (try aesop)\n          <;>\n          (try\n            {\n              exact (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))\n            })\n        })\n      <;>\n      (try\n        {\n          exact measurable_const\n        })\n    · -- Case i ≠ j\n      by_cases h' : i < j\n      · -- Subcase i < j\n        simp_all [wignerMatrixEntryFunction, wignerMatrixMap', h, h']\n        <;>\n        (try simp_all [Matrix.of_apply, MeasurableFunction.comp_apply, Prod.mk.injEq]) <;>\n        (try measurability) <;>\n        (try\n          {\n            refine' (measurable_fst.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n          }) <;>\n        (try\n          {\n            refine' (measurable_snd.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n          }) <;>\n        (try\n          {\n            simp_all [Prod.ext_iff]\n            <;>\n            (try aesop)\n            <;>\n            (try\n              {\n                exact (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))\n              })\n          })\n        <;>\n        (try\n          {\n            exact measurable_const\n          })\n      · -- Subcase j < i\n        have h'' : j < i := by\n          have h''' : ¬i < j := h'\n          have h'''' : i ≠ j := h\n          have h''''' : j < i := by\n            cases' lt_or_gt_of_ne h'''' with h'''' h''''\n            · exfalso\n              exact h''' h''''\n            · exact h''''\n          exact h'''''\n        simp_all [wignerMatrixEntryFunction, wignerMatrixMap', h, h']\n        <;>\n        (try simp_all [Matrix.of_apply, MeasurableFunction.comp_apply, Prod.mk.injEq]) <;>\n        (try measurability) <;>\n        (try\n          {\n            refine' (measurable_fst.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n          }) <;>\n        (try\n          {\n            refine' (measurable_snd.comp (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))).measurable\n          }) <;>\n        (try\n          {\n            simp_all [Prod.ext_iff]\n            <;>\n            (try aesop)\n            <;>\n            (try\n              {\n                exact (measurable_subtype_val : Measurable (fun (p : Subtype (fun p : Fin n × Fin n => p.1 ≤ p.2)) => p.val))\n              })\n          })\n        <;>\n        (try\n          {\n            exact measurable_const\n          })\n  -- Use the measurability of the entries to prove the measurability of the matrix\n  exact h₁",
      "\n  have h₁ : ∀ (j : Fin n) (i : Fin n), Measurable (fun (ω : WignerSpace n) => wignerMatrixEntryFunction ω i j) := by\n    intro j i\n    have h₂ : Measurable (fun (ω : WignerSpace n) => wignerMatrixEntryFunction ω i j) := by\n      -- We need to show that the function ω ↦ wignerMatrixEntryFunction ω i j is measurable.\n      -- Since wignerMatrixEntryFunction is defined piecewise based on the comparison of i and j, we need to consider each case separately.\n      -- The function is constructed using the WignerSpace ω and the indices i and j, and it either returns ω (⟨(i, i), le_refl i⟩), ω (⟨(i, j), le_of_lt h_lt⟩), or ω (⟨(j, i), le_of_lt h_gt⟩).\n      -- Each of these cases is measurable because ω is a measurable function from WignerSpace n to ℝ and the indices are fixed.\n      -- The piecewise definition is based on decidable conditions (i = j, i < j, etc.), which are measurable.\n      -- Therefore, the overall function is measurable as a combination of measurable functions.\n      have h₃ : Measurable (fun (ω : WignerSpace n) => (if h_eq : (i : ℕ) = (j : ℕ) then ω ⟨(i, i), le_refl i⟩ else if h_lt : (i : ℕ) < (j : ℕ) then ω ⟨(i, j), le_of_lt h_lt⟩ else ω ⟨(j, i), le_of_lt (by\n        have h₄ : (j : ℕ) < (i : ℕ) := by\n          by_contra h\n          have h₅ : (i : ℕ) ≤ (j : ℕ) := by omega\n          have h₆ : (i : ℕ) ≠ (j : ℕ) := by\n            intro h₆\n            simp_all\n          have h₇ : (i : ℕ) < (j : ℕ) := by\n            omega\n          simp_all\n        exact h₄)⟩)) := by\n        -- We need to show that the piecewise function is measurable.\n        -- Each case is measurable because it is a composition of measurable functions.\n        -- The conditions (i = j, i < j, etc.) are decidable and thus measurable",
      "\n    rw [show (wignerMatrixMap n) = Matrix.of ∘ (fun ω => wignerMatrixEntryFunction ω) by\n      ext ω\n      <;> simp [wignerMatrixMap', wignerMatrixEntryFunction]\n      <;> rfl]\n    -- The composition of measurable functions is measurable.\n    apply Measurable.comp\n    · -- The function `Matrix.of` is measurable.\n      exact inferInstance\n    · -- The function `fun ω => wignerMatrixEntryFunction ω` is measurable.\n      -- This is because each entry of `wignerMatrixEntryFunction ω i j` is measurable in `ω`,\n      -- and the product of measurable functions is measurable.\n      exact inferInstance",
      "\n  have h₁ : Measurable (wignerMatrixMap n) := by\n    apply Measurable.of_stronglyMeasurable\n    exact stronglyMeasurable_matrix_of (fun i j ↦ ?_)\n    -- Prove that each entry is strongly measurable.\n    <;> simp [wignerMatrixMap, wignerMatrixMap']\n    <;>\n    (try\n      {\n        -- Each entry is either ω (⟨(i, i), _⟩), ω (⟨(i, j), _⟩), or ω (⟨(j, i), _⟩), which are measurable because ω is measurable.\n        apply stronglyMeasurable.comp (stronglyMeasurable_fst)\n        <;>\n        (try\n          {\n            -- Prove that the function (i, j) ↦ ⟨(i, j), _⟩ is measurable.\n            -- But perhaps it is not necessary, because the composition is already measurable if the inner function is measurable.\n            -- Alternatively, perhaps we can use that the projection ω ↦ ω p is measurable for each p.\n            -- But in Lean 4, WignerSpace n is Index n → ℝ, and the product space is given the product topology, so each projection is measurable.\n            -- Hence, for each p : Index n, the function ω ↦ ω p is measurable, and hence any finite combination of them is measurable.\n            -- Therefore, the entry is a finite combination of such functions, hence measurable.\n            -- But perhaps it is not necessary to go into all these details if we are allowed to use `apply` tactics.\n            -- Perhaps we can use `stronglyMeasurable_fst` because the composition is measurable.\n            exact stronglyMeasurable_const\n          })\n      })\n  exact h₁"
