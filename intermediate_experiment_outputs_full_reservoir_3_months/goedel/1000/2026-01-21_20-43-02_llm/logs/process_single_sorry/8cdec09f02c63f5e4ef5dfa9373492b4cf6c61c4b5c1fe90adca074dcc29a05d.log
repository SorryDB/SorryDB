    have h₂ : Measurable (fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω)) := by
      -- Each entry of the matrix is measurable.
      have h₃ : ∀ (i j : Fin n), Measurable fun (ω : WignerSpace n) => (Matrix.of (wignerMatrixEntryFunction ω) : Matrix (Fin n) (Fin n) ℝ) i j := by
        intro i j
        -- Show that each entry of the matrix is measurable.
        have h₄ : Measurable fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j : ℝ) := by
          -- Consider the cases for the position of the entry.
          by_cases h : i = j
          · -- Case: i = j
            have h₅ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j : ℝ)) = (fun (ω : WignerSpace n) => ω ⟨(i, i), le_refl i⟩) := by
              funext ω
              simp [wignerMatrixEntryFunction, h, eq_comm]
              <;>
              simp_all [Fin.ext_iff]
              <;>
              omega
            rw [h₅]
            -- The function is measurable because it is the projection of a measurable space.
            exact measurable_pi.1 (fun p : Index n => (by trivial))
          · -- Case: i ≠ j
            by_cases h₆ : i < j
            · -- Subcase: i < j
              have h₇ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j : ℝ)) = (fun (ω : WignerSpace n) => ω ⟨(i, j), h₆⟩) := by
                funext ω
                simp [wignerMatrixEntryFunction, h, h₆]
                <;>
                simp_all [Fin.ext_iff]
                <;>
                omega
              rw [h₇]
              -- The function is measurable because it is the projection of a measurable space.
              exact measurable_pi.1 (fun p : Index n => (by trivial))
            · -- Subcase: i > j
              have h₈ : j < i := by
                cases' lt_or_gt_of_ne h with h₉ h₉
                · exfalso
                  linarith
                · exact h₉
              have h₉ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j : ℝ)) = (fun (ω : WignerSpace n) => ω ⟨(j, i), h₈⟩) := by
                funext ω
                simp [wignerMatrixEntryFunction, h, h₆, h₈]
                <;>
                simp_all [Fin.ext_iff]
                <;>
                omega
              rw [h₉]
              -- The function is measurable because it is the projection of a measurable space.
              exact measurable_pi.1 (fun p : Index n => (by trivial))
        -- The matrix entry function is measurable.
        have h₅ : Measurable fun (ω : WignerSpace n) => (Matrix.of (wignerMatrixEntryFunction ω) : Matrix (Fin n) (Fin n) ℝ) i j := by
          convert h₄ using 1
          <;> simp [Matrix.of_apply]
        exact h₅
      -- Each entry of the matrix is measurable, so the matrix itself is measurable.
      have h₄ : Measurable (fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω)) := by
        apply Matrix.measurable_of_forall_measurable
        intro i j
        exact h₃ i j
      exact h₄
    -- The function is measurable because it is the composition of measurable functions.
    have h₅ : (wignerMatrixMap n) = (fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω)) := by
      funext ω
      simp [wignerMatrixMap, wignerMatrixMap']
      <;>
      congr
      <;>
      funext i j
      <;>
      simp [Matrix.of_apply, wignerMatrixEntryFunction]
    rw [h₅]
    exact h₂
  exact h₁
