      "\n  have h₁ : Measurable (fun ω : WignerSpace n ↦ wignerMatrixMap' ω) := by\n    -- Use the fact that the matrix is built from measurable projections\n    refine' Matrix.measurable _\n    intro i j\n    -- We need to show that for each (i, j), the matrix entry is measurable\n    have h₂ : Measurable (fun ω : WignerSpace n ↦ (wignerMatrixEntryFunction ω i j)) := by\n      classical\n      -- Case analysis on the position of i and j\n      by_cases h : i = j\n      · -- Case i = j\n        have h₃ : (fun ω : WignerSpace n ↦ (wignerMatrixEntryFunction ω i j)) = (fun ω : WignerSpace n ↦ ω (⟨(i, i), le_refl i⟩ : Index n)) := by\n          funext ω\n          simp [wignerMatrixEntryFunction, h]\n          <;> aesop\n        rw [h₃]\n        -- The projection ω ↦ ω p is measurable\n        exact measurable_pi.1 (by simp [measurable_const])\n      · -- Case i ≠ j\n        by_cases h' : i < j\n        · -- Case i < j\n          have h₃ : (fun ω : WignerSpace n ↦ (wignerMatrixEntryFunction ω i j)) = (fun ω : WignerSpace n ↦ ω (⟨(i, j), h'⟩ : Index n)) := by\n            funext ω\n            simp [wignerMatrixEntryFunction, h, h']\n            <;> aesop\n          rw [h₃]\n          -- The projection ω ↦ ω p is measurable\n          exact measurable_pi.1 (by simp [measurable_const])\n        · -- Case i > j\n          have h₃ : j < i := by\n            have h₄ : ¬i < j := h'\n            have h₅ : i ≠ j := h\n            -- Since i ≠ j and not i < j, then j < i\n            contrapose! h₅\n            apply le_antisymm\n            · -- i ≤ j\n              omega\n            · -- j ≤ i\n              omega\n          have h₄ : (fun ω : WignerSpace n ↦ (wignerMatrixEntryFunction ω i j)) = (fun ω : WignerSpace n ↦ ω (⟨(j, i), h₃⟩ : Index n)) := by\n            funext ω\n            simp [wignerMatrixEntryFunction, h, h', h₃]\n            <;>\n            (try omega) <;>\n            (try aesop) <;>\n            (try\n              {\n                simp_all [le_of_lt]\n                <;>\n                omega\n              })\n          rw [h₄]\n          -- The projection ω ↦ ω p is measurable\n          exact measurable_pi.1 (by simp [measurable_const])\n    -- Use the fact that the entry is measurable to conclude\n    simpa [wignerMatrixMap'] using h₂\n  -- The matrix is scaled by a fixed scalar, so it preserves measurability\n  have h₂ : Measurable (wignerMatrixMap n) := by\n    have h₃ : (wignerMatrixMap n) = (fun ω : WignerSpace n ↦ (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) := rfl\n    rw [h₃]\n    have h₄ : Measurable (fun ω : WignerSpace n ↦ (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) := by\n      -- Use the fact that scalar multiplication preserves measurability\n      have h₅ : Continuous (fun (x : Matrix (Fin n) (Fin n) ℝ) : Matrix (Fin n) (Fin n) ℝ => (1 / Real.sqrt (n : ℝ)) • x) := by\n        -- The scalar multiplication by a fixed scalar is continuous\n        continuity\n      -- Apply the fact that the composition of measurable and continuous functions is measurable\n      have h₆ : Measurable (wignerMatrixMap') := h₁\n      have h₇ : Measurable (fun ω : WignerSpace n ↦ (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) :=\n        h₆.comp h₅.measurable\n      exact h₇\n    exact h₄\n  exact h₂",
