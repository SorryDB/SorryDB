      "\n  have h : Measurable (wignerMatrixMap n) := by\n    have h₁ : Measurable (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω)) := by\n      -- Prove that the function constructing the matrix entries is measurable\n      have h₂ : ∀ (i j : Fin n), Measurable (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j)) := by\n        intro i j\n        -- Consider the three cases in the definition of wignerMatrixEntryFunction\n        by_cases h₃ : i = j\n        · -- Case: i = j\n          have h₄ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j)) = (fun (ω : WignerSpace n) => ω (⟨(i, i), le_refl i⟩ : Index n)) := by\n            funext ω\n            simp [wignerMatrixEntryFunction, h₃]\n            <;>\n            (try decide) <;>\n            (try simp_all [Fin.ext_iff]) <;>\n            (try aesop)\n          rw [h₄]\n          -- The projection map is measurable\n          apply measurable_pi\n          <;>\n          (try simp) <;>\n          (try aesop)\n        · -- Case: i ≠ j\n          by_cases h₄ : i < j\n          · -- Subcase: i < j\n            have h₅ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j)) = (fun (ω : WignerSpace n) => ω (⟨(i, j), by exact le_of_lt h₄⟩ : Index n)) := by\n              funext ω\n              simp [wignerMatrixEntryFunction, h₃, h₄]\n              <;>\n              (try decide) <;>\n              (try simp_all [Fin.ext_iff]) <;>\n              (try aesop)\n            rw [h₅]\n            -- The projection map is measurable\n            apply measurable_pi\n            <;>\n            (try simp) <;>\n            (try aesop)\n          · -- Subcase: j < i\n            have h₅ : j < i := by\n              have h₅₁ : ¬(i < j) := h₄\n              have h₅₂ : i ≠ j := h₃\n              have h₅₃ : i > j := by\n                cases' lt_or_gt_of_ne h₅₂ with h₅₄ h₅₄\n                · exfalso\n                  exact h₅₁ h₅₄\n                · exact h₅₄\n              exact h₅₃\n            have h₆ : (fun (ω : WignerSpace n) => (wignerMatrixEntryFunction ω i j)) = (fun (ω : WignerSpace n) => ω (⟨(j, i), by exact le_of_lt h₅⟩ : Index n)) := by\n              funext ω\n              simp [wignerMatrixEntryFunction, h₃, h₄, h₅]\n              <;>\n              (try decide) <;>\n              (try simp_all [Fin.ext_iff]) <;>\n              (try aesop)\n            rw [h₆]\n            -- The projection map is measurable\n            apply measurable_pi\n            <;>\n            (try simp) <;>\n            (try aesop)\n      -- The function constructing the matrix entries is measurable because each entry is measurable\n      refine' Measurable.of_forall_measurable₂ _ _\n      intro i j\n      exact h₂ i j\n    -- Use the measurability of the entry function to prove the measurability of the matrix map\n    have h₃ : Measurable (wignerMatrixMap n) := by\n      have h₄ : (wignerMatrixMap n) = (fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω)) := by\n        funext ω\n        rfl\n      rw [h₄]\n      -- Matrix.of is continuous, and the entries are measurable\n      apply Measurable.of_continuous _\n      continuity\n    exact h₃\n  exact h",
