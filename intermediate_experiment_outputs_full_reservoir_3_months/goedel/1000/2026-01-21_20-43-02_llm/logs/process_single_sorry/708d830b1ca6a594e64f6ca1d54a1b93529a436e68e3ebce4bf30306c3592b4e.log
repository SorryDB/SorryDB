def coerceLang {Z : Finset α} (l : Language Z) : Language α := fun word => ∃ w, w ∈ l ∧ (coerceWord w = word)

instance {Z : Finset α} : CoeOut (Word Z) (Word α) where
  coe word := @coerceWord α Z word

instance {Z : Finset α} : CoeOut (Language Z) (Language α) where
  coe lang := @coerceLang α Z lang

theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · intro h
    refine' ⟨w, h, _⟩
    <;> simp [coerceWord]
  · rintro ⟨w', hw', hw''⟩
    have h : w = w' := by
      have h₁ : coerceWord w = coerceWord w' := by
        simp_all [coerceWord]
      have h₂ : w = w' := by
        apply Word.ext
        intro i
        have h₃ := congr_arg (fun w => w.get i) h₁
        simp [coerceWord, List.get_map] at h₃
        <;> simp_all [Finset.mem_coe]
        <;> aesop
      exact h₂
    rw [h] at *
    exact hw'

