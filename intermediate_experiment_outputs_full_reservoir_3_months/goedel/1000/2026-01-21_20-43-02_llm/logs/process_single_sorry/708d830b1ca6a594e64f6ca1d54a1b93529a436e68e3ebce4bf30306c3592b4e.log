theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · intro h
    exact ⟨w, h, rfl⟩
  · intro h
    obtain ⟨w', h', h''⟩ := h
    have h''' : w' = w := by
      have h₁ : coerceWord w' = coerceWord w := by
        rw [h'']
        <;> simp_all
      have h₂ : w' = w := by
        apply Word.ext
        intro i
        have h₃ := congr_arg (fun w => w.get i) h₁
        simp [coerceWord, Word.get_map] at h₃
        <;> simp_all [Z.val]
        <;>
          (try
            {
              aesop
            })
          <;>
            (try
              {
                simp_all [Fin.ext_iff]
                <;>
                  aesop
              })
          <;>
            (try
              {
                simp_all [Finset.ext_iff]
                <;>
                  aesop
              })
      exact h₂
    rw [h'''] at h'
    exact h'

