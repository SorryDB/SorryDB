          <;> aesop
        have h₈ : (sSup (SetLike.coe I) : Submodule K (M.obj c)).c = ⊤ := by
          -- Use the fact that the decomposition is the top element to show the required equality
          rw [h₆]
          <;> simp
        rw [h₇, h₈]
      calc
        ⨆ p : I, (p : Submodule K (M.obj c)).c = ⨆ p ∈ SetLike.coe I, (p : Submodule K (M.obj c)).c := by
          simp [iSup]
          <;> congr 1 <;> ext1 p <;> simp [SetLike.mem_coe]
          <;> aesop
