lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove that the set is linearly independent
    sorry
  · -- Prove that the supremum is the entire space
    have h : ⨆ p : I, (p : _) c = ⊤ := by
      have h₁ : ⨆ p : I, (p : _) c = ⊤ := by
        -- Use the fact that the supremum of the entire set of submodules is the top element
        have h₂ : (⨆ p : I, (p : _) c : Submodule K (M.obj c)) = (⊤ : Submodule K (M.obj c)) := by
          -- The supremum of the family of submodules is the top element
          have h₃ : sSup (Set.range (fun p : I ↦ (p : _) c)) = ⊤ := by
            -- Use the pointwise supremum property
            have h₄ : sSup (↑I : Set (PersistenceSubmodule M)) = ⊤ := I.sSup_eq_top
            have h₅ : sSup (Set.range (fun p : I ↦ (p : _) c)) = (sSup (↑I : Set (PersistenceSubmodule M))) c := by
              -- The pointwise supremum of the set of submodules is the supremum of the family
              simp [iSup_range_eq_iSup, Set.range]
              <;>
                simp_all [sSup_const, Submodule.sSup, DirectSum.le_iSup]
              <;>
                congr <;> ext <;> simp [Set.mem_range]
              <;>
                (try simp_all [iSup_range_eq_iSup])
              <;>
                (try congr <;> ext <;> simp [Set.mem_range])
              <;>
                (try simp_all [iSup_range_eq_iSup])
              <;>
                (try congr <;> ext <;> simp [Set.mem_range])
            rw [h₅] at *
            rw [h₄]
            <;> simp
          -- Convert the supremum to the desired form
          have h₆ : (⨆ p : I, (p : _) c : Submodule K (M.obj c)) = sSup (Set.range (fun p : I ↦ (p : _) c)) := by
            simp [iSup_range_eq_iSup]
          rw [h₆]
          rw [h₃]
        rw [h₂]
      exact h₁
    simpa using h
