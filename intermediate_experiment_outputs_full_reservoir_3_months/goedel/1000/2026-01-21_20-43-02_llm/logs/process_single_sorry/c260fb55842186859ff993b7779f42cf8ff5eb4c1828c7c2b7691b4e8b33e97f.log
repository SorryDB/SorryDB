    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove the independent part
    apply fun (s : Finset I) => by
      have h₁ : ∀ (p : I), p.val c ≤ ⨆ p : I, (p : .val c := by
        intro p
        apply le_iSup
      have h₂ : ∀ (p : I), p.val c ≤ ⨆ p : I, (p : .val c := by
        intro p
        apply le_iSup
      -- Use the fact that the decomposition is independent to show the required independence
      have h₃ : sSupIndep (SetLike.coe I) := I.sSupIndep'
      -- Use the fact that the decomposition is independent to show the required independence
      exact (by
        have h₄ : sSupIndep (SetLike.coe I) := I.sSupIndep'
        -- Use the fact that the decomposition is independent to show the required independence
        have h₅ : ∀ (s : Finset I), ⨆ p ∈ s, (p.val c : Submodule K (M.obj c)) ≤ ⨆ p : I, (p : .val c := by
          intro p
          apply le_iSup
        -- Use the fact that the decomposition is independent to show the required independence
        have h₆ : ∀ (s : Finset I), ⨆ p ∈ s, (p.val c : Submodule K (M.obj c)) ≤ ⨆ p : I, (p : .val c := by
          intro p
          apply le_iSup
        -- Use the fact that the decomposition is independent to show the required independence
        have h₇ : sSupIndep (SetLike.coe I) := I.sSupIndep'
        -- Use the fact that the decomposition is independent to show the required independence
        simp_all [sSupIndep]
      )
  · -- Prove the iSup_eq_top part
    have h₁ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
    have h₂ : ⨆ p : I, (p : .val c = ⊤ := by
      have h₃ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
      have h₄ : ⨆ p : I, (p : .val c = ⨆ p ∈ SetLike.coe I, (p : Submodule K (M.obj c)).c := by
        -- Use the fact that the decomposition is the top element to show the required equality
