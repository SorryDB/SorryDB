  exact C!_trans H₁ H₂;

lemma Equivalence.equivalent_fml [m₁ ≅[L] m₂] (φ : Formula _) : L ⊢ m₁ φ ⭤ m₂ φ := by
  apply E!_intro <;> apply Translation.translate_fml;

