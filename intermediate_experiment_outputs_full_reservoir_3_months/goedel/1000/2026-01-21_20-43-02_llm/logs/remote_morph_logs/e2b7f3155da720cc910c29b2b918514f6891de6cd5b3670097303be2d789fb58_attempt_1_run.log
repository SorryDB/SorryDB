  constructor;
  intro a;
  simpa using Translation.translate_fml (L := L) (m₁ := m₁) (m₂ := m₂) $ m (.atom a);

lemma translation_expand_left {L : Logic _} [L.IsNormal] (m₁ m₂ m) [m₁ ⤳[L] m₂] [m ⤳[L] (-)] : (m + m₁) ⤳[L] (m₂) := by
