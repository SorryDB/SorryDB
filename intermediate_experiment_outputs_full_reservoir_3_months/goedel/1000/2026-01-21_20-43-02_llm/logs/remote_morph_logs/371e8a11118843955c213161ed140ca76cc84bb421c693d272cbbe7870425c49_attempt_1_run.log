```lean4
def foldr1 (f : α → α → α) : List α → α :=
  let helper : List α → α := by
    refine' fun xs => xs.foldr (fun x y => f y x) ?_
  helper

example {a : Type} [Inhabited a]
  (xs ys : List a) (f : a → a → a)
  : xs ≠ [] ∧ ys ≠ [] → foldr1 f (xs ++ ys) = f (foldr1 f xs) (foldr1 f ys) := by
  intro h
  have h₁ : xs ≠ [] := h.1
  have h₂ : ys ≠ [] := h.2
  have h₃ : ∀ (xs ys : List a), xs ≠ [] → ys ≠ [] → foldr1 f (xs ++ ys) = f (foldr1 f xs) (foldr1 f ys) := by
    intro xs ys hxs hys
    induction' xs with x xs ih generalizing ys
    · exfalso
      exact hxs rfl
    · cases xs with
      | nil =>
        -- Case: xs = [x]
        simp_all [foldr1, List.foldr, List.append_assoc]
        <;>
        (try cases ys with
        | nil => contradiction
        | cons y ys =>
          simp_all [foldr1, List.foldr, List.append_assoc]
          <;>
          ring_nf at *
          <;>
          simp_all)
      | cons x' xs =>
        -- Case: xs = x :: x' :: xs
        simp_all [foldr1, List.foldr, List.append_assoc]
        <;>
        (try cases ys with
        | nil => contradiction
        | cons y ys =>
          simp_all [foldr1, List.foldr, List.append_assoc]
          <;>
          ring_nf at *
          <;>
          simp_all)
        <;>
        (try {
          have h₄ := ih (y :: ys)
          simp_all [foldr1, List.foldr, List.append_assoc]
          <;>
          ring_nf at *
          <;>
          simp_all
        })
  exact h₃ xs ys h₁ h₂
``` 

