    ∀ (h : Type*) [DecidableEq h], ∀ (x : h), p h x = true := by
  intro h _ x
  have h₁ := p Unit (λ _ _ => inferInstance) ⟨⟩
  have h₂ := p Bool (λ _ _ => inferInstance) true
  have h₃ := p Bool (λ _ _ => inferInstance) false
  have h₄ := p h x
  -- We will show that p h x is trivially true by inspection of the function p
