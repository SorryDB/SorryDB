example (l : List ℕ) (n : ℕ) : ∃ m, ∀ i ∈ l, m > i ∧ m > n := by
  have h_main : ∃ m, ∀ i ∈ l, m > i ∧ m > n := by
    use (l.foldl (fun a b => max a b) 0) + n + 1
    intro i hi
    have h₁ : i ≤ l.foldl (fun a b => max a b) 0 := by
      have h₂ : i ∈ l := hi
      have h₃ : i ≤ l.foldl (fun a b => max a b) 0 := by
        -- Prove that i is less than or equal to the maximum element in the list
        have h₄ : ∀ (l : List ℕ) (i : ℕ), i ∈ l → i ≤ l.foldl (fun a b => max a b) 0 := by
          intro l i hi
          induction l with
          | nil => contradiction
          | cons a as ih =>
            cases as with
            | nil =>
              simp_all [List.foldl]
              <;> omega
            | cons b bs =>
              simp_all [List.foldl, List.mem_cons]
              <;>
              (try omega) <;>
              (try
                {
                  cases' le_total a b with h h <;>
                  cases' le_total i a with h' h' <;>
                  cases' le_total i b with h'' h'' <;>
                  simp_all [max_eq_left, max_eq_right, le_refl] <;>
                  omega
                }) <;>
              (try
                {
                  aesop
                })
        exact h₄ l i hi
      exact h₃
    constructor
    · -- Prove m > i
      have h₂ : (l.foldl (fun a b => max a b) 0) + n + 1 > i := by
        omega
      exact h₂
    · -- Prove m > n
      have h₂ : (l.foldl (fun a b => max a b) 0) + n + 1 > n := by
        have h₃ : l.foldl (fun a b => max a b) 0 ≥ 0 := by
          -- The foldl operation with max and initial value 0 will always be non-negative
          have h₄ : ∀ (l : List ℕ), l.foldl (fun a b => max a b) 0 ≥ 0 := by
            intro l
            induction l with
            | nil => simp
            | cons a as ih =>
              simp_all [List.foldl, max_eq_left]
              <;> omega
          exact h₄ l
        omega
      exact h₂
  exact h_main
