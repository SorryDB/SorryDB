theorem ex7_1_1 {α : Type} [LinearOrderedCommRing α] (xs : List α) : 
  xs.prod ≤ xs.map (fun x => if x ≤ 0 then 0 else x).prod := by
  have h : ∀ (x : α), x ≤ (if x ≤ 0 then 0 else x) := by
    intro x
    split_ifs with h
    · -- Case: x ≤ 0
      have h₁ : x ≤ 0 := h
      have h₂ : (if x ≤ 0 then 0 else x) = 0 := by simp [h₁]
      rw [h₂]
      <;> linarith
    · -- Case: x > 0
      have h₁ : ¬x ≤ 0 := h
      have h₂ : (if x ≤ 0 then 0 else x) = x := by simp [h₁]
      rw [h₂]
  -- Use the fact that the product of the modified list is greater than or equal to the product of the original list
  have h₁ : xs.prod ≤ xs.map (fun x => if x ≤ 0 then 0 else x).prod := by
    -- Use the fact that each element in the original list is less than or equal to the corresponding element in the modified list
    have h₂ : ∀ (l : List α), l.prod ≤ l.map (fun x => if x ≤ 0 then 0 else x).prod := by
      intro l
      induction l with
      | nil =>
        simp
      | cons a l ih =>
        simp_all [List.prod_cons, List.map]
        <;>
        (try { contradiction }) <;>
        (try {
          split_ifs at * <;>
          (try { nlinarith }) <;>
          (try {
            cases' le_or_lt 0 a with h₃ h₃ <;>
            cases' le_or_lt 0 (a * l.prod) with h₄ h₄ <;>
            simp_all [mul_assoc] <;>
            nlinarith
          }) <;>
          (try {
            nlinarith [mul_self_nonneg (a - l.prod)]
          })
        }) <;>
        (try {
          cases' le_or_lt 0 a with h₃ h₃ <;>
          cases' le_or_lt 0 (a * l.prod) with h₄ h₄ <;>
          simp_all [mul_assoc] <;>
          nlinarith
        }) <;>
        (try {
          nlinarith [mul_self_nonneg (a - l.prod)]
        })
    exact h₂ xs
  exact h₁
