lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement
    B sorry sorry sorry
  have contra : ¬ IsMin D := by
    simp only [not_isMin_iff]
    use newD
    apply refinement_lt_of_exists_ne_singleton
    use x ⊔ y, hN
    simp only [B, if_true]
    intro h
    have h₁ : ({x, y} : Set (PersistenceSubmodule M)) = {x ⊔ y} := by simpa using h
    have h₂ : x ⊔ y = x := by
      have h₃ : x ∈ ({x, y} : Set (PersistenceSubmodule M)) := by simp
      rw [h₁] at h₃
      simp only [Set.mem_singleton_iff] at h₃
      simp_all [Set.mem_singleton_iff]
      <;> aesop
    have h₃ : Disjoint x y := hxy
    have h₄ : x ≠ ⊥ := hx
    have h₅ : Disjoint x x := by
      have h₆ := h₃
      simp_all [h₂, disjoint_iff]
      <;> aesop
    have h₆ : x = ⊥ := by
      have h₇ : Disjoint x x := h₅
      have h₈ : x = ⊥ := by
        apply eq_bot_of_eq_bot_of_disjoint_self
        <;> aesop
      exact h₈
    have h₇ : x ≠ ⊥ := hx
    contradiction
