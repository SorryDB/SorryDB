      split_ifs <;> simp_all [Set.ext_iff, le_sup_iff]
      <;>
      (try
        {
          aesop
        })
      <;>
      (try
        {
          simp_all [hxy, hx, hy]
          <;>
          (try tauto)
        })
    )
  have contra : ¬ IsMin D := by
    simp only [not_isMin_iff]
    use newD
    apply refinement_lt_of_exists_ne_singleton
    use x ⊔ y, (by
      -- Prove that x ⊔ y ∈ D
      have h₁ : x ⊔ y ∈ D := by sorry
      exact h₁
      )
    simp only [B, if_true]
    intro h
    have h₁ : ({x, y} : Set (PersistenceSubmodule M)) = ({x ⊔ y} : Set (PersistenceSubmodule M)) := by simpa [Set.ext_iff] using h
    have h₂ : x = x ⊔ y := by
      have h₃ : x ∈ ({x ⊔ y} : Set (PersistenceSubmodule M)) := by
        rw [← h₁]
        simp [Set.mem_insert_iff, Set.mem_singleton_iff]
      simpa [Set.mem_singleton_iff] using h₃
