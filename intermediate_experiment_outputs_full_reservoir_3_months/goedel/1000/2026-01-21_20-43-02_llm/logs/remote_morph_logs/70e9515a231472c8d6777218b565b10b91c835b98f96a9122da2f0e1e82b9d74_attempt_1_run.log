```lean
lemma refinement_lt_of_exists_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  classical
  have h₁ : refinement B hB hB' hB'' ≤ D := by
    exact refinement_le B hB hB' hB''
  have h₂ : refinement B hB hB' hB'' ≠ D := by
    by_contra h₃
    have h₄ : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N} := H
    rcases h₄ with ⟨N, hN, h₅⟩
    have h₆ : B N hN ≠ {N} := h₅
    have h₇ : N ∈ D := hN
    have h₈ : N ∈ refinement B hB hB' hB''.carrier := by
      have h₉ : B N hN ⊆ refinement B hB hB' hB''.carrier := by
        intro x hx
        simp only [refinement, Set.mem_iUnion, exists_prop] at hx ⊢
        <;> aesop
      have h₁₀ : N = sSup (B N hN) := hB N hN
      have h₁₁ : sSup (B N hN) ∈ refinement B hB hB' hB''.carrier := by
        apply SetLike.mem_coe.mpr
        have h₁₂ : (∃ (T : Set (PersistenceSubmodule M)), T ∈ D.mem_B) := by
          use B N hN
          aesop
        aesop
      aesop
    have h₉ : N ∈ (D : Set (PersistenceSubmodule M)) := h₇
    have h₁₀ : N ∈ (refinement B hB hB' hB'' : Set (PersistenceSubmodule M)) := h₈
    have h₁₁ : refinement B hB hB' hB'' = D := by
      exact h₃
    simp_all [SetLike.ext_iff]
    <;> aesop
  exact lt_of_le_of_ne h₁ h₂
