    use coloring_of_eight
    intro h
    obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
    dsimp [coloring_of_eight] at *
    interval_cases i <;> interval_cases j <;>
      (try contradiction) <;>
      (try
        {
          simp_all [Set.mem_Icc, coloring_of_eight, Fin.ext_iff]
          <;> norm_num at * <;>
          (try omega) <;>
          (try
