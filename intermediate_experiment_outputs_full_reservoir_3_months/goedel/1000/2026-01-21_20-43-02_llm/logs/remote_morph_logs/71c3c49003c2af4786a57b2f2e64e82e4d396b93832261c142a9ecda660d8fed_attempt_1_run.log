theorem imo_2008_p2_part_i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  have h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
    have h₃ : 0 < (x - 1) ^ 2 := by
      apply sq_pos_of_ne_zero
      intro h
      apply h₀.1
      nlinarith
    have h₄ : 0 < (y - 1) ^ 2 := by
      apply sq_pos_of_ne_zero
      intro h
      apply h₀.2.1
      nlinarith
    have h₅ : 0 < (z - 1) ^ 2 := by
      apply sq_pos_of_ne_zero
      intro h
      apply h₀.2.2
      nlinarith
    have h₆ : 0 < (x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2 := by positivity
    field_simp [h₀.1, h₀.2.1, h₀.2.2, sub_eq_zero, Ne.symm h₀.1, Ne.symm h₀.2.1, Ne.symm h₀.2.2]
    rw [le_div_iff (by positivity)]
    nlinarith [sq_nonneg (x + y + z - 3), sq_nonneg (x - y), sq_nonneg (y - z), sq_nonneg (z - x),
      sq_nonneg (x * y + y * z + z * x - 3), sq_nonneg (x * y - 1), sq_nonneg (y * z - 1),
      sq_nonneg (z * x - 1)]
  exact h₂
```
