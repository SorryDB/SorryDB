theorem imo_2008_p2_parts_i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  have h₂ : x ≠ 1 := h₀.1
  have h₃ : y ≠ 1 := h₀.2.1
  have h₄ : z ≠ 1 := h₀.2.2
  have h₅ : (x - 1) ≠ 0 := by intro h; apply h₂; linarith
  have h₆ : (y - 1) ≠ 0 := by intro h; apply h₃; linarith
  have h₇ : (z - 1) ≠ 0 := by intro h; apply h₄; linarith
  have h₈ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
    have h₉ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 - 1 ≥ 0 := by
      have h₁₀ : 0 < (x - 1) ^ 2 := by
        apply sq_pos_of_ne_zero
        exact h₅
      have h₁₁ : 0 < (y - 1) ^ 2 := by
        apply sq_pos_of_ne_zero
        exact h₆
      have h₁₂ : 0 < (z - 1) ^ 2 := by
        apply sq_pos_of_ne_zero
        exact h₇
      have h₁₃ : 0 < (x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2 := by positivity
      field_simp [h₅, h₆, h₇]
      rw [le_div_iff (by positivity)]
      -- Use nlinarith to prove the inequality after simplifying
      nlinarith [sq_nonneg (x * (y - 1) * (z - 1) + y * (x - 1) * (z - 1) + z * (x - 1) * (y - 1) - (x - 1) * (y - 1) * (z - 1)),
        sq_nonneg (x * (y - 1) * (z - 1) - y * (x - 1) * (z - 1)),
        sq_nonneg (x * (y - 1) * (z - 1) - z * (x - 1) * (y - 1)),
        sq_nonneg (y * (x - 1) * (z - 1) - z * (x - 1) * (y - 1)),
        mul_self_nonneg (x + y + z - 3),
        mul_self_nonneg (x - y),
        mul_self_nonneg (y - z),
        mul_self_nonneg (z - x)]
    linarith
  exact h₈
