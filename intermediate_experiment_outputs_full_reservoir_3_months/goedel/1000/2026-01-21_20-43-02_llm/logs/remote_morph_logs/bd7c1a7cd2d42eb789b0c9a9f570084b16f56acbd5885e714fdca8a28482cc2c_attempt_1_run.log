  have h₁ : DifferentiableAt ℝ (fun x : ℝ² => ⟪pbar.rotM (x 0) (x 1) P, pc.w⟫ / ‖P‖) pbar.outerParams := by
    -- Prove that the function is differentiable at the given point
    have h₂ : DifferentiableAt ℝ (fun x : ℝ² => ⟪pbar.rotM (x 0) (x 1) P, pc.w⟫) pbar.outerParams := by
      -- Prove that the numerator is differentiable
      have h₃ : DifferentiableAt ℝ (fun x : ℝ² => pbar.rotM (x 0) (x 1) P) pbar.outerParams := by
        -- Prove that the projection is differentiable
        have h₄ : DifferentiableAt ℝ (fun x : ℝ² => pbar.rotM (x 0) (x 1)) pbar.outerParams := by
          -- Prove that the rotation matrix is differentiable
          apply DifferentiableAt.congr_of_eventuallyEq (differentiableAt_id (α := ℝ) |>.x |>.congrFun x |>.congrFun y)
          <;> simp [pbar.rotM, pbar.rotation_zxy, zxy_rotation]
          <;> ring_nf
          <;> simp_all [zxy_rotation]
          <;> aesop
        -- Use the differentiability of the projection
        have h₅ : DifferentiableAt ℝ (fun x : ℝ² => pbar.rotM (x 0) (x 1) P) pbar.outerParams := by
          apply DifferentiableAt.comp (h₄) (differentiableAt_id (α := ℝ³))
          <;> simp [differentiableAt_id]
        exact h₅
      -- Prove that the inner product is differentiable
