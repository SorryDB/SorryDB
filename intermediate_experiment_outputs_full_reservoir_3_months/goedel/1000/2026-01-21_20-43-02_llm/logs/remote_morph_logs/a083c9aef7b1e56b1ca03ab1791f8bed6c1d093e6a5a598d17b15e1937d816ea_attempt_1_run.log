```lean
inductive State := | Begin | A | B | C | D | E | Accept

def transition (s: State) (c: Char): State :=
  match s, c with
  | _, 'a' =>
    match s with
    | State.Begin => State.A
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  | _, 'b' =>
    match s with
    | State.Begin => State.B
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  | _, 'c' =>
    match s with
    | State.Begin => State.C
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  | _, 'd' =>
    match s with
    | State.Begin => State.D
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  | _, 'e' =>
    match s with
    | State.Begin => State.E
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  | _, _ => s

def subsequenceState (s: State)(c: Char): State :=
  if c = 'a' then
    match s with
    | State.Begin => State.A
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  else if c = 'b' then
    match s with
    | State.Begin => State.B
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  else if c = 'c' then
    match s with
    | State.Begin => State.C
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  else if c = 'd' then
    match s with
    | State.Begin => State.D
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  else if c = 'e' then
    match s with
    | State.Begin => State.E
    | State.A => State.B
    | State.B => State.C
    | State.C => State.D
    | State.D => State.E
    | State.E => State.Accept
    | State.Accept => State.Accept
  else s

def isSubsequence (s: String) : Bool :=
  let letters := s.toList
  let stateTransition := fun (s: State)(c: Char) => subsequenceState s c
  let finalState := letters.foldl stateTransition State.Begin
  match finalState with
  | State.Accept => true
  | _ => false

def isSubsequence2 (s: String) : Bool :=
  let letters := s.toList
  let stateTransition := fun (s: State)(c: Char) => transition s c
  let finalState := letters.foldl stateTransition State.Begin
  match finalState with
  | State.Accept => true
  | _ => false

def main (s: String) : Bool :=
  isSubsequence s
