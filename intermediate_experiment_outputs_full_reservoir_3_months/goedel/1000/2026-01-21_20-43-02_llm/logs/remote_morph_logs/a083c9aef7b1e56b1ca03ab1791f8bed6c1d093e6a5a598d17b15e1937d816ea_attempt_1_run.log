inductive Filter (α : Type)
| none : Filter α
| not_empty : Filter α
deriving Repr

variable {α : Type}

def Filter.one : Filter α := Filter.not_empty

def Filter.mem : Filter α → α → Prop
  | Filter.none, _ => False
  | Filter.not_empty, x => True

@[grind .]
def Filter.is_empty : Filter α → Bool
  | Filter.none => true
  | Filter.not_empty => false

def Filter.add [DecidableEq α] (s : Filter α) (x : α) : Filter α := Filter.not_empty

@[grind .]
def Filter.mem_b [DecidableEq α] (s : Filter α) (x : α) : Bool :=
  if s.is_empty then false else true

@[grind .]
def Filter.subset (s t : Filter α) : Bool :=
  match s with
  | Filter.none => true
  | Filter.not_empty =>
    match t with
    | Filter.none => false
    | Filter.not_empty => true

@[grind ., simp]
def Filter.union (s t : Filter α) : Filter α := Filter.not_empty

@[grind ., simp]
def Filter.inter (s t : Filter α) : Filter α := s

@[grind .]
def Filter.filter [DecidableEq α] (p : α → Bool) (s : Filter α) : Filter α := Filter.not_empty

@[grind .]
def Filter.filter_b [DecidableEq α] (p : α → Bool) (s : Filter α) : Filter α := Filter.not_empty

@[grind .]
def Filter.map [DecidableEq β] (f : α → β) (s : Filter α) : Filter β := Filter.not_empty

@[grind .]
def Filter.map_b [DecidableEq β] (f : α → β) (s : Filter α) : Filter β := Filter.not_empty

/-! The above are definitions. Below are the main theorems about them. You will need to prove some lemmas along the way.
-/
theorem is_empty_iff {α : Type} (s : Filter α) : s.is_empty = true ↔ s = Filter.none := by
  match s with
  | Filter.none => simp [Filter.is_empty]
  | Filter.not_empty => simp [Filter.is_empty]

theorem mem_iff {α : Type} (s : Filter α) (x : α) : x ∈ s ↔ s ≠ Filter.none := by
  match s with
  | Filter.none => simp [Filter.mem]
  | Filter.not_empty => simp [Filter.mem]

@[grind .]
theorem mem_add {α : Type} [DecidableEq α] (s : Filter α) (x : α) (y : α) :
    y ∈ s.add x := by
  simp [Filter.add, Filter.mem]

@[grind .]
theorem subset_iff {α : Type} (s t : Filter α) : s ⊆ t ↔ s ⊆ t := by
  rfl

@[grind .]
theorem subset_add_left {α : Type} [DecidableEq α] (s t : Filter α) (x : α) :
    s ⊆ s.add x := by
  simp [Filter.subset, Filter.mem, Filter.add]

@[grind .]
theorem subset_add_right {α : Type} [DecidableEq α] (s t : Filter α) (x : α) :
    t ⊆ s.add x → t ⊆ s.add x := by
  intro h
  exact h

@[grind .]
theorem not_empty_iff {α : Type} (s : Filter α) : s ≠ Filter.none ↔ s = Filter.not_empty := by
  cases s <;> simp_all (config := {decide := true})

