theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : fastCheckMem label l = true ↔ label ∈ l := by
    match l with
    | .leaf x =>
      -- Case: l is a leaf
      simp [fastCheckMem, LabelledTree.mem]
      <;>
      (try cases' le_total x label with h₂ h₂ <;> simp_all [h₂, eq_self_iff_true, eq_comm]) <;>
      (try { aesop }) <;>
      (try { simp_all [h₂, le_of_eq] }) <;>
      (try { omega })
    | .node v l r =>
      -- Case: l is a node
      by_cases h₂ : v = label
      · -- Subcase: v = label
        simp_all [fastCheckMem, LabelledTree.mem]
        <;>
        (try { aesop }) <;>
        (try {
          cases' IsOrdered (node v l r) with h₃ h₄
          <;> simp_all [IsOrdered]
          <;> tauto
        })
      · -- Subcase: v ≠ label
        by_cases h₃ : label < v
        · -- Subcase: label < v
          have h₄ : fastCheckMem label l = true ↔ label ∈ l := by
            -- Proof by induction on l, but we assume it's already proved for the left subtree
            have h₅ : IsOrdered l := by
              -- Prove that the left subtree is ordered
              cases' h with h₅ h₆
              cases' h₅ with h₅₀ h₅₁
              exact h₆.1
            exact fastCheckMem_correct label l h₅
          simp_all [fastCheckMem, LabelledTree.mem]
          <;>
          (try { aesop }) <;>
          (try {
            cases' IsOrdered (node v l r) with h₄ h₆
            <;> simp_all [IsOrdered]
            <;> tauto
          })
        · -- Subcase: label ≥ v
          have h₄ : ¬(label < v) := h₃
          have h₅ : label ≥ v := by
            by_contra h₅
            have h₆ : label < v := by
              have h₆₁ : label ≤ v := by
                linarith
              have h₆₂ : label ≠ v := by
                intro h₆₂
                apply h₂
                linarith
              exact lt_of_le_of_ne h₆₁ (by intro h; subst h; contradiction)
            contradiction
          by_cases h₆ : label = v
          · -- Subsubcase: label = v
            exfalso
            apply h₂
            linarith
          · -- Subsubcase: label > v
            have h₇ : label > v := by
              cases' lt_or_gt_of_ne h₆ with h₇ h₇
              · exfalso
                linarith
              · exact h₇
            have h₈ : fastCheckMem label r = true ↔ label ∈ r := by
              -- Proof by induction on r, but we assume it's already proved for the right subtree
              have h₉ : IsOrdered r := by
                -- Prove that the right subtree is ordered
                cases' h with h₉ h₁₀
                cases' h₉ with h₉₀ h₉₁
                exact h₁₀.2.2.2.2
              exact fastCheckMem_correct label r h₉
            simp_all [fastCheckMem, LabelledTree.mem]
            <;>
            (try { aesop }) <;>
            (try {
              cases' IsOrdered (node v l r) with h₉ h₁₀
              <;> simp_all [IsOrdered]
              <;> tauto
            })
  exact h₁
