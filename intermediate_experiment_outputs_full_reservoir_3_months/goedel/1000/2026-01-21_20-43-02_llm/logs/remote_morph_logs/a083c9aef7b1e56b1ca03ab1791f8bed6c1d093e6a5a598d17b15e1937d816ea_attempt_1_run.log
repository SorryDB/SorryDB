theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : ∀ (l : LabelledTree α) (h : IsOrdered l) (label : α), fastCheckMem label l = true ↔ label ∈ l := by
    intro l h label
    induction l generalizing label with
    | leaf x =>
      simp [fastCheckMem, LabelledTree.mem]
      <;> aesop
    | node v l r =>
      simp [fastCheckMem, IsOrdered, LabelledTree.mem] at h ⊢
      -- Consider the three cases: label < v, label = v, label > v
      by_cases h₂ : label = v
      · -- Case 1: label = v
        simp [h₂]
        <;> aesop
      · -- Case 2: label ≠ v
        by_cases h₃ : label < v
        · -- Subcase 2.1: label < v
          simp [h₂, h₃]
          <;>
          (try
            {
              have h₄ := h.1
              have h₅ := h.2.1
              have h₆ := h.2.2.1
              have h₇ := h.2.2.2.1
              have h₈ := h.2.2.2.2
              simp_all [IsOrdered, LabelledTree.mem]
              <;>
              (try omega)
              <;>
              (try aesop)
            })
          <;>
          (try
            {
              simp_all [IsOrdered, LabelledTree.mem]
              <;>
              (try omega)
              <;>
              (try aesop)
            })
        · -- Subcase 2.2: label ≥ v
          have h₃' : label ≥ v := by
            by_contra h₄
            have h₅ : label < v := lt_of_not_ge h₄
            contradiction
          simp [h₂, h₃, h₃']
          <;>
