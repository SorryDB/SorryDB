    have h₂ : ∀ (t : LabelledTree α), IsOrdered t → (fastCheckMem label t = true ↔ label ∈ t) := by
      intro t ht
      induction t with
      | leaf x =>
        cases' le_total label x with h₃ h₃ <;> simp_all [fastCheckMem, LabelledTree.mem, IsOrdered]
        <;>
        (try { contradiction }) <;>
        (try { aesop }) <;>
        (try {
          split_ifs at * <;>
          simp_all [fastCheckMem, LabelledTree.mem, IsOrdered] <;>
          aesop
        }) <;>
        (try {
          norm_num at * <;>
          aesop
        })
      | node v l r =>
        have h₃ := ht.1
        have h₄ := ht.2.1
        have h₅ := ht.2.2.1
        have h₆ := ht.2.2.2.1
        have h₇ := ht.2.2.2.2
        cases' lt_trichotomy label v with h₈ h₈ <;> simp_all [fastCheckMem, LabelledTree.mem, IsOrdered]
        <;>
        (try {
          split_ifs at * <;>
          simp_all [fastCheckMem, LabelledTree.mem, IsOrdered] <;>
          (try {
            have h₉ := h₃
            have h₁₀ := h₄
            aesop
          }) <;>
          (try {
            have h₉ := h₅
            have h₁₀ := h₆
            aesop
          }) <;>
          (try { aesop })
        }) <;>
        (try {
          norm_num at * <;>
          aesop
        }) <;>
        (try {
          have h₉ : label ∈ l ∨ label ∈ r := by
            have h₁₀ : label ∈ l ∨ label ∈ r := by
              by_cases h₁₁ : label ∈ l
              · exact Or.inl h₁₁
              · have h₁₂ : label ∈ r := by
                  have h₁₃ : label ∈ l ∨ label ∈ r := by
