```lean
@[grind .]
def fastCheckMem (label : α)(l: LabelledTree α) : Bool := match l with
  | leaf l => l == label
  | node l left right =>
    if l == label then true
    else if label ≤ l then fastCheckMem label left
    else fastCheckMem label right


theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : fastCheckMem label l = true ↔ label ∈ l := by
    classical
    -- Define a helper function to check membership efficiently
    have h₂ : ∀ (t : LabelledTree α), IsOrdered t → (fastCheckMem label t = true ↔ label ∈ t) := by
      intro t ht
      induction t with
      | leaf x =>
        -- Base case: the tree is a leaf
        simp [fastCheckMem, LabelledTree.mem]
      | node x l r =>
        -- Inductive step: the tree is a node
        simp_all [fastCheckMem, LabelledTree.mem, IsOrdered, le_of_lt]
        <;>
        (try
          {
            split_ifs at * <;>
            (try contradiction) <;>
            (try simp_all) <;>
            (try
              {
                have h₃ := ht.1
                have h₄ := ht.2.1
                have h₅ := ht.2.2.1
                have h₆ := ht.2.2.2.1
                simp_all [IsOrdered, LabelledTree.mem]
                <;>
                (try omega) <;>
                (try
                  {
                    by_cases h₇ : label ≤ x <;>
                    simp_all [h₇] <;>
                    (try omega)
                  })
                <;>
                (try tauto)
              })
          })
        <;>
        (try
          {
            by_cases h₃ : label = x <;>
            by_cases h₄ : label ≤ x <;>
            simp_all [h₃, h₄]
            <;>
            (try tauto)
            <;>
            (try
              {
                have h₅ := ht.1
                have h₆ := ht.2.1
                have h₇ := ht.2.2.1
                have h₈ := ht.2.2.2.1
                simp_all [IsOrdered, LabelledTree.mem]
                <;>
                (try omega)
                <;>
                (try
                  {
                    by_cases h₉ : label ≤ x <;>
                    simp_all [h₉] <;>
                    (try omega)
                  })
                <;>
                (try tauto)
              })
          })
        <;>
        (try
          {
            tauto
          })
    -- Apply the helper function to the given tree
    have h₃ := h₂ l h
    exact h₃
  exact h₁
