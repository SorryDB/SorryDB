@[grind .]
def fastCheckMem (label : α)(l: LabelledTree α) : Bool := match l with
  | leaf l => l == label
  | node l left right =>
    if l == label then true
    else if label < l then fastCheckMem label left
    else fastCheckMem label right

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : ∀ (l : LabelledTree α), IsOrdered l → (fastCheckMem label l = true ↔ label ∈ l) := by
    intro l h
    -- Prove by induction on the structure of the tree
    struct_induction l generalizing h using LabelledTree.induction
    <;> simp_all [IsOrdered, fastCheckMem, LabelledTree.mem]
    <;>
    (try { contradiction }) <;>
    (try { aesop }) <;>
    (try {
      split_ifs at * <;> simp_all (config := {decide := true})
      <;>
      (try { omega }) <;>
      (try { aesop })
    }) <;>
    (try {
      aesop
    }) <;>
    (try {
      simp_all [LinearOrder.lt_iff_le_not_le]
      <;>
      (try { omega }) <;>
      (try { aesop })
    }) <;>
    (try {
      simp_all [LinearOrder.le_of_lt]
      <;>
      (try { omega }) <;>
      (try { aesop })
    }) <;>
    (try {
      exfalso <;>
      (try { simp_all [LinearOrder.lt_iff_le_not_le] <;> omega }) <;>
      (try { aesop })
    }) <;>
    (try {
      omega
    }) <;>
    (try {
      aesop
    })
  -- Use the general result to prove the specific case
  exact h₁ l h
