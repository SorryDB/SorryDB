```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  have h₁ : ∀ (l : LabelledTree α), fastCheckMem label l = true ↔ label ∈ l := by
    intro l
    have h₂ : ∀ (l : LabelledTree α) (h : IsOrdered l), fastCheckMem label l = true ↔ label ∈ l := by
      intro l h
      have h₃ : fastCheckMem label l = true ↔ label ∈ l := by
        -- Use induction on the structure of theLabelledTree to prove the equivalence
        induction l using LabelledTree.recOn with
        | leaf x =>
          -- Case: l is a leaf
          simp [fastCheckMem, Membership.mem]
          <;>
          (try cases (x = label) <;> simp_all [Eq.refl]) <;>
          (try cases (x < label) <;> simp_all [Eq.refl]) <;>
          (try cases (x > label) <;> simp_all [Eq.refl]) <;>
          simp_all [LinearOrder.lt_iff_le_and_ne]
        | node v l r =>
          -- Case: l is a node
          have h₄ : (∀ x ∈ l, x ≤ v) ∧ (∀ x ∈ r, v ≤ x) ∧ IsOrdered l ∧ IsOrdered r ∧ (v ∈ l ∨ v ∈ r) := h
          simp_all [fastCheckMem, Membership.mem]
          <;>
          (try {
            split_ifs at * <;>
            (try {
              simp_all [LinearOrder.lt_iff_le_and_ne]
              <;>
              (try { contradiction }) <;>
              (try {
                have h₅ := h₄.1.1
                have h₆ := h₄.1.2
                have h₇ := h₄.2.1
                simp_all [Membership.mem]
                <;>
                (try {
                  tauto
                }) <;>
                (try {
                  cases' h₄.1.2 with x hx <;>
                  simp_all [Membership.mem] <;>
                  (try {
                    linarith
                  }) <;>
                  (try {
                    aesop
                  })
                }) <;>
                (try {
                  cases' h₄.2.1 with x hx <;>
                  simp_all [Membership.mem] <;>
                  (try {
                    linarith
                  }) <;>
                  (try {
                    aesop
                  })
                })
              })
            }) <;>
            (try {
              aesop
            })
          }) <;>
          (try {
            simp_all [LinearOrder.lt_iff_le_and_ne]
            <;>
            (try {
              tauto
            }) <;>
            (try {
              cases' h₄.1.2 with x hx <;>
              simp_all [Membership.mem] <;>
              (try {
                linarith
              }) <;>
              (try {
                aesop
              })
            }) <;>
            (try {
              cases' h₄.2.1 with x hx <;>
              simp_all [Membership.mem] <;>
              (try {
                linarith
              }) <;>
              (try {
                aesop
              })
            })
          }) <;>
          (try {
            aesop
          })
      exact h₃
    -- Remove the hypothesis by applying the lemma to the current l and h
    have h₄ : fastCheckMem label l = true ↔ label ∈ l := by
      apply h₂
      <;>
      (try {
        exact h
      })
    exact h₄
  -- Apply the lemma to l
  have h₂ : fastCheckMem label l = true ↔ label ∈ l := h₁ l
  exact h₂
