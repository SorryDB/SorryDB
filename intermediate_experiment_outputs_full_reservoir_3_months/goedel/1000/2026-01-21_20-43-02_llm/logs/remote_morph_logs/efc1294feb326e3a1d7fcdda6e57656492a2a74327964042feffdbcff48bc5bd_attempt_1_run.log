    aesop
  have h₅ : A.toLinearMap (reindex_to_pctrat'' (sharedEigenbasis hA hB hAB) j) =
      (hA'.directSum_isInternal_of_commute' hB' hAB') j := by
    calc
      A.toLinearMap (reindex_to_pctrat'' (sharedEigenbasis hA hB hAB) j) = (A.toLinearMap.reindex (reindex_to_pctrat'' (sharedEigenbasis hA hB hAB))) j := by
        rw [h₁]
