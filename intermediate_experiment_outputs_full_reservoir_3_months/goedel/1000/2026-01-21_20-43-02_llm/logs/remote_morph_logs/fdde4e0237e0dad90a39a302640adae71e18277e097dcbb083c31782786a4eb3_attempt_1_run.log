namespace BST1

def flatcat : (t : Tree a) â†’ (xs: List a) â†’ List a
| .null, xs => xs
| .node l x r, xs => flatcat l (x :: flatcat r xs)

def Tree.flattenâ‚پ (t : Tree a) : List a :=
 flatcat t []

theorem flatten_eq_helper_accum (t : Tree a) (xs: List a)
  : t.flatten ++ xs = flatcat t xs := by
  induction t generalizing xs with
  | null => rfl
  | node l x r ihl ihr =>
    rw [flatcat, â†گihr]
    rw [â†گihl (x :: (r.flatten ++ xs))]
    rw [List.append_cons]
    rw [â†گ List.append_assoc]
    rw [Tree.flatten]

example (t: Tree a) : t.flatten = t.flattenâ‚پ := by
  induction t with
  | null => exact rfl
  | node l x r ihl ihr =>
    rw [Tree.flattenâ‚پ]
    simp [â†گ flatten_eq_helper_accum]

