    intro p
    have h₃ : #S = 0 := by simpa using h₁
    have h₄ : Fin #S → S := p
    have h₅ : Fin #S → ℕ := fun i => (p i : ℕ)
    have h₆ : #S = 0 := by simpa using h₁
    have h₇ : IsEmpty (Fin #S) := by
      rw [h₆]
      infer_instance
    exact IsEmpty.false (p (Classical.arbitrary (Fin #S)))
  
  have h₃ : False := by
    apply h₂ p₁
  
