    cases' h₄ with h₄_left h₄_right
    -- The contradiction arises from assuming S.card ≠ 0
    simp_all [Finset.card_eq_zero]
    <;>
    (try omega) <;>
    (try contradiction) <;>
    (try aesop) <;>
    (try norm_num at *) <;>
    (try linarith)
  
