theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  classical
  by_cases h : S.Nonempty
  · exfalso
    have h₁ := hS (S.min' h)
    have h₂ := h₁.1
    have h₃ := h₁.2
    have h₄ := h₃.eq_two_or_odd
    cases h₄ with
    | inl h₄ =>
      have h₅ : (S.min' h) = 2 := h₄
      have h₆ := h₃.two_le
      norm_num [h₅] at h₆
      <;> contradiction
    | inr h₄ =>
      cases' h₂ with c hc
      have h₅ := hc
      have h₆ := h₃.eq_two_or_odd
      omega
  · exfalso
    simp_all [Finset.nonempty_iff_ne_empty]
