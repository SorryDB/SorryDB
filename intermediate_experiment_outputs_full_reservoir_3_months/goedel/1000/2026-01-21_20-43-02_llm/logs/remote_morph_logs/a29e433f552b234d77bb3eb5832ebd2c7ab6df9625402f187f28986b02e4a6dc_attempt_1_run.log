            cases h₂ with
            | inl h₂ =>
              exfalso
              -- This case leads to a contradiction because χ ➝ φ ∈ T.theory would imply χ ➝ ξ ∈ T.theory
              have h₃ := T.imp_closed h₂
              simp_all [hT]
            | inr h₂ =>
              -- Use the inductive hypothesis to conclude
              have h₃ := h₂ Γ (by
                simp_all [subset_construction_succ, Set.subset_def]
                <;>
                aesop
              )
              simp_all
          exact h₁ Γ hΓ
        }) <;>
        (try {
          simp_all [Set.mem_insert_iff]
          <;>
          aesop
        })
      · -- Case: h is false
        simp_all [Set.mem_insert_iff]
        <;>
