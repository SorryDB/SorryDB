    --convert LHS and RHS to density
    rw [Measure.map_apply (measurable_add_const y) hs]
    rw [withDensity_apply' _]
    rw [withDensity_apply' _]

    --change of variables
    have h_change : ∫⁻ (a : ℝ) in (fun x ↦ x + y) ⁻¹
