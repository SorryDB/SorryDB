    ∀ (a n : ℕ),
    n % 2 = 0 →
    (a + n) % 2 = a % 2 := by
  intro a n hn
  have h₁ : n % 2 = 0 := hn
  have h₂ : (a + n) % 2 = a % 2 := by
    have h₃ : (a + n) % 2 = (a % 2 + n % 2) % 2 := by
