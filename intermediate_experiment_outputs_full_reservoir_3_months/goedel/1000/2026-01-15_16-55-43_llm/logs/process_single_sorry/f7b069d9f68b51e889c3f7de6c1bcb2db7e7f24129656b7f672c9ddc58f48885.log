lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement
    B (fun N hN => by
      have h₁ : B N hN = if N = x ⊔ y then {x, y} else {N} := rfl
      rw [h₁]
      split_ifs with h
      · -- Case: N = x ⊔ y
        have h₂ : x ⊔ y = sSup ({x, y} : Set (PersistenceSubmodule M)) := by
          have h₃ : sSup ({x, y} : Set (PersistenceSubmodule M)) = x ⊔ y := by
            simp [sSup_pair]
          rw [h₃]
        rw [h, h₂]
      · -- Case: N ≠ x ⊔ y
        have h₂ : N = sSup ({N} : Set (PersistenceSubmodule M)) := by
          simp [sSup_singleton]
        rw [h₂]
    )
    (fun N hN => by
      have h₁ : B N hN = if N = x ⊔ y then {x, y} else {N} := rfl
      rw [h₁]
      split_ifs with h
      · -- Case: N = x ⊔ y
        have h₂ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by
          -- Prove that {x, y} is independent
          have h₃ : Disjoint x y := by
            simpa [h] using hxy
          have h₄ : sSupIndep ({x, y} : Set (PersistenceSubmodule M)) := by
            rw [sSupIndep_pair]
