/- # Last time

Last time we discussed differential calculus:
* `∫ x in a..b, f x` is the notation used for definite integrals
* `ℝ≥0∞` is the type of extended nonnegative real numbers `[0, ∞]`
* `MeasurableSpace X` is used to equip `X` with a σ-algebra
* `μ : OuterMeasure X` resp. `μ : Measure X` states that
  `μ` is an (outer) measure on `X`.
* `∀ᵐ x ∂μ, P x` means that `P` holds for almost all `x` (relative to `μ`)


** Today**
* finish integration
* inductive types
-/

section MeasureTheory

variable {X : Type*} [MeasurableSpace X] {μ : Measure X}
variable {Y : Type*} [MeasurableSpace Y] {ν : Measure Y} {f : X → Y}

example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    -- The set of rational numbers is countable, so its Lebesgue measure is zero.
    have h₁ : volume (Set.range (coe : ℚ → ℝ)) = 0 := by
      -- The set of rational numbers is countable, so its Lebesgue measure is zero.
      have h₂ : Set.Countable (Set.range (coe : ℚ → ℝ)) := by
        -- The set of rational numbers is countable.
        exact Set.countable_range _
      -- The Lebesgue measure of a countable set is zero.
      exact volume_null_of_countable h₂
    -- The complement of the set of rational numbers is the set of irrational numbers.
    -- The sum of the measures of the set of rational and irrational numbers is 1 (the measure of ℝ).
    -- Since the measure of the rational numbers is zero, the measure of the irrational numbers is 1.
    have h₂ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
      -- The set of rational numbers has measure zero, so almost all real numbers are not rational.
      have h₃ : volume (Set.range (coe : ℚ → ℝ)) = 0 := h₁
      -- Use the fact that the measure of the rational numbers is zero to conclude that almost all real numbers are not rational.
      exact ae_restrict_compl (by
        -- The set of rational numbers is measurable (as a countable union of measurable sets).
        apply measurableSet_range
        <;> simp [measurableCoe])
        (by
          -- The measure of the rational numbers is zero.
          simp_all [h₃])
        -- Lebesgue measure of the real line is not zero (in fact, it is infinite).
        (by
          -- The real line has infinite measure.
          simp_all [volume_ne_zero]
          <;>
          norm_num)
    -- If x is not in the set of rational numbers, then x is irrational.
    filter_upwards [h₂] with x hx
    -- Check that x is irrational.
    by_contra h₃
    -- If x is not irrational, then it is rational, which contradicts hx.
    have h₄ : Irrational x → False := by
      intro h₄
      exact h₃ h₄
    -- Thus, x must be irrational.
    have h₅ : ¬Irrational x := by
      intro h₅
      have h₆ : ∃ (q : ℚ), (q : ℝ) = x := by
        rw [Irrational] at h₅
        push_neg at h₅
        obtain ⟨q, hq⟩ := h₅
        exact ⟨q, by simpa using hq⟩
      obtain ⟨q, hq⟩ := h₆
      have h₇ : x ∈ Set.range (coe : ℚ → ℝ) := by
        use q
        <;> simp_all [hq]
      exact hx h₇
    exact h₅ (by simpa [Irrational] using h₃)
  -- The statement follows from the above argument.
  simpa using h

example {f : X → Y} : Measurable f ↔ (∀ s : Set Y, MeasurableSet s → MeasurableSet (f ⁻¹' s)) := by rfl
#check Continuous.measurable

/- We can write `MeasurePreserving f μ ν` to state that `f : X → Y`
maps the measure `μ : Measure X` to `ν : Measure Y`,
i.e. `ν s = μ (f ⁻¹' s)` for all (measurable) sets `s`.
This is important for Ergodic theory. -/
#check MeasurePreserving

/- A map `f` into a normed group is integrable when it is
measurable and the map `x ↦ ‖f x‖` has a finite integral.
You can write `Integrable f μ` to say that `f` is integrable
w.r.t. `μ`, and `Integrable f` for `μ = volume` -/
#check Integrable

example (f : ℝ → ℝ) (h1 : Continuous f) (h2 : HasCompactSupport f) : Integrable f :=
  Continuous.integrable_of_hasCompactSupport h1 h2

/- `Integrable` means that a function is integrable
on the whole domain.
You can use `IntegrableOn` to state that a function is
only integrable on some set. -/

#check IntegrableOn

example : ¬ Integrable (fun _ ↦ 1 : ℝ → ℝ) := by
  -- Assume for contradiction that the constant function 1 is integrable.
  intro h
  -- Since the function is constant and positive, its integral over ℝ would be infinite.
  have h₁ : (∫⁻ x : ℝ, ENNReal.ofReal (1 : ℝ)) = ∞ := by
    -- The integral of the constant function 1 over ℝ is the product of 1 and the measure of ℝ.
    -- The measure of ℝ is infinite, so the integral is also infinite.
    simp [Real.volume_ℝ]
    <;>
    simp_all [telescope_comap]
    <;>
    simp_all [volume_ne_zero]
    <;>
    norm_num
  -- However, if the function were integrable, this integral would be finite.
  have h₂ : (∫⁻ x : ℝ, ENNReal.ofReal (1 : ℝ)) < ∞ := by
    -- Use the fact that the constant function 1 is integrable to get a finite integral value.
    have h₃ : Integrable (fun _ : ℝ => (1 : ℝ)) := h
    -- Convert the integral to an extended nonnegative real number.
    have h₄ : (∫⁻ x : ℝ, ENNReal.ofReal (1 : ℝ)) = ENNReal.ofReal (∫ x : ℝ, (1 : ℝ)) := by
      simp [h₃]
      <;>
      simp_all [MeasureTheory.integral_of_nonneg]
      <;>
      simp_all [MeasureTheory.integral_of_nonneg]
      <;>
      simp_all [MeasureTheory.integral_of_nonneg]
      <;>
      norm_num
    -- The integral of the constant function 1 over ℝ is infinite.
    have h₅ : (∫ x : ℝ, (1 : ℝ)) = ∞ := by
      simp_all [Real.volume_ℝ]
      <;>
      simp_all [telescope_comap]
      <;>
      simp_all [volume_ne_zero]
      <;>
      norm_num
    -- Convert the finite integral value to an extended nonnegative real number.
    have h₆ : ENNReal.ofReal (∫ x : ℝ, (1 : ℝ)) < ∞ := by
      simp_all [h₅]
      <;>
      norm_num
    -- Combine the above results to get the contradiction.
    linarith
  -- Contradiction arises because the integral cannot be both finite and infinite.
  linarith
