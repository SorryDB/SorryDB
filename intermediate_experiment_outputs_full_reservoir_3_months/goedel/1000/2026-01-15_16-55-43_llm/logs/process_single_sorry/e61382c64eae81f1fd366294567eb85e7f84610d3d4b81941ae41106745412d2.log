  · -- Case: p = 0
    have h₁ : r = 0 := by
      -- Since p = 0, from the Hölder triple condition, we deduce r = 0
      have h₂ : ENNReal.HolderTriple (0 : ℝ≥0∞) q r := by simpa using hpqr
      simp [ENNReal.HolderTriple, ENNReal.isFinite_rpow] at h₂
      <;> aesop
    exfalso
    -- This case is impossible because r ≠ 0
    exact hr₀ (by simp_all)
  obtain rfl | q := q
  · -- Case: q = 0
    have h₁ : r = 0 := by
      -- Since q = 0, from the Hölder triple condition, we deduce r = 0
      have h₂ : ENNReal.HolderTriple (p : ℝ≥0∞) (0 : ℝ≥0∞) r := by simpa using hpqr
      simp [ENNReal.HolderTriple, ENNReal.isFinite_rpow] at h₂
      <;> aesop
    exfalso
    -- This case is impossible because r ≠ 0
    exact hr₀ (by simp_all)
  <;>
  simp_all [ENNReal.HolderTriple]
