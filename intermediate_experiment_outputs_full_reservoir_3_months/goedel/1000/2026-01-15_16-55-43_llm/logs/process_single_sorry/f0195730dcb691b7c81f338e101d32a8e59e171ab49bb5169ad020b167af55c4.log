```lean
lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  have h₁ : edgeSet q.2 = edgeSet (⟨s p.1, permMapWalk n s p.2⟩ : ClosedLoopWalk (K n)) := by rw [hs]
  rw [h₁]
  have h₂ : edgeSet (⟨s p.1, permMapWalk n s p.2⟩ : ClosedLoopWalk (K n)) = edgeSet (permMapWalk n s p.2) := by
    simp [ClosedLoopWalk, edgeSet]
  rw [h₂]
  have h₃ : (edgeSet (permMapWalk n s p.2)).card = (edgeSet p.2).card := by
    have h₄ : (edgeSet (permMapWalk n s p.2)).card = (edgeSet p.2).card := by
      -- The edges are mapped by a permutation, so the cardinality is preserved
      have h₅ : ∀ (p : (K n).LoopWalk _ _), (edgeSet (permMapWalk n s p)).card = (edgeSet p).card := by
        intro p
        induction' p with u v w h p ih
        · simp [permMapWalk_nil]
        · simp_all [permMapWalk_cons, SimpleGraph.LoopWalk.edges, Finset.card_union_of_disjoint, Finset.disjoint_singleton_right]
          <;>
          (try omega)
          <;>
          (try aesop)
          <;>
          (try simp_all [Equiv.Perm.card_perm])
          <;>
          (try simp_all [Finset.card_image_of_injective])
          <;>
          (try aesop)
        · simp_all [permMapWalk_loop, SimpleGraph.LoopWalk.edges]
          <;>
          (try omega)
          <;>
          (try aesop)
      exact h₅ p.2
    exact h₄
  rw [h₃]
```
