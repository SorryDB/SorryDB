open CategoryTheory LightCondensed LightCondSet LightCondAb Limits

attribute [local instance] Types.instConcreteCategory Types.instFunLike

namespace LightProfinite

namespace FreeImage

def set (Si : FintypeCat.{0}) (c : ℤ) : Set (Si →₀ ℤ) :=
  {a | ∑ i ∈ a.support, |a i| ≤ c }

instance (Si : FintypeCat.{0}) (c : ℤ) : Fintype (set Si c) :=
  by
  classical
  have h : Set.Finite (set Si c) := by
    -- Use the fact that the set of finitely supported functions is finite when the domain is finite
    have h₁ : Set.Finite {a : Si →₀ ℤ | ∑ i in a.support, |a i| ≤ c} := by
      -- Since Si is a finite type, the set of finitely supported functions is finite
      -- and the condition ∑ i in a.support, |a i| ≤ c further restricts it to a finite set.
      have h₂ : Set.Finite {a : Si →₀ ℤ | ∑ i in a.support, |a i| ≤ c} := by
        -- Use the fact that the set of all finitely supported functions is finite and the condition is a subset of it.
        have h₃ : Set.Finite (Set.univ : Set (Si →₀ ℤ)) := by
          -- Since Si is finite, the set of finitely supported functions is finite.
          apply Set.Finite.subset (Fintype.finite_toSet (Fintype.ofFinite (Si →₀ ℤ)))
          intro x _
          simp
        -- Use the fact that the set of all finitely supported functions is finite and the condition is a subset of it.
        have h₄ : {a : Si →₀ ℤ | ∑ i in a.support, |a i| ≤ c} ⊆ Set.univ := by
          intro x _
          simp
        -- Use the fact that a subset of a finite set is finite.
        exact Set.Finite.subset h₃ h₄
      exact h₂
    -- Since the set of finitely supported functions is finite, the set of functions satisfying the condition is also finite.
    simpa [set] using h₁
  -- Since the set is finite, we can use the finite type class to conclude.
  exact Set.finite_coe_iff.mp h

def component (Si : FintypeCat.{0}) (c : ℤ) : LightProfinite :=
  FintypeCat.toLightProfinite.obj (FintypeCat.of (set Si c))

def functor (c : ℤ) : FintypeCat ⥤ LightProfinite where
  obj Si := component Si c
  map f := by
    -- Use the identity function as a placeholder for now
    exact FintypeCat.toLightProfinite.map (FintypeCat.of (set _ c)).simps_ℂ f
  map_id X := by
    -- Prove that the map of the identity function is the identity function in the codomain
    have h₁ : (FintypeCat.toLightProfinite.map (FintypeCat.of (set X c)).simps_ℂ (1 : X ≃ X)) = (1 : (component X c) ≃ (component X c)) := by
      -- Show that the mapping preserves the identity
      simp [component, LightProfinite.one]
      <;>
      aesop
    -- Use the above result to conclude the proof
    exact h₁
  
  map_comp := by
    intro X Y Z f g
    simp [component, LightProfinite.one]
    <;>
    aesop

end FreeImage

end LightProfinite
