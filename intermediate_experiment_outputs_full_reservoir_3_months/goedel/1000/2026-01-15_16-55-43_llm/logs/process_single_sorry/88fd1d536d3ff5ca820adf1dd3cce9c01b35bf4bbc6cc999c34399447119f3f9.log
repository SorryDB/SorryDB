      _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(ZeroAtInfty.liftContinuousMap _ f : C₀((spectrum ℂ a), ℂ))‖ := by rfl
      _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
        have h₂ : ‖(ZeroAtInfty.liftContinuousMap _ f : C₀((spectrum ℂ a), ℂ))‖ = ‖f‖ := by
