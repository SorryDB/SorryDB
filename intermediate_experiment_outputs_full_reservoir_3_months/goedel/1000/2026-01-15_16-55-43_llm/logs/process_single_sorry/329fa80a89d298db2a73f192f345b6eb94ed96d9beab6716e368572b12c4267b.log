      have h₃ : ∫ (x : X) in univ, (f x : ℝ) ∂μ.re = (μ.re.integral (fun x => (f x : ℝ))).toReal := by
        simp [MeasureTheory.integral_congr]
        <;> simp_all [ComplexMeasure.integral_def, ComplexMeasure.re]
