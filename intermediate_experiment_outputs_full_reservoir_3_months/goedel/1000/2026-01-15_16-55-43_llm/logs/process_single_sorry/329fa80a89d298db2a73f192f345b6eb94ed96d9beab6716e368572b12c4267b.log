lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  --Reduce the problem to the real case by considering the real and imaginary parts
