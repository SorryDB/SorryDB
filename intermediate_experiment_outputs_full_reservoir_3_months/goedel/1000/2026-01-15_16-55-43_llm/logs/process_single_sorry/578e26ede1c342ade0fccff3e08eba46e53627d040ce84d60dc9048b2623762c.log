theorem RelIO.mapVal {α β} {n : Nat} {f : Fin n → α} {g : α → β} :
  AssocList.mapVal (λ _ => g) (RelIO.liftFinf n f) = RelIO.liftFinf n (λ i => g (f i)) := by
  -- Simplify the definitions to see the underlying structure.
  dsimp [RelIO.liftFinf]
  -- Use the properties of lists and Fin sets to show equality.
  have h₁ : (fin_range n).map (λ i : Fin n => ⟨i.toNat, f i⟩) = (fin_range n).map (λ i : Fin n => ⟨i.toNat, f i⟩) := rfl
  -- Use the fact that mapping over a list and then converting to an association list is the same as directly constructing the association list.
  have h₂ : ((fin_range n).map (λ i : Fin n => ⟨i.toNat, f i⟩ |>.toAssocList)).mapVal (fun x => g) = ((fin_range n).map (λ i : Fin n => ⟨i.toNat, g (f i)⟩) |>.toAssocList) := by
    -- Use the simp tactic to simplify the expressions and show they are equal.
    simp [List.map_toList_toAssocList, List.map_mapFinIdx]
    <;>
    (try
      {
        induction n with
        | zero => rfl
        | succ n ih =>
          simp_all [fin_range, List.map_cons, List.map_singleton]
          <;>
          simp_all [List.toAssocList, List.map_mapFinIdx]
          <;>
          simp_all [List.map_mapFinIdx]
          <;>
          simp_all [List.toAssocList]
          <;>
          simp_all [List.map_mapFinIdx]
          <;>
          simp_all [List.toAssocList]
          <;>
          simp_all [List.map_mapFinIdx]
          <;>
          simp_all [List.toAssocList]
      }
      )
    <;>
    simp_all [AssocList.mapVal]
    <;>
    simp_all [List.map_mapFinIdx]
    <;>
    simp_all [List.toAssocList]
    <;>
    simp_all [List.map_mapFinIdx]
    <;>
    simp_all [List.toAssocList]
  -- Use the simplified expressions to conclude the proof.
  simpa [h₁, h₂] using h₂
