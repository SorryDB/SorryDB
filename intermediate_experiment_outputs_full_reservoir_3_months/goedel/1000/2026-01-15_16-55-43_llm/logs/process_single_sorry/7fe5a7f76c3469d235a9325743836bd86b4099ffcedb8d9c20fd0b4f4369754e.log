theorem kerLift_injective' (f : R →+* S) (x : R ⧸ ker f) (hx : kerLift f x = 0) : x = 0 := by
  rcases Ideal.Quotient.mk_surjective x with ⟨x', hx'⟩
  rw [← hx']
  rw [← hx'] at hx
  have h₁ : kerLift f (Ideal.Quotient.mk (ker f) x') = 0 := hx
  have h₂ : f x' = 0 := by
    have h₂₁ : kerLift f (Ideal.Quotient.mk (ker f) x') = f x' := by
      rw [kerLift_mk]
    rw [h₂₁] at h₁
    exact h₁
  
  have h₃ : x' ∈ ker f := by
    rw [Ideal.mem_ker]
    exact h₂
  
  have h₄ : Ideal.Quotient.mk (ker f) x' = 0 := by
    have h₄₁ : Ideal.Quotient.mk (ker f) x' = 0 := by
      apply Ideal.Quotient.eq_zero_iff_mem.mpr
      exact h₃
    exact h₄₁
  
  have h₅ : x = 0 := by
    rw [hx']
    exact h₄
  
  exact h₅
