noncomputable section

namespace ItaLean4

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact Filter.map_mono f h

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h : (F.map (t ∘ s)) ≤ H := by
    calc
      F.map (t ∘ s) = F.map s |>.map t := by
        rw [Function.comp]
        <;> simp [Filter.map_map]
      _ ≤ G.map t := by
        -- Since `F.map s ≤ G`, we can use the fact that mapping preserves the order
        have h₁ : F.map s ≤ G := hs
        exact Filter.map_mono t h₁
      _ ≤ H := ht
  exact h

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the fact that the composition of tendsto functions is tendsto
    have h₁ : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h₂ : Tendsto g (𝓝 Real.pi) atTop := hg
    exact Tendsto_comp h₁ h₂
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    -- Use the fact that the composition of tendsto functions is tendsto
    have h₁ : Tendsto a atTop (𝓝 (-1)) := ha
    have h₂ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
    exact Tendsto_comp h₁ h₂
  exact h

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x : α | p x ∧ q x} ∈ 𝓝 x := by
    have h₁₁ : {x : α | p x} ∈ 𝓝 x := hT
    have h₁₂ : {x : α | q x} ∈ 𝓝 x := hS
    -- The intersection of two neighborhoods is a neighborhood
    have h₁₃ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      apply Filter.inter_mem
      · exact h₁₁
      · exact h₁₂
    -- The intersection is the set where both p and q hold
    have h₁₄ : {x : α | p x} ∩ {x : α | q x} = {x : α | p x ∧ q x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h₁₄] at h₁₃
    exact h₁₃
  have h₂ : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    have h₂₁ : {x : α | p' x} ∈ 𝓝 x := hT'
    have h₂₂ : {x : α | q' x} ∈ 𝓝 x := hS'
    -- The intersection of two neighborhoods is a neighborhood
    have h₂₃ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      apply Filter.inter_mem
      · exact h₂₁
      · exact h₂₂
    -- The intersection is the set where both p' and q' hold
    have h₂₄ : {x : α | p' x} ∩ {x : α | q' x} = {x : α | p' x ∧ q' x} := by
      ext x
      simp [and_comm]
      <;> aesop
    rw [h₂₄] at h₂₃
    exact h₂₃
  -- The union of two neighborhoods is a neighborhood
  have h₃ : {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    apply Filter.union_mem
    · exact h₁
    · exact h₂
  -- The union is the set where either (p and q) or (p' and q') hold
  have h₄ : {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} = {x : α | p x ∧ q x ∨ p' x ∧ q' x} := by
    ext x
    simp [or_comm]
    <;> aesop
  rw [h₄] at h₃
  exact h₃

end Filter

section Lp

open MeasureTheory ENNReal Set

def μD : OuterMeasure ℝ where
  measureOf := fun s => if 0 ∈ s then 1 else 0
  empty := by
    simp [measureOf]
    <;> aesop
