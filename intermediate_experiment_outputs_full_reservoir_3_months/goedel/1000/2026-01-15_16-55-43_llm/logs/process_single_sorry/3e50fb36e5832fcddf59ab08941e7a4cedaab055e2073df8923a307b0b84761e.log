lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X Y hXY
  have h : val_image A X = val_image A Y := hXY
  have h1 : X ⊆ Y := by
    intro x hx
    have h2 : (x : U) ∈ val_image A X := by
      exact ⟨x, hx, rfl⟩
    have h3 : (x : U) ∈ val_image A Y := by
      rw [h] at h2
      exact h2
    rcases h3 with ⟨y, hy, hy'⟩
    have h4 : (y : U) = (x : U) := by
      simp_all [Subtype.ext_iff]
      <;> aesop
    have h5 : y = x := by
      simpa [Subtype.ext_iff] using h4
    exact hy
  have h2 : Y ⊆ X := by
    intro x hx
    have h3 : (x : U) ∈ val_image A Y := by
      exact ⟨x, hx, rfl⟩
    have h4 : (x : U) ∈ val_image A X := by
      rw [h] at *
      exact h3
    rcases h4 with ⟨y, hy, hy'⟩
    have h5 : (y : U) = (x : U) := by
      simp_all [Subtype.ext_iff]
      <;> aesop
    have h6 : y = x := by
      simpa [Subtype.ext_iff] using h5
    exact hy
  exact Set.Subset.antisymm h1 h2
  
lemma range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  apply Set.Subset.antisymm
  · -- Prove that the range of val_image A is a subset of 𝒫 A
    intro X hX
    rcases hX with ⟨S, rfl⟩
    -- For any S : Set (A : Set U), val_image A S is a subset of A
    have h : val_image A S ⊆ A := by
      intro x hx
      rcases hx with ⟨y, hy, rfl⟩
      exact hy.1
    -- Since val_image A S is a subset of A, it is in 𝒫 A
    exact h
  · -- Prove that 𝒫 A is a subset of the range of val_image A
    intro X hX
    -- For any X in 𝒫 A, there exists S such that val_image A S = X
    have h : X ∈ 𝒫 A := hX
    have h1 : X ⊆ A := by simpa using h
    -- Take S = {x : A | (x : U) ∈ X}
    let S : Set {x : U // x ∈ A} := {x : {x : U // x ∈ A} | (x : U) ∈ X}
    -- Show that val_image A S = X
    have h2 : val_image A S = X := by
      apply Set.Subset.antisymm
      · -- Prove val_image A S ⊆ X
        intro x hx
        rcases hx with ⟨y, hy, hy'⟩
        have h3 : (y : U) ∈ X := by
          simp_all [S, Set.mem_setOf_eq]
          <;> aesop
        simp_all [Subtype.ext_iff]
        <;> aesop
      · -- Prove X ⊆ val_image A S
        intro x hx
        have h3 : x ∈ A := h1 hx
        have h4 : ⟨x, h3⟩ ∈ S := by
          simp_all [S, Set.mem_setOf_eq]
          <;> aesop
        have h5 : (x : U) ∈ val_image A S := by
          exact ⟨⟨x, h3⟩, h4, rfl⟩
        simp_all [Subtype.ext_iff]
        <;> aesop
    -- Therefore, X is in the range of val_image A
    refine' ⟨S, _⟩
    simp_all
  
lemma Set_equinum_powerset {U : Type} (A : Set U) :
    Set A ∼ 𝒫 A := by
  -- We need to show that the set of subsets of A is equinumerous with the powerset of A.
  -- The powerset of A is defined as the set of all subsets of A, so they are trivially equinumerous.
  -- We can use the fact that the powerset of A is exactly Set A.
  -- Therefore, the cardinality of Set A is the same as the cardinality of 𝒫 A.
  have h : 𝒫 A = Set A := by
    -- Prove that the powerset of A is equal to the set of subsets of A.
    ext X
    simp [Set.mem_pow]
    <;> tauto
  -- Since 𝒫 A = Set A, we have Set A ∼ 𝒫 A.
  rw [h]
  <;> equi.refl
  
