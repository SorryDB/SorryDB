theorem list_Perm_insertIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
    {idx1 idx2 : Nat} {hidx1 : idx1 <= l1.length} {hidx2 : idx2 <= l2.length} {elt : α} :
    (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
  -- Use the given permutation to construct a new permutation for the inserted lists
  have h : (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
    -- Utilize the fact that inserting an element into two permutation lists at arbitrary indices preserves the permutation property
    have h₁ : (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx1 elt) := by
      -- Use the `Perm.insert` lemma to insert an element at the same index in both lists
      apply List.Perm.insert
      <;> simp_all [List.Perm]
      <;> try omega
    have h₂ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
      -- Use the `Perm.insert` lemma to show that inserting at two different indices preserves permutation
      have h₃ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
        -- Handle the case where the indices are the same
        by_cases h₄ : idx1 = idx2
        · simp_all [h₄, List.Perm]
        · -- Use the `Perm.insert` lemma to show that inserting at two different indices preserves permutation
          have h₅ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
            -- Use the `Perm.insert` lemma to show that inserting at two different indices preserves permutation
            have h₆ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
              -- Use the `Perm.insert` lemma to show that inserting at two different indices preserves permutation
              have h₇ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
                -- Use the `Perm.insert` lemma to show that inserting at two different indices preserves permutation
                apply List.Perm.swapList
                <;> simp_all [List.Perm]
                <;>
                  (try omega) <;>
                  (try {
                    have h₈ : idx1 < l2.length + 1 := by omega
                    have h₉ : idx2 < l2.length + 1 := by omega
                    omega
                  }) <;>
                  (try {
                    have h₈ : idx1 < l2.length + 1 := by omega
                    have h₉ : idx2 < l2.length + 1 := by omega
                    simp_all [Nat.lt_succ_iff]
                    <;> omega
                  })
              exact h₇
            exact h₆
          exact h₅
      exact h₃
    -- Combine the two permutations to get the final result
    exact List.Perm.trans h₁ h₂
  exact h
