lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  have h : valuation L (e x) = valuation L x := by
    have h₁ : valuation L = valuation L := rfl
    have h₂ : e.toFun = e.toFun := rfl
    -- Use the property of valuation preserving field automorphisms in non-archimedean local fields
    have h₃ : valuation L (e x) = valuation L x := by
      -- Since the valuation is preserved under field automorphisms in non-archimedean local fields,
      -- we have that valuation (e x) = valuation x.
      have h₄ : valuation L (e x) = valuation L x := by
        -- Use the fact that the valuation is preserved under field automorphisms
        calc
          valuation L (e x) = valuation L (e.toFun x) := rfl
          _ = valuation L x := by
            -- Since e is an automorphism, it preserves the valuation
            have h₅ : (e.toFun : L ≃+* L).toFun = e.toFun := rfl
            -- Use the fact that the valuation is preserved under field automorphisms
            -- This is a property that can be derived from the theory of non-archimedean local fields
            -- Specifically, in such fields, the valuation is preserved under automorphisms
            -- Therefore, valuation (e x) = valuation x
            -- The following line is a placeholder for the actual proof of this property
            -- In a full proof, this would require detailed number-theoretic arguments
            -- However, we can use the fact that the valuation is preserved under field automorphisms in non-archimedean local fields
            -- This is a known property in the theory of local fields
            simp_all [RingHom.isUnit_iff_map_isUnit]
            <;> simp_all [RingHom.isUnit_iff_map_isUnit]
            <;>
              (try norm_num) <;>
              (try simp_all [val_add_eq]) <;>
              (try simp_all [val_mul_eq]) <;>
              (try simp_all [val_inv_eq]) <;>
              (try simp_all [val_one]) <;>
              (try simp_all [val_zero]) <;>
              (try simp_all [val_neg_eq]) <;>
              (try simp_all [val_pow]) <;>
              (try simp_all [val_eq_zero_iff]) <;>
              (try simp_all [val_lt_zero_iff]) <;>
              (try simp_all [val_pos_iff])
            <;>
              (try contradiction) <;>
              (try aesop)
      exact h₄
    exact h₃
  exact h

instance (G : Type*) [Group G] (L : Type*) [Field L] [TopologicalSpace L] [ValuativeRel L]
    [IsNonarchimedeanLocalField L] [MulSemiringAction G L] : MulSemiringAction G 𝒪[L] where
  smul g r := ⟨g • r.1, by
    obtain ⟨r, hr⟩ := r
    rw [Valuation.mem_integer_iff] at hr
    rwa [← valuation_ringEquiv (MulSemiringAction.toRingEquiv G L g) r] at hr⟩
  one_smul r := Subtype.ext <| one_smul G _
  mul_smul g h r := Subtype.ext <| mul_smul g h _
  smul_zero g := Subtype.ext <| smul_zero g
  smul_add g r s := Subtype.ext <| smul_add g _ _
  smul_one g := Subtype.ext <| smul_one g
  smul_mul g r s := Subtype.ext <| smul_mul' g _ _

instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    SMul 𝒪[K] 𝒪[L] where
  smul r s := ⟨r.1 • s.1, by
    obtain ⟨r, hr⟩ := r
    obtain ⟨s, hs⟩ := s
    rw [Valuation.mem_integer_iff] at hr hs ⊢
    rw [Algebra.smul_def, Valuation.map_mul]
    apply mul_le_one₀ _ zero_le' hs
    rw [← map_one (valuation L), ← Valuation.Compatible.rel_iff_le,
      ← RingHom.map_one (algebraMap K L),
      ValuativeExtension.rel_iff_rel]
    rw [← map_one (valuation K), ← Valuation.Compatible.rel_iff_le] at hr
    exact hr⟩

instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
