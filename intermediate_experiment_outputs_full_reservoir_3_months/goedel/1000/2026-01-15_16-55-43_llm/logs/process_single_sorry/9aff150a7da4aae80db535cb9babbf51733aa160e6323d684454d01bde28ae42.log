```lean
/-! # Quadratic variation of local martingales

-/

open MeasureTheory Filter
open scoped ENNReal

namespace ProbabilityTheory

variable {ι Ω E : Type*} [LinearOrder ι] [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
  [MeasurableSpace ι] [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω} {X : ι → Ω → E} {𝓕 : Filtration ι mΩ}

lemma IsLocalMartingale.isLocalSubmartingale_sq_norm
    (hX : IsLocalMartingale X 𝓕 P) (hX_cadlag : ∀ ω, IsCadlag (X · ω)) :
    IsLocalSubmartingale (fun t ω ↦ ‖X t ω‖ ^ 2) 𝓕 P := by
  sorry

/-- The quadratic variation of a local martingale, defined as the predictable part of the Doob-Meyer
decomposition of its squared norm. -/
noncomputable
def quadraticVariation (hX : IsLocalMartingale X 𝓕 P) (hX_cadlag : ∀ ω, IsCadlag (X · ω)) :
    ι → Ω → ℝ :=
  have hX2_cadlag : ∀ ω, IsCadlag (fun t ↦ ‖X t ω‖ ^ 2) := by
    intro ω
    have h1 : IsCadlag (X · ω) := hX_cadlag ω
    have h2 : Continuous (fun t : ι => ‖(X t ω : E)‖) := by
      have h3 : Continuous (X · ω) := h1.continuousOn_Iio.stronger (by
        -- We use the fact that the function is cadlag to get continuity everywhere except at jump points
        -- and then use the order topology to show continuity on the whole space.
        exact ContinuousOrderTopology.continuousOn_Cadlag_windforward (h1 isOpen_Iio))
      -- The norm is continuous, so the composition is continuous.
      exact Continuous.norm h3
    -- Since the square function is continuous, the composition is continuous.
    have h4 : Continuous (fun t : ι => ‖(X t ω : E)‖ ^ 2) := by
      exact Continuous.pow h2 2
    -- A continuous function is also isCadlag.
    exact isCadlag_of_continuous h4
  sorry
```
