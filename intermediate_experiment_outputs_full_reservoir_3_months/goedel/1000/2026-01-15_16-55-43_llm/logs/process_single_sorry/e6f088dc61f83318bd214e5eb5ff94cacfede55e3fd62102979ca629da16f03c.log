theorem list_Perm_eraseIdx {l1 l2 : List α} {idx1 idx2 : Nat} {hidx1 : idx1 < l1.length} {hidx2 : idx2 < l2.length} {heq : l1[idx1] = l2[idx2]} {hperm : l1.Perm l2} :
    (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
  have h : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
    -- Use the fact that permutation is preserved when we remove the same element from both lists
    -- despite the difference in indices, provided that the elements at those indices are equal.
    have h₁ : (List.eraseAt l1 idx1).Perm (List.eraseAt l2 idx2) := by
      have h₂ := hperm
      -- Use the property of permutations that removing the same element preserves the permutation
      -- if we adjust the indices appropriately.
      have h₃ : (List.eraseAt l1 idx1).Perm (List.eraseAt l2 idx2) := by
        -- Use the fact that we can adjust the indices to match the permutation
        apply List.Perm.trans (List.eraseAt_perm_insertAt l1 idx1)
        apply List.Perm.trans (List.Perm.symm (List.eraseAt_perm_insertAt l2 idx2))
        -- Use the original permutation to bridge the gap
        apply List.Perm.trans (List.Perm.symm (hperm.insertAtPerm_insertAt 0))
        -- Since we are removing the same element, we can adjust the indices to match
        <;>
        (try
          simp_all [List.get, List.eraseAt, List.insertAt, Nat.add_assoc, Nat.add_sub_cancel,
            Nat.add_comm, Nat.add_left_comm])
        <;>
        (try
          omega)
        <;>
        (try
          aesop)
      exact h₃
    exact h₁
  exact h
```

### Explanation of the Proof

1. **Understanding the Problem**:
   - We have two lists `l1` and `l2` that are permutations of each other (`hperm : l1.Perm l2`).
   - We are given `idx1 : ℕ` such that `hidx1 : idx1 < l1.length`, and similarly for `l2` (`hidx2 : idx2 < l2.length`).
