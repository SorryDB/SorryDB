    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  have h₁ : M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl N)) := by
    exact ⟨fun ϕ _ hprime => by
      -- For a pseudo-isomorphism ϕ : M → N, we need to show that for each height one prime p,
      -- the localized modules are isomorphic.
      have h₂ : ϕ.IsPseudoIsomorphism := ϕ.isPseudoIsomorphism
      -- Use the fact that ϕ is a pseudo-isomorphism to deduce the required property for each p.
      have h₃ : (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT (ϕ.2)).mp h₂
      have h₄ : Function.Bijective (LocalizedModule.map (⨅ p ∈ (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}, p.1.primeCompl) (ϕ.2))
          := h₃
      have h₅ : ∀ (p : PrimeSpectrum A), p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl N)) := by
        intro p hprime
        -- For each height one prime p, we need to find an isomorphism between the localized modules.
        have h₆ : p ∈ (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1} ∨ p ∉ (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1} := by
          by_cases h : p ∈ (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
          · exact Or.inl h
          · exact Or.inr h
        cases h₆ with
