import Lean

namespace BitVec

def bb (x : BitVec w) : BitVec w :=
  (iunfoldr (fun i _ => ((), x.getLsbD i)) ()).snd

theorem self_eq_bb (x : BitVec w) : x = x.bb := by
  unfold bb
  rw [iunfoldr_replace_snd (λ _ => ()) (init:=rfl)]
  intro i
  rfl

def beq (x : BitVec w) (y : BitVec w) : Bool :=
  go (w - 1)
where
  go : Nat → Bool
    | 0     => x.getLsbD (w - 1) == y.getLsbD (w - 1)
    | i + 1 => x.getLsbD ((w - 1) - (i + 1)) == y.getLsbD ((w - 1) - (i + 1)) && go i

def beq (w : ℕ) (x : BitVec w) (y : BitVec w) : Bool :=
  go (w - 1)
where
  go : Nat → Bool
    | 0     => x.getLsbD (w - 1) == y.getLsbD (w - 1)
    | i + 1 => x.getLsbD ((w - 1) - (i + 1)) == y.getLsbD ((w - 1) - (i + 1)) && go i

theorem eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  have h_main : (x = y) = (x.beq y = true) := by
    have h₁ : ∀ (w : ℕ) (x y : BitVec w), (x = y) = (beq w x y = true) := by
      intro w x y
      have h₂ : ∀ (w : ℕ) (x y : BitVec w), (x = y) ↔ (beq w x y = true) := by
        intro w x y
        have h₃ : ∀ (n : ℕ) (x y : BitVec n), (x = y) ↔ (beq n x y = true) := by
          intro n
          induction' n with n ih
          · intro x y
            simp [beq]
          · intro x y
            simp_all [beq, BitVec.ext_iff, Nat.succ_eq_add_one]
            <;>
            (try cases x <;> cases y <;> simp_all (config := {decide := true})) <;>
            (try {
              constructor <;> intro h <;>
              (try simp_all [Bool.and_eq_true]) <;>
              (try {
                aesop
              }) <;>
              (try {
                cases n <;> simp_all [beq, BitVec.ext_iff, Nat.succ_eq_add_one] <;>
                (try aesop)
              })
            }) <;>
            (try {
              simp_all [Bool.and_eq_true]
              <;>
              aesop
            }) <;>
            (try {
              aesop
            })
        exact h₃ w x y
      have h₄ := h₂ w x y
      simp [h₄]
      <;>
      aesop
    have h₅ := h₁ w x y
    simp_all [beq]
    <;>
    aesop
  have h₂ : (x = y) = x.beq y := by
    have h₃ : x.beq y = true ↔ (x = y) := by
      have h₄ : (x = y) = (x.beq y = true) := h_main
      have h₅ : (x = y) ↔ (x.beq y = true) := by
        simp [h₄]
      tauto
    have h₆ : (x = y) = x.beq y := by
      cases Classical.em (x = y) <;> simp_all [Bool.eq_iff_true]
      <;>
      (try {
        simp_all [h₃]
        <;>
        aesop
      }) <;>
      (try {
        simp_all [h₃]
        <;>
        aesop
      })
    exact h₆
  exact h₂
```
