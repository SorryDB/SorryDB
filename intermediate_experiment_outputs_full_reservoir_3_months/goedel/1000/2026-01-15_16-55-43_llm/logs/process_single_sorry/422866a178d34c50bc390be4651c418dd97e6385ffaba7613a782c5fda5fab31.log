    [inst_1 : SampleableType α] [(spec α).DecidableEq]
    (preexisting_cache : (spec α).QueryCache) (n : ℕ)
    (leaves : List.Vector α (2 ^ (n + 1))) : HasEvalSPMF.NeverFail
      ((simulateQ randomOracle (buildLayer α n leaves)).run preexisting_cache) := by
  have h₁ : HasEvalSPMF.NeverFail ((Vector.mmap (fun (x : α × α) => (query (spec := (MerkleTree.spec α)) x : OracleComp (MerkleTree.spec α) α))
    (List.Vector.ofFn (fun (i : Fin (2 ^ n)) =>
      (leaves.get ⟨2 * (i : ℕ), by
        have h₁ : 2 * (i : ℕ) < 2 ^ (n + 1) := by
          have h₂ : (i : ℕ) < 2 ^ n := by
            exact Fin.is_lt i
          have h₃ : 2 * (i : ℕ) < 2 ^ (n + 1) := by
            calc
              2 * (i : ℕ) < 2 * 2 ^ n := by
                nlinarith [pow_pos (by decide : (0 : ℕ) < 2) n]
              _ = 2 ^ (n + 1) := by
                ring_nf
                <;> simp [pow_succ]
                <;> ring_nf
          exact h₃
        exact h₁
      ⟩, leaves.get ⟨2 * (i : ℕ) + 1, by
        have h₁ : 2 * (i : ℕ) + 1 < 2 ^ (n + 1) := by
          have h₂ : (i : ℕ) < 2 ^ n := by
            exact Fin.is_lt i
          have h₃ : 2 * (i : ℕ) + 1 < 2 ^ (n + 1) := by
            calc
              2 * (i : ℕ) + 1 < 2 * 2 ^ n + 1 := by
                nlinarith [pow_pos (by decide : (0 : ℕ) < 2) n]
              _ ≤ 2 * 2 ^ n + 1 := by rfl
              _ < 2 ^ (n + 1) := by
                have h₄ : 2 ^ (n + 1) = 2 * 2 ^ n := by
                  ring_nf
                  <;> simp [pow_succ]
                  <;> ring_nf
                omega
          exact h₃
        exact h₁
      ⟩)))).run preexisting_cache) := by sorry
  sorry
