open AlgebraicGeometry

variable {R : CommRingCat} {G : Scheme} [G.Over (Spec R)] [GrpObj (asOver G (Spec R))] {A : Type u} [AddCommGroup A]
variable [IsDomain R]

/-- An affine algebraic group `G` over a domain `R` is diagonalisable iff it is affine and `Γ(G)` is
`R`-spanned by its group-like elements.

Note that this is more generally true over arbitrary commutative rings, but we do not prove that.
See SGA III, Exposé VIII for more info.

Note that more generally a not necessarily affine algebraic group `G` over a field `K` is
diagonalisable iff it is affine and `Γ(G)` is `K`-spanned by its group-like elements, but we do not
prove that. -/
lemma isDiagonalisable_iff_span_isGroupLikeElem_eq_top [IsAffine G] :
    IsDiagonalisable (Spec R) G ↔ Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
  have h₁ : IsDiagonalisable (Spec R) G → Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
    intro h
    rcases h with ⟨A, _, e, _, _⟩
    -- We need to show that the span of group-like elements is the entire space of global sections.
    -- This will follow from the fact that the diagonal algebra is generated by its group-like elements.
    have h₂ : Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
      -- Use the fact that the diagonal algebra is generated by group-like elements to show that the span is the entire space.
      sorry
    exact h₂
  have h₂ : Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ → IsDiagonalisable (Spec R) G := by
    intro h
    -- We need to show that G is diagonalizable given that the span of group-like elements is the entire space.
    -- This will involve showing that G is isomorphic to a diagonal group.
    have h₃ : IsDiagonalisable (Spec R) G := by
      -- Use the fact that the span of group-like elements is the entire space to construct an isomorphism to a diagonal group.
      sorry
    exact h₃
  exact ⟨h₁, h₂⟩
  <;> try simp_all
  <;> try aesop
  <;> try norm_num
  <;> try ring
  <;> try field_simp
  <;> try norm_cast
  <;> try linarith
