```lean
noncomputable instance Circle.hasEnoghRootsOfUnity {n : ℕ} [NeZero n] : HasEnoughRootsOfUnity Circle n where
  prim := by
    refine ⟨⟨cexp ((2 * π / n :) * I), ?_⟩, ?_⟩
    · simpa only [Submonoid.mem_unitSphere] using norm_exp_ofReal_mul_I (2 * π / ↑n)
    · refine IsPrimitiveRoot.of_map_of_injective (f := coeHom) ?_
        ((Set.injective_codRestrict Subtype.property).mp fun ⦃_ _⦄ a ↦ a)
      simp only [coeHom_apply]
      convert Complex.isPrimitiveRoot_exp n (NeZero.ne n) using 2
      push_cast
      ring
  cyc := by
    let M : Type _ := rootsOfUnity n Circle
    have : IsCyclic M := by
      -- Use the fact that roots of unity in ℂ form a cyclic group and the isomorphism between them
      have h₁ : rootsOfUnity n ℂ ≃* rootsOfUnity n Circle := (Circle.rootsOfUnityMulEquiv n).symm
      have h₂ : IsCyclic (rootsOfUnity n ℂ) := by
        -- The roots of unity in ℂ are cyclic
        apply cyclic_of_prime_not_dvd
        <;>
        (try
          {
            norm_num
            <;>
            deduce_instance
          })
        <;>
        (try
          {
            simp_all [Nat.Prime]
            <;>
            deduce_instance
          })
        <;>
        (try
          {
            aesop
          })
      -- Since roots of unity in ℂ are cyclic and the groups are isomorphic, roots of unity in Circle are also cyclic
      exact IsCyclic.of_mulEquiv h₁ h₂
    exact this
```

