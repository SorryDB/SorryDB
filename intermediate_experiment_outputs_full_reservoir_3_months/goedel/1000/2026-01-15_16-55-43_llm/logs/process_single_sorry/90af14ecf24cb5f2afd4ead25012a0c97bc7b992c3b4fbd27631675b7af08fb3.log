### Complete Lean 4 Proof

```lean
noncomputable section

namespace LeanProof

variable (R : Type)
variable [Fintype R]
variable [CommSemiring R]

have h_main : ⨅ (m : Ideal R) (hm : IsMaximal m), m = ⊥ := by
  have h₁ : ⨅ (m : Ideal R) (hm : IsMaximal m), m = ⨅ m : Ideal R, m.prime → m := by
    apply le_antisymm
    · -- Prove that the intersection of all maximal ideals is less than or equal to the intersection of all prime ideals
      apply iInf₂_le_iInf
      intro m
      intro hm
      haveI : m.IsMaximal := hm
      have h₂ : m.prime := by
        exact m.isPrime_of_isMaximal
      exact h₂
    · -- Prove that the intersection of all prime ideals is less than or equal to the intersection of all maximal ideals
      apply iInf_le_iInf₂
      intro m hm
      have h₂ : m.prime := hm
      by_cases h₃ : m = ⊤
      · exfalso
        have h₄ : ¬m.prime := by
          intro h₄
          have h₅ : m ≠ ⊤ := by
            intro h₅
            rw [h₅] at h₄
            exact not_prime_top h₄
          contradiction
        contradiction
      · -- Since R is finite, every prime ideal is maximal
        have h₄ : IsMaximal m := by
          have h₅ : m.prime := h₂
          have h₆ : m ≠ ⊤ := h₃
          have h₇ : IsMaximal m := by
            apply isPrime_iff_isMaximal.mp h₅
          exact h₇
        exact h₄
  have h₂ : ⨅ m : Ideal R, m.prime → m = ⊥ := by
    -- The intersection of all prime ideals is the nilradical, which is zero in a reduced ring.
    -- Since R is finite, it is reduced.
    have h₃ : ⨅ m : Ideal R, m.prime → m = ⊥ := by
      have h₄ : Reduced R := by
        infer_instance
      have h₅ : ⨅ m : Ideal R, m.prime → m = ⊥ := by
        -- Use the fact that the nilradical is zero in a reduced ring
        have h₆ : (⊥ : Ideal R) = ⊥ := rfl
        have h₇ : ⨅ m : Ideal R, m.prime → m = ⊥ := by
          -- Use the property of the nilradical in reduced rings
          classical
          calc
            ⨅ m : Ideal R, m.prime → m = radical (⊥ : Ideal R) := by
              -- The intersection of all prime ideals is the radical of the zero ideal
              simp [radical_eq_iInf_prime]
            _ = ⊥ := by
              -- The radical of the zero ideal is zero in a reduced ring
              simp [h₄.radical_bot]
        exact h₇
      exact h₅
    exact h₃
  calc
    ⨅ (m : Ideal R) (hm : IsMaximal m), m = ⨅ m : Ideal R, m.prime → m := h₁
    _ = ⊥ := h₂

end LeanProof
