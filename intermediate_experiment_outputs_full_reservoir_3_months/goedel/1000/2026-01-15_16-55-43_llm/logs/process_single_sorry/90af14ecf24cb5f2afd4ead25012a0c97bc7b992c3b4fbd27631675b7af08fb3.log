-- Goal: Show that the intersection of all maximal ideals in a finite commutative semiring R is zero.

have h_main : ⨅ (m : Ideal R) (hm : IsMaximal m), m = ⊥ := by sorry

-- Explanation:
-- 1. Since R is finite, every prime ideal is maximal.
-- 2. The nilradical (intersection of all prime ideals) is zero because R is reduced (no nonzero nilpotents in a finite semiring).
