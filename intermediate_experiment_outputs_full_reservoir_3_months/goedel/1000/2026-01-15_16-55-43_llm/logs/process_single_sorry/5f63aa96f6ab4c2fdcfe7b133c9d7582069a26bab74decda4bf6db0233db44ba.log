          omega
        have h₈ : Nat.sqrt (p - 1) ^ 2 ≤ p - 1 := Nat.sqrt_le' (p - 1)
        have h₉ : p - 1 < (Nat.sqrt (p - 1) + 1) ^ 2 := by
          have h₁₀ : (Nat.sqrt (p - 1) + 1) ^ 2 > p - 1 := by
