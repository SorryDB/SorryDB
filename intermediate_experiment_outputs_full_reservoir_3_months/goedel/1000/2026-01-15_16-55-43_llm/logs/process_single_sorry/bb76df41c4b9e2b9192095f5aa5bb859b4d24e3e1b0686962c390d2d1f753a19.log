theorem Functor.iso_preserve {α β : Type*} [C : Category α] [D : Category β]
    (F : Functor α β) {X Y : α} (f : C.Hom X Y) (hf : IsIso f) :
    IsIso (F.homF f) := by
  rw [iso_iff_isIso] at hf
  obtain ⟨⟨f, g, hg, hf⟩, rfl⟩ := hf
  use F.homF g
  simp only
  constructor
  · rw [← F.map_comp]
    rw [hg]
    rw [F.map_id]
  · rw [← F.map_comp]
    rw [hf]
    rw [F.map_id]

def g_set_left_action (α : Type*) [Group α] (β : Type*) :
  @Functor Unit (Set β) (Category.Monoid α) _ := by
  haveI := Inhabited.of_subtype (by infer_instance : Nonempty (Set β))
  refine' { F := fun _ => Subsingleton.elim _ (Set.univ : Set β), homF := fun _ => _, map_id := _, map_comp := _ }
