    ($ xs).finSupport = xs.toList.toFinset := by
  simp_all [finSupport_uniformSelectList]
  <;>
  (try simp_all [Vector.mem_toList])
  <;>
  (try aesop)
  <;>
  (try simp_all [Vector.mem_toList])

@[simp]
lemma probOutput_uniformSelectVector [DecidableEq α] (xs : Vector α (n + 1)) (x : α) :
    Pr[= x | $ xs] = xs.toList.count x / (n + 1) := by
