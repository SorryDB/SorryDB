@[simp]
lemma probEvent_uniformSelectVector (xs : Vector α (n + 1)) (p : α → Prop)
    [DecidablePred p] : Pr[p | $ xs] = xs.toList.countP p / (n + 1) := by
  simp_all [probEvent_uniformSelectList]
