@[simp] lemma evalDist_uniformSelectList (xs : List α) :
    evalDist ($ xs) = match xs with
    | [] => failure
    | x :: xs => (PMF.uniformSample (Fin xs.length.succ)).map (some (x :: xs)[·]) := by
  match xs with
  | [] => simp [uniformSelectList_nil]
  | x :: xs => by
    simp [uniformSelectList_cons]
    <;> rfl

@[simp] lemma support_uniformSelectList (xs : List α) :
    ($ xs).support = if xs.isEmpty then ∅ else {y | y ∈ (xs)} := by
  match xs with
  | [] =>
    simp [uniformSelectList_nil]
    <;> aesop
  | x :: xs =>
    simp [uniformSelectList_cons, Finset.mem_range, List.mem_cons, Fin.val_mk]
    <;> aesop

@[simp] lemma finSupport_uniformSelectList [DecidableEq α] (xs : List α) :
    ($ xs).finSupport = if xs.isEmpty then ∅ else xs.toFinset := by
  match xs with
  | [] => simp
  | x :: xs =>
    simp_all [uniformSelectList_cons, Finset.mem_range, List.mem_cons, Fin.val_mk]
    <;> aesop

@[simp] lemma probOutput_uniformSelectList [DecidableEq α] (xs : List α) (x : α) :
    Pr[= x | $ xs] = if xs.isEmpty then 0 else (xs.count x : ℝ≥0∞) / xs.length := by
  match xs with
  | [] =>
    simp [uniformSelectList_nil]
    <;> aesop
  | x :: xs =>
    simp [uniformSelectList_cons, Finset.mem_range, List.mem_cons, Fin.val_mk]
    <;> aesop

@[simp] lemma probFailure_uniformSelectList (xs : List α) :
    Pr[⊥ | $ xs] = if xs.isEmpty then 1 else 0 := by
  match xs with
  | [] =>
    simp [uniformSelectList_nil]
    <;> aesop
  | x :: xs =>
    simp [uniformSelectList_cons, Finset.mem_range, List.mem_cons, Fin.val_mk]
    <;> aesop

@[simp] lemma probEvent_uniformSelectList (xs : List α) (p : α → Prop) [DecidablePred p] :
    Pr[p | $ xs] = if xs.isEmpty then 0 else (xs.countP p : ℝ≥0∞) / xs.length := by
  match xs with
  | [] =>
    simp [uniformSelectList_nil]
    <;> aesop
  | x :: xs =>
    simp [uniformSelectList_cons, Finset.mem_range, List.mem_cons, Fin.val_mk]
    <;> aesop

end uniformSelectList

