          (y_val * y_val % p = (x_val * x_val + 1 + d * x_val * x_val * y_val * y_val) % p) ∧

          y_val % p = y_encoded % p ∧

          (x_sign_bit ↔ x_is_neg.val = 1#u8) ∧

          (Field51_as_Nat ep.T % p = (Field51_as_Nat ep.X * Field51_as_Nat ep.Y) % p))) := by
