    ∃ result, edwards.CompressedEdwardsY.decompress cey = ok result ∧

      (∀ ep, result = some ep →
        let y_encoded := (U8x32_as_Nat cey) % (2^255)
        let x_sign_bit := cey[31]!.val.testBit 7

        (∃ Z_inv x_val y_val x_is_neg,
