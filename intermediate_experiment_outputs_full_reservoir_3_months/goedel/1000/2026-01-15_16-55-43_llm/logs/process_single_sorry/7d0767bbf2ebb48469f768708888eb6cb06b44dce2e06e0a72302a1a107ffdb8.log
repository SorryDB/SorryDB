theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  have h₁ : ∃ (f : α →* β), F.homF (X := ()) (Y := ()) = f := by
    -- We need to construct a group homomorphism from α to β.
    -- The given F is a monoid homomorphism from Unit to Unit,
    -- but since α and β are groups, it behaves as a group homomorphism.
    have h₂ : (F : α → β) (1 : α) = (1 : β) := by
      -- Prove that F(1) = 1 in β.
      have h₃ : F.map_id (0 : Unit) = F.map_id (0 : Unit) := rfl
      simp [F.map_id] at h₃ ⊢
      <;>
