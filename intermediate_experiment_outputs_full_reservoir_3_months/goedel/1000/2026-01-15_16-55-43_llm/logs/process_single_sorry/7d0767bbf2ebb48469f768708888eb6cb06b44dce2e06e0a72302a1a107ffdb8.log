            <;>
            aesop
          })
        map_mul' := by
          -- Prove that F(ab) = F(a)F(b).
          intro a b
          have h₄ : F.map_comp (Unit.unit : Unit) (Unit.unit : Unit) (Unit.unit : Unit) (1 : Unit) (1 : Unit) = F.map_comp (Unit.unit : Unit) (Unit.unit : Unit) (Unit.unit : Unit) (1 : Unit) (1 : Unit) := rfl
          simp [F.map_comp] at h₄ ⊢
          <;>
          (try norm_num at h₄ ⊢) <;>
          (try simp_all [MonoidHom.map_mul]) <;>
          (try norm_num) <;>
