        <;>
        norm_num
        <;>
        simp_all [MonoidHom.map_one]
        <;>
        aesop
      })
    -- Now, we can define the group homomorphism using the given F.
    have h₃ : ∃ (f : α →* β), F = f := by
      use {
        toFun := (F : α → β)
        map_one' := by
          -- Prove that F(1) = 1 in β.
          have h₄ : F.map_id (0 : Unit) = F.map_id (0 : Unit) := rfl
          simp [F.map_id] at h₄ ⊢
          <;>
          (try norm_num at h₄ ⊢) <;>
          (try simp_all [MonoidHom.map_one]) <;>
