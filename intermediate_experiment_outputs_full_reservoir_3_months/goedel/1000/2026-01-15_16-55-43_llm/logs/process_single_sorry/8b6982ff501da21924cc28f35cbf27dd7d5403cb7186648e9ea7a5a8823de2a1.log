                      ‖T (f₁ + f₂ + f₃) x + T f₄ x‖ₑ ≤ ‖T (f₁ + f₂ + f₃) x‖ₑ + ‖T f₄ x‖ₑ := norm_add_le _ _
                      _ = ‖T (f₁ + f₂ + f₃) x‖ₑ + ‖T f₄ x‖ₑ := by rfl
                  exact h₃
                _ = ‖T (f₁ + f₂ + f₃) x‖ₑ + ‖T f₄ x‖ₑ := by rfl
            have h₃ : ‖T (f₁ + f₂ + f₃) x‖ₑ ≤ ‖T (f₁ + f₂) x + T f₃ x‖ₑ := by
              -- Use the subadditivity property T_subadd
              have h₄ : ‖T (f₁ + f₂ + f₃) x‖ₑ ≤ ‖T (f₁ + f₂) x + T f₃ x‖ₑ := by
                calc
                  ‖T (f₁ + f₂ + f₃) x‖ₑ = ‖T (f₁ + f₂) x + T f₃ x‖ₑ := by
                    have h₅ : T (f₁ + f₂ + f₃) = T ((f₁ + f₂) + f₃) := by
                      ext y
                      <;> simp [add_assoc]
                      <;> ring_nf
                    rw [h₅]
                    have h₆ : T ((f₁ + f₂) + f₃) x = T (f₁ + f₂) x + T f₃ x := by
                      have h₇ := T_subadd (f₁ + f₂) f₃ x
                      have h₈ : (MemLorentz (f₁ + f₂) p 1 μ) := by
                        -- Show that (f₁ + f₂) is in Lorentz space
                        have h₉ : MemLorentz f₁ p 1 μ := hf₁
                        have h₁₀ : MemLorentz f₂ p 1 μ := hf₂
                        -- Sum of functions in Lorentz space
                        exact hf₁.add hf₂
                      have h₉ : (MemLorentz f₃ p 1 μ) := hf₃
                      -- Use the subadditivity property
                      have h₁₀ := h₇ h₈ h₉
                      simp_all [norm_add_le]
                      <;> linarith
                    rw [h₆]
                  _ ≤ ‖T (f₁ + f₂) x + T f₃ x‖ₑ := le_refl _
              exact h₄
            have h₄ : ‖T (f₁ + f₂) x + T f₃ x‖ₑ ≤ ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := by
              -- Use the triangle inequality for norms
              calc
                ‖T (f₁ + f₂) x + T f₃ x‖ₑ ≤ ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := by
                  -- Apply the triangle inequality
                  have h₅ : ‖T (f₁ + f₂) x + T f₃ x‖ₑ ≤ ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := by
                    calc
                      ‖T (f₁ + f₂) x + T f₃ x‖ₑ ≤ ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := norm_add_le _ _
                      _ = ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := by rfl
                  exact h₅
                _ = ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ := by rfl
            have h₅ : ‖T (f₁ + f₂) x‖ₑ ≤ ‖T f₁ x + T f₂ x‖ₑ := by
              -- Use the subadditivity property T_subadd
              have h₆ : ‖T (f₁ + f₂) x‖ₑ ≤ ‖T f₁ x + T f₂ x‖ₑ := by
                calc
                  ‖T (f₁ + f₂) x‖ₑ = ‖T f₁ x + T f₂ x‖ₑ := by
                    have h₇ := T_subadd f₁ f₂ x hf₁ hf₂
                    have h₈ := h₇
                    have h₉ : T (f₁ + f₂) x = T f₁ x + T f₂ x := by
                      have h₁₀ := h₈
                      simp_all [norm_add_le]
                      <;> linarith
                    rw [h₉]
                  _ ≤ ‖T f₁ x + T f₂ x‖ₑ := le_refl _
              exact h₆
            have h₆ : ‖T f₁ x + T f₂ x‖ₑ ≤ ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := by
              -- Use the triangle inequality for norms
              calc
                ‖T f₁ x + T f₂ x‖ₑ ≤ ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := by
                  -- Apply the triangle inequality
                  have h₇ : ‖T f₁ x + T f₂ x‖ₑ ≤ ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := by
                    calc
                      ‖T f₁ x + T f₂ x‖ₑ ≤ ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := norm_add_le _ _
                      _ = ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := by rfl
                  exact h₇
                _ = ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ := by rfl
            -- Combine all the inequalities
            calc
              ‖T (f₁ + f₂ + f₃ + f₄) x‖ₑ ≤ ‖T (f₁ + f₂ + f₃) x‖ₑ + ‖T f₄ x‖ₑ := by
                linarith
              _ ≤ ‖T (f₁ + f₂) x + T f₃ x‖ₑ + ‖T f₄ x‖ₑ := by
                linarith
              _ ≤ ‖T (f₁ + f₂) x‖ₑ + ‖T f₃ x‖ₑ + ‖T f₄ x‖ₑ := by
                linarith
              _ ≤ ‖T f₁ x + T f₂ x‖ₑ + ‖T f₃ x‖ₑ + ‖T f₄ x‖ₑ := by
                linarith
              _ ≤ ‖T f₁ x‖ₑ + ‖T f₂ x‖ₑ + ‖T f₃ x‖ₑ + ‖T f₄ x‖ₑ := by
                linarith
          -- Use the subadditivity property to bound the norm of the sum
          have h₂ : ‖T (1 • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₁ + -1 • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₂ +
            RCLike.I • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₃ + -RCLike.I • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₄) x‖ₑ ≤
            ‖T (1 • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₁) x‖ₑ + ‖T (-1 • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₂) x‖ₑ +
              ‖T (RCLike.I • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₃) x‖ₑ + ‖T (-RCLike.I • ⇑(algebraMap ℝ 𝕂) ∘ NNReal.toReal ∘ g₄) x‖ₑ := by
