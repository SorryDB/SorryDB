      apply isOrthogonalProjection_iff_closure_of_range_add_closure_of_orthogonal_eq_top.mpr
      constructor
      · -- Show that the range is closed
        apply continuousLinearMap_ofBilin_closed_range
      · -- Show that the range and orthogonal complement sum to the whole space
        have h₂ : ContinuousLinearMap.range (innerProductSpace.continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (Set.indicator s (1 : (spectrum ℂ a) → ℂ)))) = ⊤ := by
          apply le_antisymm
          · -- Show that the range is a subspace of the whole space
            exact le_top
          · -- Show that the whole space is a subspace of the range
            intro x _
            use x
            <;>
