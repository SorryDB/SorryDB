    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h₁ : (K ◁ x) ◁ K = x := K.call x K
      have h₂ : (K ◁ y) ◁ K = y := K.call y K
      have h₃ : (K ◁ x) ◁ K = x := by simpa using h₁
      have h₄ : (K ◁ y) ◁ K = y := by simpa using h₂
      calc
        x = (K ◁ x) ◁ K := by rw [h₃]
        _ = (K ◁ y) ◁ K := by rw [kestrel_application]
        _ = y := by rw [h₄]

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ◁ x`,
