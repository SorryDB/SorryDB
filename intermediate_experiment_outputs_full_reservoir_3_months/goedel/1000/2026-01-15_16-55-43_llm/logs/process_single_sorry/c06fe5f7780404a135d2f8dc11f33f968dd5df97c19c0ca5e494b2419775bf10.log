        have h₈ : (K ◁ x) = K := by
          have h₉ : (K ◁ x) ◁ K = x := by simpa using h₇
          have h₁₀ : (K ◁ x) ◁ K = x := by simpa using h₉
          have h₁₁ : (K ◁ x) ◁ K = x := by simpa using h₁₀
          have h₁₂ : (K ◁ x) = K := by
            have h₁₃ : (K ◁ K) = K := kestrel_egocentric
            have h₁₄ : (K ◁ x) ◁ K = x := by simpa using h₁₁
            have h₁₅ : (K ◁ x) = K := by
              have h₁₆ := K.call x K
