```lean
def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -∞ = ∞
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - a₁*x - a₃)
    MordellWeilGroup.mk_point E x (-y - E.val.a₁*x - E.val.a₃) 
      (let W := E.val;
       calc
         (-y - E.val.a₁*x - E.val.a₃)^2 + W.a₁*x*(-y - E.val.a₁*x - E.val.a₃) + W.a₃*(-y - E.val.a₁*x - E.val.a₃)
           = (-y - W.a₁*x - W.a₃)^2 + W.a₁*x*(-y - W.a₁*x - W.a₃) + W.a₃*(-y - W.a₁*x - W.a₃) := by rfl
         _ = y^2 + W.a₁*x*y + W.a₃*y := by
           ring_nf
           <;>
           simp [add_assoc, add_comm, add_left_comm, mul_comm, mul_assoc, mul_left_comm]
           <;>
           ring_nf
           <;>
           simp_all [sub_eq_add_neg]
           <;>
           ring_nf
         _ = x^3 + W.a₂*x^2 + W.a₄*x + W.a₆ := by
           have h₁ : y^2 + W.a₁*x*y + W.a₃*y = x^3 + W.a₂*x^2 + W.a₄*x + W.a₆ := by
             exact P.on_curve x y rfl
           linarith
      )
```

