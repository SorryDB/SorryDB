lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  have h5 : ∀ (x : U), x ∈ A \ {a} → f x ∈ B \ {b} := by
    intro x hx
    have hx₁ : x ∈ A := by
      simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
      exact hx.1
    have hx₂ : x ≠ a := by
      simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
      tauto
    have h6 : f x ∈ B := by
      have h7 : f x ∈ image f A := by
        exact Set.mem_image_of_mem f hx₁
      rw [h2] at h7
      exact h7
    have h7 : f x ≠ b := by
      intro h8
      have h9 : f x = b := h8
      have h10 : f a = b := h4
      have h11 : x ∈ A := hx₁
      have h12 : a ∈ A := h3
      have h13 : f x = f a := by rw [h9, h10]
      have h14 : x = a := h1 h11 h12 h13
      contradiction
    exact ⟨h6, h7⟩
  
  have h6 : Set.InjOn f A := by
    intro x hx y hy hxy
    exact h1 hx hy hxy
  
  have h7 : Set.InjOn (fun x : ↑(A \ {a}) => f x.val) (Set.univ : Set (↑(A \ {a}))) := by
    intro x _ y _ h
    have h₁ : f x.val = f y.val := h
    have h₂ : x.val ∈ A := by
      have h₃ : x.val ∈ A \ {a} := x.prop
      simp only [Set.mem_diff, Set.mem_singleton_iff] at h₃ ⊢
      exact h₃.1
    have h₃ : y.val ∈ A := by
      have h₄ : y.val ∈ A \ {a} := y.prop
      simp only [Set.mem_diff, Set.mem_singleton_iff] at h₄ ⊢
      exact h₄.1
    have h₄ : x.val = y.val := by
      apply h6
      · exact h₂
      · exact h₃
      · exact h₁
    have h₅ : x = y := by
      cases x
      cases y
      simp_all [Subtype.ext_iff]
      <;> aesop
    exact h₅
  
