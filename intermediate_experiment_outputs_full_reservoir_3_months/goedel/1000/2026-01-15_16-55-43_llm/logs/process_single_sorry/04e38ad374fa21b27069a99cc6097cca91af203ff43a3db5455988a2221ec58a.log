example {A B : Islander} (hAB : A said (A.isKnave or B.isKnave)) : A.isKnight and B.isKnave := by
 骑士_or_骗子 A with hA hA
  · -- Case: A is a knight
    have h := knight_said hAB hA
    cases h with
    | inl hA' =>
      -- Subcase: A is a knave (which contradicts hA : A is a knight)
      exfalso
      exact (not_isKnight_and_isKnave A ⟨hA, hA'⟩).elim
    | inr hB =>
      -- Subcase: B is a knave
      exact ⟨hA, hB⟩
  · -- Case: A is a knave
    have h := knave_said hAB hA
    -- Since A is a knave, the statement A said (A.isKnave or B.isKnave) is false
    -- Therefore, ¬(A.isKnave or B.isKnave) holds, which implies neither A nor B is a knave
    -- But we already know A is a knave, leading to a contradiction
    exfalso
    apply h
    apply Or.inl
    exact hA
```
