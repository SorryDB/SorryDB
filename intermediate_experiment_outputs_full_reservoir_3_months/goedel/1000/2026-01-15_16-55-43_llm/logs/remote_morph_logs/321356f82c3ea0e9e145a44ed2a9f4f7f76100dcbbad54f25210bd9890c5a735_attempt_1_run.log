### Complete Lean 4 Proof

```lean
def RequestArray._insert : RequestArray → Request → Array (Option (Request))
  | arr, req =>
    let vals' := growArray arr.val (req.id.toNat + 1)
    let i := req.id.toNat.toUSize
    if h : i.toNat < vals'.size
    then vals'.uset i (some req) h
    else if h: (Nat.beq i.toNat vals'.size) then
      let hless : i.toNat < vals'.size + 1 := by
        {apply Nat.lt_of_succ_le
         apply Nat.le_of_eq
         rw [Nat.succ_eq_add_one]
         rw [Nat.beq_eq] at h
         rw [h]
         }
      let idfin := Fin.mk i.toNat hless
      vals'.insertIdx idfin (some req)
    else unreachable!

-- can't be proving these things right now
theorem RequestArrayInsertConsistent (arr : RequestArray) (req : Request) :
  valConsistent (arr._insert req) = true := by
  dsimp [valConsistent, RequestArray._insert, growArray] at *
  <;> simp_all [List.all_cons, List.all_nil, Option.isSome, Option.isNone]
  <;> try norm_num
  <;> try aesop
  <;> try {
    simp_all [Finset.mem_filter, Finset.mem_range]
    <;> norm_num
    <;> omega
  }
