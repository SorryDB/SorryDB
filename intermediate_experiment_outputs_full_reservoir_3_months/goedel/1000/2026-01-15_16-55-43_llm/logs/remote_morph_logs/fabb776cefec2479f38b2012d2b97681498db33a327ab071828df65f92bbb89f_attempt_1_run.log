theorem Φ₃_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₃ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₃_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h₁ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
    have h₂ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn
    have h₃ : IsBoundedUnder (· ≤ ·) (Ioc (0 : ℝ) 1) (fun x => |Φ₃ r x|) := by
      -- Prove that |Φ₃ r| is bounded on (0, 1]
      have h₄ : ∃ (M : ℝ), ∀ x ∈ Ioc (0 : ℝ) 1, |Φ₃ r x| ≤ M := by
        -- Use the fact that Φ₃ r is continuous on [0, 1] and hence bounded
        have h₅ : ContinuousOn (fun x => |Φ₃ r x|) (Icc 0 1) := by
          apply ContinuousOn.abs
          exact Φ₃_contDiffOn.continuousOn.mono (by
            intro x hx
            simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢
            constructor <;> linarith)
        -- Use the fact that a continuous function on a closed interval is bounded
        have h₆ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc
        have h₇ : ∃ (M : ℝ), ∀ x ∈ Icc (0 : ℝ) 1, |Φ₃ r x| ≤ M := by
          -- Extract the bound from the compactness
          have h₈ : ∃ (M : ℝ), ∀ x ∈ Icc (0 : ℝ) 1, |Φ₃ r x| ≤ M := by
            classical
            -- Use the extreme value theorem to find the maximum of |Φ₃ r| on [0, 1]
            have h₉ : ∃ (M : ℝ), IsLUB (Set.range (fun x : Icc (0 : ℝ) 1 => |Φ₃ r x|)) M := by
              use sSup (Set.range (fun x : Icc (0 : ℝ) 1 => |Φ₃ r x|))
              exact ⟨by
                -- Prove that the supremum is an upper bound
                intro y hy
                exact le_csSup (by
                  -- Prove that the set is bounded above
                  have h₁₀ : BddAbove (Set.range (fun x : Icc (0 : ℝ) 1 => |Φ₃ r x|)) := by
                    -- Use the fact that the function is continuous on a compact set
                    have h₁₁ : ContinuousOn (fun x : Icc (0 : ℝ) 1 => (|Φ₃ r x| : ℝ)) (Set.univ : Set (Icc (0 : ℝ) 1)) := by
                      apply ContinuousOn.abs
                      exact (Φ₃_contDiffOn.continuousOn.mono (by
                        intro x hx
                        simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢
                        constructor <;> linarith)).comp (continuousOn_id)
                    exact IsCompact.bddAbove_image (isCompact_univ : IsCompact (Set.univ : Set (Icc (0 : ℝ) 1))) h₁₁
                  exact h₁₀) hy,
                  by
                  -- Prove that the set is nonempty
                  exact Set.nonempty_range_iff.mpr ⟨⟨0, by norm_num⟩⟩
                ⟩
            obtain ⟨M, hM⟩ := h₉
            use M
            intro x hx
            have h₁₀ : (|Φ₃ r x| : ℝ) ∈ Set.range (fun x : Icc (0 : ℝ) 1 => |Φ₃ r x|) := by
              use ⟨x.1, by
                simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢
                exact ⟨by linarith, by linarith⟩⟩
              <;> simp_all [Icc]
              <;> norm_num
              <;> linarith
            have h₁₁ : (|Φ₃ r x| : ℝ) ≤ M := by
              have h₁₂ : IsLUB (Set.range (fun x : Icc (0 : ℝ) 1 => |Φ₃ r x|)) M := hM
              exact h₁₂.1 h₁₀
            exact h₁₁
          exact h₈
        obtain ⟨M, hM⟩ := h₇
        refine' ⟨M, _⟩
        intro x hx
        have h₉ : x ∈ Icc (0 : ℝ) 1 := by
          simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢
          exact ⟨by linarith, by linarith⟩
        have h₁₀ : |Φ₃ r x| ≤ M := hM x h₉
        exact h₁₀
      obtain ⟨M, hM⟩ := h₄
      refine' ⟨M, _⟩
      intro x hx y hy hxy
      have h₅ : |Φ₃ r x| ≤ M := hM x hx
      have h₆ : |Φ₃ r y| ≤ M := hM y hy
      linarith
    -- Use the fact that a bounded continuous function on a compact interval is integrable
    have h₄ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
      have h₅ : (Ioc (0 : ℝ) 1 : Set ℝ).Compact := by
        -- Prove that (0, 1] is compact
        have h₆ : IsClosed (Icc (0 : ℝ) 1) := isClosed_Icc
        have h₇ : (Ioc (0 : ℝ) 1 : Set ℝ) = Icc (0 : ℝ) 1 \ {0} := by
          ext x
          simp only [Ioc, Icc, Set.mem_setOf_eq, Set.mem_diff, Set.mem_singleton_iff]
          <;>
          by_cases hx : x = 0 <;>
          simp_all [hx] <;>
          (try { nlinarith }) <;>
          (try { linarith }) <;>
          (try { exact ⟨by linarith, by linarith⟩ })
          <;>
          (try { aesop })
        rw [h₇]
        apply IsClosed.sdiff
        · exact h₆
        · exact isClosed_singleton
      -- Use the fact that a continuous function on a compact set is integrable
      have h₆ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn
      have h₇ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
        apply ContinuousOn.hasFiniteIntegral
        <;> aesop
      exact h₇
    exact h₄
  -- Use the fact that a function with a finite integral is integrable
  have h₂ : IntegrableOn (Φ₃ r) (Ioc (0 : ℝ) 1) volume := by
    exact h₁.integrableOn
  exact h₂
