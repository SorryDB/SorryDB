theorem support_semicirclePDF {μ : ℝ} {v : ℝ≥0} (hv : v ≠ 0) :
    Function.support (semicirclePDF μ v) = Ioo (μ - 2 * √v) (μ + 2 * √v) := by
  have h₁ : Function.support (semicirclePDF μ v) = {x : ℝ | |x - μ| < 2 * √v} := by
    apply Set.ext
    intro x
    simp only [Set.mem_setOf_eq, Set.mem_support_iff, semicirclePDF, Real.sqrt_eq_iff_sq_eq,
      mul_comm]
    constructor
    · -- Prove the forward direction: if semicirclePDF μ v x ≠ 0, then |x - μ| < 2 * √v
      intro h
      by_cases h₂ : (x - μ) ^ 2 < 4 * v
      · -- Case: (x - μ) ^ 2 < 4 * v
        have h₃ : |x - μ| < 2 * √v := by
          have h₄ : 0 ≤ (x - μ) ^ 2 := by nlinarith
          have h₅ : 0 ≤ 4 * v := by
            have h₅₁ : (v : ℝ) ≥ 0 := by exact_mod_cast v.property
            positivity
          have h₆ : 0 ≤ Real.sqrt v := Real.sqrt_nonneg v
          have h₇ : 0 ≤ 2 * Real.sqrt v := by positivity
          have h₈ : (2 * Real.sqrt v) ^ 2 = 4 * v := by
            nlinarith [Real.sq_sqrt (by positivity : 0 ≤ (v : ℝ))]
          have h₉ : |x - μ| < 2 * Real.sqrt v := by
            rw [abs_lt]
            constructor <;> nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : 0 ≤ (v : ℝ)),
              sq_nonneg (x - μ - 2 * Real.sqrt v), sq_nonneg (x - μ + 2 * Real.sqrt v)]
          exact h₉
        exact h₃
      · -- Case: (x - μ) ^ 2 ≥ 4 * v
        have h₃ : (x - μ) ^ 2 ≥ 4 * v := by
          by_contra h₄
          have h₅ : (x - μ) ^ 2 < 4 * v := by linarith
          contradiction
        have h₄ : Real.sqrt (4 * v - (x - μ) ^ 2) = 0 := by
          have h₅ : 4 * v - (x - μ) ^ 2 ≤ 0 := by
            have h₅₁ : (x - μ) ^ 2 ≥ 4 * v := by linarith
            linarith
          have h₆ : Real.sqrt (4 * v - (x - μ) ^ 2) = 0 := by
            rw [Real.sqrt_eq_zero_of_nonpos] <;> linarith
          exact h₆
        have h₅ : (1 : ℝ) / (2 * π * v) * Real.sqrt (4 * v - (x - μ) ^ 2) = 0 := by
          rw [h₄]
          <;> simp [mul_zero]
        simp_all [h₅, Real.sqrt_eq_zero_of_nonpos, le_of_lt]
        <;>
        (try norm_num) <;>
        (try linarith) <;>
        (try nlinarith) <;>
        (try ring_nf at * <;> nlinarith)
    · -- Prove the reverse direction: if |x - μ| < 2 * √v, then semicirclePDF μ v x ≠ 0
      intro h
      have h₂ : (x - μ) ^ 2 < 4 * v := by
        have h₃ : |x - μ| < 2 * √v := h
        have h₄ : - (2 * √v) < x - μ := by
          linarith [abs_lt.mp h₃]
        have h₅ : x - μ < 2 * √v := by
          linarith [abs_lt.mp h₃]
        have h₆ : (x - μ) ^ 2 < 4 * v := by
          have h₇ : 0 ≤ Real.sqrt v := Real.sqrt_nonneg v
          have h₈ : 0 ≤ 2 * Real.sqrt v := by positivity
          have h₉ : (2 * Real.sqrt v) ^ 2 = 4 * v := by
            nlinarith [Real.sq_sqrt (by positivity : 0 ≤ (v : ℝ))]
          nlinarith [Real.sqrt_nonneg v, Real.sq_sqrt (by positivity : 0 ≤ (v : ℝ)),
            sq_nonneg (x - μ - 2 * Real.sqrt v), sq_nonneg (x - μ + 2 * Real.sqrt v)]
        exact h₆
      have h₃ : Real.sqrt (4 * v - (x - μ) ^ 2) > 0 := by
        apply Real.sqrt_pos_of_pos
        have h₄ : (x - μ) ^ 2 < 4 * v := h₂
        have h₅ : 0 < 4 * v - (x - μ) ^ 2 := by linarith
        linarith
      have h₄ : (1 : ℝ) / (2 * π * v) * Real.sqrt (4 * v - (x - μ) ^ 2) > 0 := by
        have h₅ : (1 : ℝ) / (2 * π * v) > 0 := by
          have h₅₁ : (v : ℝ) > 0 := by
            have h₅₂ : (v : ℝ) ≥ 0 := by exact_mod_cast v.property
            have h₅₃ : (v : ℝ) ≠ 0 := by exact_mod_cast hv
            contrapose! h₅₃
            linarith
          positivity
        have h₆ : Real.sqrt (4 * v - (x - μ) ^ 2) > 0 := h₃
        positivity
      simp_all [h₄, Real.sqrt_eq_zero_of_nonpos, le_of_lt]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try nlinarith) <;>
      (try ring_nf at * <;> nlinarith)
  
  have h₂ : {x : ℝ | |x - μ| < 2 * √v} = Ioo (μ - 2 * √v) (μ + 2 * √v) := by
    apply Set.ext
    intro x
    simp only [Set.mem_setOf_eq, Set.mem_Ioo]
    constructor
    · -- Prove the forward direction: if |x - μ| < 2 * √v, then x ∈ (μ - 2 * √v, μ + 2 * √v)
      intro h
      have h₁ : - (2 * √v) < x - μ := by
        linarith [abs_lt.mp h]
      have h₂ : x - μ < 2 * √v := by
        linarith [abs_lt.mp h]
      constructor <;> linarith
    · -- Prove the reverse direction: if x ∈ (μ - 2 * √v, μ + 2 * √v), then |x - μ| < 2 * √v
      intro h
      have h₁ : μ - 2 * √v < x := h.1
      have h₂ : x < μ + 2 * √v := h.2
      have h₃ : - (2 * √v) < x - μ := by linarith
      have h₄ : x - μ < 2 * √v := by linarith
      have h₅ : |x - μ| < 2 * √v := by
        rw [abs_lt]
        exact ⟨h₃, h₄⟩
      exact h₅
  
  have h₃ : Function.support (semicirclePDF μ v) = Ioo (μ - 2 * √v) (μ + 2 * √v) := by
    rw [h₁]
    rw [h₂]
    <;>
    simp_all
    <;>
    aesop
  
  rw [h₃]
  <;>
  aesop
