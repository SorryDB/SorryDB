theorem isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  have h_main : IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
    rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
    constructor
    · -- Prove that the family of submodules is `iSupIndep`
      exact I.sSupIndep'.comp c
    · -- Prove that the `iSup` of the family of submodules is `⊤`
      have h : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
      have h₁ : ⨆ p : I, p.val c = ⊤ := by
        have h₂ : ⨆ p : I, p.val c = (⨆ p : I, p.val c) := rfl
        rw [h₂]
        have h₃ : ⨆ p : I, p.val c = ⊤ := by
          have h₄ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
          have h₅ : ⨆ p : I, p.val c = ⊤ := by
            have h₆ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
            have h₇ : ⨆ p : I, p.val c = ⊤ := by
              -- Use the fact that the supremum of the submodules is the top element
              have h₈ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
              have h₉ : ⨆ p : I, p.val c = ⊤ := by
                -- Use the fact that the supremum of the submodules is the top element
