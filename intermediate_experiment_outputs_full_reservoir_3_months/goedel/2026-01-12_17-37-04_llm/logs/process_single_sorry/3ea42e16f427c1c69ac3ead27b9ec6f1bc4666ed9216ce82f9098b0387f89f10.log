```lean4
theorem le_induction {P : Nat → Prop} {m}
    (h0 : P m) (h1 : ∀ n, m ≤ n → P n → P (n + 1)) :
    ∀ n, m ≤ n → P n := by
  have h_main : ∀ n, m ≤ n → P n := by
    intro n hn
    -- Use the `Nat.le.rec` function to perform the induction.
    have h₂ : ∀ n, m ≤ n → P n := by
      intro n hn
      -- Use the `Nat.le.rec` function to perform the induction.
      induction' hn with n hn IH
      · -- Base case: n = m
        simpa using h0
      · -- Inductive step: assume P n holds, prove P (n + 1)
        have h₃ : m ≤ n + 1 := by
          omega
        have h₄ : P (n + 1) := h1 n hn IH
        simpa using h₄
    exact h₂ n hn
  exact h_main
