lemma integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  have h_main : Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
    have h₁ : Integrable f (μ i) := hf
    have h₂ : ∀ i : Fin d, IsProbabilityMeasure (μ i) := by intro i; exact inferInstance
    -- Use the fact that the product measure is the product of the measures μ i
    -- and the function f is integrable with respect to μ i
    have h₃ : Integrable (fun a : Fin d → ℝ => f (a i)) (Measure.pi μ) := by
      -- Use the fact that the product measure is the product of the measures μ i
      -- and the function f is integrable with respect to μ i
      have h₄ : Integrable (fun a : Fin d → ℝ => f (a i)) (Measure.pi μ) := by
        -- Use the fact that the product measure is the product of the measures μ i
        -- and the function f is integrable with respect to μ i
        apply IntegralTheory.integrable_comp_mulMeasure
        <;> simp_all [h₂]
        <;> aesop
      exact h₄
    exact h₃
  exact h_main
