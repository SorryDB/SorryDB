```lean4
lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intro w args cs h
  have h₁ : (assert_bits_e args cs).eval = .n := by
    have h₂ : ¬ assert_bits args := h
    have h₃ : ∃ i, args.get i ≠ 0 ∧ args.get i ≠ 1 := by
      simp only [assert_bits, Vector.all_eq_true, not_forall, not_and, not_not, exists_prop] at h₂
      rcases h₂ with ⟨i, hi⟩
      refine' ⟨i, _⟩
      simp_all [Vector.get]
      <;> aesop
    -- Use the existence of an index i where args.get i ≠ 0 and args.get i ≠ 1 to show that the evaluation is n
    have h₄ : (assert_bits_e args cs).eval = .n := by
      -- Use the recursive definition of assert_bits_e to show that the evaluation is n
      have h₅ : ∀ (w : ℕ) (args : Vector (ZMod p) w) (cs : Cs p (ZMod p)),
        (∃ i, args.get i ≠ 0 ∧ args.get i ≠ 1) → (assert_bits_e args cs).eval = .n := by
        intro w args cs h₅
        induction w with
        | zero =>
          -- Base case: w = 0
          simp_all [Vector.get, assert_bits_e]
          <;> aesop
        | succ w ih =>
          -- Inductive step: assume the statement holds for w, prove for w + 1
          rcases h₅ with ⟨i, hi⟩
          -- Consider the cases for i
          by_cases h₆ : i = 0
          · -- Case i = 0
            simp_all [Vector.get, assert_bits_e, List.cons, List.nil, Nat.add_assoc]
            <;> aesop
          · -- Case i ≠ 0
            simp_all [Vector.get, assert_bits_e, List.cons, List.nil, Nat.add_assoc]
            <;> aesop
      -- Apply the result to our specific case
      exact h₅ w args cs h₃
    exact h₄
  exact h₁

lemma fail₂ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
    e.eval ≠ (bits2num args) -> (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
  intro w args e cs h
  have h₁ : (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
    have h₂ : e.eval ≠ bits2num args := h
    have h₃ : (bits2num_e args - e).eval ≠ 0 := by
      intro h₄
      have h₅ : (bits2num_e args - e).eval = 0 := h₄
      have h₆ : (bits2num_e args - e).eval = bits2num_e args.eval - e.eval := by
        simp [Exp.eval_sub]
      rw [h₆] at h₅
      have h₇ : bits2num_e args.eval = bits2num args := by
        simp [bits2num_e, bits2num, Vector.foldl]
        <;> rfl
      rw [h₇] at h₅
      apply h₂
      simp_all [sub_eq_zero]
    have h₄ : (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
      simp [Cs.eval, h₃]
      <;> aesop
    exact h₄
  exact h₁
