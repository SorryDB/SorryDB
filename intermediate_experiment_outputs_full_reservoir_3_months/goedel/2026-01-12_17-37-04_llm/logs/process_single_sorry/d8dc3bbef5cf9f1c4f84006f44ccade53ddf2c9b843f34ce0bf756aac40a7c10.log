          contradiction
      exact h₈
    have h₄ : C ∈ Knave ↔ B ∈ Knight := stCn
    have h₅ : B ∈ Knight := h₁
    have h₆ : C ∈ Knave := h₃
    have h₇ : C ∈ Knave := h₃
    have h₈ : B ∈ Knight := h₁
    -- We need to derive a contradiction
