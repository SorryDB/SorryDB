lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v; unfold vectorSpaceToInternalTangentSpace
  simp
  classical
  refine ⟨0, ?_⟩
  have hs : Subsingleton (InternalTangentSpace x) := by
    classical
    unfold InternalTangentSpace
    set R : Submodule ℝ (PreInternalTangentSpace x) := Submodule.span ℝ
      {v : PreInternalTangentSpace x | ∃ p q : pointedPlots x,
        ∃ f : DSmoothMap (Eucl p.1.1) (Eucl q.1.1), ∃ w : Eucl p.1.1,
          v = PreInternalTangentSpace.lof p w - PreInternalTangentSpace.lof q (fderiv ℝ f 0 w)} with hR
    rw [← hR]
    refine ⟨fun a b => ?_⟩
    have hy : ∀ y : PreInternalTangentSpace x, y ∈ R := by
      intro y
      refine DirectSum.induction_on y (by simpa using (zero_mem R))
        (fun y z hy hz => by simpa using add_mem hy hz) (fun p w => ?_)
      rw [hR]
      refine Submodule.subset_span ?_
      refine ⟨p, p, ⟨fun _ => (0 : Eucl p.1.1), dsmooth_const⟩, w, by simp⟩
    have hk : ∀ y : PreInternalTangentSpace x, (Submodule.mkQ R) y = 0 := by
      intro y
      exact (Submodule.mkQ_eq_zero R).2 (hy y)
    have hq : ∀ q : PreInternalTangentSpace x ⧸ R, q = 0 := by
      intro q
      rcases (Submodule.mkQ_surjective R) q with ⟨y, rfl⟩
      simpa using hk y
    simpa [hq a, hq b]
  haveI : Subsingleton (InternalTangentSpace x) := hs
  exact Subsingleton.elim _ _
