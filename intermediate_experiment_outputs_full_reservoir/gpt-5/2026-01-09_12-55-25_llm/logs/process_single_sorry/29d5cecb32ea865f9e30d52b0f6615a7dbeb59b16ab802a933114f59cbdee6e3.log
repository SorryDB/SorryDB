    theorem RelIO.liftFinf_in {S} {ident : InternalPort Nat} {n : Nat} {f : Fin n → RelIO S}:
      AssocList.contains ident (RelIO.liftFinf n f) = true
      → ∃ i : Fin n, ident = i := by
          intro h
          have h' := h
          simp [RelIO.liftFinf, AssocList.contains_eq, List.toList_toAssocList] at h'
          rcases (List.any_eq_true).1 h' with ⟨kv, hkv, hk⟩
          rcases (List.mem_map).1 hkv with ⟨i, _, rfl⟩
          have : ((↑i.toNat : InternalPort Nat) == ident) = true := by
            simpa using hk
          have hiEq : (↑i.toNat : InternalPort Nat) = ident := (beq_iff_eq).1 this
          refine ⟨i, ?_⟩
          simpa using hiEq.symm
```
